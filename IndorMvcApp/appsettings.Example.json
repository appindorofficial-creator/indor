{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=IndorDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;MultipleActiveResultSets=true;TrustServerCertificate=true;Encrypt=false"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "Version": "1"
  },
  "Diagnostics": {
    "ShowDetailedErrors": true
  },
  "OpenAiProperty": {
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "Model": "gpt-4o-mini",
    "ResearchModel": "gpt-4o",
    "SearchModel": "gpt-4o-search-preview",
    "UseChatGptSearchModelForResearch": true,
    "WebSearchContextSize": "medium",
    "FastModel": "gpt-4o-mini",
    "Enabled": true,
    "EnableWebSearch": true,
    "RestrictWebSearchDomains": false,
    "UseTwoStepPipeline": false,
    "SkipOrganizationWhenStructured": true,
    "UseQuickEnrichmentFirst": true,
    "DeferFullHouseFactResearch": true,
    "QuickEnrichmentMaxTokens": 2048,
    "QuickWebSearchTimeoutSeconds": 75,
    "DeferMaintenanceRecommendations": true,
    "EnableEnrichmentCache": true,
    "EnrichmentCacheHours": 168,
    "ResearchTemperature": 0,
    "OrganizationTemperature": 0,
    "EnrichmentMaxTokens": 8192,
    "OrganizationMaxTokens": 4096,
    "WebSearchTimeoutSeconds": 120,
    "MaintenanceMaxTokens": 4096,
    "InspectionMaxTokens": 8192,
    "InspectionParallelChunks": 3,
    "InspectionPagesPerChunk": 15
  },
  "Attom": {
    "BaseUrl": "https://api.gateway.attomdata.com/",
    "ApiKey": "YOUR_ATTOM_API_KEY",
    "Enabled": false
  },
  "GoogleMaps": {
    "BrowserApiKey": "YOUR_GOOGLE_MAPS_BROWSER_API_KEY",
    "ServerApiKey": "YOUR_GOOGLE_MAPS_SERVER_API_KEY",
    "DefaultLatitude": 35.2271,
    "DefaultLongitude": -80.8431
  },
  "Smtp": {
    "Enabled": true,
    "Host": "smtp.your-provider.com",
    "Port": 587,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD",
    "EnableSsl": true,
    "FromEmail": "no-reply@yourdomain.com",
    "FromName": "INDOR"
  },
  "Insurance": {
    "CarrierEmail": "carrier@example.com",
    "CarrierName": "Insurance Carrier",
    "CopyToEmail": "jeanna@carolinacoverageinsurance.com"
  },
  "Stripe": {
    "PublishableKey": "pk_test_YOUR_PUBLISHABLE_KEY",
    "SecretKey": "sk_test_YOUR_SECRET_KEY",
    "WebhookSecret": "whsec_YOUR_WEBHOOK_SECRET"
  }
}
