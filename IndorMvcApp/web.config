<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- 100 MB — large inspection PDFs (realtor upload wizard) -->
        <requestLimits maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>
    <!--
      Warms the app after an IIS app-pool recycle so users never hit a cold start
      (the ~10s blank screen on first open). Requires, on the server:
        - IIS feature "Application Initialization" installed.
        - App pool: Start Mode = AlwaysRunning, Idle Time-out (minutes) = 0.
        - Site advanced settings: Preload Enabled = True.
    -->
    <applicationInitialization doAppInitAfterRestart="true">
      <add initializationPage="/healthz" />
    </applicationInitialization>
  </system.webServer>
</configuration>
