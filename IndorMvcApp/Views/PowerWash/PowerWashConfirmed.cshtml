@model IndorMvcApp.ViewModels.PowerWashConfirmedViewModel
@{
    ViewData["Title"] = "Power Wash Request Confirmed - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_PowerWashStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.NombreServicio</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_PowerWashStepper", 4)

    <div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Power Wash Request Confirmed</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">Your exterior service request is ready. A pro will review your details and confirm your visit.</p>
    </div>

    <div class="summary-grid">
        <div class="summary-mini"><i class="fas fa-house"></i><div class="summary-label">Area</div><div class="summary-value">@Model.AreaLabel</div></div>
        <div class="summary-mini"><i class="fas fa-layer-group"></i><div class="summary-label">Material</div><div class="summary-value">@Model.MaterialLabel</div></div>
        <div class="summary-mini"><i class="fas fa-building"></i><div class="summary-label">Stories</div><div class="summary-value">@Model.StoriesLabel</div></div>
        <div class="summary-mini"><i class="fas fa-droplet"></i><div class="summary-label">Condition</div><div class="summary-value">@Model.ConditionLabel</div></div>
        <div class="summary-mini"><i class="fas fa-faucet"></i><div class="summary-label">Water access</div><div class="summary-value">@Model.WaterAccessLabel</div></div>
        <div class="summary-mini"><i class="fas fa-calendar"></i><div class="summary-label">Preferred time</div><div class="summary-value">@Model.PreferredTimeLabel</div></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.TipConfirmacionTexto))
    {
        <div class="tip-box">
            <i class="fas fa-lightbulb"></i>
            <span>Tip: @Model.TipConfirmacionTexto</span>
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn-primary">
        <i class="fas fa-house"></i> Back to Home Care Guide
    </a>

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-bell"></i> View my reminders
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-bell"></i> View my reminders
        </a>
    }
</div>
</body>
</html>
