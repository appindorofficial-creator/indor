@model IndorMvcApp.ViewModels.PowerWashServiceViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}


<h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@L.Catalog(Model.LandingTitulo)</h1>
    @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
    {
        <div class="tagline">@L.Catalog(Model.LandingTagline)</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@L.Catalog(Model.LandingTitulo)" class="hero-img" />
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTexto))
    {
        <div class="info-box-blue">
            <i class="fas fa-spray-can-sparkles"></i>
            <span>@L.Catalog(Model.InfoBoxTexto)</span>
        </div>
    }

    @if (Model.BestForItems.Count > 0)
    {
        <div class="includes-box">
            <div class="includes-label">@L["Best for"]</div>
            <div class="bestfor-grid">
                @foreach (var item in Model.BestForItems)
                {
                    <div class="bestfor-item"><i class="fas @item.Icon"></i><span>@L.Catalog(item.Text)</span></div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.PreviewTexto))
    {
        <div class="preview-box-pw">
            <i class="fas fa-clipboard-list"></i>
            <div>
                <strong>@L["We'll ask a few quick questions"]</strong>
                <p>@L.Catalog(Model.PreviewTexto)</p>
            </div>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="PowerWashService" method="post">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            @L.Catalog(Model.CtaTexto) <i class="fas fa-chevron-right"></i>
        </button>
    </form>
