@model IndorMvcApp.ViewModels.PowerWashConditionViewModel
@{
    ViewData["Title"] = L["Condition & Access - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("PowerWashDetails", "PowerWash", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;

}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Condition & Access"]</h1>
    <p class="page-lead" style="margin-bottom:16px;"><span class="tagline">@L["Help us understand buildup and access."]</span></p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="pw-condition-form" asp-action="PowerWashCondition" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="ProblemasSeleccionados" id="ProblemasSeleccionados" />
        <input type="hidden" asp-for="AreasDelicadas" id="AreasDelicadas" />
        <input type="hidden" asp-for="AccesoGrifo" id="AccesoGrifo" />
        <input type="hidden" asp-for="TimingPreferido" id="TimingPreferido" />
        <input type="hidden" asp-for="VentanaHorario" id="VentanaHorario" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-eye"></i><span>@L["What are you seeing?"]</span></div>
            <div class="issue-grid">
                <button type="button" class="issue-card" data-issue="LightDirt"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-house main"></i><span class="label">@L["Light dirt"]</span></button>
                <button type="button" class="issue-card" data-issue="HeavyDirt"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-house main"></i><span class="label">@L["Heavy dirt"]</span></button>
                <button type="button" class="issue-card" data-issue="MoldAlgae"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-leaf main"></i><span class="label">@L["Mold / algae"]</span></button>
                <button type="button" class="issue-card" data-issue="Pollen"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-tree main"></i><span class="label">@L["Pollen"]</span></button>
                <button type="button" class="issue-card" data-issue="RustStains"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-droplet main"></i><span class="label">@L["Rust stains"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-triangle-exclamation"></i><span>@L["Any delicate areas?"]</span></div>
            <div class="issue-grid" style="grid-template-columns:repeat(2,1fr);">
                <button type="button" class="issue-card" data-delicate="LoosePaint"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-paint-roller main"></i><span class="label">@L["Loose paint"]</span></button>
                <button type="button" class="issue-card" data-delicate="CrackedSiding"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-grip-lines main"></i><span class="label">@L["Cracked siding"]</span></button>
                <button type="button" class="issue-card" data-delicate="OldCaulking"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-spray-can main"></i><span class="label">@L["Old caulking"]</span></button>
                <button type="button" class="issue-card" data-delicate="None"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-shield-halved main"></i><span class="label">@L["None"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-faucet"></i><span>@L["Do you have water spigot access?"]</span></div>
            <div class="spigot-grid">
                <button type="button" class="spigot-card" data-spigot="Yes"><i class="fas fa-droplet main"></i><span class="label">@L["Yes"]</span></button>
                <button type="button" class="spigot-card" data-spigot="No"><i class="fas fa-ban main"></i><span class="label">@L["No"]</span></button>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><i class="fas fa-camera"></i><span>@L["Upload photos (optional)"]</span></div>
            <p class="field-hint" style="margin-top:0;margin-bottom:10px;">@L["Add up to 5 photos to help our pros prepare."]</p>
            <div class="upload-drop-wrap">
                <input type="file" name="files" id="photoInput" class="upload-input-hidden" multiple
                       accept="image/*,.jpg,.jpeg,.png,.webp,.heic,.heif" />
                <label class="upload-drop" id="photoDropzone" for="photoInput">
                    <i class="fas fa-camera"></i>
                    <strong>@L["Tap to upload photos"]</strong>
                    <span>@L["JPG or PNG, up to 10 MB each"]</span>
                </label>
            </div>
            <div class="upload-selected-list" id="photoSelectedList" hidden></div>
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="upload-selected-list" id="photoSavedList">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <div class="upload-selected-item">
                            <img class="upload-preview-thumb" src="@Url.Content($"~{file.RutaArchivo}")" alt="" loading="lazy" />
                            <span>@file.NombreArchivo</span>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-clock"></i><span>@L["Preferred timing"]</span></div>
            <div class="time-grid-3" style="margin-bottom:10px;">
                <button type="button" class="time-card" data-timing="NextWeek"><span class="radio"></span><i class="fas fa-calendar main"></i><span class="label">@L["Next week"]</span></button>
                <button type="button" class="time-card" data-timing="ThisMonth"><span class="radio"></span><i class="fas fa-calendar-days main"></i><span class="label">@L["This month"]</span></button>
                <button type="button" class="time-card" data-timing="Flexible"><span class="radio"></span><i class="fas fa-clock main"></i><span class="label">@L["Flexible"]</span></button>
            </div>
            <div class="field-head" style="margin-top:8px;"><i class="fas fa-sun"></i><span>@L["Preferred time window"]</span></div>
            <div class="time-grid-3">
                <button type="button" class="time-card" data-window="Morning"><span class="radio"></span><i class="fas fa-sun main"></i><span class="label">@L["Morning"]</span></button>
                <button type="button" class="time-card" data-window="Midday"><span class="radio"></span><i class="fas fa-sun main"></i><span class="label">@L["Midday"]</span></button>
                <button type="button" class="time-card" data-window="Afternoon"><span class="radio"></span><i class="fas fa-cloud-sun main"></i><span class="label">@L["Afternoon"]</span></button>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><i class="fas fa-note-sticky"></i><span>@L["Notes (optional)"]</span></div>
            <textarea asp-for="Notas" placeholder="@L["Add any details"]" maxlength="300"></textarea>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.InfoCondicionTexto))
        {
            <div class="info-box-blue">
                <i class="fas fa-shield-halved"></i>
                <span>@Model.InfoCondicionTexto</span>
            </div>
        }

        <button type="submit" name="action" value="continue" class="btn-primary">
            Review request <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        var issuesInput = document.getElementById('ProblemasSeleccionados');
        var delicateInput = document.getElementById('AreasDelicadas');
        var spigotInput = document.getElementById('AccesoGrifo');
        var timingInput = document.getElementById('TimingPreferido');
        var windowInput = document.getElementById('VentanaHorario');

        function getPipe(input) { return input.value ? input.value.split('|').filter(Boolean) : []; }
        function setPipe(input, values) { input.value = values.join('|'); }

        document.querySelectorAll('[data-issue]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var code = btn.getAttribute('data-issue');
                var current = getPipe(issuesInput);
                if (current.indexOf(code) >= 0) {
                    current = current.filter(function (v) { return v !== code; });
                    btn.classList.remove('active');
                } else {
                    current.push(code);
                    btn.classList.add('active');
                }
                setPipe(issuesInput, current);
            });
            if (getPipe(issuesInput).indexOf(btn.getAttribute('data-issue')) >= 0) btn.classList.add('active');
        });

        document.querySelectorAll('[data-delicate]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var code = btn.getAttribute('data-delicate');
                if (code === 'None') {
                    document.querySelectorAll('[data-delicate]').forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    setPipe(delicateInput, ['None']);
                    return;
                }
                var current = getPipe(delicateInput).filter(function (v) { return v !== 'None'; });
                if (current.indexOf(code) >= 0) {
                    current = current.filter(function (v) { return v !== code; });
                    btn.classList.remove('active');
                } else {
                    current.push(code);
                    btn.classList.add('active');
                }
                setPipe(delicateInput, current);
            });
            if (getPipe(delicateInput).indexOf(btn.getAttribute('data-delicate')) >= 0) btn.classList.add('active');
        });

        document.querySelectorAll('[data-spigot]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-spigot]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                spigotInput.value = btn.getAttribute('data-spigot');
            });
            if (btn.getAttribute('data-spigot') === spigotInput.value) btn.classList.add('active');
        });

        document.querySelectorAll('[data-timing]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-timing]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                timingInput.value = btn.getAttribute('data-timing');
            });
            if (btn.getAttribute('data-timing') === timingInput.value) btn.classList.add('active');
        });

        document.querySelectorAll('[data-window]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-window]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                windowInput.value = btn.getAttribute('data-window');
            });
            if (btn.getAttribute('data-window') === windowInput.value) btn.classList.add('active');
        });

        var photoInput = document.getElementById('photoInput');
        var photoDropzone = document.getElementById('photoDropzone');
        var photoSelectedList = document.getElementById('photoSelectedList');
        var maxPhotos = 5;
        var existingCount = @Model.ArchivosExistentes.Count;
        var pendingPhotos = [];

        function syncPhotoInputFiles() {
            if (!photoInput) return;
            var dt = new DataTransfer();
            pendingPhotos.slice(0, Math.max(0, maxPhotos - existingCount)).forEach(function (file) {
                dt.items.add(file);
            });
            photoInput.files = dt.files;
        }

        function mergePhotoFiles(newFiles) {
            Array.from(newFiles || []).forEach(function (file) {
                if (file && file.size > 0) {
                    pendingPhotos.push(file);
                }
            });
            var allowed = Math.max(0, maxPhotos - existingCount);
            if (pendingPhotos.length > allowed) {
                pendingPhotos = pendingPhotos.slice(0, allowed);
            }
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function removePendingPhoto(index) {
            pendingPhotos.splice(index, 1);
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function renderPhotoSelection(files) {
            if (!photoSelectedList || !photoDropzone) return;
            var list = Array.from(files || []).filter(function (f) { return f && f.size > 0; });
            photoSelectedList.innerHTML = '';
            if (list.length === 0) {
                photoSelectedList.hidden = true;
                photoDropzone.classList.remove('has-files');
                return;
            }
            photoDropzone.classList.add('has-files');
            photoSelectedList.hidden = false;
            list.forEach(function (file, index) {
                var row = document.createElement('div');
                row.className = 'upload-selected-item';
                if (!file.type || file.type.indexOf('image/') === 0) {
                    var img = document.createElement('img');
                    img.className = 'upload-preview-thumb';
                    img.alt = 'Selected photo ' + (index + 1);
                    row.appendChild(img);
                    var reader = new FileReader();
                    reader.onload = function (ev) { img.src = ev.target.result; };
                    reader.readAsDataURL(file);
                } else {
                    var icon = document.createElement('i');
                    icon.className = 'fas fa-image';
                    row.appendChild(icon);
                }
                var name = document.createElement('span');
                name.textContent = file.name || ('Photo ' + (index + 1));
                row.appendChild(name);
                var removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'upload-remove-btn';
                removeBtn.setAttribute('aria-label', 'Remove ' + (file.name || 'photo'));
                removeBtn.innerHTML = '<i class="fas fa-xmark"></i>';
                removeBtn.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    ev.stopPropagation();
                    removePendingPhoto(index);
                });
                row.appendChild(removeBtn);
                photoSelectedList.appendChild(row);
            });
        }

        photoInput?.addEventListener('change', function () {
            mergePhotoFiles(this.files);
            this.value = '';
        });
    })();

</script>
}
