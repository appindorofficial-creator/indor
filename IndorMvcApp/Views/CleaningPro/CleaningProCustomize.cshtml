@model IndorMvcApp.ViewModels.CleaningProCustomizeViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
var selectedAreas = (Model.AreasLimpieza ?? string.Empty).Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
    var selectedAddons = (Model.AddonsSeleccionados ?? string.Empty).Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("CleaningProSetup", "CleaningPro", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


<p class="page-lead" style="margin-top:-8px;">@L["Tell us what you need so we can match you with the right cleaner."]</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <span asp-validation-for="AreasLimpieza" class="text-danger" style="font-size:0.75rem;display:block;margin-bottom:8px;"></span>

    <form asp-action="CleaningProCustomize" method="post" id="customizeForm">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="Frecuencia" id="Frecuencia" />
        <input type="hidden" asp-for="CantidadLimpiadores" id="CantidadLimpiadores" />
        <input type="hidden" asp-for="AreasLimpieza" id="AreasLimpieza" />
        <input type="hidden" asp-for="HorasEstimadas" id="HorasEstimadas" />
        <input type="hidden" asp-for="AddonsSeleccionados" id="AddonsSeleccionados" />

        <div class="field-card">
            <div class="section-num">@L["What do you want cleaned?"]</div>
            <div class="section-hint">@L["You can select as many as you need."]</div>
            <div class="area-grid" id="areaGroup">
                @foreach (var area in CleaningProPricingService.AreaOptions)
                {
                    <button type="button" class="area-chip @(selectedAreas.Contains(area.Code) ? "active" : "")" data-code="@area.Code">
                        <i class="fas @area.Icon"></i>
                        <span>@L[area.Label]</span>
                        <span class="check"><i class="fas fa-check"></i></span>
                    </button>
                }
            </div>
        </div>

        <div class="field-card">
            <div class="section-num">@L["How often?"]</div>
            <div class="freq-row" id="freqGroup">
                <button type="button" class="freq-chip" data-value="OneTime"><i class="fas fa-calendar-day"></i>@L["One-time"]</button>
                <button type="button" class="freq-chip" data-value="Weekly"><i class="fas fa-rotate"></i>@L["Weekly"]</button>
                <button type="button" class="freq-chip" data-value="Biweekly"><i class="fas fa-calendar-week"></i>@L["Biweekly"]</button>
                <button type="button" class="freq-chip" data-value="Monthly"><i class="fas fa-calendar"></i>@L["Monthly"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="section-num">@L["Crew size"]</div>
            <div class="section-hint">@L["More cleaners = faster service."]</div>
            <div class="crew-grid" id="crewGroup">
                <button type="button" class="crew-card" data-value="One" data-rate="35">
                    <span class="check"><i class="fas fa-check"></i></span>
                    <i class="fas fa-user main"></i>
                    <strong>@L["1 cleaner"]</strong>
                    <div class="rate">@L["$35/hr"]</div>
                </button>
                <button type="button" class="crew-card" data-value="Two" data-rate="70">
                    <span class="check"><i class="fas fa-check"></i></span>
                    <i class="fas fa-user-group main"></i>
                    <strong>@L["2 cleaners"]</strong>
                    <div class="rate">@L["$70/hr"]</div>
                </button>
                <button type="button" class="crew-card" data-value="Three" data-rate="105">
                    <span class="check"><i class="fas fa-check"></i></span>
                    <i class="fas fa-users main"></i>
                    <strong>@L["3 cleaners"]</strong>
                    <div class="rate">@L["$105/hr"]</div>
                </button>
            </div>
        </div>

        <div class="field-card">
            <div class="section-num">@L["Estimated hours"]</div>
            <div class="section-hint">@L["Not sure? You can adjust later."]</div>
            <div class="hours-row" id="hoursGroup">
                @foreach (var hr in new[] { 2m, 3m, 4m, 5m })
                {
                    <button type="button" class="hour-btn" data-value="@hr.ToString(System.Globalization.CultureInfo.InvariantCulture)">@hr.ToString("0") @L["hr"]</button>
                }
            </div>
        </div>

        <div class="field-card">
            <div class="section-num">@L["Optional add-ons"]</div>
            <div class="section-hint">@L["Deep-clean extras you can add now."]</div>
            <div class="addon-grid" id="addonGroup">
                @foreach (var addon in CleaningProPricingService.AddonOptions)
                {
                    <button type="button" class="addon-row @(selectedAddons.Contains(addon.Code) ? "active" : "")" data-code="@addon.Code" data-price="@addon.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                        <i class="fas @addon.Icon main"></i>
                        <span class="copy">@L[addon.Label]</span>
                        <span class="price">$@addon.Price.ToString("0")</span>
                        <span class="check"><i class="fas fa-check"></i></span>
                    </button>
                }
            </div>
        </div>

        <div class="sticky-footer">
            <div class="summary-bar" id="summaryBar">@Model.SummaryLine</div>
            <button type="submit" name="action" value="continue" class="btn-primary">
                @L["Next: Review"] <i class="fas fa-chevron-right"></i>
            </button>
            <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
        </div>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        const rates = { One: 35, Two: 70, Three: 105 };
        const selectedAreas = new Set((document.getElementById('AreasLimpieza').value || '').split('|').map(s => s.trim()).filter(Boolean));
        const selectedAddons = new Set((document.getElementById('AddonsSeleccionados').value || '').split('|').map(s => s.trim()).filter(Boolean));

        function syncAreas() {
            document.getElementById('AreasLimpieza').value = Array.from(selectedAreas).join('|');
        }

        function syncAddons() {
            document.getElementById('AddonsSeleccionados').value = Array.from(selectedAddons).join('|');
        }

        document.querySelectorAll('#areaGroup .area-chip').forEach(chip => {
            chip.addEventListener('click', () => {
                const code = chip.dataset.code;
                if (selectedAreas.has(code)) {
                    selectedAreas.delete(code);
                    chip.classList.remove('active');
                } else {
                    selectedAreas.add(code);
                    chip.classList.add('active');
                }
                syncAreas();
                updateSummary();
            });
        });

        document.querySelectorAll('#addonGroup .addon-row').forEach(row => {
            row.addEventListener('click', () => {
                const code = row.dataset.code;
                if (selectedAddons.has(code)) {
                    selectedAddons.delete(code);
                    row.classList.remove('active');
                } else {
                    selectedAddons.add(code);
                    row.classList.add('active');
                }
                syncAddons();
                updateSummary();
            });
        });

        function normalizeCrewCode(value) {
            const map = { '1': 'One', '2': 'Two', '3': 'Three', One: 'One', Two: 'Two', Three: 'Three' };
            return map[value] || value || '';
        }

        function getSelectedHours() {
            const activeHour = document.querySelector('#hoursGroup .hour-btn.active');
            if (activeHour?.dataset.value) return parseFloat(activeHour.dataset.value);
            const hiddenHours = document.getElementById('HorasEstimadas');
            const parsed = parseFloat(hiddenHours?.value || '0');
            return Number.isFinite(parsed) && parsed > 0 ? parsed : 0;
        }

        function getAddonsTotal() {
            let total = 0;
            selectedAddons.forEach(code => {
                const row = document.querySelector('#addonGroup .addon-row[data-code="' + code + '"]');
                if (row) total += parseFloat(row.dataset.price || '0');
            });
            return total;
        }

        function getActiveCrewCard() {
            return document.querySelector('#crewGroup .crew-card.active');
        }

        function getHourlyRateForCrew(crewCode) {
            const card = getActiveCrewCard();
            if (card?.dataset.value === crewCode && card.dataset.rate) {
                return parseFloat(card.dataset.rate);
            }
            const match = document.querySelector('#crewGroup .crew-card[data-value="' + crewCode + '"]');
            if (match?.dataset.rate) return parseFloat(match.dataset.rate);
            return rates[normalizeCrewCode(crewCode)] || 0;
        }

        function initSingle(groupId, selector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            if (!hidden) return;

            const buttons = document.querySelectorAll('#' + groupId + ' ' + selector);
            const initialValue = (initial || hidden.value || '').trim();
            const treatZeroAsEmpty = hiddenId === 'HorasEstimadas' && (initialValue === '0' || Number(initialValue) === 0);
            const effectiveInitial = treatZeroAsEmpty ? '' : initialValue;

            function activate(btn) {
                buttons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                hidden.value = btn.dataset.value;
                updateSummary();
            }

            buttons.forEach(btn => {
                if (effectiveInitial && btn.dataset.value === effectiveInitial) {
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                }
                btn.addEventListener('click', () => activate(btn));
            });
        }

        const labels = {
            OneTime: @Json.Serialize(L["One-time"]),
            Weekly: @Json.Serialize(L["Weekly"]),
            Biweekly: @Json.Serialize(L["Biweekly"]),
            Monthly: @Json.Serialize(L["Monthly"]),
            One: @Json.Serialize(L["1 cleaner"]),
            Two: @Json.Serialize(L["2 cleaners"]),
            Three: @Json.Serialize(L["3 cleaners"]),
            Est: @Json.Serialize(L["Est."]),
            Hr: @Json.Serialize(L["hr"]),
            From: @Json.Serialize(L["From"]),
            SelectOptions: @Json.Serialize(L["Select your cleaning options"])
        };

        function formatFreq(v) {
            return labels[v] || v;
        }

        function formatCrew(v) {
            const code = normalizeCrewCode(v);
            return labels[code] || v;
        }

        function updateSummary() {
            const crewHidden = document.getElementById('CantidadLimpiadores');
            const activeCrew = getActiveCrewCard();
            const crew = normalizeCrewCode(activeCrew?.dataset.value || crewHidden?.value || '');
            if (crewHidden) crewHidden.value = crew;

            const hours = getSelectedHours();
            const hourlyRate = getHourlyRateForCrew(crew);
            const subtotal = (hourlyRate * hours) + getAddonsTotal();
            const freq = document.getElementById('Frecuencia')?.value || '';

            const summary = document.getElementById('summaryBar');
            if (!summary) return;

            if (!freq || !crew || hours <= 0) {
                summary.textContent = labels.SelectOptions;
                return;
            }

            summary.textContent =
                formatFreq(freq) + ' • ' + formatCrew(crew) + ' • ' + labels.Est + ' ' + hours + ' ' + labels.Hr + ' • ' + labels.From + ' $' + Math.round(subtotal);
        }

        initSingle('freqGroup', '.freq-chip', 'Frecuencia', '@Model.Frecuencia');
        initSingle('crewGroup', '.crew-card', 'CantidadLimpiadores', '@Model.CantidadLimpiadores');
        initSingle('hoursGroup', '.hour-btn', 'HorasEstimadas', '@Model.HorasEstimadas.ToString(System.Globalization.CultureInfo.InvariantCulture)');
        syncAreas();
        syncAddons();
        updateSummary();
    })();

</script>
}
