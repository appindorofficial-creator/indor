    .hour-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .summary-bar { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 12px; padding: 12px 14px; margin-bottom: 12px; font-size: 0.78rem; font-weight: 600; color: #0A2540; text-align: center; }
