    .section-hint { font-size: 0.78rem; color: #64748B; margin-bottom: 10px; }
    .freq-row { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 6px; }
    .freq-chip {
        border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 10px 4px;
