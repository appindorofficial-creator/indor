@await Html.PartialAsync("../Cleaning/_CleaningStyles")
<style>
    /* Bug #24: prevent iOS Safari zoom when tapping option buttons (needs 16px+ on controls). */
    html {
        -webkit-text-size-adjust: 100%;
    }

    .page-container {
        touch-action: manipulation;
    }

    .page-container button {
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
    }
    .cp-stepper { display: flex; align-items: center; gap: 0; margin-bottom: 18px; }
    .cp-stepper .line { flex: 1; height: 3px; background: #E5E7EB; border-radius: 2px; }
    .cp-stepper .line.done { background: #0066CC; }
    .cp-step-dot { width: 10px; height: 10px; border-radius: 999px; background: #E5E7EB; flex-shrink: 0; }
