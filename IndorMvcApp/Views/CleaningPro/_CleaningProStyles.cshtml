    .summary-card h3 { font-size: 0.88rem; font-weight: 800; margin: 0 0 12px; }
    .summary-row { display: flex; align-items: flex-start; gap: 12px; padding: 8px 0; font-size: 0.82rem; }
    .summary-row i { color: #0066CC; width: 18px; margin-top: 2px; text-align: center; }
    .summary-row .summary-label { font-size: 0.68rem; color: #94A3B8; font-weight: 600; }
    .summary-row .summary-value { font-weight: 700; color: #0A2540; white-space: pre-line; }
    .info-row { display: flex; align-items: center; gap: 10px; font-size: 0.78rem; color: #64748B; margin-bottom: 10px; }
    .info-row i { color: #0066CC; width: 18px; text-align: center; }
</style>
