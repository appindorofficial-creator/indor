        width: 18px; height: 18px; border-radius: 50%; border: 2px solid #CBD5E1;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0; background: #FFF;
    }
    .time-btn .check i { font-size: 0.5rem; margin: 0; line-height: 1; color: transparent; }
    .time-btn.active .check { border-color: #0066CC; background: #0066CC; }
