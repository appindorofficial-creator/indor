    .notes-row i { color: #0066CC; flex-shrink: 0; }
    .notes-row textarea { border: none; background: transparent; width: 100%; font-family: inherit; font-size: 0.82rem; resize: vertical; min-height: 48px; }
    .sticky-total { position: sticky; bottom: 0; background: rgba(255,255,255,0.96); backdrop-filter: blur(6px); border-top: 1px solid #E5E7EB; padding: 12px 0 0; margin-top: 12px; }
