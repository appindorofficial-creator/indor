@model IndorMvcApp.ViewModels.CleaningProServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home", new { fragment = "home-care-essentials" });

}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="cp-hero-icon"><i class="fas fa-sparkles"></i></span>
        </div>
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@Model.LandingTitulo</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@Model.LandingTagline</div>
            }
        </div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="includes-box" style="background:#F9FAFB;border:1px solid #E5E7EB;border-radius:14px;padding:12px 14px;margin-bottom:14px;">
            <div style="font-size:0.65rem;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:#6B7280;margin-bottom:8px;">Includes</div>
            <ul style="list-style:none;padding:0;margin:0;">
                @foreach (var item in Model.IncludedItems)
                {
                    <li style="display:flex;align-items:center;gap:8px;font-size:0.82rem;font-weight:600;padding:4px 0;"><i class="fas @item.Icon" style="color:#0066CC;font-size:0.72rem;"></i><span>@item.Text</span></li>
                }
            </ul>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.PrecioTexto))
    {
        <div style="display:flex;align-items:baseline;gap:6px;margin-bottom:14px;font-weight:700;color:#0066CC;">
            <i class="fas fa-tag"></i> @Model.PrecioTexto
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTexto))
    {
        <div class="info-box-blue"><i class="fas fa-shield-halved"></i><span>@Model.InfoBoxTexto</span></div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="CleaningProService" method="post">
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>
