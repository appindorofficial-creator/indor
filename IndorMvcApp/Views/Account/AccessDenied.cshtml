@{
    ViewData["Title"] = "Access denied";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
</head>
<body class="ob-page ob-page--white">
    <div class="ob-shell">
        <div class="ob-shell-inner ob-success-wrap">
            <h1>Access denied</h1>
            <p>You do not have permission to view this page. Sign in again or choose a different account.</p>
            <a asp-controller="Account" asp-action="Welcome" class="ob-btn ob-btn-primary">Back to welcome</a>
        </div>
    </div>
</body>
</html>
