@{
    ViewData["Title"] = "Check Your Email - INDOR";
    Layout = "_LayoutAuth";
    var email = ViewBag.Email as string;
}

<div class="login-container">
    <div class="top-bar">
        <a asp-controller="Account" asp-action="LoginForm" class="back-btn" aria-label="Back">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div style="width:44px;"></div>
    </div>

    <div class="logo-container">
        <img src="~/images/indor-logo-transparent.png" alt="Indor - The Home Operating System" class="smart-home-logo smart-home-logo--login" asp-append-version="true" />
    </div>

    <div class="brand-section">
        <h1 class="brand-title brand-title--login">Check your email</h1>
        <p class="brand-tagline">
            If an account exists for
            @if (!string.IsNullOrWhiteSpace(email))
            {
                <span class="highlight">@email</span>
            }
            else
            {
                <span>that email</span>
            },
            we've sent a 6-digit code and a reset link. The code is valid for <span class="highlight">24 hours</span>.
        </p>
    </div>

    <div class="form-card">
        <a asp-controller="Account" asp-action="ResetPassword" asp-route-email="@email" class="btn btn-primary btn-primary--submit" style="text-decoration:none;text-align:center;">
            <span class="btn-label">Enter code</span>
        </a>

        <div class="auth-or"><span>or</span></div>

        <div class="signup-link">
            Didn't get it? <a asp-controller="Account" asp-action="ForgotPassword">Try again</a>
        </div>
    </div>
</div>
