@model IndorMvcApp.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password - INDOR";
    Layout = "_LayoutAuth";
}

<div class="login-container">
    <div class="top-bar">
        <a asp-controller="Account" asp-action="LoginForm" class="back-btn" aria-label="Back">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div style="width:44px;"></div>
    </div>

    <div class="logo-container">
        <img src="~/images/indor-logo-transparent.png" alt="Indor - The Home Operating System" class="smart-home-logo smart-home-logo--login" asp-append-version="true" />
    </div>

    <div class="brand-section">
        <h1 class="brand-title brand-title--login">Forgot your password?</h1>
        <p class="brand-tagline">
            Enter your email and we'll send you a <span class="highlight">verification code</span> to reset it.
        </p>
    </div>

    <div class="form-card">
        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="input-group">
                <label asp-for="Email" class="input-label">Email</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input asp-for="Email" type="email" class="form-input" placeholder="you@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-primary--submit">
                <span class="btn-label">Send code</span>
            </button>

            <div class="auth-or"><span>or</span></div>

            <div class="signup-link">
                Remembered it? <a asp-controller="Account" asp-action="LoginForm">Back to sign in</a>
            </div>
        </form>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
