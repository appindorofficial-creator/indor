@{
    ViewData["Title"] = L["Password Updated - INDOR"];
    Layout = "_LayoutAuth";
}

<div class="login-container">
    <div class="top-bar">
        <div style="width:44px;"></div>
        <div style="width:44px;"></div>
    </div>

    <div class="logo-container">
        <img src="~/images/indor-logo-transparent.png" alt="@L["Indor - The Home Operating System"]" class="smart-home-logo smart-home-logo--login" asp-append-version="true" />
    </div>

    <div class="brand-section">
        <h1 class="brand-title brand-title--login">@L["Password updated"]</h1>
        <p class="brand-tagline">
            @L["Your password has been changed. You can now"] <span class="highlight">@L["sign in"]</span> @L["with your new password."]
        </p>
    </div>

    <div class="form-card">
        <a asp-controller="Account" asp-action="LoginForm" class="btn btn-primary btn-primary--submit" style="text-decoration:none;text-align:center;">
            <span class="btn-label">@L["Sign In"]</span>
        </a>
    </div>
</div>
