@model IndorMvcApp.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = L["Reset Password - INDOR"];
    Layout = "_LayoutAuth";
}

<div class="login-container">
    <div class="top-bar">
        <a asp-controller="Account" asp-action="LoginForm" class="back-btn" aria-label="@L["Back"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_AuthBrandMark")

    <div class="brand-section">
        <h1 class="brand-title brand-title--login">@L["Set a new password"]</h1>
        <p class="brand-tagline">
            @L["Enter the"] <span class="highlight">@L["code"]</span> @L["we emailed you and choose a new password."]
        </p>
    </div>

    <div class="form-card">
        <form asp-controller="Account" asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="input-group">
                <label asp-for="Email" class="input-label">@L["Email"]</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input asp-for="Email" type="email" class="form-input" placeholder="you@email.com" autocomplete="email"
                           data-val="true"
                           data-val-required="@L["Email is required"]"
                           data-val-email="@L["Invalid email address"]" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="Code" class="input-label">@L["Verification code"]</label>
                <div class="input-wrapper">
                    <i class="fas fa-key input-icon"></i>
                    <input asp-for="Code" type="text" inputmode="numeric" maxlength="6" class="form-input" placeholder="@L["6-digit code"]" autocomplete="one-time-code"
                           data-val="true"
                           data-val-required="@L["Enter the 6-digit code"]"
                           data-val-regex="@L["The code must be 6 digits"]"
                           data-val-regex-pattern="^\d{6}$" />
                </div>
                <span asp-validation-for="Code" class="field-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="NewPassword" class="input-label">@L["New password"]</label>
                <div class="input-wrapper password-field">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="NewPassword" type="password" id="newPassword" class="form-input" placeholder="@L["At least 8 characters"]" autocomplete="new-password"
                           data-val="true"
                           data-val-required="@L["Password is required"]"
                           data-val-length="@L["Password must be at least 8 characters"]"
                           data-val-length-min="8"
                           data-val-length-max="100" />
                    <button type="button" class="password-toggle" id="newPasswordToggle" aria-label="@L["Show password"]" aria-pressed="false">
                        <i class="fas fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="ConfirmPassword" class="input-label">@L["Confirm password"]</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="@L["Re-enter your password"]" autocomplete="new-password"
                           data-val="true"
                           data-val-required="@L["Confirm your password"]"
                           data-val-equalto="@L["Passwords do not match"]"
                           data-val-equalto-other="*.NewPassword" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-primary--submit">
                <span class="btn-label">@L["Reset password"]</span>
            </button>

            <div class="auth-or"><span>@L["or"]</span></div>

            <div class="signup-link">
                <a asp-controller="Account" asp-action="LoginForm">@L["Back to sign in"]</a>
            </div>
        </form>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
<script src="@Url.Content("~/js/auth-password-toggle.js")" asp-append-version="true"></script>
<script>
    window.indorBindPasswordToggle('newPassword', 'newPasswordToggle');
</script>
