@model IndorMvcApp.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password - INDOR";
    Layout = "_LayoutAuth";
}

<div class="login-container">
    <div class="top-bar">
        <a asp-controller="Account" asp-action="LoginForm" class="back-btn" aria-label="Back">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div style="width:44px;"></div>
    </div>

    <div class="logo-container">
        <img src="~/images/indor-logo-transparent.png" alt="Indor - The Home Operating System" class="smart-home-logo smart-home-logo--login" asp-append-version="true" />
    </div>

    <div class="brand-section">
        <h1 class="brand-title brand-title--login">Set a new password</h1>
        <p class="brand-tagline">
            Enter the <span class="highlight">code</span> we emailed you and choose a new password.
        </p>
    </div>

    <div class="form-card">
        <form asp-controller="Account" asp-action="ResetPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-error"></div>

            <div class="input-group">
                <label asp-for="Email" class="input-label">Email</label>
                <div class="input-wrapper">
                    <i class="fas fa-envelope input-icon"></i>
                    <input asp-for="Email" type="email" class="form-input" placeholder="you@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="Code" class="input-label">Verification code</label>
                <div class="input-wrapper">
                    <i class="fas fa-key input-icon"></i>
                    <input asp-for="Code" type="text" inputmode="numeric" maxlength="6" class="form-input" placeholder="6-digit code" autocomplete="one-time-code" />
                </div>
                <span asp-validation-for="Code" class="field-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="NewPassword" class="input-label">New password</label>
                <div class="input-wrapper password-field">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="NewPassword" type="password" id="newPassword" class="form-input" placeholder="At least 8 characters" autocomplete="new-password" />
                    <button type="button" class="password-toggle" id="newPasswordToggle" aria-label="Show password" aria-pressed="false">
                        <i class="fas fa-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="input-group">
                <label asp-for="ConfirmPassword" class="input-label">Confirm password</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock input-icon"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Re-enter your password" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-primary--submit">
                <span class="btn-label">Reset password</span>
            </button>

            <div class="auth-or"><span>or</span></div>

            <div class="signup-link">
                <a asp-controller="Account" asp-action="LoginForm">Back to sign in</a>
            </div>
        </form>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
<script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
<script>
    (function () {
        const input = document.getElementById('newPassword');
        const toggle = document.getElementById('newPasswordToggle');
        if (!input || !toggle) return;

        toggle.addEventListener('click', function (e) {
            e.preventDefault();
            const icon = toggle.querySelector('i');
            const show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            icon.classList.toggle('fa-eye', !show);
            icon.classList.toggle('fa-eye-slash', show);
            toggle.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
            toggle.setAttribute('aria-pressed', show ? 'true' : 'false');
        });
    })();
</script>
