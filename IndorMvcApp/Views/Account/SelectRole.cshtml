@model IndorMvcApp.ViewModels.SelectRoleViewModel
@{
    ViewData["Title"] = L["How will you use INDOR? - INDOR"];
    Layout = "_LayoutAuth";
    ViewData["LanguageSelectorVariant"] = "compact";
    ViewData["AuthExtraCss"] = "selectrole-v3.css";
    var selected = string.IsNullOrWhiteSpace(Model.SelectedRole) ? "Propietario" : Model.SelectedRole;
}

<div class="login-container login-container--select-role sr-screen sr-screen--v4">
    <div class="top-bar top-bar--with-lang">
        <a asp-controller="Account" asp-action="Welcome" class="back-btn" data-smart-back aria-label="@L["Back"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        @await Html.PartialAsync("_LanguageSelector")
    </div>

    <div class="brand-section sr-brand">
        <h1 class="brand-title sr-brand-title">@L["How will you use INDOR?"]</h1>
        <p class="brand-tagline sr-brand-tagline">
            @L["Select the option that best describes what you need today. You can add other options later."]
        </p>
    </div>

    <div class="sr-info-banner" role="note">
        <span class="sr-info-banner-icon" aria-hidden="true"><i class="fas fa-circle-info"></i></span>
        <p>@L["One account. You choose how to personalize INDOR."]</p>
    </div>

    <form asp-controller="Account" asp-action="SelectRole" method="post" id="roleForm" class="sr-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="SelectedRole" id="selectedRoleInput" value="@selected" />

        <div asp-validation-summary="ModelOnly" class="validation-error sr-validation"></div>

        <section class="sr-section" aria-labelledby="srPersonalHeading">
            <h2 id="srPersonalHeading" class="sr-section-title">@L["Personal use"]</h2>

            <div class="sr-role-list">
                <button type="button"
                        class="sr-role-card @(selected == "Propietario" ? "selected" : "")"
                        data-role="Propietario"
                        onclick="selectRole(this)"
                        role="radio"
                        aria-checked="@(selected == "Propietario" ? "true" : "false")"
                        tabindex="0"
                        onkeydown="roleKeySelect(event, this)">
                    <img src="~/images/selectrole-icon-home.png" alt="" class="sr-role-art" loading="lazy" asp-append-version="true" />
                    <span class="sr-role-copy">
                        <strong>@L["My home"]</strong>
                        <span>@L["To organize your house, maintenance, and documents."]</span>
                    </span>
                    <span class="sr-role-radio" aria-hidden="true"></span>
                </button>

                <button type="button"
                        class="sr-role-card @(selected == "AdministradorPropiedades" ? "selected" : "")"
                        data-role="AdministradorPropiedades"
                        onclick="selectRole(this)"
                        role="radio"
                        aria-checked="@(selected == "AdministradorPropiedades" ? "true" : "false")"
                        tabindex="0"
                        onkeydown="roleKeySelect(event, this)">
                    <img src="~/images/selectrole-icon-properties.png" alt="" class="sr-role-art" loading="lazy" asp-append-version="true" />
                    <span class="sr-role-copy">
                        <strong>@L["My properties"]</strong>
                        <span>@L["For investors, Airbnb, rentals, or multiple properties."]</span>
                    </span>
                    <span class="sr-role-radio" aria-hidden="true"></span>
                </button>
            </div>
        </section>

        <section class="sr-section sr-section--pro" aria-labelledby="srProHeading">
            <div class="sr-pro-heading">
                <h2 id="srProHeading" class="sr-section-title">@L["Professional access"]</h2>
                <span class="sr-pro-badge">
                    <strong>INDOR PRO</strong>
                    <span>@L["Exclusive entry for professionals"]</span>
                </span>
            </div>

            <div class="sr-role-list">
                <button type="button"
                        class="sr-role-card @(selected == "ProveedorServicios" ? "selected" : "")"
                        data-role="ProveedorServicios"
                        onclick="selectRole(this)"
                        role="radio"
                        aria-checked="@(selected == "ProveedorServicios" ? "true" : "false")"
                        tabindex="0"
                        onkeydown="roleKeySelect(event, this)">
                    <img src="~/images/selectrole-icon-provider.png" alt="" class="sr-role-art" loading="lazy" asp-append-version="true" />
                    <span class="sr-role-copy">
                        <strong>@L["Service Provider"]</strong>
                        <span>@L["To offer services, receive jobs, and get clients."]</span>
                    </span>
                    <span class="sr-role-radio" aria-hidden="true"></span>
                </button>

                <button type="button"
                        class="sr-role-card @(selected == "Realtor" ? "selected" : "")"
                        data-role="Realtor"
                        onclick="selectRole(this)"
                        role="radio"
                        aria-checked="@(selected == "Realtor" ? "true" : "false")"
                        tabindex="0"
                        onkeydown="roleKeySelect(event, this)">
                    <img src="~/images/selectrole-icon-realtor.png" alt="" class="sr-role-art" loading="lazy" asp-append-version="true" />
                    <span class="sr-role-copy">
                        <strong>@L["Realtor"]</strong>
                        <span>@L["For real estate agents, clients, and properties."]</span>
                    </span>
                    <span class="sr-role-radio" aria-hidden="true"></span>
                </button>
            </div>
        </section>

        <div class="roles-divider sr-divider">
            <i class="fas fa-shield-halved"></i>
            <span>@L["You can change or expand your profile later."]</span>
        </div>

        <div class="role-form-actions sr-actions">
            <button type="submit" class="sr-continue-btn" id="continueBtn">
                <span class="sr-continue-label">@L["Continue"]</span>
            </button>

            <div class="skip-link sr-skip">
                <button type="submit" name="skipLater" value="true">@L["I'll choose later"]</button>
            </div>
        </div>
    </form>
</div>

<script>
    function selectRole(card) {
        document.querySelectorAll('.sr-role-card').forEach(function (c) {
            c.classList.remove('selected');
            c.setAttribute('aria-checked', 'false');
        });
        card.classList.add('selected');
        card.setAttribute('aria-checked', 'true');
        document.getElementById('selectedRoleInput').value = card.getAttribute('data-role');
    }

    function roleKeySelect(e, card) {
        if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            selectRole(card);
        }
    }

    document.getElementById('roleForm').addEventListener('submit', function (e) {
        var skipBtn = e.submitter && e.submitter.name === 'skipLater';
        if (skipBtn) {
            document.getElementById('selectedRoleInput').value = 'Propietario';
            return;
        }

        var selectedRole = document.getElementById('selectedRoleInput').value;
        if (!selectedRole) {
            e.preventDefault();
            alert('@Html.Raw(L["Please select a profile before continuing."].Replace("'", "\\'"))');
        }
    });
</script>
