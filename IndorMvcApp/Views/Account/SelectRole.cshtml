@model IndorMvcApp.ViewModels.SelectRoleViewModel
@{
    ViewData["Title"] = "Select your role - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
            color: #0A2540;
        }

        .login-container {
            width: 100%;
            max-width: 460px;
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            animation: fadeIn 0.6s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .top-bar {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .back-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #FFFFFF;
            border: 1.5px solid #E5E7EB;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0A2540;
            text-decoration: none;
            font-size: 1rem;
            transition: all 0.25s ease;
        }

        .back-btn:hover {
            border-color: #0066CC;
            color: #0066CC;
            transform: translateX(-2px);
        }

        .logo-container {
            margin-bottom: 14px;
            animation: logoAnimation 0.8s ease-out;
        }

        @@keyframes logoAnimation {
            0%   { opacity: 0; transform: scale(0.85); }
            100% { opacity: 1; transform: scale(1); }
        }

        .smart-home-logo {
            width: min(100%, 240px);
            height: auto;
            display: block;
            margin: 0 auto;
        }

        .brand-section {
            text-align: center;
            margin-bottom: 22px;
        }

        .brand-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #0A2540;
            margin-bottom: 6px;
        }

        .brand-tagline {
            font-size: 0.92rem;
            color: #6B7280;
            font-weight: 400;
        }

        .brand-tagline .highlight {
            color: #0066CC;
            font-weight: 600;
        }

        .form-card {
            width: 100%;
            background: #FFFFFF;
            border-radius: 20px;
            padding: 22px 18px;
            box-shadow: 0 12px 40px rgba(10, 37, 64, 0.08);
            border: 1px solid rgba(229, 231, 235, 0.7);
            animation: slideUp 0.7s ease-out 0.15s backwards;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .roles-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 18px;
        }

        .role-card {
            background: #F9FAFB;
            border: 1.5px solid #E5E7EB;
            border-radius: 14px;
            padding: 18px 12px;
            cursor: pointer;
            transition: all 0.25s ease;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            min-height: 148px;
            justify-content: center;
        }

        .role-card:hover {
            border-color: #0066CC;
            background: #FFFFFF;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(0, 102, 204, 0.12);
        }

        .role-card.selected {
            border-color: #0066CC;
            background: #FFFFFF;
            box-shadow: 0 0 0 4px rgba(0, 102, 204, 0.12);
        }

        .role-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: linear-gradient(135deg, rgba(0, 102, 204, 0.12) 0%, rgba(0, 79, 163, 0.12) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0066CC;
            font-size: 1.4rem;
        }

        .role-card.selected .role-icon {
            background: linear-gradient(135deg, #0066CC 0%, #004FA3 100%);
            color: #FFFFFF;
        }

        .role-name {
            font-size: 0.92rem;
            font-weight: 600;
            color: #0A2540;
            line-height: 1.25;
        }

        .role-desc {
            font-size: 0.72rem;
            color: #64748B;
            line-height: 1.35;
            margin-top: 2px;
        }

        .validation-error {
            font-size: 0.85rem;
            color: #EF4444;
            margin-bottom: 14px;
            background: rgba(239, 68, 68, 0.08);
            padding: 10px 12px;
            border-radius: 10px;
        }

        .validation-error:empty,
        .validation-error ul:empty,
        .validation-error.validation-summary-valid {
            display: none;
            padding: 0;
            margin: 0;
            background: transparent;
        }

        .btn {
            width: 100%;
            padding: 16px 22px;
            border-radius: 14px;
            font-size: 1rem;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, #0066CC 0%, #004FA3 100%);
            color: #FFFFFF;
            box-shadow: 0 8px 24px rgba(0, 102, 204, 0.25);
        }

        .btn-primary:hover:not(:disabled) {
            transform: scale(1.02) translateY(-2px);
            box-shadow: 0 12px 32px rgba(0, 102, 204, 0.35);
        }

        .btn-primary:active { transform: scale(0.98); }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            box-shadow: none;
        }

        .btn-icon {
            font-size: 1.1rem;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
        }

        .btn-icon-left { left: 22px; }

        .btn-icon-right { right: 22px; }

        .btn-label { line-height: 1; }

        .skip-link {
            text-align: center;
            margin-top: 14px;
            font-size: 0.9rem;
        }

        .skip-link a {
            color: #6B7280;
            text-decoration: none;
            font-weight: 500;
        }

        .skip-link a:hover { color: #0066CC; }

        @@media (max-width: 380px) {
            .roles-grid { gap: 8px; }
            .role-card { padding: 14px 8px; min-height: 110px; }
            .role-icon { width: 44px; height: 44px; font-size: 1.2rem; }
            .role-name { font-size: 0.82rem; }
            .smart-home-logo { width: 95px; }
            .form-card { padding: 18px 14px; }
        }
    </style>
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
</head>
<body>
    <div class="login-container">
        <div class="ob-progress" style="width:100%;max-width:460px;margin:0 auto 12px;display:flex;gap:6px" aria-label="Progress">
            <div class="ob-progress-seg is-done" style="flex:1;height:4px;border-radius:999px;background:#0066CC"></div>
            <div class="ob-progress-seg is-active" style="flex:1;height:4px;border-radius:999px;background:#0066CC"></div>
            <div class="ob-progress-seg" style="flex:1;height:4px;border-radius:999px;background:#CBD5E1"></div>
            <div class="ob-progress-seg" style="flex:1;height:4px;border-radius:999px;background:#CBD5E1"></div>
            <div class="ob-progress-seg" style="flex:1;height:4px;border-radius:999px;background:#CBD5E1"></div>
        </div>
        <div class="top-bar">
            <a asp-controller="Account" asp-action="Welcome" class="back-btn" aria-label="Back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div style="width:44px;"></div>
        </div>

        <div class="logo-container">
            <img src="~/logoindor.png" alt="Indor - The Home Operating System" class="smart-home-logo" />
        </div>

        <div class="brand-section">
            <h1 class="brand-title">Select your role</h1>
            <p class="brand-tagline">
                Choose the profile that best <span class="highlight">matches you</span>.
            </p>
        </div>

        <div class="form-card">
            <form asp-controller="Account" asp-action="SelectRole" method="post" id="roleForm">
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="SelectedRole" id="selectedRoleInput" />

                <div asp-validation-summary="ModelOnly" class="validation-error"></div>

                <div class="roles-grid">
                    <div class="role-card" data-role="Realtor" onclick="selectRole(this)">
                        <div class="role-icon"><i class="fas fa-user-tie"></i></div>
                        <div class="role-name">Realtor</div>
                        <div class="role-desc">Manage client properties and transactions.</div>
                    </div>

                    <div class="role-card" data-role="Propietario" onclick="selectRole(this)">
                        <div class="role-icon"><i class="fas fa-house"></i></div>
                        <div class="role-name">Property Owner</div>
                        <div class="role-desc">Manage your primary residence.</div>
                    </div>

                    <div class="role-card" data-role="AdministradorPropiedades" onclick="selectRole(this)">
                        <div class="role-icon"><i class="fas fa-building"></i></div>
                        <div class="role-name">Multi-Property Owner</div>
                        <div class="role-desc">Airbnb, rentals &amp; multiple homes.</div>
                    </div>

                    <div class="role-card" data-role="ProveedorServicios" onclick="selectRole(this)">
                        <div class="role-icon"><i class="fas fa-tools"></i></div>
                        <div class="role-name">Service Provider</div>
                        <div class="role-desc">Manage services and maintenance work.</div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" id="continueBtn" disabled>
                    <i class="fas fa-circle-check btn-icon btn-icon-left"></i>
                    <span class="btn-label">Continue</span>
                    <i class="fas fa-chevron-right btn-icon btn-icon-right"></i>
                </button>

                <div class="skip-link">
                    <a href="#" onclick="skipRole(event)">Skip for now</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        function selectRole(card) {
            document.querySelectorAll('.role-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            const role = card.getAttribute('data-role');
            document.getElementById('selectedRoleInput').value = role;
            document.getElementById('continueBtn').disabled = false;
        }

        function skipRole(e) {
            e.preventDefault();
            window.location.href = '@Url.Action("Index", "Home")';
        }

        document.getElementById('roleForm').addEventListener('submit', function (e) {
            const selectedRole = document.getElementById('selectedRoleInput').value;
            if (!selectedRole) {
                e.preventDefault();
                alert('Please select a role before continuing.');
            }
        });
    </script>
</body>
</html>
