@{
    ViewData["Title"] = "Welcome - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#0B1F3A" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/welcome-landing.css" asp-append-version="true" />
</head>
<body class="wl-body">
    <div class="wl-screen">
        <div class="wl-hero">
            <div class="wl-hero-bg" aria-hidden="true"></div>
            <div class="wl-hero-overlay" aria-hidden="true"></div>

            <header class="wl-top wl-reveal wl-reveal-1">
                <div class="wl-brand" aria-label="INDOR home Indor">
                    <div class="wl-logo-main">
                        <span>IND</span>
                        <svg class="wl-logo-house" viewBox="0 0 28 28" aria-hidden="true" focusable="false">
                            <path d="M14 3 L26 14 V26 H2 V14 Z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
                            <rect x="9" y="15" width="4" height="4" fill="currentColor" />
                            <rect x="15" y="15" width="4" height="4" fill="currentColor" />
                            <rect x="9" y="21" width="4" height="4" fill="currentColor" />
                            <rect x="15" y="21" width="4" height="4" fill="currentColor" />
                        </svg>
                        <span>R</span>
                    </div>
                    <p class="wl-logo-sub">
                        <span class="wl-logo-sub-home">home </span><span class="wl-logo-sub-indor">Indor</span>
                    </p>
                </div>
                <div class="wl-rule" aria-hidden="true"></div>
                <p class="wl-tagline">
                    <span class="wl-tagline-accent">The Home Operating System</span>,
                    helping navigate owning a house.
                </p>
            </header>

            <div class="wl-hero-copy wl-reveal wl-reveal-2">
                <div class="wl-headline-wrap">
                    <h1 class="wl-headline">Navigate owning your house with confidence.</h1>
                </div>
            </div>

            <div class="wl-sheet wl-reveal wl-reveal-3">
                <div class="wl-sheet-handle" aria-hidden="true"></div>
                <a asp-action="LoginForm" class="wl-btn">
                    <span>Log In</span>
                    <svg class="wl-btn-arrow" viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                        <path d="M4 10h12M11 5l5 5-5 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
                <p class="wl-secondary-cta">
                    New to INDOR? <a asp-action="Register">Create Account</a>
                </p>
            </div>
        </div>
    </div>
</body>
</html>
