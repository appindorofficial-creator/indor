@model IndorMvcApp.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account - INDOR";
    Layout = null;
    ViewBag.OnboardingStep = 1;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
</head>
<body class="ob-page ob-page--white">
    <div class="ob-shell">
        <div class="ob-shell-inner">
            @await Html.PartialAsync("_OnboardingNav")
            @await Html.PartialAsync("_OnboardingStepper")

            <div class="ob-head-block">
                <h1>Your Info</h1>
                <p>Tell us a bit about yourself to get started.</p>
            </div>

            <div class="ob-form-card">
                <form asp-controller="Account" asp-action="Register" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="ob-summary"></div>
                    }

                    <div class="ob-field">
                        <label asp-for="FullName" class="ob-label">Full Name</label>
                        <input asp-for="FullName" class="ob-control" placeholder="John Smith" autocomplete="name" />
                        <span asp-validation-for="FullName" class="ob-error"></span>
                    </div>

                    <div class="ob-field">
                        <label asp-for="Email" class="ob-label">Email</label>
                        <input asp-for="Email" type="email" class="ob-control" placeholder="john@email.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="ob-error"></span>
                    </div>

                    <div class="ob-field">
                        <label asp-for="Telefono" class="ob-label">Phone <span style="font-weight:400;color:#94A3B8;">(Optional)</span></label>
                        <div class="ob-phone-row">
                            <div class="ob-phone-code"><span>🇺🇸</span> +1</div>
                            <input asp-for="Telefono" type="tel" class="ob-control" placeholder="555 123 4567" autocomplete="tel" />
                        </div>
                        <span asp-validation-for="Telefono" class="ob-error"></span>
                    </div>

                    <div class="ob-field">
                        <label asp-for="Password" class="ob-label">Password</label>
                        <div class="ob-control-wrap">
                            <input asp-for="Password" type="password" class="ob-control" placeholder="Create a password" autocomplete="new-password" id="passwordInput" />
                            <button type="button" class="ob-pw-toggle" id="togglePassword" aria-label="Show password">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <ul class="ob-pw-rules" id="pwRules">
                            <li data-rule="length"><i class="fas fa-circle"></i> At least 8 characters</li>
                            <li data-rule="upper"><i class="fas fa-circle"></i> One uppercase letter</li>
                            <li data-rule="number"><i class="fas fa-circle"></i> One number</li>
                        </ul>
                        <span asp-validation-for="Password" class="ob-error"></span>
                    </div>

                    <button type="submit" class="ob-btn ob-btn-primary">Create Account</button>

                    <p class="ob-legal">
                        By continuing, you agree to our
                        <a asp-action="Terms" asp-route-from="register">Terms &amp; Conditions</a> and
                        <a asp-action="Privacy" asp-route-from="register">Privacy Policy</a>.
                    </p>
                </form>
            </div>
        </div>
    </div>
    <script>
        (function () {
            const input = document.getElementById('passwordInput');
            const toggle = document.getElementById('togglePassword');
            const rules = document.querySelectorAll('#pwRules li');

            toggle?.addEventListener('click', function () {
                if (!input) return;
                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';
                const icon = this.querySelector('i');
                icon.classList.toggle('fa-eye', !show);
                icon.classList.toggle('fa-eye-slash', show);
            });

            function validatePassword(value) {
                rules.forEach(function (li) {
                    const rule = li.getAttribute('data-rule');
                    let ok = false;
                    if (rule === 'length') ok = value.length >= 8;
                    if (rule === 'upper') ok = /[A-Z]/.test(value);
                    if (rule === 'number') ok = /[0-9]/.test(value);
                    li.classList.toggle('is-valid', ok);
                    li.querySelector('i').className = ok ? 'fas fa-check' : 'fas fa-circle';
                });
            }

            input?.addEventListener('input', function () { validatePassword(this.value); });
            if (input?.value) validatePassword(input.value);
        })();
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
