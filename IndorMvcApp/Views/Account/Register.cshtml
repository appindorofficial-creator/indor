@model IndorMvcApp.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account - INDOR";
    Layout = "_LayoutAuthOnboarding";
    ViewBag.OnboardingStep = 1;
}

<div class="ob-shell">
        <div class="ob-shell-inner">
            @await Html.PartialAsync("_OnboardingNav")
            @await Html.PartialAsync("_OnboardingStepper")

            <div class="ob-head-block">
                <h1>Your Info</h1>
                <p>Tell us a bit about yourself to get started.</p>
            </div>

            <div class="ob-form-card">
                <form asp-controller="Account" asp-action="Register" method="post">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="ob-summary"></div>
                    }

                    <div class="ob-field">
                        <label asp-for="FullName" class="ob-label">Full Name</label>
                        <input asp-for="FullName" class="ob-control" placeholder="John Smith" autocomplete="name"
                               inputmode="text" autocapitalize="words" spellcheck="false"
                               aria-describedby="fullNameHint" />
                        <span id="fullNameHint" class="ob-error" style="color:#64748B;font-size:.75rem;margin-top:4px;display:block">
                            Use your first and last name (letters only).
                        </span>
                        <span asp-validation-for="FullName" class="ob-error"></span>
                    </div>

                    <div class="ob-field">
                        <label asp-for="Email" class="ob-label">Email</label>
                        <input asp-for="Email" type="email" class="ob-control" placeholder="john@gmail.com" autocomplete="email" id="Email" />
                        <span asp-validation-for="Email" class="ob-error"></span>
                    </div>

                    <div class="ob-field">
                        <label asp-for="Telefono" class="ob-label">Phone <span style="font-weight:400;color:#94A3B8;">(Optional)</span></label>
                        <div class="ob-phone-row">
                            <div class="ob-phone-code"><span aria-hidden="true">&#127482;&#127480;</span> +1</div>
                            <input asp-for="Telefono" type="tel" class="ob-control" placeholder="5551234567" autocomplete="tel"
                                   inputmode="numeric" maxlength="10" pattern="[0-9]{10}" id="Telefono" />
                        </div>
                        <span class="ob-error" style="color:#64748B;font-size:.75rem;margin-top:4px;display:block">
                            Optional &mdash; if entered, use 10 digits (US).
                        </span>
                        <span asp-validation-for="Telefono" class="ob-error"></span>
                    </div>

                    <div class="ob-field">
                        <label asp-for="Password" class="ob-label">Password</label>
                        <div class="ob-control-wrap">
                            <input asp-for="Password" type="password" class="ob-control" placeholder="Create a password" autocomplete="new-password" id="passwordInput" />
                            <button type="button" class="ob-pw-toggle" id="togglePassword" aria-label="Show password" aria-pressed="false">
                                <i class="fas fa-eye-slash" aria-hidden="true"></i>
                            </button>
                        </div>
                        <ul class="ob-pw-rules" id="pwRules">
                            <li data-rule="length"><i class="fas fa-circle"></i> At least 8 characters</li>
                            <li data-rule="upper"><i class="fas fa-circle"></i> One uppercase letter</li>
                            <li data-rule="number"><i class="fas fa-circle"></i> One number</li>
                        </ul>
                        <span asp-validation-for="Password" class="ob-error"></span>
                    </div>

                    <button type="submit" class="ob-btn ob-btn-primary">Create Account</button>

                    <p class="ob-legal">
                        By continuing, you agree to our
                        <a asp-action="Terms" asp-route-from="register">Terms &amp; Conditions</a> and
                        <a asp-action="Privacy" asp-route-from="register">Privacy Policy</a>.
                    </p>
                </form>
            </div>
        </div>
    </div>
    <script src="@Url.Content("~/js/auth-password-toggle.js")" asp-append-version="true"></script>
    <script>
        (function () {
            window.indorBindPasswordToggle('passwordInput', 'togglePassword');

            const input = document.getElementById('passwordInput');
            const rules = document.querySelectorAll('#pwRules li');

            function validatePassword(value) {
                rules.forEach(function (li) {
                    const rule = li.getAttribute('data-rule');
                    let ok = false;
                    if (rule === 'length') ok = value.length >= 8;
                    if (rule === 'upper') ok = /[A-Z]/.test(value);
                    if (rule === 'number') ok = /[0-9]/.test(value);
                    li.classList.toggle('is-valid', ok);
                    li.querySelector('i').className = ok ? 'fas fa-check' : 'fas fa-circle';
                });
            }

            input?.addEventListener('input', function () { validatePassword(this.value); });
            if (input?.value) validatePassword(input.value);

            const fullName = document.getElementById('FullName');
            const hasLetter = /\p{L}/u;
            const onlyDigits = /^[\d\s]+$/;

            function validateFullName(value) {
                const v = (value || '').trim();
                if (!v) return true;
                if (!hasLetter.test(v) || onlyDigits.test(v)) return false;
                const parts = v.split(/\s+/).filter(Boolean);
                return parts.length >= 2 && parts.every(p => /\p{L}/u.test(p));
            }

            fullName?.addEventListener('input', function () {
                this.setCustomValidity(validateFullName(this.value) ? '' : 'Enter your first and last name using letters.');
            });
            if (fullName?.value) fullName.dispatchEvent(new Event('input'));

            const emailInput = document.getElementById('Email');
            const blockedDomains = {
                'hmail.com': 'gmail.com', 'hmial.com': 'gmail.com', 'gmial.com': 'gmail.com',
                'gmal.com': 'gmail.com', 'gamil.com': 'gmail.com', 'gnail.com': 'gmail.com',
                'hotmial.com': 'hotmail.com', 'outlok.com': 'outlook.com', 'yahooo.com': 'yahoo.com'
            };
            const emailPattern = /^[a-zA-Z0-9._%+-]+@@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$/;

            function validateEmail(value) {
                const v = (value || '').trim();
                if (!v) return '';
                if (!emailPattern.test(v)) return 'Enter a valid email address.';
                const domain = v.split('@@')[1]?.toLowerCase();
                if (domain && blockedDomains[domain]) {
                    return 'Check your email address. Did you mean @@' + blockedDomains[domain] + '?';
                }
                return '';
            }

            emailInput?.addEventListener('input', function () {
                this.setCustomValidity(validateEmail(this.value));
            });
            if (emailInput?.value) emailInput.dispatchEvent(new Event('input'));

            const phoneInput = document.getElementById('Telefono');
            function normalizePhoneDigits(value) {
                let digits = (value || '').replace(/\D/g, '');
                if (digits.length === 11 && digits[0] === '1') digits = digits.slice(1);
                return digits.slice(0, 10);
            }
            function validatePhone(value) {
                const digits = normalizePhoneDigits(value);
                if (!digits) return true;
                return digits.length === 10;
            }
            phoneInput?.addEventListener('input', function () {
                const digits = normalizePhoneDigits(this.value);
                if (this.value !== digits) this.value = digits;
                this.setCustomValidity(validatePhone(digits) ? '' : 'Enter a valid 10-digit US phone number.');
            });
            phoneInput?.addEventListener('paste', function (e) {
                e.preventDefault();
                const text = (e.clipboardData || window.clipboardData).getData('text');
                this.value = normalizePhoneDigits(text);
                this.dispatchEvent(new Event('input'));
            });
            if (phoneInput?.value) phoneInput.dispatchEvent(new Event('input'));
        })();
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}