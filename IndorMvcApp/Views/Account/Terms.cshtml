@{
    ViewData["Title"] = L["Terms & Conditions - INDOR"];
    Layout = "_LayoutAuthOnboarding";
    ViewBag.OnboardingShowBack = true;
}

<div class="ob-shell">
        <div class="ob-shell-inner">
            @await Html.PartialAsync("_OnboardingNav")

            <article class="ob-legal-doc">
                <h1>@L["Terms & Conditions"]</h1>
                <p class="ob-legal-updated">@L["Last updated: May 2026"]</p>
                <p class="ob-legal-related">@L["Also read our"] <a asp-controller="Account" asp-action="Privacy" asp-route-from="@ViewBag.LegalFrom" asp-route-propiedadId="@ViewBag.LegalPropiedadId">@L["Privacy Policy"]</a>.</p>

                <p>@L["Welcome to INDOR. These Terms & Conditions govern your use of the INDOR platform operated by Safe Project Solution. By creating an account or using our services, you agree to these terms."]</p>

                <h2>@L["1. Your Account"]</h2>
                <p>@L["You are responsible for maintaining the confidentiality of your login credentials and for all activity under your account. You agree to provide accurate information when registering and to keep your profile up to date."]</p>

                <h2>@L["2. Home & Property Information"]</h2>
                <p>@L["INDOR helps you manage information about your home, including address details, house facts, documents, services, and maintenance. Property data may be enriched from third-party sources to improve your experience. You confirm that you have the right to add and manage the property information you provide."]</p>

                <h2>@L["3. Acceptable Use"]</h2>
                <p>@L["You agree not to misuse the platform, attempt unauthorized access, upload harmful content, or use INDOR for unlawful purposes. We may suspend or terminate accounts that violate these terms."]</p>

                <h2>@L["4. Services & Third Parties"]</h2>
                <p>@L["INDOR may connect you with service providers, inspections, or informational resources. Unless explicitly stated, Safe Project Solution is not a party to agreements between you and third-party providers."]</p>

                <h2>@L["5. Disclaimers"]</h2>
                <p>@L["INDOR is provided on an \"as is\" basis. We do not guarantee that property data, recommendations, or service outcomes will be complete, accurate, or suitable for every situation. You should verify important decisions independently."]</p>

                <h2>@L["6. Limitation of Liability"]</h2>
                <p>@L["To the fullest extent permitted by law, Safe Project Solution shall not be liable for indirect, incidental, or consequential damages arising from your use of the platform."]</p>

                <h2>@L["7. Changes"]</h2>
                <p>@L["We may update these Terms from time to time. Continued use of INDOR after changes are posted constitutes acceptance of the revised Terms."]</p>

                <h2>@L["8. Contact"]</h2>
                <p>@L["Questions about these Terms may be directed to Safe Project Solution through"] <a href="https://homeindor.com" target="_blank" rel="noopener">homeindor.com</a> @L["or the support channels available in the app."]</p>
            </article>
        </div>
    </div>
