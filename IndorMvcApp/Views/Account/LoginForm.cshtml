@model IndorMvcApp.ViewModels.LoginViewModel
@using IndorMvcApp.Localization
@{
    ViewData["Title"] = L["Sign In - INDOR"];
    Layout = "_LayoutAuth";
    var returnUrl = ViewData["ReturnUrl"] as string;
    ViewData["LanguageSelectorVariant"] = "compact";
}

<div class="login-container login-container--signin">
        <div class="top-bar top-bar--with-lang">
            <a asp-controller="Account" asp-action="Welcome" class="back-btn" aria-label="@L["Back"]">
                <i class="fas fa-arrow-left"></i>
            </a>
            @await Html.PartialAsync("_LanguageSelector")
        </div>

        @await Html.PartialAsync("_AuthBrandMark")

        <div class="brand-section">
            <h1 class="brand-title brand-title--login">@L["Welcome back"]</h1>
            <p class="brand-tagline">
                @L["Sign in to access your"] <span class="highlight">@L["smart home"]</span>.
            </p>
        </div>

        <div class="form-card">
            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-error"></div>

                <div class="input-group">
                    <label asp-for="Email" class="input-label">@L["Email"]</label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input asp-for="Email" type="email" class="form-input" placeholder="you@email.com" autocomplete="email"
                               data-val="true"
                               data-val-required="@L["Email is required"]"
                               data-val-email="@L["Invalid email address"]" />
                    </div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="input-group">
                    <label asp-for="Password" class="input-label">@L["Password"]</label>
                    <div class="input-wrapper password-field">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="Password" type="password" id="loginPassword" class="form-input" placeholder="@L["Enter your password"]" autocomplete="current-password"
                               data-val="true"
                               data-val-required="@L["Password is required"]" />
                        <button type="button" class="password-toggle" id="loginPasswordToggle" aria-label="@L["Show password"]" aria-pressed="false">
                            <i class="fas fa-eye-slash" aria-hidden="true"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="row-options">
                    <label class="remember-me">
                        <input asp-for="RememberMe" type="checkbox" />
                        <span>@L["Remember me"]</span>
                    </label>
                    <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">@L["Forgot your password?"]</a>
                </div>

                <button type="submit" class="btn btn-primary btn-primary--submit">
                    <span class="btn-label">@L["Sign In"]</span>
                </button>

                <div class="auth-or"><span>@L["or"]</span></div>

                <div class="signup-link">
                    @L["Don't have an account?"] <a asp-controller="Account" asp-action="Register">@L["Create account"]</a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
    <script src="@Url.Content("~/js/auth-password-toggle.js")" asp-append-version="true"></script>
    <script>
        window.indorBindPasswordToggle('loginPassword', 'loginPasswordToggle');
    </script>
