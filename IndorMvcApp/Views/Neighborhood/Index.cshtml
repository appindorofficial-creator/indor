@model IndorMvcApp.ViewModels.NeighborhoodFeedViewModel
@{
    Layout = null;
    ViewData["Title"] = L["INDOR Neighborhood"];
    ViewBag.BottomNavActive = "nearby";
    var backUrl = (Url.Action("Index", "Home") ?? "/") + "#section-home";
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    @await Html.PartialAsync("_AppVersionHead")
    @await Html.PartialAsync("_IndorDesignHead")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/homeowner-bottom-nav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/neighborhood-feed.css" asp-append-version="true" />
</head>
<body class="nb-body">
    <header class="nb-header">
        <div class="nb-header-brand">
            <div class="nb-brand">
                <i class="fas fa-house nb-brand-icon"></i>
                <span class="nb-brand-text">INDOR</span>
            </div>
            <a href="@Model.SavedUrl" class="nb-header-bell" aria-label="@L["My Saved"]">
                <i class="far fa-bell"></i>
                @if (Model.NotificationCount > 0)
                {
                    <span class="nb-bell-dot">@Model.NotificationCount</span>
                }
            </a>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ZipCode))
        {
            <div class="nb-header-zip">
                <span><i class="fas fa-location-dot"></i> ZIP @Model.ZipCode@(string.IsNullOrWhiteSpace(Model.City) ? "" : " · " + Model.City)</span>
                <button type="button" class="nb-zip-change" id="nbZipChange" data-current="@Model.HomeZip">@L["Change ZIP"]</button>
            </div>
        }
    </header>

    <main class="nb-main">
        @if (!Model.HasProperty || string.IsNullOrWhiteSpace(Model.ZipCode))
        {
            <div class="nb-empty nb-empty--noprop">
                <i class="fas fa-house-circle-exclamation"></i>
                <p>@L["Add your home address to unlock your neighborhood feed."]</p>
                <a href="@(Url.Action("Index", "Home"))" class="nb-btn nb-btn-primary">@L["Go to My Home"]</a>
            </div>
        }
        else
        {
            <form method="get" class="nb-search" role="search">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search neighbors, services, and help"]" />
                @if (!string.Equals(Model.ActiveFilter, "All", StringComparison.OrdinalIgnoreCase))
                {
                    <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                }
                @if (!string.Equals(Model.ActiveTab, "all", StringComparison.OrdinalIgnoreCase))
                {
                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                }
                @if (Model.IsBrowsingOtherZip)
                {
                    <input type="hidden" name="zip" value="@Model.ZipCode" />
                }
            </form>

            <div class="nb-tabs" role="tablist">
                @foreach (var tab in Model.Tabs)
                {
                    <a href="@tab.Url" class="nb-tab @(tab.IsActive ? "is-active" : null)">@tab.Label</a>
                }
            </div>

            <div class="nb-chips" role="tablist">
                @foreach (var chip in Model.Filters)
                {
                    <a href="@chip.Url" class="nb-chip @(chip.IsActive ? "is-active" : null)">
                        <i class="fas @chip.Icon"></i><span>@chip.Label</span>
                    </a>
                }
            </div>

            @if (Model.IsBrowsingOtherZip)
            {
                <div class="nb-browse-banner">
                    <i class="fas fa-eye"></i>
                    <span>@L["Viewing ZIP"] @Model.ZipCode</span>
                    <a href="@(Url.Action("Index", "Neighborhood"))">@L["Back to my ZIP"]</a>
                </div>
            }

            <section class="nb-feed">
                @if (Model.Posts.Count == 0)
                {
                    <div class="nb-empty">
                        <i class="fas fa-comments"></i>
                        <p>@L["No posts yet in your ZIP code. Be the first to share something."]</p>
                    </div>
                }
                else
                {
                    @foreach (var post in Model.Posts)
                    {
                        @await Html.PartialAsync("_NeighborhoodPostCard", post)
                    }
                }
            </section>
        }
    </main>

    @if (Model.HasProperty && !string.IsNullOrWhiteSpace(Model.ZipCode))
    {
        <a href="@Model.CreatePostUrl" class="nb-fab" aria-label="@L["Create post"]">
            <i class="fas fa-plus"></i>
        </a>
    }

    @await Html.PartialAsync("_NeighborhoodBottomNav")

    <button type="button" class="nb-scroll-top" id="nbScrollTop" aria-label="@L["Back to top"]" hidden>
        <i class="fas fa-arrow-up"></i>
    </button>

    <form id="nbSaveForm" method="post" action="@(Url.Action("Save", "Neighborhood"))" hidden>
        @Html.AntiForgeryToken()
    </form>
    <form id="nbSaveCommentForm" method="post" action="@(Url.Action("SaveComment", "Neighborhood"))" hidden>
        @Html.AntiForgeryToken()
    </form>
    <form id="nbDeleteForm" method="post" action="@(Url.Action("Delete", "Neighborhood"))" hidden>
        @Html.AntiForgeryToken()
    </form>
    <form id="nbReportForm" method="post" action="@(Url.Action("Report", "Neighborhood"))" hidden>
        @Html.AntiForgeryToken()
    </form>

    <script>
        window.nbFeed = {
            changeZipPrompt: '@L["Enter a ZIP code to explore"]',
            deleteConfirm: '@L["Delete this post?"]',
            reportDone: '@L["Thanks, we received your report."]',
            copied: '@L["Link copied"]'
        };
    </script>
    <script src="~/js/neighborhood-feed.js" asp-append-version="true"></script>
</body>
</html>
