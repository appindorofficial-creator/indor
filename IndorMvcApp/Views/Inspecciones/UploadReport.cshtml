@model IndorMvcApp.ViewModels.UploadReportViewModel
@{
    ViewData["Title"] = "Upload Report - INDOR";
    ViewData["WizardTitle"] = "Upload Report";
    ViewData["WizardBackUrl"] = Url.Action("PurchaseDetails", "Inspecciones", new { id = Model.InspeccionId });

}

</div>

        <h1 class="page-heading">Upload your inspection report</h1>
        <p class="page-lead">Upload the home inspection report so INDOR can identify the priority items before scheduling.</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="UploadReport" method="post" enctype="multipart/form-data" id="uploadForm">
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="DireccionPropiedad" />

            <div class="dropzone" id="dropzone">
                <i class="fas fa-cloud-arrow-up"></i>
                <p>Drag files here or <strong>browse</strong></p>
                <p style="margin-top:6px;font-size:0.82rem;">PDF, JPG, PNG</p>
            </div>
            <input type="file" id="fileInput" name="files" class="hidden-input" multiple accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*" />

            <div class="action-list">
                <label class="action-item" for="fileInput">
                    <i class="fas fa-file-pdf"></i><span>Upload PDF</span>
                </label>
                <label class="action-item" for="fileInput">
                    <i class="fas fa-camera"></i><span>Take photo of report pages</span>
                </label>
                <label class="action-item" for="fileInput">
                    <i class="fas fa-images"></i><span>Upload screenshots</span>
                </label>
            </div>

            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="file-list">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <div class="file-item">
                            <span><i class="fas fa-paperclip"></i> @file.NombreArchivo</span>
                            <a href="@file.RutaArchivo" target="_blank" rel="noopener">View</a>
                        </div>
                    }
                </div>
            }

            <div id="selectedFiles" class="file-list"></div>

            <div class="field-card">
                <label asp-for="NotasRevision" class="field-label">What would you like us to review first? (Optional)</label>
                <textarea asp-for="NotasRevision" class="form-textarea" maxlength="250"
                          placeholder="Example: HVAC, roof leak, or electrical panel concerns..."></textarea>
                <div class="char-count"><span id="charCount">0</span>/250</div>
            </div>

            <div class="tip-box">
                <i class="fas fa-circle-info"></i>
                <div>Tip: Uploading the report first helps INDOR focus on the right issues and prepare a better assessment.</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="upload">
                Continue <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
        </form>
    </div>

    <script>
        const fileInput = document.getElementById('fileInput');
        const dropzone = document.getElementById('dropzone');
        const selectedFiles = document.getElementById('selectedFiles');
        const notes = document.querySelector('textarea[name="NotasRevision"]');
        const charCount = document.getElementById('charCount');

        function renderSelectedFiles() {
            selectedFiles.innerHTML = '';
            Array.from(fileInput.files).forEach(file => {
                const item = document.createElement('div');
                item.className = 'file-item';
                item.innerHTML = `<span><i class="fas fa-file"></i> ${file.name}</span><span>${Math.round(file.size / 1024)} KB</span>`;
                selectedFiles.appendChild(item);
            });
        }

        dropzone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', renderSelectedFiles);

        dropzone.addEventListener('dragover', e => {
            e.preventDefault();
            dropzone.classList.add('dragover');
        });
        dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
        dropzone.addEventListener('drop', e => {
            e.preventDefault();
            dropzone.classList.remove('dragover');
            fileInput.files = e.dataTransfer.files;
            renderSelectedFiles();
        });

        function updateCount() {
            charCount.textContent = (notes.value || '').length;
        }
        notes.addEventListener('input', updateCount);
        updateCount();
    
</script>
}