@model IndorMvcApp.ViewModels.EmergencyHvacContactViewModel
@{
    ViewData["Title"] = "Emergency HVAC - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 14px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 10px; display: block; }
        .address-display { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: rgba(0,102,204,0.06); font-size: 0.92rem; }
        .address-display .left { display: flex; align-items: center; gap: 10px; }
        .address-display i { color: #0066CC; }
        .dropzone { border: 2px dashed #0066CC; border-radius: 18px; background: rgba(0,102,204,0.04); padding: 28px 18px; text-align: center; margin-bottom: 14px; cursor: pointer; }
        .dropzone.dragover { background: rgba(0,102,204,0.08); }
        .dropzone i { font-size: 2rem; color: #0066CC; margin-bottom: 10px; }
        .action-list { display: grid; gap: 10px; margin-bottom: 16px; }
        .action-item { display: flex; align-items: center; gap: 12px; background: #FFF; border: 1px solid #E5E7EB; border-radius: 14px; padding: 14px 16px; cursor: pointer; }
        .action-item i.icon { color: #0066CC; width: 20px; text-align: center; font-size: 1.1rem; }
        .action-item .action-text { flex: 1; }
        .action-item .action-text strong { display: block; font-size: 0.92rem; font-weight: 600; }
        .action-item .chevron { color: #CBD5E1; }
        .form-input, .form-textarea { width: 100%; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; font-family: 'Inter', sans-serif; font-size: 0.95rem; background: #F9FAFB; color: #0A2540; }
        .input-wrap { position: relative; }
        .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #0066CC; }
        .input-wrap .form-input { padding-left: 42px; }
        .segmented-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 8px; }
        .segment-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.84rem; color: #64748B; cursor: pointer; text-align: center; }
        .segment-btn.active { background: rgba(0,102,204,0.08); border-color: #0066CC; color: #0066CC; }
        .file-list { display: grid; gap: 8px; margin-bottom: 14px; }
        .file-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; background: #F8FAFC; border-radius: 10px; padding: 10px 12px; font-size: 0.85rem; }
        .tip-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .tip-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .validation-summary { background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; border-radius: 12px; padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
        .hidden-input { display: none; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="EmergencyHvacDetails" asp-route-id="@Model.ServicioEmergenciaId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <strong>Emergency HVAC</strong>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_EmergencyHvacStepper", 2)

    <h1 class="page-heading">Add photos and contact details</h1>
    <p class="page-lead">Optional photos help, but you can finish fast.</p>

    @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <form asp-controller="Inspecciones" asp-action="EmergencyHvacContact" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="PuedeLlamarYa" id="PuedeLlamarYa" />
        <input type="hidden" asp-for="EnCasaAhora" id="EnCasaAhora" />

        <div class="field-card">
            <div class="address-display">
                <div class="left"><i class="fas fa-house"></i><span>@Model.DireccionPropiedad</span></div>
                <a asp-action="EmergencyHvacDetails" asp-route-id="@Model.ServicioEmergenciaId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;">Edit</a>
            </div>
        </div>

        <div class="dropzone" id="dropzone">
            <i class="fas fa-cloud-arrow-up"></i>
            <p><strong style="color:#0066CC;">Add photos or video</strong></p>
            <p style="margin-top:6px;font-size:0.82rem;color:#64748B;">JPG, PNG, MOV, MP4</p>
        </div>
        <input type="file" id="fileInput" name="files" class="hidden-input" multiple accept=".jpg,.jpeg,.png,.mp4,.mov,.webm,image/*,video/*" />

        <div class="action-list">
            <label class="action-item" for="fileInputCamera">
                <i class="fas fa-camera icon"></i>
                <div class="action-text"><strong>Take photo</strong></div>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <input type="file" id="fileInputCamera" class="hidden-input" accept="image/*" capture="environment" />
            <label class="action-item" for="fileInput">
                <i class="fas fa-images icon"></i>
                <div class="action-text"><strong>Upload photos</strong></div>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <label class="action-item" for="fileInputVideo">
                <i class="fas fa-video icon"></i>
                <div class="action-text"><strong>Add video</strong></div>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <input type="file" id="fileInputVideo" class="hidden-input" accept="video/*,.mp4,.mov,.webm" />
        </div>

        @if (Model.ArchivosExistentes.Count > 0)
        {
            <div class="file-list">
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="file-item">
                        <span><i class="fas fa-paperclip"></i> @file.NombreArchivo</span>
                        <a href="@file.RutaArchivo" target="_blank" rel="noopener">View</a>
                    </div>
                }
            </div>
        }

        <div id="selectedFiles" class="file-list"></div>

        <div class="field-card">
            <label asp-for="NotaCorta" class="field-label">Short note (optional)</label>
            <textarea asp-for="NotaCorta" class="form-textarea" maxlength="500" placeholder="Outdoor unit is running but the house is warm. Thermostat set to 68. No cool air coming out."></textarea>
        </div>

        <div class="field-card">
            <label asp-for="TelefonoContacto" class="field-label">Best contact number</label>
            <div class="input-wrap">
                <i class="fas fa-phone"></i>
                <input asp-for="TelefonoContacto" class="form-input" placeholder="(704) 555-0186" required />
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Can we call you right away?</span>
            <div class="segmented-3" data-target="PuedeLlamarYa">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="CallFirst">Call first</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Are you home now?</span>
            <div class="segmented-3" data-target="EnCasaAhora">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="OnMyWay">On my way</button>
            </div>
        </div>

        <div class="tip-box">
            <i class="fas fa-circle-info"></i>
            <div>Photos of the thermostat, indoor unit, outdoor condenser, and any leaking water help us respond faster.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="continue">Continue <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="skip">Skip for now</button>
    </form>
</div>
<script>
    const fileInput = document.getElementById('fileInput');
    const fileInputCamera = document.getElementById('fileInputCamera');
    const fileInputVideo = document.getElementById('fileInputVideo');
    const dropzone = document.getElementById('dropzone');
    const selectedFiles = document.getElementById('selectedFiles');
    let pendingFiles = [];

    function mergeFiles(newFiles) {
        Array.from(newFiles).forEach(f => pendingFiles.push(f));
        const dt = new DataTransfer();
        pendingFiles.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        selectedFiles.innerHTML = '';
        pendingFiles.forEach(file => {
            const item = document.createElement('div');
            item.className = 'file-item';
            item.innerHTML = `<span><i class="fas fa-file"></i> ${file.name}</span><span>${Math.round(file.size / 1024)} KB</span>`;
            selectedFiles.appendChild(item);
        });
    }

    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => mergeFiles(fileInput.files));
    fileInputCamera.addEventListener('change', () => mergeFiles(fileInputCamera.files));
    fileInputVideo.addEventListener('change', () => mergeFiles(fileInputVideo.files));
    dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', e => { e.preventDefault(); dropzone.classList.remove('dragover'); mergeFiles(e.dataTransfer.files); });

    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });
</script>
</body>
</html>
