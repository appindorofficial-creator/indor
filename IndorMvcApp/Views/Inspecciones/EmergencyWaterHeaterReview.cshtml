@model IndorMvcApp.ViewModels.EmergencyWaterHeaterReviewViewModel
@{
    ViewData["Title"] = "Review - INDOR";
    ViewData["WizardTitle"] = "Review";
var isEmergency = string.Equals(Model.UrgenciaResumen, "Emergency", StringComparison.OrdinalIgnoreCase);
    var hasPhotos = !Model.ArchivosResumen.StartsWith("None", StringComparison.OrdinalIgnoreCase);
    ViewData["WizardBackUrl"] = Url.Action("EmergencyWaterHeaterUpload", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 4;
    ViewData["WizardTotalSteps"] = 4;

}

<a asp-action="EmergencyWaterHeaterUpload" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-arrow-left"></i></a>

    <div class="title-row">
        <h1>Emergency Water Heater</h1>
        <span class="badge-247">24/7</span>
    </div>
    <p class="page-lead">Fast help for leaks, no hot water, or unsafe units.</p>

    
<h2 class="page-heading">Review your request</h2>
    <p class="page-lead" style="margin-top:-4px;">Make sure everything looks right before we dispatch help.</p>

    <form asp-controller="Inspecciones" asp-action="EmergencyWaterHeaterReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />

        <div class="summary-card">
            <div class="summary-row">
                <i class="fas fa-wrench"></i>
                <div style="flex:1;"><div class="summary-label">Service</div><div class="summary-value">@Model.TituloServicio</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-house"></i>
                <div style="flex:1;"><div class="summary-label">Property</div><div class="summary-value">@Model.DireccionPropiedad</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-droplet"></i>
                <div style="flex:1;"><div class="summary-label">Issue</div><div class="summary-value">@Model.ProblemaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-fire"></i>
                <div style="flex:1;"><div class="summary-label">Unit type</div><div class="summary-value">@Model.TipoUnidadResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-location-dot"></i>
                <div style="flex:1;"><div class="summary-label">Location</div><div class="summary-value">@Model.UbicacionResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-circle-exclamation"></i>
                <div style="flex:1;"><div class="summary-label">Priority</div><div class="summary-value @(isEmergency ? "emergency" : "")">@Model.UrgenciaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-power-off"></i>
                <div style="flex:1;"><div class="summary-label">Unit running</div><div class="summary-value">@Model.UnidadFuncionandoResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-images"></i>
                <div style="flex:1;"><div class="summary-label">Photos</div><div class="summary-value @(hasPhotos ? "photos" : "")">@Model.ArchivosResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-key"></i>
                <div style="flex:1;"><div class="summary-label">Access details</div><div class="summary-value">@Model.DetallesAcceso</div></div>
            </div>
        </div>

        <div class="disclaimer-box">
            <i class="fas fa-circle-info"></i>
            <div>If this becomes unsafe before arrival, leave the area and call emergency services if needed.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="confirm">Request emergency service <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="edit">Back to edit</button>
    </form>