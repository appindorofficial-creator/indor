@model IndorMvcApp.ViewModels.HomeSafetyPropertyContextViewModel
@{
    ViewData["Title"] = L["Home Safety Details - INDOR"];
    ViewData["WizardTitle"] = L["Home Safety Details"];
    ViewData["WizardBackUrl"] = Url.Action("HomeSafetyDetails", "Inspecciones", new { id = Model.InspeccionId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">@L["Tell us about the property"]</h1>
    <p class="page-lead">@L["A few details help us evaluate home safety more accurately."]</p>

    <form asp-controller="Inspecciones" asp-action="HomeSafetyPropertyContext" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="MotivosRevision" id="MotivosRevision" />
        <input type="hidden" asp-for="MotivoRevision" id="MotivoRevision" />
        <input type="hidden" asp-for="TipoPropiedad" id="TipoPropiedad" />
        <input type="hidden" asp-for="NumeroPisos" id="NumeroPisos" />
        <input type="hidden" asp-for="AreasEnfoque" id="AreasEnfoque" />
        <input type="hidden" asp-for="AccesoPreferido" id="AccesoPreferido" />
        <input type="hidden" asp-for="OcupantesHogar" id="OcupantesHogar" />

        <div class="field-card">
            <div class="address-summary"><i class="fas fa-house"></i><span>@Model.DireccionPropiedad</span></div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Why are you requesting this inspection?"]</span>
            <div class="chip-grid" id="motivosGroup">
                <button type="button" class="chip-btn" data-value="AnnualReview"><span class="check"><i class="fas fa-check"></i></span>@L["Annual review"]</button>
                <button type="button" class="chip-btn" data-value="ChildrenAtHome"><span class="check"><i class="fas fa-check"></i></span>@L["Children at home"]</button>
                <button type="button" class="chip-btn" data-value="BeforePurchase"><span class="check"><i class="fas fa-check"></i></span>@L["Before purchase"]</button>
                <button type="button" class="chip-btn" data-value="ElderlySafety"><span class="check"><i class="fas fa-check"></i></span>@L["Elderly safety"]</button>
                <button type="button" class="chip-btn" data-value="SecondOpinion"><span class="check"><i class="fas fa-check"></i></span>@L["Second opinion"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Property type"]</span>
            <div class="chip-grid" data-target="TipoPropiedad">
                <button type="button" class="chip-btn" data-value="SingleFamily"><span class="check"><i class="fas fa-check"></i></span>@L["Single-family"]</button>
                <button type="button" class="chip-btn" data-value="Townhome"><span class="check"><i class="fas fa-check"></i></span>@L["Townhome"]</button>
                <button type="button" class="chip-btn" data-value="Condo"><span class="check"><i class="fas fa-check"></i></span>@L["Condo"]</button>
                <button type="button" class="chip-btn" data-value="Apartment"><span class="check"><i class="fas fa-check"></i></span>@L["Apartment"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How many stories?"]</span>
            <div class="chip-grid" data-target="NumeroPisos">
                <button type="button" class="chip-btn" data-value="OneStory"><span class="check"><i class="fas fa-check"></i></span>@L["1 story"]</button>
                <button type="button" class="chip-btn" data-value="TwoStory"><span class="check"><i class="fas fa-check"></i></span>@L["2 story"]</button>
                <button type="button" class="chip-btn" data-value="ThreePlus"><span class="check"><i class="fas fa-check"></i></span>@L["3+ story"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Main area to evaluate"]</span>
            <div class="chip-grid" id="enfoqueGroup">
                <button type="button" class="chip-btn" data-value="SmokeCoDetectors"><span class="check"><i class="fas fa-check"></i></span>@L["Smoke / CO detectors"]</button>
                <button type="button" class="chip-btn" data-value="WholeHouse"><span class="check"><i class="fas fa-check"></i></span>@L["Whole house"]</button>
                <button type="button" class="chip-btn" data-value="StairsRailings"><span class="check"><i class="fas fa-check"></i></span>@L["Stairs &amp; railings"]</button>
                <button type="button" class="chip-btn" data-value="DoorsExits"><span class="check"><i class="fas fa-check"></i></span>@L["Doors &amp; exits"]</button>
                <button type="button" class="chip-btn" data-value="GarageSafety"><span class="check"><i class="fas fa-check"></i></span>@L["Garage safety"]</button>
                <button type="button" class="chip-btn" data-value="KitchenSafety"><span class="check"><i class="fas fa-check"></i></span>@L["Kitchen safety"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Access available"]</span>
            <div class="chip-grid" data-target="AccesoPreferido">
                <button type="button" class="chip-btn" data-value="SomeoneHome"><span class="check"><i class="fas fa-check"></i></span>@L["Someone home"]</button>
                <button type="button" class="chip-btn" data-value="Lockbox"><span class="check"><i class="fas fa-check"></i></span>@L["Lockbox"]</button>
                <button type="button" class="chip-btn" data-value="RealtorAccess"><span class="check"><i class="fas fa-check"></i></span>@L["Realtor access"]</button>
                <button type="button" class="chip-btn" data-value="Vacant"><span class="check"><i class="fas fa-check"></i></span>@L["Vacant"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Who lives in the home?"]</span>
            <div class="chip-grid" id="ocupantesGroup">
                <button type="button" class="chip-btn" data-value="Children"><span class="check"><i class="fas fa-check"></i></span>@L["Children"]</button>
                <button type="button" class="chip-btn" data-value="Adults"><span class="check"><i class="fas fa-check"></i></span>@L["Adults"]</button>
                <button type="button" class="chip-btn" data-value="Seniors"><span class="check"><i class="fas fa-check"></i></span>@L["Seniors"]</button>
                <button type="button" class="chip-btn" data-value="Pets"><span class="check"><i class="fas fa-check"></i></span>@L["Pets"]</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>@L["Photos of detectors, stairways, child safety areas, and visible hazards can help speed up the review."]</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-secondary" name="action" value="back">@L["Back"]</button>
    </form>

@section Scripts {
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll('.chip-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initMulti(groupId, hiddenId, primaryId, defaultValues){
        const hidden = document.getElementById(hiddenId);
        const primary = primaryId ? document.getElementById(primaryId) : null;
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = defaultValues.slice();
        function render(){
            document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            if (primary) primary.value = selected[0] || defaultValues[0];
        }
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    }
    initMulti('motivosGroup', 'MotivosRevision', 'MotivoRevision', ['AnnualReview']);
    initMulti('enfoqueGroup', 'AreasEnfoque', null, ['SmokeCoDetectors']);
    initMulti('ocupantesGroup', 'OcupantesHogar', null, ['Children']);
    document.querySelectorAll('.chip-grid[data-target]').forEach(group => {
        const hidden = document.getElementById(group.dataset.target);
        group.querySelectorAll('.chip-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, btn.dataset.value)));
        setSingle(group, hidden.value);
    });

</script>
}