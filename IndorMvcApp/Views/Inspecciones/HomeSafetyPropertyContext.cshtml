@model IndorMvcApp.ViewModels.HomeSafetyPropertyContextViewModel
@{
    ViewData["Title"] = "Home Safety Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .address-summary { display: flex; align-items: center; gap: 10px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: #F9FAFB; padding: 14px 16px; font-size: 0.92rem; }
        .address-summary i { color: #0066CC; }
        .chip-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .chip-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 10px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; position: relative; line-height: 1.3; }
        .chip-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .chip-btn .check { position: absolute; top: 8px; right: 8px; width: 18px; height: 18px; border-radius: 50%; background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.6rem; }
        .chip-btn.active .check { display: flex; }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; }
        .btn-primary, .btn-secondary { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-secondary { margin-top: 10px; border: none; background: transparent; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="HomeSafetyDetails" asp-route-id="@Model.InspeccionId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <strong>Home Safety Details</strong>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_HomeSafetyStepper", 2)

    <h1 class="page-heading">Tell us about the property</h1>
    <p class="page-lead">A few details help us evaluate home safety more accurately.</p>

    <form asp-controller="Inspecciones" asp-action="HomeSafetyPropertyContext" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="MotivosRevision" id="MotivosRevision" />
        <input type="hidden" asp-for="MotivoRevision" id="MotivoRevision" />
        <input type="hidden" asp-for="TipoPropiedad" id="TipoPropiedad" />
        <input type="hidden" asp-for="NumeroPisos" id="NumeroPisos" />
        <input type="hidden" asp-for="AreasEnfoque" id="AreasEnfoque" />
        <input type="hidden" asp-for="AccesoPreferido" id="AccesoPreferido" />
        <input type="hidden" asp-for="OcupantesHogar" id="OcupantesHogar" />

        <div class="field-card">
            <div class="address-summary"><i class="fas fa-house"></i><span>@Model.DireccionPropiedad</span></div>
        </div>

        <div class="field-card">
            <span class="field-label">Why are you requesting this inspection?</span>
            <div class="chip-grid" id="motivosGroup">
                <button type="button" class="chip-btn" data-value="AnnualReview"><span class="check"><i class="fas fa-check"></i></span>Annual review</button>
                <button type="button" class="chip-btn" data-value="ChildrenAtHome"><span class="check"><i class="fas fa-check"></i></span>Children at home</button>
                <button type="button" class="chip-btn" data-value="BeforePurchase"><span class="check"><i class="fas fa-check"></i></span>Before purchase</button>
                <button type="button" class="chip-btn" data-value="ElderlySafety"><span class="check"><i class="fas fa-check"></i></span>Elderly safety</button>
                <button type="button" class="chip-btn" data-value="SecondOpinion"><span class="check"><i class="fas fa-check"></i></span>Second opinion</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Property type</span>
            <div class="chip-grid" data-target="TipoPropiedad">
                <button type="button" class="chip-btn" data-value="SingleFamily"><span class="check"><i class="fas fa-check"></i></span>Single-family</button>
                <button type="button" class="chip-btn" data-value="Townhome"><span class="check"><i class="fas fa-check"></i></span>Townhome</button>
                <button type="button" class="chip-btn" data-value="Condo"><span class="check"><i class="fas fa-check"></i></span>Condo</button>
                <button type="button" class="chip-btn" data-value="Apartment"><span class="check"><i class="fas fa-check"></i></span>Apartment</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How many stories?</span>
            <div class="chip-grid" data-target="NumeroPisos">
                <button type="button" class="chip-btn" data-value="OneStory"><span class="check"><i class="fas fa-check"></i></span>1 story</button>
                <button type="button" class="chip-btn" data-value="TwoStory"><span class="check"><i class="fas fa-check"></i></span>2 story</button>
                <button type="button" class="chip-btn" data-value="ThreePlus"><span class="check"><i class="fas fa-check"></i></span>3+ story</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Main area to evaluate</span>
            <div class="chip-grid" id="enfoqueGroup">
                <button type="button" class="chip-btn" data-value="SmokeCoDetectors"><span class="check"><i class="fas fa-check"></i></span>Smoke / CO detectors</button>
                <button type="button" class="chip-btn" data-value="WholeHouse"><span class="check"><i class="fas fa-check"></i></span>Whole house</button>
                <button type="button" class="chip-btn" data-value="StairsRailings"><span class="check"><i class="fas fa-check"></i></span>Stairs &amp; railings</button>
                <button type="button" class="chip-btn" data-value="DoorsExits"><span class="check"><i class="fas fa-check"></i></span>Doors &amp; exits</button>
                <button type="button" class="chip-btn" data-value="GarageSafety"><span class="check"><i class="fas fa-check"></i></span>Garage safety</button>
                <button type="button" class="chip-btn" data-value="KitchenSafety"><span class="check"><i class="fas fa-check"></i></span>Kitchen safety</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Access available</span>
            <div class="chip-grid" data-target="AccesoPreferido">
                <button type="button" class="chip-btn" data-value="SomeoneHome"><span class="check"><i class="fas fa-check"></i></span>Someone home</button>
                <button type="button" class="chip-btn" data-value="Lockbox"><span class="check"><i class="fas fa-check"></i></span>Lockbox</button>
                <button type="button" class="chip-btn" data-value="RealtorAccess"><span class="check"><i class="fas fa-check"></i></span>Realtor access</button>
                <button type="button" class="chip-btn" data-value="Vacant"><span class="check"><i class="fas fa-check"></i></span>Vacant</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Who lives in the home?</span>
            <div class="chip-grid" id="ocupantesGroup">
                <button type="button" class="chip-btn" data-value="Children"><span class="check"><i class="fas fa-check"></i></span>Children</button>
                <button type="button" class="chip-btn" data-value="Adults"><span class="check"><i class="fas fa-check"></i></span>Adults</button>
                <button type="button" class="chip-btn" data-value="Seniors"><span class="check"><i class="fas fa-check"></i></span>Seniors</button>
                <button type="button" class="chip-btn" data-value="Pets"><span class="check"><i class="fas fa-check"></i></span>Pets</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>Photos of detectors, stairways, child safety areas, and visible hazards can help speed up the review.</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-secondary" name="action" value="back">Back</button>
    </form>
</div>
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll('.chip-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initMulti(groupId, hiddenId, primaryId, defaultValues){
        const hidden = document.getElementById(hiddenId);
        const primary = primaryId ? document.getElementById(primaryId) : null;
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = defaultValues.slice();
        function render(){
            document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            if (primary) primary.value = selected[0] || defaultValues[0];
        }
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    }
    initMulti('motivosGroup', 'MotivosRevision', 'MotivoRevision', ['AnnualReview']);
    initMulti('enfoqueGroup', 'AreasEnfoque', null, ['SmokeCoDetectors']);
    initMulti('ocupantesGroup', 'OcupantesHogar', null, ['Children']);
    document.querySelectorAll('.chip-grid[data-target]').forEach(group => {
        const hidden = document.getElementById(group.dataset.target);
        group.querySelectorAll('.chip-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, btn.dataset.value)));
        setSingle(group, hidden.value);
    });
</script>
</body>
</html>
