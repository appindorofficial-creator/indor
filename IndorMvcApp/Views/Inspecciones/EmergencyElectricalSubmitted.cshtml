@model IndorMvcApp.ViewModels.EmergencyElectricalSubmittedViewModel
@{
    ViewData["Title"] = "Request received - INDOR";
    ViewData["WizardTitle"] = "Request received";
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading">Request received</h1>
    <p class="page-lead">Your emergency electrical request is being reviewed and dispatched.</p>

    <div class="summary-card">
        <div class="summary-row">
            <i class="fas fa-plug"></i>
            <div style="flex:1;"><div class="summary-label">Service</div><div class="summary-value">@Model.TituloServicio</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-location-dot"></i>
            <div style="flex:1;"><div class="summary-label">Property</div><div class="summary-value">@Model.DireccionPropiedad</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-triangle-exclamation danger"></i>
            <div style="flex:1;"><div class="summary-label">Concern</div><div class="summary-value">@Model.ProblemaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-house"></i>
            <div style="flex:1;"><div class="summary-label">Area</div><div class="summary-value">@Model.AreaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-bolt"></i>
            <div style="flex:1;"><div class="summary-label">Power status</div><div class="summary-value">@Model.EnergiaEncendidaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-arrow-down danger"></i>
            <div style="flex:1;"><div class="summary-label">Breaker shut off</div><div class="summary-value">@Model.PuedeApagarBreakerResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-headset"></i>
            <div style="flex:1;"><div class="summary-label">Status</div><div class="summary-value"><span class="status-pill">@Model.EstadoResumen</span></div></div>
        </div>
    </div>

    <div class="timing-card">
        <div class="timing-box">
            <div class="label">Estimated callback</div>
            <div class="value">@Model.CallbackRango</div>
        </div>
        <div class="timing-box">
            <div class="label">Avg. arrival</div>
            <div class="value">@Model.TiempoLlegadaRango</div>
        </div>
    </div>

    <div class="info-box">
        <i class="fas fa-shield-halved"></i>
        <div>If the situation gets worse, leave the area and call 911 or emergency support immediately.</div>
    </div>

    <a asp-action="EmergencyElectricalSubmitted" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-file-lines"></i> View request</a>
    <a href="tel:+17045550186" class="btn-outline"><i class="fas fa-phone"></i> Call support</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> Go home</a>