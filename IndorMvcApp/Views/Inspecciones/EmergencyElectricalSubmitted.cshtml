@model IndorMvcApp.ViewModels.EmergencyElectricalSubmittedViewModel
@{
    ViewData["Title"] = L["Request received - INDOR"];
    ViewData["WizardTitle"] = L["Request received"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading">@L["Request received"]</h1>
    <p class="page-lead">@L["Your emergency electrical request is being reviewed and dispatched."]</p>

    <div class="summary-card">
        <div class="summary-row">
            <i class="fas fa-plug"></i>
            <div style="flex:1;"><div class="summary-label">@L["Service"]</div><div class="summary-value">@L.Catalog(Model.TituloServicio)</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-location-dot"></i>
            <div style="flex:1;"><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-triangle-exclamation danger"></i>
            <div style="flex:1;"><div class="summary-label">@L["Concern"]</div><div class="summary-value">@L.Catalog(Model.ProblemaResumen)</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-house"></i>
            <div style="flex:1;"><div class="summary-label">@L["Area"]</div><div class="summary-value">@Model.AreaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-bolt"></i>
            <div style="flex:1;"><div class="summary-label">@L["Power status"]</div><div class="summary-value">@Model.EnergiaEncendidaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-arrow-down danger"></i>
            <div style="flex:1;"><div class="summary-label">@L["Breaker shut off"]</div><div class="summary-value">@Model.PuedeApagarBreakerResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-headset"></i>
            <div style="flex:1;"><div class="summary-label">@L["Status"]</div><div class="summary-value"><span class="status-pill">@L.Catalog(Model.EstadoResumen)</span></div></div>
        </div>
    </div>

    <div class="timing-card">
        <div class="timing-box">
            <div class="label">@L["Estimated callback"]</div>
            <div class="value">@Model.CallbackRango</div>
        </div>
        <div class="timing-box">
            <div class="label">@L["Avg. arrival"]</div>
            <div class="value">@Model.TiempoLlegadaRango</div>
        </div>
    </div>

    <div class="info-box">
        <i class="fas fa-shield-halved"></i>
        <div>@L["If the situation gets worse, leave the area and call 911 or emergency support immediately."]</div>
    </div>

    <a asp-action="EmergencyElectricalSubmitted" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-file-lines"></i> @L["View request"]</a>
    <a href="tel:+17045550186" class="btn-outline"><i class="fas fa-phone"></i> @L["Call support"]</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Go home"]</a>