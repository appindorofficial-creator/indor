@model IndorMvcApp.ViewModels.EmergencyFloodUploadViewModel
@{
    ViewData["Title"] = "Flood Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: inline-flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; margin-bottom: 12px; }
        .title-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
        .title-row h1 { font-size: 1.2rem; font-weight: 800; }
        .badge-247 { background: rgba(220,38,38,0.1); color: #DC2626; font-size: 0.68rem; font-weight: 700; padding: 4px 8px; border-radius: 999px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 8px; }
        .address-display { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: rgba(0,102,204,0.06); font-size: 0.92rem; margin-bottom: 14px; }
        .address-display i { color: #0066CC; margin-right: 8px; }
        .dropzone { border: 2px dashed #0066CC; border-radius: 18px; background: rgba(0,102,204,0.04); padding: 28px 18px; text-align: center; margin-bottom: 14px; cursor: pointer; }
        .dropzone.dragover { background: rgba(0,102,204,0.08); }
        .dropzone i { font-size: 2rem; color: #0066CC; margin-bottom: 10px; }
        .action-list { display: grid; gap: 10px; margin-bottom: 16px; }
        .action-item { display: flex; align-items: center; gap: 12px; background: #FFF; border: 1px solid #E5E7EB; border-radius: 14px; padding: 14px 16px; cursor: pointer; }
        .action-item i.icon { color: #0066CC; width: 20px; text-align: center; font-size: 1.1rem; }
        .action-item .action-text { flex: 1; }
        .action-item .action-text strong { display: block; font-size: 0.92rem; font-weight: 600; }
        .action-item .chevron { color: #CBD5E1; }
        .form-textarea { width: 100%; min-height: 100px; padding: 14px; border: 1.5px solid #E5E7EB; border-radius: 12px; font-family: 'Inter', sans-serif; font-size: 0.92rem; resize: vertical; background: #F9FAFB; }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 10px; display: block; }
        .tip-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .tip-box i { color: #0066CC; margin-right: 8px; }
        .file-list { display: grid; gap: 8px; margin-bottom: 14px; }
        .file-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; background: #F8FAFC; border-radius: 10px; padding: 10px 12px; font-size: 0.85rem; }
        .validation-summary { background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; border-radius: 12px; padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
        .hidden-input { display: none; }
    </style>
</head>
<body>
<div class="page-container">
    <a asp-action="EmergencyFloodSafety" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-arrow-left"></i></a>

    <div class="title-row">
        <h1>Flood Details</h1>
        <span class="badge-247">24/7</span>
    </div>
    <p class="page-lead">Photos help the provider understand the situation before arrival.</p>

    @await Html.PartialAsync("_EmergencyFloodStepper", 3)

    <h2 class="page-heading">Add photos and a quick note</h2>

    @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <form asp-controller="Inspecciones" asp-action="EmergencyFloodUpload" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />

        <div class="address-display">
            <span><i class="fas fa-house"></i>@Model.DireccionPropiedad</span>
        </div>

        <div class="dropzone" id="dropzone">
            <i class="fas fa-cloud-arrow-up"></i>
            <p><strong style="color:#0066CC;">Drag files here or browse</strong></p>
            <p style="margin-top:6px;font-size:0.82rem;color:#64748B;">JPG, PNG, PDF up to 25 MB each</p>
        </div>
        <input type="file" id="fileInput" name="files" class="hidden-input" multiple accept=".pdf,.jpg,.jpeg,.png,.mp4,.mov,.webm,application/pdf,image/*,video/*" />

        <div class="action-list">
            <label class="action-item" for="fileInputCamera">
                <i class="fas fa-camera icon"></i>
                <div class="action-text"><strong>Take photo</strong></div>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <input type="file" id="fileInputCamera" class="hidden-input" accept="image/*" capture="environment" />
            <label class="action-item" for="fileInput">
                <i class="fas fa-images icon"></i>
                <div class="action-text"><strong>Upload photos</strong></div>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <label class="action-item" for="fileInputVideo">
                <i class="fas fa-video icon"></i>
                <div class="action-text"><strong>Add video</strong></div>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <input type="file" id="fileInputVideo" class="hidden-input" accept="video/*,.mp4,.mov,.webm" />
        </div>

        @if (Model.ArchivosExistentes.Count > 0)
        {
            <div class="file-list">
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="file-item">
                        <span><i class="fas fa-paperclip"></i> @file.NombreArchivo</span>
                        <a href="@file.RutaArchivo" target="_blank" rel="noopener">View</a>
                    </div>
                }
            </div>
        }

        <div id="selectedFiles" class="file-list"></div>

        <label asp-for="NotaCorta" class="field-label">Tell us anything important</label>
        <textarea asp-for="NotaCorta" class="form-textarea" maxlength="500" placeholder="Water is coming from under the sink and spreading into the kitchen and hallway."></textarea>

        <div class="tip-box">
            <i class="fas fa-circle-info"></i>
            Include where the water started, how long it has been happening, and any damage already visible.
        </div>

        <button type="submit" class="btn-primary" name="action" value="continue">Continue <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="skip">Skip for now</button>
    </form>
</div>
<script>
    const fileInput = document.getElementById('fileInput');
    const fileInputCamera = document.getElementById('fileInputCamera');
    const fileInputVideo = document.getElementById('fileInputVideo');
    const dropzone = document.getElementById('dropzone');
    const selectedFiles = document.getElementById('selectedFiles');
    let pendingFiles = [];
    function mergeFiles(newFiles) {
        Array.from(newFiles).forEach(f => pendingFiles.push(f));
        const dt = new DataTransfer();
        pendingFiles.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        selectedFiles.innerHTML = '';
        pendingFiles.forEach(file => {
            const item = document.createElement('div');
            item.className = 'file-item';
            item.innerHTML = `<span><i class="fas fa-file"></i> ${file.name}</span><span>${Math.round(file.size / 1024)} KB</span>`;
            selectedFiles.appendChild(item);
        });
    }
    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => mergeFiles(fileInput.files));
    fileInputCamera.addEventListener('change', () => mergeFiles(fileInputCamera.files));
    fileInputVideo.addEventListener('change', () => mergeFiles(fileInputVideo.files));
    dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', e => { e.preventDefault(); dropzone.classList.remove('dragover'); mergeFiles(e.dataTransfer.files); });
</script>
</body>
</html>
