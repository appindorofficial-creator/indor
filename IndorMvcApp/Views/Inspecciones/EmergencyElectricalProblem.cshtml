@model IndorMvcApp.ViewModels.EmergencyElectricalProblemViewModel
@{
    ViewData["Title"] = L["Electrical emergency - INDOR"];
    ViewData["WizardTitle"] = L["Electrical emergency"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;

}

<h1 class="page-heading">@L["Tell us what's happening"]</h1>
    <p class="page-lead">@L["Tell us what's happening so we can send the right help fast."]</p>

    <form asp-controller="Inspecciones" asp-action="EmergencyElectricalProblem" method="post">
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />
        <input type="hidden" asp-for="PuedeApagarBreaker" id="PuedeApagarBreaker" />

        <div class="field-card">
            <div class="address-display">
                <div class="left">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" placeholder="@L["123 Riverside Dr, Mount Holly, NC 28120"]" required />
                </div>
                <span style="color:#0066CC;font-weight:600;font-size:0.85rem;">@L["Edit"]</span>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What best describes the problem?"]</span>
            <div class="issue-grid" id="issueGroup">
                <button type="button" class="issue-btn" data-value="NoPower"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-bolt issue-icon"></i>@L["No power"]</button>
                <button type="button" class="issue-btn" data-value="PartialOutage"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-gauge-high issue-icon"></i>@L["Partial outage"]</button>
                <button type="button" class="issue-btn" data-value="BreakerTripping"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-plug issue-icon"></i>@L["Breaker keeps tripping"]</button>
                <button type="button" class="issue-btn" data-value="OutletSwitch"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-plug issue-icon"></i>@L["Outlet / switch issue"]</button>
                <button type="button" class="issue-btn" data-value="SparksBurning"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-fire issue-icon"></i>@L["Sparks or burning smell"]</button>
                <button type="button" class="issue-btn" data-value="PanelIssue"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-table-columns issue-icon"></i>@L["Panel issue"]</button>
                <button type="button" class="issue-btn" data-value="ExposedWire"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-code-branch issue-icon"></i>@L["Exposed wire"]</button>
                <button type="button" class="issue-btn" data-value="Other"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-ellipsis issue-icon"></i>@L["Other"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How urgent is it?"]</span>
            <div class="urgency-grid" data-target="Urgencia">
                <button type="button" class="urgency-btn" data-value="Priority">@L["Priority"]</button>
                <button type="button" class="urgency-btn" data-value="Urgent">@L["Urgent"]</button>
                <button type="button" class="urgency-btn" data-value="Emergency">@L["Emergency"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Can you safely turn off the breaker?"]</span>
            <div class="segmented-3" data-target="PuedeApagarBreaker">
                <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                <button type="button" class="segment-btn" data-value="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-shield-halved"></i>
            <div>@L["If you see smoke, fire, or active sparking, move away and call"] <strong>911</strong> @L["first."]</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"]</button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-camera"></i> @L["Add photo first"]</button>
    </form>
</div>
@section Scripts {
<script>
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('#issueGroup .issue-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('TipoProblema').value = btn.dataset.value;
            document.querySelectorAll('#issueGroup .issue-btn').forEach(b => b.classList.toggle('active', b === btn));
        });
        if (btn.dataset.value === document.getElementById('TipoProblema').value) btn.classList.add('active');
    });
    document.querySelectorAll('.segmented-3, .urgency-grid').forEach(group => {
        const selector = group.classList.contains('urgency-grid') ? '.urgency-btn' : '.segment-btn';
        group.querySelectorAll(selector).forEach(btn => btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value)));
        setSingle(group, selector, document.getElementById(group.dataset.target).value);
    });

</script>
}