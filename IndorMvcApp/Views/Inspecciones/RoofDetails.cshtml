@model IndorMvcApp.ViewModels.RoofDetailsViewModel
@{
    ViewData["Title"] = L["Roof Details - INDOR"];
    ViewData["WizardTitle"] = L["Roof Details"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">@L["Tell us about your roof concern"]</h1>
    <p class="page-lead">@L["This helps us send the right provider and prepare the inspection faster."]</p>

    <form asp-controller="Inspecciones" asp-action="RoofDetails" method="post">
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="TiposProblema" id="TiposProblema" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />

        <div class="field-card">
            <label asp-for="DireccionPropiedad" class="field-label">@L["Property address"]</label>
            <div class="address-summary" style="padding:0;border:none;background:transparent;">
                <div class="left" style="flex:1;">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" style="border:none;background:transparent;padding:0;font-weight:600;width:100%;" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What's the main issue?"]</span>
            <div class="chip-grid" id="tiposGroup">
                <button type="button" class="chip-btn" data-value="ActiveLeak"><span class="check"><i class="fas fa-check"></i></span>@L["Active leak"]</button>
                <button type="button" class="chip-btn" data-value="MissingShingles"><span class="check"><i class="fas fa-check"></i></span>@L["Missing shingles"]</button>
                <button type="button" class="chip-btn" data-value="StormDamage"><span class="check"><i class="fas fa-check"></i></span>@L["Storm damage"]</button>
                <button type="button" class="chip-btn" data-value="CeilingStain"><span class="check"><i class="fas fa-check"></i></span>@L["Ceiling stain"]</button>
                <button type="button" class="chip-btn" data-value="GutterIssue"><span class="check"><i class="fas fa-check"></i></span>@L["Gutter issue"]</button>
                <button type="button" class="chip-btn" data-value="GeneralReview"><span class="check"><i class="fas fa-check"></i></span>@L["General review"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Where is it happening?"]</span>
            <div class="chip-grid" data-target="UbicacionProblema" data-multi="false">
                <button type="button" class="chip-btn" data-value="MainRoof"><span class="check"><i class="fas fa-check"></i></span>@L["Main roof"]</button>
                <button type="button" class="chip-btn" data-value="AroundChimney"><span class="check"><i class="fas fa-check"></i></span>@L["Around chimney"]</button>
                <button type="button" class="chip-btn" data-value="AroundVent"><span class="check"><i class="fas fa-check"></i></span>@L["Around vent"]</button>
                <button type="button" class="chip-btn" data-value="GutterEdge"><span class="check"><i class="fas fa-check"></i></span>@L["Gutter / edge"]</button>
                <button type="button" class="chip-btn" data-value="AtticCeiling"><span class="check"><i class="fas fa-check"></i></span>@L["Attic / ceiling"]</button>
                <button type="button" class="chip-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span>@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How urgent is it?"]</span>
            <div class="segmented-3" data-target="Urgencia">
                <button type="button" class="segment-btn" data-value="Normal">@L["Normal"]</button>
                <button type="button" class="segment-btn" data-value="Priority">@L["Priority"]</button>
                <button type="button" class="segment-btn emergency" data-value="Emergency">@L["Emergency"]</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>@L["If there is active leaking or visible storm damage, upload photos in the next step for a faster review."]</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-camera"></i> @L["Upload photos or report"]</button>
    </form>

@section Scripts {
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, selector, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    (function initMulti(){
        const hidden = document.getElementById('TiposProblema');
        const primary = document.getElementById('TipoProblema');
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = ['ActiveLeak'];
        function render(){
            document.querySelectorAll('#tiposGroup .chip-btn').forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            primary.value = selected[0] || 'ActiveLeak';
        }
        document.querySelectorAll('#tiposGroup .chip-btn').forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    })();
    document.querySelectorAll('[data-target="UbicacionProblema"]').forEach(group => {
        group.querySelectorAll('.chip-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.chip-btn', btn.dataset.value)));
        setSingle(group, '.chip-btn', document.getElementById('UbicacionProblema').value);
    });
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById('Urgencia').value);
    });

</script>
}