@model IndorMvcApp.ViewModels.EmergencyFloodReviewViewModel
@{
    ViewData["Title"] = "Review - INDOR";
    Layout = null;
    var hasPhotos = !Model.ArchivosResumen.StartsWith("None", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: inline-flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; margin-bottom: 12px; }
        .title-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
        .title-row h1 { font-size: 1.2rem; font-weight: 800; }
        .badge-247 { background: rgba(220,38,38,0.1); color: #DC2626; font-size: 0.68rem; font-weight: 700; padding: 4px 8px; border-radius: 999px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 8px; }
        .summary-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .summary-row { display: flex; align-items: flex-start; gap: 12px; padding: 14px 0; border-bottom: 1px solid #E5E7EB; }
        .summary-row:last-child { border-bottom: none; }
        .summary-row i { color: #0066CC; width: 18px; margin-top: 2px; text-align: center; }
        .summary-label { font-size: 0.78rem; color: #94A3B8; margin-bottom: 4px; font-weight: 600; }
        .summary-value { font-size: 0.9rem; font-weight: 600; color: #0A2540; line-height: 1.4; }
        .summary-value.photos { color: #0066CC; }
        .disclaimer-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.84rem; line-height: 1.45; color: #334155; }
        .disclaimer-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <a asp-action="EmergencyFloodUpload" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-arrow-left"></i></a>

    <div class="title-row">
        <h1>Flood Details</h1>
        <span class="badge-247">24/7</span>
    </div>
    <p class="page-lead">Make sure everything looks right before we dispatch help.</p>

    @await Html.PartialAsync("_EmergencyFloodStepper", 4)

    <h2 class="page-heading">Review your request</h2>

    <form asp-controller="Inspecciones" asp-action="EmergencyFloodReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />

        <div class="summary-card">
            <div class="summary-row">
                <i class="fas fa-water"></i>
                <div style="flex:1;"><div class="summary-label">Service</div><div class="summary-value">@Model.TituloServicio</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-house"></i>
                <div style="flex:1;"><div class="summary-label">Property</div><div class="summary-value">@Model.DireccionPropiedad</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-droplet"></i>
                <div style="flex:1;"><div class="summary-label">Water source</div><div class="summary-value">@Model.CausaAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-location-dot"></i>
                <div style="flex:1;"><div class="summary-label">Area</div><div class="summary-value">@Model.UbicacionAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-faucet-drip"></i>
                <div style="flex:1;"><div class="summary-label">Shutoff status</div><div class="summary-value">@Model.PuedeCerrarAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-bolt"></i>
                <div style="flex:1;"><div class="summary-label">Power near water</div><div class="summary-value">@Model.PuedeApagarElectricidadResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-water"></i>
                <div style="flex:1;"><div class="summary-label">Amount of water</div><div class="summary-value">@Model.CantidadAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-circle-exclamation"></i>
                <div style="flex:1;"><div class="summary-label">Water active</div><div class="summary-value">@Model.AguaActivaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-images"></i>
                <div style="flex:1;"><div class="summary-label">Photos</div><div class="summary-value @(hasPhotos ? "photos" : "")">@Model.ArchivosResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-note-sticky"></i>
                <div style="flex:1;"><div class="summary-label">Note</div><div class="summary-value">@Model.NotaCorta</div></div>
            </div>
        </div>

        <div class="disclaimer-box">
            <i class="fas fa-circle-info"></i>
            <div>If water reaches electrical outlets, avoid the area and wait for professional help.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="confirm">Request emergency service <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="edit">Back to edit</button>
    </form>
</div>
</body>
</html>
