@model IndorMvcApp.ViewModels.EmergencyFloodReviewViewModel
@{
    ViewData["Title"] = L["Review - INDOR"];
    ViewData["WizardTitle"] = L["Review"];
var hasPhotos = !Model.ArchivosResumen.StartsWith("None", StringComparison.OrdinalIgnoreCase);
    ViewData["WizardBackUrl"] = Url.Action("EmergencyFloodUpload", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 4;
    ViewData["WizardTotalSteps"] = 4;

}


    <div class="title-row">
        <h1>@L["Flood Details"]</h1>
        <span class="badge-247">24/7</span>
    </div>
    <p class="page-lead">@L["Make sure everything looks right before we dispatch help."]</p>

    
<h2 class="page-heading">@L["Review your request"]</h2>

    <form asp-controller="Inspecciones" asp-action="EmergencyFloodReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />

        <div class="summary-card">
            <div class="summary-row">
                <i class="fas fa-water"></i>
                <div style="flex:1;"><div class="summary-label">@L["Service"]</div><div class="summary-value">@L.Catalog(Model.TituloServicio)</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-house"></i>
                <div style="flex:1;"><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-droplet"></i>
                <div style="flex:1;"><div class="summary-label">@L["Water source"]</div><div class="summary-value">@L.Catalog(Model.CausaAguaResumen)</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-location-dot"></i>
                <div style="flex:1;"><div class="summary-label">@L["Area"]</div><div class="summary-value">@Model.UbicacionAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-faucet-drip"></i>
                <div style="flex:1;"><div class="summary-label">@L["Shutoff status"]</div><div class="summary-value">@Model.PuedeCerrarAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-bolt"></i>
                <div style="flex:1;"><div class="summary-label">@L["Power near water"]</div><div class="summary-value">@Model.PuedeApagarElectricidadResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-water"></i>
                <div style="flex:1;"><div class="summary-label">@L["Amount of water"]</div><div class="summary-value">@Model.CantidadAguaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-circle-exclamation"></i>
                <div style="flex:1;"><div class="summary-label">@L["Water active"]</div><div class="summary-value">@Model.AguaActivaResumen</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-images"></i>
                <div style="flex:1;"><div class="summary-label">@L["Photos"]</div><div class="summary-value @(hasPhotos ? "photos" : "")">@UiDisplayLocalization.Localize(L, Model.ArchivosResumen)</div></div>
            </div>
            <div class="summary-row">
                <i class="fas fa-note-sticky"></i>
                <div style="flex:1;"><div class="summary-label">@L["Note"]</div><div class="summary-value">@Model.NotaCorta</div></div>
            </div>
        </div>

        <div class="disclaimer-box">
            <i class="fas fa-circle-info"></i>
            <div>@L["If water reaches electrical outlets, avoid the area and wait for professional help."]</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="confirm">@L["Request emergency service"] <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="edit">@L["Back to edit"]</button>
    </form>