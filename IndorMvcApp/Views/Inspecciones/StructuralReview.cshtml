@model IndorMvcApp.ViewModels.StructuralReviewViewModel
@{
    ViewData["Title"] = "Review & Confirm - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .service-card, .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .service-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
        .service-name { font-size: 1rem; font-weight: 800; }
        .service-subtitle { font-size: 0.85rem; color: #64748B; margin-top: 4px; }
        .service-price { font-size: 1.05rem; font-weight: 800; color: #0066CC; white-space: nowrap; }
        .section-title { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; }
        .chip-list { display: flex; flex-wrap: wrap; gap: 8px; }
        .chip { padding: 8px 10px; border-radius: 999px; background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.2); color: #0066CC; font-size: 0.78rem; font-weight: 600; }
        .detail-row { display: flex; justify-content: space-between; gap: 12px; padding: 10px 0; border-bottom: 1px solid #E5E7EB; }
        .detail-row:last-child { border-bottom: none; }
        .detail-label { font-size: 0.82rem; color: #64748B; font-weight: 600; }
        .detail-value { font-size: 0.86rem; color: #0A2540; text-align: right; font-weight: 600; }
        .photo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .thumb { border: 1px solid #E5E7EB; border-radius: 12px; min-height: 90px; overflow: hidden; background: #F8FAFC; display: flex; align-items: center; justify-content: center; color: #64748B; font-size: 0.78rem; font-weight: 600; text-decoration: none; }
        .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .comments-box { background: #F8FAFC; border: 1px solid #E5E7EB; border-radius: 12px; padding: 12px; font-size: 0.86rem; color: #334155; line-height: 1.5; }
        .btn-primary { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="StructuralUpload" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <strong>Review &amp; Confirm</strong>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_StructuralStepper", 6)

    <h1 class="page-heading">Review &amp; Confirm</h1>
    <p class="page-lead">Verify your structural request details before submitting.</p>

    <form asp-controller="Inspecciones" asp-action="StructuralReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />

        <div class="service-card">
            <div class="service-row">
                <div>
                    <div class="service-name">@Model.NombreInspeccion</div>
                    <div class="service-subtitle">@Model.SubtituloInspeccion</div>
                </div>
                <div class="service-price">@Model.Moneda @Model.Precio.ToString("0.##")</div>
            </div>
        </div>

        <div class="field-card">
            <div class="section-title">Main concerns</div>
            <div class="chip-list">
                @if (Model.Preocupaciones.Count == 0)
                {
                    <span class="chip">No concerns selected</span>
                }
                else
                {
                    @foreach (var concern in Model.Preocupaciones)
                    {
                        <span class="chip">@concern</span>
                    }
                }
            </div>
        </div>

        <div class="field-card">
            <div class="section-title">Details</div>
            <div class="detail-row"><span class="detail-label">Address</span><span class="detail-value">@Model.DireccionPropiedad</span></div>
            <div class="detail-row"><span class="detail-label">When noticed</span><span class="detail-value">@Model.CuandoNotadoResumen</span></div>
            <div class="detail-row"><span class="detail-label">Severity</span><span class="detail-value">@Model.SeveridadResumen</span></div>
            <div class="detail-row"><span class="detail-label">Urgency</span><span class="detail-value">@Model.UrgenciaResumen</span></div>
            <div class="detail-row"><span class="detail-label">Foundation</span><span class="detail-value">@Model.TipoFundacionResumen</span></div>
            <div class="detail-row"><span class="detail-label">Repairs</span><span class="detail-value">@Model.ReparacionesPreviasResumen</span></div>
            <div class="detail-row"><span class="detail-label">Reason</span><span class="detail-value">@Model.MotivoResumen</span></div>
            <div class="detail-row"><span class="detail-label">Property type</span><span class="detail-value">@Model.TipoPropiedadResumen</span></div>
            <div class="detail-row"><span class="detail-label">Report</span><span class="detail-value">@Model.ReporteResumen</span></div>
            <div class="detail-row"><span class="detail-label">Access</span><span class="detail-value">@Model.AccesoResumen</span></div>
        </div>

        <div class="field-card">
            <div class="section-title">Photos &amp; files</div>
            <div class="photo-grid">
                @if (Model.Archivos.Count == 0)
                {
                    <div class="thumb">No files uploaded</div>
                }
                else
                {
                    @foreach (var file in Model.Archivos.Take(4))
                    {
                        var lower = (file.NombreArchivo ?? string.Empty).ToLowerInvariant();
                        var isImage = lower.EndsWith(".jpg") || lower.EndsWith(".jpeg") || lower.EndsWith(".png") || lower.EndsWith(".gif") || lower.EndsWith(".webp");
                        <a class="thumb" href="@file.RutaArchivo" target="_blank" rel="noopener">
                            @if (isImage)
                            {
                                <img src="@file.RutaArchivo" alt="@file.NombreArchivo" />
                            }
                            else
                            {
                                <span><i class="fas fa-file"></i> @file.NombreArchivo</span>
                            }
                        </a>
                    }
                }
            </div>
        </div>

        <div class="field-card">
            <div class="section-title">Comments</div>
            <div class="comments-box">@(string.IsNullOrWhiteSpace(Model.ComentariosProveedor) ? "No additional comments were provided." : Model.ComentariosProveedor)</div>
        </div>

        <button type="submit" class="btn-primary">Confirm &amp; Continue <i class="fas fa-check"></i></button>
    </form>
</div>
</body>
</html>
