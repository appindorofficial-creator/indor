@model IndorMvcApp.ViewModels.StructuralReviewViewModel
@{
    ViewData["Title"] = L["Review & Confirm - INDOR"];
    ViewData["WizardTitle"] = L["Review & Confirm"];
    ViewData["WizardBackUrl"] = Url.Action("StructuralUpload", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 6;
    ViewData["WizardTotalSteps"] = 6;

}

<h1 class="page-heading">@L["Review &amp; Confirm"]</h1>
    <p class="page-lead">@L["Verify your structural request details before submitting."]</p>

    <form asp-controller="Inspecciones" asp-action="StructuralReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />

        <div class="service-card">
            <div class="service-row">
                <div>
                    <div class="service-name">@Model.NombreInspeccion</div>
                    <div class="service-subtitle">@Model.SubtituloInspeccion</div>
                </div>
                <div class="service-price">@Model.Moneda @Model.Precio.ToString("0.##")</div>
            </div>
        </div>

        <div class="field-card">
            <div class="section-title">@L["Main concerns"]</div>
            <div class="chip-list">
                @if (Model.Preocupaciones.Count == 0)
                {
                    <span class="chip">@L["No concerns selected"]</span>
                }
                else
                {
                    @foreach (var concern in Model.Preocupaciones)
                    {
                        <span class="chip">@concern</span>
                    }
                }
            </div>
        </div>

        <div class="field-card">
            <div class="section-title">@L["Details"]</div>
            <div class="detail-row"><span class="detail-label">@L["Address"]</span><span class="detail-value">@Model.DireccionPropiedad</span></div>
            <div class="detail-row"><span class="detail-label">@L["When noticed"]</span><span class="detail-value">@Model.CuandoNotadoResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Severity"]</span><span class="detail-value">@Model.SeveridadResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Urgency"]</span><span class="detail-value">@Model.UrgenciaResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Foundation"]</span><span class="detail-value">@Model.TipoFundacionResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Repairs"]</span><span class="detail-value">@Model.ReparacionesPreviasResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Reason"]</span><span class="detail-value">@Model.MotivoResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Property type"]</span><span class="detail-value">@Model.TipoPropiedadResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Report"]</span><span class="detail-value">@Model.ReporteResumen</span></div>
            <div class="detail-row"><span class="detail-label">@L["Access"]</span><span class="detail-value">@Model.AccesoResumen</span></div>
        </div>

        <div class="field-card">
            <div class="section-title">@L["Photos &amp; files"]</div>
            <div class="photo-grid">
                @if (Model.Archivos.Count == 0)
                {
                    <div class="thumb">@L["No files uploaded"]</div>
                }
                else
                {
                    @foreach (var file in Model.Archivos.Take(4))
                    {
                        var lower = (file.NombreArchivo ?? string.Empty).ToLowerInvariant();
                        var isImage = lower.EndsWith(".jpg") || lower.EndsWith(".jpeg") || lower.EndsWith(".png") || lower.EndsWith(".gif") || lower.EndsWith(".webp");
                        <a class="thumb" href="@file.RutaArchivo" target="_blank" rel="noopener">
                            @if (isImage)
                            {
                                <img src="@file.RutaArchivo" alt="@file.NombreArchivo" />
                            }
                            else
                            {
                                <span><i class="fas fa-file"></i> @file.NombreArchivo</span>
                            }
                        </a>
                    }
                }
            </div>
        </div>

        <div class="field-card">
            <div class="section-title">@L["Comments"]</div>
            <div class="comments-box">@(string.IsNullOrWhiteSpace(Model.ComentariosProveedor) ? "No additional comments were provided." : Model.ComentariosProveedor)</div>
        </div>

        <button type="submit" class="btn-primary">@L["Confirm &amp; Continue"] <i class="fas fa-check"></i></button>
    </form>