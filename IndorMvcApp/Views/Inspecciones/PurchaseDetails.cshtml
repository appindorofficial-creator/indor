@model IndorMvcApp.ViewModels.PurchaseDetailsViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Purchase Details - INDOR";
    Layout = null;
    var closingDateValue = Model.FechaCierreEstimada?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
                           ?? DateTime.Today.AddDays(21).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .back-btn, .icon-btn {
            width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB;
            display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none;
        }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card {
            background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px;
            border: 1px solid rgba(229, 231, 235, 0.9); box-shadow: 0 8px 24px rgba(10, 37, 64, 0.04);
        }
        .field-head { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
        .field-icon {
            width: 36px; height: 36px; border-radius: 10px; background: rgba(0, 102, 204, 0.1);
            color: #0066CC; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .field-label { font-size: 0.92rem; font-weight: 700; color: #0A2540; }
        .form-input {
            width: 100%; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px;
            font-family: 'Inter', sans-serif; font-size: 0.95rem; background: #F9FAFB; color: #0A2540;
        }
        .form-input:focus { outline: none; border-color: #0066CC; background: #FFF; box-shadow: 0 0 0 4px rgba(0,102,204,0.1); }
        .segmented { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .segment-btn {
            border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 14px;
            font-weight: 600; font-size: 0.92rem; color: #64748B; cursor: pointer; display: flex;
            align-items: center; justify-content: center; gap: 8px; transition: all 0.2s ease;
        }
        .segment-btn.active {
            background: linear-gradient(135deg, #0066CC, #004FA3); border-color: transparent; color: #FFF;
            box-shadow: 0 8px 20px rgba(0, 102, 204, 0.22);
        }
        .chip-group { display: flex; flex-wrap: wrap; gap: 10px; }
        .chip-btn {
            flex: 1 1 calc(33.333% - 10px); min-width: 90px; border: 1.5px solid #E5E7EB; background: #F9FAFB;
            border-radius: 12px; padding: 12px 10px; font-weight: 600; font-size: 0.88rem; color: #64748B;
            cursor: pointer; text-align: center; transition: all 0.2s ease;
        }
        .chip-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .goal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .goal-btn {
            border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 14px; padding: 14px 12px;
            text-align: left; cursor: pointer; position: relative; min-height: 92px; transition: all 0.2s ease;
        }
        .goal-btn.active { border-color: #0066CC; background: rgba(0,102,204,0.06); box-shadow: 0 0 0 1px rgba(0,102,204,0.15); }
        .goal-btn i { color: #0066CC; font-size: 1rem; margin-bottom: 8px; display: block; }
        .goal-btn span { display: block; font-size: 0.84rem; font-weight: 700; color: #0A2540; line-height: 1.35; }
        .goal-btn .check {
            position: absolute; top: 10px; right: 10px; width: 22px; height: 22px; border-radius: 50%;
            background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.7rem;
        }
        .goal-btn.active .check { display: flex; }
        .validation-summary {
            background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; border-radius: 12px;
            padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px;
        }
        .btn-primary, .btn-secondary {
            width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem;
            cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-primary {
            border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF;
            box-shadow: 0 8px 24px rgba(0, 102, 204, 0.25); margin-top: 8px;
        }
        .btn-secondary {
            margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC;
        }
        .hidden-input { display: none; }
    </style>
</head>
<body>
    <div class="page-container">
        <div class="top-bar">
            <a asp-controller="Home" asp-action="Index" class="back-btn" aria-label="Back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <strong>Purchase Details</strong>
            <div style="width:44px;"></div>
        </div>

        <h1 class="page-heading">Tell us about this home purchase</h1>
        <p class="page-lead">We’ll use this information to prepare the right inspection flow.</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="PurchaseDetails" method="post" id="purchaseForm">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="SubtituloInspeccion" />
            <input type="hidden" asp-for="BajoContrato" id="BajoContrato" />
            <input type="hidden" asp-for="TieneReporteExistente" id="TieneReporteExistente" />
            <input type="hidden" asp-for="RolComprador" id="RolComprador" />
            <input type="hidden" asp-for="ObjetivoPrincipal" id="ObjetivoPrincipal" />

            <div class="field-card">
                <div class="field-head">
                    <div class="field-icon"><i class="fas fa-house"></i></div>
                    <div class="field-label">Property address</div>
                </div>
                <input asp-for="DireccionPropiedad" class="form-input" placeholder="123 Main St, Charlotte, NC 28202" required />
            </div>

            <div class="field-card">
                <div class="field-head">
                    <div class="field-icon"><i class="fas fa-file-signature"></i></div>
                    <div class="field-label">Are you under contract?</div>
                </div>
                <div class="segmented" data-target="BajoContrato">
                    <button type="button" class="segment-btn" data-value="true"><i class="fas fa-check"></i> Yes</button>
                    <button type="button" class="segment-btn" data-value="false">No</button>
                </div>
            </div>

            <div class="field-card">
                <div class="field-head">
                    <div class="field-icon"><i class="fas fa-calendar-day"></i></div>
                    <div class="field-label">Estimated closing date</div>
                </div>
                <input type="date" class="form-input" id="FechaCierreEstimada" name="FechaCierreEstimada" value="@closingDateValue" />
            </div>

            <div class="field-card">
                <div class="field-head">
                    <div class="field-icon"><i class="fas fa-clipboard-list"></i></div>
                    <div class="field-label">Do you already have a home inspection report?</div>
                </div>
                <div class="segmented" data-target="TieneReporteExistente">
                    <button type="button" class="segment-btn" data-value="true">Yes</button>
                    <button type="button" class="segment-btn" data-value="false"><i class="fas fa-check"></i> No</button>
                </div>
            </div>

            <div class="field-card">
                <div class="field-head">
                    <div class="field-icon"><i class="fas fa-user"></i></div>
                    <div class="field-label">Who are you?</div>
                </div>
                <div class="chip-group" data-target="RolComprador">
                    <button type="button" class="chip-btn" data-value="Buyer">Buyer</button>
                    <button type="button" class="chip-btn" data-value="Realtor">Realtor</button>
                    <button type="button" class="chip-btn" data-value="Investor">Investor</button>
                </div>
            </div>

            <div class="field-card">
                <div class="field-head">
                    <div class="field-icon"><i class="fas fa-bullseye"></i></div>
                    <div class="field-label">Main goal</div>
                </div>
                <div class="goal-grid" data-target="ObjetivoPrincipal">
                    <button type="button" class="goal-btn" data-value="BuyWithConfidence">
                        <span class="check"><i class="fas fa-check"></i></span>
                        <i class="fas fa-shield-heart"></i><span>Buy with confidence</span>
                    </button>
                    <button type="button" class="goal-btn" data-value="UnderstandRepairRisks">
                        <span class="check"><i class="fas fa-check"></i></span>
                        <i class="fas fa-magnifying-glass"></i><span>Understand repair risks</span>
                    </button>
                    <button type="button" class="goal-btn" data-value="NegotiateRepairs">
                        <span class="check"><i class="fas fa-check"></i></span>
                        <i class="fas fa-handshake"></i><span>Negotiate repairs</span>
                    </button>
                    <button type="button" class="goal-btn" data-value="SecondOpinion">
                        <span class="check"><i class="fas fa-check"></i></span>
                        <i class="fas fa-comments"></i><span>Get a second opinion</span>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">
                <i class="fas fa-arrow-right"></i> Next
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
        </form>
    </div>

    <script>
        function setSegment(group, value) {
            const targetId = group.dataset.target;
            const input = document.getElementById(targetId);
            const boolValue = value === 'true';
            input.value = boolValue ? 'True' : 'False';
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        document.querySelectorAll('.segmented').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSegment(group, btn.dataset.value));
            });
            const target = document.getElementById(group.dataset.target);
            const current = target.value === 'True' ? 'true' : 'false';
            setSegment(group, current);
        });

        document.querySelectorAll('.chip-group').forEach(group => {
            group.querySelectorAll('.chip-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.chip-btn', btn.dataset.value));
            });
            setSingle(group, '.chip-btn', document.getElementById(group.dataset.target).value);
        });

        document.querySelectorAll('.goal-grid').forEach(group => {
            group.querySelectorAll('.goal-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.goal-btn', btn.dataset.value));
            });
            setSingle(group, '.goal-btn', document.getElementById(group.dataset.target).value);
        });
    </script>
</body>
</html>
