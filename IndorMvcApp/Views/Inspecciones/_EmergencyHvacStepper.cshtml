@model int
@{
    var steps = new[] { "Service", "Details", "Review" };
}
<style>
    .eh-stepper { display: flex; gap: 6px; margin-bottom: 18px; overflow-x: auto; padding-bottom: 4px; }
    .eh-step { flex: 1; min-width: 52px; text-align: center; }
    .eh-step-dot {
        width: 28px; height: 28px; border-radius: 50%; margin: 0 auto 6px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 700; border: 2px solid #CBD5E1; color: #94A3B8; background: #FFF;
    }
    .eh-step.done .eh-step-dot { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .eh-step.active .eh-step-dot { border-color: #0066CC; color: #0066CC; background: #FFF; }
    .eh-step-label { font-size: 0.68rem; font-weight: 600; color: #94A3B8; line-height: 1.2; }
    .eh-step.active .eh-step-label, .eh-step.done .eh-step-label { color: #0066CC; }
    .eh-step-meta { text-align: center; font-size: 0.75rem; font-weight: 600; color: #0066CC; margin-bottom: 14px; }
</style>
<div class="eh-stepper">
    @for (var i = 0; i < steps.Length; i++)
    {
        var stepNum = i + 1;
        var css = stepNum < Model ? "eh-step done" : stepNum == Model ? "eh-step active" : "eh-step";
        <div class="@css">
            <div class="eh-step-dot">
                @if (stepNum < Model)
                {
                    <i class="fas fa-check" style="font-size:0.7rem;"></i>
                }
                else
                {
                    @stepNum
                }
            </div>
            <div class="eh-step-label">@steps[i]</div>
        </div>
    }
</div>
@if (Model <= 3)
{
    <div class="eh-step-meta">Step @Model of 3</div>
}
