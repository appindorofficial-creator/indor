@model IndorMvcApp.ViewModels.WindowsInsulationDetailsViewModel
@{
    ViewData["Title"] = "Windows & Insulation Details - INDOR";
    ViewData["WizardTitle"] = "Windows & Insulation Details";
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">Tell us about your efficiency concern</h1>
    <p class="page-lead">This helps INDOR understand the issue and prepare the right provider.</p>

    <form asp-controller="Inspecciones" asp-action="WindowsInsulationDetails" method="post">
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="TiposProblema" id="TiposProblema" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="AreasAtencion" id="AreasAtencion" />
        <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />
        <input type="hidden" asp-for="DanoHumedadVisible" id="DanoHumedadVisible" />

        <div class="field-card">
            <label asp-for="DireccionPropiedad" class="field-label">Property address</label>
            <div class="address-summary">
                <div class="left" style="flex:1;">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" style="border:none;background:transparent;padding:0;font-weight:600;width:100%;font-family:inherit;font-size:0.92rem;" placeholder="123 Main St, Charlotte, NC 28202" required />
                </div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What's the main issue?</span>
            <div class="chip-grid" id="tiposGroup">
                <button type="button" class="chip-btn" data-value="DraftAir"><span class="check"><i class="fas fa-check"></i></span>Draft / air coming in</button>
                <button type="button" class="chip-btn" data-value="HighEnergyBill"><span class="check"><i class="fas fa-check"></i></span>High energy bill</button>
                <button type="button" class="chip-btn" data-value="ColdRoom"><span class="check"><i class="fas fa-check"></i></span>Cold room</button>
                <button type="button" class="chip-btn" data-value="HotRoom"><span class="check"><i class="fas fa-check"></i></span>Hot room</button>
                <button type="button" class="chip-btn" data-value="WindowCondensation"><span class="check"><i class="fas fa-check"></i></span>Window condensation</button>
                <button type="button" class="chip-btn" data-value="WindowSealing"><span class="check"><i class="fas fa-check"></i></span>Window sealing issue</button>
                <button type="button" class="chip-btn" data-value="DamagedInsulation"><span class="check"><i class="fas fa-check"></i></span>Damaged insulation</button>
                <button type="button" class="chip-btn" data-value="AtticInsulation"><span class="check"><i class="fas fa-check"></i></span>Attic insulation</button>
                <button type="button" class="chip-btn" data-value="WallInsulation"><span class="check"><i class="fas fa-check"></i></span>Wall insulation</button>
                <button type="button" class="chip-btn" data-value="MoistureAroundWindow"><span class="check"><i class="fas fa-check"></i></span>Moisture around window</button>
                <button type="button" class="chip-btn" data-value="WholeHouseReview"><span class="check"><i class="fas fa-check"></i></span>Whole-house review</button>
                <button type="button" class="chip-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Which area needs attention?</span>
            <div class="chip-grid" id="areasGroup">
                <button type="button" class="chip-btn" data-value="LivingRoom"><span class="check"><i class="fas fa-check"></i></span>Living room</button>
                <button type="button" class="chip-btn" data-value="Bedroom"><span class="check"><i class="fas fa-check"></i></span>Bedroom</button>
                <button type="button" class="chip-btn" data-value="Attic"><span class="check"><i class="fas fa-check"></i></span>Attic</button>
                <button type="button" class="chip-btn" data-value="CrawlSpace"><span class="check"><i class="fas fa-check"></i></span>Crawl space</button>
                <button type="button" class="chip-btn" data-value="AroundWindows"><span class="check"><i class="fas fa-check"></i></span>Around windows</button>
                <button type="button" class="chip-btn" data-value="ExteriorWall"><span class="check"><i class="fas fa-check"></i></span>Exterior wall</button>
                <button type="button" class="chip-btn" data-value="WholeHouse"><span class="check"><i class="fas fa-check"></i></span>Whole house</button>
                <button type="button" class="chip-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How urgent is it?</span>
            <div class="segmented-3" data-target="Urgencia">
                <button type="button" class="segment-btn" data-value="Normal">Normal</button>
                <button type="button" class="segment-btn" data-value="Priority">Priority</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Is there visible moisture or water damage?</span>
            <div class="segmented-3" data-target="DanoHumedadVisible">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>If you see condensation, drafts, damaged weatherstripping, or insulation gaps, include that in the next step.</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-cloud-arrow-up"></i> Upload photos or report</button>
    </form>
</div>
@section Scripts {
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, selector, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initMulti(groupId, hiddenId, primaryId, defaultValues){
        const hidden = document.getElementById(hiddenId);
        const primary = document.getElementById(primaryId);
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = defaultValues.slice();
        function render(){
            document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            primary.value = selected[0] || defaultValues[0];
        }
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    }
    initMulti('tiposGroup', 'TiposProblema', 'TipoProblema', ['DraftAir']);
    initMulti('areasGroup', 'AreasAtencion', 'UbicacionProblema', ['LivingRoom']);
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });

</script>
}