@model IndorMvcApp.ViewModels.PlumbingDetailsViewModel
@{
    ViewData["Title"] = L["Plumbing Details - INDOR"];
    ViewData["WizardTitle"] = L["Plumbing Details"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

</div>

        <h1 class="page-heading">@L["Tell us about your plumbing concern"]</h1>
        <p class="page-lead">@L["This helps INDOR prepare the right checklist and find the right provider."]</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="PlumbingDetails" method="post" id="plumbingForm">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
            <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
            <input type="hidden" asp-for="Urgencia" id="Urgencia" />
            <input type="hidden" asp-for="FugaAguaAhora" id="FugaAguaAhora" />

            <div class="field-card">
                <label asp-for="DireccionPropiedad" class="field-label">@L["Property address"]</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">@L["Step 1"]</div>
                <span class="field-label">@L["What type of plumbing issue is it?"]</span>
                <div class="issue-grid" data-target="TipoProblema">
                    <button type="button" class="issue-btn" data-value="BathroomIssue"><span class="check"><i class="fas fa-check"></i></span>@L["Bathroom issue"]</button>
                    <button type="button" class="issue-btn" data-value="KitchenIssue"><span class="check"><i class="fas fa-check"></i></span>@L["Kitchen issue"]</button>
                    <button type="button" class="issue-btn" data-value="Toilet"><span class="check"><i class="fas fa-check"></i></span>@L["Toilet"]</button>
                    <button type="button" class="issue-btn" data-value="FaucetSink"><span class="check"><i class="fas fa-check"></i></span>@L["Faucet / sink"]</button>
                    <button type="button" class="issue-btn" data-value="ShowerTub"><span class="check"><i class="fas fa-check"></i></span>@L["Shower / tub"]</button>
                    <button type="button" class="issue-btn" data-value="WaterSupplyLine"><span class="check"><i class="fas fa-check"></i></span>@L["Water supply line"]</button>
                    <button type="button" class="issue-btn" data-value="DrainLineClog"><span class="check"><i class="fas fa-check"></i></span>@L["Drain line / clog"]</button>
                    <button type="button" class="issue-btn" data-value="MainWaterLine"><span class="check"><i class="fas fa-check"></i></span>@L["Main water line"]</button>
                    <button type="button" class="issue-btn" data-value="MainShutoffValve"><span class="check"><i class="fas fa-check"></i></span>@L["Main shutoff valve"]</button>
                    <button type="button" class="issue-btn" data-value="LeakDetection"><span class="check"><i class="fas fa-check"></i></span>@L["Leak detection"]</button>
                    <button type="button" class="issue-btn" data-value="LowWaterPressure"><span class="check"><i class="fas fa-check"></i></span>@L["Low water pressure"]</button>
                    <button type="button" class="issue-btn" data-value="SewerMainDrain"><span class="check"><i class="fas fa-check"></i></span>@L["Sewer / main drain"]</button>
                    <button type="button" class="issue-btn" data-value="ExteriorHoseBib"><span class="check"><i class="fas fa-check"></i></span>@L["Exterior hose bib"]</button>
                    <button type="button" class="issue-btn" data-value="GeneralReview"><span class="check"><i class="fas fa-check"></i></span>@L["General review"]</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">@L["Step 2"]</div>
                <span class="field-label">@L["Where is the problem?"]</span>
                <div class="location-group" data-target="UbicacionProblema">
                    <button type="button" class="location-btn" data-value="Kitchen"><span class="check"><i class="fas fa-check"></i></span>@L["Kitchen"]</button>
                    <button type="button" class="location-btn" data-value="Bathroom"><span class="check"><i class="fas fa-check"></i></span>@L["Bathroom"]</button>
                    <button type="button" class="location-btn" data-value="Laundry"><span class="check"><i class="fas fa-check"></i></span>@L["Laundry"]</button>
                    <button type="button" class="location-btn" data-value="CrawlSpace"><span class="check"><i class="fas fa-check"></i></span>@L["Crawl space"]</button>
                    <button type="button" class="location-btn" data-value="Basement"><span class="check"><i class="fas fa-check"></i></span>@L["Basement"]</button>
                    <button type="button" class="location-btn" data-value="Exterior"><span class="check"><i class="fas fa-check"></i></span>@L["Exterior"]</button>
                    <button type="button" class="location-btn" data-value="WholeHouse"><span class="check"><i class="fas fa-check"></i></span>@L["Whole house"]</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">@L["Step 3"]</div>
                <span class="field-label">@L["How urgent is it?"]</span>
                <div class="segmented-3" data-target="Urgencia">
                    <button type="button" class="segment-btn" data-value="Normal">@L["Normal"]</button>
                    <button type="button" class="segment-btn" data-value="Priority">@L["Priority"]</button>
                    <button type="button" class="segment-btn emergency" data-value="Emergency">@L["Emergency"]</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">@L["Step 4"]</div>
                <span class="field-label">@L["Is water leaking right now?"]</span>
                <div class="segmented-3" data-target="FugaAguaAhora">
                    <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                    <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                    <button type="button" class="segment-btn" data-value="NotSure">@L["Not sure"]</button>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                <div>@L["If there is active flooding or a burst pipe, choose"] <strong>@L["Emergency"]</strong> @L["or contact support immediately."]</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">
                @L["Next"] <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn-outline" name="action" value="upload">
                <i class="fas fa-cloud-arrow-up"></i> @L["Upload photos or report"]
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">@L["Skip for now"]</button>
        </form>
    </div>

    <script>
        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        document.querySelectorAll('.issue-grid, .location-group').forEach(group => {
            const selector = group.classList.contains('issue-grid') ? '.issue-btn' : '.location-btn';
            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value));
            });
            setSingle(group, selector, document.getElementById(group.dataset.target).value);
        });

        document.querySelectorAll('.segmented-3').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value));
            });
            setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
        });
    
</script>
}