@model IndorMvcApp.ViewModels.HomeReviewDetailsViewModel
@{
    ViewData["Title"] = "Home Review Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .back-btn {
            width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB;
            display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none;
        }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card {
            background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px;
            border: 1px solid rgba(229, 231, 235, 0.9); box-shadow: 0 8px 24px rgba(10, 37, 64, 0.04);
        }
        .field-label { font-size: 0.92rem; font-weight: 700; color: #0A2540; margin-bottom: 12px; display: block; }
        .form-input {
            width: 100%; padding: 14px 16px 14px 42px; border: 1.5px solid #E5E7EB; border-radius: 12px;
            font-family: 'Inter', sans-serif; font-size: 0.95rem; background: #F9FAFB; color: #0A2540;
        }
        .input-wrap { position: relative; }
        .input-wrap i {
            position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
            color: #0066CC; font-size: 0.95rem;
        }
        .form-input:focus { outline: none; border-color: #0066CC; background: #FFF; box-shadow: 0 0 0 4px rgba(0,102,204,0.1); }
        .chip-group { display: flex; flex-wrap: wrap; gap: 10px; }
        .chip-btn {
            flex: 1 1 calc(50% - 10px); min-width: 120px; border: 1.5px solid #E5E7EB; background: #F9FAFB;
            border-radius: 12px; padding: 12px 10px; font-weight: 600; font-size: 0.86rem; color: #64748B;
            cursor: pointer; text-align: center; transition: all 0.2s ease; position: relative;
        }
        .chip-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .chip-btn .check {
            position: absolute; top: 8px; right: 8px; width: 18px; height: 18px; border-radius: 50%;
            background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.6rem;
        }
        .chip-btn.active .check { display: flex; }
        .focus-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .focus-btn {
            border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 10px;
            font-weight: 600; font-size: 0.84rem; color: #64748B; cursor: pointer; text-align: center;
            position: relative; transition: all 0.2s ease;
        }
        .focus-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .focus-btn .check {
            position: absolute; top: 8px; right: 8px; width: 18px; height: 18px; border-radius: 50%;
            background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.6rem;
        }
        .focus-btn.active .check { display: flex; }
        .segmented-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .segment-btn {
            border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px;
            font-weight: 600; font-size: 0.88rem; color: #64748B; cursor: pointer; text-align: center;
            transition: all 0.2s ease;
        }
        .segment-btn.active { background: rgba(0,102,204,0.08); border-color: #0066CC; color: #0066CC; }
        .info-box {
            background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px;
            padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; color: #0A2540; font-size: 0.86rem; line-height: 1.45;
        }
        .info-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .validation-summary {
            background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; border-radius: 12px;
            padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px;
        }
        .btn-primary, .btn-secondary {
            width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem;
            cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-primary {
            border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF;
            box-shadow: 0 8px 24px rgba(0, 102, 204, 0.25); margin-top: 8px;
        }
        .btn-secondary {
            margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC;
        }
    </style>
</head>
<body>
    <div class="page-container">
        <div class="top-bar">
            <a asp-controller="Home" asp-action="Index" class="back-btn" aria-label="Back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <strong>Home Review Details</strong>
            <div style="width:44px;"></div>
        </div>

        <h1 class="page-heading">Tell us about this home review</h1>
        <p class="page-lead">This helps INDOR prepare the right checklist and schedule the right provider.</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="HomeReviewDetails" method="post" id="reviewForm">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="MotivoInspeccion" id="MotivoInspeccion" />
            <input type="hidden" asp-for="AreasEnfoque" id="AreasEnfoque" />
            <input type="hidden" asp-for="EsUrgente" id="EsUrgente" />

            <div class="field-card">
                <label asp-for="DireccionPropiedad" class="field-label">Property address</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" placeholder="123 Main St, Charlotte, NC 28202" required />
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">Why do you need this inspection?</span>
                <div class="chip-group" data-target="MotivoInspeccion" data-mode="single">
                    <button type="button" class="chip-btn" data-value="BuyingHome">
                        <span class="check"><i class="fas fa-check"></i></span>Buying a home
                    </button>
                    <button type="button" class="chip-btn" data-value="AnnualReview">
                        <span class="check"><i class="fas fa-check"></i></span>Annual review
                    </button>
                    <button type="button" class="chip-btn" data-value="SellingHome">
                        <span class="check"><i class="fas fa-check"></i></span>Selling a home
                    </button>
                    <button type="button" class="chip-btn" data-value="InspectionFollowUp">
                        <span class="check"><i class="fas fa-check"></i></span>Inspection follow-up
                    </button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">What would you like us to focus on?</span>
                <div class="focus-grid" id="focusGrid">
                    <button type="button" class="focus-btn" data-value="Electrical"><span class="check"><i class="fas fa-check"></i></span>Electrical</button>
                    <button type="button" class="focus-btn" data-value="HVAC"><span class="check"><i class="fas fa-check"></i></span>HVAC</button>
                    <button type="button" class="focus-btn" data-value="GeneralStructure"><span class="check"><i class="fas fa-check"></i></span>General structure</button>
                    <button type="button" class="focus-btn" data-value="Plumbing"><span class="check"><i class="fas fa-check"></i></span>Plumbing</button>
                    <button type="button" class="focus-btn" data-value="Roof"><span class="check"><i class="fas fa-check"></i></span>Roof</button>
                    <button type="button" class="focus-btn" data-value="Moisture"><span class="check"><i class="fas fa-check"></i></span>Moisture</button>
                    <button type="button" class="focus-btn" data-value="Safety"><span class="check"><i class="fas fa-check"></i></span>Safety</button>
                </div>
            </div>

            <div class="field-card">
                <label asp-for="TamanoPropiedad" class="field-label">Property size</label>
                <input asp-for="TamanoPropiedad" class="form-input" style="padding-left:16px;" placeholder="2,150 sq ft" />
            </div>

            <div class="field-card">
                <span class="field-label">Is anything urgent right now?</span>
                <div class="segmented-3" data-target="EsUrgente" data-mode="single">
                    <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                    <button type="button" class="segment-btn" data-value="No">No</button>
                    <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                <div><strong>We'll help you focus on what matters most.</strong> This review helps us prioritize the home systems that matter most so you get clear insights and next steps.</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">
                Continue <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
        </form>
    </div>

    <script>
        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        document.querySelectorAll('[data-mode="single"]').forEach(group => {
            const selector = group.classList.contains('chip-group') ? '.chip-btn' : '.segment-btn';
            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value));
            });
            setSingle(group, selector, document.getElementById(group.dataset.target).value);
        });

        const focusInput = document.getElementById('AreasEnfoque');
        const focusButtons = document.querySelectorAll('#focusGrid .focus-btn');

        function syncFocusAreas() {
            const selected = Array.from(focusButtons)
                .filter(btn => btn.classList.contains('active'))
                .map(btn => btn.dataset.value);
            focusInput.value = selected.join('|');
        }

        function initFocusAreas() {
            const current = (focusInput.value || '').split('|').filter(Boolean);
            focusButtons.forEach(btn => {
                btn.classList.toggle('active', current.includes(btn.dataset.value));
            });
            syncFocusAreas();
        }

        focusButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                btn.classList.toggle('active');
                syncFocusAreas();
            });
        });

        initFocusAreas();
    </script>
</body>
</html>
