@model IndorMvcApp.ViewModels.HomeReviewDetailsViewModel
@{
    ViewData["Title"] = L["Home Review Details - INDOR"];
    ViewData["WizardTitle"] = L["Home Review Details"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}


        <h1 class="page-heading">@L["Tell us about this home review"]</h1>
        <p class="page-lead">@L["This helps INDOR prepare the right checklist and schedule the right provider."]</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="HomeReviewDetails" method="post" id="reviewForm">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="MotivoInspeccion" id="MotivoInspeccion" />
            <input type="hidden" asp-for="AreasEnfoque" id="AreasEnfoque" />
            <input type="hidden" asp-for="EsUrgente" id="EsUrgente" />

            <div class="field-card">
                <label asp-for="DireccionPropiedad" class="field-label">@L["Property address"]</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["Why do you need this inspection?"]</span>
                <div class="chip-group" data-target="MotivoInspeccion" data-mode="single">
                    <button type="button" class="chip-btn" data-value="BuyingHome">
                        <span class="check"><i class="fas fa-check"></i></span>@L["Buying a home"]
                    </button>
                    <button type="button" class="chip-btn" data-value="AnnualReview">
                        <span class="check"><i class="fas fa-check"></i></span>@L["Annual review"]
                    </button>
                    <button type="button" class="chip-btn" data-value="SellingHome">
                        <span class="check"><i class="fas fa-check"></i></span>@L["Selling a home"]
                    </button>
                    <button type="button" class="chip-btn" data-value="InspectionFollowUp">
                        <span class="check"><i class="fas fa-check"></i></span>@L["Inspection follow-up"]
                    </button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["What would you like us to focus on?"]</span>
                <div class="focus-grid" id="focusGrid">
                    <button type="button" class="focus-btn" data-value="Electrical"><span class="check"><i class="fas fa-check"></i></span>@L["Electrical"]</button>
                    <button type="button" class="focus-btn" data-value="HVAC"><span class="check"><i class="fas fa-check"></i></span>@L["HVAC"]</button>
                    <button type="button" class="focus-btn" data-value="GeneralStructure"><span class="check"><i class="fas fa-check"></i></span>@L["General structure"]</button>
                    <button type="button" class="focus-btn" data-value="Plumbing"><span class="check"><i class="fas fa-check"></i></span>@L["Plumbing"]</button>
                    <button type="button" class="focus-btn" data-value="Roof"><span class="check"><i class="fas fa-check"></i></span>@L["Roof"]</button>
                    <button type="button" class="focus-btn" data-value="Moisture"><span class="check"><i class="fas fa-check"></i></span>@L["Moisture"]</button>
                    <button type="button" class="focus-btn" data-value="Safety"><span class="check"><i class="fas fa-check"></i></span>@L["Safety"]</button>
                </div>
            </div>

            <div class="field-card">
                <label asp-for="TamanoPropiedad" class="field-label">@L["Property size"]</label>
                <input asp-for="TamanoPropiedad" class="form-input" style="padding-left:16px;" placeholder="@L["2,150 sq ft"]" />
            </div>

            <div class="field-card">
                <span class="field-label">@L["Is anything urgent right now?"]</span>
                <div class="segmented-3" data-target="EsUrgente" data-mode="single">
                    <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                    <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                    <button type="button" class="segment-btn" data-value="NotSure">@L["Not sure"]</button>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                <div><strong>@L["We'll help you focus on what matters most."]</strong> @L["This review helps us prioritize the home systems that matter most so you get clear insights and next steps."]</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">
                @L["Continue"] <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">@L["Skip for now"]</button>
        </form>

@section Scripts {
    <script>
        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        document.querySelectorAll('[data-mode="single"]').forEach(group => {
            const selector = group.classList.contains('chip-group') ? '.chip-btn' : '.segment-btn';
            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value));
            });
            setSingle(group, selector, document.getElementById(group.dataset.target).value);
        });

        const focusInput = document.getElementById('AreasEnfoque');
        const focusButtons = document.querySelectorAll('#focusGrid .focus-btn');

        function syncFocusAreas() {
            const selected = Array.from(focusButtons)
                .filter(btn => btn.classList.contains('active'))
                .map(btn => btn.dataset.value);
            focusInput.value = selected.join('|');
        }

        function initFocusAreas() {
            const current = (focusInput.value || '').split('|').filter(Boolean);
            focusButtons.forEach(btn => {
                btn.classList.toggle('active', current.includes(btn.dataset.value));
            });
            syncFocusAreas();
        }

        focusButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                btn.classList.toggle('active');
                syncFocusAreas();
            });
        });

        initFocusAreas();
    
</script>
}