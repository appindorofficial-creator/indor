@model int
@{
    var steps = new[] { "Concern", "Property", "Photos", "Confirm" };
}
<style>
    .roof-stepper { display: flex; gap: 6px; margin-bottom: 18px; overflow-x: auto; padding-bottom: 4px; }
    .roof-step { flex: 1; min-width: 52px; text-align: center; }
    .roof-step-dot {
        width: 28px; height: 28px; border-radius: 50%; margin: 0 auto 6px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 700; border: 2px solid #CBD5E1; color: #94A3B8; background: #FFF;
    }
    .roof-step.done .roof-step-dot { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .roof-step.active .roof-step-dot { border-color: #0066CC; color: #0066CC; background: #FFF; }
    .roof-step-label { font-size: 0.68rem; font-weight: 600; color: #94A3B8; line-height: 1.2; }
    .roof-step.active .roof-step-label, .roof-step.done .roof-step-label { color: #0066CC; }
</style>
<div class="roof-stepper">
    @for (var i = 0; i < steps.Length; i++)
    {
        var stepNum = i + 1;
        var css = stepNum < Model ? "roof-step done" : stepNum == Model ? "roof-step active" : "roof-step";
        <div class="@css">
            <div class="roof-step-dot">
                @if (stepNum < Model)
                {
                    <i class="fas fa-check" style="font-size:0.7rem;"></i>
                }
                else
                {
                    @stepNum
                }
            </div>
            <div class="roof-step-label">@steps[i]</div>
        </div>
    }
</div>
