@model IndorMvcApp.ViewModels.EmergencyRoofLeakDetailsViewModel
@{
    ViewData["Title"] = "Roof Leak Emergency - INDOR";
    ViewData["WizardTitle"] = "Roof Leak Emergency";
    ViewData["WizardBackUrl"] = Url.Action("EmergencyRoofLeakDescribe", "Inspecciones", new { id = Model.ServicioEmergenciaId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 3;

}

    <div><strong>Roof Leak Emergency</strong><span class="badge-247">24/7</span></div>
    <p class="page-lead" style="margin-top:8px;">Fast help for active roof leaks and water intrusion.</p>

    
@if (ViewContext.ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <form asp-controller="Inspecciones" asp-action="EmergencyRoofLeakDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="PuedeColocarCubeta" id="PuedeColocarCubeta" />

        <div class="address-display">
            <span><i class="fas fa-house"></i>@Model.DireccionPropiedad</span>
            <a asp-action="EmergencyRoofLeakDescribe" asp-route-id="@Model.ServicioEmergenciaId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;">Edit</a>
        </div>

        <div class="dropzone" id="dropzone">
            <i class="fas fa-cloud-arrow-up"></i>
            <p><strong style="color:#0066CC;">Drag files here or browse</strong></p>
            <p style="font-size:0.82rem;color:#64748B;margin-top:4px;">JPG, PNG, PDF up to 25 MB each</p>
        </div>
        <input type="file" id="fileInput" name="files" class="hidden-input" multiple accept=".pdf,.jpg,.jpeg,.png,.mp4,.mov,.webm,application/pdf,image/*,video/*" />

        <div class="action-grid">
            <label class="action-btn" for="fileInputCamera"><i class="fas fa-camera"></i>Take photo</label>
            <input type="file" id="fileInputCamera" class="hidden-input" accept="image/*" capture="environment" />
            <label class="action-btn" for="fileInput"><i class="fas fa-images"></i>Upload photos</label>
            <label class="action-btn" for="fileInputVideo"><i class="fas fa-video"></i>Add video</label>
            <input type="file" id="fileInputVideo" class="hidden-input" accept="video/*,.mp4,.mov,.webm" />
            <button type="button" class="action-btn" onclick="document.getElementById('NotaCorta').focus()"><i class="fas fa-note-sticky"></i>Add note</button>
        </div>

        @if (Model.ArchivosExistentes.Count > 0)
        {
            <div class="file-list">
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="file-item"><span><i class="fas fa-paperclip"></i> @file.NombreArchivo</span><a href="@file.RutaArchivo" target="_blank" rel="noopener">View</a></div>
                }
            </div>
        }
        <div id="selectedFiles" class="file-list"></div>

        <label asp-for="NotaCorta" class="field-label">Notes (optional)</label>
        <textarea asp-for="NotaCorta" id="NotaCorta" class="form-textarea" maxlength="500" placeholder="Water dripping through ceiling in upstairs hallway after heavy rain. Stain is spreading near the vent."></textarea>
        <div class="char-count"><span id="charCount">0</span>/500</div>

        <div class="field-card">
            <span class="field-label">Can you safely place a bucket or move items away from the leak?</span>
            <div class="choice-row" data-target="PuedeColocarCubeta">
                <button type="button" class="choice-btn" data-value="Yes"><i class="fas fa-check" style="color:#16A34A;"></i>Yes</button>
                <button type="button" class="choice-btn" data-value="No"><i class="fas fa-xmark" style="color:#DC2626;"></i>No</button>
                <button type="button" class="choice-btn" data-value="AlreadyDone"><i class="fas fa-bucket" style="color:#0066CC;"></i>Already done</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>If it is safe, a photo of the leak area, ceiling stain, attic, or outside roof damage can speed up dispatch.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="submit">Submit emergency request <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="back">Back</button>
    </form>
</div>
@section Scripts {
<script>
    function setSingle(group, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll('.choice-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('[data-target]').forEach(group => {
        group.querySelectorAll('.choice-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, btn.dataset.value)));
        setSingle(group, document.getElementById(group.dataset.target).value);
    });
    const fileInput = document.getElementById('fileInput');
    const fileInputCamera = document.getElementById('fileInputCamera');
    const fileInputVideo = document.getElementById('fileInputVideo');
    const dropzone = document.getElementById('dropzone');
    const selectedFiles = document.getElementById('selectedFiles');
    let pendingFiles = [];
    function mergeFiles(newFiles) {
        Array.from(newFiles).forEach(f => pendingFiles.push(f));
        const dt = new DataTransfer();
        pendingFiles.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        selectedFiles.innerHTML = '';
        pendingFiles.forEach(file => {
            const item = document.createElement('div');
            item.className = 'file-item';
            item.innerHTML = `<span><i class="fas fa-file"></i> ${file.name}</span>`;
            selectedFiles.appendChild(item);
        });
    }
    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => mergeFiles(fileInput.files));
    fileInputCamera.addEventListener('change', () => mergeFiles(fileInputCamera.files));
    fileInputVideo.addEventListener('change', () => mergeFiles(fileInputVideo.files));
    const note = document.getElementById('NotaCorta');
    const charCount = document.getElementById('charCount');
    function updateCount() { charCount.textContent = (note.value || '').length; }
    note.addEventListener('input', updateCount);
    updateCount();

</script>
}