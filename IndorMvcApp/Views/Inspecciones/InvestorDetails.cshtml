@model IndorMvcApp.ViewModels.InvestorDetailsViewModel
@{
    ViewData["Title"] = L["Investor Details - INDOR"];
    ViewData["WizardTitle"] = L["Investor Details"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">@L["Tell us about your investment goal"]</h1>
    <p class="page-lead">@L["This helps INDOR prepare the right checklist and the right provider."]</p>

    <form asp-controller="Inspecciones" asp-action="InvestorDetails" method="post">
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="TipoInversion" id="TipoInversion" />
        <input type="hidden" asp-for="EnfoquesInversion" id="EnfoquesInversion" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />

        <div class="field-card">
            <label asp-for="DireccionPropiedad" class="field-label">@L["Property address"]</label>
            <div class="address-summary">
                <div class="left" style="flex:1;">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" style="border:none;background:transparent;padding:0;font-weight:600;width:100%;font-family:inherit;font-size:0.92rem;" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What kind of investment is this?"]</span>
            <div class="chip-grid" data-target="TipoInversion">
                <button type="button" class="chip-btn" data-value="Flip"><span class="check"><i class="fas fa-check"></i></span>@L["Flip"]</button>
                <button type="button" class="chip-btn" data-value="RentalProperty"><span class="check"><i class="fas fa-check"></i></span>@L["Rental property"]</button>
                <button type="button" class="chip-btn" data-value="BuyAndHold"><span class="check"><i class="fas fa-check"></i></span>@L["Buy and hold"]</button>
                <button type="button" class="chip-btn" data-value="BRRRR"><span class="check"><i class="fas fa-check"></i></span>@L["BRRRR"]</button>
                <button type="button" class="chip-btn" data-value="BeforeOffer"><span class="check"><i class="fas fa-check"></i></span>@L["Before offer"]</button>
                <button type="button" class="chip-btn" data-value="BeforeClosing"><span class="check"><i class="fas fa-check"></i></span>@L["Before closing"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What would you like us to focus on?"]</span>
            <div class="chip-grid" id="enfoquesGroup">
                <button type="button" class="chip-btn" data-value="GeneralAssessment"><span class="check"><i class="fas fa-check"></i></span>@L["General assessment"]</button>
                <button type="button" class="chip-btn" data-value="RepairRisk"><span class="check"><i class="fas fa-check"></i></span>@L["Repair risk"]</button>
                <button type="button" class="chip-btn" data-value="RehabBudget"><span class="check"><i class="fas fa-check"></i></span>@L["Rehab budget"]</button>
                <button type="button" class="chip-btn" data-value="RentReadiness"><span class="check"><i class="fas fa-check"></i></span>@L["Rent readiness"]</button>
                <button type="button" class="chip-btn" data-value="ResalePotential"><span class="check"><i class="fas fa-check"></i></span>@L["Resale potential"]</button>
                <button type="button" class="chip-btn" data-value="NegotiationSupport"><span class="check"><i class="fas fa-check"></i></span>@L["Negotiation support"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How urgent is this inspection?"]</span>
            <div class="segmented-3" data-target="Urgencia">
                <button type="button" class="segment-btn" data-value="Normal">@L["Normal"]</button>
                <button type="button" class="segment-btn" data-value="Priority">@L["Priority"]</button>
                <button type="button" class="segment-btn" data-value="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>@L["Choose the goals that matter most so your provider can review the property from an investor perspective."]</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-cloud-arrow-up"></i> @L["Upload photos or report"]</button>
    </form>

@section Scripts {
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, selector, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initMulti(groupId, hiddenId, defaultValues){
        const hidden = document.getElementById(hiddenId);
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = defaultValues.slice();
        function render(){
            document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
        }
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    }
    initMulti('enfoquesGroup', 'EnfoquesInversion', ['RehabBudget']);
    document.querySelectorAll('.chip-grid[data-target]').forEach(group => {
        const hidden = document.getElementById(group.dataset.target);
        group.querySelectorAll('.chip-btn').forEach(btn => btn.addEventListener('click', () => {
            hidden.value = btn.dataset.value;
            group.querySelectorAll('.chip-btn').forEach(b => b.classList.toggle('active', b.dataset.value === btn.dataset.value));
        }));
        group.querySelectorAll('.chip-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.value === hidden.value));
    });
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });

</script>
}