@model IndorMvcApp.ViewModels.StructuralSignsViewModel
@{
    ViewData["Title"] = "Structural Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .chip-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .chip-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 10px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; position: relative; line-height: 1.3; }
        .chip-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .chip-btn .check { position: absolute; top: 8px; right: 8px; width: 18px; height: 18px; border-radius: 50%; background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.6rem; }
        .chip-btn.active .check { display: flex; }
        .segmented-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .segment-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.84rem; color: #64748B; cursor: pointer; text-align: center; }
        .segment-btn.active { background: rgba(0,102,204,0.08); border-color: #0066CC; color: #0066CC; }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; }
        .btn-primary, .btn-secondary { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-secondary { margin-top: 10px; border: 1.5px solid #CBD5E1; background: #FFF; color: #64748B; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="StructuralDetails" asp-route-id="@Model.InspeccionId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <strong>Structural Details</strong>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_StructuralStepper", 2)

    <h1 class="page-heading">Select the visible signs</h1>
    <p class="page-lead">Choose all signs you can currently see around the property.</p>

    <form asp-controller="Inspecciones" asp-action="StructuralSigns" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="SignosVisibles" id="SignosVisibles" />
        <input type="hidden" asp-for="SeveridadApariencia" id="SeveridadApariencia" />

        <div class="field-card">
            <span class="field-label">Visible signs</span>
            <div class="chip-grid" id="signosGroup">
                <button type="button" class="chip-btn" data-value="HairlineCrack"><span class="check"><i class="fas fa-check"></i></span>Hairline crack</button>
                <button type="button" class="chip-btn" data-value="StairStepCrack"><span class="check"><i class="fas fa-check"></i></span>Stair-step crack</button>
                <button type="button" class="chip-btn" data-value="HorizontalCrack"><span class="check"><i class="fas fa-check"></i></span>Horizontal crack</button>
                <button type="button" class="chip-btn" data-value="VerticalCrack"><span class="check"><i class="fas fa-check"></i></span>Vertical crack</button>
                <button type="button" class="chip-btn" data-value="WideCrack"><span class="check"><i class="fas fa-check"></i></span>Wide crack</button>
                <button type="button" class="chip-btn" data-value="SeparationGap"><span class="check"><i class="fas fa-check"></i></span>Separation gap</button>
                <button type="button" class="chip-btn" data-value="UnevenFloor"><span class="check"><i class="fas fa-check"></i></span>Uneven floor</button>
                <button type="button" class="chip-btn" data-value="BouncyFloor"><span class="check"><i class="fas fa-check"></i></span>Bouncy floor</button>
                <button type="button" class="chip-btn" data-value="WallBulging"><span class="check"><i class="fas fa-check"></i></span>Wall bulging</button>
                <button type="button" class="chip-btn" data-value="CeilingCrack"><span class="check"><i class="fas fa-check"></i></span>Ceiling crack</button>
                <button type="button" class="chip-btn" data-value="DoorSticking"><span class="check"><i class="fas fa-check"></i></span>Door sticking</button>
                <button type="button" class="chip-btn" data-value="WindowNotClosing"><span class="check"><i class="fas fa-check"></i></span>Window not closing</button>
                <button type="button" class="chip-btn" data-value="WaterIntrusion"><span class="check"><i class="fas fa-check"></i></span>Water intrusion</button>
                <button type="button" class="chip-btn" data-value="CrawlSpaceMoisture"><span class="check"><i class="fas fa-check"></i></span>Crawl space moisture</button>
                <button type="button" class="chip-btn" data-value="RotDecay"><span class="check"><i class="fas fa-check"></i></span>Rot or decay</button>
                <button type="button" class="chip-btn" data-value="RustedSupport"><span class="check"><i class="fas fa-check"></i></span>Rusted support</button>
                <button type="button" class="chip-btn" data-value="FoundationSettlement"><span class="check"><i class="fas fa-check"></i></span>Foundation settlement</button>
                <button type="button" class="chip-btn" data-value="RoofSaggingSign"><span class="check"><i class="fas fa-check"></i></span>Roof sagging sign</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Severity</span>
            <div class="segmented-3" id="severityGroup">
                <button type="button" class="segment-btn" data-value="Mild">Mild</button>
                <button type="button" class="segment-btn" data-value="Moderate">Moderate</button>
                <button type="button" class="segment-btn" data-value="Severe">Severe</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>You can select more than one sign. Pick every symptom that applies right now for a better provider match.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-secondary" name="action" value="back"><i class="fas fa-arrow-left"></i> Back</button>
    </form>
</div>
<script>
    function parsePipe(v){ return (v || '').split('|').map(x => x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    const signsHidden = document.getElementById('SignosVisibles');
    const severityHidden = document.getElementById('SeveridadApariencia');
    const signButtons = document.querySelectorAll('#signosGroup .chip-btn');
    const severityButtons = document.querySelectorAll('#severityGroup .segment-btn');
    let selectedSigns = parsePipe(signsHidden.value);
    if (!selectedSigns.length) selectedSigns = ['HairlineCrack'];

    function renderSigns() {
        signButtons.forEach(btn => btn.classList.toggle('active', selectedSigns.includes(btn.dataset.value)));
        signsHidden.value = joinPipe(selectedSigns);
    }

    function renderSeverity() {
        const value = severityHidden.value || 'Moderate';
        severityHidden.value = value;
        severityButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }

    signButtons.forEach(btn => btn.addEventListener('click', () => {
        const value = btn.dataset.value;
        selectedSigns = selectedSigns.includes(value)
            ? selectedSigns.filter(v => v !== value)
            : [...selectedSigns, value];
        if (!selectedSigns.length) selectedSigns = [value];
        renderSigns();
    }));

    severityButtons.forEach(btn => btn.addEventListener('click', () => {
        severityHidden.value = btn.dataset.value;
        renderSeverity();
    }));

    renderSigns();
    renderSeverity();
</script>
</body>
</html>
