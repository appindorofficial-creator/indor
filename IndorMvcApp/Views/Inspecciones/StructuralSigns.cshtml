@model IndorMvcApp.ViewModels.StructuralSignsViewModel
@{
    ViewData["Title"] = L["Structural Details - INDOR"];
    ViewData["WizardTitle"] = L["Structural Details"];
    ViewData["WizardBackUrl"] = Url.Action("StructuralDetails", "Inspecciones", new { id = Model.InspeccionId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 6;

}

<h1 class="page-heading">@L["Select the visible signs"]</h1>
    <p class="page-lead">@L["Choose all signs you can currently see around the property."]</p>

    <form asp-controller="Inspecciones" asp-action="StructuralSigns" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="SignosVisibles" id="SignosVisibles" />
        <input type="hidden" asp-for="SeveridadApariencia" id="SeveridadApariencia" />

        <div class="field-card">
            <span class="field-label">@L["Visible signs"]</span>
            <div class="chip-grid" id="signosGroup">
                <button type="button" class="chip-btn" data-value="HairlineCrack"><span class="check"><i class="fas fa-check"></i></span>@L["Hairline crack"]</button>
                <button type="button" class="chip-btn" data-value="StairStepCrack"><span class="check"><i class="fas fa-check"></i></span>@L["Stair-step crack"]</button>
                <button type="button" class="chip-btn" data-value="HorizontalCrack"><span class="check"><i class="fas fa-check"></i></span>@L["Horizontal crack"]</button>
                <button type="button" class="chip-btn" data-value="VerticalCrack"><span class="check"><i class="fas fa-check"></i></span>@L["Vertical crack"]</button>
                <button type="button" class="chip-btn" data-value="WideCrack"><span class="check"><i class="fas fa-check"></i></span>@L["Wide crack"]</button>
                <button type="button" class="chip-btn" data-value="SeparationGap"><span class="check"><i class="fas fa-check"></i></span>@L["Separation gap"]</button>
                <button type="button" class="chip-btn" data-value="UnevenFloor"><span class="check"><i class="fas fa-check"></i></span>@L["Uneven floor"]</button>
                <button type="button" class="chip-btn" data-value="BouncyFloor"><span class="check"><i class="fas fa-check"></i></span>@L["Bouncy floor"]</button>
                <button type="button" class="chip-btn" data-value="WallBulging"><span class="check"><i class="fas fa-check"></i></span>@L["Wall bulging"]</button>
                <button type="button" class="chip-btn" data-value="CeilingCrack"><span class="check"><i class="fas fa-check"></i></span>@L["Ceiling crack"]</button>
                <button type="button" class="chip-btn" data-value="DoorSticking"><span class="check"><i class="fas fa-check"></i></span>@L["Door sticking"]</button>
                <button type="button" class="chip-btn" data-value="WindowNotClosing"><span class="check"><i class="fas fa-check"></i></span>@L["Window not closing"]</button>
                <button type="button" class="chip-btn" data-value="WaterIntrusion"><span class="check"><i class="fas fa-check"></i></span>@L["Water intrusion"]</button>
                <button type="button" class="chip-btn" data-value="CrawlSpaceMoisture"><span class="check"><i class="fas fa-check"></i></span>@L["Crawl space moisture"]</button>
                <button type="button" class="chip-btn" data-value="RotDecay"><span class="check"><i class="fas fa-check"></i></span>@L["Rot or decay"]</button>
                <button type="button" class="chip-btn" data-value="RustedSupport"><span class="check"><i class="fas fa-check"></i></span>@L["Rusted support"]</button>
                <button type="button" class="chip-btn" data-value="FoundationSettlement"><span class="check"><i class="fas fa-check"></i></span>@L["Foundation settlement"]</button>
                <button type="button" class="chip-btn" data-value="RoofSaggingSign"><span class="check"><i class="fas fa-check"></i></span>@L["Roof sagging sign"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Severity"]</span>
            <div class="segmented-3" id="severityGroup">
                <button type="button" class="segment-btn" data-value="Mild">@L["Mild"]</button>
                <button type="button" class="segment-btn" data-value="Moderate">@L["Moderate"]</button>
                <button type="button" class="segment-btn" data-value="Severe">@L["Severe"]</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>@L["You can select more than one sign. Pick every symptom that applies right now for a better provider match."]</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-secondary" name="action" value="back"><i class="fas fa-arrow-left"></i> @L["Back"]</button>
    </form>
</div>
@section Scripts {
<script>
    function parsePipe(v){ return (v || '').split('|').map(x => x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    const signsHidden = document.getElementById('SignosVisibles');
    const severityHidden = document.getElementById('SeveridadApariencia');
    const signButtons = document.querySelectorAll('#signosGroup .chip-btn');
    const severityButtons = document.querySelectorAll('#severityGroup .segment-btn');
    let selectedSigns = parsePipe(signsHidden.value);
    if (!selectedSigns.length) selectedSigns = ['HairlineCrack'];

    function renderSigns() {
        signButtons.forEach(btn => btn.classList.toggle('active', selectedSigns.includes(btn.dataset.value)));
        signsHidden.value = joinPipe(selectedSigns);
    }

    function renderSeverity() {
        const value = severityHidden.value || 'Moderate';
        severityHidden.value = value;
        severityButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }

    signButtons.forEach(btn => btn.addEventListener('click', () => {
        const value = btn.dataset.value;
        selectedSigns = selectedSigns.includes(value)
            ? selectedSigns.filter(v => v !== value)
            : [...selectedSigns, value];
        if (!selectedSigns.length) selectedSigns = [value];
        renderSigns();
    }));

    severityButtons.forEach(btn => btn.addEventListener('click', () => {
        severityHidden.value = btn.dataset.value;
        renderSeverity();
    }));

    renderSigns();
    renderSeverity();

</script>
}