@model IndorMvcApp.ViewModels.MoldMoistureDetailsViewModel
@{
    ViewData["Title"] = "Mold & Moisture Details - INDOR";
    ViewData["WizardTitle"] = "Mold & Moisture Details";
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">Tell us about your mold or moisture concern</h1>
    <p class="page-lead">This helps us send the right provider and prepare the inspection faster.</p>

    <form asp-controller="Inspecciones" asp-action="MoldMoistureDetails" method="post">
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="TiposProblema" id="TiposProblema" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />
        <input type="hidden" asp-for="HumedadActiva" id="HumedadActiva" />

        <div class="field-card">
            <label asp-for="DireccionPropiedad" class="field-label">Property address</label>
            <div class="address-summary">
                <div class="left" style="flex:1;">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" style="border:none;background:transparent;padding:0;font-weight:600;width:100%;font-family:inherit;font-size:0.92rem;" placeholder="123 Main St, Charlotte, NC 28202" required />
                </div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What's the main issue?</span>
            <div class="chip-grid" id="tiposGroup">
                <button type="button" class="chip-btn" data-value="MustySmell"><span class="check"><i class="fas fa-check"></i></span>Musty smell</button>
                <button type="button" class="chip-btn" data-value="VisibleMold"><span class="check"><i class="fas fa-check"></i></span>Visible mold</button>
                <button type="button" class="chip-btn" data-value="WaterStain"><span class="check"><i class="fas fa-check"></i></span>Water stain</button>
                <button type="button" class="chip-btn" data-value="ActiveLeak"><span class="check"><i class="fas fa-check"></i></span>Active leak</button>
                <button type="button" class="chip-btn" data-value="Condensation"><span class="check"><i class="fas fa-check"></i></span>Condensation</button>
                <button type="button" class="chip-btn" data-value="CrawlSpaceHumidity"><span class="check"><i class="fas fa-check"></i></span>Crawl space humidity</button>
                <button type="button" class="chip-btn" data-value="BathroomMoisture"><span class="check"><i class="fas fa-check"></i></span>Bathroom moisture</button>
                <button type="button" class="chip-btn" data-value="AtticMoisture"><span class="check"><i class="fas fa-check"></i></span>Attic moisture</button>
                <button type="button" class="chip-btn" data-value="HvacMoisture"><span class="check"><i class="fas fa-check"></i></span>HVAC moisture</button>
                <button type="button" class="chip-btn" data-value="GeneralReview"><span class="check"><i class="fas fa-check"></i></span>General review</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Where is it happening?</span>
            <div class="chip-grid" data-target="UbicacionProblema">
                <button type="button" class="chip-btn" data-value="Bathroom"><span class="check"><i class="fas fa-check"></i></span>Bathroom</button>
                <button type="button" class="chip-btn" data-value="Kitchen"><span class="check"><i class="fas fa-check"></i></span>Kitchen</button>
                <button type="button" class="chip-btn" data-value="Ceiling"><span class="check"><i class="fas fa-check"></i></span>Ceiling</button>
                <button type="button" class="chip-btn" data-value="Wall"><span class="check"><i class="fas fa-check"></i></span>Wall</button>
                <button type="button" class="chip-btn" data-value="CrawlSpace"><span class="check"><i class="fas fa-check"></i></span>Crawl space</button>
                <button type="button" class="chip-btn" data-value="Attic"><span class="check"><i class="fas fa-check"></i></span>Attic</button>
                <button type="button" class="chip-btn" data-value="Basement"><span class="check"><i class="fas fa-check"></i></span>Basement</button>
                <button type="button" class="chip-btn" data-value="HvacCloset"><span class="check"><i class="fas fa-check"></i></span>HVAC closet</button>
                <button type="button" class="chip-btn" data-value="AroundWindow"><span class="check"><i class="fas fa-check"></i></span>Around window</button>
                <button type="button" class="chip-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How urgent is it?</span>
            <div class="segmented-3" data-target="Urgencia">
                <button type="button" class="segment-btn" data-value="Normal">Normal</button>
                <button type="button" class="segment-btn" data-value="Priority">Priority</button>
                <button type="button" class="segment-btn emergency" data-value="Emergency">Emergency</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Is moisture active right now?</span>
            <div class="segmented-3" data-target="HumedadActiva">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>If you see spreading stains, strong odor, active leak, or visible mold growth, choose <strong>Priority</strong> or contact support immediately.</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-cloud-arrow-up"></i> Upload photos or report</button>
    </form>
</div>
@section Scripts {
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, selector, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    (function initMulti(){
        const hidden = document.getElementById('TiposProblema');
        const primary = document.getElementById('TipoProblema');
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = ['VisibleMold'];
        function render(){
            document.querySelectorAll('#tiposGroup .chip-btn').forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            primary.value = selected[0] || 'VisibleMold';
        }
        document.querySelectorAll('#tiposGroup .chip-btn').forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    })();
    document.querySelectorAll('[data-target="UbicacionProblema"]').forEach(group => {
        group.querySelectorAll('.chip-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.chip-btn', btn.dataset.value)));
        setSingle(group, '.chip-btn', document.getElementById('UbicacionProblema').value);
    });
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });

</script>
}