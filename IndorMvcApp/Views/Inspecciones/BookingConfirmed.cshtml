@model IndorMvcApp.ViewModels.BookingConfirmedViewModel
@{
    ViewData["Title"] = L["Booking Confirmed - INDOR"];
    ViewData["WizardTitle"] = L["Booking Confirmed"];
var fechaTexto = Model.FechaCita.ToString("MMM dd, yyyy", System.Globalization.CultureInfo.GetCultureInfo("en-US"));
    var headline = Model.FlowType == "investor"
        ? "Your investor inspection has been scheduled"
        : Model.FlowType == "homesafety"
        ? "Your home safety inspection has been scheduled"
        : Model.FlowType == "windowsinsulation"
        ? "Your windows and insulation inspection has been scheduled"
        : Model.FlowType == "moldmoisture"
        ? "Your mold and moisture inspection has been scheduled"
        : Model.FlowType == "roof"
        ? "Your roof inspection has been scheduled"
        : Model.FlowType == "structural"
        ? "Your structural inspection has been scheduled"
        : Model.FlowType == "hvac"
        ? "Your HVAC inspection has been scheduled"
        : Model.FlowType == "plumbing"
        ? "Your plumbing inspection has been scheduled"
        : Model.FlowType == "complete"
        ? "Your complete home inspection has been scheduled"
        : Model.NombreServicio.Contains("Electrical", StringComparison.OrdinalIgnoreCase)
            ? "Your electrical inspection has been scheduled"
            : $"Your {Model.NombreServicio.ToLowerInvariant()} has been scheduled";
    var subtext = Model.FlowType == "complete"
        ? "Everything is confirmed. We've reserved your appointment and sent your request."
        : "Everything is confirmed. We've sent your request and reserved your appointment.";
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<div class="success-wrap">
            <div class="success-icon"><i class="fas fa-check"></i></div>
            <h1 class="page-heading">@headline</h1>
            <p class="page-lead">@subtext</p>
        </div>

        <div class="summary-card">
            <div class="summary-title">@L["Appointment summary"]</div>

            <div class="summary-row">
                <i class="fas @(Model.FlowType == "investor" ? "fa-chart-line" : Model.FlowType == "homesafety" ? "fa-shield-halved" : Model.FlowType == "windowsinsulation" ? "fa-window-maximize" : Model.FlowType == "moldmoisture" ? "fa-droplet" : Model.FlowType == "roof" ? "fa-house-chimney-window" : Model.FlowType == "structural" ? "fa-building-shield" : Model.FlowType == "hvac" ? "fa-fan" : Model.FlowType == "plumbing" ? "fa-faucet" : Model.FlowType == "complete" ? "fa-clipboard-check" : Model.FlowType == "electrical" ? "fa-bolt" : "fa-house-chimney")"></i>
                <div>
                    <div class="summary-label">@L["Service"]</div>
                    <div class="summary-value">@Model.NombreServicio</div>
                </div>
            </div>

            <div class="summary-row">
                <i class="fas fa-location-dot"></i>
                <div>
                    <div class="summary-label">@L["Property"]</div>
                    <div class="summary-value">@Model.DireccionPropiedad</div>
                </div>
            </div>

            <div class="summary-row">
                <i class="fas fa-calendar-day"></i>
                <div class="datetime-grid">
                    <div>
                        <div class="summary-label">@L["Date"]</div>
                        <div class="summary-value">@fechaTexto</div>
                    </div>
                    <div>
                        <div class="summary-label">@L["Time"]</div>
                        <div class="summary-value">@Model.HoraCita</div>
                    </div>
                </div>
            </div>

            <div class="summary-row">
                <i class="fas @(Model.FlowType == "complete" || !string.IsNullOrWhiteSpace(Model.ResumenSecundarioEtiqueta) ? "fa-bullseye" : "fa-comment-dots")"></i>
                <div>
                    <div class="summary-label">@Model.ResumenEtiqueta</div>
                    <div class="summary-value">@Model.ResumenPreocupacion</div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ResumenSecundario))
            {
                <div class="summary-row">
                    <i class="fas fa-crosshairs"></i>
                    <div>
                        <div class="summary-label">@Model.ResumenSecundarioEtiqueta</div>
                        <div class="summary-value">@Model.ResumenSecundario</div>
                    </div>
                </div>
            }

            <div class="summary-row">
                <i class="fas fa-shield-check"></i>
                <div>
                    <div class="summary-label">@L["Status"]</div>
                    <div class="summary-value">
                        <span class="status-badge"><i class="fas fa-check"></i> @Model.Estado</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>@Model.InfoMensaje</div>
        </div>

        <a asp-action="BookingConfirmed" asp-route-type="@Model.FlowType" asp-route-id="@Model.SolicitudId" class="btn-primary">
            @L["View appointment"] <i class="fas fa-arrow-right"></i>
        </a>
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-schedule" class="btn-secondary">
            <i class="far fa-calendar"></i> Go to Schedule
        </a>
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-secondary">
            <i class="fas fa-house"></i> Go to My Home
        </a>