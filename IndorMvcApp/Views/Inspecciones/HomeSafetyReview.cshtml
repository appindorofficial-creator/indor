@model IndorMvcApp.ViewModels.HomeSafetyReviewViewModel
@{
    ViewData["Title"] = L["Review & Confirm - INDOR"];
    ViewData["WizardTitle"] = L["Review & Confirm"];
var priceLabel = string.Equals(Model.PrecioPrefijo, "From", StringComparison.OrdinalIgnoreCase) ? "Starting at" : Model.PrecioPrefijo;
    ViewData["WizardBackUrl"] = Url.Action("HomeSafetyUpload", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 4;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">@L["Review your inspection request"]</h1>
    <p class="page-lead">@L["Make sure everything looks right before we schedule your visit."]</p>

    <form asp-controller="Inspecciones" asp-action="HomeSafetyReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />

        <div class="service-card">
            <div class="service-row">
                <div>
                    <div class="service-name">@Model.NombreInspeccion</div>
                    <div class="service-subtitle">@Model.SubtituloInspeccion</div>
                    @if (!string.IsNullOrWhiteSpace(Model.FrecuenciaInspeccion))
                    {
                        <div class="freq-badge"><i class="far fa-calendar"></i> @Model.FrecuenciaInspeccion</div>
                    }
                </div>
                <div class="service-price">@priceLabel<br /><strong>$@Model.Precio.ToString("0") @Model.Moneda</strong></div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-row">
                <i class="fas fa-shield-halved"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Main concern"]</div>
                    <div class="summary-value">@Model.PreocupacionPrincipal</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-house"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Property"]</div>
                    <div class="summary-value">@Model.DireccionPropiedad</div>
                    <div class="summary-value" style="font-weight:500;color:#64748B;margin-top:4px;">@Model.PropiedadResumen</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-bullseye"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Focus areas"]</div>
                    <div class="summary-value">@Model.AreasEnfoqueResumen</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-user"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Access"]</div>
                    <div class="summary-value">@Model.AccesoResumen</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-images"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Files uploaded"]</div>
                    <div class="summary-value">@Model.ArchivosResumen</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-comment-dots"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Comments"]</div>
                    <div class="summary-value">@(string.IsNullOrWhiteSpace(Model.ComentariosProveedor) ? "No additional comments were provided." : Model.ComentariosProveedor)</div>
                </div>
            </div>
        </div>

        <div class="disclaimer-box">
            <i class="fas fa-circle-info"></i>
            <div>@L["This inspection helps identify visible safety concerns, detector coverage, and basic prevention issues. Installation, wiring repairs, code enforcement, and specialty testing are not included unless stated."]</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="confirm"><i class="far fa-calendar-check"></i> @L["Confirm &amp; Schedule"]</button>
        <button type="submit" class="btn-secondary" name="action" value="back">@L["Back"]</button>
    </form>