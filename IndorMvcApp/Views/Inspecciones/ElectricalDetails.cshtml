@model IndorMvcApp.ViewModels.ElectricalDetailsViewModel
@{
    ViewData["Title"] = L["Electrical Details - INDOR"];
    ViewData["WizardTitle"] = L["Electrical Details"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

</div>

        <h1 class="page-heading">@L["Tell us about your electrical concern"]</h1>
        <p class="page-lead">@L["This helps INDOR prepare the right checklist and send the right provider."]</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="ElectricalDetails" method="post" id="electricalForm">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="MotivoRevision" id="MotivoRevision" />
            <input type="hidden" asp-for="PreocupacionPrincipal" id="PreocupacionPrincipal" />
            <input type="hidden" asp-for="OcurreAhora" id="OcurreAhora" />
            <input type="hidden" asp-for="Urgencia" id="Urgencia" />

            <div class="field-card">
                <label asp-for="DireccionPropiedad" class="field-label">@L["Property address"]</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["Why do you need this review?"]</span>
                <div class="chip-group" data-target="MotivoRevision">
                    <button type="button" class="chip-btn" data-value="BuyingHome">
                        <span class="check"><i class="fas fa-check"></i></span>Buying a home
                    </button>
                    <button type="button" class="chip-btn" data-value="SafetyCheck">
                        <span class="check"><i class="fas fa-check"></i></span>Safety check
                    </button>
                    <button type="button" class="chip-btn" data-value="IssueAtHome">
                        <span class="check"><i class="fas fa-check"></i></span>Issue at home
                    </button>
                    <button type="button" class="chip-btn" data-value="InspectionFollowUp">
                        <span class="check"><i class="fas fa-check"></i></span>Inspection follow-up
                    </button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["What is the main concern?"]</span>
                <div class="concern-grid" data-target="PreocupacionPrincipal">
                    <button type="button" class="concern-btn" data-value="BreakerTrips">
                        <span class="check"><i class="fas fa-check"></i></span>Breaker trips
                    </button>
                    <button type="button" class="concern-btn" data-value="LightsFlicker">
                        <span class="check"><i class="fas fa-check"></i></span>Lights flicker
                    </button>
                    <button type="button" class="concern-btn" data-value="OutletsNotWorking">
                        <span class="check"><i class="fas fa-check"></i></span>Outlets not working
                    </button>
                    <button type="button" class="concern-btn" data-value="OldPanel">
                        <span class="check"><i class="fas fa-check"></i></span>Old panel
                    </button>
                    <button type="button" class="concern-btn" data-value="BurningSmell">
                        <span class="check"><i class="fas fa-check"></i></span>Burning smell
                    </button>
                    <button type="button" class="concern-btn" data-value="GeneralReview">
                        <span class="check"><i class="fas fa-check"></i></span>General review
                    </button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["Is this happening right now?"]</span>
                <div class="segmented-3" data-target="OcurreAhora">
                    <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                    <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                    <button type="button" class="segment-btn" data-value="Sometimes">@L["Sometimes"]</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["How urgent is it?"]</span>
                <div class="segmented-3" data-target="Urgencia">
                    <button type="button" class="segment-btn" data-value="Normal">@L["Normal"]</button>
                    <button type="button" class="segment-btn" data-value="Priority">@L["Priority"]</button>
                    <button type="button" class="segment-btn" data-value="Emergency">@L["Emergency"]</button>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                <div>@L["If there is heat, smoke, or a burning smell, choose"] <strong>@L["Emergency"]</strong> @L["or contact support immediately."]</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">
                Next <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">@L["Skip for now"]</button>
        </form>
    </div>

    <script>
        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        document.querySelectorAll('.chip-group').forEach(group => {
            group.querySelectorAll('.chip-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.chip-btn', btn.dataset.value));
            });
            setSingle(group, '.chip-btn', document.getElementById(group.dataset.target).value);
        });

        document.querySelectorAll('.concern-grid').forEach(group => {
            group.querySelectorAll('.concern-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.concern-btn', btn.dataset.value));
            });
            setSingle(group, '.concern-btn', document.getElementById(group.dataset.target).value);
        });

        document.querySelectorAll('.segmented-3').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value));
            });
            setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
        });
    
</script>
}