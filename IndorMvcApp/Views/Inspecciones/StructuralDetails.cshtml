@model IndorMvcApp.ViewModels.StructuralDetailsViewModel
@{
    ViewData["Title"] = "Structural Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .page-heading { font-size: 1.45rem; font-weight: 800; line-height: 1.25; margin-bottom: 8px; }
        .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .form-input { width: 100%; padding: 14px 16px 14px 42px; border: 1.5px solid #E5E7EB; border-radius: 12px; font-family: 'Inter', sans-serif; font-size: 0.95rem; background: #F9FAFB; }
        .input-wrap { position: relative; }
        .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #0066CC; }
        .issue-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .issue-btn, .area-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 10px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; position: relative; line-height: 1.3; }
        .issue-btn.active, .area-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .issue-btn .check, .area-btn .check { position: absolute; top: 8px; right: 8px; width: 18px; height: 18px; border-radius: 50%; background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.6rem; }
        .issue-btn.active .check, .area-btn.active .check { display: flex; }
        .area-group { display: flex; flex-wrap: wrap; gap: 10px; }
        .area-btn { flex: 1 1 calc(50% - 10px); min-width: 130px; font-size: 0.82rem; }
        .segmented-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .segment-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.84rem; color: #64748B; cursor: pointer; text-align: center; }
        .segment-btn.active { background: rgba(0,102,204,0.08); border-color: #0066CC; color: #0066CC; }
        .segment-btn.emergency.active { border-color: #DC2626; color: #DC2626; background: rgba(220,38,38,0.08); }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; }
        .btn-primary, .btn-secondary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
        .btn-secondary { margin-top: 10px; border: 1.5px solid #CBD5E1; background: #FFF; color: #64748B; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <strong>Structural Details</strong>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_StructuralStepper", 1)

    <h1 class="page-heading">Tell us about your structural concern</h1>
    <p class="page-lead">This helps INDOR prepare the right checklist and send the right provider.</p>

    <form asp-controller="Inspecciones" asp-action="StructuralDetails" method="post">
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="TiposPreocupacion" id="TiposPreocupacion" />
        <input type="hidden" asp-for="TipoPreocupacion" id="TipoPreocupacion" />
        <input type="hidden" asp-for="AreaPreocupacion" id="AreaPreocupacion" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />
        <input type="hidden" asp-for="DanoVisible" id="DanoVisible" />

        <div class="field-card">
            <label asp-for="DireccionPropiedad" class="field-label">Property address</label>
            <div class="input-wrap"><i class="fas fa-location-dot"></i><input asp-for="DireccionPropiedad" class="form-input" placeholder="123 Main St, Charlotte, NC 28202" required /></div>
        </div>

        <div class="field-card">
            <span class="field-label">What type of structural issue is it?</span>
            <div class="issue-grid" id="tiposGroup">
                <button type="button" class="issue-btn" data-value="FoundationCrack"><span class="check"><i class="fas fa-check"></i></span>Foundation crack</button>
                <button type="button" class="issue-btn" data-value="WallCrack"><span class="check"><i class="fas fa-check"></i></span>Wall crack</button>
                <button type="button" class="issue-btn" data-value="FloorSloping"><span class="check"><i class="fas fa-check"></i></span>Floor sloping</button>
                <button type="button" class="issue-btn" data-value="SettlementSigns"><span class="check"><i class="fas fa-check"></i></span>Settlement signs</button>
                <button type="button" class="issue-btn" data-value="SaggingFloor"><span class="check"><i class="fas fa-check"></i></span>Sagging floor</button>
                <button type="button" class="issue-btn" data-value="SaggingRoof"><span class="check"><i class="fas fa-check"></i></span>Sagging roof</button>
                <button type="button" class="issue-btn" data-value="DoorWindowSticking"><span class="check"><i class="fas fa-check"></i></span>Door / window sticking</button>
                <button type="button" class="issue-btn" data-value="SupportColumn"><span class="check"><i class="fas fa-check"></i></span>Support column</button>
                <button type="button" class="issue-btn" data-value="BeamConcern"><span class="check"><i class="fas fa-check"></i></span>Beam concern</button>
                <button type="button" class="issue-btn" data-value="CrawlSpaceIssue"><span class="check"><i class="fas fa-check"></i></span>Crawl space issue</button>
                <button type="button" class="issue-btn" data-value="ChimneyCrack"><span class="check"><i class="fas fa-check"></i></span>Chimney crack</button>
                <button type="button" class="issue-btn" data-value="GeneralReview"><span class="check"><i class="fas fa-check"></i></span>General review</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Which area needs attention?</span>
            <div class="area-group" data-target="AreaPreocupacion">
                <button type="button" class="area-btn" data-value="Foundation"><span class="check"><i class="fas fa-check"></i></span>Foundation</button>
                <button type="button" class="area-btn" data-value="InteriorWall"><span class="check"><i class="fas fa-check"></i></span>Interior wall</button>
                <button type="button" class="area-btn" data-value="ExteriorWall"><span class="check"><i class="fas fa-check"></i></span>Exterior wall</button>
                <button type="button" class="area-btn" data-value="Floor"><span class="check"><i class="fas fa-check"></i></span>Floor</button>
                <button type="button" class="area-btn" data-value="CeilingRoof"><span class="check"><i class="fas fa-check"></i></span>Ceiling / roof</button>
                <button type="button" class="area-btn" data-value="CrawlSpace"><span class="check"><i class="fas fa-check"></i></span>Crawl space</button>
                <button type="button" class="area-btn" data-value="GarageSlab"><span class="check"><i class="fas fa-check"></i></span>Garage slab</button>
                <button type="button" class="area-btn" data-value="WholeHouse"><span class="check"><i class="fas fa-check"></i></span>Whole house</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How urgent is it?</span>
            <div class="segmented-3" data-target="Urgencia">
                <button type="button" class="segment-btn" data-value="Normal">Normal</button>
                <button type="button" class="segment-btn" data-value="Priority">Priority</button>
                <button type="button" class="segment-btn emergency" data-value="Emergency">Emergency</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Is movement or cracking active right now?</span>
            <div class="segmented-3" data-target="DanoVisible">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>If you see major movement, widening cracks, or unsafe floors, choose <strong>Emergency</strong> or contact support immediately.</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-cloud-arrow-up"></i> Upload photos or report</button>
        <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
    </form>
</div>
<script>
    function parsePipe(v){return (v||'').split('|').map(x=>x.trim()).filter(Boolean);}
    function joinPipe(v){return v.join('|');}
    function setSingle(group, selector, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    (function initMulti(){
        const hidden = document.getElementById('TiposPreocupacion');
        const primary = document.getElementById('TipoPreocupacion');
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = ['FoundationCrack'];
        function render(){
            document.querySelectorAll('#tiposGroup .issue-btn').forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            primary.value = selected[0] || 'FoundationCrack';
        }
        document.querySelectorAll('#tiposGroup .issue-btn').forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    })();
    document.querySelectorAll('.area-group').forEach(group => {
        group.querySelectorAll('.area-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.area-btn', btn.dataset.value)));
        setSingle(group, '.area-btn', document.getElementById(group.dataset.target).value);
    });
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });
</script>
</body>
</html>
