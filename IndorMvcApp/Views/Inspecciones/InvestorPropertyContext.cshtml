@model IndorMvcApp.ViewModels.InvestorPropertyContextViewModel
@{
    ViewData["Title"] = L["Property & Scope - INDOR"];
    ViewData["WizardTitle"] = L["Property & Scope"];
    ViewData["WizardBackUrl"] = Url.Action("InvestorDetails", "Inspecciones", new { id = Model.InspeccionId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">@L["Tell us about the property"]</h1>
    <p class="page-lead">@L["Help us understand the property and the level of evaluation you need."]</p>

    <form asp-controller="Inspecciones" asp-action="InvestorPropertyContext" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="TipoPropiedad" id="TipoPropiedad" />
        <input type="hidden" asp-for="Ocupacion" id="Ocupacion" />
        <input type="hidden" asp-for="NivelRehab" id="NivelRehab" />
        <input type="hidden" asp-for="AreasRevision" id="AreasRevision" />
        <input type="hidden" asp-for="AccesoPreferido" id="AccesoPreferido" />

        <div class="field-card">
            <div class="address-summary"><i class="fas fa-house"></i><span>@Model.DireccionPropiedad</span></div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Property type"]</span>
            <div class="chip-grid" data-target="TipoPropiedad">
                <button type="button" class="chip-btn" data-value="SingleFamily"><span class="check"><i class="fas fa-check"></i></span>@L["Single-family"]</button>
                <button type="button" class="chip-btn" data-value="Duplex"><span class="check"><i class="fas fa-check"></i></span>@L["Duplex"]</button>
                <button type="button" class="chip-btn" data-value="Triplex"><span class="check"><i class="fas fa-check"></i></span>@L["Triplex"]</button>
                <button type="button" class="chip-btn" data-value="Condo"><span class="check"><i class="fas fa-check"></i></span>@L["Condo"]</button>
                <button type="button" class="chip-btn" data-value="SmallMultifamily"><span class="check"><i class="fas fa-check"></i></span>@L["Small multifamily"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Occupancy"]</span>
            <div class="chip-grid" data-target="Ocupacion">
                <button type="button" class="chip-btn" data-value="TenantOccupied"><span class="check"><i class="fas fa-check"></i></span>@L["Tenant occupied"]</button>
                <button type="button" class="chip-btn" data-value="Vacant"><span class="check"><i class="fas fa-check"></i></span>@L["Vacant"]</button>
                <button type="button" class="chip-btn" data-value="OwnerOccupied"><span class="check"><i class="fas fa-check"></i></span>@L["Owner occupied"]</button>
                <button type="button" class="chip-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span>@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Estimated rehab level"]</span>
            <div class="chip-grid" data-target="NivelRehab">
                <button type="button" class="chip-btn" data-value="Light"><span class="check"><i class="fas fa-check"></i></span>@L["Light"]</button>
                <button type="button" class="chip-btn" data-value="Medium"><span class="check"><i class="fas fa-check"></i></span>@L["Medium"]</button>
                <button type="button" class="chip-btn" data-value="Heavy"><span class="check"><i class="fas fa-check"></i></span>@L["Heavy"]</button>
                <button type="button" class="chip-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span>@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Main areas to review"]</span>
            <div class="chip-grid" id="areasGroup">
                <button type="button" class="chip-btn" data-value="Roof"><span class="check"><i class="fas fa-check"></i></span>@L["Roof"]</button>
                <button type="button" class="chip-btn" data-value="Hvac"><span class="check"><i class="fas fa-check"></i></span>@L["HVAC"]</button>
                <button type="button" class="chip-btn" data-value="Plumbing"><span class="check"><i class="fas fa-check"></i></span>@L["Plumbing"]</button>
                <button type="button" class="chip-btn" data-value="Electrical"><span class="check"><i class="fas fa-check"></i></span>@L["Electrical"]</button>
                <button type="button" class="chip-btn" data-value="Foundation"><span class="check"><i class="fas fa-check"></i></span>@L["Foundation"]</button>
                <button type="button" class="chip-btn" data-value="Moisture"><span class="check"><i class="fas fa-check"></i></span>@L["Moisture"]</button>
                <button type="button" class="chip-btn" data-value="Safety"><span class="check"><i class="fas fa-check"></i></span>@L["Safety"]</button>
                <button type="button" class="chip-btn" data-value="Cosmetic"><span class="check"><i class="fas fa-check"></i></span>@L["Cosmetic"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Preferred access"]</span>
            <div class="chip-grid" data-target="AccesoPreferido">
                <button type="button" class="chip-btn" data-value="SomeoneHome"><span class="check"><i class="fas fa-check"></i></span>@L["Someone home"]</button>
                <button type="button" class="chip-btn" data-value="Lockbox"><span class="check"><i class="fas fa-check"></i></span>@L["Lockbox"]</button>
                <button type="button" class="chip-btn" data-value="RealtorAccess"><span class="check"><i class="fas fa-check"></i></span>@L["Realtor access"]</button>
                <button type="button" class="chip-btn" data-value="Vacant"><span class="check"><i class="fas fa-check"></i></span>@L["Vacant"]</button>
            </div>
        </div>

        <div class="info-box"><i class="fas fa-circle-info"></i><div>@L["This step helps the provider plan the visit and focus on the systems that matter to your investment."]</div></div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-secondary" name="action" value="back">@L["Back"]</button>
    </form>
</div>
@section Scripts {
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, value){
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll('.chip-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initMulti(groupId, hiddenId, defaultValues){
        const hidden = document.getElementById(hiddenId);
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = defaultValues.slice();
        function render(){
            document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
        }
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    }
    initMulti('areasGroup', 'AreasRevision', ['Roof', 'Hvac', 'Plumbing', 'Electrical']);
    document.querySelectorAll('.chip-grid[data-target]').forEach(group => {
        const hidden = document.getElementById(group.dataset.target);
        group.querySelectorAll('.chip-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, btn.dataset.value)));
        setSingle(group, hidden.value);
    });

</script>
}