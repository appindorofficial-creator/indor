@model IndorMvcApp.ViewModels.EmergencyWaterHeaterIssueViewModel
@{
    ViewData["Title"] = "Emergency Water Heater - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .title-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
        .title-row h1 { font-size: 1.2rem; font-weight: 800; }
        .badge-247 { background: rgba(220,38,38,0.1); color: #DC2626; font-size: 0.68rem; font-weight: 700; padding: 4px 8px; border-radius: 999px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 8px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .address-display { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: rgba(0,102,204,0.06); font-size: 0.92rem; }
        .address-display .left { display: flex; align-items: center; gap: 10px; flex: 1; }
        .address-display i { color: #0066CC; }
        .address-display input { border: none; background: transparent; font-weight: 600; width: 100%; font-family: inherit; font-size: 0.92rem; }
        .issue-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .issue-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.72rem; color: #64748B; cursor: pointer; text-align: center; position: relative; line-height: 1.3; }
        .issue-btn i { display: block; font-size: 1rem; margin-bottom: 6px; color: #94A3B8; }
        .issue-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .issue-btn.active i { color: #0066CC; }
        .issue-btn .check { position: absolute; top: 6px; right: 6px; width: 16px; height: 16px; border-radius: 50%; background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.55rem; }
        .issue-btn.active .check { display: flex; }
        .segmented-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .segment-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.84rem; color: #64748B; cursor: pointer; text-align: center; }
        .segment-btn.active { background: rgba(0,102,204,0.08); border-color: #0066CC; color: #0066CC; }
        .segment-btn.active[data-value="Emergency"] { border-color: #DC2626; color: #DC2626; background: rgba(220,38,38,0.08); }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <div style="width:44px;"></div>
    </div>

    <div class="title-row">
        <h1>Emergency Water Heater</h1>
        <span class="badge-247">24/7</span>
    </div>
    <p class="page-lead">Fast help for leaks, no hot water, or unsafe units.</p>

    @await Html.PartialAsync("_EmergencyWaterHeaterStepper", 1)

    <h2 class="page-heading">Tell us what's happening</h2>
    <p class="page-lead" style="margin-top:-4px;">Choose the issue so we can dispatch the right technician faster.</p>

    <form asp-controller="Inspecciones" asp-action="EmergencyWaterHeaterIssue" method="post">
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="TiposProblema" id="TiposProblema" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />
        <input type="hidden" asp-for="UnidadFuncionando" id="UnidadFuncionando" />

        <div class="field-card">
            <div class="address-display">
                <div class="left">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" placeholder="123 Main St, Charlotte, NC 28202" required />
                </div>
                <span style="color:#0066CC;font-weight:600;font-size:0.85rem;">Edit</span>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What's the issue?</span>
            <div class="issue-grid" id="issueGroup">
                <button type="button" class="issue-btn" data-value="NoHotWater"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-droplet"></i>No hot water</button>
                <button type="button" class="issue-btn" data-value="LeakingTank"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-water"></i>Leaking tank</button>
                <button type="button" class="issue-btn" data-value="WaterAroundUnit"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-house-flood-water"></i>Water around unit</button>
                <button type="button" class="issue-btn" data-value="PilotLight"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-fire"></i>Pilot light / ignition</button>
                <button type="button" class="issue-btn" data-value="ErrorCode"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-triangle-exclamation"></i>Error code</button>
                <button type="button" class="issue-btn" data-value="StrangeNoise"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-volume-high"></i>Strange noise</button>
                <button type="button" class="issue-btn" data-value="SmellOfGas"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-wind"></i>Smell of gas</button>
                <button type="button" class="issue-btn" data-value="PressureReliefValve"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-faucet"></i>Pressure relief valve</button>
                <button type="button" class="issue-btn" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question"></i>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How urgent is it?</span>
            <div class="segmented-3" data-target="Urgencia">
                <button type="button" class="segment-btn" data-value="Normal">Normal</button>
                <button type="button" class="segment-btn" data-value="Priority">Priority</button>
                <button type="button" class="segment-btn" data-value="Emergency">Emergency</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Is the unit still running?</span>
            <div class="segmented-3" data-target="UnidadFuncionando">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>If you smell gas or see active leaking, choose <strong>Emergency</strong>.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-camera"></i> Upload photos first</button>
    </form>
</div>
<script>
    function parsePipe(v){ return (v||'').split('|').map(x=>x.trim()).filter(Boolean); }
    function joinPipe(v){ return v.join('|'); }
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initMulti(groupId, hiddenId, primaryId, defaultValues) {
        const hidden = document.getElementById(hiddenId);
        const primary = document.getElementById(primaryId);
        let selected = parsePipe(hidden.value);
        if (!selected.length) selected = defaultValues.slice();
        function render() {
            document.querySelectorAll(`#${groupId} .issue-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = joinPipe(selected);
            primary.value = selected[0] || defaultValues[0];
        }
        document.querySelectorAll(`#${groupId} .issue-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            if (!selected.length) selected = [v];
            render();
        }));
        render();
    }
    initMulti('issueGroup', 'TiposProblema', 'TipoProblema', ['NoHotWater']);
    document.querySelectorAll('.segmented-3').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });
</script>
</body>
</html>
