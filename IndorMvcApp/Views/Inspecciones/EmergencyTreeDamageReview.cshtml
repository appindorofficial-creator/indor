@model IndorMvcApp.ViewModels.EmergencyTreeDamageReviewViewModel
@{
    ViewData["Title"] = "Tree Damage Details - INDOR";
    ViewData["WizardTitle"] = "Tree Damage Details";
var isDanger = string.Equals(Model.PeligroInmediatoResumen, "Yes", StringComparison.OrdinalIgnoreCase);
    var hasPhotos = !Model.ArchivosResumen.StartsWith("None", StringComparison.OrdinalIgnoreCase);
    ViewData["WizardBackUrl"] = Url.Action("EmergencyTreeDamagePhotos", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 3;

}

    <strong style="display:block;margin-bottom:4px;">Tree Damage Details</strong>
    <div class="step-sub">Step 3 of 3 &middot; Review and dispatch</div>

    
<h2 class="page-heading">Review your request</h2>

    <form asp-controller="Inspecciones" asp-action="EmergencyTreeDamageReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />

        <div class="summary-card">
            <div class="summary-row"><i class="fas fa-tree"></i><div style="flex:1;"><div class="summary-label">Service</div><div class="summary-value">@Model.TituloServicio</div></div></div>
            <div class="summary-row"><i class="fas fa-house"></i><div style="flex:1;"><div class="summary-label">Property</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
            <div class="summary-row"><i class="fas fa-triangle-exclamation danger"></i><div style="flex:1;"><div class="summary-label">What happened</div><div class="summary-value">@Model.ProblemaResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-location-dot"></i><div style="flex:1;"><div class="summary-label">Location</div><div class="summary-value">@Model.UbicacionResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-circle-exclamation danger"></i><div style="flex:1;"><div class="summary-label">Immediate danger</div><div class="summary-value @(isDanger ? "danger" : "")">@Model.PeligroInmediatoResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-bolt"></i><div style="flex:1;"><div class="summary-label">Utility risk</div><div class="summary-value">@Model.RiesgoUtilidadResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-road"></i><div style="flex:1;"><div class="summary-label">Access</div><div class="summary-value">@Model.AccesoCasaResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-images"></i><div style="flex:1;"><div class="summary-label">Photos</div><div class="summary-value @(hasPhotos ? "photos" : "")">@Model.ArchivosResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-phone"></i><div style="flex:1;"><div class="summary-label">Contact</div><div class="summary-value">@Model.TelefonoContacto</div></div></div>
            <div class="summary-row"><i class="fas fa-clock"></i><div style="flex:1;"><div class="summary-label">Estimated arrival</div><div class="summary-value eta">@Model.TiempoLlegadaRango</div></div></div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>Stay clear of the tree and any power lines until help arrives.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="confirm"><i class="fas fa-paper-plane"></i> Request emergency help</button>
        <button type="submit" class="btn-outline" name="action" value="back"><i class="fas fa-arrow-left"></i> Back</button>
    </form>