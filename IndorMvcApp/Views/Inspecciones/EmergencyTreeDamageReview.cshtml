@model IndorMvcApp.ViewModels.EmergencyTreeDamageReviewViewModel
@{
    ViewData["Title"] = "Tree Damage Details - INDOR";
    Layout = null;
    var isDanger = string.Equals(Model.PeligroInmediatoResumen, "Yes", StringComparison.OrdinalIgnoreCase);
    var hasPhotos = !Model.ArchivosResumen.StartsWith("None", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: inline-flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; margin-bottom: 8px; }
        .step-sub { font-size: 0.78rem; color: #64748B; margin-bottom: 14px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 16px; }
        .summary-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .summary-row { display: flex; align-items: flex-start; gap: 12px; padding: 14px 0; border-bottom: 1px solid #E5E7EB; }
        .summary-row:last-child { border-bottom: none; }
        .summary-row i { color: #0066CC; width: 18px; margin-top: 2px; text-align: center; }
        .summary-row i.danger { color: #DC2626; }
        .summary-label { font-size: 0.78rem; color: #94A3B8; margin-bottom: 4px; font-weight: 600; }
        .summary-value { font-size: 0.9rem; font-weight: 600; color: #0A2540; line-height: 1.4; }
        .summary-value.danger { color: #DC2626; }
        .summary-value.photos { color: #0066CC; }
        .summary-value.eta { color: #16A34A; }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <a asp-action="EmergencyTreeDamagePhotos" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
    <strong style="display:block;margin-bottom:4px;">Tree Damage Details</strong>
    <div class="step-sub">Step 3 of 3 · Review and dispatch</div>

    @await Html.PartialAsync("_EmergencyTreeDamageStepper", 3)

    <h2 class="page-heading">Review your request</h2>

    <form asp-controller="Inspecciones" asp-action="EmergencyTreeDamageReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />

        <div class="summary-card">
            <div class="summary-row"><i class="fas fa-tree"></i><div style="flex:1;"><div class="summary-label">Service</div><div class="summary-value">@Model.TituloServicio</div></div></div>
            <div class="summary-row"><i class="fas fa-house"></i><div style="flex:1;"><div class="summary-label">Property</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
            <div class="summary-row"><i class="fas fa-triangle-exclamation danger"></i><div style="flex:1;"><div class="summary-label">What happened</div><div class="summary-value">@Model.ProblemaResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-location-dot"></i><div style="flex:1;"><div class="summary-label">Location</div><div class="summary-value">@Model.UbicacionResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-circle-exclamation danger"></i><div style="flex:1;"><div class="summary-label">Immediate danger</div><div class="summary-value @(isDanger ? "danger" : "")">@Model.PeligroInmediatoResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-bolt"></i><div style="flex:1;"><div class="summary-label">Utility risk</div><div class="summary-value">@Model.RiesgoUtilidadResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-road"></i><div style="flex:1;"><div class="summary-label">Access</div><div class="summary-value">@Model.AccesoCasaResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-images"></i><div style="flex:1;"><div class="summary-label">Photos</div><div class="summary-value @(hasPhotos ? "photos" : "")">@Model.ArchivosResumen</div></div></div>
            <div class="summary-row"><i class="fas fa-phone"></i><div style="flex:1;"><div class="summary-label">Contact</div><div class="summary-value">@Model.TelefonoContacto</div></div></div>
            <div class="summary-row"><i class="fas fa-clock"></i><div style="flex:1;"><div class="summary-label">Estimated arrival</div><div class="summary-value eta">@Model.TiempoLlegadaRango</div></div></div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>Stay clear of the tree and any power lines until help arrives.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="confirm"><i class="fas fa-paper-plane"></i> Request emergency help</button>
        <button type="submit" class="btn-outline" name="action" value="back"><i class="fas fa-arrow-left"></i> Back</button>
    </form>
</div>
</body>
</html>
