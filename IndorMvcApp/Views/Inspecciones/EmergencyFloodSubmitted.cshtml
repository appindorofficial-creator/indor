@model IndorMvcApp.ViewModels.EmergencyFloodSubmittedViewModel
@{
    ViewData["Title"] = L["Request Confirmed - INDOR"];
    ViewData["WizardTitle"] = L["Request Confirmed"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

</div>

    <div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading">@L["Your flood emergency request has been sent"]</h1>
    <p class="page-lead">@L["We've received your details and are finding the right provider now."]</p>

    <div class="summary-card">
        <div class="arrival-badge">
            <i class="fas fa-clock"></i>
            <div class="label">@L["Estimated arrival"]</div>
            <div class="value">@Model.TiempoLlegadaRango</div>
        </div>

        <div class="summary-row">
            <i class="fas fa-water"></i>
            <div style="flex:1;"><div class="summary-label">@L["Service"]</div><div class="summary-value">@Model.TituloServicio</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-house"></i>
            <div style="flex:1;"><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-location-dot"></i>
            <div style="flex:1;"><div class="summary-label">@L["Area"]</div><div class="summary-value">@Model.AreaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-droplet"></i>
            <div style="flex:1;"><div class="summary-label">@L["Water source"]</div><div class="summary-value">@Model.CausaAguaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-faucet-drip"></i>
            <div style="flex:1;"><div class="summary-label">@L["Shutoff status"]</div><div class="summary-value">@Model.PuedeCerrarAguaResumen</div></div>
        </div>
        <div class="summary-row">
            <i class="fas fa-magnifying-glass"></i>
            <div style="flex:1;"><div class="summary-label">@L["Status"]</div><div class="summary-value"><span class="status-pill">@Model.EstadoResumen</span></div></div>
        </div>
    </div>

    <div class="info-box">
        <i class="fas fa-circle-info"></i>
        <div>@L["Keep children and pets away from standing water. If water reaches electrical outlets, avoid the area and wait for professional help."]</div>
    </div>

    <a asp-action="EmergencyFloodSubmitted" asp-route-id="@Model.SolicitudId" class="btn-primary">@L["View request"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" asp-fragment="section-schedule" class="btn-outline"><i class="fas fa-calendar"></i> @L["Go to Schedule"]</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Go to My Home"]</a>