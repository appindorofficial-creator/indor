@model IndorMvcApp.ViewModels.EmergencyRoofLeakDescribeViewModel
@{
    ViewData["Title"] = "Roof Leak Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .badge-247 { background: rgba(220,38,38,0.1); color: #DC2626; font-size: 0.68rem; font-weight: 700; padding: 4px 8px; border-radius: 999px; margin-left: 8px; }
        .step-sub { font-size: 0.78rem; color: #64748B; margin-bottom: 14px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 6px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .address-display { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: rgba(0,102,204,0.06); font-size: 0.92rem; }
        .address-display .left { display: flex; align-items: center; gap: 10px; flex: 1; }
        .address-display i { color: #0066CC; }
        .address-display input { border: none; background: transparent; font-weight: 600; width: 100%; font-family: inherit; font-size: 0.92rem; }
        .issue-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .issue-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.72rem; color: #64748B; cursor: pointer; text-align: center; line-height: 1.3; }
        .issue-btn i { display: block; font-size: 1rem; margin-bottom: 6px; color: #0066CC; }
        .issue-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .loc-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .loc-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 10px 6px; font-weight: 600; font-size: 0.68rem; color: #64748B; cursor: pointer; text-align: center; }
        .loc-btn i { display: block; font-size: 0.9rem; margin-bottom: 4px; color: #64748B; }
        .loc-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .urgency-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .urgency-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; }
        .urgency-btn i { display: block; font-size: 1rem; margin-bottom: 6px; }
        .urgency-btn.active[data-value="Emergency"] { border-color: #DC2626; color: #DC2626; background: rgba(220,38,38,0.08); }
        .urgency-btn.active[data-value="Priority"] { border-color: #EA580C; color: #EA580C; background: rgba(234,88,12,0.08); }
        .urgency-btn.active[data-value="Normal"] { border-color: #16A34A; color: #16A34A; background: rgba(22,163,74,0.08); }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <div><strong>Roof Leak Emergency</strong><span class="badge-247">24/7</span></div>
        <div style="width:44px;"></div>
    </div>
    <div class="step-sub">Step 1 of 3</div>

    @await Html.PartialAsync("_EmergencyRoofLeakStepper", 1)

    <h2 class="page-heading">Describe the roof leak</h2>
    <p class="page-lead">A few quick answers help us send the right crew faster.</p>

    <form asp-controller="Inspecciones" asp-action="EmergencyRoofLeakDescribe" method="post">
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="UbicacionFuga" id="UbicacionFuga" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />

        <div class="field-card">
            <div class="address-display">
                <div class="left">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" placeholder="123 Riverside Dr, Mount Holly, NC 28120" required />
                </div>
                <span style="color:#0066CC;font-weight:600;font-size:0.85rem;">Edit</span>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">1. What are you seeing?</span>
            <div class="issue-grid" id="issueGroup">
                <button type="button" class="issue-btn" data-value="ActiveDripping"><i class="fas fa-droplet"></i>Active dripping</button>
                <button type="button" class="issue-btn" data-value="CeilingStain"><i class="fas fa-circle"></i>Ceiling stain</button>
                <button type="button" class="issue-btn" data-value="WaterNearChimney"><i class="fas fa-house-chimney"></i>Water near chimney</button>
                <button type="button" class="issue-btn" data-value="WaterNearSkylight"><i class="fas fa-sun"></i>Water near skylight</button>
                <button type="button" class="issue-btn" data-value="MissingShingles"><i class="fas fa-th"></i>Missing shingles</button>
                <button type="button" class="issue-btn" data-value="StormDamage"><i class="fas fa-cloud-bolt"></i>Storm damage</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">2. Where is it showing up?</span>
            <div class="loc-grid" data-target="UbicacionFuga">
                <button type="button" class="loc-btn" data-value="Attic"><i class="fas fa-warehouse"></i>Attic</button>
                <button type="button" class="loc-btn" data-value="Ceiling"><i class="fas fa-lightbulb"></i>Ceiling</button>
                <button type="button" class="loc-btn" data-value="Wall"><i class="fas fa-door-open"></i>Wall</button>
                <button type="button" class="loc-btn" data-value="NearWindow"><i class="fas fa-window-maximize"></i>Near window</button>
                <button type="button" class="loc-btn" data-value="GutterEdge"><i class="fas fa-grip-lines"></i>Gutter / edge</button>
                <button type="button" class="loc-btn" data-value="Unknown"><i class="fas fa-circle-question"></i>Unknown</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">3. How urgent is it?</span>
            <div class="urgency-grid" data-target="Urgencia">
                <button type="button" class="urgency-btn" data-value="Normal"><i class="fas fa-clock" style="color:#16A34A;"></i>Normal</button>
                <button type="button" class="urgency-btn" data-value="Priority"><i class="fas fa-circle-exclamation" style="color:#EA580C;"></i>Priority</button>
                <button type="button" class="urgency-btn" data-value="Emergency"><i class="fas fa-bell" style="color:#DC2626;"></i>Emergency</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>If water is actively entering the home, choose Emergency and upload a photo if possible.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-camera"></i> Skip to photos</button>
    </form>
</div>
<script>
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('#issueGroup .issue-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('TipoProblema').value = btn.dataset.value;
            document.querySelectorAll('#issueGroup .issue-btn').forEach(b => b.classList.toggle('active', b === btn));
        });
        if (btn.dataset.value === document.getElementById('TipoProblema').value) btn.classList.add('active');
    });
    document.querySelectorAll('.loc-grid').forEach(group => {
        group.querySelectorAll('.loc-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.loc-btn', btn.dataset.value)));
        setSingle(group, '.loc-btn', document.getElementById(group.dataset.target).value);
    });
    document.querySelectorAll('.urgency-grid').forEach(group => {
        group.querySelectorAll('.urgency-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.urgency-btn', btn.dataset.value)));
        setSingle(group, '.urgency-btn', document.getElementById(group.dataset.target).value);
    });
</script>
</body>
</html>
