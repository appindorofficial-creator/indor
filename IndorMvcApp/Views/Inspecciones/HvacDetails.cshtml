@model IndorMvcApp.ViewModels.HvacDetailsViewModel
@{
    ViewData["Title"] = "HVAC Details - INDOR";
    ViewData["WizardTitle"] = "HVAC Details";
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

</div>

        <h1 class="page-heading">Tell us about your HVAC concern</h1>
        <p class="page-lead">This helps INDOR prepare the right checklist and send the right provider.</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="HvacDetails" method="post">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
            <input type="hidden" asp-for="ParteAtencion" id="ParteAtencion" />
            <input type="hidden" asp-for="Urgencia" id="Urgencia" />
            <input type="hidden" asp-for="SistemaFuncionando" id="SistemaFuncionando" />

            <div class="field-card">
                <label asp-for="DireccionPropiedad" class="field-label">Property address</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" placeholder="123 Main St, Charlotte, NC 28202" required />
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">What type of HVAC issue is it?</span>
                <div class="issue-grid" data-target="TipoProblema">
                    <button type="button" class="issue-btn" data-value="NotCooling"><span class="check"><i class="fas fa-check"></i></span>Not cooling</button>
                    <button type="button" class="issue-btn" data-value="NotHeating"><span class="check"><i class="fas fa-check"></i></span>Not heating</button>
                    <button type="button" class="issue-btn" data-value="NoAirflow"><span class="check"><i class="fas fa-check"></i></span>No airflow</button>
                    <button type="button" class="issue-btn" data-value="WeakAirflow"><span class="check"><i class="fas fa-check"></i></span>Weak airflow</button>
                    <button type="button" class="issue-btn" data-value="StrangeNoise"><span class="check"><i class="fas fa-check"></i></span>Strange noise</button>
                    <button type="button" class="issue-btn" data-value="BadSmell"><span class="check"><i class="fas fa-check"></i></span>Bad smell</button>
                    <button type="button" class="issue-btn" data-value="WaterLeak"><span class="check"><i class="fas fa-check"></i></span>Water leak</button>
                    <button type="button" class="issue-btn" data-value="FrozenCoil"><span class="check"><i class="fas fa-check"></i></span>Frozen coil</button>
                    <button type="button" class="issue-btn" data-value="ThermostatIssue"><span class="check"><i class="fas fa-check"></i></span>Thermostat issue</button>
                    <button type="button" class="issue-btn" data-value="FilterIssue"><span class="check"><i class="fas fa-check"></i></span>Filter issue</button>
                    <button type="button" class="issue-btn" data-value="HighEnergyBill"><span class="check"><i class="fas fa-check"></i></span>High energy bill</button>
                    <button type="button" class="issue-btn" data-value="AnnualMaintenance"><span class="check"><i class="fas fa-check"></i></span>Annual maintenance</button>
                    <button type="button" class="issue-btn" data-value="GeneralReview"><span class="check"><i class="fas fa-check"></i></span>General review</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">Which part needs attention?</span>
                <div class="part-group" data-target="ParteAtencion">
                    <button type="button" class="part-btn" data-value="OutdoorUnit"><span class="check"><i class="fas fa-check"></i></span>Outdoor unit</button>
                    <button type="button" class="part-btn" data-value="IndoorUnit"><span class="check"><i class="fas fa-check"></i></span>Indoor unit</button>
                    <button type="button" class="part-btn" data-value="FurnaceAirHandler"><span class="check"><i class="fas fa-check"></i></span>Furnace / air handler</button>
                    <button type="button" class="part-btn" data-value="Thermostat"><span class="check"><i class="fas fa-check"></i></span>Thermostat</button>
                    <button type="button" class="part-btn" data-value="AirFilter"><span class="check"><i class="fas fa-check"></i></span>Air filter</button>
                    <button type="button" class="part-btn" data-value="DuctVents"><span class="check"><i class="fas fa-check"></i></span>Duct / vents</button>
                    <button type="button" class="part-btn" data-value="WholeSystem"><span class="check"><i class="fas fa-check"></i></span>Whole system</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">How urgent is it?</span>
                <div class="segmented-3" data-target="Urgencia">
                    <button type="button" class="segment-btn" data-value="Normal">Normal</button>
                    <button type="button" class="segment-btn" data-value="Priority">Priority</button>
                    <button type="button" class="segment-btn emergency" data-value="Emergency">Emergency</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">Is the system running right now?</span>
                <div class="segmented-3" data-target="SistemaFuncionando">
                    <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                    <button type="button" class="segment-btn" data-value="No">No</button>
                    <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                <div>If there is no cooling or heating during extreme weather, choose <strong>Emergency</strong> or contact support immediately.</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
            <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-cloud-arrow-up"></i> Upload photos or report</button>
            <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
        </form>
    </div>

    <script>
        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }
        document.querySelectorAll('.issue-grid, .part-group').forEach(group => {
            const selector = group.classList.contains('issue-grid') ? '.issue-btn' : '.part-btn';
            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value));
            });
            setSingle(group, selector, document.getElementById(group.dataset.target).value);
        });
        document.querySelectorAll('.segmented-3').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value));
            });
            setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
        });
    
</script>
}