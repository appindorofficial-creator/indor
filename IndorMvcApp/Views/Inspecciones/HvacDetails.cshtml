@model IndorMvcApp.ViewModels.HvacDetailsViewModel
@{
    ViewData["Title"] = L["HVAC Details - INDOR"];
    ViewData["WizardTitle"] = L["HVAC Details"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}


        <h1 class="page-heading">@L["Tell us about your HVAC concern"]</h1>
        <p class="page-lead">@L["This helps INDOR prepare the right checklist and send the right provider."]</p>

        @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-controller="Inspecciones" asp-action="HvacDetails" method="post">
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
            <input type="hidden" asp-for="ParteAtencion" id="ParteAtencion" />
            <input type="hidden" asp-for="Urgencia" id="Urgencia" />
            <input type="hidden" asp-for="SistemaFuncionando" id="SistemaFuncionando" />

            <div class="field-card">
                <label asp-for="DireccionPropiedad" class="field-label">@L["Property address"]</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionPropiedad" class="form-input" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["What type of HVAC issue is it?"]</span>
                <div class="issue-grid" data-target="TipoProblema">
                    <button type="button" class="issue-btn" data-value="NotCooling"><span class="check"><i class="fas fa-check"></i></span>@L["Not cooling"]</button>
                    <button type="button" class="issue-btn" data-value="NotHeating"><span class="check"><i class="fas fa-check"></i></span>@L["Not heating"]</button>
                    <button type="button" class="issue-btn" data-value="NoAirflow"><span class="check"><i class="fas fa-check"></i></span>@L["No airflow"]</button>
                    <button type="button" class="issue-btn" data-value="WeakAirflow"><span class="check"><i class="fas fa-check"></i></span>@L["Weak airflow"]</button>
                    <button type="button" class="issue-btn" data-value="StrangeNoise"><span class="check"><i class="fas fa-check"></i></span>@L["Strange noise"]</button>
                    <button type="button" class="issue-btn" data-value="BadSmell"><span class="check"><i class="fas fa-check"></i></span>@L["Bad smell"]</button>
                    <button type="button" class="issue-btn" data-value="WaterLeak"><span class="check"><i class="fas fa-check"></i></span>@L["Water leak"]</button>
                    <button type="button" class="issue-btn" data-value="FrozenCoil"><span class="check"><i class="fas fa-check"></i></span>@L["Frozen coil"]</button>
                    <button type="button" class="issue-btn" data-value="ThermostatIssue"><span class="check"><i class="fas fa-check"></i></span>@L["Thermostat issue"]</button>
                    <button type="button" class="issue-btn" data-value="FilterIssue"><span class="check"><i class="fas fa-check"></i></span>@L["Filter issue"]</button>
                    <button type="button" class="issue-btn" data-value="HighEnergyBill"><span class="check"><i class="fas fa-check"></i></span>@L["High energy bill"]</button>
                    <button type="button" class="issue-btn" data-value="AnnualMaintenance"><span class="check"><i class="fas fa-check"></i></span>@L["Annual maintenance"]</button>
                    <button type="button" class="issue-btn" data-value="GeneralReview"><span class="check"><i class="fas fa-check"></i></span>@L["General review"]</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["Which part needs attention?"]</span>
                <div class="part-group" data-target="ParteAtencion">
                    <button type="button" class="part-btn" data-value="OutdoorUnit"><span class="check"><i class="fas fa-check"></i></span>@L["Outdoor unit"]</button>
                    <button type="button" class="part-btn" data-value="IndoorUnit"><span class="check"><i class="fas fa-check"></i></span>@L["Indoor unit"]</button>
                    <button type="button" class="part-btn" data-value="FurnaceAirHandler"><span class="check"><i class="fas fa-check"></i></span>@L["Furnace / air handler"]</button>
                    <button type="button" class="part-btn" data-value="Thermostat"><span class="check"><i class="fas fa-check"></i></span>@L["Thermostat"]</button>
                    <button type="button" class="part-btn" data-value="AirFilter"><span class="check"><i class="fas fa-check"></i></span>@L["Air filter"]</button>
                    <button type="button" class="part-btn" data-value="DuctVents"><span class="check"><i class="fas fa-check"></i></span>@L["Duct / vents"]</button>
                    <button type="button" class="part-btn" data-value="WholeSystem"><span class="check"><i class="fas fa-check"></i></span>@L["Whole system"]</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["How urgent is it?"]</span>
                <div class="segmented-3" data-target="Urgencia">
                    <button type="button" class="segment-btn" data-value="Normal">@L["Normal"]</button>
                    <button type="button" class="segment-btn" data-value="Priority">@L["Priority"]</button>
                    <button type="button" class="segment-btn emergency" data-value="Emergency">@L["Emergency"]</button>
                </div>
            </div>

            <div class="field-card">
                <span class="field-label">@L["Is the system running right now?"]</span>
                <div class="segmented-3" data-target="SistemaFuncionando">
                    <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                    <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                    <button type="button" class="segment-btn" data-value="NotSure">@L["Not sure"]</button>
                </div>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                <div>@L["If there is no cooling or heating during extreme weather, choose"] <strong>@L["Emergency"]</strong> @L["or contact support immediately."]</div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
            <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-cloud-arrow-up"></i> @L["Upload photos or report"]</button>
            <button type="submit" class="btn-secondary" name="action" value="skip">@L["Skip for now"]</button>
        </form>

@section Scripts {
    <script>
        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }
        document.querySelectorAll('.issue-grid, .part-group').forEach(group => {
            const selector = group.classList.contains('issue-grid') ? '.issue-btn' : '.part-btn';
            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value));
            });
            setSingle(group, selector, document.getElementById(group.dataset.target).value);
        });
        document.querySelectorAll('.segmented-3').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value));
            });
            setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
        });
    
</script>
}