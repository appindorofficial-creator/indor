@model IndorMvcApp.ViewModels.RoofReviewViewModel
@{
    ViewData["Title"] = L["Review & Confirm - INDOR"];
    ViewData["WizardTitle"] = L["Review & Confirm"];
    ViewData["WizardBackUrl"] = Url.Action("RoofUpload", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 4;
    ViewData["WizardTotalSteps"] = 4;

}

<h1 class="page-heading">@L["Review &amp; Confirm"]</h1>
    <p class="page-lead">@L["Please review your information before scheduling."]</p>

    <form asp-controller="Inspecciones" asp-action="RoofReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="InspeccionId" />
        <input type="hidden" asp-for="NombreInspeccion" />

        <div class="service-card">
            <div class="service-row">
                <div>
                    <div class="service-name">@L.Catalog(Model.NombreInspeccion)</div>
                    <div class="service-subtitle">@L.Catalog(Model.SubtituloInspeccion)</div>
                </div>
                <div class="service-price">$@Model.Precio.ToString("0") @Model.Moneda</div>
            </div>
        </div>

        <div class="summary-card">
            <div class="summary-row">
                <i class="fas fa-triangle-exclamation"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Main issue"]</div>
                    <div class="chip-list">
                        @foreach (var issue in Model.ProblemasPrincipales)
                        {
                            <span class="chip">@issue</span>
                        }
                    </div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-house"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Property"]</div>
                    <div class="summary-value">@Model.DireccionPropiedad</div>
                    <div class="summary-value" style="font-weight:500;color:#64748B;margin-top:4px;">@Model.PropiedadResumen</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-user"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Access"]</div>
                    <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.AccesoResumen)</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-images"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Files"]</div>
                    <div class="summary-value">@(Model.Archivos.Count == 0
                        ? L["No files uploaded"]
                        : Model.Archivos.Count == 1
                            ? L["1 photo uploaded"]
                            : L.T("{0} photos uploaded", Model.Archivos.Count))</div>
                </div>
            </div>
            <div class="summary-row">
                <i class="fas fa-comment-dots"></i>
                <div style="flex:1;">
                    <div class="summary-label">@L["Comments"]</div>
                    <div class="summary-value">@(string.IsNullOrWhiteSpace(Model.ComentariosProveedor) ? L["No additional comments were provided."] : Model.ComentariosProveedor)</div>
                </div>
            </div>
        </div>

        <div class="secure-note"><i class="fas fa-lock"></i> @L["Your inspection request will be sent after confirmation."]</div>

        <button type="submit" class="btn-primary" name="action" value="confirm">@L["Confirm &amp; Schedule"]</button>
        <button type="submit" class="btn-secondary" name="action" value="back">@L["Back"]</button>
    </form>