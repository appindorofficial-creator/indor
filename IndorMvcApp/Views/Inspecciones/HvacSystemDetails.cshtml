@model IndorMvcApp.ViewModels.HvacSystemDetailsViewModel
@{
    ViewData["Title"] = "System Details - INDOR";
    ViewData["WizardTitle"] = "System Details";
    ViewData["WizardBackUrl"] = Url.Action("HvacDetails", "Inspecciones", new { id = Model.InspeccionId });

}

</div>

        <h1 class="page-heading">Help us understand the system better</h1>
        <p class="page-lead">Add more details so we can prepare the provider and recommend the right next step.</p>

        <div class="summary-box">
            <div class="summary-row"><i class="fas fa-triangle-exclamation"></i><span><strong>Selected concern:</strong> @Model.ResumenProblema</span></div>
            <div class="summary-row"><i class="fas fa-house"></i><span><strong>Area:</strong> @Model.ResumenArea</span></div>
        </div>

        <form asp-controller="Inspecciones" asp-action="HvacSystemDetails" method="post">
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="DireccionPropiedad" />
            <input type="hidden" asp-for="TipoProblema" />
            <input type="hidden" asp-for="ParteAtencion" />
            <input type="hidden" asp-for="ResumenProblema" />
            <input type="hidden" asp-for="ResumenArea" />
            <input type="hidden" asp-for="TipoEquipo" id="TipoEquipo" />
            <input type="hidden" asp-for="CantidadSistemas" id="CantidadSistemas" />
            <input type="hidden" asp-for="ComponentesRevision" id="ComponentesRevision" />
            <input type="hidden" asp-for="EdadSistema" id="EdadSistema" />
            <input type="hidden" asp-for="FiltroCambiado" id="FiltroCambiado" />
            <input type="hidden" asp-for="TipoTermostato" id="TipoTermostato" />
            <input type="hidden" asp-for="NotasOpcionales" id="NotasOpcionales" />

            <div class="field-card">
                <div class="step-label">Question 1</div>
                <span class="field-label">What equipment do you have?</span>
                <div class="chip-grid" data-target="TipoEquipo" data-single="true">
                    <button type="button" class="chip-btn" data-value="CentralAC">Central AC</button>
                    <button type="button" class="chip-btn" data-value="HeatPump">Heat pump</button>
                    <button type="button" class="chip-btn" data-value="Furnace">Furnace</button>
                    <button type="button" class="chip-btn" data-value="AirHandler">Air handler</button>
                    <button type="button" class="chip-btn" data-value="MiniSplit">Mini split</button>
                    <button type="button" class="chip-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 2</div>
                <span class="field-label">How many systems are in the home?</span>
                <div class="segmented-3" data-target="CantidadSistemas">
                    <button type="button" class="segment-btn" data-value="One">1</button>
                    <button type="button" class="segment-btn" data-value="Two">2</button>
                    <button type="button" class="segment-btn" data-value="ThreePlus">3+</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 3</div>
                <span class="field-label">Which components should we review? (Select all that apply)</span>
                <div class="chip-grid" id="componentesGroup">
                    <button type="button" class="chip-btn" data-value="OutdoorCondenser">Outdoor condenser</button>
                    <button type="button" class="chip-btn" data-value="IndoorCoil">Indoor coil</button>
                    <button type="button" class="chip-btn" data-value="Furnace">Furnace</button>
                    <button type="button" class="chip-btn" data-value="Thermostat">Thermostat</button>
                    <button type="button" class="chip-btn" data-value="Filters">Filters</button>
                    <button type="button" class="chip-btn" data-value="Ductwork">Ductwork</button>
                    <button type="button" class="chip-btn" data-value="DrainLine">Drain line</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 4</div>
                <span class="field-label">Do you know the age of the system?</span>
                <div class="segmented-4" data-target="EdadSistema">
                    <button type="button" class="segment-btn" data-value="LessThan5">Less than 5 years</button>
                    <button type="button" class="segment-btn" data-value="FiveToTen">5&ndash;10 years</button>
                    <button type="button" class="segment-btn" data-value="TenPlus">10+ years</button>
                    <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 5</div>
                <span class="field-label">Have you changed the filter recently?</span>
                <div class="segmented-3" data-target="FiltroCambiado">
                    <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                    <button type="button" class="segment-btn" data-value="No">No</button>
                    <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 6</div>
                <span class="field-label">Thermostat type</span>
                <div class="segmented-4" data-target="TipoTermostato">
                    <button type="button" class="segment-btn" data-value="Smart">Smart thermostat</button>
                    <button type="button" class="segment-btn" data-value="StandardDigital">Standard digital</button>
                    <button type="button" class="segment-btn" data-value="OldManual">Old manual</button>
                    <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 7</div>
                <label asp-for="DescripcionProblema" class="field-label">Describe the issue</label>
                <textarea asp-for="DescripcionProblema" class="form-textarea" maxlength="500"
                          placeholder="Outdoor unit runs but the house is not cooling well, thermostat is set to 72, indoor airflow feels weak, and the upstairs is warmer than the rest of the home..."></textarea>
                <div class="char-count"><span id="descCount">0</span>/500</div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 8</div>
                <span class="field-label">Any of the following apply? (Optional)</span>
                <div class="extra-group" id="notasGroup">
                    <button type="button" class="extra-btn" data-value="UpstairsHotter">Upstairs hotter +</button>
                    <button type="button" class="extra-btn" data-value="NoisyUnit">Noisy unit +</button>
                    <button type="button" class="extra-btn" data-value="BreakerTripped">Breaker tripped +</button>
                    <button type="button" class="extra-btn" data-value="PoorAirflow">Poor airflow +</button>
                    <button type="button" class="extra-btn" data-value="TenantOccupied">Tenant occupied +</button>
                    <button type="button" class="extra-btn" data-value="RepeatedIssue">Repeated issue +</button>
                </div>
                <div class="info-box">
                    <i class="fas fa-circle-info"></i>
                    <div>The more details you provide, the faster we can diagnose and send the right specialist prepared for your visit.</div>
                </div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-arrow-right"></i></button>
            <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
        </form>
    </div>

    <script>
        function parsePipe(value) { return (value || '').split('|').map(v => v.trim()).filter(Boolean); }
        function joinPipe(values) { return values.join('|'); }

        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        document.querySelectorAll('[data-target][data-single="true"]').forEach(group => {
            group.querySelectorAll('.chip-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.chip-btn', btn.dataset.value));
            });
            setSingle(group, '.chip-btn', document.getElementById(group.dataset.target).value);
        });

        document.querySelectorAll('.segmented-3, .segmented-4').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value));
            });
            setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
        });

        function initMultiSelect(groupId, hiddenId, selector) {
            const group = document.getElementById(groupId);
            const hidden = document.getElementById(hiddenId);
            let selected = parsePipe(hidden.value);
            function render() {
                group.querySelectorAll(selector).forEach(btn => {
                    btn.classList.toggle('active', selected.includes(btn.dataset.value));
                });
                hidden.value = joinPipe(selected);
            }
            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => {
                    const value = btn.dataset.value;
                    selected = selected.includes(value) ? selected.filter(v => v !== value) : [...selected, value];
                    render();
                });
            });
            render();
        }

        initMultiSelect('componentesGroup', 'ComponentesRevision', '.chip-btn');
        initMultiSelect('notasGroup', 'NotasOpcionales', '.extra-btn');

        const desc = document.querySelector('textarea[name="DescripcionProblema"]');
        const descCount = document.getElementById('descCount');
        function updateDescCount() { descCount.textContent = (desc.value || '').length; }
        desc.addEventListener('input', updateDescCount);
        updateDescCount();
    
</script>
}