@model IndorMvcApp.ViewModels.EmergencyHvacSubmittedViewModel
@{
    ViewData["Title"] = L["Request Submitted - INDOR"];
    ViewData["WizardTitle"] = L["Request Submitted"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<strong>@L["Request Submitted"]</strong>
        <div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading">@L["Your HVAC emergency request is on the way"]</h1>
    <p class="page-lead">@L["We've sent your request and a provider is reviewing it now."]</p>

    <div class="summary-card">
        <div class="summary-row">
            <i class="fas fa-snowflake"></i>
            <div style="flex:1;">
                <div class="summary-label">@L["Service"]</div>
                <div class="summary-value">@L.Catalog(Model.TituloServicio)</div>
            </div>
        </div>
        <div class="summary-row">
            <i class="fas fa-location-dot"></i>
            <div style="flex:1;">
                <div class="summary-label">@L["Property"]</div>
                <div class="summary-value">@Model.DireccionPropiedad</div>
            </div>
        </div>
        <div class="summary-row">
            <i class="fas fa-temperature-half"></i>
            <div style="flex:1;">
                <div class="summary-label">@L["Issue"]</div>
                <div class="summary-value">@L.Catalog(Model.ProblemaResumen)</div>
            </div>
        </div>
        <div class="summary-row">
            <i class="fas fa-stopwatch"></i>
            <div style="flex:1;">
                <div class="summary-label">@L["Avg. arrival"]</div>
                <div class="summary-value arrival-green">@Model.TiempoLlegadaMinutos min</div>
            </div>
        </div>
        <div class="summary-row">
            <i class="fas fa-shield-halved"></i>
            <div style="flex:1;">
                <div class="summary-label">@L["Status"]</div>
                <div class="summary-value"><span class="status-pill"><span class="status-dot"></span>@L.Catalog(Model.EstadoResumen)</span></div>
            </div>
        </div>
        <div class="summary-row">
            <i class="fas fa-phone"></i>
            <div style="flex:1;">
                <div class="summary-label">@L["Contact"]</div>
                <div class="summary-value">@Model.TelefonoContacto</div>
            </div>
        </div>
    </div>

    <div class="info-box">
        <i class="fas fa-circle-info"></i>
        <div>@L["Keep your phone nearby. If the system smells like burning or is smoking, leave it turned off until help arrives."]</div>
    </div>

    <a asp-action="EmergencyHvacSubmitted" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-paper-plane"></i> @L["Track request"]</a>
    <a href="tel:+17045550186" class="btn-outline"><i class="fas fa-phone"></i> @L["Call support"]</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Go to Home"]</a>