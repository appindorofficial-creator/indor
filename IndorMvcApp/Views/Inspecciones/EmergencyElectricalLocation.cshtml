@model IndorMvcApp.ViewModels.EmergencyElectricalLocationViewModel
@{
    ViewData["Title"] = "Electrical emergency - INDOR";
    ViewData["WizardTitle"] = "Electrical emergency";
    ViewData["WizardBackUrl"] = Url.Action("EmergencyElectricalProblem", "Inspecciones", new { id = Model.ServicioEmergenciaId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 3;

}


    <strong style="display:block;margin-bottom:6px;">Electrical emergency</strong>
    
<div class="issue-banner"><i class="fas fa-bolt"></i> @Model.ProblemaResumen</div>

    <h2 class="page-heading">Location &amp; safety</h2>

    <form asp-controller="Inspecciones" asp-action="EmergencyElectricalLocation" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ProblemaResumen" />
        <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
        <input type="hidden" asp-for="SintomasNotados" id="SintomasNotados" />
        <input type="hidden" asp-for="EnergiaEncendida" id="EnergiaEncendida" />
        <input type="hidden" asp-for="PuedeAlejarse" id="PuedeAlejarse" />

        <div class="field-card">
            <span class="field-label">Where is the problem?</span>
            <div class="option-grid" data-target="UbicacionProblema" data-single="true">
                <button type="button" class="option-btn" data-value="WholeHouse">Whole house</button>
                <button type="button" class="option-btn" data-value="Kitchen">Kitchen</button>
                <button type="button" class="option-btn" data-value="LivingRoom">Living room</button>
                <button type="button" class="option-btn" data-value="Bedroom">Bedroom</button>
                <button type="button" class="option-btn" data-value="Bathroom">Bathroom</button>
                <button type="button" class="option-btn" data-value="Garage">Garage</button>
                <button type="button" class="option-btn" data-value="Outside">Outside</button>
                <button type="button" class="option-btn" data-value="ElectricalPanel">Electrical panel</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What do you notice right now? (Select all that apply)</span>
            <div class="symptom-list" id="symptomGroup">
                <button type="button" class="symptom-btn" data-value="NoPower">No power <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="Sparks">Sparks <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="BurningSmell">Burning smell <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="WarmOutlet">Warm outlet <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="Buzzing">Buzzing <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="LightsFlickering">Lights flickering <i class="fas fa-check check"></i></button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Is power still on in that area?</span>
            <div class="choice-row" data-target="EnergiaEncendida">
                <button type="button" class="choice-btn" data-value="Yes"><i class="fas fa-check" style="color:#16A34A;"></i>Yes</button>
                <button type="button" class="choice-btn" data-value="No"><i class="fas fa-xmark" style="color:#DC2626;"></i>No</button>
                <button type="button" class="choice-btn" data-value="NotSure"><i class="fas fa-circle-question" style="color:#64748B;"></i>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Can you stay safely away from the affected area?</span>
            <div class="choice-row cols-2" data-target="PuedeAlejarse">
                <button type="button" class="choice-btn" data-value="Yes"><i class="fas fa-check" style="color:#16A34A;"></i>Yes</button>
                <button type="button" class="choice-btn" data-value="NeedHelp"><i class="fas fa-triangle-exclamation" style="color:#DC2626;"></i>Need help</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-shield-halved"></i>
            <div>Stay away from hot outlets, exposed wires, or panels with smoke.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Continue</button>
        <button type="submit" class="btn-outline" name="action" value="back">Back</button>
    </form>
</div>
@section Scripts {
<script>
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('[data-target][data-single]').forEach(group => {
        group.querySelectorAll('.option-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.option-btn', btn.dataset.value)));
        setSingle(group, '.option-btn', document.getElementById(group.dataset.target).value);
    });
    document.querySelectorAll('.choice-row').forEach(group => {
        group.querySelectorAll('.choice-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.choice-btn', btn.dataset.value)));
        setSingle(group, '.choice-btn', document.getElementById(group.dataset.target).value);
    });
    const hiddenSymptoms = document.getElementById('SintomasNotados');
    let selectedSymptoms = (hiddenSymptoms.value || '').split('|').map(x => x.trim()).filter(Boolean);
    function renderSymptoms() {
        document.querySelectorAll('#symptomGroup .symptom-btn').forEach(btn => btn.classList.toggle('active', selectedSymptoms.includes(btn.dataset.value)));
        hiddenSymptoms.value = selectedSymptoms.join('|');
    }
    document.querySelectorAll('#symptomGroup .symptom-btn').forEach(btn => btn.addEventListener('click', () => {
        const v = btn.dataset.value;
        selectedSymptoms = selectedSymptoms.includes(v) ? selectedSymptoms.filter(x => x !== v) : [...selectedSymptoms, v];
        renderSymptoms();
    }));
    renderSymptoms();

</script>
}