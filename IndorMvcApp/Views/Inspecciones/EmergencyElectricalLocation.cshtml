@model IndorMvcApp.ViewModels.EmergencyElectricalLocationViewModel
@{
    ViewData["Title"] = L["Electrical emergency - INDOR"];
    ViewData["WizardTitle"] = L["Electrical emergency"];
    ViewData["WizardBackUrl"] = Url.Action("EmergencyElectricalProblem", "Inspecciones", new { id = Model.ServicioEmergenciaId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 3;

}


    <strong style="display:block;margin-bottom:6px;">@L["Electrical emergency"]</strong>
    
<div class="issue-banner"><i class="fas fa-bolt"></i> @L.Catalog(Model.ProblemaResumen)</div>

    <h2 class="page-heading">@L["Location &amp; safety"]</h2>

    <form asp-controller="Inspecciones" asp-action="EmergencyElectricalLocation" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ProblemaResumen" />
        <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
        <input type="hidden" asp-for="SintomasNotados" id="SintomasNotados" />
        <input type="hidden" asp-for="EnergiaEncendida" id="EnergiaEncendida" />
        <input type="hidden" asp-for="PuedeAlejarse" id="PuedeAlejarse" />

        <div class="field-card">
            <span class="field-label">@L["Where is the problem?"]</span>
            <div class="option-grid" data-target="UbicacionProblema" data-single="true">
                <button type="button" class="option-btn" data-value="WholeHouse">@L["Whole house"]</button>
                <button type="button" class="option-btn" data-value="Kitchen">@L["Kitchen"]</button>
                <button type="button" class="option-btn" data-value="LivingRoom">@L["Living room"]</button>
                <button type="button" class="option-btn" data-value="Bedroom">@L["Bedroom"]</button>
                <button type="button" class="option-btn" data-value="Bathroom">@L["Bathroom"]</button>
                <button type="button" class="option-btn" data-value="Garage">@L["Garage"]</button>
                <button type="button" class="option-btn" data-value="Outside">@L["Outside"]</button>
                <button type="button" class="option-btn" data-value="ElectricalPanel">@L["Electrical panel"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What do you notice right now? (Select all that apply)"]</span>
            <div class="symptom-list" id="symptomGroup">
                <button type="button" class="symptom-btn" data-value="NoPower">@L["No power"] <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="Sparks">@L["Sparks"] <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="BurningSmell">@L["Burning smell"] <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="WarmOutlet">@L["Warm outlet"] <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="Buzzing">@L["Buzzing"] <i class="fas fa-check check"></i></button>
                <button type="button" class="symptom-btn" data-value="LightsFlickering">@L["Lights flickering"] <i class="fas fa-check check"></i></button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Is power still on in that area?"]</span>
            <div class="choice-row" data-target="EnergiaEncendida">
                <button type="button" class="choice-btn" data-value="Yes"><i class="fas fa-check" style="color:#16A34A;"></i>@L["Yes"]</button>
                <button type="button" class="choice-btn" data-value="No"><i class="fas fa-xmark" style="color:#DC2626;"></i>@L["No"]</button>
                <button type="button" class="choice-btn" data-value="NotSure"><i class="fas fa-circle-question" style="color:#64748B;"></i>@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Can you stay safely away from the affected area?"]</span>
            <div class="choice-row cols-2" data-target="PuedeAlejarse">
                <button type="button" class="choice-btn" data-value="Yes"><i class="fas fa-check" style="color:#16A34A;"></i>@L["Yes"]</button>
                <button type="button" class="choice-btn" data-value="NeedHelp"><i class="fas fa-triangle-exclamation" style="color:#DC2626;"></i>@L["Need help"]</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-shield-halved"></i>
            <div>@L["Stay away from hot outlets, exposed wires, or panels with smoke."]</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Continue"]</button>
        <button type="submit" class="btn-outline" name="action" value="back">@L["Back"]</button>
    </form>

@section Scripts {
<script>
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('[data-target][data-single]').forEach(group => {
        group.querySelectorAll('.option-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.option-btn', btn.dataset.value)));
        setSingle(group, '.option-btn', document.getElementById(group.dataset.target).value);
    });
    document.querySelectorAll('.choice-row').forEach(group => {
        group.querySelectorAll('.choice-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.choice-btn', btn.dataset.value)));
        setSingle(group, '.choice-btn', document.getElementById(group.dataset.target).value);
    });
    const hiddenSymptoms = document.getElementById('SintomasNotados');
    let selectedSymptoms = (hiddenSymptoms.value || '').split('|').map(x => x.trim()).filter(Boolean);
    function renderSymptoms() {
        document.querySelectorAll('#symptomGroup .symptom-btn').forEach(btn => btn.classList.toggle('active', selectedSymptoms.includes(btn.dataset.value)));
        hiddenSymptoms.value = selectedSymptoms.join('|');
    }
    document.querySelectorAll('#symptomGroup .symptom-btn').forEach(btn => btn.addEventListener('click', () => {
        const v = btn.dataset.value;
        selectedSymptoms = selectedSymptoms.includes(v) ? selectedSymptoms.filter(x => x !== v) : [...selectedSymptoms, v];
        renderSymptoms();
    }));
    renderSymptoms();

</script>
}