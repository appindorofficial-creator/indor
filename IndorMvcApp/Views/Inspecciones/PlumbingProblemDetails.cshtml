@model IndorMvcApp.ViewModels.PlumbingProblemDetailsViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = "Problem Details - INDOR";
    ViewData["WizardTitle"] = "Problem Details";
var ubicacionLabel = InspeccionDisplayLabels.UbicacionProblemaPlomeria(Model.UbicacionProblema);
    ViewData["WizardBackUrl"] = Url.Action("PlumbingDetails", "Inspecciones", new { id = Model.InspeccionId });

}

</div>

        <h1 class="page-heading">Help us understand the problem better</h1>
        <p class="page-lead">Add more details so we can prepare the provider and recommend the right next step.</p>

        <div class="summary-box">
            <div class="summary-row">
                <i class="fas fa-droplet"></i>
                <span><strong>Selected issue:</strong> @Model.ResumenProblema</span>
            </div>
            <div class="summary-row">
                <i class="fas fa-location-dot"></i>
                <span><strong>Location:</strong> @ubicacionLabel</span>
            </div>
        </div>

        <form asp-controller="Inspecciones" asp-action="PlumbingProblemDetails" method="post" id="problemForm">
            <input type="hidden" asp-for="SolicitudId" />
            <input type="hidden" asp-for="InspeccionId" />
            <input type="hidden" asp-for="NombreInspeccion" />
            <input type="hidden" asp-for="DireccionPropiedad" />
            <input type="hidden" asp-for="TipoProblema" />
            <input type="hidden" asp-for="UbicacionProblema" />
            <input type="hidden" asp-for="ResumenProblema" />
            <input type="hidden" asp-for="SituacionesActuales" id="SituacionesActuales" />
            <input type="hidden" asp-for="NotasAdicionales" id="NotasAdicionales" />
            <input type="hidden" asp-for="CuandoEmpezo" id="CuandoEmpezo" />
            <input type="hidden" asp-for="AguaCerrada" id="AguaCerrada" />

            <div class="field-card">
                <div class="step-label">Question 1</div>
                <span class="field-label">What is happening?</span>
                <div class="chip-grid" id="situacionesGroup">
                    <button type="button" class="chip-btn" data-value="LeakUnderSink">Leak under sink</button>
                    <button type="button" class="chip-btn" data-value="SlowDrain">Slow drain</button>
                    <button type="button" class="chip-btn" data-value="ClogBackup">Clog / backup</button>
                    <button type="button" class="chip-btn" data-value="PipeNoise">Pipe noise</button>
                    <button type="button" class="chip-btn" data-value="WaterStain">Water stain</button>
                    <button type="button" class="chip-btn" data-value="NoHotWater">No hot water</button>
                    <button type="button" class="chip-btn" data-value="ToiletRunning">Toilet running</button>
                    <button type="button" class="chip-btn" data-value="BadSmell">Bad smell</button>
                    <button type="button" class="chip-btn" data-value="FixtureLoose">Fixture loose</button>
                    <button type="button" class="chip-btn" data-value="LowPressure">Low pressure</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 2</div>
                <span class="field-label">When did it start?</span>
                <div class="segmented-4" data-target="CuandoEmpezo">
                    <button type="button" class="segment-btn" data-value="Today">Today</button>
                    <button type="button" class="segment-btn" data-value="ThisWeek">This week</button>
                    <button type="button" class="segment-btn" data-value="MoreThanWeek">More than a week</button>
                    <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 3</div>
                <span class="field-label">Have you already shut off the water if needed?</span>
                <div class="segmented-3" data-target="AguaCerrada">
                    <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                    <button type="button" class="segment-btn" data-value="No">No</button>
                    <button type="button" class="segment-btn" data-value="NotNeeded">Not needed</button>
                </div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 4</div>
                <label asp-for="DescripcionProblema" class="field-label">Describe the problem</label>
                <textarea asp-for="DescripcionProblema" class="form-textarea" maxlength="500"
                          placeholder="Example: There is water leaking under the kitchen sink and the drain is backing up after using the dishwasher..."></textarea>
                <div class="char-count"><span id="descCount">0</span>/500</div>
            </div>

            <div class="field-card">
                <div class="step-label">Question 5</div>
                <span class="field-label">Anything else the provider should know?</span>
                <div class="extra-group" id="notasGroup">
                    <button type="button" class="extra-btn" data-value="TenantOccupied">Tenant occupied +</button>
                    <button type="button" class="extra-btn" data-value="AccessUnderSink">Access needed under sink +</button>
                    <button type="button" class="extra-btn" data-value="RepeatedIssue">Repeated issue +</button>
                    <button type="button" class="extra-btn" data-value="AfterHoursVisit">After-hours visit needed +</button>
                </div>
                <div class="info-box">
                    <i class="fas fa-circle-info"></i>
                    <div>The more details you provide, the faster we can diagnose and send the right specialist prepared for your visit.</div>
                </div>
            </div>

            <button type="submit" class="btn-primary" name="action" value="next">
                Next <i class="fas fa-arrow-right"></i>
            </button>
            <button type="submit" class="btn-secondary" name="action" value="skip">Skip for now</button>
        </form>
    </div>

    <script>
        function parsePipe(value) {
            return (value || '').split('|').map(v => v.trim()).filter(Boolean);
        }

        function joinPipe(values) {
            return values.join('|');
        }

        function initMultiSelect(groupId, hiddenId, selector) {
            const group = document.getElementById(groupId);
            const hidden = document.getElementById(hiddenId);
            let selected = parsePipe(hidden.value);

            function render() {
                group.querySelectorAll(selector).forEach(btn => {
                    btn.classList.toggle('active', selected.includes(btn.dataset.value));
                });
                hidden.value = joinPipe(selected);
            }

            group.querySelectorAll(selector).forEach(btn => {
                btn.addEventListener('click', () => {
                    const value = btn.dataset.value;
                    if (selected.includes(value)) {
                        selected = selected.filter(v => v !== value);
                    } else {
                        selected.push(value);
                    }
                    render();
                });
            });

            if (selected.length === 0 && groupId === 'situacionesGroup') {
                selected = ['LeakUnderSink'];
            }
            render();
        }

        function setSingle(group, selector, value) {
            const targetId = group.dataset.target;
            document.getElementById(targetId).value = value;
            group.querySelectorAll(selector).forEach(btn => {
                btn.classList.toggle('active', btn.dataset.value === value);
            });
        }

        initMultiSelect('situacionesGroup', 'SituacionesActuales', '.chip-btn');
        initMultiSelect('notasGroup', 'NotasAdicionales', '.extra-btn');

        document.querySelectorAll('.segmented-3, .segmented-4').forEach(group => {
            group.querySelectorAll('.segment-btn').forEach(btn => {
                btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value));
            });
            setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
        });

        const desc = document.querySelector('textarea[name="DescripcionProblema"]');
        const descCount = document.getElementById('descCount');
        function updateDescCount() {
            descCount.textContent = (desc.value || '').length;
        }
        desc.addEventListener('input', updateDescCount);
        updateDescCount();
    
</script>
}