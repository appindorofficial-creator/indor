@model IndorMvcApp.ViewModels.EmergencyTreeDamageDescribeViewModel
@{
    ViewData["Title"] = "Tree Damage Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
        .step-sub { font-size: 0.78rem; color: #64748B; margin-bottom: 14px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 6px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .address-display { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: rgba(0,102,204,0.06); font-size: 0.92rem; }
        .address-display .left { display: flex; align-items: center; gap: 10px; flex: 1; }
        .address-display i { color: #0066CC; }
        .address-display input { border: none; background: transparent; font-weight: 600; width: 100%; font-family: inherit; font-size: 0.92rem; }
        .issue-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .issue-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.72rem; color: #64748B; cursor: pointer; text-align: center; line-height: 1.3; }
        .issue-btn i { display: block; font-size: 1rem; margin-bottom: 6px; color: #16A34A; }
        .issue-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .issue-btn.span-2 { grid-column: span 2; }
        .loc-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .loc-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 10px 6px; font-weight: 600; font-size: 0.68rem; color: #64748B; cursor: pointer; text-align: center; }
        .loc-btn i { display: block; font-size: 0.9rem; margin-bottom: 4px; color: #16A34A; }
        .loc-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .segmented-3, .segmented-4 { display: grid; gap: 8px; }
        .segmented-3 { grid-template-columns: 1fr 1fr 1fr; }
        .segmented-4 { grid-template-columns: 1fr 1fr; }
        .segment-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; }
        .segment-btn.active { background: rgba(0,102,204,0.08); border-color: #0066CC; color: #0066CC; }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-arrow-left"></i></a>
        <strong>Tree Damage Details</strong>
        <div style="width:44px;"></div>
    </div>
    <div class="step-sub">Step 1 of 3 · Describe the damage</div>

    @await Html.PartialAsync("_EmergencyTreeDamageStepper", 1)

    <h2 class="page-heading">Tell us what happened</h2>
    <p class="page-lead">We'll use this to dispatch the right crew fast.</p>

    <form asp-controller="Inspecciones" asp-action="EmergencyTreeDamageDescribe" method="post">
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="UbicacionDanio" id="UbicacionDanio" />
        <input type="hidden" asp-for="PeligroInmediato" id="PeligroInmediato" />
        <input type="hidden" asp-for="RiesgoUtilidad" id="RiesgoUtilidad" />

        <div class="field-card">
            <div class="address-display">
                <div class="left">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" placeholder="123 Riverside Dr, Mount Holly, NC 28120" required />
                </div>
                <span style="color:#0066CC;font-weight:600;font-size:0.85rem;">Edit</span>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">1. What happened?</span>
            <div class="issue-grid" id="issueGroup">
                <button type="button" class="issue-btn" data-value="TreeOnRoof"><i class="fas fa-house-chimney"></i>Tree on roof</button>
                <button type="button" class="issue-btn" data-value="FallenBranch"><i class="fas fa-code-branch"></i>Fallen branch</button>
                <button type="button" class="issue-btn" data-value="BlockedDriveway"><i class="fas fa-road-barrier"></i>Blocked driveway</button>
                <button type="button" class="issue-btn" data-value="FenceDamage"><i class="fas fa-border-all"></i>Fence damage</button>
                <button type="button" class="issue-btn" data-value="TreeLeaning"><i class="fas fa-tree"></i>Tree leaning</button>
                <button type="button" class="issue-btn" data-value="DebrisCleanup"><i class="fas fa-broom"></i>Debris cleanup</button>
                <button type="button" class="issue-btn span-2" data-value="Other"><i class="fas fa-comment"></i>Other</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">2. Where is it?</span>
            <div class="loc-grid" data-target="UbicacionDanio">
                <button type="button" class="loc-btn" data-value="FrontYard"><i class="fas fa-tree"></i>Front yard</button>
                <button type="button" class="loc-btn" data-value="BackYard"><i class="fas fa-tree"></i>Back yard</button>
                <button type="button" class="loc-btn" data-value="Roof"><i class="fas fa-house"></i>Roof</button>
                <button type="button" class="loc-btn" data-value="Driveway"><i class="fas fa-car"></i>Driveway</button>
                <button type="button" class="loc-btn" data-value="Street"><i class="fas fa-road"></i>Street</button>
                <button type="button" class="loc-btn" data-value="SideOfHouse"><i class="fas fa-house"></i>Side of house</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">3. Is there immediate danger?</span>
            <div class="segmented-3" data-target="PeligroInmediato">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">4. Any utility risk?</span>
            <div class="segmented-4" data-target="RiesgoUtilidad">
                <button type="button" class="segment-btn" data-value="NearPowerLine">Near power line</button>
                <button type="button" class="segment-btn" data-value="NearGasMeter">Near gas meter</button>
                <button type="button" class="segment-btn" data-value="NoUtilityRisk">No utility risk</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>If power lines are involved, stay back and call emergency services if needed.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-chevron-right"></i></button>
        <a href="tel:+17045550186" class="btn-outline"><i class="fas fa-phone"></i> Call now</a>
    </form>
</div>
<script>
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('#issueGroup .issue-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('TipoProblema').value = btn.dataset.value;
            document.querySelectorAll('#issueGroup .issue-btn').forEach(b => b.classList.toggle('active', b === btn));
        });
        if (btn.dataset.value === document.getElementById('TipoProblema').value) btn.classList.add('active');
    });
    document.querySelectorAll('.loc-grid').forEach(group => {
        group.querySelectorAll('.loc-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.loc-btn', btn.dataset.value)));
        setSingle(group, '.loc-btn', document.getElementById(group.dataset.target).value);
    });
    document.querySelectorAll('.segmented-3, .segmented-4').forEach(group => {
        group.querySelectorAll('.segment-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, '.segment-btn', btn.dataset.value)));
        setSingle(group, '.segment-btn', document.getElementById(group.dataset.target).value);
    });
</script>
</body>
</html>
