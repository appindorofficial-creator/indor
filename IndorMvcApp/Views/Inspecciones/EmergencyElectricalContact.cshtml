@model IndorMvcApp.ViewModels.EmergencyElectricalContactViewModel
@{
    ViewData["Title"] = L["Electrical emergency - INDOR"];
    ViewData["WizardTitle"] = L["Electrical emergency"];
    ViewData["WizardBackUrl"] = Url.Action("EmergencyElectricalLocation", "Inspecciones", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 3;

}


    <strong style="display:block;margin-bottom:6px;">@L["Electrical emergency"]</strong>
    
<h2 class="page-heading">@L["Photos &amp; callback"]</h2>
    <p class="page-lead">@L["Add anything that helps us respond faster."]</p>

    @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <div class="summary-row"><i class="fas fa-house"></i> @Model.DireccionPropiedad</div>
    <div class="summary-row issue"><i class="fas fa-bolt"></i> @Model.ProblemaResumen</div>

    <form asp-controller="Inspecciones" asp-action="EmergencyElectricalContact" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ProblemaResumen" />
        <input type="hidden" asp-for="AceptaTextos" id="AceptaTextos" />

        <div class="dropzone" id="dropzone">
            <i class="fas fa-camera"></i>
            <p><strong style="color:#0066CC;">@L["Add photo or short video"]</strong></p>
            <p style="font-size:0.82rem;color:#64748B;margin-top:4px;">@L["Optional"]</p>
        </div>
        <input type="file" id="fileInput" name="files" class="hidden-input" multiple accept=".jpg,.jpeg,.png,.mp4,.mov,.webm,image/*,video/*" />

        <div class="action-list">
            <label class="action-item" for="fileInputCamera">
                <i class="fas fa-camera icon"></i>
                <span class="action-text">@L["Take photo"]</span>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <input type="file" id="fileInputCamera" class="hidden-input" accept="image/*" capture="environment" />
            <label class="action-item" for="fileInput">
                <i class="fas fa-images icon"></i>
                <span class="action-text">@L["Upload photo"]</span>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <label class="action-item" for="fileInputVideo">
                <i class="fas fa-video icon"></i>
                <span class="action-text">@L["Add short video"]</span>
                <i class="fas fa-chevron-right chevron"></i>
            </label>
            <input type="file" id="fileInputVideo" class="hidden-input" accept="video/*,.mp4,.mov,.webm" />
        </div>

        @if (Model.ArchivosExistentes.Count > 0)
        {
            <div class="file-list">
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="file-item">
                        <span><i class="fas fa-paperclip"></i> @file.NombreArchivo</span>
                        <a href="@file.RutaArchivo" target="_blank" rel="noopener">@L["View"]</a>
                    </div>
                }
            </div>
        }
        <div id="selectedFiles" class="file-list"></div>

        <label asp-for="NotaCorta" class="field-label">@L["Short note for the electrician"]</label>
        <textarea asp-for="NotaCorta" id="NotaCorta" class="form-textarea" maxlength="250" placeholder="@L["Breaker trips when AC starts. Smell near panel."]"></textarea>
        <div class="char-count"><span id="charCount">0</span>/250</div>

        <label asp-for="TelefonoContacto" class="field-label">@L["Best callback number"]</label>
        <div class="input-wrap">
            <i class="fas fa-phone"></i>
            <input asp-for="TelefonoContacto" class="form-input" placeholder="(704) 555-0123" required />
        </div>

        <div class="toggle-row">
            <span>@L["Okay to text updates"]</span>
            <button type="button" class="toggle @(Model.AceptaTextos == "Yes" ? "on" : "")" id="textToggle" aria-label="@L["Toggle text updates"]"></button>
        </div>

        <div class="tip-box">
            <i class="fas fa-circle-info"></i>
            Photos of the panel, outlet, or affected area can help us prepare.
        </div>

        <button type="submit" class="btn-primary" name="action" value="send"><i class="fas fa-paper-plane"></i> @L["Send emergency request"]</button>
        <button type="submit" class="btn-outline" name="action" value="skip">@L["Skip and send"]</button>
    </form>
</div>
@section Scripts {
<script>
    const fileInput = document.getElementById('fileInput');
    const fileInputCamera = document.getElementById('fileInputCamera');
    const fileInputVideo = document.getElementById('fileInputVideo');
    const dropzone = document.getElementById('dropzone');
    const selectedFiles = document.getElementById('selectedFiles');
    let pendingFiles = [];
    function mergeFiles(newFiles) {
        Array.from(newFiles).forEach(f => pendingFiles.push(f));
        const dt = new DataTransfer();
        pendingFiles.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        selectedFiles.innerHTML = '';
        pendingFiles.forEach(file => {
            const item = document.createElement('div');
            item.className = 'file-item';
            item.innerHTML = `<span><i class="fas fa-file"></i> ${file.name}</span>`;
            selectedFiles.appendChild(item);
        });
    }
    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => mergeFiles(fileInput.files));
    fileInputCamera.addEventListener('change', () => mergeFiles(fileInputCamera.files));
    fileInputVideo.addEventListener('change', () => mergeFiles(fileInputVideo.files));
    const note = document.getElementById('NotaCorta');
    const charCount = document.getElementById('charCount');
    function updateCount() { charCount.textContent = (note.value || '').length; }
    note.addEventListener('input', updateCount);
    updateCount();
    const toggle = document.getElementById('textToggle');
    const hiddenText = document.getElementById('AceptaTextos');
    toggle.addEventListener('click', () => {
        toggle.classList.toggle('on');
        hiddenText.value = toggle.classList.contains('on') ? 'Yes' : 'No';
    });

</script>
}