@model IndorMvcApp.ViewModels.EmergencySmokeDetectorYourInfoViewModel
@{
    ViewData["Title"] = "Smoke & CO Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: inline-flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; margin-bottom: 8px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 6px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .summary-row { display: flex; align-items: center; gap: 10px; padding: 12px 14px; background: #FFF; border: 1px solid #E5E7EB; border-radius: 12px; margin-bottom: 8px; font-size: 0.88rem; font-weight: 600; }
        .summary-row i { color: #0066CC; width: 18px; text-align: center; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
        .access-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .access-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; }
        .access-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .form-input { width: 100%; padding: 14px 14px 14px 42px; border: 1.5px solid #E5E7EB; border-radius: 12px; font-family: 'Inter', sans-serif; font-size: 0.92rem; background: #F9FAFB; }
        .input-wrap { position: relative; }
        .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #0066CC; }
        .validation-summary { background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; border-radius: 12px; padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    </style>
</head>
<body>
<div class="page-container">
    <a asp-action="EmergencySmokeDetectorDetails" asp-route-id="@Model.ServicioEmergenciaId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
    <strong style="display:block;margin-bottom:4px;">Smoke &amp; CO Details</strong>

    @await Html.PartialAsync("_EmergencySmokeDetectorStepper", 2)

    <h2 class="page-heading">Your info</h2>
    <p class="page-lead">Help us reach you and access the property if needed.</p>

    @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <div class="summary-row"><i class="fas fa-house"></i> @Model.DireccionPropiedad</div>
    <div class="summary-row"><i class="fas fa-bell"></i> @Model.ProblemaResumen</div>

    <form asp-controller="Inspecciones" asp-action="EmergencySmokeDetectorYourInfo" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ProblemaResumen" />
        <input type="hidden" asp-for="AccesoPropiedad" id="AccesoPropiedad" />

        <div class="field-card">
            <span class="field-label">Who is at the property?</span>
            <div class="access-grid" data-target="AccesoPropiedad">
                <button type="button" class="access-btn" data-value="AdultHomeNow">Adult home now</button>
                <button type="button" class="access-btn" data-value="ChildrenHome">Children home now</button>
                <button type="button" class="access-btn" data-value="NoOneHome">No one home</button>
                <button type="button" class="access-btn" data-value="SomeoneArriving">Someone arriving soon</button>
                <button type="button" class="access-btn" data-value="NotSure" style="grid-column:span 2;">Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <label asp-for="TelefonoContacto" class="field-label">Best callback number</label>
            <div class="input-wrap">
                <i class="fas fa-phone"></i>
                <input asp-for="TelefonoContacto" class="form-input" placeholder="(704) 555-0186" required />
            </div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="back">Back</button>
    </form>
</div>
<script>
    document.querySelectorAll('[data-target]').forEach(group => {
        group.querySelectorAll('.access-btn').forEach(btn => btn.addEventListener('click', () => {
            document.getElementById(group.dataset.target).value = btn.dataset.value;
            group.querySelectorAll('.access-btn').forEach(b => b.classList.toggle('active', b === btn));
        }));
        const current = document.getElementById(group.dataset.target).value;
        const active = group.querySelector(`.access-btn[data-value="${current}"]`);
        if (active) active.classList.add('active');
    });
</script>
</body>
</html>
