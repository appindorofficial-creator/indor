@model IndorMvcApp.ViewModels.EmergencyPlumbingDetailsViewModel
@{
    ViewData["Title"] = L["Emergency Request - INDOR"];
    ViewData["WizardTitle"] = L["Emergency Request"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;

}

<h1 class="page-heading">@L["What plumbing emergency is happening?"]</h1>
    <p class="page-lead">@L["A quick check helps us send the right pro faster."]</p>

    <form asp-controller="Inspecciones" asp-action="EmergencyPlumbingDetails" method="post">
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="TipoProblema" id="TipoProblema" />
        <input type="hidden" asp-for="AguaFluyendo" id="AguaFluyendo" />
        <input type="hidden" asp-for="PuedeCerrarAgua" id="PuedeCerrarAgua" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />

        <div class="field-card">
            <div class="address-display">
                <div class="left">
                    <i class="fas fa-house"></i>
                    <input asp-for="DireccionPropiedad" placeholder="@L["123 Main St, Charlotte, NC 28202"]" required />
                </div>
                <span style="color:#0066CC;font-weight:600;font-size:0.85rem;">@L["Edit"]</span>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What's the issue?"]</span>
            <div class="issue-grid" id="issueGroup">
                <button type="button" class="issue-btn" data-value="BurstPipe"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-burst issue-icon"></i>@L["Burst pipe"]</button>
                <button type="button" class="issue-btn" data-value="LeakDripping"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-droplet issue-icon"></i>@L["Leak / dripping"]</button>
                <button type="button" class="issue-btn" data-value="CloggedDrain"><span class="check"><i class="fas fa-bath issue-icon"></i></span>@L["Clogged drain"]</button>
                <button type="button" class="issue-btn" data-value="ToiletOverflow"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-toilet issue-icon"></i>@L["Toilet overflow"]</button>
                <button type="button" class="issue-btn" data-value="MainShutoff"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-faucet issue-icon"></i>@L["Main shutoff"]</button>
                <button type="button" class="issue-btn" data-value="WaterHeaterLeak"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-fire-flame-simple issue-icon"></i>@L["Water heater leak"]</button>
                <button type="button" class="issue-btn" data-value="SewerBackup"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-pipe-section issue-icon"></i>@L["Sewer backup"]</button>
                <button type="button" class="issue-btn" data-value="Other"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-ellipsis issue-icon"></i>@L["Other"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Is water actively flowing?"]</span>
            <div class="segmented-3" data-target="AguaFluyendo">
                <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                <button type="button" class="segment-btn" data-value="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Can you shut off the water?"]</span>
            <div class="segmented-3" data-target="PuedeCerrarAgua">
                <button type="button" class="segment-btn" data-value="Yes">@L["Yes"]</button>
                <button type="button" class="segment-btn" data-value="No">@L["No"]</button>
                <button type="button" class="segment-btn" data-value="NeedHelp">@L["Need help"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How urgent is it?"]</span>
            <div class="urgency-grid" data-target="Urgencia">
                <button type="button" class="urgency-btn" data-value="Emergency"><i class="fas fa-bell"></i>@L["Emergency"]</button>
                <button type="button" class="urgency-btn" data-value="Priority"><i class="fas fa-angles-up"></i>@L["Priority"]</button>
                <button type="button" class="urgency-btn" data-value="Today"><i class="fas fa-calendar-day"></i>@L["Today"]</button>
            </div>
        </div>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>@L["If there is major flooding or sewage exposure, leave the area if needed and call emergency services first."]</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="continue">@L["Continue"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="upload"><i class="fas fa-camera"></i> @L["Upload photos first"]</button>
    </form>
</div>
@section Scripts {
<script>
    function setSingle(group, selector, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll(selector).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('#issueGroup .issue-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('TipoProblema').value = btn.dataset.value;
            document.querySelectorAll('#issueGroup .issue-btn').forEach(b => b.classList.toggle('active', b === btn));
        });
    });
    document.querySelectorAll('.segmented-3, .urgency-grid').forEach(group => {
        const selector = group.classList.contains('urgency-grid') ? '.urgency-btn' : '.segment-btn';
        group.querySelectorAll(selector).forEach(btn => btn.addEventListener('click', () => setSingle(group, selector, btn.dataset.value)));
        setSingle(group, selector, document.getElementById(group.dataset.target).value);
    });
    document.querySelectorAll('#issueGroup .issue-btn').forEach(btn => {
        if (btn.dataset.value === document.getElementById('TipoProblema').value) btn.classList.add('active');
    });

</script>
}