@model IndorMvcApp.ViewModels.EmergencyWaterHeaterDetailsViewModel
@{
    ViewData["Title"] = L["Emergency Water Heater - INDOR"];
    ViewData["WizardTitle"] = L["Emergency Water Heater"];
    ViewData["WizardBackUrl"] = Url.Action("EmergencyWaterHeaterIssue", "Inspecciones", new { id = Model.ServicioEmergenciaId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


    <div class="title-row">
        <h1>@L["Emergency Water Heater"]</h1>
        <span class="badge-247">24/7</span>
    </div>
    <p class="page-lead">@L["Fast help for leaks, no hot water, or unsafe units."]</p>

    
<h2 class="page-heading">@L["Add a few details"]</h2>
    <p class="page-lead" style="margin-top:-4px;">@L["A quick summary helps the provider arrive prepared."]</p>

    <div class="address-row">
        <span><i class="fas fa-location-dot"></i>@Model.DireccionPropiedad</span>
        <i class="fas fa-chevron-right" style="color:#CBD5E1;"></i>
    </div>

    <form asp-controller="Inspecciones" asp-action="EmergencyWaterHeaterDetails" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="UbicacionProblema" id="UbicacionProblema" />
        <input type="hidden" asp-for="TipoUnidad" id="TipoUnidad" />
        <input type="hidden" asp-for="SintomasVisibles" id="SintomasVisibles" />

        <div class="field-card">
            <span class="field-label">@L["Where is the problem?"]</span>
            <div class="chip-grid" id="locationGroup">
                <button type="button" class="chip-btn" data-value="Garage">@L["Garage"]</button>
                <button type="button" class="chip-btn" data-value="Closet">@L["Closet"]</button>
                <button type="button" class="chip-btn" data-value="Attic">@L["Attic"]</button>
                <button type="button" class="chip-btn" data-value="Basement">@L["Basement"]</button>
                <button type="button" class="chip-btn" data-value="Outside">@L["Outside"]</button>
                <button type="button" class="chip-btn" data-value="UtilityRoom">@L["Utility room"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["What type of unit?"]</span>
            <div class="chip-grid" id="unitGroup">
                <button type="button" class="chip-btn" data-value="Gas">@L["Gas"]</button>
                <button type="button" class="chip-btn" data-value="Electric">@L["Electric"]</button>
                <button type="button" class="chip-btn" data-value="Tankless">@L["Tankless"]</button>
                <button type="button" class="chip-btn" data-value="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Visible symptoms"]</span>
            <div class="chip-grid" id="symptomsGroup">
                <button type="button" class="chip-btn" data-value="WaterLeaking">@L["Water leaking"]</button>
                <button type="button" class="chip-btn" data-value="RustyWater">@L["Rusty water"]</button>
                <button type="button" class="chip-btn" data-value="NoHotWater">@L["No hot water"]</button>
                <button type="button" class="chip-btn" data-value="WarmOnly">@L["Warm only"]</button>
                <button type="button" class="chip-btn" data-value="LowPressureNearby">@L["Low pressure nearby"]</button>
                <button type="button" class="chip-btn" data-value="ErrorCode">@L["Error code"]</button>
                <button type="button" class="chip-btn" data-value="BurnerWontStayOn">@L["Burner won't stay on"]</button>
                <button type="button" class="chip-btn" data-value="PoppingNoise">@L["Popping noise"]</button>
            </div>
        </div>

        <div class="field-card">
            <label asp-for="NotaCorta" class="field-label">@L["Short note"]</label>
            <textarea asp-for="NotaCorta" class="form-textarea" maxlength="250" id="NotaCorta" placeholder="@L["Add any details that might help (e.g., when it started, any error codes)."]"></textarea>
            <div class="char-count"><span id="charCount">0</span>/250</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">@L["Next"] <i class="fas fa-arrow-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="back">@L["Back"]</button>
    </form>

@section Scripts {
<script>
    function setSingle(groupId, hiddenId, value) {
        document.getElementById(hiddenId).value = value;
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    function initSingle(groupId, hiddenId, defaultValue) {
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => setSingle(groupId, hiddenId, btn.dataset.value)));
        setSingle(groupId, hiddenId, document.getElementById(hiddenId).value || defaultValue);
    }
    function initMulti(groupId, hiddenId, defaultValues) {
        const hidden = document.getElementById(hiddenId);
        let selected = (hidden.value || '').split('|').map(x => x.trim()).filter(Boolean);
        if (!selected.length) selected = defaultValues.slice();
        function render() {
            document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.classList.toggle('active', selected.includes(btn.dataset.value)));
            hidden.value = selected.join('|');
        }
        document.querySelectorAll(`#${groupId} .chip-btn`).forEach(btn => btn.addEventListener('click', () => {
            const v = btn.dataset.value;
            selected = selected.includes(v) ? selected.filter(x => x !== v) : [...selected, v];
            render();
        }));
        render();
    }
    initSingle('locationGroup', 'UbicacionProblema', 'Garage');
    initSingle('unitGroup', 'TipoUnidad', 'Gas');
    initMulti('symptomsGroup', 'SintomasVisibles', []);
    const notes = document.getElementById('NotaCorta');
    const charCount = document.getElementById('charCount');
    function updateCount() { charCount.textContent = (notes.value || '').length; }
    notes.addEventListener('input', updateCount);
    updateCount();

</script>
}