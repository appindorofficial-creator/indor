@model IndorMvcApp.ViewModels.EmergencyTreeDamagePhotosViewModel
@{
    ViewData["Title"] = "Tree Damage Details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
        .page-container { max-width: 520px; margin: 0 auto; }
        .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: inline-flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; margin-bottom: 8px; }
        .step-sub { font-size: 0.78rem; color: #64748B; margin-bottom: 14px; }
        .page-heading { font-size: 1.35rem; font-weight: 800; margin-bottom: 6px; }
        .page-lead { font-size: 0.88rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
        .address-display { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: rgba(0,102,204,0.06); font-size: 0.92rem; margin-bottom: 14px; }
        .address-display i { color: #0066CC; margin-right: 8px; }
        .dropzone { border: 2px dashed #0066CC; border-radius: 18px; background: rgba(0,102,204,0.04); padding: 24px 18px; text-align: center; margin-bottom: 14px; cursor: pointer; }
        .dropzone i { font-size: 1.8rem; color: #0066CC; margin-bottom: 8px; }
        .action-list { display: grid; gap: 8px; margin-bottom: 16px; }
        .action-item { display: flex; align-items: center; gap: 12px; background: #FFF; border: 1px solid #E5E7EB; border-radius: 14px; padding: 14px 16px; cursor: pointer; }
        .action-item i.icon { color: #0066CC; width: 20px; text-align: center; }
        .action-item .action-text { flex: 1; font-weight: 600; font-size: 0.9rem; }
        .action-item .chevron { color: #CBD5E1; }
        .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); }
        .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 10px; display: block; }
        .choice-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .choice-row.cols-2 { grid-template-columns: 1fr 1fr; }
        .choice-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 8px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; }
        .choice-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
        .form-input, .form-textarea { width: 100%; padding: 14px; border: 1.5px solid #E5E7EB; border-radius: 12px; font-family: 'Inter', sans-serif; font-size: 0.92rem; background: #F9FAFB; }
        .form-textarea { min-height: 90px; resize: vertical; margin-top: 8px; }
        .input-wrap { position: relative; }
        .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #0066CC; }
        .input-wrap .form-input { padding-left: 42px; }
        .file-list { display: grid; gap: 8px; margin-bottom: 14px; }
        .file-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; background: #F8FAFC; border-radius: 10px; padding: 10px 12px; font-size: 0.85rem; }
        .validation-summary { background: #FEF2F2; border: 1px solid #FECACA; color: #B91C1C; border-radius: 12px; padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px; }
        .info-box { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 16px; font-size: 0.86rem; line-height: 1.45; }
        .info-box i { color: #0066CC; margin-top: 2px; flex-shrink: 0; }
        .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
        .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
        .hidden-input { display: none; }
    </style>
</head>
<body>
<div class="page-container">
    <a asp-action="EmergencyTreeDamageDescribe" asp-route-id="@Model.ServicioEmergenciaId" class="back-btn"><i class="fas fa-arrow-left"></i></a>
    <strong style="display:block;margin-bottom:4px;">Tree Damage Details</strong>
    <div class="step-sub">Step 2 of 3 · Photos and access</div>

    @await Html.PartialAsync("_EmergencyTreeDamageStepper", 2)

    <h2 class="page-heading">Add photos and access details</h2>
    <p class="page-lead">This helps our crew arrive prepared.</p>

    @if (ViewContext.ViewData.ModelState.ErrorCount > 0)
    {
        <div asp-validation-summary="All" class="validation-summary"></div>
    }

    <form asp-controller="Inspecciones" asp-action="EmergencyTreeDamagePhotos" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioEmergenciaId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TituloServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="AccesoCasa" id="AccesoCasa" />
        <input type="hidden" asp-for="EntradaBloqueada" id="EntradaBloqueada" />
        <input type="hidden" asp-for="PuedeAlejarse" id="PuedeAlejarse" />

        <div class="address-display">
            <span><i class="fas fa-house"></i>@Model.DireccionPropiedad</span>
            <a asp-action="EmergencyTreeDamageDescribe" asp-route-id="@Model.ServicioEmergenciaId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;">Edit</a>
        </div>

        <div class="dropzone" id="dropzone">
            <i class="fas fa-cloud-arrow-up"></i>
            <p><strong style="color:#0066CC;">Add photos or short video</strong></p>
            <p style="font-size:0.82rem;color:#64748B;margin-top:4px;">JPG, PNG, MOV up to 25 MB each</p>
        </div>
        <input type="file" id="fileInput" name="files" class="hidden-input" multiple accept=".jpg,.jpeg,.png,.mp4,.mov,.webm,image/*,video/*" />

        <div class="action-list">
            <label class="action-item" for="fileInputCamera"><i class="fas fa-camera icon"></i><span class="action-text">Take photo</span><i class="fas fa-chevron-right chevron"></i></label>
            <input type="file" id="fileInputCamera" class="hidden-input" accept="image/*" capture="environment" />
            <label class="action-item" for="fileInput"><i class="fas fa-images icon"></i><span class="action-text">Upload photos</span><i class="fas fa-chevron-right chevron"></i></label>
            <label class="action-item" for="fileInputVideo"><i class="fas fa-video icon"></i><span class="action-text">Add short video</span><i class="fas fa-chevron-right chevron"></i></label>
            <input type="file" id="fileInputVideo" class="hidden-input" accept="video/*,.mp4,.mov,.webm" />
        </div>

        @if (Model.ArchivosExistentes.Count > 0)
        {
            <div class="file-list">
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="file-item"><span><i class="fas fa-paperclip"></i> @file.NombreArchivo</span><a href="@file.RutaArchivo" target="_blank" rel="noopener">View</a></div>
                }
            </div>
        }
        <div id="selectedFiles" class="file-list"></div>

        <div class="field-card">
            <span class="field-label">Can you access the home?</span>
            <div class="choice-row" data-target="AccesoCasa">
                <button type="button" class="choice-btn" data-value="Yes">Yes</button>
                <button type="button" class="choice-btn" data-value="Partially">Partially</button>
                <button type="button" class="choice-btn" data-value="No">No</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Is the driveway blocked?</span>
            <div class="choice-row" data-target="EntradaBloqueada">
                <button type="button" class="choice-btn" data-value="Yes">Yes</button>
                <button type="button" class="choice-btn" data-value="No">No</button>
                <button type="button" class="choice-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Can you stay away from the damaged area?</span>
            <div class="choice-row cols-2" data-target="PuedeAlejarse">
                <button type="button" class="choice-btn" data-value="Yes">Yes</button>
                <button type="button" class="choice-btn" data-value="NeedHelp">Need help</button>
                <button type="button" class="choice-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <label asp-for="TelefonoContacto" class="field-label">Best callback number</label>
        <div class="input-wrap">
            <i class="fas fa-phone"></i>
            <input asp-for="TelefonoContacto" class="form-input" placeholder="(704) 555-0182" required />
        </div>

        <label asp-for="NotaCorta" class="field-label" style="margin-top:14px;">Notes</label>
        <textarea asp-for="NotaCorta" class="form-textarea" maxlength="500" placeholder="Large branch fell across the driveway and is touching the gutter."></textarea>

        <div class="info-box">
            <i class="fas fa-circle-info"></i>
            <div>Avoid moving heavy limbs or approaching unstable branches.</div>
        </div>

        <button type="submit" class="btn-primary" name="action" value="next">Next <i class="fas fa-chevron-right"></i></button>
        <button type="submit" class="btn-outline" name="action" value="skip">Skip photos</button>
    </form>
</div>
<script>
    function setSingle(group, value) {
        document.getElementById(group.dataset.target).value = value;
        group.querySelectorAll('.choice-btn').forEach(btn => btn.classList.toggle('active', btn.dataset.value === value));
    }
    document.querySelectorAll('[data-target]').forEach(group => {
        group.querySelectorAll('.choice-btn').forEach(btn => btn.addEventListener('click', () => setSingle(group, btn.dataset.value)));
        setSingle(group, document.getElementById(group.dataset.target).value);
    });
    const fileInput = document.getElementById('fileInput');
    const fileInputCamera = document.getElementById('fileInputCamera');
    const fileInputVideo = document.getElementById('fileInputVideo');
    const dropzone = document.getElementById('dropzone');
    const selectedFiles = document.getElementById('selectedFiles');
    let pendingFiles = [];
    function mergeFiles(newFiles) {
        Array.from(newFiles).forEach(f => pendingFiles.push(f));
        const dt = new DataTransfer();
        pendingFiles.forEach(f => dt.items.add(f));
        fileInput.files = dt.files;
        selectedFiles.innerHTML = '';
        pendingFiles.forEach(file => {
            const item = document.createElement('div');
            item.className = 'file-item';
            item.innerHTML = `<span><i class="fas fa-file"></i> ${file.name}</span>`;
            selectedFiles.appendChild(item);
        });
    }
    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => mergeFiles(fileInput.files));
    fileInputCamera.addEventListener('change', () => mergeFiles(fileInputCamera.files));
    fileInputVideo.addEventListener('change', () => mergeFiles(fileInputVideo.files));
</script>
</body>
</html>
