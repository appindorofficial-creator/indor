@model IndorMvcApp.ViewModels.HvacFilterScheduleViewModel
@{
    ViewData["Title"] = "Customize Schedule";
var recommended = Model.HasPets ? "Every2Months" : "Every3Months";
    ViewData["WizardTitle"] = "Filter Reminders";
    ViewData["WizardBackUrl"] = Url.Action("Pets", "HvacFilterReplacement", new { id = Model.PropiedadId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


        
<h1 class="hfr-title">Customize Schedule</h1>
        <p class="hfr-subtitle">Choose the schedule that works best for your home.</p>

        <div class="hfr-pet-badge">
            <i class="fas fa-paw"></i>
            Pet household: @(Model.HasPets ? "Yes" : "No")
        </div>

        <form asp-action="Schedule" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PropiedadId" />
            <input type="hidden" asp-for="HasPets" />

            <div class="hfr-schedule-list">
                <label class="hfr-schedule-option @(Model.ScheduleMode == "Every2Months" ? "selected" : "")">
                    <input type="radio" asp-for="ScheduleMode" value="Every2Months" />
                    <span class="hfr-schedule-icon"><i class="far fa-calendar"></i><em>2</em></span>
                    <span class="hfr-schedule-copy">
                        <span class="hfr-schedule-title">
                            Every 2 months
                            @if (recommended == "Every2Months")
                            {
                                <span class="hfr-rec-badge">Recommended</span>
                            }
                        </span>
                        <span class="hfr-schedule-sub">Best for homes with pets</span>
                    </span>
                </label>

                <label class="hfr-schedule-option @(Model.ScheduleMode == "Every3Months" ? "selected" : "")">
                    <input type="radio" asp-for="ScheduleMode" value="Every3Months" />
                    <span class="hfr-schedule-icon"><i class="far fa-calendar"></i><em>3</em></span>
                    <span class="hfr-schedule-copy">
                        <span class="hfr-schedule-title">
                            Every 3 months
                            @if (recommended == "Every3Months")
                            {
                                <span class="hfr-rec-badge">Recommended</span>
                            }
                        </span>
                        <span class="hfr-schedule-sub">Best for homes without pets</span>
                    </span>
                </label>

                <label class="hfr-schedule-option @(Model.ScheduleMode == "Custom" ? "selected" : "")">
                    <input type="radio" asp-for="ScheduleMode" value="Custom" />
                    <span class="hfr-schedule-icon"><i class="far fa-calendar-check"></i></span>
                    <span class="hfr-schedule-copy">
                        <span class="hfr-schedule-title">Custom date</span>
                        <span class="hfr-schedule-sub">Choose your own next change date</span>
                    </span>
                </label>
            </div>

            <p class="hfr-note-inline"><i class="fas fa-circle-info"></i> You can edit this anytime.</p>

            <button type="submit" class="hvac-save-btn hfr-continue">Continue</button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
@section Scripts {
<script>
    document.querySelectorAll('.hfr-schedule-option input').forEach(function (radio) {
        radio.addEventListener('change', function () {
            document.querySelectorAll('.hfr-schedule-option').forEach(function (o) { o.classList.remove('selected'); });
            radio.closest('.hfr-schedule-option').classList.add('selected');
        });
    });

</script>
}
