@model IndorMvcApp.ViewModels.HvacFilterPetsViewModel
@{
    ViewData["Title"] = "HVAC Filter Replacement";
    ViewData["WizardTitle"] = "Filter Reminders";
    ViewData["WizardBackUrl"] = Url.Action("Saved", "HvacSetup", new { id = Model.PropiedadId });
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}


        
<h1 class="hfr-title">HVAC Filter Replacement</h1>
        <p class="hfr-subtitle">Let's set up your filter reminder.</p>

        <p class="hfr-question">Do you have pets?</p>

        <form asp-action="Pets" method="post" id="petsForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PropiedadId" />
            <input type="hidden" asp-for="HasPets" id="hasPetsInput" />

            <button type="button" class="hfr-choice-card" data-pets="true">
                <span class="hfr-choice-icon"><i class="fas fa-paw"></i></span>
                <span class="hfr-choice-body">
                    <strong>Yes, I have pets</strong>
                    <span>Recommended every 2 months</span>
                </span>
                <i class="fas fa-chevron-right hfr-chevron"></i>
            </button>

            <button type="button" class="hfr-choice-card" data-pets="false">
                <span class="hfr-choice-icon"><i class="fas fa-house"></i></span>
                <span class="hfr-choice-body">
                    <strong>No pets</strong>
                    <span>Recommended every 3 months</span>
                </span>
                <i class="fas fa-chevron-right hfr-chevron"></i>
            </button>

            <div class="hfr-info-box">
                <i class="fas fa-circle-info"></i>
                <span>With pets we recommend every 2 months. Without pets we recommend every 3 months.</span>
            </div>

            <span asp-validation-for="HasPets" class="text-danger"></span>

            <button type="submit" class="hvac-save-btn hfr-continue" id="continueBtn" disabled>@L["Continue"]</button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
@section Scripts {
<script>
    (function () {
        var input = document.getElementById('hasPetsInput');
        var btn = document.getElementById('continueBtn');
        var cards = document.querySelectorAll('.hfr-choice-card');
        var initial = @(Model.HasPets.HasValue ? Model.HasPets.Value.ToString().ToLowerInvariant() : "null");

        function select(hasPets) {
            input.value = hasPets ? 'true' : 'false';
            cards.forEach(function (c) {
                c.classList.toggle('selected', c.getAttribute('data-pets') === String(hasPets));
            });
            btn.disabled = false;
        }

        cards.forEach(function (card) {
            card.addEventListener('click', function () {
                select(card.getAttribute('data-pets') === 'true');
            });
        });

        if (initial !== null) select(initial);
    })();

</script>
}
