@model IndorMvcApp.ViewModels.RealtorPropertyFileViewViewModel
@using IndorMvcApp.Helpers
@{
    Layout = "_RealtorLayout";
    ViewData["Title"] = L["Property File"];
    ViewBag.NavActive = "files";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("~/Views/Realtor/_RealtorTopbar.cshtml", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Files" class="rl-back-link"><i class="fas fa-chevron-left"></i> @L["Property Files"]</a>
        <h1 class="rl-page-title">@Model.Address</h1>
        @if (!string.IsNullOrWhiteSpace(Model.CityRegion))
        {
            <p class="rl-page-subtitle">@Model.CityRegion</p>
        }
    </div>

    <div class="rl-review-card rl-review-card--property rl-file-view-hero">
        <img src="@Model.PhotoUrl" alt="" />
        <div>
            <strong>@Model.Address</strong>
            @if (!string.IsNullOrWhiteSpace(Model.ClientName))
            {
                <span class="rl-premium-client"><i class="fas fa-user"></i> @Model.ClientName</span>
            }
            <span class="rl-file-code">@L.T("File ID: {0}", Model.FileCode)</span>
            <span class="rl-phase-badge rl-phase-badge--pre-closing">@Model.FilePhaseLabel</span>
            <span class="rl-status-pill rl-status-pill--@Model.StatusCss">@Model.StatusBadge</span>
            <span class="rl-premium-muted">@Model.UpdatedLabel</span>
            @if (Model.RepairItemsCount > 0)
            {
                <span class="rl-premium-muted">@L.T("Repair items: {0}", Model.RepairItemsCount)</span>
            }
            @if (Model.QuotesReceivedCount > 0)
            {
                <span class="rl-premium-muted">@L.T("Quotes received: {0}", Model.QuotesReceivedCount)</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.PrimaryActionLabel) || !string.IsNullOrWhiteSpace(Model.SecondaryActionLabel))
    {
        <div class="rl-file-view-actions">
            @if (!string.IsNullOrWhiteSpace(Model.PrimaryActionLabel) && !string.IsNullOrWhiteSpace(Model.PrimaryActionUrl))
            {
                <a href="@Model.PrimaryActionUrl" class="ob-btn ob-btn-primary">@Model.PrimaryActionLabel</a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SecondaryActionLabel) && !string.IsNullOrWhiteSpace(Model.SecondaryActionUrl))
            {
                <a href="@Model.SecondaryActionUrl" class="rl-btn-outline">@Model.SecondaryActionLabel</a>
            }
        </div>
    }

    @if (Model.Sections.Count == 0)
    {
        <div class="rl-dash-empty">
            @if (Model.PrimaryActionUrl?.Contains("RealtorInspectionUpload/Continue", StringComparison.OrdinalIgnoreCase) == true)
            {
                <span>@L["Inspection report uploaded. Continue analysis to add findings to this file."]</span>
            }
            else
            {
                <span>@L["No items in this file yet. Upload an inspection report or add content to get started."]</span>
            }
        </div>
    }
    else
    {
        @foreach (var fileSection in Model.Sections)
        {
            <div class="rl-dash-section">
                <div class="rl-dash-section-head">
                    <h2><i class="fas @fileSection.Icon"></i> @fileSection.Label</h2>
                </div>
                <ul class="rl-file-view-items">
                    @foreach (var item in fileSection.Items)
                    {
                        <li class="rl-file-view-item">
                            <div>
                                <strong>@item.ItemLabel</strong>
                                @if (!string.IsNullOrWhiteSpace(item.NoteText))
                                {
                                    <span class="rl-premium-muted">@item.NoteText</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.MetaLabel))
                                {
                                    <span class="rl-file-code">@item.MetaLabel</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(item.FileUrl))
                            {
                                var fileOpenUrl = item.FileUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                                    ? item.FileUrl
                                    : Url.Content("~" + item.FileUrl);
                                <button type="button"
                                        class="rl-btn-outline rl-btn-outline--sm rl-file-open-btn"
                                        data-file-url="@fileOpenUrl"
                                        aria-label="@L.T("Open {0}", item.ItemLabel)">
                                    @L["Open"] <i class="fas fa-arrow-up-right-from-square" aria-hidden="true"></i>
                                </button>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    }
</div>

@section Scripts {
    <script src="~/js/realtor-property-file-open.js" asp-append-version="true"></script>
}
