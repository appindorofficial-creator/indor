@model IndorMvcApp.ViewModels.RealtorPropertyFileAddItemsViewModel
@{
    var formErrors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(e => e.ErrorMessage))
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<div class="rl-prop-summary-card">
    <img src="@(Model.PhotoUrl ?? "/welcome-house.png")" alt="" />
    <div>
        <span>Property</span>
        <strong>@Model.PropertyDisplay</strong>
        <span>File Type</span>
        <strong>@Model.FilePhaseLabel</strong>
    </div>
</div>

<form id="addItemsForm" asp-action="AddItems" method="post" class="rl-invite-form" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary" role="alert"></div>

    @if (formErrors.Count > 0)
    {
        <div class="rl-error-banner" role="alert" id="propFileAddItemsFormErrors">
            <i class="fas fa-circle-exclamation"></i>
            <div>
                <strong>Please fix the following to continue:</strong>
                <ul class="rl-error-list">
                    @foreach (var msg in formErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        </div>
    }

    <h2 class="rl-invite-section-title">Select what to add <span class="rl-required" aria-hidden="true">*</span></h2>
    <div class="rl-category-grid">
        @foreach (var cat in Model.Categories)
        {
            <label class="rl-category-card @(cat.Selected ? "is-selected" : "")">
                <input type="checkbox" name="categoryTypes" value="@cat.CategoryType" @(cat.Selected ? "checked" : null) />
                <i class="fas @cat.Icon"></i>
                <strong>@cat.Label</strong>
                <span>@cat.Description</span>
                @if (cat.Selected) { <i class="fas fa-circle-check rl-collab-check"></i> }
            </label>
        }
    </div>

    <div class="rl-info-box">
        <i class="fas fa-circle-info"></i>
        <p>You can add these now and add more later from inside the file.</p>
    </div>
</form>

<div class="rl-invite-actions">
    <a asp-action="Details" class="rl-invite-cancel">Back</a>
    <button type="submit" form="addItemsForm" class="ob-btn ob-btn-primary">Next</button>
</div>

@section Scripts {
<script>
    (function () {
        var banner = document.getElementById('propFileAddItemsFormErrors');
        var summary = document.querySelector('#addItemsForm .ob-summary:not(.validation-summary-valid)');
        var scrollTarget = banner || summary;
        if (scrollTarget) {
            scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    })();
</script>
}
