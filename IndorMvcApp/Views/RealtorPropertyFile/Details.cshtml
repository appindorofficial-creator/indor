@model IndorMvcApp.ViewModels.RealtorPropertyFileDetailsViewModel
@{
    var formErrors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(e => e.ErrorMessage))
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<h2 class="rl-invite-section-title">@L["Property"] <span class="rl-required" aria-hidden="true">*</span></h2>

<form asp-action="Details" method="get" class="rl-search-form">
    <div class="rl-search-bar">
        <i class="fas fa-magnifying-glass"></i>
        <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search existing properties by address"]" />
    </div>
</form>

<form id="propFileForm" asp-action="Details" method="post" class="rl-invite-form" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary" role="alert"></div>

    @if (formErrors.Count > 0)
    {
        <div class="rl-error-banner" role="alert" id="propFileDetailsFormErrors">
            <i class="fas fa-circle-exclamation"></i>
            <div>
                <strong>@L["Please fix the following to continue:"]</strong>
                <ul class="rl-error-list">
                    @foreach (var msg in formErrors)
                    {
                        <li>@msg</li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (Model.Properties.Count == 0)
    {
        if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
        {
            <div class="rl-prop-file-empty">
                <p><strong>No property found for &ldquo;@Model.SearchQuery&rdquo;.</strong></p>
                <p class="rl-prop-file-empty-hint">@L["This step links a file to a property already in your account. Add the property first, then search again here."]</p>
                <a asp-controller="RealtorInviteClient" asp-action="CreateProperty" class="rl-btn-outline rl-btn-outline--sm">@L["Add property"]</a>
            </div>
        }
        else
        {
            <div class="rl-prop-file-empty">
                <p><strong>@L["No properties in your account yet."]</strong></p>
                <p class="rl-prop-file-empty-hint">@L["Add a property first, then return here to create a file for it."]</p>
                <a asp-controller="RealtorInviteClient" asp-action="CreateProperty" class="rl-btn-outline rl-btn-outline--sm">@L["Add property"]</a>
            </div>
        }
    }
    else
    {
        @foreach (var prop in Model.Properties)
        {
            var selected = Model.SelectedPropertyId == prop.Id;
            <label class="rl-property-pick rl-property-pick--card @(selected ? "is-selected" : "")">
                <input type="radio" name="sourcePropertyId" value="@prop.Id" @(selected ? "checked" : null) />
                <img src="@prop.PhotoUrl" alt="" class="rl-property-pick-thumb" />
                <span class="rl-property-pick-body">
                    <strong>@prop.DisplayAddress</strong>
                    @if (!string.IsNullOrWhiteSpace(prop.ClientName))
                    {
                        <span><i class="fas fa-user"></i> @prop.ClientName</span>
                    }
                </span>
                <i class="fas fa-chevron-right rl-card-chevron"></i>
            </label>
        }
    }

    <h2 class="rl-invite-section-title">@L["File Type"] <span class="rl-required" aria-hidden="true">*</span></h2>
    <div class="rl-file-type-list">
        @foreach (var opt in Model.FilePhaseOptions)
        {
            var selected = Model.FilePhase == opt.Value;
            <label class="rl-file-type-option @(selected ? "is-selected" : "")">
                <input type="radio" name="filePhase" value="@opt.Value" @(selected ? "checked" : null) />
                <i class="fas @opt.Icon"></i>
                <span>@L[opt.Label]</span>
            </label>
        }
    </div>

    <h2 class="rl-invite-section-title">@L["What this file can include"]</h2>
    <div class="rl-include-grid">
        @foreach (var cat in IndorMvcApp.Models.RealtorPropertyFileCategoryTypes.All)
        {
            <div class="rl-include-item"><i class="fas @cat.Icon"></i><span>@L[cat.Label]</span></div>
        }
    </div>

    <div class="rl-info-box">
        <i class="fas fa-circle-info"></i>
        <p>@L["Create one organized property file so clients, reports, quotes, and documents stay connected in one place."]</p>
    </div>
</form>

<div class="rl-invite-actions">
    <form asp-action="Cancel" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="rl-invite-cancel">@L["Cancel"]</button>
    </form>
    <button type="submit" form="propFileForm" class="ob-btn ob-btn-primary">@L["Next"]</button>
</div>

@section Scripts {
<script>
    (function () {
        var banner = document.getElementById('propFileDetailsFormErrors');
        var summary = document.querySelector('#propFileForm .ob-summary:not(.validation-summary-valid)');
        var scrollTarget = banner || summary;
        if (scrollTarget) {
            scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    })();
</script>
}
