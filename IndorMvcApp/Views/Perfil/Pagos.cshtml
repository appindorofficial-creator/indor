@{
    ViewData["Title"] = "Payments & History";
    ViewData["Subtitulo"] = "Track services, billing, and financing in one place.";
    var pagos = (IEnumerable<IndorMvcApp.Models.Pago>?)ViewBag.Pagos ?? Enumerable.Empty<IndorMvcApp.Models.Pago>();
    var metodos = (IEnumerable<IndorMvcApp.Models.MetodoPago>?)ViewBag.MetodosPago ?? Enumerable.Empty<IndorMvcApp.Models.MetodoPago>();
    var culture = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var year = DateTime.Today.Year;

    bool IsPending(string? s) => s is "Pendiente" or "Pending" or "Vencido" or "Overdue";
    bool IsPaid(string? s) => s is "Completado" or "Completed";
    bool IsFinance(string? s) => s is "Financiado" or "Financed";

    var pendientes = pagos.Where(p => IsPending(p.Estado)).ToList();
    var financiados = pagos.Where(p => IsFinance(p.Estado)).ToList();
    var pagadosAnio = pagos.Where(p => IsPaid(p.Estado) && (p.FechaPago?.Year ?? p.FechaCreacion.Year) == year).ToList();

    var pendingTotal = pendientes.Sum(p => p.Monto);
    var paidTotal = pagadosAnio.Sum(p => p.Monto);
    var financeTotal = financiados.Sum(p => p.Monto);
    var nextFinanceDue = financiados
        .Where(p => p.FechaVencimiento.HasValue)
        .OrderBy(p => p.FechaVencimiento)
        .FirstOrDefault();

    var actividad = pagos
        .OrderByDescending(p => p.FechaCreacion)
        .Take(6)
        .Select(p => new {
            Title = p.Concepto,
            Sub = $"{(p.FechaPago ?? p.FechaVencimiento ?? p.FechaCreacion):MMM d, yyyy} · INV-{p.Id:D5}",
            Amount = p.Monto.ToString("C2", culture),
            Badge = IsPending(p.Estado) ? "pending" : IsPaid(p.Estado) ? "paid" : IsFinance(p.Estado) ? "finance" : "pending",
            BadgeLabel = IsPending(p.Estado) ? "Pending" : IsPaid(p.Estado) ? "Paid" : IsFinance(p.Estado) ? "Financing" : p.Estado,
            Icon = "fa-receipt"
        })
        .ToList();
}

<div class="pay-hero-row">
    <div class="perfil-top-title" style="margin:0;">
        <h1 style="font-size:1.35rem;">Payments &amp; History</h1>
        <p>Track services, billing, and financing in one place.</p>
    </div>
    <img class="pay-hero-art" src="~/images/pay-doc-house.svg" alt="" asp-append-version="true"
         onerror="this.outerHTML='<i class=\'fas fa-file-invoice-dollar pay-hero-art\' style=\'font-size:3rem;color:#0066CC;\'></i>'" />
</div>

<div class="pay-summary-grid">
    <a href="#pending" class="pay-summary-card pending">
        <div class="psc-icon"><i class="far fa-clock"></i></div>
        <div class="psc-label">Pending</div>
        <div class="psc-amount">@pendingTotal.ToString("C2", culture)</div>
        <div class="psc-sub">@pendientes.Count item@(pendientes.Count == 1 ? "" : "s")</div>
    </a>
    <a href="#paid" class="pay-summary-card paid">
        <div class="psc-icon"><i class="fas fa-check-circle"></i></div>
        <div class="psc-label">Paid</div>
        <div class="psc-amount">@paidTotal.ToString("C2", culture)</div>
        <div class="psc-sub">This year</div>
    </a>
    <a href="#finance" class="pay-summary-card finance">
        <div class="psc-icon"><i class="far fa-credit-card"></i></div>
        <div class="psc-label">Financing</div>
        <div class="psc-amount">@financeTotal.ToString("C2", culture)</div>
        <div class="psc-sub">
            @(nextFinanceDue?.FechaVencimiento != null
                ? $"Due {nextFinanceDue.FechaVencimiento:MMM d, yyyy}"
                : "—")
        </div>
    </a>
</div>

<div class="pay-section-head">
    <h3>Recent Activity</h3>
    <a asp-action="Historial">View all</a>
</div>

@if (!actividad.Any())
{
    <div class="empty">No payment activity yet.</div>
}
else
{
    @foreach (var a in actividad)
    {
        <div class="pay-activity-item">
            <span class="pa-icon"><i class="fas @a.Icon"></i></span>
            <span class="pa-body">
                <strong>@a.Title</strong>
                <small>@a.Sub</small>
            </span>
            <span class="pa-right">
                <span class="pa-amount">@a.Amount</span>
                <span class="badge-status @a.Badge">@a.BadgeLabel</span>
            </span>
            <i class="fas fa-chevron-right" style="color:#9CA3AF;font-size:.75rem;"></i>
        </div>
    }
}

<div class="pay-section-head" style="margin-top:18px;">
    <h3>Saved payment methods</h3>
    <a asp-action="Opciones" asp-fragment="payment">Manage</a>
</div>

@if (!metodos.Any())
{
    <div class="empty">You have no saved payment methods.</div>
}
else
{
    @foreach (var m in metodos)
    {
        <div class="pm-saved-card">
            <i class="fab fa-cc-visa" style="font-size:1.8rem;color:#1A1F71;"></i>
            <div style="flex:1;">
                <strong>@(string.IsNullOrWhiteSpace(m.Marca) ? "Card" : m.Marca) ending in @m.Ultimos4</strong>
                <div style="font-size:.78rem;color:#6B7280;">Expires @m.Expiracion</div>
            </div>
            @if (m.EsPredeterminado)
            {
                <span class="badge-status paid">Default</span>
            }
        </div>
    }
}

<a class="pm-add-btn" asp-action="Opciones" asp-fragment="payment">
    <i class="fas fa-plus"></i> Add payment method
</a>

<div class="pay-quick-links">
    <a class="pay-quick-link" asp-action="Pagos" asp-fragment="finance">
        <i class="fas fa-landmark"></i>
        <strong>Financing options</strong>
        <small>Explore payment plans for larger services</small>
    </a>
    <a class="pay-quick-link" asp-action="Historial">
        <i class="fas fa-clock-rotate-left"></i>
        <strong>View billing history</strong>
        <small>See all past invoices and receipts</small>
    </a>
</div>

<div id="pending" class="pf-card" style="margin-top:20px;">
    <h3><i class="fas fa-hourglass-half"></i> Pending</h3>
    @if (!pendientes.Any()) { <div class="empty">No pending payments.</div> }
    else
    {
        @foreach (var p in pendientes)
        {
            <div class="pay-activity-item" style="margin-bottom:6px;">
                <span class="pa-body"><strong>@p.Concepto</strong><small>Due @(p.FechaVencimiento?.ToString("MM/dd/yyyy") ?? "—")</small></span>
                <span class="pa-amount">@p.Monto.ToString("C2", culture)</span>
            </div>
        }
    }
</div>
