@model IndorMvcApp.ViewModels.HomeownerEditProfileViewModel
@using IndorMvcApp.Models
@{
    ViewData["Title"] = L["Edit Profile"];
    ViewData["Subtitulo"] = L["Update your details and connect your home with AI."];
    var homeJustEnriched = TempData["HomeEnriched"] as bool? == true;
}

<link rel="stylesheet" href="~/css/property-loading.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/address-autocomplete.css" asp-append-version="true" />

<section class="pf-edit-photo-card" id="photo">
    <h3><i class="fas fa-camera"></i> @L["Profile photo"]</h3>
    <p>@L["Upload a photo. It will appear on your profile in the More section."]</p>
    <div id="editProfilePhotoAlerts"></div>
    <form asp-controller="Perfil" asp-action="SubirFoto" method="post" enctype="multipart/form-data" id="editProfilePhotoForm" class="pf-edit-photo-upload-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnTo" value="editar" />
        <div class="pf-edit-photo-row">
            <div class="pf-edit-photo-preview" id="photoPreview">
                @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
                {
                    <img src="@Url.Content($"~{Model.PhotoUrl}")" alt="@L["Current profile photo"]" id="photoPreviewImg" />
                    <span id="photoPreviewInitial" hidden>@Model.DisplayInitial</span>
                }
                else
                {
                    <span id="photoPreviewInitial">@Model.DisplayInitial</span>
                    <img src="" alt="" id="photoPreviewImg" hidden />
                }
            </div>
            <div class="pf-edit-photo-actions">
                <button type="button" class="pf-edit-upload-btn" id="editProfilePhotoBtn" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-camera"></i> @L["Change photo"]
                </button>
                <div class="more-profile-photo-menu pf-edit-photo-menu" id="editProfilePhotoMenu" role="menu" hidden>
                    <button type="button" class="more-profile-photo-menu-item" id="editProfilePhotoTake" role="menuitem">
                        <i class="fas fa-camera"></i> @L["Take photo"]
                    </button>
                    <button type="button" class="more-profile-photo-menu-item" id="editProfilePhotoChoose" role="menuitem">
                        <i class="fas fa-image"></i> @L["Choose from library"]
                    </button>
                </div>
                <input type="file" id="editProfilePhotoCamera" name="foto" accept="image/*" capture="environment" hidden />
                <input type="file" id="editProfilePhotoLibrary" name="foto" accept="image/jpeg,image/png,image/webp,image/*" hidden />
                <small>@L["JPG, PNG or WEBP · Max 10 MB"]</small>
            </div>
        </div>
    </form>
</section>

<form asp-controller="Perfil" asp-action="EditarPerfil" method="post" enctype="multipart/form-data" class="pf-edit-profile-form" id="editProfileForm">
    @Html.AntiForgeryToken()

    <div class="pf-card" id="personal">
        <h3><i class="fas fa-id-card"></i> @L["Personal details"]</h3>
        <div class="pf-form">
            <div class="pf-row">
                <label class="pf-field">
                    <span>@L["First name"]</span>
                    <input type="text" name="nombre" value="@Model.Nombre" placeholder="@L["First name"]" autocomplete="given-name" required />
                </label>
                <label class="pf-field">
                    <span>@L["Last name"]</span>
                    <input type="text" name="apellidos" value="@Model.Apellidos" placeholder="@L["Last name"]" autocomplete="family-name" required />
                </label>
            </div>
            <label class="pf-field">
                <span>@L["Phone"]</span>
                <input type="tel" name="telefono" value="@Model.Telefono" placeholder="5551234567" autocomplete="tel"
                       data-phone-input required />
            </label>
            <label class="pf-field">
                <span>@L["Email"]</span>
                <div class="pf-field-readonly">@Model.Email</div>
            </label>
        </div>
    </div>

    <section class="pf-edit-home-card @(Model.HasEnrichedData ? "is-enriched" : "") @(homeJustEnriched ? "is-celebrate" : "")" id="home">
        <div class="pf-home-card-glow" aria-hidden="true"></div>
        <div class="pf-home-card-head">
            <div class="pf-home-card-icon"><i class="fas fa-house-chimney"></i></div>
            <div>
                <h3>@L["Your home"]</h3>
                <p>@L["Add your address and let AI build your House Facts profile — beds, baths, systems, maintenance, and more."]</p>
            </div>
        </div>

        @if (Model.HasEnrichedData)
        {
            <div class="pf-home-enriched-banner">
                <span class="pf-home-ai-badge"><i class="fas fa-wand-magic-sparkles"></i> @L["AI connected"]</span>
                @if (!string.IsNullOrWhiteSpace(Model.HomeAddress))
                {
                    <strong>@Model.HomeAddress</strong>
                }
                <div class="pf-home-stat-chips">
                    @if (Model.YearBuilt is > 0)
                    {
                        <span><i class="fas fa-calendar"></i> @L.T("Built {0}", Model.YearBuilt)</span>
                    }
                    @if (Model.LivingArea is > 0)
                    {
                        <span><i class="fas fa-ruler-combined"></i> @L.T("{0} sq ft", Model.LivingArea.Value.ToString("N0"))</span>
                    }
                    @if (Model.Bedrooms is > 0)
                    {
                        <span><i class="fas fa-bed"></i> @L.T("{0} bed", Model.Bedrooms)</span>
                    }
                    @if (Model.Bathrooms is > 0)
                    {
                        <span><i class="fas fa-bath"></i> @L.T("{0} bath", Model.Bathrooms)</span>
                    }
                    @if (Model.HouseFactFieldCount > 0)
                    {
                        <span><i class="fas fa-database"></i> @L.T("{0} facts", Model.HouseFactFieldCount)</span>
                    }
                </div>
                @if (Model.PropiedadId is > 0)
                {
                    <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" class="pf-home-view-link">
                        @L["View full House Facts"] <i class="fas fa-arrow-right"></i>
                    </a>
                }
            </div>
        }
        else if (Model.HasHome)
        {
            <div class="pf-home-pending-banner">
                <i class="fas fa-location-dot"></i>
                <div>
                    <strong>@Model.HomeAddress</strong>
                    <small>@L["Run AI research below to unlock House Facts and maintenance insights."]</small>
                </div>
            </div>
        }

        <div class="pf-home-address-form">
            <label class="pf-field">
                <span>@L["Street address"]</span>
                <input asp-for="AddressForm.StreetAddress"
                       id="ep-street"
                       placeholder="@L["House number and street name"]"
                       autocomplete="address-line1"
                       data-address-autocomplete
                       data-ac-street-only="true"
                       data-ac-city="ep-city"
                       data-ac-state="ep-state"
                       data-ac-zip="ep-zip" />
            </label>

            <div class="pf-row">
                <label class="pf-field">
                    <span>@L["City"]</span>
                    <input asp-for="AddressForm.City"
                           id="ep-city"
                           placeholder="@L["City"]"
                           autocomplete="off"
                           data-city-autocomplete
                           data-ac-state="ep-state"
                           data-ac-zip="ep-zip" />
                </label>
                <label class="pf-field">
                    <span>@L["State"]</span>
                    <select asp-for="AddressForm.State"
                            id="ep-state"
                            autocomplete="address-level1"
                            data-ac-zip="ep-zip"
                            data-ac-city="ep-city"
                            data-ac-address="ep-street">
                        <option value="">@L["Select state"]</option>
                        @foreach (var stateCode in PropertyAdministratorCatalog.UsStateCodes)
                        {
                            <option value="@stateCode">@stateCode</option>
                        }
                    </select>
                </label>
            </div>

            <div class="pf-row">
                <label class="pf-field">
                    <span>@L["ZIP code"]</span>
                    <input asp-for="AddressForm.ZipCode"
                           id="ep-zip"
                           placeholder="@L["Enter 5-digit ZIP code"]"
                           autocomplete="postal-code"
                           inputmode="numeric"
                           maxlength="10"
                           minlength="5"
                           pattern="\d{5}(-\d{4})?"
                           title="@L["Enter a 5-digit ZIP code or ZIP+4 (e.g. 28269 or 28269-1234)"]"
                           data-zip-input />
                    <small class="pf-home-zip-hint" id="ep-zip-hint" data-ac-zip-hint-for="ep-zip" hidden>
                        @L["Suggested from city and state when you select a state. Change it if your property uses a different ZIP."]
                    </small>
                </label>
                <label class="pf-field">
                    <span>@L["Unit"] <small class="pf-optional">(@L["Optional"])</small></span>
                    <input asp-for="AddressForm.Unit" placeholder="@L["Apt, suite, unit"]" autocomplete="address-line2" />
                </label>
            </div>

            <p class="pf-home-hint">
                <i class="fas fa-circle-info"></i>
                @L["Save profile stores your address. Use Discover with AI below to research House Facts (can take up to 90 seconds)."]
            </p>

            <button type="submit"
                    class="pf-home-ai-btn"
                    formaction="@Url.Action("EnriquecerPropiedad", "Perfil")"
                    data-trigger-research-loading="true">
                <span class="pf-home-ai-btn-icon"><i class="fas fa-wand-magic-sparkles"></i></span>
                <span class="pf-home-ai-btn-copy">
                    <strong>@(Model.HasEnrichedData ? L["Refresh my home with AI"] : L["Discover my home with AI"])</strong>
                    <small>@L["Build House Facts, systems profile, and maintenance plan"]</small>
                </span>
                <i class="fas fa-arrow-right pf-home-ai-btn-arrow"></i>
            </button>
        </div>
    </section>

    <footer class="pf-edit-profile-actions">
        <a asp-controller="Perfil" asp-action="Opciones" class="pf-btn outline">@L["Cancel"]</a>
        <button type="submit" class="pf-btn">
            <i class="fas fa-floppy-disk"></i> @L["Save profile"]
        </button>
    </footer>
</form>

@await Html.PartialAsync("_PropertyResearchLoading")

@section Scripts {
    <script src="~/js/zip-input.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_AddressAutocompleteScripts")
    <script>
        (function () {
            if (window.location.hash === '#home') {
                var home = document.getElementById('home');
                if (home) {
                    setTimeout(function () { home.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 120);
                }
            }
        })();
    </script>
}
