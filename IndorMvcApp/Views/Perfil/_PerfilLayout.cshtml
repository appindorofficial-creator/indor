@{
    Layout = "_Layout";
    var titulo = ViewData["Title"] as string ?? "Profile";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<style>
    body { background: #FFFFFF; }
    .perfil-page {
        max-width: 760px; margin: 0 auto;
        padding: 16px 16px 80px; font-family: 'Segoe UI', Tahoma, sans-serif; color: #0A2540;
    }
    .perfil-header {
        display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
    }
    .perfil-back {
        width: 40px; height: 40px; border-radius: 12px;
        background: #FFF; border: 1px solid #EEF2F7; color: #0A2540;
        display: inline-flex; align-items: center; justify-content: center;
        text-decoration: none; box-shadow: 0 4px 12px rgba(10,37,64,.06);
    }
    .perfil-back:hover { color: #0066CC; }
    .perfil-header h1 { font-size: 1.15rem; margin: 0; font-weight: 800; }
    .perfil-header p { font-size: .78rem; color: #6B7280; margin: 0; }
    .pf-card {
        background: #FFF; border-radius: 18px; padding: 16px;
        box-shadow: 0 6px 18px rgba(10, 37, 64, .08);
        border: 1px solid #EEF2F7; margin-bottom: 14px;
    }
    .pf-card h3 { font-size: .95rem; margin: 0 0 12px; color: #0A2540; display: flex; align-items: center; gap: 8px; }
    .pf-card h3 i { color: #0066CC; }
    .pf-form { display: flex; flex-direction: column; gap: 10px; }
    .pf-form input, .pf-form select, .pf-form textarea {
        border: 1px solid #E5E7EB; border-radius: 10px; padding: 10px 12px;
        font-size: .9rem; font-family: inherit; width: 100%;
    }
    .pf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .pf-btn {
        background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF;
        border: none; padding: 11px 14px; border-radius: 12px;
        font-size: .85rem; font-weight: 700; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    }
    .pf-btn.danger { background: #FEE2E2; color: #B91C1C; }
    .alert-ok, .alert-err { padding: 10px 12px; border-radius: 10px; font-size: .85rem; margin-bottom: 12px; }
    .alert-ok { background: #DCFCE7; color: #166534; }
    .alert-err { background: #FEE2E2; color: #991B1B; }
    .empty { text-align: center; color: #6B7280; font-size: .85rem; padding: 18px 8px; }
    @@media (max-width: 480px) { .pf-row { grid-template-columns: 1fr; } }
</style>

<div class="perfil-page">
    <div class="perfil-header">
        <a class="perfil-back" asp-controller="Home" asp-action="Index" asp-route-section="more" title="Back">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1>@titulo</h1>
            <p>@ViewData["Subtitulo"]</p>
        </div>
    </div>

    @if (TempData["PerfilOk"] != null)
    {
        <div class="alert-ok"><i class="fas fa-check-circle"></i> @TempData["PerfilOk"]</div>
    }
    @if (TempData["PerfilError"] != null)
    {
        <div class="alert-err"><i class="fas fa-exclamation-triangle"></i> @TempData["PerfilError"]</div>
    }

    @RenderBody()
</div>
