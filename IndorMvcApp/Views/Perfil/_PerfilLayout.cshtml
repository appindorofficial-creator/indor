@using IndorMvcApp.Helpers
@{
    Layout = "_Layout";
    var titulo = ViewData["Title"] as string ?? "Profile";
    var step = ViewData["MembershipStep"] as int?;
    var totalSteps = ViewData["MembershipTotalSteps"] as int? ?? 6;
    var progressPct = step.HasValue ? (int)Math.Round(step.Value / (double)totalSteps * 100) : 0;
}
<link rel="stylesheet" href="~/css/profile-more.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/app-back-button.css" asp-append-version="true" />

<div class="perfil-page">
    <div class="perfil-header-row">
        @{
            var backUrl = ViewData["MembershipBackUrl"] as string;
        }
        @if (!string.IsNullOrEmpty(backUrl))
        {
            <a class="app-back-btn" href="@backUrl" aria-label="Back"><i class="fas fa-chevron-left"></i></a>
        }
        else
        {
            <a class="app-back-btn" href="@HomeNavigationUrls.MoreTab(Url)" aria-label="Back">
                <i class="fas fa-chevron-left"></i>
            </a>
        }
        <div class="perfil-top-title perfil-top-title--grow">
            @if (step.HasValue)
            {
                <div class="mem-progress">
                    <span>Step @step of @totalSteps</span>
                    @if (totalSteps == 6)
                    {
                        <div class="mem-progress-segments" aria-hidden="true">
                            @for (var i = 1; i <= totalSteps; i++)
                            {
                                <span class="mem-seg @(i <= step ? "filled" : "")"></span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mem-progress-bar"><div class="fill" style="width:@progressPct%"></div></div>
                    }
                </div>
            }
            <h1>@titulo</h1>
            <p>@ViewData["Subtitulo"]</p>
        </div>
    </div>

    @if (TempData["PerfilOk"] != null)
    {
        <div class="alert-ok"><i class="fas fa-check-circle"></i> @TempData["PerfilOk"]</div>
    }
    @if (TempData["PerfilError"] != null)
    {
        <div class="alert-err"><i class="fas fa-exclamation-triangle"></i> @TempData["PerfilError"]</div>
    }

    @RenderBody()
</div>
@{
    ViewBag.BottomNavActive ??= "more";
}
@await Html.PartialAsync("_AppBottomNav", ViewBag.BottomNavActive as string ?? "more")
<script src="~/js/phone-input.js" asp-append-version="true"></script>
<script src="~/js/profile-photo-upload.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
