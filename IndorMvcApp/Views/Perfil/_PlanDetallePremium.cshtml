@model IndorMvcApp.Models.PlanMembresia
@using IndorMvcApp.Localization
@{
    var culture = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var es = L.IsSpanish;
    var featText = CatalogText.PickPipeList(Model.Caracteristicas, Model.CaracteristicasEs, es);
    var feats = string.IsNullOrWhiteSpace(featText)
        ? Array.Empty<string>()
        : featText.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
}

<div class="mem-filter-hero">
    <span class="plan-pick-icon" style="width:56px;height:56px;"><i class="fas fa-shield-halved"></i></span>
    <div class="mf-body">
        <h2>@Model.LocalizedNombre(es)</h2>
        @{
            var subtitulo = CatalogText.Pick(Model.Subtitulo, Model.SubtituloEs, es);
        }
        @if (!string.IsNullOrWhiteSpace(subtitulo))
        {
            <small style="color:#6B7280;">@subtitulo</small>
        }
    </div>
    <div class="plan-pick-price">@Model.PrecioMensual.ToString("C0", culture)<em>@L["/mo"]</em></div>
</div>

@foreach (var f in feats)
{
    <div class="mem-benefit-card">
        <span class="mb-icon"><i class="fas fa-circle-check"></i></span>
        <div class="mb-text"><strong>@f</strong></div>
        <i class="fas fa-chevron-right mb-chevron"></i>
    </div>
}

<div class="mem-sticky-footer">
    <a asp-action="MembresiaEntregaHogar" class="pf-btn" style="width:100%;">@L["Continue"] <i class="fas fa-chevron-right"></i></a>
    <div class="mem-trust" style="margin-top:12px;"><i class="fas fa-shield-check"></i> @L["Cancel anytime. No long-term contracts."]</div>
</div>
