@{
    ViewData["Title"] = "Profile options";
    ViewData["Subtitulo"] = "Edit your details, photo, and password";
    var usr = (IndorMvcApp.Models.ApplicationUser?)ViewBag.UsuarioActual;
}

<div class="pf-card">
    <h3><i class="fas fa-id-card"></i> Personal details</h3>
    <form class="pf-form" method="post" asp-controller="Perfil" asp-action="ActualizarDatos">
        @Html.AntiForgeryToken()
        <div class="pf-row">
            <input type="text" name="nombre" placeholder="First name" value="@usr?.Nombre" />
            <input type="text" name="apellidos" placeholder="Last name" value="@usr?.Apellidos" />
        </div>
        <input type="text" name="telefono" placeholder="Mobile phone" value="@usr?.Telefono" />
        <button type="submit" class="pf-btn"><i class="fas fa-save"></i> Save changes</button>
    </form>
</div>

<div class="pf-card">
    <h3><i class="fas fa-camera"></i> Profile photo</h3>
    @if (!string.IsNullOrWhiteSpace(usr?.FotoUrl))
    {
        <div style="text-align:center;margin-bottom:10px;">
            <img src="@Url.Content("~" + usr!.FotoUrl)" alt="Photo" style="width:96px;height:96px;border-radius:50%;object-fit:cover;border:1px solid #E5E7EB;" />
        </div>
    }
    <form class="pf-form" method="post" enctype="multipart/form-data" asp-controller="Perfil" asp-action="SubirFoto">
        @Html.AntiForgeryToken()
        <input type="file" name="foto" accept="image/*" required />
        <button type="submit" class="pf-btn"><i class="fas fa-upload"></i> Upload photo</button>
    </form>
</div>

<div class="pf-card">
    <h3><i class="fas fa-lock"></i> Change password</h3>
    <form class="pf-form" method="post" asp-controller="Perfil" asp-action="CambiarPassword">
        @Html.AntiForgeryToken()
        <input type="password" name="actual" placeholder="Current password" required />
        <input type="password" name="nueva" placeholder="New password" required />
        <input type="password" name="confirmar" placeholder="Confirm new password" required />
        <button type="submit" class="pf-btn"><i class="fas fa-key"></i> Change password</button>
    </form>
</div>

<div class="pf-card">
    <h3><i class="fas fa-credit-card"></i> Add payment method</h3>
    <form class="pf-form" method="post" asp-controller="Perfil" asp-action="AgregarMetodoPago" id="paymentMethodForm" novalidate>
        @Html.AntiForgeryToken()
        <div class="pf-row">
            <select name="tipo" id="paymentTipo">
                <option value="Card">Card</option>
                <option value="Bank">Bank</option>
                <option value="PayPal">PayPal</option>
            </select>
            <input type="text" name="marca" id="paymentMarca" placeholder="Brand (Visa, etc.)" autocomplete="cc-type" />
        </div>
        <div class="pf-row">
            <input type="text" name="ultimos4" id="paymentUltimos4" placeholder="Last 4 digits" maxlength="4"
                   inputmode="numeric" pattern="\d{4}" autocomplete="cc-number" />
            <input type="text" name="expiracion" id="paymentExpiracion" placeholder="MM/YY" maxlength="5"
                   inputmode="numeric" pattern="(0[1-9]|1[0-2])\/[0-9]{2}" autocomplete="cc-exp" />
        </div>
        <input type="text" name="titular" id="paymentTitular" placeholder="Cardholder name"
               autocomplete="cc-name" autocapitalize="words" />
        <label style="font-size:.78rem;color:#475569;">
            <input type="checkbox" name="predeterminado" value="true" /> Set as default
        </label>
        <button type="submit" class="pf-btn"><i class="fas fa-plus"></i> Add method</button>
    </form>
</div>

<script>
    (function () {
        const form = document.getElementById('paymentMethodForm');
        const last4 = document.getElementById('paymentUltimos4');
        const expiry = document.getElementById('paymentExpiracion');
        const holder = document.getElementById('paymentTitular');
        const brand = document.getElementById('paymentMarca');
        const hasLetter = /\p{L}/u;
        const onlyDigits = /^[\d\s]+$/;
        const fourDigits = /^\d{4}$/;
        const expiryPattern = /^(0[1-9]|1[0-2])\/\d{2}$/;

        function digitsOnly(value, maxLen) {
            return (value || '').replace(/\D/g, '').slice(0, maxLen);
        }

        function formatExpiry(value) {
            let d = digitsOnly(value, 4);
            if (d.length >= 3) return d.slice(0, 2) + '/' + d.slice(2);
            return d;
        }

        function validateBrand(value) {
            const v = (value || '').trim();
            if (!v) return 'Enter the card brand (e.g. Visa, Mastercard).';
            if (!hasLetter.test(v) || onlyDigits.test(v)) return 'Card brand must use letters only.';
            return '';
        }

        function validateLast4(value) {
            const d = digitsOnly(value, 4);
            if (!d) return 'Enter the last 4 digits (numbers only).';
            if (!fourDigits.test(d)) return 'Last 4 digits must be exactly 4 numbers.';
            return '';
        }

        function validateExpiry(value) {
            const v = formatExpiry(value);
            if (!v) return 'Enter expiration as MM/YY.';
            if (!expiryPattern.test(v)) return 'Enter a valid expiration date (MM/YY).';
            return '';
        }

        function validateHolder(value) {
            const v = (value || '').trim();
            if (!v) return 'Enter the cardholder name.';
            if (!hasLetter.test(v) || onlyDigits.test(v)) return 'Cardholder name must use letters (not numbers only).';
            return '';
        }

        last4?.addEventListener('input', function () {
            const d = digitsOnly(this.value, 4);
            if (this.value !== d) this.value = d;
            this.setCustomValidity(validateLast4(d));
        });

        expiry?.addEventListener('input', function () {
            const f = formatExpiry(this.value);
            if (this.value !== f) this.value = f;
            this.setCustomValidity(validateExpiry(f));
        });

        holder?.addEventListener('input', function () {
            this.setCustomValidity(validateHolder(this.value));
        });

        brand?.addEventListener('input', function () {
            this.setCustomValidity(validateBrand(this.value));
        });

        form?.addEventListener('submit', function (e) {
            if (last4) last4.dispatchEvent(new Event('input'));
            if (expiry) expiry.dispatchEvent(new Event('input'));
            if (holder) holder.dispatchEvent(new Event('input'));
            if (brand) brand.dispatchEvent(new Event('input'));
            if (!form.checkValidity()) {
                e.preventDefault();
                form.reportValidity();
            }
        });

        [last4, expiry, holder, brand].forEach(function (el) {
            if (el?.value) el.dispatchEvent(new Event('input'));
        });
    })();
</script>

<form method="post" asp-controller="Account" asp-action="Logout">
    @Html.AntiForgeryToken()
    <button type="submit" class="pf-btn danger" style="width:100%;">
        <i class="fas fa-right-from-bracket"></i> Sign out
    </button>
</form>
