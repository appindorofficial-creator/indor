@model IndorMvcApp.ViewModels.MoreProfileViewModel
@using IndorMvcApp.Services

<div class="more-avatar-wrap">
    <div class="more-avatar">
        @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
        {
            <img src="@Url.Content("~" + Model.PhotoUrl)" alt="Profile photo" />
        }
        else
        {
            <i class="fas fa-user"></i>
        }
    </div>
    <a class="more-avatar-edit" asp-controller="Perfil" asp-action="EditarPerfil" asp-fragment="photo" aria-label="Edit profile photo">
        <i class="fas fa-pen"></i>
    </a>
</div>
<div class="more-profile-meta">
    <p class="mp-name">@Model.FullName</p>
    <div class="mp-row"><i class="far fa-envelope"></i><span>@Model.Email</span></div>
    <div class="mp-row"><i class="fas fa-phone"></i><span>@Model.Phone</span></div>
    @if (ProfileDisplayService.PaidMembershipEnabled)
    {
        <div class="mp-row membership">
            <i class="fas fa-shield-alt"></i>
            <span>
                @if (Model.HasActiveMembership)
                {
                    <strong>@Model.MembershipLabel</strong>
                }
                else
                {
                    <span>No active membership</span>
                }
            </span>
        </div>
    }
</div>
<div class="more-ring" style="--pct:@Model.ProfileCompletionPercent" aria-hidden="true">
    <span class="more-ring-pct">@Model.ProfileCompletionPercent%</span>
    <span class="more-ring-label">Complete</span>
</div>
