@model IndorMvcApp.ViewModels.MoreProfileViewModel
@using IndorMvcApp.Services

<div class="more-avatar-wrap">
    <form asp-controller="Perfil" asp-action="SubirFoto" method="post" enctype="multipart/form-data" id="moreProfilePhotoForm">
        @Html.AntiForgeryToken()
        <div class="more-avatar" id="moreProfilePhotoPreview">
            @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
            {
                <img src="@Url.Content("~" + Model.PhotoUrl)" alt="Profile photo" id="moreProfilePhotoImg" />
                <i class="fas fa-user" id="moreProfilePhotoPlaceholder" hidden></i>
            }
            else
            {
                <i class="fas fa-user" id="moreProfilePhotoPlaceholder"></i>
                <img src="" alt="Profile photo" id="moreProfilePhotoImg" hidden />
            }
        </div>
        <button type="button" class="more-avatar-edit" id="moreProfilePhotoBtn" aria-label="Change profile photo" aria-haspopup="true" aria-expanded="false">
            <i class="fas fa-camera"></i>
        </button>
        <div class="more-profile-photo-menu" id="moreProfilePhotoMenu" role="menu" hidden>
            <button type="button" class="more-profile-photo-menu-item" id="moreProfilePhotoTake" role="menuitem">
                <i class="fas fa-camera"></i> Take photo
            </button>
            <button type="button" class="more-profile-photo-menu-item" id="moreProfilePhotoChoose" role="menuitem">
                <i class="fas fa-image"></i> Choose from library
            </button>
        </div>
        <input type="file" id="moreProfilePhotoCamera" name="foto" accept="image/*" capture="environment" hidden />
        <input type="file" id="moreProfilePhotoLibrary" name="foto" accept="image/jpeg,image/png,image/webp,image/*" hidden />
    </form>
</div>
<div class="more-profile-meta">
    <p class="mp-name">@Model.FullName</p>
    <div class="mp-row"><i class="far fa-envelope"></i><span>@Model.Email</span></div>
    <div class="mp-row"><i class="fas fa-phone"></i><span>@Model.Phone</span></div>
    @if (ProfileDisplayService.PaidMembershipEnabled)
    {
        <div class="mp-row membership">
            <i class="fas fa-shield-alt"></i>
            <span>
                @if (Model.HasActiveMembership)
                {
                    <strong>@Model.MembershipLabel</strong>
                }
                else
                {
                    <span>No active membership</span>
                }
            </span>
        </div>
    }
</div>
<div class="more-ring" style="--pct:@Model.ProfileCompletionPercent" aria-hidden="true">
    <span class="more-ring-pct">@Model.ProfileCompletionPercent%</span>
    <span class="more-ring-label">Complete</span>
</div>
