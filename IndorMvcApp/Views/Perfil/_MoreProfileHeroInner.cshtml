@model IndorMvcApp.ViewModels.MoreProfileViewModel
@using IndorMvcApp.Services

<div class="more-avatar-wrap">
    <div class="more-avatar">
        @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
        {
            <img src="@Url.Content("~" + Model.PhotoUrl)" alt="@L["Profile Photo"]" />
        }
        else
        {
            <i class="fas fa-user"></i>
        }
    </div>
</div>
<div class="more-profile-meta">
    <p class="mp-name">@(Model.FullName is "Your name" ? L["Your name"] : Model.FullName)</p>
    <div class="mp-row"><i class="far fa-envelope"></i><span>@(Model.Email is "Add your email" ? L["Add your email"] : Model.Email)</span></div>
    <div class="mp-row"><i class="fas fa-phone"></i><span>@(Model.Phone is "Add your phone" ? L["Add your phone"] : Model.Phone)</span></div>
    @if (ProfileDisplayService.PaidMembershipEnabled)
    {
        <div class="mp-row membership">
            <i class="fas fa-shield-alt"></i>
            <span>
                @if (Model.HasActiveMembership)
                {
                    <strong>@(Model.MembershipLabel is "No Membership" ? L["No Membership"] : Model.MembershipLabel)</strong>
                }
                else
                {
                    <span>@L["No active membership"]</span>
                }
            </span>
        </div>
    }
</div>
<div class="more-ring" style="--pct:@Model.ProfileCompletionPercent" aria-hidden="true">
    <span class="more-ring-pct">@Model.ProfileCompletionPercent%</span>
    <span class="more-ring-label">@L["Complete"]</span>
</div>
