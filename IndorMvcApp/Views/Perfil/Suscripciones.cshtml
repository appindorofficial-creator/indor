@using IndorMvcApp.Services
@using IndorMvcApp.Localization
@{
    ViewData["Title"] = L["Choose your membership"];
    ViewData["Subtitulo"] = L["Pick the plan that fits your home care needs."];
    ViewData["MembershipStep"] = 1;
    ViewData["MembershipTotalSteps"] = 6;
    var planes = (IEnumerable<IndorMvcApp.Models.PlanMembresia>?)ViewBag.Planes ?? Enumerable.Empty<IndorMvcApp.Models.PlanMembresia>();
    var membresia = (IndorMvcApp.Models.MembresiaUsuario?)ViewBag.MembresiaActual;
    var selectedId = ViewBag.SelectedPlanId as int?;
    var culture = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var es = L.IsSpanish;
    var defaultPlan = planes.FirstOrDefault(p => ProfileDisplayService.IsHomeCarePlan(p.Nombre))
        ?? planes.FirstOrDefault(p => p.Recomendado)
        ?? planes.FirstOrDefault();
    var initialId = selectedId ?? defaultPlan?.Id ?? planes.First().Id;
    var selectedLabel = L["Selected"];
}

@if (!planes.Any())
{
    <div class="empty">@L["No plans available. Run SeedIndorMembershipPlans.sql on your database."]</div>
}
else
{
    <form method="post" asp-action="SeleccionarPlan" id="planPickForm" data-selected-label="@selectedLabel">
        @Html.AntiForgeryToken()
        <input type="hidden" name="planId" id="selectedPlanId" value="@initialId" />

        @foreach (var pl in planes)
        {
            var featText = CatalogText.PickPipeList(pl.Caracteristicas, pl.CaracteristicasEs, es);
            var feats = string.IsNullOrWhiteSpace(featText)
                ? Array.Empty<string>()
                : featText.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var kind = ProfileDisplayService.GetPlanKind(pl);
            var esActual = membresia?.PlanMembresiaId == pl.Id;
            var isSelected = pl.Id == initialId;
            var icon = ProfileDisplayService.PlanIconClass(pl.Nombre);
            var solidCheck = ProfileDisplayService.UseSolidCheckmarks(kind);
            var sub = string.IsNullOrWhiteSpace(CatalogText.Pick(pl.Subtitulo, pl.SubtituloEs, es))
                ? (kind == MembershipPlanKind.Free ? L["Basic reminders only."] : "")
                : CatalogText.Pick(pl.Subtitulo, pl.SubtituloEs, es);
            <div class="plan-pick-card @(isSelected ? "selected" : "")"
                 data-plan-id="@pl.Id" role="button" tabindex="0">
                <span class="plan-badge-area">
                    @if (isSelected)
                    {
                        <span class="plan-badge"><i class="fas fa-check"></i> @L["Selected"]</span>
                    }
                    else if (pl.Recomendado)
                    {
                        <span class="plan-badge"><i class="fas fa-star"></i> @L["Most popular"]</span>
                    }
                    else if (esActual)
                    {
                        <span class="plan-badge">@L["Current plan"]</span>
                    }
                </span>
                <span class="plan-pick-icon"><i class="fas @icon"></i></span>
                <div class="plan-pick-body">
                    <h4>@pl.LocalizedNombre(es)</h4>
                    @if (!string.IsNullOrWhiteSpace(sub))
                    {
                        <div class="sub">@sub</div>
                    }
                    <ul>
                        @foreach (var f in feats)
                        {
                            <li>
                                <i class="fas fa-check @(solidCheck ? "check-solid" : "check-outline")"></i>
                                <span>@f</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="plan-pick-price @(isSelected ? "price-selected" : "")">
                    @pl.PrecioMensual.ToString("C0", culture)<em>@L["/mo"]</em>
                </div>
            </div>
        }

        <div class="mem-footer">
            <button type="submit" class="pf-btn">@L["Continue"] <i class="fas fa-chevron-right"></i></button>
            <span class="compare-link">@L["Compare plan details"]</span>
            <div class="mem-trust"><i class="fas fa-shield-check"></i> @L["Cancel anytime. No long-term contracts."]</div>
        </div>
    </form>
}

<script>
    (function () {
        const form = document.getElementById('planPickForm');
        if (!form) return;
        const hidden = document.getElementById('selectedPlanId');
        const selectedLabel = form.dataset.selectedLabel || 'Selected';

        function refreshBadges(selectedCard) {
            document.querySelectorAll('.plan-pick-card').forEach(c => {
                c.classList.remove('selected');
                const price = c.querySelector('.plan-pick-price');
                if (price) price.classList.remove('price-selected');
                const area = c.querySelector('.plan-badge-area');
                if (area) area.innerHTML = '';
            });
            selectedCard.classList.add('selected');
            const priceEl = selectedCard.querySelector('.plan-pick-price');
            if (priceEl) priceEl.classList.add('price-selected');
            const area = selectedCard.querySelector('.plan-badge-area');
            if (area) {
                area.innerHTML = '<span class="plan-badge"><i class="fas fa-check"></i> ' + selectedLabel + '</span>';
            }
            hidden.value = selectedCard.dataset.planId;
        }

        document.querySelectorAll('.plan-pick-card').forEach(card => {
            const pick = () => refreshBadges(card);
            card.addEventListener('click', pick);
            card.addEventListener('keypress', e => { if (e.key === 'Enter') pick(); });
        });
    })();
</script>
