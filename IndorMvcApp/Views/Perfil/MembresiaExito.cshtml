@using IndorMvcApp.Services
@{
    var plan = (IndorMvcApp.Models.PlanMembresia?)ViewBag.Plan;
    var signup = (IndorMvcApp.ViewModels.MembershipSignupState?)ViewBag.Signup;
    var culture = System.Globalization.CultureInfo.GetCultureInfo("en-US");
    var kind = plan != null ? ProfileDisplayService.GetPlanKind(plan) : MembershipPlanKind.Other;
    var isFilter = kind == MembershipPlanKind.Filter;
    var isHomeStyle = kind is MembershipPlanKind.HomeCare or MembershipPlanKind.Premium;
    var es = L.IsSpanish;
    var nextReminder = ViewBag.NextReminderDate as DateTime?;
    if (nextReminder == null && signup?.FirstDeliveryDate != null)
        nextReminder = signup.FirstDeliveryDate.Value.AddDays(-7);
    ViewData["MembershipTotalSteps"] = 6;
}

@if (isFilter && plan != null)
{
    <div class="mem-success-active">
        <span class="check-bubble"><i class="fas fa-check"></i></span>
        <div style="flex:1;">
            <div class="sa-label">@L["Filter Plan Active"]</div>
            <div class="sa-price">@plan.PrecioMensual.ToString("C0", culture)<small>@L["/month"]</small></div>
        </div>
    </div>

    @if (signup?.FirstDeliveryDate != null)
    {
        <div class="mem-info-tile">
            <span class="mit-icon"><i class="far fa-calendar"></i></span>
            <div>
                <div class="mit-label">@L["Next filter delivery"]</div>
                <div class="mit-value">@signup.FirstDeliveryDate.Value.ToString("MMMM d")</div>
            </div>
        </div>
    }
    @if (nextReminder != null)
    {
        <div class="mem-info-tile">
            <span class="mit-icon"><i class="far fa-bell"></i></span>
            <div>
                <div class="mit-label">@L["Next reminder"]</div>
                <div class="mit-value">@nextReminder.Value.ToString("MMMM d")</div>
            </div>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(signup?.ShippingAddress))
    {
        <div class="mem-info-tile">
            <span class="mit-icon"><i class="fas fa-location-dot"></i></span>
            <div>
                <div class="mit-label">@L["Shipping to"]</div>
                <div class="mit-value">@signup.ShippingAddress</div>
            </div>
        </div>
    }

    <div class="mem-what-next">
        <h3>@L["What happens next"]</h3>
        <div class="wn-item"><i class="fas fa-truck"></i> @L["We'll ship your first filter"]</div>
        <div class="wn-item"><i class="far fa-bell"></i> @L["You'll receive reminder notifications"]</div>
        <div class="wn-item"><i class="fas fa-shield-check"></i> @L["You can manage or cancel anytime"]</div>
    </div>

    <div class="mem-sticky-footer">
        <a asp-action="Suscripciones" class="pf-btn" style="width:100%;">@L["Go to my plan"] <i class="fas fa-chevron-right"></i></a>
        <a asp-controller="Home" asp-action="Index" class="pf-btn outline" style="width:100%;margin-top:10px;"><i class="fas fa-house"></i> @L["Back to home"]</a>
    </div>
}
else if (isHomeStyle && plan != null)
{
    <div class="mem-success-hero-icon"><i class="fas fa-house-heart"></i></div>

    <div class="pf-card" style="padding:14px;">
        <div class="mem-welcome-row">
            <i class="fas fa-circle-check"></i>
            <div>
                <strong>@L.T("{0} activated", plan.LocalizedNombre(es))</strong>
                <small>@L["Your membership is active."]</small>
            </div>
        </div>
        <div class="mem-welcome-row" style="border-top:1px solid #F1F5F9;">
            <i class="fas fa-truck"></i>
            <div>
                <strong>@L["First filter delivery scheduled"]</strong>
                <small>@L["Your first filter will arrive in 2–3 business days."]</small>
            </div>
        </div>
        <div class="mem-welcome-row" style="border-top:1px solid #F1F5F9;">
            <i class="fas fa-bell"></i>
            <div>
                <strong>@L["Maintenance reminders turned on"]</strong>
                <small>@L["We'll help you stay on top of your home care."]</small>
            </div>
        </div>
        <div class="mem-welcome-row" style="border-top:1px solid #F1F5F9;">
            <i class="fas fa-tag"></i>
            <div>
                <strong>@L.T("{0} service discount ready", kind == MembershipPlanKind.Premium ? "10%" : "5%")</strong>
                <small>@L["Your discount will be applied at checkout."]</small>
            </div>
        </div>
    </div>

    <div class="mem-what-next">
        <h3>@L["What happens next"]</h3>
        <div class="wn-item"><i class="fas fa-truck"></i> @L["We'll send your filter every 3 months"]</div>
        <div class="wn-item"><i class="far fa-bell"></i> @L["You'll receive reminder notifications"]</div>
        <div class="wn-item"><i class="fas fa-tag"></i> @L["Your discount applies when booking services"]</div>
    </div>

    <div class="mem-sticky-footer">
        <a asp-action="Suscripciones" class="pf-btn" style="width:100%;">@L["Go to membership"] <i class="fas fa-chevron-right"></i></a>
        <a asp-controller="Home" asp-action="Index" class="pf-btn outline" style="width:100%;margin-top:10px;">@L["Back to home"]</a>
    </div>
}
else if (plan != null)
{
    <div class="mem-success-icon"><i class="fas fa-shield-check"></i></div>
    <div class="mem-success-title">
        <h1>@L.T("You're enrolled in {0}", plan.LocalizedNombre(es))</h1>
        <p>@L["Your membership is active."]</p>
    </div>
    <a asp-action="Suscripciones" class="pf-btn" style="width:100%;">@L["Go to membership"]</a>
}
else
{
    <div class="mem-success-icon"><i class="fas fa-check"></i></div>
    <div class="mem-success-title"><h1>@L["You're all set!"]</h1><p>@L["Your plan is now active."]</p></div>
    <a asp-controller="Home" asp-action="Index" class="pf-btn" style="width:100%;"><i class="fas fa-house"></i> @L["Back to home"]</a>
}

<p class="mem-trust" style="margin-top:20px;">
    <i class="fas fa-shield-check"></i>
    @L["Thank you for choosing INDOR. We're here to make home care effortless."]
</p>
