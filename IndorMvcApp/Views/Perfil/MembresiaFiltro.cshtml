@{
    var signup = (IndorMvcApp.ViewModels.MembershipSignupState)ViewBag.Signup!;
    ViewData["MembershipTotalSteps"] = 6;
}

<form method="post" asp-action="MembresiaFiltro" enctype="multipart/form-data" class="pf-form">
    @Html.AntiForgeryToken()

    <div class="mem-wizard-row">
        <span class="mw-icon"><i class="fas fa-house"></i></span>
        <div class="mw-body">
            <strong>@L["Property address"]</strong>
            <input class="mw-value" type="text" name="propertyAddress" value="@signup.PropertyAddress" placeholder="5317 Quail Ridge Dr" required />
        </div>
        <i class="fas fa-chevron-right mw-chevron"></i>
    </div>

    <div class="mem-wizard-row">
        <span class="mw-icon"><i class="fas fa-fan"></i></span>
        <div class="mw-body">
            <strong>@L["HVAC system nickname"]</strong>
            <input class="mw-value" type="text" name="hvacNickname" value="@(signup.HvacNickname ?? L["Main unit"])" placeholder="@L["Main unit"]" />
        </div>
        <i class="fas fa-chevron-right mw-chevron"></i>
    </div>

    <div class="mem-wizard-row">
        <span class="mw-icon"><i class="fas fa-wind"></i></span>
        <div class="mw-body">
            <strong>@L["Filter size"]</strong>
            <input class="mw-value" type="text" name="filterSize" value="@(signup.FilterSize ?? "20 x 20 x 1")" placeholder="20 x 20 x 1" />
        </div>
        <i class="fas fa-chevron-right mw-chevron"></i>
    </div>

    <div class="mem-wizard-row">
        <span class="mw-icon"><i class="fas fa-grip-lines"></i></span>
        <div class="mw-body">
            <strong>@L["Filter type"]</strong>
            <input class="mw-value" type="text" name="filterType" value="@(signup.FilterType ?? L["Standard pleated"])" placeholder="@L["Standard pleated"]" />
        </div>
        <i class="fas fa-chevron-right mw-chevron"></i>
    </div>

    <label class="mem-wizard-row upload-row" style="cursor:pointer;">
        <span class="mw-icon upload"><i class="fas fa-camera"></i></span>
        <div class="mw-body">
            <strong>@L["Upload a photo of your current filter"]</strong>
            <small style="color:#6B7280;">(@L["Optional"])</small>
            <input type="file" name="filterPhoto" accept="image/*" style="font-size:.75rem;margin-top:6px;width:100%;" />
            @if (!string.IsNullOrWhiteSpace(signup.FilterPhotoUrl))
            {
                <small style="color:#16A34A;display:block;margin-top:4px;"><i class="fas fa-check"></i> @L["Photo saved"]</small>
            }
        </div>
        <i class="fas fa-chevron-right mw-chevron"></i>
    </label>

    <div class="mem-pets-row">
        <div class="pets-copy">
            <strong>@L["Pets at home"]</strong>
            <small>@L["Homes with pets may need more frequent replacement reminders."]</small>
        </div>
        <div class="mem-segment" role="group" aria-label="@L["Pets at home"]">
            <label>
                <input type="radio" name="petsAtHome" value="true" @(signup.PetsAtHome ? "checked" : "") />
                @L["Yes"]
            </label>
            <label>
                <input type="radio" name="petsAtHome" value="false" @(!signup.PetsAtHome ? "checked" : "") />
                @L["No"]
            </label>
        </div>
    </div>

    <div class="mem-sticky-footer">
        <button type="submit" class="pf-btn" style="width:100%;">@L["Continue"] <i class="fas fa-chevron-right"></i></button>
    </div>
</form>
