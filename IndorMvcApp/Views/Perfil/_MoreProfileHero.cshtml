@model IndorMvcApp.ViewModels.MoreProfileViewModel
@{
    var showChevron = ViewData["ShowChevron"] as bool? ?? false;
    var linkUrl = ViewData["HeroLink"] as string;
}

<div class="more-profile-card">
    <img class="profile-house-art" src="~/images/profile-house.svg" alt="" asp-append-version="true"
         onerror="this.style.display='none'" />
    @if (!string.IsNullOrEmpty(linkUrl))
    {
        <a href="@linkUrl" class="more-profile-top" style="text-decoration:none;color:inherit;">
            @await Html.PartialAsync("~/Views/Perfil/_MoreProfileHeroInner.cshtml", Model)
            @if (showChevron)
            {
                <i class="fas fa-chevron-right" style="position:absolute;right:16px;top:42px;color:#9CA3AF;"></i>
            }
        </a>
    }
    else
    {
        <div class="more-profile-top">
            @await Html.PartialAsync("~/Views/Perfil/_MoreProfileHeroInner.cshtml", Model)
        </div>
    }

    <div class="more-completion">
        <div class="more-completion-head">
            <span>Profile completion</span>
            <span>@Model.ProfileCompletionPercent%</span>
        </div>
        <div class="more-progress-track">
            <div class="more-progress-fill" style="width:@Model.ProfileCompletionPercent%"></div>
        </div>
        @if (Model.IsProfileComplete)
        {
            <p class="more-completion-hint is-complete"><i class="fas fa-circle-check"></i> Your profile is complete.</p>
        }
        else
        {
            <p class="more-completion-hint">Complete your profile to unlock better recommendations.</p>
            <ul class="more-completion-list">
                @foreach (var item in Model.CompletionItems.Where(i => !i.IsComplete).Take(4))
                {
                    <li>
                        @if (!string.IsNullOrEmpty(item.ActionUrl))
                        {
                            <a href="@item.ActionUrl">@item.Label</a>
                        }
                        else
                        {
                            @item.Label
                        }
                    </li>
                }
            </ul>
        }
    </div>

    @if (ViewData["ShowActions"] as bool? == true)
    {
        <div class="more-actions">
            <a asp-controller="Perfil" asp-action="EditarPerfil"><i class="far fa-user"></i> Edit Profile</a>
            <a asp-controller="Perfil" asp-action="Suscripciones" class="btn-upgrade"><i class="fas fa-star"></i> Upgrade</a>
            <a asp-controller="Perfil" asp-action="Soporte"><i class="fas fa-headset"></i> Support</a>
        </div>
    }
</div>
