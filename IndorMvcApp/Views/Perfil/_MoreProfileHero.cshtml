@model IndorMvcApp.ViewModels.MoreProfileViewModel
@using IndorMvcApp.Services
@{
    var showChevron = ViewData["ShowChevron"] as bool? ?? false;
    var linkUrl = ViewData["HeroLink"] as string;
}

<div class="more-profile-card">
    <div class="more-profile-top-wrap">
        @if (!string.IsNullOrEmpty(linkUrl))
        {
            <a href="@linkUrl" class="more-profile-top" style="text-decoration:none;color:inherit;">
                @await Html.PartialAsync("~/Views/Perfil/_MoreProfileHeroInner.cshtml", Model)
                @if (showChevron)
                {
                    <i class="fas fa-chevron-right" style="position:absolute;right:16px;top:42px;color:#9CA3AF;"></i>
                }
            </a>
        }
        else
        {
            <div class="more-profile-top">
                @await Html.PartialAsync("~/Views/Perfil/_MoreProfileHeroInner.cshtml", Model)
            </div>
        }
    </div>

    <div class="more-completion">
        <div class="more-completion-head">
            <span>@L["Profile completion"]</span>
            <span>@Model.ProfileCompletionPercent%</span>
        </div>
        <div class="more-progress-track">
            <div class="more-progress-fill" style="width:@Model.ProfileCompletionPercent%"></div>
        </div>
        @if (Model.IsProfileComplete)
        {
            <p class="more-completion-hint is-complete"><i class="fas fa-circle-check"></i> @L["Your profile is complete."]</p>
        }
        else
        {
            <p class="more-completion-hint">@L["Complete your profile to unlock better recommendations."]</p>
            var nextItem = Model.CompletionItems.FirstOrDefault(i =>
                !i.IsComplete && !i.Label.Contains("photo", StringComparison.OrdinalIgnoreCase));
            if (nextItem != null)
            {
                var nextIcon = nextItem.Label.Contains("photo", StringComparison.OrdinalIgnoreCase) ? "fa-camera" : "fa-circle-plus";
                <a class="more-complete-link" href="@(string.IsNullOrEmpty(nextItem.ActionUrl) ? "#" : nextItem.ActionUrl)">
                    <i class="fas @nextIcon"></i>
                    <span>@L[nextItem.Label]</span>
                    <i class="fas fa-chevron-right more-complete-chevron"></i>
                </a>
            }
        }
    </div>

    @if (ViewData["ShowActions"] as bool? == true)
    {
        <div class="more-actions">
            <a asp-controller="Perfil" asp-action="EditarPerfil" class="more-action">
                <span class="more-action-icon"><i class="far fa-user"></i></span>
                <span class="more-action-body"><strong>@L["Edit Profile"]</strong><small>@L["Update your details"]</small></span>
                <i class="fas fa-chevron-right more-action-chevron"></i>
            </a>
            @if (ProfileDisplayService.PaidMembershipEnabled)
            {
                <a asp-controller="Perfil" asp-action="Suscripciones" class="more-action more-action-upgrade">
                    <span class="more-action-icon"><i class="fas fa-star"></i></span>
                    <span class="more-action-body"><strong>@L["Upgrade"]</strong><small>@L["Unlock premium"]</small></span>
                    <i class="fas fa-chevron-right more-action-chevron"></i>
                </a>
            }
            <a asp-controller="Perfil" asp-action="Soporte" class="more-action">
                <span class="more-action-icon"><i class="fas fa-headset"></i></span>
                <span class="more-action-body"><strong>@L["Support"]</strong><small>@L["We're here to help"]</small></span>
                <i class="fas fa-chevron-right more-action-chevron"></i>
            </a>
        </div>
    }
</div>
