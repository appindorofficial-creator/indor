@model IndorMvcApp.ViewModels.SafeAirServiceViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home", new { fragment = "home-care-essentials" });
}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@L.Catalog(Model.LandingTitulo)" class="hero-img" />
            <span class="sa-hero-icon"><i class="fas fa-wind"></i></span>
        </div>
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@L.Catalog(Model.LandingTitulo)</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@L.Catalog(Model.LandingTagline)</div>
            }
        </div>
    </div>
    <p class="page-lead">@L.Catalog(Model.LandingSubtitulo)</p>

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="sa-feature-grid">
            @foreach (var item in Model.IncludedItems)
            {
                <div class="sa-feature-item">
                    <i class="fas @item.Icon"></i>
                    <span>@L.Catalog(item.Text)</span>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.PrecioTexto))
    {
        <div class="sa-price-row"><i class="fas fa-tag"></i> @L.Catalog(Model.PrecioTexto)</div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="SafeAirService" method="post">
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="SolicitudId" />

        <button type="submit" name="action" value="schedule" class="btn-primary">
            <i class="fas fa-calendar-plus"></i> @L.Catalog(Model.CtaScheduleTexto) <i class="fas fa-chevron-right"></i>
        </button>
        <button type="submit" name="action" value="changed" class="btn-outline">@L.Catalog(Model.CtaChangedTexto)</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTexto))
    {
        <div class="info-box-blue" style="margin-top:14px;">
            <i class="fas fa-camera"></i>
            <span>@L.Catalog(Model.InfoBoxTexto)</span>
        </div>
    }
