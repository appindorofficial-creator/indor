@model IndorMvcApp.ViewModels.SafeAirScheduleViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("SafeAirDetails", "SafeAir", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 2;
}

<h2 class="page-heading" style="font-size:1.1rem;">@L["Photos & schedule"]</h2>
    <p class="page-lead" style="margin-top:-8px;">@L["Add context so the provider arrives prepared."]</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form asp-action="SafeAirSchedule" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="TipoNecesidad" />
        <input type="hidden" asp-for="VentanaTiempo" id="VentanaTiempo" />
        <input type="hidden" asp-for="DetallesAcceso" id="DetallesAcceso" />

        <div class="field-card">
            <span class="field-label">@L["Add a photo of the filter or vent"]</span>
            <div class="photo-row">
                <div class="photo-upload-slot">
                    <input type="file" name="files" id="safeAirPhotos" class="photo-input-sr-only" multiple
                           accept="image/*,.jpg,.jpeg,.png,.webp,.heic,.heif" tabindex="-1" aria-hidden="true" />
                    <input type="file" id="safeAirCamera" class="photo-input-sr-only"
                           accept="image/*" capture="environment" tabindex="-1" aria-hidden="true" />
                    <div class="photo-upload" id="safeAirPhotoDropzone" role="button" tabindex="0" aria-label="@L["Upload photos from gallery"]">
                        <i class="fas fa-images"></i>
                        <p><strong>@L["Upload photo"]</strong></p>
                        <p>@L["Tap to add (JPG, PNG, HEIC)"]</p>
                    </div>
                    <button type="button" class="photo-camera-btn" id="safeAirCameraBtn">
                        <i class="fas fa-camera"></i> @L["Take photo"]
                    </button>
                    <div class="photo-selected-list" id="safeAirPhotoList" hidden></div>
                </div>
                <div class="photo-example">
                    <span class="photo-badge">@L["Good example"]</span>
                    <img src="@Url.Content("~/aire.jpeg")" alt="Ceiling vent example" loading="lazy" onerror="this.style.display='none'" />
                </div>
                <div class="photo-example">
                    <span class="photo-badge">@L["Good example"]</span>
                    <img src="@Url.Content("~/aire.jpeg")" alt="Filter size example" loading="lazy" onerror="this.style.display='none'" />
                </div>
            </div>
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="photo-attached-list" id="safeAirSavedPhotos">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <div class="photo-selected-item">
                            @if (!string.IsNullOrWhiteSpace(file.RutaArchivo))
                            {
                                <img class="photo-preview-thumb" src="@file.RutaArchivo" alt="" loading="lazy" />
                            }
                            else
                            {
                                <i class="fas fa-image"></i>
                            }
                            <span>@file.NombreArchivo</span>
                            <button type="submit" form="removeSafeAirPhoto@(file.Id)" class="photo-remove-btn" aria-label="@L["Remove @file.NombreArchivo"]">
                                <i class="fas fa-xmark"></i>
                            </button>
                        </div>
                    }
                </div>
            }
            <div class="info-box-blue" style="margin-top:10px;margin-bottom:0;">
                <i class="fas fa-circle-info"></i>
                <span>@L["If you don't know the filter size, a photo helps us verify it."]</span>
            </div>
        </div>

        @if (Model.ShowScheduleOptions)
        {
            <div class="field-card">
                <span class="field-label">@L["Preferred time"]</span>
                <div class="chip-scroll" id="timeGroup">
                    <button type="button" class="chip-option" data-value="NextAvailable"><i class="fas fa-clock"></i> @L["Next available"]</button>
                    <button type="button" class="chip-option" data-value="Morning"><i class="fas fa-sun"></i> @L["Morning"]</button>
                    <button type="button" class="chip-option" data-value="Afternoon"><i class="fas fa-cloud-sun"></i> @L["Afternoon"]</button>
                    <button type="button" class="chip-option" data-value="Flexible"><i class="fas fa-calendar"></i> @L["Flexible"]</button>
                </div>
            </div>
        }

        <div class="field-card">
            <span class="field-label">@L["Access details"]</span>
            <div class="chip-scroll" id="accessGroup">
                <button type="button" class="chip-option" data-value="House"><i class="fas fa-house"></i> @L["House"]</button>
                <button type="button" class="chip-option" data-value="Apartment"><i class="fas fa-building"></i> @L["Apartment"]</button>
                <button type="button" class="chip-option" data-value="AtticAccess"><i class="fas fa-stairs"></i> @L["Attic access"]</button>
                <button type="button" class="chip-option" data-value="GateCode"><i class="fas fa-lock"></i> @L["Gate code"]</button>
            </div>
            <div class="input-wrap" style="margin-top:10px;">
                <i class="fas fa-note-sticky"></i>
                <input asp-for="NotasAcceso" placeholder="@L["Add any access notes (optional)"]" />
            </div>
        </div>

        <div class="summary-inline">
            <i class="fas fa-clipboard-list main"></i>
            <div>
                <div class="line"><strong>@L["Service:"]</strong> @L.Catalog(Model.NombreServicio)</div>
                <div class="line"><strong>@L["Filters:"]</strong> @Model.CantidadFiltrosLabel</div>
                <div class="line"><strong>@L["Size:"]</strong> @Model.FiltroTamanioLabel</div>
                @if (Model.ShowScheduleOptions)
                {
                    <div class="line"><strong>@L["Provider brings filter:"]</strong> @Model.ProveedorFiltroLabel</div>
                }
                <div class="line"><strong>@L["Reminder:"]</strong> @Model.RecordatorioLabel</div>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar-plus"></i> @L["Confirm request"]
        </button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>

    @foreach (var file in Model.ArchivosExistentes)
    {
        <form id="removeSafeAirPhoto@(file.Id)" asp-action="RemovePhoto" method="post" style="display:none">
            @Html.AntiForgeryToken()
            <input type="hidden" name="photoId" value="@file.Id" />
            <input type="hidden" name="solicitudId" value="@Model.SolicitudId" />
        </form>
    }

@section Scripts {
<script>
    (function () {
        function initSingle(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            if (!hidden) return;
            document.querySelectorAll('#' + groupId + ' .chip-option').forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' .chip-option').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                });
            });
        }

        initSingle('timeGroup', 'VentanaTiempo', '@Model.VentanaTiempo');
        initSingle('accessGroup', 'DetallesAcceso', '@Model.DetallesAcceso');

        const photoInput = document.getElementById('safeAirPhotos');
        const cameraInput = document.getElementById('safeAirCamera');
        const photoDropzone = document.getElementById('safeAirPhotoDropzone');
        const cameraBtn = document.getElementById('safeAirCameraBtn');
        const photoList = document.getElementById('safeAirPhotoList');
        const maxPhotos = 3;
        let pendingPhotos = [];

        function syncPhotoInputFiles() {
            if (!photoInput) return;
            const dt = new DataTransfer();
            pendingPhotos.slice(0, maxPhotos).forEach(function (file) {
                dt.items.add(file);
            });
            photoInput.files = dt.files;
        }

        function mergePhotoFiles(newFiles) {
            Array.from(newFiles || []).forEach(function (file) {
                if (file && file.size > 0) {
                    pendingPhotos.push(file);
                }
            });
            if (pendingPhotos.length > maxPhotos) {
                pendingPhotos = pendingPhotos.slice(0, maxPhotos);
            }
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function removePendingPhoto(index) {
            pendingPhotos.splice(index, 1);
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function renderPhotoSelection(files) {
            if (!photoList || !photoDropzone) return;
            const list = Array.from(files || []).filter(function (f) { return f && f.size > 0; });
            photoList.innerHTML = '';
            if (list.length === 0) {
                photoList.hidden = true;
                photoDropzone.classList.remove('has-files');
                return;
            }
            photoDropzone.classList.add('has-files');
            photoList.hidden = false;
            list.forEach(function (file, index) {
                const row = document.createElement('div');
                row.className = 'photo-selected-item';
                if (!file.type || file.type.indexOf('image/') === 0) {
                    const img = document.createElement('img');
                    img.className = 'photo-preview-thumb';
                    img.alt = 'Selected photo ' + (index + 1);
                    row.appendChild(img);
                    const reader = new FileReader();
                    reader.onload = function (e) { img.src = e.target.result; };
                    reader.readAsDataURL(file);
                } else {
                    const icon = document.createElement('i');
                    icon.className = 'fas fa-image';
                    row.appendChild(icon);
                }
                const name = document.createElement('span');
                name.textContent = file.name || ('Photo ' + (index + 1));
                row.appendChild(name);
                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'photo-remove-btn';
                removeBtn.setAttribute('aria-label', 'Remove ' + (file.name || 'photo'));
                removeBtn.innerHTML = '<i class="fas fa-xmark"></i>';
                removeBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    removePendingPhoto(index);
                });
                row.appendChild(removeBtn);
                photoList.appendChild(row);
            });
        }

        function openGallery() {
            if (photoInput) {
                photoInput.click();
            }
        }

        photoInput?.addEventListener('change', function () {
            mergePhotoFiles(this.files);
            this.value = '';
        });

        cameraInput?.addEventListener('change', function () {
            mergePhotoFiles(this.files);
            this.value = '';
        });

        photoDropzone?.addEventListener('click', openGallery);
        photoDropzone?.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                openGallery();
            }
        });

        cameraBtn?.addEventListener('click', function () {
            if (cameraInput) {
                cameraInput.click();
            }
        });
    })();

</script>
}
