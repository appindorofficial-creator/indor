@model IndorMvcApp.ViewModels.SafeAirDetailsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("SafeAirService", "SafeAir", new { id = Model.MicroservicioId });
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 2;
}

<h2 class="page-heading" style="font-size:1.1rem;">Filter details</h2>
    <p class="page-lead" style="margin-top:-8px;">Help us identify the right filter for your home.</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form asp-action="SafeAirDetails" method="post" novalidate id="safeAirDetailsForm">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="TipoNecesidad" id="TipoNecesidad" />
        <input type="hidden" asp-for="CantidadFiltros" id="CantidadFiltros" />
        <input type="hidden" asp-for="UbicacionFiltro" id="UbicacionFiltro" />
        <input type="hidden" asp-for="ProveedorFiltro" id="ProveedorFiltro" />
        <input type="hidden" asp-for="FiltroTamanioDesconocido" id="FiltroTamanioDesconocido" value="@(Model.FiltroTamanioDesconocido ? "true" : "false")" />
        <input type="hidden" asp-for="RecordatorioActivo" id="RecordatorioActivo" value="@(Model.RecordatorioActivo ? "true" : "false")" />

        <div class="field-card">
            <div class="field-label-row"><span class="question-num">1</span><span class="field-label" style="margin:0;">What do you need today?</span></div>
            <div class="need-grid" id="needGroup">
                <button type="button" class="need-card" data-value="IndorReplaces"><i class="fas fa-box"></i>INDOR replaces it</button>
                <button type="button" class="need-card" data-value="ChangedMyself"><i class="fas fa-screwdriver-wrench"></i>I changed it myself</button>
                <button type="button" class="need-card" data-value="RemindOnly"><i class="fas fa-bell"></i>Just remind me</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-label-row"><span class="question-num">2</span><span class="field-label" style="margin:0;">How many filters?</span></div>
            <div class="count-row" id="countGroup">
                <button type="button" class="count-btn" data-value="One">1</button>
                <button type="button" class="count-btn" data-value="Two">2</button>
                <button type="button" class="count-btn" data-value="ThreePlus">3+</button>
            </div>
        </div>

        <div class="field-card" id="sizeSection">
            <div class="field-label-row"><span class="question-num">3</span><span class="field-label" style="margin:0;">Do you know the filter size?</span></div>
            <div class="size-row" id="sizeInputs">
                <div class="size-field">
                    <label>Width (in)</label>
                    <input asp-for="FiltroAncho" type="text" inputmode="decimal" autocomplete="off" class="filter-size-input" placeholder="20" />
                </div>
                <span class="size-sep">x</span>
                <div class="size-field">
                    <label>Height (in)</label>
                    <input asp-for="FiltroAlto" type="text" inputmode="decimal" autocomplete="off" class="filter-size-input" placeholder="25" />
                </div>
                <span class="size-sep">x</span>
                <div class="size-field">
                    <label>Depth (in)</label>
                    <input asp-for="FiltroProfundidad" type="text" inputmode="decimal" autocomplete="off" class="filter-size-input" placeholder="1" />
                </div>
            </div>
            <button type="button" class="link-btn" id="unknownSizeBtn">I don't know</button>
        </div>

        <div class="field-card">
            <div class="field-label-row"><span class="question-num">4</span><span class="field-label" style="margin:0;">Where is the filter located?</span></div>
            <div class="location-grid" id="locationGroup">
                <button type="button" class="location-tile" data-value="Ceiling"><i class="fas fa-border-all"></i>Ceiling</button>
                <button type="button" class="location-tile" data-value="WallReturn"><i class="fas fa-grip-lines"></i>Wall return</button>
                <button type="button" class="location-tile" data-value="HvacUnit"><i class="fas fa-fan"></i>HVAC unit</button>
                <button type="button" class="location-tile" data-value="Attic"><i class="fas fa-warehouse"></i>Attic</button>
                <button type="button" class="location-tile" data-value="NotSure"><i class="fas fa-circle-question"></i>Not sure</button>
            </div>
        </div>

        <div class="field-card" id="providerSection">
            <div class="field-label-row"><span class="question-num">5</span><span class="field-label" style="margin:0;">Who provides the filter?</span></div>
            <div class="provider-grid" id="providerGroup">
                <button type="button" class="provider-card" data-value="IndorBrings"><i class="fas fa-truck"></i>INDOR brings it</button>
                <button type="button" class="provider-card" data-value="IHaveFilter"><i class="fas fa-shopping-bag"></i>I have the filter</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-label-row"><span class="question-num">6</span></div>
            <div class="toggle-row">
                <div class="toggle-copy">
                    <strong>Remind me every 3 months</strong>
                    <span>We'll send reminders when it's time.</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" id="reminderToggle" @(Model.RecordatorioActivo ? "checked" : "") />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">Continue</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>

@section Scripts {
<script>
    (function () {
        function initSingle(groupId, selector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' ' + selector).forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' ' + selector).forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                    if (hiddenId === 'TipoNecesidad') updateSections();
                });
            });
        }

        const unknownHidden = document.getElementById('FiltroTamanioDesconocido');
        const sizeInputs = document.getElementById('sizeInputs');
        const unknownBtn = document.getElementById('unknownSizeBtn');
        const reminderToggle = document.getElementById('reminderToggle');
        const reminderHidden = document.getElementById('RecordatorioActivo');

        function setUnknown(active) {
            unknownHidden.value = active ? 'true' : 'false';
            sizeInputs.style.opacity = active ? '0.45' : '1';
            sizeInputs.querySelectorAll('input').forEach(i => i.disabled = active);
            unknownBtn.textContent = active ? 'Enter size manually' : "I don't know";
        }

        unknownBtn.addEventListener('click', () => setUnknown(unknownHidden.value !== 'true'));
        setUnknown(unknownHidden.value === 'true');

        reminderToggle.addEventListener('change', () => {
            reminderHidden.value = reminderToggle.checked ? 'true' : 'false';
        });

        function updateSections() {
            const need = document.getElementById('TipoNecesidad').value;
            document.getElementById('providerSection').style.display = need === 'RemindOnly' ? 'none' : 'block';
        }

        initSingle('needGroup', '.need-card', 'TipoNecesidad', '@Model.TipoNecesidad');
        initSingle('countGroup', '.count-btn', 'CantidadFiltros', '@Model.CantidadFiltros');
        initSingle('locationGroup', '.location-tile', 'UbicacionFiltro', '@Model.UbicacionFiltro');
        initSingle('providerGroup', '.provider-card', 'ProveedorFiltro', '@Model.ProveedorFiltro');
        updateSections();

        const sizeInvalidMessage = 'Please enter a number.';
        const sizeRangeMessage = 'Enter a realistic size in inches (e.g. 20 x 25 x 1). Each side must be between 0.25 and 99.99.';
        const sizePattern = /^\d+(\.\d+)?$/;
        const sizeMin = 0.25;
        const sizeMax = 99.99;

        function isValidFilterSize(value) {
            const trimmed = (value || '').trim();
            if (trimmed === '') {
                return true;
            }
            if (!sizePattern.test(trimmed)) {
                return false;
            }
            const n = parseFloat(trimmed);
            return !Number.isNaN(n) && n >= sizeMin && n <= sizeMax;
        }

        function filterSizeErrorMessage(value) {
            const trimmed = (value || '').trim();
            if (trimmed === '') {
                return '';
            }
            if (!sizePattern.test(trimmed)) {
                return sizeInvalidMessage;
            }
            const n = parseFloat(trimmed);
            if (Number.isNaN(n) || n < sizeMin || n > sizeMax) {
                return sizeRangeMessage;
            }
            return '';
        }

        document.getElementById('safeAirDetailsForm').addEventListener('submit', function (e) {
            const submitter = e.submitter;
            if (submitter && submitter.value === 'back') {
                return;
            }
            if (unknownHidden.value === 'true') {
                return;
            }

            let firstInvalid = null;
            sizeInputs.querySelectorAll('.filter-size-input').forEach(function (input) {
                const msg = filterSizeErrorMessage(input.value);
                input.setCustomValidity(msg);
                if (msg && !firstInvalid) {
                    firstInvalid = input;
                }
            });

            if (firstInvalid) {
                e.preventDefault();
                firstInvalid.reportValidity();
            }
        });
    })();

</script>
}
