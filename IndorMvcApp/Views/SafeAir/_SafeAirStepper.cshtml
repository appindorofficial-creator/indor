@model int
@{
    var current = Model;
}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
    <div style="width:44px;"></div>
    <div class="step-count">Step @current of 2</div>
</div>
<div class="sa-stepper">
    @for (var i = 1; i <= 2; i++)
    {
        var css = i < current ? "sa-step-dot done" : i == current ? "sa-step-dot active" : "sa-step-dot";
        <div class="@css">@i</div>
        @if (i < 2)
        {
            <div class="line @(i < current ? "done" : "")"></div>
        }
    }
</div>
