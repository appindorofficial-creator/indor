@model IndorMvcApp.ViewModels.GutterCleaningSetupViewModel
@{
    ViewData["Title"] = L["Tell us about your home - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("GutterCleaningService", "GutterCleaning", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;
}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@Model.PageTitle</h1>
    <p class="page-lead" style="margin-bottom:16px;"><span class="tagline">@L["Tell us about your home"]</span></p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="gc-setup-form" asp-action="GutterCleaningSetup" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="NumeroPisos" id="NumeroPisos" />
        <input type="hidden" asp-for="TipoCanaletas" id="TipoCanaletas" />
        <input type="hidden" asp-for="ProtectorCanaletas" id="ProtectorCanaletas" />
        <input type="hidden" asp-for="UltimaLimpieza" id="UltimaLimpieza" />
        <input type="hidden" asp-for="CantidadBajantes" id="CantidadBajantes" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-building"></i><span>@L["Home size"]</span></div>
            <div class="stories-grid">
                <button type="button" class="story-card" data-stories="One"><i class="fas fa-house main"></i><span class="label">@L["1 story"]</span></button>
                <button type="button" class="story-card" data-stories="Two"><i class="fas fa-building main"></i><span class="label">@L["2 stories"]</span></button>
                <button type="button" class="story-card" data-stories="ThreePlus"><i class="fas fa-city main"></i><span class="label">@L["3+ stories"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-water"></i><span>@L["What type of gutters do you have?"]</span></div>
            <div class="gutter-grid">
                <button type="button" class="gutter-card" data-gutter="Aluminum"><i class="fas fa-grip-lines main"></i><span class="label">@L["Aluminum"]</span></button>
                <button type="button" class="gutter-card" data-gutter="Vinyl"><i class="fas fa-grip-lines main"></i><span class="label">@L["Vinyl"]</span></button>
                <button type="button" class="gutter-card" data-gutter="Copper"><i class="fas fa-grip-lines main"></i><span class="label">@L["Copper"]</span></button>
                <button type="button" class="gutter-card" data-gutter="NotSure"><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-shield-halved"></i><span>@L["Do you have gutter guards?"]</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-guard="Yes"><i class="fas fa-shield-halved main"></i><span class="label">@L["Yes"]</span></button>
                <button type="button" class="choice-card" data-guard="No"><i class="fas fa-xmark main"></i><span class="label">@L["No"]</span></button>
                <button type="button" class="choice-card" data-guard="NotSure"><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>@L["When were they last cleaned?"]</span></div>
            <div class="gutter-grid" style="grid-template-columns:repeat(4,1fr);">
                <button type="button" class="gutter-card" data-last="LessThan6Months"><i class="fas fa-calendar main"></i><span class="label">@L["&lt; 6 months"]</span></button>
                <button type="button" class="gutter-card" data-last="SixToTwelveMonths"><i class="fas fa-calendar main"></i><span class="label">@L["6–12 months"]</span></button>
                <button type="button" class="gutter-card" data-last="OnePlusYear"><i class="fas fa-calendar main"></i><span class="label">@L["1+ year"]</span></button>
                <button type="button" class="gutter-card" data-last="NotSure"><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-faucet"></i><span>@L["Downspout count (optional)"]</span></div>
            <p style="font-size:0.74rem;color:#64748B;margin-bottom:10px;">@L["Help us estimate the scope of the job."]</p>
            <div class="stepper-control">
                <button type="button" id="downMinus">−</button>
                <span class="value" id="downValue">@(Model.CantidadBajantes ?? 0)</span>
                <button type="button" id="downPlus">+</button>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            Continue <i class="fas fa-chevron-right"></i>
        </button>
    </form>

@section Scripts {
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        bindSingle('[data-stories]', 'data-stories', document.getElementById('NumeroPisos'));
        bindSingle('[data-gutter]', 'data-gutter', document.getElementById('TipoCanaletas'));
        bindSingle('[data-guard]', 'data-guard', document.getElementById('ProtectorCanaletas'));
        bindSingle('[data-last]', 'data-last', document.getElementById('UltimaLimpieza'));

        var form = document.getElementById('gc-setup-form');
        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') return;

            var stories = document.getElementById('NumeroPisos');
            var gutter = document.getElementById('TipoCanaletas');
            var guard = document.getElementById('ProtectorCanaletas');
            var last = document.getElementById('UltimaLimpieza');
            var checks = [
                { input: stories, message: 'Select your home size.' },
                { input: gutter, message: 'Select your gutter type.' },
                { input: guard, message: 'Select whether you have gutter guards.' },
                { input: last, message: 'Select when gutters were last cleaned.' }
            ];

            for (var i = 0; i < checks.length; i++) {
                if (!checks[i].input.value || !checks[i].input.value.trim()) {
                    e.preventDefault();
                    alert(checks[i].message);
                    return;
                }
            }
        });

        var downInput = document.getElementById('CantidadBajantes');
        var downValue = document.getElementById('downValue');
        if (!downInput.value) downInput.value = '0';
        function syncDown() { downValue.textContent = downInput.value; }
        document.getElementById('downMinus').addEventListener('click', function () {
            var v = parseInt(downInput.value || '0', 10);
            downInput.value = Math.max(0, v - 1);
            syncDown();
        });
        document.getElementById('downPlus').addEventListener('click', function () {
            var v = parseInt(downInput.value || '0', 10);
            downInput.value = Math.min(50, v + 1);
            syncDown();
        });
        syncDown();
    })();

</script>
}
