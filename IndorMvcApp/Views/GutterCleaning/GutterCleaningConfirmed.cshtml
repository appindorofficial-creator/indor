@model IndorMvcApp.ViewModels.GutterCleaningConfirmedViewModel
@{
    ViewData["Title"] = L["Gutter Cleaning - All set - INDOR"];
    ViewData["WizardTitle"] = Model.NombreServicio;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    var heading = Model.AlreadyCompleted ? "Task marked complete" : "All set!";
    var subheading = Model.AlreadyCompleted
        ? "Thanks for keeping your gutters on track."
        : "Your gutter plan is ready. We'll help keep your home protected.";
}


<div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">@heading</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;"><span class="tagline">@L["All set"]</span></p>
    </div>

    <div class="confirm-hero">
        <strong>@L["Your gutter plan is ready"]</strong>
        <p>@subheading</p>
    </div>

    @if (!Model.AlreadyCompleted)
    {
        <div class="summary-grid">
            <div class="summary-mini"><i class="fas fa-calendar"></i><div class="summary-label">@L["Frequency"]</div><div class="summary-value">@Model.FrequencyLabel</div></div>
            <div class="summary-mini"><i class="fas fa-house"></i><div class="summary-label">@L["Home"]</div><div class="summary-value">@Model.HomeLabel</div></div>
            <div class="summary-mini"><i class="fas fa-shield-halved"></i><div class="summary-label">@L["Gutter guards"]</div><div class="summary-value">@Model.GutterGuardsLabel</div></div>
            <div class="summary-mini"><i class="fas fa-clock"></i><div class="summary-label">@L["Last cleaned"]</div><div class="summary-value">@Model.LastCleanedLabel</div></div>
            <div class="summary-mini"><i class="fas fa-user"></i><div class="summary-label">@L["Need"]</div><div class="summary-value">@Model.NeedLabel</div></div>
            <div class="summary-mini"><i class="fas fa-bell"></i><div class="summary-label">@L["Reminder"]</div><div class="summary-value">@Model.ReminderLabel</div></div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.NextReminderLabel))
        {
            <div class="status-card">
                <div class="head"><i class="fas fa-calendar-check"></i><div><div class="title">@L["Reminder set"]</div><div class="value">@Model.FrequencyLabel</div></div></div>
                <div class="desc">@L["We'll remind you before spring and fall cleaning."]</div>
                <div class="status-badge"><i class="fas fa-calendar"></i> @Model.NextReminderLabel</div>
            </div>
        }

        @if (Model.ShowServiceRequested && !string.IsNullOrWhiteSpace(Model.PreferredVisitLabel))
        {
            <div class="status-card">
                <div class="head"><i class="fas fa-water"></i><div><div class="title">@L["Service requested"]</div><div class="value">@Model.PreferredVisitLabel</div></div></div>
                <div class="desc">@L["We received your request. A pro will confirm soon."]</div>
                <div class="status-badge success"><i class="fas fa-check"></i> @L["Request received"]</div>
            </div>
        }

        @if (Model.NextStepsItems.Count > 0)
        {
            <div class="next-steps">
                <h4>@L["What happens next"]</h4>
                @foreach (var item in Model.NextStepsItems)
                {
                    <div class="next-step-item"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                }
            </div>
        }

        @if (Model.RecommendedTimingItems.Count > 0)
        {
            <div class="field-card">
                <div class="field-head"><i class="fas fa-calendar"></i><span>@L["Recommended timing"]</span></div>
                <div class="timing-cards">
                    @foreach (var item in Model.RecommendedTimingItems)
                    {
                        <div class="timing-card">
                            <i class="fas @item.Icon"></i>
                            <strong>@item.Text</strong>
                            @if (!string.IsNullOrWhiteSpace(item.Subtext))
                            {
                                <span>@item.Subtext</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }

    @if (!string.IsNullOrWhiteSpace(Model.InfoConfirmacionTexto))
    {
        <div class="info-box-blue">
            <i class="fas fa-shield-halved"></i>
            <span>@Model.InfoConfirmacionTexto</span>
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn-primary">@L["Done"]</a>

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-action="GutterCleaningService" asp-route-id="@Model.HomeCarePriorityId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-pen"></i> Edit reminder or request
        </a>
    }
    else
    {
        <a asp-action="GutterCleaningService" asp-route-id="@Model.HomeCarePriorityId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-pen"></i> Edit reminder or request
        </a>
    }
