@model string
<header class="prv-pro-topbar">
    <div class="prv-pro-brand">
        <span class="prv-pro-brand-indor">INDOR</span>
        <span class="prv-pro-brand-pro">PRO</span>
    </div>
    <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-profile-btn">
        <span class="prv-pro-avatar"><i class="fas fa-building"></i></span>
        <span>@Model</span>
        <i class="fas fa-chevron-down"></i>
    </a>
</header>
