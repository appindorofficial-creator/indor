@{
    var step = ViewBag.OnboardingStep as int? ?? 1;
    var total = ViewBag.OnboardingTotalSteps as int? ?? 5;
}
<div class="ob-progress" aria-label="Onboarding progress">
    @for (var i = 1; i <= total; i++)
    {
        var cls = i < step ? "is-done" : i == step ? "is-active" : "";
        <div class="ob-progress-seg @cls"></div>
    }
</div>
