@using IndorMvcApp.Localization
@inject IIndorLocalizer L
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#0066CC" />
    <title>@(ViewData["Title"] ?? "INDOR")</title>
    @await Html.PartialAsync("_AppVersionHead")
    @await Html.PartialAsync("_AuthPortalHead")
    <link rel="stylesheet" href="~/css/language-selector.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
<body class="auth-page">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
