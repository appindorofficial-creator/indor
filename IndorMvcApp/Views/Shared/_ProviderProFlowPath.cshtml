@model List<IndorMvcApp.ViewModels.ProviderProFlowStepViewModel>
<nav class="prv-pro-flow-path" aria-label="@L["Flow path"]">
    @for (var i = 0; i < Model.Count; i++)
    {
        var step = Model[i];
        if (i > 0)
        {
            <span class="prv-pro-flow-sep"><i class="fas fa-chevron-right"></i></span>
        }
        if (step.IsLink && !string.IsNullOrWhiteSpace(step.Url))
        {
            <a href="@step.Url">
                @if (!string.IsNullOrWhiteSpace(step.IconClass))
                {
                    <i class="fas @step.IconClass"></i>
                }
                @UiDisplayLocalization.Localize(L, step.Label)
            </a>
        }
        else if (step.IsCurrent)
        {
            <strong>
                @if (!string.IsNullOrWhiteSpace(step.IconClass))
                {
                    <i class="fas @step.IconClass"></i>
                }
                @UiDisplayLocalization.Localize(L, step.Label)
            </strong>
        }
        else
        {
            <span>
                @if (!string.IsNullOrWhiteSpace(step.IconClass))
                {
                    <i class="fas @step.IconClass"></i>
                }
                @UiDisplayLocalization.Localize(L, step.Label)
            </span>
        }
    }
</nav>
