@* Global INDOR design system — sky background + UI layer on every screen *@
@* Boot splash first so first paint is branded before Google Fonts / CSS bundles. *@
@await Html.PartialAsync("_IndorBootSplashHead")
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
@await Html.PartialAsync("_NavigationLoadingHead")
@await Html.PartialAsync("_IndorGreetingHead")
@await Html.PartialAsync("_IndorFileSourceHead")
<script>
    // Smart back + navigation recovery (see PreventWebViewCacheMiddleware: no-store is
    // avoided so bfcache can restore pages instantly when the browser allows it).
    (function () {
        if (window.__indorSmartBack) return;
        window.__indorSmartBack = true;

        var LAST_URL_KEY = 'indor.lastInAppUrl';

        function internalReferrer() {
            try { return !!document.referrer && new URL(document.referrer).origin === location.origin; }
            catch (e) { return false; }
        }

        function isHomeHref(href) {
            if (!href) return false;
            try {
                var url = new URL(href, location.origin);
                var path = url.pathname.replace(/\/+$/, '').toLowerCase();
                return path === '' || path === '/home' || path === '/home/index';
            } catch (e) { return false; }
        }

        function normalizePath(pathname) {
            return (pathname || '').replace(/\/+$/, '').toLowerCase() || '/';
        }

        function isRootScreen() {
            var path = normalizePath(location.pathname);
            if (path === '/' || path === '/account/welcome' || path === '/account/loginform') return true;
            if (path === '/home' || path === '/home/index') return true;
            if (path === '/proveedor/dashboard' || path === '/realtor/dashboard') return true;
            if (path === '/administrador' || path === '/administrador/index' || path === '/administrador/dashboard') return true;
            return false;
        }

        function findBackLink() {
            return document.querySelector(
                'a[data-smart-back][href], a.ob-nav-back[href], a.back-btn[href], a.iw-wizard-nav-btn[href], a.app-back-btn[href], a[aria-label="Back"][href]:not(.nr-wizard-nav-btn):not([data-nr-history-back])'
            );
        }

        function resolveBackHref(el) {
            if (!el) return '';
            var href = el.getAttribute('href') || '';
            if (!href || href === '#' || href.toLowerCase().indexOf('javascript:') === 0) return '';
            return href;
        }

        function rememberInAppUrl() {
            try {
                if (isRootScreen()) return;
                localStorage.setItem(LAST_URL_KEY, location.pathname + location.search + location.hash);
            } catch (e) { }
        }

        function navigateTo(href) {
            if (!href) return;
            if (typeof window.indorShowNavigationLoading === 'function') {
                window.indorShowNavigationLoading();
            }
            window.location.assign(href);
        }

        function clearNavigationBusyState() {
            document.querySelectorAll('.nr-wizard-nav-btn.is-busy, .app-back-btn.is-busy, a[data-smart-back].is-busy, a.ob-nav-back.is-busy, a.back-btn.is-busy').forEach(function (el) {
                el.classList.remove('is-busy');
                el.removeAttribute('aria-busy');
            });

            document.body.classList.remove('prl-loading');
            var overlay = document.getElementById('propertyResearchLoading');
            if (overlay) {
                overlay.classList.remove('is-visible');
                overlay.setAttribute('hidden', 'hidden');
            }

            if (typeof window.indorHideNavigationLoading === 'function') {
                window.indorHideNavigationLoading();
            }
        }

        window.addEventListener('pageshow', clearNavigationBusyState);
        document.addEventListener('visibilitychange', function () {
            if (document.visibilityState === 'visible') {
                clearNavigationBusyState();
            }
        });

        // Blank / resume compositor recovery lives in _IndorBootSplashHead
        // (indorShowBootSplash + visibility/pageshow heal) so Welcome and all
        // portals share one language-agnostic path.

        rememberInAppUrl();

        // System / gesture back: when history is shallow (PWA / WebView launcher),
        // Android back exits the app. Arm a one-shot history entry on mid-flow
        // screens that already expose an in-app Back link, then route popstate to
        // that same href. Root screens stay unguarded so exit remains possible.
        (function armSystemBackGuard() {
            if (isRootScreen()) return;
            var backEl = findBackLink();
            var backHref = resolveBackHref(backEl);
            if (!backHref) return;
            if (history.state && history.state.indorNavGuard === 'armed') return;

            try {
                var pageState = Object.assign({}, history.state || {}, {
                    indorNavGuard: 'page',
                    indorBackHref: backHref
                });
                history.replaceState(pageState, '');
                history.pushState({ indorNavGuard: 'armed', indorBackHref: backHref }, '');
            } catch (e) {
                return;
            }

            window.addEventListener('popstate', function (event) {
                var href = (event.state && event.state.indorBackHref) || backHref;
                if (!href) return;
                try {
                    var target = new URL(href, location.origin);
                    if (normalizePath(target.pathname) === normalizePath(location.pathname)
                        && target.search === location.search) {
                        return;
                    }
                } catch (err) { }
                navigateTo(href);
            });
        })();

        document.addEventListener('click', function (e) {
            if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
            if (!e.target || !e.target.closest) return;
            var el = e.target.closest('a[aria-label="Back"]:not([data-nr-history-back]):not(.nr-wizard-nav-btn), a[data-smart-back], a.ob-nav-back');
            if (!el) return;

            var href = resolveBackHref(el);
            if (!href || isHomeHref(href)) {
                return;
            }

            // Always follow the explicit Back href. history.back() can restore a
            // previous wizard step from bfcache after the draft was cleared, or
            // only pop the pushState sentinel and leave the user stranded.
            e.preventDefault();
            el.classList.add('is-busy');
            el.setAttribute('aria-busy', 'true');
            navigateTo(href);
        });
    })();
</script>
