@{
    Layout = null;
    ViewBag.GuestNavActive = ViewBag.GuestNavActive as string ?? "home";
}
<!DOCTYPE html>
<html lang="@(L.IsSpanish ? "es" : "en")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#1867F2" />
    <title>@ViewData["Title"]</title>
    @await Html.PartialAsync("_IndorDesignHead")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await Html.PartialAsync("_AppVersionHead")
    <link rel="stylesheet" href="~/css/homeowner-bottom-nav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/explore-guest-v1.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
<body class="xp-guest-page">
    @RenderBody()
    @if (ViewBag.HideGuestBottomNav as bool? != true)
    {
        @await Html.PartialAsync("_GuestBottomNav")
    }
    @RenderSection("Scripts", required: false)
</body>
</html>
