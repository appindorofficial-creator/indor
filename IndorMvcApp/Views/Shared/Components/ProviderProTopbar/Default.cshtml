@model IndorMvcApp.ViewModels.ProviderProTopbarViewModel
<header class="prv-pro-topbar prv-pro-topbar--v2">
    <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-brand prv-pro-brand--link" aria-label="@L["INDOR PRO home"]">
        <i class="fas fa-house" aria-hidden="true"></i>
        <span class="prv-pro-brand-indor">INDOR</span>
        <span class="prv-pro-brand-pro">PRO</span>
    </a>
    @if (Model.ShowNotifications)
    {
        @await Component.InvokeAsync("ProviderProNotifications")
    }
</header>
