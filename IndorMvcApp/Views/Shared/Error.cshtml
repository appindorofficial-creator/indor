@using IndorMvcApp.Localization
@using IndorMvcApp.Services
@inject IIndorLocalizer L
@model ErrorViewModel
@{
    ViewData["Title"] = L["Error"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        body {
            font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            margin: 0;
            padding: 20px;
            background: #f8fafc;
            color: #0f172a;
            line-height: 1.5;
        }
        .wrap { max-width: 900px; margin: 0 auto; }
        h1 { color: #dc2626; margin-bottom: 8px; font-size: 1.5rem; }
        h2 { font-size: 1.1rem; margin-top: 24px; }
        .meta, code, pre {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
        }
        .meta { padding: 12px 14px; margin: 12px 0; }
        pre {
            padding: 14px;
            overflow: auto;
            white-space: pre-wrap;
            word-break: break-word;
            font-size: 0.85rem;
        }
        .hint {
            margin-top: 20px;
            padding: 12px 14px;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            color: #1e3a8a;
            font-size: 0.92rem;
        }
    </style>
</head>
<body>
    <div class="wrap">
        <h1>@L["Error"]</h1>
        <p>@L["An error occurred while processing your request."]</p>

        @if (Model.ShowRequestId)
        {
            <div class="meta"><strong>@L["Request ID:"]</strong> <code>@Model.RequestId</code></div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Path))
        {
            <div class="meta"><strong>@L["Path:"]</strong> <code>@Model.Path</code></div>
        }

        @if (Model.ShowDetails)
        {
            @if (!string.IsNullOrWhiteSpace(Model.ExceptionType))
            {
                <h2>@L["Exception"]</h2>
                <div class="meta"><strong>@L["Type:"]</strong> @Model.ExceptionType</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ExceptionMessage))
            {
                <div class="meta"><strong>@L["Message:"]</strong> @Model.ExceptionMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.InnerExceptionMessage))
            {
                <div class="meta"><strong>@L["Inner exception:"]</strong> @Model.InnerExceptionMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.StackTrace))
            {
                <h2>@L["Stack trace"]</h2>
                <pre>@Model.StackTrace</pre>
            }
        }
        else
        {
            <div class="hint">
                @L["Detailed errors are disabled. Set"] <code>Diagnostics:ShowDetailedErrors</code> @L["in Azure App Service configuration to see the full exception."]
            </div>
        }
    </div>
</body>
</html>
