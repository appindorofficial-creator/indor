<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />

    <meta name="theme-color" content="#0066CC" />

    <title>@(ViewData["Title"] ?? "Realtor") - INDOR</title>

    @await Html.PartialAsync("_AppVersionHead")

    @await Html.PartialAsync("_RealtorPortalHead")

    <link rel="stylesheet" href="~/css/indor-sections.css" asp-append-version="true" />

    @RenderSection("Head", required: false)

</head>

<body class="rl-dash-page">

    @RenderBody()

    @await Html.PartialAsync("~/Views/Realtor/_RealtorBottomNav.cshtml")

    <script src="~/js/realtor-notifications.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>

