@{
    var activeRaw = ViewBag.BottomNavActive as string
        ?? ViewData["BottomNavActive"] as string
        ?? ViewBag.MyHomeNav as string
        ?? "nearby";
    var active = activeRaw.ToLowerInvariant();
    var spaMode = ViewBag.BottomNavSpa as bool? ?? false;

    Func<string, string> IsActive = key =>
    {
        var on = key switch
        {
            "nearby" => active is "home" or "nearby" or "network",
            "services" => active == "services",
            "housefacts" => active is "housefacts" or "myhome" or "summary" or "maintenance",
            "schedule" => active == "schedule",
            "more" => active is "more" or "profile" or "history" or "documents" or "quotes",
            _ => active == key
        };
        return on ? "active" : "";
    };

    var nearbyUrl = Url.Action("Index", "Home") + "#section-home";
    var servicesUrl = Url.Action("Index", "Home") + "#section-services";
    var houseFactsUrl = Url.Action("Index", "Home") + "#section-myhome";
    var scheduleUrl = Url.Action("Index", "Home") + "#section-schedule";
    var moreUrl = Url.Action("Index", "Home") + "#section-more";
}

<nav class="bottom-nav" aria-label="@L["Home navigation"]">
    @if (spaMode)
    {
        <button type="button" class="nav-item @IsActive("nearby")" data-target="section-home">
            <i class="fas fa-location-dot"></i><span>@L["Nearby"]</span>
        </button>
        <button type="button" class="nav-item @IsActive("services")" data-target="section-services">
            <i class="fas fa-screwdriver-wrench"></i><span>@L["Services"]</span>
        </button>
        <button type="button" class="nav-item @IsActive("housefacts")" data-target="section-myhome">
            <i class="fas fa-house-circle-check"></i><span>@L["House Facts"]</span>
        </button>
        <button type="button" class="nav-item @IsActive("schedule")" data-target="section-schedule">
            <i class="fas fa-clipboard-list"></i><span>@L["Schedule"]</span>
        </button>
        <button type="button" class="nav-item @IsActive("more")" data-target="section-more">
            <i class="fas fa-ellipsis"></i><span>@L["More"]</span>
        </button>
    }
    else
    {
        <a href="@nearbyUrl" class="nav-item @IsActive("nearby")"><i class="fas fa-location-dot"></i><span>@L["Nearby"]</span></a>
        <a href="@servicesUrl" class="nav-item @IsActive("services")"><i class="fas fa-screwdriver-wrench"></i><span>@L["Services"]</span></a>
        <a href="@houseFactsUrl" class="nav-item @IsActive("housefacts")"><i class="fas fa-house-circle-check"></i><span>@L["House Facts"]</span></a>
        <a href="@scheduleUrl" class="nav-item @IsActive("schedule")"><i class="fas fa-clipboard-list"></i><span>@L["Schedule"]</span></a>
        <a href="@moreUrl" class="nav-item @IsActive("more")"><i class="fas fa-ellipsis"></i><span>@L["More"]</span></a>
    }
</nav>
