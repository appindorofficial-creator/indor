<script>
    (function () {
        function isRequired(field) {
            return field.hasAttribute('required') || field.getAttribute('data-pa-required') === 'true';
        }

        function requiredFields(form) {
            return form.querySelectorAll('[required], [data-pa-required="true"]');
        }

        function labelFor(field) {
            return field.getAttribute('data-field-label')
                || field.getAttribute('placeholder')
                || (field.tagName === 'SELECT' && field.options.length ? field.options[0].text : '')
                || field.name;
        }

        function anchorFor(field) {
            return field.closest('.pa-field, .pa-choice-grid, .pa-terms, .ob-field, .prv-wiz-terms, .prv-exam-q') || field;
        }

        function messageFor(field) {
            var label = labelFor(field);
            if (field.type === 'checkbox') {
                return 'Please agree to ' + label + ' to continue.';
            }
            if (isEmailField(field)) {
                return 'Enter a valid email address (e.g. name@@email.com).';
            }
            if (field.type === 'radio' || field.tagName === 'SELECT') {
                return 'Please select ' + label + '.';
            }
            return 'Please enter ' + label + '.';
        }

        var emailFormatRegex = /^[a-zA-Z0-9._%+-]+@@[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(?:\.[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?)*\.[a-zA-Z]{2,}$/;

        function isEmailField(field) {
            return field.getAttribute('data-pa-email') === 'true' || field.type === 'email';
        }

        function emailDomainIsValid(value) {
            var at = value.lastIndexOf('@@');
            if (at < 1) {
                return false;
            }

            var domain = value.slice(at + 1).toLowerCase();
            var truncatedDomains = {
                'hotmail.c': true,
                'hotmail.co': true,
                'gmail.c': true,
                'gmail.co': true,
                'yahoo.c': true,
                'outlook.c': true,
                'icloud.c': true
            };
            if (truncatedDomains[domain]) {
                return false;
            }

            var lastDot = domain.lastIndexOf('.');
            if (lastDot < 1 || lastDot >= domain.length - 2) {
                return false;
            }

            var tld = domain.slice(lastDot + 1);
            return tld.length >= 2 && /^[a-z]+$/.test(tld);
        }

        function isInvalidEmail(field) {
            var value = (field.value || '').trim();
            if (!value) {
                return false;
            }
            return value.length > 254
                || !emailFormatRegex.test(value)
                || !emailDomainIsValid(value);
        }

        function summaryFor(form) {
            var summary = form.querySelector('[data-pa-form-summary]');
            if (!summary) {
                summary = document.createElement('div');
                summary.className = 'pa-summary-error';
                summary.setAttribute('data-pa-form-summary', 'true');
                summary.setAttribute('role', 'alert');
                form.insertBefore(summary, form.firstChild);
            }
            return summary;
        }

        function clearErrors(form) {
            form.querySelectorAll('.pa-inline-error[data-pa-client-error="true"]').forEach(function (el) { el.remove(); });
            form.querySelectorAll('.pa-invalid').forEach(function (el) { el.classList.remove('pa-invalid'); });
            var summary = form.querySelector('[data-pa-form-summary]');
            if (summary) {
                summary.remove();
            }
        }

        function showError(field, customMessage) {
            var anchor = anchorFor(field);
            anchor.classList.add('pa-invalid');
            if (anchor.nextElementSibling && anchor.nextElementSibling.classList.contains('pa-inline-error')) {
                return;
            }
            var msg = document.createElement('div');
            msg.className = 'pa-inline-error';
            msg.setAttribute('data-pa-client-error', 'true');
            msg.setAttribute('role', 'alert');
            msg.textContent = customMessage || messageFor(field);
            anchor.insertAdjacentElement('afterend', msg);
        }

        function registerValidationIssue(field, text, state) {
            if (!state.firstInvalid) {
                state.firstInvalid = field;
            }
            if (state.messages.indexOf(text) === -1) {
                state.messages.push(text);
            }
            showError(field, text);
        }

        function isMissing(field, form) {
            if (field.type === 'radio') {
                return !form.querySelector('input[name="' + CSS.escape(field.name) + '"]:checked');
            }
            if (field.type === 'checkbox') {
                return !field.checked;
            }
            return !field.value || !field.value.trim();
        }

        function formIsValid(form) {
            var requiredOk = Array.from(requiredFields(form)).every(function (item) { return !isMissing(item, form); });
            var emailOk = Array.from(form.querySelectorAll('[data-pa-email="true"], input[type="email"]')).every(function (item) {
                return isMissing(item, form) || !isInvalidEmail(item);
            });
            return requiredOk && emailOk;
        }

        function validateForm(form, options) {
            options = options || {};
            clearErrors(form);
            var seenRadioGroups = {};
            var state = { firstInvalid: null, messages: [] };

            requiredFields(form).forEach(function (field) {
                if (field.type === 'radio') {
                    if (seenRadioGroups[field.name]) { return; }
                    seenRadioGroups[field.name] = true;
                }
                if (isMissing(field, form)) {
                    registerValidationIssue(field, messageFor(field), state);
                }
            });

            form.querySelectorAll('[data-pa-email="true"], input[type="email"]').forEach(function (field) {
                if (isMissing(field, form) || !isInvalidEmail(field)) {
                    return;
                }
                registerValidationIssue(field, messageFor(field), state);
            });

            if (state.firstInvalid) {
                if (state.messages.length > 0) {
                    var summary = summaryFor(form);
                    summary.innerHTML = state.messages.map(function (text) {
                        return '<div>' + text + '</div>';
                    }).join('');
                }
                if (options.scroll !== false) {
                    var scrollTarget = form.querySelector('[data-pa-form-summary]') || anchorFor(state.firstInvalid);
                    scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
                return false;
            }

            return true;
        }

        window.validatePaForm = validateForm;

        document.querySelectorAll('form.pa-validate').forEach(function (form) {
            form.setAttribute('novalidate', 'novalidate');

            form.addEventListener('invalid', function (e) {
                e.preventDefault();
                showError(e.target);
            }, true);

            form.addEventListener('submit', function (e) {
                if (!validateForm(form)) {
                    e.preventDefault();
                }
            });

            form.addEventListener('input', function (e) {
                var field = e.target;
                if (!isRequired(field) && !isEmailField(field)) { return; }
                if ((!isRequired(field) || !isMissing(field, form)) && !isInvalidEmail(field)) {
                    var anchor = anchorFor(field);
                    anchor.classList.remove('pa-invalid');
                    if (anchor.nextElementSibling && anchor.nextElementSibling.classList.contains('pa-inline-error')) {
                        anchor.nextElementSibling.remove();
                    }
                    if (formIsValid(form)) {
                        var summary = form.querySelector('[data-pa-form-summary]');
                        if (summary) { summary.remove(); }
                    }
                }
            });

            form.addEventListener('change', function (e) {
                var field = e.target;
                if (!isRequired(field) && !isEmailField(field)) { return; }
                if ((!isRequired(field) || !isMissing(field, form)) && !isInvalidEmail(field)) {
                    var anchor = anchorFor(field);
                    anchor.classList.remove('pa-invalid');
                    if (anchor.nextElementSibling && anchor.nextElementSibling.classList.contains('pa-inline-error')) {
                        anchor.nextElementSibling.remove();
                    }
                    if (formIsValid(form)) {
                        var summary = form.querySelector('[data-pa-form-summary]');
                        if (summary) { summary.remove(); }
                    }
                }
            });
        });
    })();
</script>
