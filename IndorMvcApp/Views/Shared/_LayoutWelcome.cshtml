@using IndorMvcApp.Localization
@inject IIndorLocalizer L
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#0066CC" />
    <title>@(ViewData["Title"] ?? "INDOR")</title>
    @await Html.PartialAsync("_AppVersionHead")
    @* Critical boot splash before Google Fonts / welcome CSS. *@
    @await Html.PartialAsync("_IndorBootSplashHead")
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/welcome-landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/language-selector.css" asp-append-version="true" />
    @await Html.PartialAsync("_NavigationLoadingHead")
    @RenderSection("Head", required: false)
</head>
<body class="wl-body">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
