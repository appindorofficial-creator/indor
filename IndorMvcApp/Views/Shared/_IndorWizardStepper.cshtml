@model IndorMvcApp.ViewModels.IndorWizardShellViewModel
<div class="iw-progress-track" data-steps="@Model.TotalSteps" aria-hidden="true">
    @for (var step = 1; step <= Model.TotalSteps; step++)
    {
        var isComplete = step < Model.DisplayStep;
        var isActive = step == Model.DisplayStep;
        <span class="iw-progress-seg@(isComplete ? " is-complete" : string.Empty)@(isActive ? " is-active" : string.Empty)"></span>
    }
</div>
