                    </a>
                }
                else
                {
                    <a asp-controller="NearbyPlaces" asp-action="Parks" asp-route-id="@propiedadId!.Value"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
                        @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                    </a>
                }
            }
            else if (card.Key == "airports" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a asp-controller="HouseFactPreview" asp-action="Airports"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
                        @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                    </a>
                }
                else
                {
                    <a asp-controller="NearbyPlaces" asp-action="Airports" asp-route-id="@propiedadId!.Value"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
                        @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                    </a>
                }
            }
            else if (card.Key == "hospitals" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a asp-controller="HouseFactPreview" asp-action="Hospitals"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
                        @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                    </a>
                }
                else
                {
                    <a asp-controller="NearbyPlaces" asp-action="Hospitals" asp-route-id="@propiedadId!.Value"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
                        @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                    </a>
                }
            }
            else
            {
                <button type="button"
                        class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "")"
                        data-hf-open-category="@card.Key"
                        data-hf-title="@card.Title"
                        data-hf-section-ids="@string.Join(",", card.SectionIds)">
                    @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                </button>
