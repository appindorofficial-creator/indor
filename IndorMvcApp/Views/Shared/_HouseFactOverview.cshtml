    </div>

    <button type="button" class="hf-explore-more" data-hf-expand-all>
        <span class="hf-explore-more-icon"><i class="fas fa-layer-group"></i></span>
        <span class="hf-explore-more-copy">
            <strong>@L["Explore more sections"]</strong>
            <span>@L["Dive deeper into every aspect of your home"]</span>
        </span>
