@model IndorMvcApp.ViewModels.HouseFactProfileViewModel
@{
    var overview = Model.Overview;
    var editUrl = ViewData["EditUrl"] as string;
    var myPropertyUrl = ViewData["MyPropertyUrl"] as string;
    var propiedadId = ViewData["PropiedadId"] as int?;
    var isPreview = ViewData["HouseFactPreview"] as bool? == true;
    var hasFlowLinks = isPreview || propiedadId.HasValue;
    var propertyImage = string.IsNullOrWhiteSpace(Model.PropertyImageUrl) ? "/welcome-house.png" : Model.PropertyImageUrl;
}

<section class="hf-overview">
    <div class="hf-overview-heading">
        <div>
            <h2 class="hf-overview-title">@L["Property Overview"]</h2>
        </div>
        <div class="hf-overview-actions">
            @if (!string.IsNullOrWhiteSpace(myPropertyUrl))
            {
                <a href="@myPropertyUrl" class="hf-overview-property"><i class="fas fa-house"></i> @L["My Property"] <i class="fas fa-chevron-down"></i></a>
            }
            @if (!string.IsNullOrWhiteSpace(editUrl))
            {
                <a href="@editUrl" class="hf-overview-edit"><i class="fas fa-pen"></i> @L["Edit"]</a>
            }
        </div>
    </div>

    @if (isPreview)
    {
        <div class="hf-banner" style="display:flex;gap:10px;background:#EFF6FF;border:1px solid #BFDBFE;border-radius:14px;padding:12px 14px;font-size:.82rem;color:#1E3A8A;margin-bottom:14px;">
            <i class="fas fa-circle-info" style="color:#0066CC;margin-top:2px;"></i>
            <div>@L["Preview mode — explore all House Fact flows before you save this property."]</div>
        </div>
    }

    <article class="hf-property-card">
        <div class="hf-property-card-top">
            <img src="@Url.Content($"~{propertyImage}")" alt="@L["Your property"]" class="hf-property-photo" />
            <div class="hf-property-card-main">
                <div class="hf-property-kicker">@L["INDOR HOUSE FACT"]</div>
                <div class="hf-property-address">@(Model.FormattedAddress ?? L["Property address"])</div>
                <div class="hf-property-badges">
                    @if (Model.ShowSuccessBadge)
                    {
                        <span class="hf-property-badge hf-property-badge-success"><i class="fas fa-check"></i> @L["Success"]</span>
                    }
                    <span class="hf-property-badge hf-property-badge-data"><i class="fas fa-database"></i> @Model.FieldCount @L["fields saved"]</span>
                    @if (Model.NeedsReviewCount > 0)
                    {
                        <span class="hf-property-badge hf-property-badge-review"><i class="fas fa-triangle-exclamation"></i> @L["Needs review"]</span>
                    }
                </div>
            </div>
        </div>
        <div class="hf-property-stats">
            @foreach (var stat in overview.HeroStats)
            {
                <div class="hf-property-stat">
                    <i class="fas @stat.Icon"></i>
                    <div>
                        <div class="hf-property-stat-label">@stat.Label</div>
                        <div class="hf-property-stat-value">@stat.Value</div>
                    </div>
                </div>
            }
        </div>
    </article>

    <div class="hf-jump-row">
        <div class="hf-jump-label">@L["Jump to section"]</div>
        <button type="button" class="hf-jump-view-all" data-hf-expand-all>@L["View all sections"] <i class="fas fa-chevron-right"></i></button>
    </div>

    <div class="hf-jump-scroll">
        @foreach (var jump in overview.QuickJumps.Where(j => j.Key != "more"))
        {
            if (jump.Key == "schools" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a class="hf-jump-chip" asp-controller="HouseFactPreview" asp-action="Schools">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
                else
                {
                    <a class="hf-jump-chip" asp-controller="Schools" asp-action="Index" asp-route-id="@propiedadId!.Value">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
            }
            else if (jump.Key == "snapshot" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a class="hf-jump-chip" asp-controller="HouseFactPreview" asp-action="PropertySnapshot">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
                else
                {
                    <a class="hf-jump-chip" asp-controller="PropertySnapshot" asp-action="Index" asp-route-id="@propiedadId!.Value">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
            }
            else if (jump.Key == "systems" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a class="hf-jump-chip" asp-controller="HouseFactPreview" asp-action="SystemsProfile">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
                else
                {
                    <a class="hf-jump-chip" asp-controller="SystemsProfile" asp-action="Index" asp-route-id="@propiedadId!.Value">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
            }
            else if (jump.Key == "roof" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a class="hf-jump-chip" asp-controller="HouseFactPreview" asp-action="RoofExterior">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
                else
                {
                    <a class="hf-jump-chip" asp-controller="RoofExterior" asp-action="Index" asp-route-id="@propiedadId!.Value">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
            }
            else if (jump.Key == "permits" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a class="hf-jump-chip" asp-controller="HouseFactPreview" asp-action="PermitsImprovements">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
                else
                {
                    <a class="hf-jump-chip" asp-controller="PermitsImprovements" asp-action="Index" asp-route-id="@propiedadId!.Value">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
            }
            else if (jump.Key == "hoa" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a class="hf-jump-chip" asp-controller="HouseFactPreview" asp-action="HoaCommunity">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
                else
                {
                    <a class="hf-jump-chip" asp-controller="HoaCommunity" asp-action="Index" asp-route-id="@propiedadId!.Value">
                        <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                        <span class="hf-jump-text">@jump.Label</span>
                    </a>
                }
            }
            else
            {
                <button type="button" class="hf-jump-chip" data-hf-open-category="@jump.Key" data-hf-title="@jump.Label">
                    <span class="hf-jump-icon"><i class="fas @jump.Icon"></i></span>
                    <span class="hf-jump-text">@jump.Label</span>
                </button>
            }
        }
    </div>

    <div class="hf-category-grid">
        @foreach (var card in overview.CategoryCards)
        {
            @* Category card rendering - same link logic as before *@
            @if (card.Key == "schools" && hasFlowLinks)
            {
                if (isPreview)
                {
                    <a asp-controller="HouseFactPreview" asp-action="Schools"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
                        @await Html.PartialAsync("_HouseFactCategoryCardBody", card)
                    </a>
                }
                else
                {
                    <a asp-controller="Schools" asp-action="Index" asp-route-id="@propiedadId!.Value"
                       class="hf-category-card hf-tone-@card.Tone @(card.IsWarning ? "is-warning" : "") hf-category-link">
