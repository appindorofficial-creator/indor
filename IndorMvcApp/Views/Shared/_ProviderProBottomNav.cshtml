@model string
@{
    var active = Model ?? "home";
}
<nav class="prv-pro-bottom-nav">
    <a asp-controller="Proveedor" asp-action="Dashboard" class="@(active == "home" ? "is-active" : "")">
        <i class="fas fa-house"></i><span>Home</span>
    </a>
    <a asp-controller="Proveedor" asp-action="Network" class="@(active == "jobs" ? "is-active" : "")">
        <i class="fas fa-briefcase"></i><span>Jobs</span>
    </a>
    @if (active == "verify")
    {
        <a asp-controller="Proveedor" asp-action="VerifyContractors" class="is-active">
            <i class="fas fa-shield-halved"></i><span>Verify</span>
        </a>
    }
    else
    {
        <a asp-controller="Proveedor" asp-action="Customers" class="@(active == "customers" ? "is-active" : "")">
            <i class="fas fa-users"></i><span>Customers</span>
        </a>
    }
    <a asp-controller="Proveedor" asp-action="Reports" class="@(active == "reports" ? "is-active" : "")">
        <i class="fas fa-chart-line"></i><span>Reports</span>
    </a>
    <a asp-controller="Proveedor" asp-action="Profile" class="@(active == "profile" ? "is-active" : "")">
        <i class="fas fa-user"></i><span>Profile</span>
    </a>
</nav>
