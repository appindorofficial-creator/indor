<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@(ViewData["Title"] ?? "Portfolio") - INDOR</title>
    @await Html.PartialAsync("_AppVersionHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/property-admin-portal.css" asp-append-version="true" />
</head>
<body class="pa-portal-page">
    @RenderBody()
    @if (ViewBag.HideBottomNav != true)
    {
        @await Html.PartialAsync("~/Views/Administrador/_PropertyAdminBottomNav.cshtml")
    }
    @RenderSection("Scripts", required: false)
</body>
</html>
