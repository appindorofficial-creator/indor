@using IndorMvcApp.Localization
@using IndorMvcApp.Services
@inject IIndorLocalizer L
<!DOCTYPE html>

<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />

    <meta name="theme-color" content="#0066CC" />

    <title>@(ViewData["Title"] ?? L["Portfolio"]) - INDOR</title>

    @await Html.PartialAsync("_AppVersionHead")

    @await Html.PartialAsync("_PropertyAdminPortalHead")

    @RenderSection("Head", required: false)

</head>

<body class="pa-portal-page@(ViewBag.HideBottomNav == true ? " pa-portal-page--no-nav" : null)">

    @RenderBody()

    @if (ViewBag.HideBottomNav != true)

    {

        @await Html.PartialAsync("~/Views/Administrador/_PropertyAdminBottomNav.cshtml")

    }

    <script src="~/js/property-admin-portal.js" asp-append-version="true"></script>
    <script src="~/js/property-admin-notifications.js" asp-append-version="true"></script>
    <script src="~/js/pa-media-capture.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>

</html>
