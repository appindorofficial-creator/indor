@model IndorMvcApp.ViewModels.FurnitureAssemblyItemsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("FurnitureAssemblyService", "FurnitureAssembly", new { id = Model.MovingSetupServicioId });
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;

}


<h2 class="page-heading" style="font-size:1.1rem;">Tell us what needs assembly</h2>
    <p class="page-lead" style="margin-top:-8px;">Help us prepare the right team and tools.</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form id="fa-items-form" asp-action="FurnitureAssemblyItems" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TiposMueble" id="TiposMueble" />
        <input type="hidden" asp-for="CantidadItems" id="CantidadItems" />
        <input type="hidden" asp-for="CondicionItems" id="CondicionItems" />
        <input type="hidden" asp-for="AnclajePared" id="AnclajePared" />

        <div class="address-card" id="addressCard">
            <div class="left">
                <i class="fas fa-location-dot" style="color:#0066CC;"></i>
                <input asp-for="DireccionPropiedad" id="DireccionPropiedad" class="address-input"
                       placeholder="123 Riverside Dr, Mount Holly, NC 28120" required readonly
                       data-address-autocomplete autocomplete="off" />
            </div>
            <button type="button" class="address-edit-btn" id="editAddressBtn" aria-controls="DireccionPropiedad">Edit ></button>
        </div>
        <span asp-validation-for="DireccionPropiedad" class="field-error"></span>

        <div class="field-card">
            <span class="field-label">What are you assembling?</span>
            <div class="tile-grid tile-grid-4" id="typesGroup">
                <button type="button" class="tile-btn" data-value="BedFrame"><i class="fas fa-bed"></i>Bed frame</button>
                <button type="button" class="tile-btn" data-value="Dresser"><i class="fas fa-box"></i>Dresser</button>
                <button type="button" class="tile-btn" data-value="Desk"><i class="fas fa-desktop"></i>Desk</button>
                <button type="button" class="tile-btn" data-value="DiningTable"><i class="fas fa-utensils"></i>Dining table</button>
                <button type="button" class="tile-btn" data-value="Bookshelf"><i class="fas fa-book"></i>Bookshelf</button>
                <button type="button" class="tile-btn" data-value="TvStand"><i class="fas fa-tv"></i>TV stand</button>
                <button type="button" class="tile-btn" data-value="OfficeChair"><i class="fas fa-chair"></i>Office chair</button>
                <button type="button" class="tile-btn" data-value="Shelving"><i class="fas fa-layer-group"></i>Shelving</button>
                <button type="button" class="tile-btn" data-value="MultipleItems"><i class="fas fa-ellipsis"></i>Multiple items</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How many items?</span>
            <div class="segment-row" data-target="CantidadItems">
                <button type="button" class="segment-btn" data-value="One">1</button>
                <button type="button" class="segment-btn" data-value="Two">2</button>
                <button type="button" class="segment-btn" data-value="Three">3</button>
                <button type="button" class="segment-btn" data-value="FourPlus">4+</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What condition are the items in?</span>
            <div class="fa-condition-grid" data-target="CondicionItems">
                <button type="button" class="type-card" data-value="NewInBox"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-box"></i>New in box</button>
                <button type="button" class="type-card" data-value="PartiallyAssembled"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-screwdriver-wrench"></i>Partially assembled</button>
                <button type="button" class="type-card" data-value="NeedsReassembly"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-arrows-rotate"></i>Needs re-assembly</button>
                <button type="button" class="type-card" data-value="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question"></i>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Will any item need wall anchoring?</span>
            <div class="segment-row" data-target="AnclajePared">
                <button type="button" class="segment-btn" data-value="Yes">Yes</button>
                <button type="button" class="segment-btn" data-value="No">No</button>
                <button type="button" class="segment-btn" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <button type="submit" class="btn-primary">Next <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="upload" class="btn-outline"><i class="fas fa-cloud-arrow-up"></i> Upload photos</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        function initMulti(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const seed = (initial && String(initial).trim()) || (hidden.value && String(hidden.value).trim()) || '';
            const selected = new Set(seed.split('|').filter(Boolean));
            document.querySelectorAll('#' + groupId + ' .tile-btn').forEach(btn => {
                if (selected.has(btn.dataset.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    const value = btn.dataset.value;
                    if (selected.has(value)) { selected.delete(value); btn.classList.remove('active'); }
                    else { selected.add(value); btn.classList.add('active'); }
                    hidden.value = Array.from(selected).join('|');
                });
            });
            hidden.value = Array.from(selected).join('|');
        }

        function initSegments(containerSelector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const container = document.querySelector(containerSelector);
            if (!container || !hidden) return;
            const buttons = container.querySelectorAll('.segment-btn');
            function setActive(value) {
                const normalized = value && String(value).trim() ? value : '';
                hidden.value = normalized;
                buttons.forEach(b => b.classList.toggle('active', normalized && b.dataset.value === normalized));
            }
            buttons.forEach(btn => btn.addEventListener('click', () => setActive(btn.dataset.value)));
            const seed = (initial && String(initial).trim()) || (hidden.value && String(hidden.value).trim()) || '';
            setActive(seed);
        }

        function initCards(containerSelector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const container = document.querySelector(containerSelector);
            if (!container || !hidden) return;
            const buttons = container.querySelectorAll('.type-card');
            function setActive(value) {
                const normalized = value && String(value).trim() ? value : '';
                hidden.value = normalized;
                buttons.forEach(b => b.classList.toggle('active', normalized && b.dataset.value === normalized));
            }
            buttons.forEach(btn => btn.addEventListener('click', () => setActive(btn.dataset.value)));
            const seed = (initial && String(initial).trim()) || (hidden.value && String(hidden.value).trim()) || '';
            setActive(seed);
        }

        initMulti('typesGroup', 'TiposMueble', '@Model.TiposMueble');
        initSegments('[data-target="CantidadItems"]', 'CantidadItems', '@Model.CantidadItems');
        initCards('[data-target="CondicionItems"]', 'CondicionItems', '@Model.CondicionItems');
        initSegments('[data-target="AnclajePared"]', 'AnclajePared', '@Model.AnclajePared');

        const form = document.getElementById('fa-items-form');
        const addressInput = document.getElementById('DireccionPropiedad');
        const addressCard = document.getElementById('addressCard');
        const editAddressBtn = document.getElementById('editAddressBtn');
        const requiredFields = [
            { id: 'TiposMueble', message: 'Select at least one item to assemble.' },
            { id: 'CantidadItems', message: 'Select how many items need assembly.' },
            { id: 'CondicionItems', message: 'Select the condition of your items.' },
            { id: 'AnclajePared', message: 'Select whether any item needs wall anchoring.' }
        ];

        const addressMessage = 'Please enter a complete street address (e.g. 123 Main St, Charlotte, NC).';

        function isValidStreetAddress(value) {
            const address = String(value || '').trim();
            if (address.length < 5) return false;
            if (!/\p{L}/u.test(address)) return false;
            if (/^[\d\s.,#-]+$/.test(address)) return false;
            const tokens = address.split(/\s+/).filter(Boolean);
            const hasDigit = /\d/.test(address);
            const wordParts = tokens.filter(part => /\p{L}/u.test(part)).length;
            if (!hasDigit || wordParts < 2) return false;
            const hasComma = address.includes(',');
            const hasZip = tokens.slice(1).some(t => /^\d{5}(-\d{4})?$/.test(t.replace(/[.,]+$/, '')));
            return hasComma || hasZip;
        }

        function addressValidity() {
            if (!addressInput) return '';
            const empty = !addressInput.value || !addressInput.value.trim();
            if (empty) return 'Please enter the property address.';
            if (!isValidStreetAddress(addressInput.value)) return addressMessage;
            return '';
        }

        addressInput?.addEventListener('input', function () {
            addressInput.setCustomValidity(addressValidity());
        });

        form?.addEventListener('submit', function (e) {
            const addressError = addressValidity();
            addressInput?.setCustomValidity(addressError);
            if (addressError) {
                e.preventDefault();
                addressInput.removeAttribute('readonly');
                addressCard?.classList.add('editing');
                addressInput.reportValidity();
                return;
            }

            let firstMissing = null;
            requiredFields.forEach(function (field) {
                const input = document.getElementById(field.id);
                if (!input) return;
                const empty = !input.value || !String(input.value).trim();
                if (empty && !firstMissing) {
                    firstMissing = field;
                }
            });

            if (firstMissing) {
                e.preventDefault();
                alert(firstMissing.message);
            }
        });

        function enableAddressEdit() {
            if (!addressInput) return;
            addressInput.removeAttribute('readonly');
            addressCard?.classList.add('editing');
            addressInput.focus();
            try {
                addressInput.setSelectionRange(0, addressInput.value.length);
            } catch (_) { /* iOS may not support selection on focus */ }
        }

        editAddressBtn?.addEventListener('click', enableAddressEdit);
        addressInput?.addEventListener('focus', function () {
            addressInput.removeAttribute('readonly');
            addressCard?.classList.add('editing');
        });
    })();

</script>
@await Html.PartialAsync("_AddressAutocompleteScripts")
}
