@model IndorMvcApp.ViewModels.FurnitureAssemblyConfirmedViewModel
@{
    ViewData["Title"] = L["Booking Confirmed - INDOR"];
    ViewData["WizardTitle"] = Model.NombreServicio;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading" style="text-align:center;">@L["Booking Confirmed"]</h1>
    <p class="page-lead" style="text-align:center;">@L["Your furniture assembly has been scheduled. We've received your request and reserved your appointment."]</p>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-couch"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Date"]</div><div class="summary-value">@Model.FechaServicioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Time"]</div><div class="summary-value">@Model.VentanaHorarioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-box"></i><div><div class="summary-label">@L["Items"]</div><div class="summary-value">@Model.ItemsResumen</div></div></div>
        <div class="summary-row"><i class="fas fa-door-open"></i><div><div class="summary-label">@L["Room"]</div><div class="summary-value">@Model.HabitacionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-stairs"></i><div><div class="summary-label">@L["Access"]</div><div class="summary-value">@Model.AccesoLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">@L["Status"]</div><div class="summary-value" style="color:#16A34A;">@L[Model.EstadoLabel]</div></div></div>
    </div>

    <div class="info-banner">
        <i class="fas fa-circle-info"></i>
        <span>@L["Our provider will review any uploaded photos or manuals before arriving to ensure a smooth experience."]</span>
    </div>

    <a asp-action="FurnitureAssemblyReview" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-calendar"></i> @L["View appointment"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-calendar"></i> @L["Go to Schedule"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Back to Home"] <i class="fas fa-chevron-right"></i></a>
