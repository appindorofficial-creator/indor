@model IndorMvcApp.ViewModels.FurnitureAssemblyReviewViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("FurnitureAssemblyPreferences", "FurnitureAssembly", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 3;

}


<h2 class="page-heading" style="font-size:1.05rem;">@L["Upload photos and review your request"]</h2>
    <p class="page-lead" style="margin-top:-8px;">@L["This helps the provider arrive ready."]</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="summary-card">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <strong><i class="fas fa-couch" style="color:#0066CC;"></i> @Model.NombreServicio</strong>
            <a asp-action="FurnitureAssemblyItems" asp-route-id="@Model.SolicitudId" style="color:#0066CC;font-size:0.85rem;text-decoration:none;"><i class="fas fa-pen"></i> @L["Edit"]</a>
        </div>
        <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-box"></i><div><div class="summary-label">@L["Items"]</div><div class="summary-value">@Model.ItemsResumen</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Schedule"]</div><div class="summary-value">@Model.FechaHorarioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">@L["Room"]</div><div class="summary-value">@Model.HabitacionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-stairs"></i><div><div class="summary-label">@L["Access"]</div><div class="summary-value">@Model.AccesoLabel</div></div></div>
    </div>

    <form asp-action="FurnitureAssemblyReview" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="DisclaimerTexto" />

        <div class="upload-drop-wrap">
            <input type="file" name="files" id="photoInput" class="upload-input-hidden" multiple
                   accept="image/*,.jpg,.jpeg,.png,.pdf,.webp,.heic,.heif" />
            <label class="upload-drop" id="photoDropzone" for="photoInput">
                <i class="fas fa-cloud-arrow-up"></i>
                <strong>@L["Tap to upload photos or manuals"]</strong>
                <span>@L["JPG, PNG, PDF up to 25 MB"]</span>
            </label>
        </div>
        <div class="upload-selected-list" id="photoSelectedList" hidden></div>
        @if (Model.ArchivosExistentes.Count > 0)
        {
            <div class="upload-selected-list" id="photoSavedList">
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="upload-selected-item">
                        @if (file.CategoriaArchivo == "Manual" || file.NombreArchivo.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                        {
                            <i class="fas fa-file-pdf"></i>
                        }
                        else
                        {
                            <img class="upload-preview-thumb" src="@Url.Content($"~{file.RutaArchivo}")" alt="" loading="lazy" />
                        }
                        <span>@file.NombreArchivo</span>
                    </div>
                }
            </div>
        }

        <div class="field-card">
            <span class="field-label">@L["Comments (optional)"]</span>
            <div class="input-wrap"><i class="fas fa-comment"></i><textarea asp-for="NotaCorta" rows="3" maxlength="250" placeholder="@L["Boxes are already inside. One item needs wall anchoring."]"></textarea></div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.DisclaimerTexto))
        {
            <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@Model.DisclaimerTexto</span></div>
        }

        <button type="submit" class="btn-primary"><i class="fas fa-paper-plane"></i> @L["Request service"]</button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
        <button type="submit" name="action" value="edit" class="btn-outline">@L["Edit details"]</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        var photoInput = document.getElementById('photoInput');
        var photoDropzone = document.getElementById('photoDropzone');
        var photoSelectedList = document.getElementById('photoSelectedList');
        var pendingPhotos = [];

        function syncPhotoInputFiles() {
            if (!photoInput) return;
            var dt = new DataTransfer();
            pendingPhotos.forEach(function (file) {
                dt.items.add(file);
            });
            photoInput.files = dt.files;
        }

        function mergePhotoFiles(newFiles) {
            Array.from(newFiles || []).forEach(function (file) {
                if (file && file.size > 0) {
                    pendingPhotos.push(file);
                }
            });
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function removePendingPhoto(index) {
            pendingPhotos.splice(index, 1);
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function renderPhotoSelection(files) {
            if (!photoSelectedList || !photoDropzone) return;
            var list = Array.from(files || []).filter(function (f) { return f && f.size > 0; });
            photoSelectedList.innerHTML = '';
            if (list.length === 0) {
                photoSelectedList.hidden = true;
                photoDropzone.classList.remove('has-files');
                return;
            }
            photoDropzone.classList.add('has-files');
            photoSelectedList.hidden = false;
            list.forEach(function (file, index) {
                var row = document.createElement('div');
                row.className = 'upload-selected-item';
                if (!file.type || file.type.indexOf('image/') === 0) {
                    var img = document.createElement('img');
                    img.className = 'upload-preview-thumb';
                    img.alt = 'Selected file ' + (index + 1);
                    row.appendChild(img);
                    var reader = new FileReader();
                    reader.onload = function (ev) { img.src = ev.target.result; };
                    reader.readAsDataURL(file);
                } else {
                    var icon = document.createElement('i');
                    icon.className = 'fas fa-file-pdf';
                    row.appendChild(icon);
                }
                var name = document.createElement('span');
                name.textContent = file.name || ('File ' + (index + 1));
                row.appendChild(name);
                var removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'upload-remove-btn';
                removeBtn.setAttribute('aria-label', 'Remove ' + (file.name || 'file'));
                removeBtn.innerHTML = '<i class="fas fa-xmark"></i>';
                removeBtn.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    ev.stopPropagation();
                    removePendingPhoto(index);
                });
                row.appendChild(removeBtn);
                photoSelectedList.appendChild(row);
            });
        }

        photoInput?.addEventListener('change', function () {
            mergePhotoFiles(this.files);
            this.value = '';
        });
    })();

</script>
}
