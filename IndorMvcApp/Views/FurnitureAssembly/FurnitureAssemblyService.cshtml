@model IndorMvcApp.ViewModels.FurnitureAssemblyServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <img src="@Model.ImagenUrl" alt="@Model.LandingTitulo" class="hero-img" />
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;"><i class="fas fa-couch" style="color:#0066CC;font-size:1rem;margin-right:6px;"></i>@Model.LandingTitulo</h1>
        </div>
        <div class="price-from">Starting at $@Model.PrecioDesde.ToString("0")</div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.Badges.Count > 0)
    {
        <div class="badge-row">
            @foreach (var badge in Model.Badges)
            {
                <span class="value-badge"><i class="fas @badge.Icon"></i> @badge.Text</span>
            }
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="FurnitureAssemblyService" method="post">
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="SolicitudId" />

        @if (Model.IncludedItems.Count > 0)
        {
            <div class="field-card">
                <span class="field-label">What's included</span>
                <div class="included-grid">
                    @foreach (var item in Model.IncludedItems)
                    {
                        <span><i class="fas @item.Icon" style="color:#0066CC;"></i> @item.Text</span>
                    }
                </div>
            </div>
        }

        <div class="info-cards">
            <div class="info-card">
                <i class="fas fa-clock"></i>
                <div class="label">@Model.EstimatedTimeLabel</div>
                <div class="value">@Model.EstimatedTimeValue</div>
                @if (!string.IsNullOrWhiteSpace(Model.EstimatedTimeNote)) { <div class="note">@Model.EstimatedTimeNote</div> }
            </div>
            <div class="info-card">
                <i class="fas fa-users"></i>
                <div class="label">@Model.BestForLabel</div>
                <div class="value">@Model.BestForValue</div>
                @if (!string.IsNullOrWhiteSpace(Model.BestForNote)) { <div class="note">@Model.BestForNote</div> }
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">@Model.CtaContinueTexto <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="upload" class="btn-outline"><i class="fas fa-cloud-arrow-up"></i> @Model.CtaUploadTexto</button>
    </form>
