@model IndorMvcApp.ViewModels.RoofExteriorCarePlanViewModel
@{
    ViewData["Title"] = L["Roof & Exterior Care Plan"];
    var hfPreview = ViewBag.HouseFactPreview as bool? == true;
    var steps = new[] { L["Overview"].ToString(), L["Review details"].ToString(), L["Verify & upload"].ToString(), L["Set care plan"].ToString() };
}
@section Head {
    <link rel="stylesheet" href="~/css/roof-exterior.css" asp-append-version="true" />
}

<div class="re-head">
    <h1 class="re-title">@L["Roof & Exterior Care Plan"]</h1>
    <p class="re-sub">@L["Turn property facts into reminders, verification, and next steps."]</p>
</div>

<div class="re-stepper">
    @for (var i = 0; i < steps.Length; i++)
    {
        var stepNum = i + 1;
        var css = stepNum < Model.CurrentStep ? "done" : stepNum == Model.CurrentStep ? "active" : "";
        <div class="re-step @css">@stepNum. @steps[i]</div>
    }
</div>

<div class="re-care-card">
    <div class="re-care-card-head">
        <div class="icon"><i class="fas fa-calendar-check"></i></div>
        <div>
            <div class="re-section-title" style="margin:0;">@L["Recommended actions for this home"]</div>
            <div class="re-sub">@L["Smart suggestions based on your property facts"]</div>
        </div>
    </div>
    @foreach (var action in Model.RecommendedActions)
    {
        if (!string.IsNullOrWhiteSpace(action.Url))
        {
            <a class="re-care-item" href="@action.Url">
                <div class="re-list-icon" style="width:40px;height:40px;"><i class="fas @action.Icon"></i></div>
                <div class="re-list-body">
                    <div class="re-list-title">@UiDisplayLocalization.Localize(L, action.Title)</div>
                    <div class="re-list-sub">@UiDisplayLocalization.Localize(L, action.Frequency)</div>
                </div>
                <span class="re-status @action.StatusTone">@UiDisplayLocalization.Localize(L, action.Status)</span>
                <i class="fas fa-chevron-right re-chev"></i>
            </a>
        }
        else
        {
            <div class="re-care-item">
                <div class="re-list-icon" style="width:40px;height:40px;"><i class="fas @action.Icon"></i></div>
                <div class="re-list-body">
                    <div class="re-list-title">@UiDisplayLocalization.Localize(L, action.Title)</div>
                    <div class="re-list-sub">@UiDisplayLocalization.Localize(L, action.Frequency)</div>
                </div>
                <span class="re-status @action.StatusTone">@UiDisplayLocalization.Localize(L, action.Status)</span>
                <i class="fas fa-chevron-right re-chev"></i>
            </div>
        }
    }
</div>

<div class="re-care-card">
    <div class="re-care-card-head">
        <div class="icon"><i class="fas fa-shield-check"></i></div>
        <div style="flex:1;">
            <div class="re-section-title" style="margin:0;">@L["Verification center"]</div>
            <div class="re-sub">@L["Keep your records up to date"]</div>
        </div>
    </div>
    <div class="re-progress-head">
        <span>@L.T("{0} of {1} completed", Model.VerifiedCount, Model.TotalCount)</span>
    </div>
    <div class="re-progress-bar">
        <div class="re-progress-fill" style="width:@Model.ProgressPercent%;"></div>
    </div>
    @foreach (var item in Model.VerificationItems)
    {
        <div class="re-care-item">
            <div class="re-list-icon" style="width:40px;height:40px;"><i class="fas @item.Icon"></i></div>
            <div class="re-list-body">
                <div class="re-list-title">@UiDisplayLocalization.Localize(L, item.Title)</div>
                <div class="re-list-sub">@UiDisplayLocalization.Localize(L, item.Subtitle)</div>
            </div>
            <span class="re-status @item.StatusTone">@UiDisplayLocalization.Localize(L, item.Status)</span>
            <i class="fas fa-chevron-right re-chev"></i>
        </div>
    }
</div>

<div class="re-section-title">@L["Service options"]</div>
<div class="re-service-grid">
    @foreach (var service in Model.ServiceOptions)
    {
        if (!string.IsNullOrWhiteSpace(service.Url))
        {
            <a class="re-service" href="@service.Url">
                <i class="fas @service.Icon"></i>
                <div class="t">@UiDisplayLocalization.Localize(L, service.Title)</div>
                <div class="s">@UiDisplayLocalization.Localize(L, service.Subtitle)</div>
            </a>
        }
        else
        {
            <div class="re-service">
                <i class="fas @service.Icon"></i>
                <div class="t">@UiDisplayLocalization.Localize(L, service.Title)</div>
                <div class="s">@UiDisplayLocalization.Localize(L, service.Subtitle)</div>
            </div>
        }
    }
</div>

<div class="re-care-card">
    <div class="re-care-card-head">
        <div class="icon"><i class="fas fa-users"></i></div>
        <div class="re-section-title" style="margin:0;">@L["What happens next"]</div>
    </div>
    <ul class="re-next-list">
        @foreach (var note in Model.WhatHappensNext)
        {
            <li><i class="fas fa-circle-check"></i> @UiDisplayLocalization.Localize(L, note)</li>
        }
    </ul>
</div>

<button type="button" class="re-btn-primary"><i class="fas fa-floppy-disk"></i> @L["Save care plan"]</button>
@if (hfPreview)
{
    <a asp-controller="HouseFactPreview" asp-action="RoofExterior" class="re-btn-secondary">
        <i class="fas fa-arrow-left"></i> @L["Back to Roof & Exterior"]
    </a>
}
else
{
    <a asp-action="Index" asp-route-id="@Model.PropiedadId" class="re-btn-secondary">
        <i class="fas fa-arrow-left"></i> @L["Back to Roof & Exterior"]
    </a>
}
