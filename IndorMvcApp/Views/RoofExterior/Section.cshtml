@model IndorMvcApp.ViewModels.RoofExteriorSectionViewModel
@{
    ViewData["Title"] = UiDisplayLocalization.Localize(L, Model.Name);
    var isRoof = Model.SectionId == "roof";
    var hfPreview = ViewBag.HouseFactPreview as bool? == true;
}
@section Head {
    <link rel="stylesheet" href="~/css/roof-exterior.css" asp-append-version="true" />
}

<div class="re-head">
    <h1 class="re-title">@UiDisplayLocalization.Localize(L, Model.Name)</h1>
    <p class="re-sub">@UiDisplayLocalization.Localize(L, Model.PageSubtitle)</p>
</div>

<div class="re-tabs">
    @foreach (var tab in Model.Tabs)
    {
        if (hfPreview)
        {
            <a class="re-tab @(Model.ActiveTab == tab.Key ? "active" : "")"
               asp-controller="HouseFactPreview" asp-action="RoofExteriorSection"
               asp-route-sectionId="@tab.Key"
               asp-route-tab="@tab.Key">
                <i class="fas @tab.Icon"></i> @UiDisplayLocalization.Localize(L, tab.Label)
            </a>
        }
        else
        {
            <a class="re-tab @(Model.ActiveTab == tab.Key ? "active" : "")"
               asp-action="Section"
               asp-route-id="@Model.PropiedadId"
               asp-route-sectionId="@tab.Key"
               asp-route-tab="@tab.Key">
                <i class="fas @tab.Icon"></i> @UiDisplayLocalization.Localize(L, tab.Label)
            </a>
        }
    }
</div>

<div class="re-property-card">
    <div class="re-property-thumb"><i class="fas fa-house"></i></div>
    <div style="flex:1;">
        <div class="re-property-address">@Model.Address</div>
        <span class="re-status green" style="display:inline-flex;margin-top:8px;"><i class="fas fa-database"></i> @L["Exterior section"]</span>
    </div>
    <i class="fas fa-chevron-right re-chev"></i>
</div>

@if (isRoof && Model.HealthBadges.Count > 0)
{
    <div class="re-section-title">@L["Roof Health Summary"]</div>
    <div class="re-health-badges">
        @foreach (var badge in Model.HealthBadges)
        {
            <span class="re-health-pill @badge.StatusTone"><i class="fas @badge.Icon"></i> @UiDisplayLocalization.Localize(L, badge.Label)</span>
        }
    </div>
}

@if (!isRoof && Model.SummaryCards.Count > 0)
{
    <div class="re-summary-scroll">
        @foreach (var card in Model.SummaryCards)
        {
            <div class="re-summary-card">
                <div class="k"><i class="fas @card.Icon"></i> @UiDisplayLocalization.Localize(L, card.Label)</div>
                <div class="v">@UiDisplayLocalization.Localize(L, card.Value)</div>
                <span class="badge @card.StatusTone">@UiDisplayLocalization.Localize(L, card.Status)</span>
            </div>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.InfoBanner))
{
    <div class="re-banner">
        <i class="fas fa-circle-info"></i>
        <div>@UiDisplayLocalization.Localize(L, Model.InfoBanner)</div>
    </div>
}

<div class="re-care-card">
    @foreach (var row in Model.Rows)
    {
        <div class="re-detail-row">
            <div class="icon"><i class="fas @row.Icon"></i></div>
            <div class="body">
                <div class="t">@UiDisplayLocalization.Localize(L, row.Title)</div>
                <div class="s">@UiDisplayLocalization.Localize(L, row.Subtitle)</div>
            </div>
            <span class="re-status @row.StatusTone">@UiDisplayLocalization.Localize(L, row.Status)</span>
            <i class="fas fa-chevron-down re-chev" style="font-size:.75rem;"></i>
        </div>
    }
</div>

@if (Model.Reminders.Count > 0)
{
    <div class="re-section-title">@L["Helpful reminders"]</div>
    <div class="re-care-card">
        @foreach (var reminder in Model.Reminders)
        {
            <div class="re-reminder"><i class="fas fa-circle-check"></i> @UiDisplayLocalization.Localize(L, reminder)</div>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.WhyItMattersText))
{
    <div class="re-banner">
        <i class="fas fa-circle-info"></i>
        <div>
            <strong>@UiDisplayLocalization.Localize(L, Model.WhyItMattersTitle)</strong><br />
            @UiDisplayLocalization.Localize(L, Model.WhyItMattersText)
        </div>
    </div>
}

@if (Model.SuggestedActions.Count > 0)
{
    @if (isRoof)
    {
        <div class="re-actions-grid">
            @foreach (var action in Model.SuggestedActions)
            {
                if (!string.IsNullOrWhiteSpace(action.Url))
                {
                    <a class="re-btn-primary" href="@action.Url" style="margin-top:0;"><i class="fas @action.Icon"></i> @UiDisplayLocalization.Localize(L, action.Title)</a>
                }
                else
                {
                    <button type="button" class="re-btn-primary" style="margin-top:0;"><i class="fas @action.Icon"></i> @UiDisplayLocalization.Localize(L, action.Title)</button>
                }
            }
        </div>
    }
    else
    {
        @foreach (var action in Model.SuggestedActions)
        {
            if (!string.IsNullOrWhiteSpace(action.Url))
            {
                <a class="re-btn-secondary" href="@action.Url"><i class="fas @action.Icon"></i> @UiDisplayLocalization.Localize(L, action.Title)</a>
            }
            else
            {
                <button type="button" class="re-btn-secondary"><i class="fas @action.Icon"></i> @UiDisplayLocalization.Localize(L, action.Title)</button>
            }
        }
    }
}

@if (hfPreview)
{
    <a asp-controller="HouseFactPreview" asp-action="RoofExterior" asp-route-tab="@Model.ActiveTab" class="re-btn-secondary">@L["Back to Roof & Exterior"]</a>
}
else
{
    <a asp-action="Index" asp-route-id="@Model.PropiedadId" asp-route-tab="@Model.ActiveTab" class="re-btn-secondary">@L["Back to Roof & Exterior"]</a>
}
