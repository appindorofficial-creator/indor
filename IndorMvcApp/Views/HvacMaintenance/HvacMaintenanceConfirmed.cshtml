@model IndorMvcApp.ViewModels.HvacMaintenanceConfirmedViewModel
@{
    ViewData["Title"] = "Tune-up request sent - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_HvacMaintenanceStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.NombreServicio</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_HvacMaintenanceStepper", 4)

    <div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Tune-up request sent</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">Your yearly HVAC service is being arranged.</p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-fan"></i><div><div class="summary-label">Service</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-barcode"></i><div><div class="summary-label">System serial</div><div class="summary-value">@Model.SerialLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">Last maintenance</div><div class="summary-value">@Model.LastMaintenanceLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">Visit window</div><div class="summary-value">@Model.VisitWindowLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-bell"></i><div><div class="summary-label">Reminder</div><div class="summary-value">@Model.ReminderLabel</div></div></div>
    </div>

    <div class="next-steps">
        <h4>What happens next</h4>
        <div class="next-step-item"><i class="fas fa-user-check"></i><span>A technician will review your request</span></div>
        <div class="next-step-item"><i class="fas fa-mobile-screen"></i><span>You'll receive confirmation in the app</span></div>
        <div class="next-step-item"><i class="fas fa-calendar-check"></i><span>We'll remind you before next year's service</span></div>
    </div>

    <a asp-controller="Home" asp-action="Index" asp-fragment="section-schedule" class="btn-primary">
        <i class="fas fa-calendar"></i> Go to My Schedule <i class="fas fa-chevron-right"></i>
    </a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline" style="margin-top:10px;">
        <i class="fas fa-house"></i> Back to Home Care Guide
    </a>
</div>
</body>
</html>
