@model IndorMvcApp.ViewModels.HvacMaintenanceDetailsViewModel
@{
    ViewData["Title"] = "Tell us about your system - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_HvacMaintenanceStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <button type="submit" form="hvac-details-form" name="action" value="back" class="back-btn" style="border:none;background:transparent;">
            <i class="fas fa-chevron-left"></i>
        </button>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_HvacMaintenanceStepper", 2)

    <h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">Tell us about your system</h1>
    <p class="page-lead" style="margin-bottom:16px;">A few details help us prepare the right tune-up.</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="hvac-details-form" asp-action="HvacMaintenanceDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-barcode"></i><span>AC serial number</span></div>
            <input asp-for="NumeroSerieAc" placeholder="Enter serial number" id="serialInput" />
            <span asp-validation-for="NumeroSerieAc" class="text-danger"></span>
            <div class="toggle-row" style="margin-top:12px;">
                <span><i class="fas fa-circle-question"></i> I don't know the serial number</span>
                <label class="toggle-switch">
                    <input asp-for="SerialDesconocido" type="checkbox" id="serialToggle" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-camera"></i><span>Photo of model / serial label</span></div>
            <label class="upload-drop" for="photoInput">
                <i class="fas fa-camera"></i>
                <strong>Add photo</strong>
                <span>JPG or PNG, up to 10 MB</span>
            </label>
            <input type="file" name="files" id="photoInput" accept=".jpg,.jpeg,.png" multiple style="display:none;" />
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="upload-preview">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <img src="@Url.Content("~" + file.RutaArchivo)" alt="@file.NombreArchivo" />
                    }
                </div>
            }
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>Last maintenance</span></div>
            <input asp-for="UltimoMantenimiento" placeholder="If you know it" id="maintenanceInput" />
            <div class="toggle-row" style="margin-top:12px;">
                <span>Not sure</span>
                <label class="toggle-switch">
                    <input asp-for="UltimoMantenimientoDesconocido" type="checkbox" id="maintenanceToggle" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-filter"></i><span>Filter size (optional)</span></div>
            <input asp-for="TamanioFiltro" placeholder="16x20x1 or I don't know" />
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-note-sticky"></i><span>Notes for technician</span></div>
            <textarea asp-for="NotasTecnico" placeholder="Tell us anything helpful (e.g., weak cooling, strange noise, etc.)"></textarea>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar"></i> Continue <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
<script>
    (function () {
        var serialToggle = document.getElementById('serialToggle');
        var serialInput = document.getElementById('serialInput');
        var maintenanceToggle = document.getElementById('maintenanceToggle');
        var maintenanceInput = document.getElementById('maintenanceInput');

        function syncSerial() {
            var disabled = serialToggle.checked;
            serialInput.disabled = disabled;
            if (disabled) serialInput.value = '';
        }

        function syncMaintenance() {
            var disabled = maintenanceToggle.checked;
            maintenanceInput.disabled = disabled;
            if (disabled) maintenanceInput.value = '';
        }

        serialToggle.addEventListener('change', syncSerial);
        maintenanceToggle.addEventListener('change', syncMaintenance);

        syncSerial();
        syncMaintenance();
    })();
</script>
</body>
</html>
