@model IndorMvcApp.ViewModels.HvacMaintenanceDetailsViewModel
@using System.Globalization
@using IndorMvcApp.Validation
@{
    ViewData["Title"] = "Tell us about your system - INDOR";
var maxMaintenanceDate = DateTime.Today.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("HvacMaintenanceService", "HvacMaintenance", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">Tell us about your system</h1>
    <p class="page-lead" style="margin-bottom:16px;">A few details help us prepare the right tune-up.</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="hvac-details-form" asp-action="HvacMaintenanceDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-barcode"></i><span>AC serial number</span></div>
            <input asp-for="NumeroSerieAc"
                   placeholder="e.g. M123456789"
                   id="serialInput"
                   maxlength="@EquipmentSerialNumberAttribute.MaxLength"
                   autocomplete="off"
                   spellcheck="false" />
            <span class="field-hint">@EquipmentSerialNumberAttribute.HintText</span>
            <span asp-validation-for="NumeroSerieAc" class="text-danger"></span>
            <div class="toggle-row" style="margin-top:12px;">
                <span><i class="fas fa-circle-question"></i> I don't know the serial number</span>
                <label class="toggle-switch">
                    <input asp-for="SerialDesconocido" type="checkbox" id="serialToggle" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-camera"></i><span>Photo of model / serial label</span></div>
            <div class="upload-drop-wrap">
                <input type="file" name="files" id="photoInput" class="upload-input-hidden" multiple
                       accept="image/*,.jpg,.jpeg,.png,.webp,.heic,.heif" />
                <label class="upload-drop" id="photoDropzone" for="photoInput">
                    <i class="fas fa-camera"></i>
                    <strong>Add photo</strong>
                    <span>JPG, PNG, or HEIC — up to 10 MB</span>
                </label>
            </div>
            <div class="upload-selected-list" id="photoSelectedList" hidden></div>
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="upload-selected-list" id="photoSavedList">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <div class="upload-selected-item">
                            <img class="upload-preview-thumb" src="@Url.Content($"~{file.RutaArchivo}")" alt="" loading="lazy" />
                            <span>@file.NombreArchivo</span>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>Last maintenance</span></div>
            <input asp-for="FechaUltimoMantenimiento"
                   type="date"
                   id="maintenanceInput"
                   class="form-input"
                   max="@maxMaintenanceDate"
                   aria-label="Last maintenance date" />
            <span class="field-hint">Select the date of your last tune-up, if you know it.</span>
            <span asp-validation-for="FechaUltimoMantenimiento" class="text-danger"></span>
            <div class="toggle-row" style="margin-top:12px;">
                <span>Not sure</span>
                <label class="toggle-switch">
                    <input asp-for="UltimoMantenimientoDesconocido" type="checkbox" id="maintenanceToggle" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-filter"></i><span>Filter size (optional)</span></div>
            <input asp-for="TamanioFiltro" placeholder="16x20x1 or I don't know" />
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-note-sticky"></i><span>Notes for technician</span></div>
            <textarea asp-for="NotasTecnico" placeholder="Tell us anything helpful (e.g., weak cooling, strange noise, etc.)"></textarea>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar"></i> Continue <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        var serialToggle = document.getElementById('serialToggle');
        var serialInput = document.getElementById('serialInput');
        var maintenanceToggle = document.getElementById('maintenanceToggle');
        var maintenanceInput = document.getElementById('maintenanceInput');

        function syncSerial() {
            var disabled = serialToggle.checked;
            serialInput.disabled = disabled;
            if (disabled) {
                serialInput.value = '';
                serialInput.setCustomValidity('');
            }
        }

        function serialErrorMessage(value) {
            var serial = String(value || '').trim();
            if (!serial) {
                return 'Enter the AC serial number or toggle "I don\'t know".';
            }
            if (serial.length < @EquipmentSerialNumberAttribute.MinLength) {
                return 'Serial number must be at least @EquipmentSerialNumberAttribute.MinLength characters.';
            }
            if (serial.length > @EquipmentSerialNumberAttribute.MaxLength) {
                return 'Serial number cannot exceed @EquipmentSerialNumberAttribute.MaxLength characters.';
            }
            if (!/^[A-Za-z0-9\-]+$/.test(serial)) {
                return 'Use only letters, numbers, and hyphens.';
            }
            if (!/\p{L}/u.test(serial) || !/\d/.test(serial)) {
                return 'Serial number must include at least one letter and one number.';
            }
            return '';
        }

        function validateSerialField() {
            if (serialToggle.checked) {
                serialInput.setCustomValidity('');
                return true;
            }
            var message = serialErrorMessage(serialInput.value);
            serialInput.setCustomValidity(message);
            return !message;
        }

        serialInput.addEventListener('input', validateSerialField);

        var detailsForm = document.getElementById('hvac-details-form');
        detailsForm?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') {
                return;
            }
            if (!validateSerialField()) {
                e.preventDefault();
                serialInput.reportValidity();
            }
        });

        function syncMaintenanceValidity() {
            if (!maintenanceInput) return;
            // Browsers show the native range message localized to the device locale
            // (e.g. Spanish). Override it with our own English message instead.
            if (!maintenanceInput.disabled && maintenanceInput.validity.rangeOverflow) {
                maintenanceInput.setCustomValidity('Select a date on or before today.');
            } else {
                maintenanceInput.setCustomValidity('');
            }
        }

        function syncMaintenance() {
            var disabled = maintenanceToggle.checked;
            maintenanceInput.disabled = disabled;
            if (disabled) maintenanceInput.value = '';
            syncMaintenanceValidity();
        }

        serialToggle.addEventListener('change', function () {
            syncSerial();
            validateSerialField();
        });
        maintenanceToggle.addEventListener('change', syncMaintenance);
        maintenanceInput.addEventListener('input', syncMaintenanceValidity);
        maintenanceInput.addEventListener('change', syncMaintenanceValidity);

        syncSerial();
        syncMaintenance();

        var photoInput = document.getElementById('photoInput');
        var photoDropzone = document.getElementById('photoDropzone');
        var photoSelectedList = document.getElementById('photoSelectedList');
        var maxPhotos = 2;
        var existingCount = @Model.ArchivosExistentes.Count;
        var pendingPhotos = [];

        function syncPhotoInputFiles() {
            if (!photoInput) return;
            var dt = new DataTransfer();
            pendingPhotos.slice(0, Math.max(0, maxPhotos - existingCount)).forEach(function (file) {
                dt.items.add(file);
            });
            photoInput.files = dt.files;
        }

        function mergePhotoFiles(newFiles) {
            Array.from(newFiles || []).forEach(function (file) {
                if (file && file.size > 0) {
                    pendingPhotos.push(file);
                }
            });
            var allowed = Math.max(0, maxPhotos - existingCount);
            if (pendingPhotos.length > allowed) {
                pendingPhotos = pendingPhotos.slice(0, allowed);
            }
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function removePendingPhoto(index) {
            pendingPhotos.splice(index, 1);
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function renderPhotoSelection(files) {
            if (!photoSelectedList || !photoDropzone) return;
            var list = Array.from(files || []).filter(function (f) { return f && f.size > 0; });
            photoSelectedList.innerHTML = '';
            if (list.length === 0) {
                photoSelectedList.hidden = true;
                photoDropzone.classList.remove('has-files');
                return;
            }
            photoDropzone.classList.add('has-files');
            photoSelectedList.hidden = false;
            list.forEach(function (file, index) {
                var row = document.createElement('div');
                row.className = 'upload-selected-item';
                if (!file.type || file.type.indexOf('image/') === 0) {
                    var img = document.createElement('img');
                    img.className = 'upload-preview-thumb';
                    img.alt = 'Selected photo ' + (index + 1);
                    row.appendChild(img);
                    var reader = new FileReader();
                    reader.onload = function (e) { img.src = e.target.result; };
                    reader.readAsDataURL(file);
                } else {
                    var icon = document.createElement('i');
                    icon.className = 'fas fa-image';
                    row.appendChild(icon);
                }
                var name = document.createElement('span');
                name.textContent = file.name || ('Photo ' + (index + 1));
                row.appendChild(name);
                var removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'upload-remove-btn';
                removeBtn.setAttribute('aria-label', 'Remove ' + (file.name || 'photo'));
                removeBtn.innerHTML = '<i class="fas fa-xmark"></i>';
                removeBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    removePendingPhoto(index);
                });
                row.appendChild(removeBtn);
                photoSelectedList.appendChild(row);
            });
        }

        photoInput?.addEventListener('change', function () {
            mergePhotoFiles(this.files);
            this.value = '';
        });
    })();

</script>
}
