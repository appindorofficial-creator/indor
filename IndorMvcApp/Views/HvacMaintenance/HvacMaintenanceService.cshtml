@model IndorMvcApp.ViewModels.HvacMaintenanceServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home", new { fragment = "section-schedule" });
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}


@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="hvac-hero-icon"><i class="fas fa-fan"></i></span>
        </div>
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@Model.LandingTitulo</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@Model.LandingTagline</div>
            }
        </div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="includes-box">
            <div class="includes-label">@L["Includes"]</div>
            <ul>
                @foreach (var item in Model.IncludedItems)
                {
                    <li><i class="fas @item.Icon"></i><span>@item.Text</span></li>
                }
            </ul>
        </div>
    }

    @if (Model.PreviewItems.Count > 0)
    {
        <div class="preview-box">
            <div class="preview-label">@L["What we'll ask"]</div>
            @foreach (var item in Model.PreviewItems)
            {
                <div class="preview-row">
                    <div class="left"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                    <div class="right"><i class="fas fa-chevron-right"></i></div>
                </div>
            }
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="HvacMaintenanceService" method="post">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar-plus"></i> @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTexto))
    {
        <div class="info-box-blue" style="margin-top:14px;">
            <i class="fas fa-shield-halved"></i>
            <span>@Model.InfoBoxTexto</span>
        </div>
    }
