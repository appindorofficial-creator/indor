@model IndorMvcApp.ViewModels.PropertyAdministratorReviewViewModel
@{
    var s = Model.State;
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<form asp-action="Review" method="post" id="paReviewForm" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="pa-summary-error"></div>

    <div class="pa-review-card">
        <div class="pa-review-illus" aria-hidden="true">
            <span class="pa-review-cloud pa-review-cloud--1"></span>
            <span class="pa-review-cloud pa-review-cloud--2"></span>
            <div class="pa-review-building">
                <div class="pa-review-building-block">
                    <div class="pa-review-building-tower"></div>
                </div>
                <div class="pa-review-building-block">
                    <div class="pa-review-building-base">
                        <span></span><span></span><span></span>
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>
            <span class="pa-review-check"><i class="fas fa-check"></i></span>
        </div>

        <div class="pa-review-line">
            <span class="pa-review-line-label"><i class="fas fa-user"></i> Profile</span>
            <strong>@s.DisplayName</strong>
        </div>
        <div class="pa-review-line">
            <span class="pa-review-line-label"><i class="fas fa-briefcase"></i> Portfolio type</span>
            <strong>@Model.PortfolioTypeLabel</strong>
        </div>
        <div class="pa-review-line">
            <span class="pa-review-line-label"><i class="fas fa-house"></i> Properties</span>
            <strong>@Model.PropertyCount</strong>
        </div>
        <div class="pa-review-line">
            <span class="pa-review-line-label"><i class="fas fa-globe"></i> Markets</span>
            <strong>@s.PrimaryMarket</strong>
        </div>
        <div class="pa-review-line">
            <span class="pa-review-line-label"><i class="fas fa-gear"></i> Management style</span>
            <strong>@Model.ManagementStyleLabel</strong>
        </div>
    </div>

    <div class="pa-checklist">
        @if (Model.AccountCreated)
        {
            <div class="pa-check-item"><i class="fas fa-circle-check"></i> Account created</div>
        }
        @if (Model.PortfolioDetailsAdded)
        {
            <div class="pa-check-item"><i class="fas fa-circle-check"></i> Portfolio details added</div>
        }
        @if (Model.PropertiesAdded)
        {
            <div class="pa-check-item"><i class="fas fa-circle-check"></i> Properties added</div>
        }
        @if (Model.ToolsSelected)
        {
            <div class="pa-check-item"><i class="fas fa-circle-check"></i> Tools selected</div>
        }
        <div class="pa-check-item pa-check-item--later"><i class="fas fa-user-plus"></i> Invite team members later from your dashboard</div>
    </div>

    <label class="pa-terms">
        <input type="checkbox" id="platformTermsAccepted" name="platformTermsAccepted" value="true" />
        <span>I agree to <a asp-controller="Account" asp-action="Terms">INDOR's platform terms</a></span>
    </label>
</form>

@{
    ViewData["StepFormId"] = "paReviewForm";
    ViewData["StepBackUrl"] = Model.BackUrl;
    ViewData["StepSubmitLabel"] = "Go to Dashboard";
}
@await Html.PartialAsync("_PropertyAdminStepActions")

@section Scripts {
<script>
    (function () {
        var form = document.getElementById('paReviewForm');
        var terms = document.getElementById('platformTermsAccepted');
        if (!form || !terms) return;

        terms.addEventListener('change', function () {
            terms.setCustomValidity('');
        });

        form.addEventListener('submit', function (e) {
            if (terms.checked) {
                terms.setCustomValidity('');
                return;
            }

            e.preventDefault();
            terms.setCustomValidity('Please agree to INDOR\'s platform terms.');
            terms.reportValidity();
        });
    })();
</script>
}
