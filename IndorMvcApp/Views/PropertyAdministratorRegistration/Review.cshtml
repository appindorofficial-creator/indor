@model IndorMvcApp.ViewModels.PropertyAdministratorReviewViewModel
@{
    var s = Model.State;
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<div class="pa-review-card">
    <div class="pa-review-illus" aria-hidden="true">
        <span class="pa-review-cloud pa-review-cloud--1"></span>
        <span class="pa-review-cloud pa-review-cloud--2"></span>
        <div class="pa-review-building">
            <div class="pa-review-building-block">
                <div class="pa-review-building-tower"></div>
            </div>
            <div class="pa-review-building-block">
                <div class="pa-review-building-base">
                    <span></span><span></span><span></span>
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
        <span class="pa-review-check"><i class="fas fa-check"></i></span>
    </div>

    <div class="pa-review-line">
        <span class="pa-review-line-label"><i class="fas fa-user"></i> @L["Profile"]</span>
        <strong>@s.DisplayName</strong>
    </div>
    <div class="pa-review-line">
        <span class="pa-review-line-label"><i class="fas fa-briefcase"></i> @L["Portfolio type"]</span>
        <strong>@Model.PortfolioTypeLabel</strong>
    </div>
    <div class="pa-review-line">
        <span class="pa-review-line-label"><i class="fas fa-house"></i> @L["Properties"]</span>
        <strong>@Model.PropertyCount</strong>
    </div>
    <div class="pa-review-line">
        <span class="pa-review-line-label"><i class="fas fa-globe"></i> @L["Markets"]</span>
        <strong>@s.PrimaryMarket</strong>
    </div>
    <div class="pa-review-line">
        <span class="pa-review-line-label"><i class="fas fa-gear"></i> @L["Management style"]</span>
        <strong>@Model.ManagementStyleLabel</strong>
    </div>
</div>

<div class="pa-checklist">
    @if (Model.AccountCreated)
    {
        <div class="pa-check-item"><i class="fas fa-circle-check"></i> @L["Account created"]</div>
    }
    @if (Model.PortfolioDetailsAdded)
    {
        <div class="pa-check-item"><i class="fas fa-circle-check"></i> @L["Portfolio details added"]</div>
    }
    @if (Model.PropertiesAdded)
    {
        <div class="pa-check-item"><i class="fas fa-circle-check"></i> @L["Properties added"]</div>
    }
    @if (Model.ToolsSelected)
    {
        <div class="pa-check-item"><i class="fas fa-circle-check"></i> @L["Tools selected"]</div>
    }
</div>

<a asp-action="InviteTeam" class="pa-action-row pa-action-row--review-invite" aria-label="@L["Invite team members"]">
    <span>
        <i class="fas fa-user-plus"></i>
        Invite team members
        @if (Model.PendingTeamInviteCount > 0)
        {
            <small class="pa-action-row-meta">(@Model.PendingTeamInviteCount added)</small>
        }
    </span>
    <i class="fas fa-chevron-right" aria-hidden="true"></i>
</a>

<form asp-action="Review" method="post" id="paReviewForm" class="pa-validate" novalidate>
    @Html.AntiForgeryToken()
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="pa-summary-error" role="alert"></div>
    }

    <label class="pa-terms">
        <input type="hidden" name="platformTermsAccepted" value="false" />
        <input type="checkbox"
               id="platformTermsAccepted"
               name="platformTermsAccepted"
               value="true"
               data-pa-required="true"
               data-field-label="INDOR's platform terms" />
        <span>@L["I agree to"] <a asp-controller="Account" asp-action="Terms">@L["INDOR's platform terms"]</a></span>
    </label>
    @if (ViewData.ModelState.TryGetValue("platformTermsAccepted", out var platformTermsState) && platformTermsState.Errors.Count > 0)
    {
        <div class="pa-inline-error" role="alert">@platformTermsState.Errors[0].ErrorMessage</div>
    }
</form>

@{
    ViewData["StepFormId"] = "paReviewForm";
    ViewData["StepBackUrl"] = Model.BackUrl;
    ViewData["StepSubmitLabel"] = "Go to Dashboard";
}
@await Html.PartialAsync("_PropertyAdminStepActions")

@section Scripts {
    @await Html.PartialAsync("_PropertyAdminStepValidation")
}
