@model IndorMvcApp.ViewModels.PropertyAdministratorImportPortfolioViewModel
@using IndorMvcApp.Models

@if (!string.IsNullOrWhiteSpace(Model.FormError))
{
    <div class="pa-summary-error">@UiDisplayLocalization.Localize(L, Model.FormError)</div>
}

<div class="pa-review-card" style="margin-bottom:16px;">
    <p class="pa-step-hint" style="margin:0 0 10px;">@L["Use a CSV file with one property per row. Required columns:"]</p>
    <div class="pa-check-item"><i class="fas fa-circle-check"></i> @L["HouseNumber, StreetName, City, State, ZipCode, PropertyType"]</div>
    <div class="pa-check-item"><i class="fas fa-circle-check"></i> @L["Nickname (optional)"]</div>
    <p class="pa-step-hint" style="margin:12px 0 0;">
        @L["Property type values:"]
        @string.Join(", ", PropertyAdministratorCatalog.PropertyTypes.Select(type =>
            L[type.Label]))
    </p>
</div>

@{
    var csvFileName = L.IsSpanish ? "indor-plantilla-portafolio.csv" : "indor-portfolio-template.csv";
    var csvFileUrl = Url.Action("DownloadPortfolioTemplateFile") ?? "#";
    var csvTemplatePageUrl = Url.Action("DownloadPortfolioTemplate", new { returnUrl = Model.BackUrl }) ?? "#";
}

<p style="margin-bottom:16px;">
    <a href="@csvTemplatePageUrl"
       id="paDownloadCsvTemplate"
       data-file-url="@csvFileUrl"
       data-file-name="@csvFileName"
       data-no-nav-loading
       class="pa-reg-action-back"
       style="display:inline-flex;align-items:center;gap:6px;">
        <i class="fas fa-download"></i> @L["Download CSV template"]
    </a>
</p>

<form asp-action="ImportPortfolio" method="post" enctype="multipart/form-data" id="importPortfolioForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@Model.BackUrl" />

    <div class="pa-file-picker" id="csvFilePicker">
        <i class="fas fa-file-csv pa-file-picker-icon" aria-hidden="true"></i>
        <input type="file"
               id="csvFile"
               name="csvFile"
               class="pa-file-picker-input"
               accept=".csv,text/csv,.txt"
               required />
        <label for="csvFile" class="pa-file-picker-btn">@L["Choose CSV file"]</label>
        <span class="pa-file-picker-name" id="csvFileName" data-empty-label="@L["No file selected"]">@L["No file selected"]</span>
    </div>

    <button type="submit" class="ob-btn ob-btn-outline" style="width:100%;margin-top:4px;">@L["Import properties"]</button>
</form>

<script>
    (function () {
        const input = document.getElementById('csvFile');
        const nameEl = document.getElementById('csvFileName');
        const picker = document.getElementById('csvFilePicker');
        if (input && nameEl && picker) {
            const emptyLabel = nameEl.dataset.emptyLabel || 'No file selected';

            function syncFileLabel() {
                const file = input.files && input.files[0];
                if (file) {
                    nameEl.textContent = file.name;
                    nameEl.classList.add('is-selected');
                    picker.classList.add('has-file');
                } else {
                    nameEl.textContent = emptyLabel;
                    nameEl.classList.remove('is-selected');
                    picker.classList.remove('has-file');
                }
            }

            input.addEventListener('change', syncFileLabel);
            syncFileLabel();
        }

        // Download CSV without leaving Import Portfolio (avoids blank/stuck WebView pages).
        const downloadLink = document.getElementById('paDownloadCsvTemplate');
        if (!downloadLink) return;

        downloadLink.addEventListener('click', function (e) {
            const fileUrl = downloadLink.getAttribute('data-file-url');
            const fileName = downloadLink.getAttribute('data-file-name') || 'indor-portfolio-template.csv';
            const fallbackUrl = downloadLink.getAttribute('href');
            if (!fileUrl || fileUrl === '#') return;

            e.preventDefault();
            e.stopPropagation();

            fetch(fileUrl, { credentials: 'same-origin' })
                .then(function (res) {
                    if (!res.ok) throw new Error('download failed');
                    return res.blob();
                })
                .then(function (blob) {
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = fileName;
                    a.style.display = 'none';
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                    setTimeout(function () { URL.revokeObjectURL(url); }, 2000);
                })
                .catch(function () {
                    // Fallback: open the template page (has back navigation).
                    if (fallbackUrl && fallbackUrl !== '#') {
                        window.location.assign(fallbackUrl);
                    }
                });
        });
    })();
</script>
