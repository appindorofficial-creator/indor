@model IndorMvcApp.ViewModels.PropertyAdministratorPortfolioTemplateViewModel

<div class="pa-review-card" style="margin-bottom:16px;">
    <p class="pa-step-hint" style="margin:0;">
        @L["Use the sample CSV, fill in your properties, then return here to import the file."]
    </p>
</div>

<p style="margin-bottom:16px;">
    @* href stays on this page — never point at the file URL (WebViews replace the UI with raw CSV and leave no Back). *@
    <a href="#"
       id="paCsvTemplateFileLink"
       role="button"
       data-file-url="@Model.FileDownloadUrl"
       data-file-name="@Model.FileName"
       data-no-nav-loading
       class="ob-btn ob-btn-outline"
       style="display:inline-flex;align-items:center;justify-content:center;gap:8px;width:100%;">
        <i class="fas fa-download"></i> @L["Download CSV template"]
    </a>
</p>

<script>
    (function () {
        const link = document.getElementById('paCsvTemplateFileLink');
        if (!link) return;

        link.addEventListener('click', function (e) {
            const fileUrl = link.getAttribute('data-file-url');
            const fileName = link.getAttribute('data-file-name') || 'indor-portfolio-template.csv';
            e.preventDefault();
            e.stopPropagation();
            if (!fileUrl || fileUrl === '#') return;

            fetch(fileUrl, { credentials: 'same-origin' })
                .then(function (res) {
                    if (!res.ok) throw new Error('download failed');
                    return res.blob();
                })
                .then(function (blob) {
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = fileName;
                    a.style.display = 'none';
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                    setTimeout(function () { URL.revokeObjectURL(url); }, 2000);
                })
                .catch(function () {
                    // Stay on this page (has back navigation) rather than navigating to a file response.
                });
        });
    })();
</script>
