@model IndorMvcApp.ViewModels.PropertyAdministratorRegistrationStepViewModel
@using IndorMvcApp.Models
@{
    var s = Model.State;
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<form asp-action="Portfolio" method="post" id="portfolioForm" class="pa-validate" novalidate>
    @Html.AntiForgeryToken()
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="pa-summary-error" role="alert"></div>
    }

    <p class="ob-label">Number of properties</p>
    <div class="pa-choice-grid">
        @foreach (var range in PropertyAdministratorCatalog.PropertyCountRanges)
        {
            <label class="pa-choice-card @(s.PropertyCountRange == range ? "is-selected" : "")">
                <input type="radio" name="propertyCountRange" value="@range" @(s.PropertyCountRange == range ? "checked" : null) data-pa-required="true" data-field-label="how many properties you manage" />
                <i class="fas fa-building"></i>
                <span>@range</span>
            </label>
        }
    </div>

    <label class="pa-field">
        <i class="fas fa-house"></i>
        <select name="portfolioType" data-pa-required="true" data-field-label="a portfolio type">
            <option value="">Portfolio type</option>
            @foreach (var item in PropertyAdministratorCatalog.PortfolioTypes)
            {
                <option value="@item.Value" selected="@(s.PortfolioType == item.Value)">@item.Label</option>
            }
        </select>
    </label>

    <label class="pa-field">
        <i class="fas fa-user"></i>
        <select name="ownershipType" data-pa-required="true" data-field-label="an ownership type">
            <option value="">Ownership type</option>
            @foreach (var item in PropertyAdministratorCatalog.OwnershipTypes)
            {
                <option value="@item.Value" selected="@(s.OwnershipType == item.Value)">@item.Label</option>
            }
        </select>
    </label>

    <label class="pa-field">
        <i class="fas fa-location-dot"></i>
        <select name="primaryMarket" data-pa-required="true" data-field-label="your primary market">
            <option value="">Select your primary market or city</option>
            @foreach (var market in PropertyAdministratorCatalog.PrimaryMarkets)
            {
                <option value="@market" selected="@(s.PrimaryMarket == market)">@market</option>
            }
        </select>
    </label>

    <p class="ob-label">Do you self-manage or use a team?</p>
    <div class="pa-choice-grid cols-3">
        @foreach (var item in PropertyAdministratorCatalog.ManagementStyles)
        {
            <label class="pa-choice-card @(s.ManagementStyle == item.Value ? "is-selected" : "")">
                <input type="radio" name="managementStyle" value="@item.Value" @(s.ManagementStyle == item.Value ? "checked" : null) data-pa-required="true" data-field-label="how you manage your properties" />
                <i class="fas @(item.Value == "SelfManage" ? "fa-user" : item.Value == "SmallTeam" ? "fa-users" : "fa-briefcase")"></i>
                <span>@item.Label</span>
            </label>
        }
    </div>

</form>

@{
    ViewData["StepFormId"] = "portfolioForm";
    ViewData["StepBackUrl"] = Model.BackUrl;
    ViewData["StepSubmitLabel"] = "Next";
}
@await Html.PartialAsync("_PropertyAdminStepActions")

@section Scripts {
<script>
    document.querySelectorAll('.pa-choice-card input[type="radio"]').forEach(input => {
        input.addEventListener('change', () => {
            const group = input.closest('.pa-choice-grid');
            group.querySelectorAll('.pa-choice-card').forEach(c => c.classList.remove('is-selected'));
            input.closest('.pa-choice-card')?.classList.add('is-selected');
        });
    });
</script>
@await Html.PartialAsync("_PropertyAdminStepValidation")
}
