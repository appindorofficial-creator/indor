@model IndorMvcApp.ViewModels.PropertyAdministratorInviteTeamViewModel
@{
    var s = Model.State;
}
@await Html.PartialAsync("_PropertyAdminRegHead", Model)

@if (!string.IsNullOrWhiteSpace(Model.FormError))
{
    <div class="pa-summary-error" role="alert">@UiDisplayLocalization.Localize(L, Model.FormError)</div>
}
@if (!string.IsNullOrWhiteSpace(Model.FormSuccess))
{
    <div class="pa-summary-success" role="status">@Model.FormSuccess</div>
}

@if (Model.PendingInvites.Count > 0)
{
    <div class="pa-review-card" style="margin-bottom:16px;">
        @foreach (var invite in Model.PendingInvites)
        {
            <div class="pa-check-item"><i class="fas fa-circle-check"></i> @invite</div>
        }
    </div>
}

<form asp-action="InviteTeam" method="post" id="inviteTeamForm" class="pa-validate" novalidate>
    @Html.AntiForgeryToken()

    <label class="pa-field">
        <i class="fas fa-user"></i>
        <input type="text"
               name="inviteName"
               value="@Model.InviteName"
               placeholder="@L["Name (optional)"]"
               autocomplete="name" />
    </label>

    <label class="pa-field">
        <i class="fas fa-envelope"></i>
        <input type="email"
               name="inviteEmail"
               value="@Model.InviteEmail"
               placeholder="@L["Email address"]"
               inputmode="email"
               autocomplete="email"
               required
               data-pa-required="true"
               data-pa-email="true"
               data-field-label="a valid email address"
               aria-describedby="inviteEmailHint" />
    </label>
    <p class="pa-form-hint" id="inviteEmailHint">
        @if (Model.PendingInvites.Count > 0)
        {
            <text>@L["Add another teammate below, or go back to review when you are done."]</text>
        }
        else
        {
            <text>@L["Use a complete email address (e.g. name@email.com)."]</text>
        }
    </p>

    <button type="submit" class="ob-btn ob-btn-outline" style="width:100%;margin-top:4px;">
        @(Model.PendingInvites.Count > 0 ? L["Add another invite"] : L["Send invite"])
    </button>
</form>

<div class="pa-reg-actions" style="margin-top:18px;">
    <a href="@Model.BackUrl" class="pa-reg-action-back">@L["Back to review"]</a>
</div>

@section Scripts {
    @await Html.PartialAsync("_PropertyAdminStepValidation")
}
