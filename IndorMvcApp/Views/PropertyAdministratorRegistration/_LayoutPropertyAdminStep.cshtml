@{
    var stepModel = Model as IndorMvcApp.ViewModels.PropertyAdministratorRegistrationStepViewModel
        ?? ViewData["PropertyAdminStep"] as IndorMvcApp.ViewModels.PropertyAdministratorRegistrationStepViewModel;
    var pageTitle = stepModel?.Title ?? ViewData["Title"] as string ?? "Property Administrator";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@pageTitle - INDOR</title>
    @await Html.PartialAsync("_AppVersionHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/property-admin-portal.css" asp-append-version="true" />
</head>
<body class="ob-page pa-page">
    <div class="ob-shell">
        <div class="ob-shell-inner">
            @if (stepModel != null)
            {
                @await Html.PartialAsync("_PropertyAdminStepper", stepModel)
            }
            @RenderBody()
        </div>
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
