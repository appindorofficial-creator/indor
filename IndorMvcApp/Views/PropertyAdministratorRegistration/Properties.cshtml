@model IndorMvcApp.ViewModels.PropertyAdministratorPropertiesStepViewModel
@{
    if (Model.IsRegistrationComplete)
    {
        Layout = "_PropertyAdminLayout";
        ViewData["Title"] = L["Add property"];
        ViewBag.NavActive = "properties";
    }
    else
    {
        ViewData["StepFormId"] = "paPropertiesContinueForm";
        ViewData["StepBackUrl"] = Model.BackUrl;
        ViewData["StepSubmitLabel"] = "Next";
        ViewData["StepSubmitFormNoValidate"] = true;
    }
}

@if (Model.IsRegistrationComplete)
{
    <div class="pa-portal-shell pa-portal-shell--portfolio">
        <header class="pa-portfolio-page-header">
            <a href="@Model.BackUrl" class="pa-profile-back" aria-label="@L["Back"]">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="pa-portfolio-page-header-text">
                @await Html.PartialAsync("_PropertyAdminRegHead", Model)
            </div>
        </header>
        <div class="pa-portfolio-add-content">
            @await Html.PartialAsync("_PropertyAdminPropertiesBody", Model)
            <div class="pa-reg-actions">
                <a href="@Model.DoneUrl" class="ob-btn ob-btn-primary">@L["Done"]</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="ob-head-block">
        <h1>@UiDisplayLocalization.Localize(L, Model.Title)</h1>
        <p>@UiDisplayLocalization.Localize(L, Model.Subtitle)</p>
        <p class="pa-step-hint">@L["You can add properties now or skip and add them later from your dashboard."]</p>
    </div>

    @await Html.PartialAsync("_PropertyAdminPropertiesBody", Model)

    <form asp-action="ContinueFromProperties" method="post" id="paPropertiesContinueForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="houseNumber" id="pa-continue-house" value="" />
        <input type="hidden" name="streetName" id="pa-continue-street" value="" />
        <input type="hidden" name="city" id="pa-continue-city" value="" />
        <input type="hidden" name="state" id="pa-continue-state" value="" />
        <input type="hidden" name="zipCode" id="pa-continue-zip" value="" />
        <input type="hidden" name="propertyType" id="pa-continue-type" value="" />
        <input type="hidden" name="propertyNickname" id="pa-continue-nickname" value="" />
    </form>

    @await Html.PartialAsync("_PropertyAdminStepActions")
}

@await Html.PartialAsync("_AddressAutocompleteScripts")
<script src="~/js/zip-input.js" asp-append-version="true"></script>

<script>
(function () {
    var manualPropertyFields = [
        { el: document.getElementById('pa-prop-house'), message: 'Enter a house number.' },
        { el: document.getElementById('pa-prop-street'), message: 'Enter a street name.' },
        { el: document.getElementById('pa-prop-city'), message: 'Enter a city.' },
        { el: document.getElementById('pa-prop-state'), message: 'Select a state.' },
        { el: document.getElementById('pa-prop-zip'), message: 'Enter a ZIP code.' },
        { el: document.getElementById('pa-prop-type'), message: 'Select a property type.' }
    ];

    function fieldValue(form, name) {
        var el = form.querySelector('[name="' + name + '"]');
        return el && el.value ? String(el.value).trim() : '';
    }

    function isManualDraftStarted(manualForm) {
        if (!manualForm) return false;

        var defaultCity = (manualForm.dataset.paDefaultCity || '').trim();
        var defaultState = (manualForm.dataset.paDefaultState || '').trim();

        if (fieldValue(manualForm, 'houseNumber')) return true;
        if (fieldValue(manualForm, 'streetName')) return true;
        if (fieldValue(manualForm, 'zipCode')) return true;
        if (fieldValue(manualForm, 'propertyType')) return true;
        if (fieldValue(manualForm, 'propertyNickname')) return true;

        var city = fieldValue(manualForm, 'city');
        var state = fieldValue(manualForm, 'state');
        if (city && city.toLowerCase() !== defaultCity.toLowerCase()) return true;
        if (state && state.toLowerCase() !== defaultState.toLowerCase()) return true;

        return false;
    }

    function syncContinueHiddenFields(manualForm, continueForm) {
        [
            ['houseNumber', 'pa-continue-house'],
            ['streetName', 'pa-continue-street'],
            ['city', 'pa-continue-city'],
            ['state', 'pa-continue-state'],
            ['zipCode', 'pa-continue-zip'],
            ['propertyType', 'pa-continue-type'],
            ['propertyNickname', 'pa-continue-nickname']
        ].forEach(function (pair) {
            var src = manualForm.querySelector('[name="' + pair[0] + '"]');
            var dest = document.getElementById(pair[1]);
            if (src && dest) {
                dest.value = src.value || '';
            }
        });
    }

    function syncFieldValidity(field) {
        if (!field.el || field.el.disabled) return;

        if (field.el.id === 'pa-prop-zip' && window.IndorZipInput) {
            var zipError = window.IndorZipInput.validateRequired(field.el.value);
            field.el.setCustomValidity(zipError || '');
            return;
        }

        var empty = !field.el.value || !String(field.el.value).trim();
        field.el.setCustomValidity(empty ? field.message : '');
    }

    function validateManualPropertyForm(manualForm) {
        var panel = manualForm.closest('details');
        if (panel && !panel.open) {
            panel.open = true;
        }

        var firstInvalid = null;
        manualPropertyFields.forEach(function (field) {
            syncFieldValidity(field);
            if (!field.el || field.el.disabled || firstInvalid) return;
            if (!field.el.checkValidity()) {
                firstInvalid = field.el;
            }
        });

        if (firstInvalid) {
            firstInvalid.reportValidity();
            return false;
        }

        return true;
    }
    function bindRequiredFields(form, fields) {
        if (!form) return;

        function syncValidity(field) {
            if (!field.el || field.el.disabled) return;

            if (field.el.id === 'pa-prop-zip' && window.IndorZipInput) {
                var zipError = window.IndorZipInput.validateRequired(field.el.value);
                field.el.setCustomValidity(zipError || '');
                return;
            }

            var empty = field.kind === 'file'
                ? !(field.el.files && field.el.files.length)
                : !field.el.value || !String(field.el.value).trim();
            field.el.setCustomValidity(empty ? field.message : '');
        }

        fields.forEach(function (field) {
            if (!field.el) return;
            field.el.addEventListener('input', function () { syncValidity(field); });
            field.el.addEventListener('change', function () { syncValidity(field); });
            field.el.addEventListener('invalid', function () { syncValidity(field); });
        });

        form.addEventListener('submit', function (e) {
            var firstInvalid = null;

            fields.forEach(function (field) {
                syncValidity(field);
                if (!field.el || field.el.disabled || firstInvalid) return;
                if (!field.el.checkValidity()) {
                    firstInvalid = field.el;
                }
            });

            if (firstInvalid) {
                e.preventDefault();
                firstInvalid.reportValidity();
            }
        });
    }

    bindRequiredFields(
        document.getElementById('pa-manual-property-form'),
        manualPropertyFields
    );

    var continueForm = document.getElementById('paPropertiesContinueForm');
    var manualForm = document.getElementById('pa-manual-property-form');
    if (continueForm && manualForm) {
        continueForm.addEventListener('submit', function (e) {
            if (!isManualDraftStarted(manualForm)) {
                return;
            }

            syncContinueHiddenFields(manualForm, continueForm);

            if (!validateManualPropertyForm(manualForm)) {
                e.preventDefault();
            }
        });
    }
})();
</script>
