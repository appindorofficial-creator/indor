@model IndorMvcApp.ViewModels.PropertyAdministratorPropertiesStepViewModel
@{
    if (Model.IsRegistrationComplete)
    {
        Layout = "_PropertyAdminLayout";
        ViewData["Title"] = "Add property";
        ViewBag.NavActive = "properties";
    }
    else
    {
        ViewData["StepFormId"] = "paPropertiesContinueForm";
        ViewData["StepBackUrl"] = Model.BackUrl;
        ViewData["StepSubmitLabel"] = "Next";
        ViewData["StepSubmitFormNoValidate"] = true;
    }
}

@if (Model.IsRegistrationComplete)
{
    <div class="pa-portal-shell pa-portal-shell--portfolio">
        <header class="pa-portfolio-page-header">
            <a href="@Model.DoneUrl" class="pa-profile-back" aria-label="Back">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="pa-portfolio-page-header-text">
                <h1>@Model.Title</h1>
                <p>@Model.Subtitle</p>
            </div>
        </header>
        <div class="pa-portfolio-add-content">
            @await Html.PartialAsync("_PropertyAdminPropertiesBody", Model)
            <div class="pa-reg-actions">
                <a href="@Model.DoneUrl" class="ob-btn ob-btn-primary">Done</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="ob-head-block">
        <h1>@Model.Title</h1>
        <p>@Model.Subtitle</p>
        <p class="pa-step-hint">You can add properties now or skip and add them later from your dashboard.</p>
    </div>

    @await Html.PartialAsync("_PropertyAdminPropertiesBody", Model)

    <form asp-action="ContinueFromProperties" method="post" id="paPropertiesContinueForm">
        @Html.AntiForgeryToken()
    </form>

    @await Html.PartialAsync("_PropertyAdminStepActions")
}

@await Html.PartialAsync("_AddressAutocompleteScripts")

<script>
(function () {
    function bindFilePickers() {
        document.querySelectorAll('.pa-file-picker-input').forEach(function (input) {
            var label = document.querySelector('[data-pa-file-name-for="' + input.id + '"]');
            var clearBtn = document.querySelector('[data-pa-file-clear-for="' + input.id + '"]');
            var emptyLabel = input.getAttribute('data-empty-label') || 'No file selected';

            function syncName() {
                var file = input.files && input.files[0];
                if (label) {
                    label.textContent = file ? file.name : emptyLabel;
                    label.classList.toggle('is-selected', !!file);
                }
                if (clearBtn) {
                    clearBtn.hidden = !file;
                }
            }

            input.addEventListener('change', syncName);
            if (clearBtn) {
                clearBtn.addEventListener('click', function () {
                    input.value = '';
                    syncName();
                    input.dispatchEvent(new Event('change', { bubbles: true }));
                });
            }
            syncName();
        });
    }

    function disableOtherForms(activeForm) {
        var disabled = [];
        document.querySelectorAll('.pa-properties-step-form').forEach(function (other) {
            if (other === activeForm) return;
            other.querySelectorAll('input, select, textarea, button').forEach(function (el) {
                if (!el.disabled) {
                    el.disabled = true;
                    disabled.push(el);
                }
            });
        });
        return disabled;
    }

    function restoreDisabled(disabled) {
        disabled.forEach(function (el) {
            el.disabled = false;
        });
    }

    function bindRequiredFields(form, fields) {
        if (!form) return;

        function syncValidity(field) {
            if (!field.el || field.el.disabled) return;
            var empty = field.kind === 'file'
                ? !(field.el.files && field.el.files.length)
                : !field.el.value || !String(field.el.value).trim();
            field.el.setCustomValidity(empty ? field.message : '');
        }

        fields.forEach(function (field) {
            if (!field.el) return;
            field.el.addEventListener('input', function () { syncValidity(field); });
            field.el.addEventListener('change', function () { syncValidity(field); });
            field.el.addEventListener('invalid', function () { syncValidity(field); });
        });

        form.addEventListener('submit', function (e) {
            var temporarilyDisabled = disableOtherForms(form);
            var firstInvalid = null;

            fields.forEach(function (field) {
                syncValidity(field);
                if (!field.el || field.el.disabled || firstInvalid) return;
                if (!field.el.checkValidity()) {
                    firstInvalid = field.el;
                }
            });

            if (firstInvalid) {
                e.preventDefault();
                restoreDisabled(temporarilyDisabled);
                firstInvalid.reportValidity();
            }
        });
    }

    bindFilePickers();

    bindRequiredFields(
        document.getElementById('pa-manual-property-form'),
        [
            { el: document.getElementById('pa-prop-house'), message: 'Enter a house number.' },
            { el: document.getElementById('pa-prop-street'), message: 'Enter a street name.' },
            { el: document.getElementById('pa-prop-city'), message: 'Enter a city.' },
            { el: document.getElementById('pa-prop-state'), message: 'Select a state.' },
            { el: document.getElementById('pa-prop-zip'), message: 'Enter a ZIP code.' },
            { el: document.getElementById('pa-prop-type'), message: 'Select a property type.' }
        ]
    );

    bindRequiredFields(
        document.getElementById('pa-import-portfolio-form'),
        [
            { el: document.getElementById('pa-csv-file'), kind: 'file', message: 'Choose a CSV file.' }
        ]
    );

    bindRequiredFields(
        document.getElementById('pa-upload-document-form'),
        [
            { el: document.getElementById('pa-doc-property'), message: 'Select a property.' },
            { el: document.getElementById('pa-document-file'), kind: 'file', message: 'Choose a document to upload.' }
        ]
    );
})();
</script>
