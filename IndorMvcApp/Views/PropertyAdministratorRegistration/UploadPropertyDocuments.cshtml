@model IndorMvcApp.ViewModels.PropertyAdministratorUploadDocumentsViewModel
@{
    if (Model.IsRegistrationComplete)
    {
        Layout = "_PropertyAdminLayout";
        ViewData["Title"] = L["Scan or upload documents"];
        ViewBag.NavActive = "properties";
    }

    var backLabel = Model.IsRegistrationComplete
        || (Model.BackUrl?.Contains("ImportPortfolio", StringComparison.OrdinalIgnoreCase) == true)
        ? L["Back to import portfolio"]
        : L["Back to properties"];
}

@if (Model.IsRegistrationComplete)
{
    <div class="pa-portal-shell pa-portal-shell--portfolio">
        <header class="pa-portfolio-page-header">
            <a href="@Model.BackUrl" class="pa-profile-back" data-smart-back aria-label="@L["Back"]">
                <i class="fas fa-chevron-left"></i>
            </a>
            <div class="pa-portfolio-page-header-text">
                @await Html.PartialAsync("_PropertyAdminRegHead", Model)
            </div>
        </header>
        <div class="pa-portfolio-add-content">
            @await Html.PartialAsync("_UploadPropertyDocumentsBody", Model)
            <div class="pa-reg-actions" style="margin-top:18px;">
                <a href="@Model.BackUrl" class="pa-reg-action-back">@backLabel</a>
            </div>
        </div>
    </div>
}
else
{
    @await Html.PartialAsync("_PropertyAdminRegHead", Model)
    @await Html.PartialAsync("_UploadPropertyDocumentsBody", Model)
    <div class="pa-reg-actions" style="margin-top:18px;">
        <a href="@Model.BackUrl" class="pa-reg-action-back">@backLabel</a>
    </div>
}

@section Scripts {
<script>
    (function () {
        const input = document.getElementById('documentFiles');
        const nameEl = document.getElementById('documentFilesName');
        const picker = document.getElementById('documentFilesPicker');
        const listEl = document.getElementById('documentFilesList');
        if (!input || !nameEl || !picker || !listEl) return;

        const emptyLabel = nameEl.dataset.emptyLabel || 'No files selected';
        const removeLabel = listEl.dataset.removeLabel || 'Remove file';
        let selectedFiles = [];

        function syncInputFromSelection() {
            if (typeof DataTransfer === 'undefined') {
                if (selectedFiles.length === 0) {
                    input.value = '';
                }
                return;
            }
            const dt = new DataTransfer();
            selectedFiles.forEach(function (file) { dt.items.add(file); });
            input.files = dt.files;
        }

        function renderStagedFiles() {
            listEl.innerHTML = '';
            if (selectedFiles.length === 0) {
                nameEl.textContent = emptyLabel;
                nameEl.classList.remove('is-selected');
                nameEl.hidden = false;
                picker.classList.remove('has-file');
                listEl.hidden = true;
                return;
            }

            nameEl.hidden = true;
            nameEl.classList.add('is-selected');
            picker.classList.add('has-file');
            listEl.hidden = false;

            selectedFiles.forEach(function (file, index) {
                const row = document.createElement('div');
                row.className = 'pa-check-item pa-check-item--file pa-staged-file';

                const label = document.createElement('span');
                label.className = 'pa-check-item-label';
                label.innerHTML = '<i class="fas fa-file" aria-hidden="true"></i> ';
                label.appendChild(document.createTextNode(file.name));

                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'pa-file-remove-btn';
                removeBtn.setAttribute('aria-label', removeLabel + ': ' + file.name);
                removeBtn.title = removeLabel;
                removeBtn.innerHTML = '<i class="fas fa-xmark" aria-hidden="true"></i>';
                removeBtn.addEventListener('click', function () {
                    selectedFiles.splice(index, 1);
                    syncInputFromSelection();
                    renderStagedFiles();
                });

                row.appendChild(label);
                row.appendChild(removeBtn);
                listEl.appendChild(row);
            });
        }

        input.addEventListener('change', function () {
            selectedFiles = input.files ? Array.from(input.files) : [];
            renderStagedFiles();
        });

        renderStagedFiles();
    })();
</script>
}
