@model IndorMvcApp.ViewModels.PropertyAdministratorRegistrationStepViewModel
@{
    var s = Model.State;
}
@await Html.PartialAsync("_PropertyAdminRegHead", Model)

<form asp-action="Profile" method="post" id="paProfileForm" class="pa-validate" novalidate>
    @Html.AntiForgeryToken()
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="pa-summary-error" role="alert">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@UiDisplayLocalization.Localize(L, error.ErrorMessage)</div>
            }
        </div>
    }

    <div class="pa-field pa-field-readonly">
        <i class="fas fa-user"></i>
        <span>@s.DisplayName</span>
    </div>
    <div class="pa-field pa-field-readonly">
        <i class="fas fa-envelope"></i>
        <span>@s.Email</span>
    </div>
    @if (!string.IsNullOrWhiteSpace(s.Phone))
    {
        <div class="pa-field pa-field-readonly">
            <i class="fas fa-phone"></i>
            <span>@s.Phone</span>
        </div>
    }

    <label class="pa-field">
        <i class="fas fa-building"></i>
        <input type="text" name="portfolioBusinessName" value="@s.PortfolioBusinessName" placeholder="@L["Portfolio / business name (optional)"]" />
    </label>

    <label class="pa-terms">
        <input type="hidden" name="termsAccepted" value="false" />
        <input type="checkbox" name="termsAccepted" value="true" @(s.TermsAccepted ? "checked" : null) data-pa-required="true" data-field-label="the Terms" />
        <span>@L["I agree to the"] <a asp-controller="Account" asp-action="Terms">@L["Terms"]</a></span>
    </label>
    @if (ViewData.ModelState.TryGetValue("termsAccepted", out var termsState) && termsState.Errors.Count > 0)
    {
        <div class="pa-inline-error" role="alert">@UiDisplayLocalization.Localize(L, termsState.Errors[0].ErrorMessage)</div>
    }

    <label class="pa-terms">
        <input type="hidden" name="marketingOptIn" value="false" />
        <input type="checkbox" name="marketingOptIn" value="true" @(s.MarketingOptIn ? "checked" : null) />
        <span>@L["Send me product updates and tips"]</span>
    </label>

</form>

@{
    ViewData["StepFormId"] = "paProfileForm";
    ViewData["StepBackUrl"] = Model.BackUrl;
    ViewData["StepSubmitLabel"] = "Next";
}
@await Html.PartialAsync("_PropertyAdminStepActions")

@section Scripts {
    @await Html.PartialAsync("_PropertyAdminStepValidation")
}
