@model IndorMvcApp.ViewModels.PropertyAdministratorRegistrationStepViewModel
@{
    var s = Model.State;
}
@await Html.PartialAsync("_PropertyAdminRegHead", Model)

<form asp-action="Tools" method="post" id="toolsForm">
    @Html.AntiForgeryToken()

    <div class="pa-tool-grid">
        <label class="pa-tool-card @(s.ToolMaintenanceRequests ? "is-selected" : "")">
            <input type="checkbox" name="toolMaintenanceRequests" value="true" @(s.ToolMaintenanceRequests ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-wrench"></i>
            <strong>@L["Maintenance requests"]</strong>
            <small>@L["Track and resolve issues"]</small>
        </label>
        <label class="pa-tool-card @(s.ToolTurnoverCleaning ? "is-selected" : "")">
            <input type="checkbox" name="toolTurnoverCleaning" value="true" @(s.ToolTurnoverCleaning ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-wand-magic-sparkles"></i>
            <strong>@L["Turnover & cleaning"]</strong>
            <small>@L["Manage cleanings and turnovers"]</small>
        </label>
        <label class="pa-tool-card @(s.ToolGuestMessaging ? "is-selected" : "")">
            <input type="checkbox" name="toolGuestMessaging" value="true" @(s.ToolGuestMessaging ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-comment-dots"></i>
            <strong>@L["Guest/tenant messaging"]</strong>
            <small>@L["Communicate in one place"]</small>
        </label>
        <label class="pa-tool-card @(s.ToolInvoicesPayments ? "is-selected" : "")">
            <input type="checkbox" name="toolInvoicesPayments" value="true" @(s.ToolInvoicesPayments ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-file-invoice-dollar"></i>
            <strong>@L["Invoices & payments"]</strong>
            <small>@L["Create and collect payments"]</small>
        </label>
        <label class="pa-tool-card @(s.ToolDocumentsWarranties ? "is-selected" : "")">
            <input type="checkbox" name="toolDocumentsWarranties" value="true" @(s.ToolDocumentsWarranties ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-folder-open"></i>
            <strong>@L["Documents & warranties"]</strong>
            <small>@L["Store important documents"]</small>
        </label>
        <label class="pa-tool-card @(s.ToolServiceProviders ? "is-selected" : "")">
            <input type="checkbox" name="toolServiceProviders" value="true" @(s.ToolServiceProviders ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-user-gear"></i>
            <strong>@L["Service providers"]</strong>
            <small>@L["Manage vendors and contracts"]</small>
        </label>
        <label class="pa-tool-card wide @(s.ToolTeamAccess ? "is-selected" : "")">
            <input type="checkbox" name="toolTeamAccess" value="true" @(s.ToolTeamAccess ? "checked" : null) />
            <span class="pa-check"><i class="fas fa-check"></i></span>
            <i class="fas fa-users"></i>
            <strong>@L["Team access"]</strong>
            <small>@L["Invite and manage your team"]</small>
        </label>
    </div>

    <p class="pa-notify-title">@L["NOTIFICATION PREFERENCES"]</p>
    <div class="pa-review-card" style="padding:4px 16px;">
        <div class="pa-toggle-row">
            <div class="left"><i class="fas fa-bell"></i> @L["Urgent maintenance alerts"]</div>
            <label class="pa-switch">
                <input type="checkbox" name="notifyUrgentMaintenance" value="true" @(s.NotifyUrgentMaintenance ? "checked" : null) />
                <span></span>
            </label>
        </div>
        <div class="pa-toggle-row">
            <div class="left"><i class="fas fa-calendar-week"></i> @L["Weekly portfolio summary"]</div>
            <label class="pa-switch">
                <input type="checkbox" name="notifyWeeklySummary" value="true" @(s.NotifyWeeklySummary ? "checked" : null) />
                <span></span>
            </label>
        </div>
        <div class="pa-toggle-row">
            <div class="left"><i class="fas fa-envelope"></i> @L["Booking or lease updates"]</div>
            <label class="pa-switch">
                <input type="checkbox" name="notifyBookingLeaseUpdates" value="true" @(s.NotifyBookingLeaseUpdates ? "checked" : null) />
                <span></span>
            </label>
        </div>
    </div>

</form>

@{
    ViewData["StepFormId"] = "toolsForm";
    ViewData["StepBackUrl"] = Model.BackUrl;
    ViewData["StepSubmitLabel"] = "Next";
}
@await Html.PartialAsync("_PropertyAdminStepActions")

@section Scripts {
<script>
    document.querySelectorAll('.pa-tool-card').forEach(card => {
        const input = card.querySelector('input[type="checkbox"]');
        if (!input) return;

        const sync = () => card.classList.toggle('is-selected', input.checked);
        sync();
        input.addEventListener('change', sync);
    });
</script>
}
