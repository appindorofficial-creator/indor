@model IndorMvcApp.ViewModels.PropertyAdministratorPropertiesStepViewModel
@using IndorMvcApp.Models
@{
    var draft = Model.DraftProperty;
    var s = Model.State;
    var defaultCity = "";
    var defaultState = "";
    if (!string.IsNullOrWhiteSpace(s.PrimaryMarket) && !string.Equals(s.PrimaryMarket, "Other", StringComparison.OrdinalIgnoreCase))
    {
        var marketParts = s.PrimaryMarket.Split(',', 2, StringSplitOptions.TrimEntries);
        if (marketParts.Length == 2)
        {
            defaultCity = marketParts[0];
            defaultState = marketParts[1];
        }
    }

    var formHouseNumber = draft?.HouseNumber ?? "";
    var formStreetName = draft?.StreetName ?? "";
    var formCity = !string.IsNullOrWhiteSpace(draft?.City) ? draft!.City : defaultCity;
    var formState = !string.IsNullOrWhiteSpace(draft?.State) ? draft!.State : defaultState;
    var formZipCode = draft?.ZipCode ?? "";
    var formPropertyType = draft?.PropertyType ?? "";
    var formNickname = draft?.PropertyName ?? "";
}

@if (!string.IsNullOrWhiteSpace(Model.FormError))
{
    <div class="pa-summary-error">@Model.FormError</div>
}
else if (TempData["PropertyAdminError"] is string err)
{
    <div class="pa-summary-error">@err</div>
}

@if (!string.IsNullOrWhiteSpace(Model.FormSuccess))
{
    <div class="pa-summary-success">@Model.FormSuccess</div>
}

@if (Model.ImportErrors.Count > 0)
{
    <div class="pa-summary-warning">
        <strong>Some rows were skipped:</strong>
        <ul class="pa-summary-warning-list">
            @foreach (var importError in Model.ImportErrors)
            {
                <li>@importError</li>
            }
        </ul>
    </div>
}

@foreach (var property in Model.Properties)
{
    <div class="pa-property-card">
        <img src="@(property.ImageUrl ?? "/inspeccion2.jpeg")" alt="" class="pa-property-thumb" />
        <div class="pa-property-body">
            <strong>@property.PropertyName</strong>
            <small>@property.Location</small>
            <div class="pa-badge-row">
                <span class="pa-badge pa-badge-type"><i class="fas fa-building"></i> @property.PropertyTypeLabel</span>
                <span class="pa-badge pa-badge-added"><i class="fas fa-check"></i> Added</span>
            </div>
        </div>
        <form asp-action="RemoveProperty" method="post" style="align-self:flex-start;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@property.Id" />
            <button type="submit" class="ob-nav-back" aria-label="Remove" style="width:32px;height:32px;font-size:.8rem;"><i class="fas fa-times"></i></button>
        </form>
    </div>
}

<details class="pa-add-property-panel" @(Model.Properties.Count == 0 || draft != null ? "open" : null)>
    <summary class="pa-add-property-summary">
        <span><i class="fas fa-house"></i> Add property manually</span>
        <i class="fas fa-chevron-up"></i>
    </summary>
    <form asp-action="AddProperty" method="post" id="pa-manual-property-form" class="pa-add-property-form pa-properties-step-form"
          data-pa-default-city="@defaultCity"
          data-pa-default-state="@defaultState">
        @Html.AntiForgeryToken()

        <div class="pa-field-row pa-field-row--2">
            <label class="pa-field">
                <i class="fas fa-hashtag"></i>
                <input type="text"
                       id="pa-prop-house"
                       name="houseNumber"
                       value="@formHouseNumber"
                       placeholder="House number"
                       inputmode="numeric"
                       required
                       autocomplete="address-line2" />
            </label>
            <label class="pa-field">
                <i class="fas fa-road"></i>
                <input type="text"
                       id="pa-prop-street"
                       name="streetName"
                       value="@formStreetName"
                       placeholder="Street name"
                       autocomplete="off"
                       required
                       data-address-autocomplete
                       data-ac-street-only="true"
                       data-ac-house-number="pa-prop-house"
                       data-ac-city="pa-prop-city"
                       data-ac-state="pa-prop-state"
                       data-ac-zip="pa-prop-zip" />
            </label>
        </div>

        <div class="pa-field-row">
            <label class="pa-field">
                <i class="fas fa-city"></i>
                <input type="text"
                       id="pa-prop-city"
                       name="city"
                       value="@formCity"
                       placeholder="City"
                       autocomplete="off"
                       required
                       data-city-autocomplete
                       data-ac-state="pa-prop-state"
                       data-ac-zip="pa-prop-zip" />
            </label>
        </div>

        <div class="pa-field-row pa-field-row--2 pa-field-row--state-zip">
            <label class="pa-field pa-field--compact">
                <i class="fas fa-map"></i>
                <select id="pa-prop-state"
                        name="state"
                        required
                        data-ac-zip="pa-prop-zip"
                        data-ac-city="pa-prop-city"
                        aria-label="State">
                    @if (string.IsNullOrWhiteSpace(formState))
                    {
                        <option value="" disabled selected>State</option>
                    }
                    else
                    {
                        <option value="" disabled>State</option>
                    }
                    @foreach (var stateCode in PropertyAdministratorCatalog.UsStateCodes)
                    {
                        if (formState == stateCode)
                        {
                            <option value="@stateCode" selected="selected">@stateCode</option>
                        }
                        else
                        {
                            <option value="@stateCode">@stateCode</option>
                        }
                    }
                </select>
            </label>
            <label class="pa-field pa-field--compact">
                <i class="fas fa-location-dot"></i>
                <input type="text"
                       id="pa-prop-zip"
                       name="zipCode"
                       value="@formZipCode"
                       placeholder="ZIP code"
                       inputmode="numeric"
                       autocomplete="postal-code"
                       maxlength="10"
                       data-zip-input
                       data-zip-required="true"
                       aria-label="ZIP code"
                       required />
            </label>
        </div>
        <p class="pa-form-hint" data-ac-zip-hint-for="pa-prop-zip" hidden>
            ZIP was filled from your address. You can edit it if needed.
        </p>

        <label class="pa-field">
            <i class="fas fa-tag"></i>
            <select id="pa-prop-type" name="propertyType" required>
                @if (string.IsNullOrWhiteSpace(formPropertyType))
                {
                    <option value="" disabled selected hidden>Property type</option>
                }
                else
                {
                    <option value="" disabled hidden>Property type</option>
                }
                @foreach (var item in PropertyAdministratorCatalog.PropertyTypes)
                {
                    if (formPropertyType == item.Value)
                    {
                        <option value="@item.Value" selected="selected">@item.Label</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Label</option>
                    }
                }
            </select>
        </label>

        <label class="pa-field">
            <i class="fas fa-pen"></i>
            <input type="text" name="propertyNickname" value="@formNickname" placeholder="Property nickname (optional)" />
        </label>

        <button type="submit" class="ob-btn ob-btn-outline pa-save-property-btn">Save property</button>
    </form>
</details>

<a asp-action="ImportPortfolio" class="pa-action-row pa-action-row--property-option">
    <span><i class="fas fa-file-import"></i> Import portfolio</span>
    <i class="fas fa-chevron-right"></i>
</a>
<a asp-action="UploadPropertyDocuments" class="pa-action-row pa-action-row--property-option">
    <span><i class="fas fa-file-lines"></i> Scan or upload documents</span>
    <i class="fas fa-chevron-right"></i>
</a>
