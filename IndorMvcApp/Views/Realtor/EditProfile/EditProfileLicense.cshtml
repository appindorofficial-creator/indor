@model IndorMvcApp.ViewModels.RealtorEditProfileLicenseViewModel
@{
    ViewData["Title"] = L["License & Professional Details"];
}

@if (TempData["EditProfileError"] is string editProfileError && !string.IsNullOrWhiteSpace(editProfileError))
{
    <div class="rl-error-banner" role="alert">
        <i class="fas fa-triangle-exclamation"></i>
        <span>@editProfileError</span>
    </div>
}

<form asp-action="EditProfileLicense" method="post" enctype="multipart/form-data" class="rl-ep-form" id="rlEditProfileLicenseForm" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary"></div>

    <div class="rl-ep-form-card">
        <div class="rl-ep-field-grid-2">
            <label class="rl-ep-field rl-ep-field--stacked">
                <span>@L["License Number"] <span class="rl-required" aria-hidden="true">*</span></span>
                <input asp-for="LicenseNumber" id="LicenseNumber" placeholder="@L["SL3456789"]" autocomplete="off" aria-required="true" />
            </label>
            <label class="rl-ep-field rl-ep-field--stacked">
                <span>@L["State"] <span class="rl-required" aria-hidden="true">*</span></span>
                <select asp-for="LicenseState" aria-required="true">
                    <option value="">@L["Select state"]</option>
                    @foreach (var st in Model.LicenseStates)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </label>
        </div>
        <span asp-validation-for="LicenseNumber" class="rl-field-error"></span>
        <span asp-validation-for="LicenseState" class="rl-field-error"></span>

        <label class="rl-ep-field rl-ep-field--stacked">
            <span>@L["Years of Experience"] <span class="rl-required" aria-hidden="true">*</span></span>
            <select asp-for="YearsOfExperience" aria-required="true">
                <option value="">@L["Select experience"]</option>
                @foreach (var level in Model.ExperienceOptions)
                {
                    <option value="@level">@level</option>
                }
            </select>
        </label>
        <span asp-validation-for="YearsOfExperience" class="rl-field-error"></span>

        <div class="rl-ep-specialties" id="rlSpecialtiesBlock">
            <span class="rl-ep-specialties-label">@L["Specialties"] <span class="rl-required" aria-hidden="true">*</span> <small>@L["(select up to 3)"]</small></span>
            <div class="rl-ep-specialty-chips">
                @foreach (var specialty in Model.SpecialtyOptions)
                {
                    var selected = Model.SelectedSpecialties.Contains(specialty, StringComparer.OrdinalIgnoreCase);
                    <label class="rl-ep-specialty-chip @(selected ? "is-selected" : "")">
                        <input type="checkbox"
                               name="selectedSpecialties"
                               value="@specialty"
                               @(selected ? "checked" : null)
                               class="rl-ep-specialty-input" />
                        @if (selected)
                        {
                            <i class="fas fa-check"></i>
                        }
                        @specialty
                    </label>
                }
            </div>
            <span asp-validation-for="SelectedSpecialties" class="rl-field-error" id="rlSpecialtiesError"></span>
        </div>

        <label class="rl-ep-field rl-ep-field--stacked">
            <span>@L["Team Name (Optional)"]</span>
            <input asp-for="TeamName" placeholder="@L["Team name"]" />
        </label>

        <label class="rl-ep-field rl-ep-field--stacked">
            <span>@L["Broker-in-Charge (Optional)"]</span>
            <input asp-for="BrokerInCharge" placeholder="@L["Broker-in-charge"]" />
        </label>
    </div>

    @if (Model.VerificationItems.Count > 0)
    {
        <div class="rl-ep-verification-list">
            @foreach (var item in Model.VerificationItems)
            {
                <div class="rl-ep-verification-item @(item.IsVerified ? "is-verified" : "")">
                    <span class="rl-ep-verification-icon">
                        <i class="fas @(item.IsVerified ? "fa-circle-check" : "fa-circle")"></i>
                    </span>
                    <span>@item.Label</span>
                    @if (item.IsVerified)
                    {
                        <span class="rl-ep-verification-badge">@L["Verified"]</span>
                    }
                </div>
            }
        </div>
    }

    <div class="rl-ep-upload-card">
        <div class="rl-ep-upload-copy">
            <i class="fas fa-cloud-arrow-up"></i>
            <div>
                <strong>@L["Upload License Documents"]</strong>
                <p>@L["Upload a clear photo or PDF of your real estate license."]</p>
                <small>@L["JPG, PNG or PDF · Max size 10MB"]</small>
            </div>
        </div>
        <label class="rl-ep-upload-btn">
            @L["Upload"]
            <input type="file" id="licensePhotoFile" name="licensePhotoFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" />
        </label>
        @{
            var licenseSlot = Model.DocumentSlots.FirstOrDefault(d => d.DocumentType == IndorMvcApp.Models.RealtorDocumentTypes.LicensePhoto);
        }
        @if (licenseSlot?.Uploaded == true && !string.IsNullOrWhiteSpace(licenseSlot.FileUrl))
        {
            <p class="rl-ep-upload-status"><i class="fas fa-circle-check"></i> @L["License document on file"]</p>
        }
    </div>

    <footer class="rl-ep-footer">
        <button type="submit" class="rl-ep-btn-primary">@L["Save &amp; Continue"]</button>
    </footer>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/realtor-license-number.js" asp-append-version="true"></script>
    <script src="~/js/realtor-edit-profile.js" asp-append-version="true"></script>
    <script>
        (function () {
            var form = document.getElementById('rlEditProfileLicenseForm');
            var licenseInput = document.getElementById('LicenseNumber');
            var stateInput = document.getElementById('LicenseState');
            var experienceInput = document.getElementById('YearsOfExperience');
            var licenseErrorEl = document.querySelector('[data-valmsg-for="LicenseNumber"]');
            var stateErrorEl = document.querySelector('[data-valmsg-for="LicenseState"]');
            var experienceErrorEl = document.querySelector('[data-valmsg-for="YearsOfExperience"]');
            var specialtiesErrorEl = document.getElementById('rlSpecialtiesError');
            var specialtiesBlock = document.getElementById('rlSpecialtiesBlock');

            function setInlineError(errorEl, field, message) {
                if (errorEl) {
                    errorEl.textContent = message || '';
                    errorEl.classList.toggle('field-validation-error', !!message);
                    errorEl.classList.toggle('field-validation-valid', !message);
                }
                if (field) {
                    field.classList.toggle('input-validation-error', !!message);
                    field.closest('.rl-ep-field')?.classList.toggle('is-error', !!message);
                }
                return !!message;
            }

            function setSpecialtiesError(message) {
                if (specialtiesErrorEl) {
                    specialtiesErrorEl.textContent = message || '';
                }
                if (specialtiesBlock) {
                    specialtiesBlock.classList.toggle('is-error', !!message);
                }
                return !!message;
            }

            function scrollToFirstError() {
                var firstError = form?.querySelector('.field-validation-error:not(:empty), .rl-field-error:not(:empty)');
                var target = firstError
                    || form?.querySelector('.rl-ep-field.is-error input, .rl-ep-field.is-error select')
                    || (specialtiesBlock?.classList.contains('is-error') ? specialtiesBlock : null);
                if (target) {
                    (target.closest('.rl-ep-field') || target).scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }

            if (licenseInput && window.IndorRealtorLicense) {
                window.IndorRealtorLicense.attach(licenseInput, {
                    errorEl: licenseErrorEl,
                    validateOnLoad: false
                });
            }

            [licenseInput, stateInput, experienceInput].forEach(function (input) {
                if (!input) {
                    return;
                }
                input.addEventListener('input', function () {
                    if (input === licenseInput) {
                        setInlineError(licenseErrorEl, licenseInput, '');
                    } else if (input === stateInput) {
                        setInlineError(stateErrorEl, stateInput, '');
                    } else {
                        setInlineError(experienceErrorEl, experienceInput, '');
                    }
                });
                input.addEventListener('change', function () {
                    if (input === stateInput) {
                        setInlineError(stateErrorEl, stateInput, '');
                    } else if (input === experienceInput) {
                        setInlineError(experienceErrorEl, experienceInput, '');
                    }
                });
            });

            document.querySelectorAll('.rl-ep-specialty-input').forEach(function (input) {
                input.addEventListener('change', function () {
                    if (document.querySelectorAll('.rl-ep-specialty-input:checked').length > 0) {
                        setSpecialtiesError('');
                    }
                });
            });

            scrollToFirstError();

            if (!form) {
                return;
            }

            form.addEventListener('submit', function (e) {
                var hasError = false;
                setInlineError(licenseErrorEl, licenseInput, '');
                setInlineError(stateErrorEl, stateInput, '');
                setInlineError(experienceErrorEl, experienceInput, '');
                setSpecialtiesError('');

                var licenseMessage = window.IndorRealtorLicense && licenseInput
                    ? window.IndorRealtorLicense.validate(licenseInput.value)
                    : '';
                if (licenseMessage) {
                    hasError = setInlineError(licenseErrorEl, licenseInput, licenseMessage) || hasError;
                }

                if (stateInput && !stateInput.value.trim()) {
                    hasError = setInlineError(stateErrorEl, stateInput, 'License state is required.') || hasError;
                }

                if (experienceInput && !experienceInput.value.trim()) {
                    hasError = setInlineError(experienceErrorEl, experienceInput, 'Years of experience is required.') || hasError;
                }

                if (!document.querySelectorAll('.rl-ep-specialty-input:checked').length) {
                    hasError = setSpecialtiesError('Select at least one specialty.') || hasError;
                }

                var fileInput = document.getElementById('licensePhotoFile');
                if (fileInput && (!fileInput.files || !fileInput.files.length)) {
                    fileInput.removeAttribute('name');
                }

                if (hasError) {
                    e.preventDefault();
                    scrollToFirstError();
                }
            });
        })();
    </script>
}
