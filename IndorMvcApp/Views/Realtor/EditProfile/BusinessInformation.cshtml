@model IndorMvcApp.ViewModels.RealtorBusinessInformationViewModel
@{
    ViewData["Title"] = L["Business Information"];
    ViewBag.NavActive = "profile";
}

<div id="rlBusinessPhotoAlerts">
@if (TempData["ProfilePhotoOk"] is string photoOk)
{
    <div class="rl-profile-photo-alert rl-profile-photo-alert--success" role="status">@photoOk</div>
}
@if (TempData["ProfilePhotoError"] is string photoError)
{
    <div class="rl-profile-photo-alert rl-profile-photo-alert--error" role="alert">@photoError</div>
}
</div>

<section class="rl-ep-photo-card">
    <h2>@L["Profile photo"]</h2>
    <p>@L["Upload a photo. It will appear on your realtor profile."]</p>
    <form asp-controller="Realtor" asp-action="UploadProfilePhoto" method="post" enctype="multipart/form-data" id="rlBusinessPhotoForm">
        @Html.AntiForgeryToken()
        <div class="rl-ep-photo-row">
            <div class="rl-profile-photo-wrap rl-ep-photo-preview">
                <div class="rl-profile-photo-preview" id="rlBusinessPhotoPreview">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                    {
                        <img src="@Model.ProfilePhotoUrl" alt="" class="rl-profile-photo" id="rlBusinessPhotoImg" />
                        <span class="rl-profile-photo rl-profile-photo--placeholder" id="rlBusinessPhotoPlaceholder" hidden><i class="fas fa-user"></i></span>
                    }
                    else
                    {
                        <span class="rl-profile-photo rl-profile-photo--placeholder" id="rlBusinessPhotoPlaceholder"><i class="fas fa-user"></i></span>
                        <img src="" alt="" class="rl-profile-photo" id="rlBusinessPhotoImg" hidden />
                    }
                </div>
                <button type="button" class="rl-profile-photo-edit" id="rlBusinessPhotoBtn" aria-label="@L["Change profile photo"]" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-camera"></i>
                </button>
            </div>
            <div class="rl-ep-photo-actions">
                <button type="button" class="rl-profile-photo-change-btn" id="rlBusinessPhotoChangeBtn" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-camera"></i> @L["Change photo"]
                </button>
                <div class="rl-profile-photo-menu" id="rlBusinessPhotoMenu" role="menu" hidden>
                    <button type="button" class="rl-profile-photo-menu-item" id="rlBusinessPhotoTake" role="menuitem">
                        <i class="fas fa-camera"></i> @L["Take photo"]
                    </button>
                    <button type="button" class="rl-profile-photo-menu-item" id="rlBusinessPhotoChoose" role="menuitem">
                        <i class="fas fa-image"></i> @L["Choose from library"]
                    </button>
                </div>
                <input type="file" id="rlBusinessPhotoCamera" name="photo" accept="image/*" capture="environment" class="rl-profile-photo-input" />
                <input type="file" id="rlBusinessPhotoLibrary" name="photo" accept="image/jpeg,image/png,image/webp,image/*" class="rl-profile-photo-input" />
                <small class="rl-ep-photo-hint">@L["JPG, PNG or WEBP · Max 10 MB"]</small>
            </div>
        </div>
    </form>
</section>

<section class="rl-ep-progress-card">
    <div class="rl-ep-progress-ring" style="--progress:@Model.ProfileCompletionPercent">
        <span>@Model.ProfileCompletionPercent%</span>
    </div>
    <div class="rl-ep-progress-copy">
        <strong>Profile @Model.ProfileCompletionPercent% complete</strong>
        <p>@L["Complete your business information to build trust and grow your visibility."]</p>
    </div>
    <img src="~/welcome-house.png" alt="" class="rl-ep-progress-art" />
</section>

<nav class="rl-ep-summary-list" aria-label="@L["Business information fields"]">
    @foreach (var row in Model.Rows)
    {
        var rowClass = $"rl-ep-summary-row{(row.IsEmpty ? " is-empty" : "")}";
        if (row.EditUrl != null)
        {
            <a href="@row.EditUrl" class="@rowClass">
                <span class="rl-ep-row-icon"><i class="fas @row.Icon"></i></span>
                <span class="rl-ep-row-body">
                    <span class="rl-ep-row-label">@row.Label</span>
                    @if (row.Key == "license")
                    {
                        <span class="rl-ep-row-value rl-ep-row-value--license">
                            @if (!string.IsNullOrWhiteSpace(row.StatusBadge))
                            {
                                <span class="rl-ep-status @row.StatusCss">@row.StatusBadge</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(row.Value))
                            {
                                <span>@row.Value</span>
                            }
                        </span>
                    }
                    else
                    {
                        <span class="rl-ep-row-value">@row.Value</span>
                    }
                </span>
                <i class="fas fa-chevron-right rl-ep-row-chevron"></i>
            </a>
        }
        else
        {
            <div class="@rowClass">
                <span class="rl-ep-row-icon"><i class="fas @row.Icon"></i></span>
                <span class="rl-ep-row-body">
                    <span class="rl-ep-row-label">@row.Label</span>
                    <span class="rl-ep-row-value">@row.Value</span>
                </span>
            </div>
        }
    }
</nav>

<div class="rl-ep-privacy">
    <i class="fas fa-lock"></i>
    <p>@L["Your phone number stays private. Clients contact you through INDOR messaging."]</p>
</div>

<footer class="rl-ep-footer">
    <a asp-controller="Realtor" asp-action="EditProfileContact" class="rl-ep-btn-primary">@L["Continue"]</a>
</footer>

@section Scripts {
<script src="~/js/profile-photo-upload.js" asp-append-version="true"></script>
}
