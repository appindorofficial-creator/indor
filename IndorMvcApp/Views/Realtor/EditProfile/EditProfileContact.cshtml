@model IndorMvcApp.ViewModels.RealtorEditProfileContactViewModel
@using IndorMvcApp.Models
@{
    ViewData["Title"] = L["Company & Contact Details"];
}

@if (TempData["EditProfileError"] is string editProfileError && !string.IsNullOrWhiteSpace(editProfileError))
{
    <div class="rl-error-banner" role="alert">
        <i class="fas fa-triangle-exclamation"></i>
        <span>@editProfileError</span>
    </div>
}

<form asp-action="EditProfileContact" method="post" class="rl-ep-form" id="rlEditProfileContactForm" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary"></div>

    <div class="rl-ep-form-card">
        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-store"></i></span>
            <label class="rl-ep-field">
                <span>@L["Business Name"] <span class="rl-required" aria-hidden="true">*</span></span>
                <input asp-for="BusinessName" placeholder="@L["Business name"]" autocomplete="organization" aria-required="true" />
            </label>
        </div>
        <span asp-validation-for="BusinessName" class="rl-field-error"></span>

        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-user-group"></i></span>
            <label class="rl-ep-field">
                <span>@L["Display Name (Public)"] <small>@L["(Optional)"]</small></span>
                <input asp-for="PublicDisplayName" placeholder="@L["Public display name"]" />
            </label>
        </div>

        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-building"></i></span>
            <label class="rl-ep-field">
                <span>@L["Brokerage Name"] <span class="rl-required" aria-hidden="true">*</span></span>
                <input asp-for="BrokerageName" placeholder="@L["Brokerage name"]" autocomplete="organization" aria-required="true" />
            </label>
        </div>
        <span asp-validation-for="BrokerageName" class="rl-field-error"></span>

        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-briefcase"></i></span>
            <label class="rl-ep-field">
                <span>@L["Realtor Title"] <small>@L["(Optional)"]</small></span>
                <input asp-for="RealtorTitle" placeholder="@L["Realtor®"]" />
            </label>
        </div>

        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-envelope"></i></span>
            <label class="rl-ep-field">
                <span>@L["Email"] <span class="rl-required" aria-hidden="true">*</span></span>
                <input asp-for="Email" type="email" placeholder="@L["Email"]" autocomplete="email" aria-required="true" />
            </label>
        </div>
        <span asp-validation-for="Email" class="rl-field-error"></span>

        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-globe"></i></span>
            <label class="rl-ep-field">
                <span>@L["Website"] <small>@L["(Optional)"]</small></span>
                <input asp-for="Website" placeholder="@L["www.example.com"]" autocomplete="url" />
            </label>
        </div>

        <div class="rl-ep-field-row">
            <span class="rl-ep-field-icon"><i class="fas fa-location-dot"></i></span>
            <label class="rl-ep-field">
                <span>@L["Office Address"] <small>@L["(Optional)"]</small></span>
                <input asp-for="OfficeAddress"
                       placeholder="@L["123 Business Ave, Suite 101"]"
                       autocomplete="off"
                       data-address-autocomplete
                       data-ac-street-only="true"
                       data-ac-city="OfficeCity"
                       data-ac-state="OfficeState"
                       data-ac-zip="OfficeZip" />
            </label>
        </div>

        <div class="rl-ep-address-grid">
            <label class="rl-ep-field rl-ep-field--compact">
                <span>@L["City"]</span>
                <input asp-for="OfficeCity"
                       placeholder="@L["City"]"
                       autocomplete="off"
                       data-city-autocomplete
                       data-ac-state="OfficeState"
                       data-ac-zip="OfficeZip" />
            </label>
            <label class="rl-ep-field rl-ep-field--compact">
                <span>@L["State"]</span>
                <select asp-for="OfficeState"
                        data-ac-zip="OfficeZip"
                        data-ac-city="OfficeCity"
                        data-ac-address="OfficeAddress">
                    <option value="">@L["State"]</option>
                    @foreach (var st in Model.LicenseStates)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </label>
            <label class="rl-ep-field rl-ep-field--compact">
                <span>@L["ZIP"]</span>
                <input asp-for="OfficeZip"
                       placeholder="@L["ZIP"]"
                       autocomplete="postal-code"
                       maxlength="10"
                       data-zip-input
                       data-zip-required="false" />
            </label>
        </div>
        <span class="rl-field-hint" id="ep-office-zip-hint" data-ac-zip-hint-for="OfficeZip" hidden>@L["Suggested from city and state. Change it if your office uses a different ZIP."]</span>

        <div class="rl-ep-languages" id="rlLanguagesBlock">
            <span class="rl-ep-languages-label">@L["Languages Spoken"] <span class="rl-required" aria-hidden="true">*</span></span>
            <div class="rl-ep-language-chips" id="rlLanguageChips">
                @foreach (var lang in RealtorEditProfileOptions.SupportedLanguages)
                {
                    var isSelected = Model.Languages.Any(l => string.Equals(l, lang, StringComparison.OrdinalIgnoreCase));
                    <button type="button"
                            class="rl-ep-language-chip @(isSelected ? "is-selected" : "")"
                            data-language="@lang"
                            aria-pressed="@(isSelected ? "true" : "false")">
                            <i class="fas fa-globe" aria-hidden="true"></i> @L[lang]
                    </button>
                }
            </div>
            <input type="hidden" asp-for="LanguagesCsv" id="rlLanguagesInput" />
            <span asp-validation-for="LanguagesCsv" class="rl-field-error" id="rlLanguagesError"></span>
        </div>
    </div>

    <div class="rl-ep-privacy">
        <i class="fas fa-lock"></i>
        <p>@L["Your phone number stays private. Clients contact you through INDOR messaging."]</p>
    </div>

    <footer class="rl-ep-footer">
        <button type="submit" class="rl-ep-btn-primary">@L["Save &amp; Continue"]</button>
    </footer>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/zip-input.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_AddressAutocompleteScripts")
    <script src="~/js/realtor-edit-profile.js" asp-append-version="true"></script>
    <script>
        (function () {
            var zipInput = document.getElementById('OfficeZip');
            if (zipInput && window.IndorZipInput) {
                window.IndorZipInput.attach(zipInput, { required: false });
            }

            var form = document.getElementById('rlEditProfileContactForm');
            if (!form) {
                return;
            }

            function setFieldError(fieldName, message) {
                var errorEl = form.querySelector('[data-valmsg-for="' + fieldName + '"]');
                var field = document.getElementById(fieldName);
                if (errorEl) {
                    errorEl.textContent = message || '';
                    errorEl.classList.toggle('field-validation-error', !!message);
                    errorEl.classList.toggle('field-validation-valid', !message);
                }
                if (field) {
                    field.classList.toggle('input-validation-error', !!message);
                    field.closest('.rl-ep-field')?.classList.toggle('is-error', !!message);
                }
                return !!message;
            }

            function scrollToFirstError() {
                var firstError = form.querySelector('.field-validation-error:not(:empty), .rl-field-error:not(:empty)');
                var target = firstError
                    || form.querySelector('.rl-ep-field.is-error input, .rl-ep-field.is-error select')
                    || (document.getElementById('rlLanguagesBlock')?.classList.contains('is-error')
                        ? document.getElementById('rlLanguagesBlock')
                        : null);
                if (target) {
                    (target.closest('.rl-ep-field-row') || target.closest('.rl-ep-field') || target)
                        .scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }

            ['BusinessName', 'BrokerageName', 'Email'].forEach(function (fieldName) {
                var field = document.getElementById(fieldName);
                if (!field) {
                    return;
                }
                field.addEventListener('input', function () {
                    setFieldError(fieldName, '');
                });
            });

            function setLanguagesError(message) {
                var errorEl = document.getElementById('rlLanguagesError');
                var block = document.getElementById('rlLanguagesBlock');
                if (errorEl) {
                    errorEl.textContent = message || '';
                }
                if (block) {
                    block.classList.toggle('is-error', !!message);
                }
                return !!message;
            }

            var languagesChips = document.getElementById('rlLanguageChips');
            if (languagesChips) {
                languagesChips.addEventListener('click', function () {
                    window.setTimeout(function () {
                        setLanguagesError('');
                    }, 0);
                });
            }

            scrollToFirstError();

            form.addEventListener('submit', function (e) {
                var hasError = false;
                setFieldError('BusinessName', '');
                setFieldError('BrokerageName', '');
                setFieldError('Email', '');
                setLanguagesError('');

                var businessName = document.getElementById('BusinessName');
                if (!businessName || !businessName.value.trim()) {
                    hasError = setFieldError('BusinessName', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Business Name is required."].ToString()))) || hasError;
                }

                var brokerageName = document.getElementById('BrokerageName');
                if (!brokerageName || !brokerageName.value.trim()) {
                    hasError = setFieldError('BrokerageName', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Brokerage Name is required."].ToString()))) || hasError;
                }

                var email = document.getElementById('Email');
                if (!email || !email.value.trim()) {
                    hasError = setFieldError('Email', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Email is required."].ToString()))) || hasError;
                } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email.value.trim())) {
                    hasError = setFieldError('Email', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Enter a valid Email address."].ToString()))) || hasError;
                }

                var languagesInput = document.getElementById('rlLanguagesInput');
                if (!languagesInput || !languagesInput.value.trim()) {
                    hasError = setLanguagesError(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Select at least one language."].ToString()))) || hasError;
                }

                if (hasError) {
                    e.preventDefault();
                    scrollToFirstError();
                }
            });
        })();
    </script>
}
