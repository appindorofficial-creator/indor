@using IndorMvcApp.Localization
@{
    var wizardModel = Model as IndorMvcApp.ViewModels.RealtorEditProfileWizardViewModel;
    var pageTitle = wizardModel?.Title ?? ViewData["Title"] as string ?? L["Edit Profile"];
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#0066CC" />
    <title>@pageTitle - INDOR</title>
    @await Html.PartialAsync("_AppVersionHead")
    @await Html.PartialAsync("_RealtorPortalHead")
</head>
<body class="rl-dash-page rl-edit-profile-page">
    <div class="rl-edit-profile-shell">
        @if (wizardModel != null)
        {
            @await Html.PartialAsync("~/Views/Realtor/EditProfile/_EditProfileHeader.cshtml", wizardModel)
        }
        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
