@{
    var wizardModel = Model as IndorMvcApp.ViewModels.RealtorEditProfileWizardViewModel;
    var pageTitle = wizardModel?.Title ?? ViewData["Title"] as string ?? "Edit Profile";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@pageTitle - INDOR</title>
    @await Html.PartialAsync("_AppVersionHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-edit-profile.css" asp-append-version="true" />
    @await Html.PartialAsync("_TabletResponsiveHead")
</head>
<body class="rl-dash-page rl-edit-profile-page">
    <div class="rl-edit-profile-shell">
        @if (wizardModel != null)
        {
            @await Html.PartialAsync("~/Views/Realtor/EditProfile/_EditProfileHeader.cshtml", wizardModel)
        }
        @RenderBody()
    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
