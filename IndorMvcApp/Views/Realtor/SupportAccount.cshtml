@model IndorMvcApp.ViewModels.RealtorPortalShellViewModel
@{
    ViewData["Title"] = L["Support & Account"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "profile";
}

<div class="rl-dash-shell rl-dash-shell--profile">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <header class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Profile" class="rl-network-back" aria-label="@L["Back to profile"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="rl-page-title">@L["Support &amp; Account"]</h1>
            <p class="rl-page-subtitle">@L["Get help and review INDOR policies for realtors."]</p>
        </div>
    </header>

    <nav class="rl-profile-nav">
        <a asp-controller="Account" asp-action="Terms" asp-route-from="realtor-support" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-scale-balanced"></i></span>
            <div>
                <strong>@L["Terms &amp; Conditions"]</strong>
                <span class="rl-profile-nav-desc">@L["Review INDOR platform terms for real estate professionals."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Account" asp-action="Privacy" asp-route-from="realtor-support" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-user-shield"></i></span>
            <div>
                <strong>@L["Privacy Policy"]</strong>
                <span class="rl-profile-nav-desc">@L["How INDOR handles your account and client data."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    <section class="rl-settings-card">
        <div class="rl-settings-head">
            <span><i class="fas fa-headset"></i> @L["Need help?"]</span>
        </div>
        <p class="rl-support-copy">@L["Contact INDOR support at"] <a href="mailto:support@homeindor.com">support@homeindor.com</a>.</p>
    </section>
</div>
