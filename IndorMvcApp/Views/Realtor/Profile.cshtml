@model IndorMvcApp.ViewModels.RealtorProfileViewModel
@{
    ViewData["Title"] = "Profile";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "profile";
    var profileCardController = Model.IsVerified ? "Realtor" : "RealtorRegistration";
    var profileCardAction = Model.IsVerified ? "PublicProfile" : "Verification";
}

<div class="rl-dash-shell rl-dash-shell--profile">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <section class="rl-profile-hero">
        <div class="rl-profile-hero-inner">
            <div class="rl-profile-hero-copy">
                <h1 class="rl-profile-hero-title">Profile</h1>
                <p class="rl-profile-hero-subtitle">Manage your realtor account, branding, and settings.</p>
            </div>
            <div class="rl-profile-hero-visual" aria-hidden="true">
                <i class="fas fa-user rl-profile-hero-icon"></i>
            </div>
        </div>
    </section>

    <section class="rl-profile-card-v2 rl-profile-card-v2--overlap">
        <div id="rlProfilePhotoAlerts">
        @if (TempData["ProfilePhotoOk"] is string photoOk)
        {
            <div class="rl-profile-photo-alert rl-profile-photo-alert--success" role="status">@photoOk</div>
        }
        @if (TempData["ProfilePhotoError"] is string photoError)
        {
            <div class="rl-profile-photo-alert rl-profile-photo-alert--error" role="alert">@photoError</div>
        }
        </div>
        <div class="rl-profile-card-link">
            <form asp-controller="Realtor" asp-action="UploadProfilePhoto" method="post" enctype="multipart/form-data" id="rlProfilePhotoForm">
                @Html.AntiForgeryToken()
                <div class="rl-profile-photo-wrap">
                    <div class="rl-profile-photo-preview" id="rlProfilePhotoPreview">
                        @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                        {
                            <img src="@Model.ProfilePhotoUrl" alt="" class="rl-profile-photo" id="rlProfilePhotoImg" />
                        }
                        else
                        {
                            <span class="rl-profile-photo rl-profile-photo--placeholder" id="rlProfilePhotoPlaceholder"><i class="fas fa-user"></i></span>
                            <img src="" alt="" class="rl-profile-photo" id="rlProfilePhotoImg" hidden />
                        }
                    </div>
                    <button type="button" class="rl-profile-photo-edit" id="rlProfilePhotoBtn" aria-label="Change profile photo" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-camera"></i>
                    </button>
                    <div class="rl-profile-photo-menu" id="rlProfilePhotoMenu" role="menu" hidden>
                        <button type="button" class="rl-profile-photo-menu-item" id="rlProfilePhotoTake" role="menuitem">
                            <i class="fas fa-camera"></i> Take photo
                        </button>
                        <button type="button" class="rl-profile-photo-menu-item" id="rlProfilePhotoChoose" role="menuitem">
                            <i class="fas fa-image"></i> Choose from library
                        </button>
                    </div>
                    <input type="file" id="rlProfilePhotoCamera" name="photo" accept="image/*" capture="environment" hidden />
                    <input type="file" id="rlProfilePhotoLibrary" name="photo" accept="image/jpeg,image/png,image/webp,image/*" hidden />
                    @if (Model.IsVerified)
                    {
                        <span class="rl-profile-photo-badge" aria-label="Verified"><i class="fas fa-circle-check"></i></span>
                    }
                </div>
            </form>
            <a asp-controller="@profileCardController" asp-action="@profileCardAction" class="rl-profile-card-info">
                <strong>@Model.FullName</strong>
                <div class="rl-home-badge-row">
                    <span class="rl-dash-badge @(Model.IsVerified ? "is-verified" : null)">
                        <i class="fas @(Model.IsVerified ? "fa-circle-check" : "fa-star")"></i>
                        @Model.BadgeLabel
                    </span>
                    @if (!Model.IsVerified)
                    {
                        <span class="rl-verify-link">Verify profile <i class="fas fa-chevron-right"></i></span>
                    }
                </div>
            </a>
        </div>
        <div class="rl-profile-stats">
            @foreach (var stat in Model.Stats)
            {
                <div class="rl-profile-stat">
                    <span class="rl-stat-icon rl-stat-icon--@stat.ColorClass"><i class="fas @stat.Icon"></i></span>
                    <strong>@stat.Count</strong>
                    <span>@stat.Label</span>
                </div>
            }
        </div>
    </section>

    <section class="rl-quick-actions rl-quick-actions--profile">
        <a asp-controller="Realtor" asp-action="PublicProfile" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-globe"></i></span>
            <span>Public Profile</span>
        </a>
        <button type="button" class="rl-quick-action" id="rlShareBtn">
            <span class="rl-quick-action-icon"><i class="fas fa-share-from-square"></i></span>
            <span>Share</span>
        </button>
        <a asp-controller="Realtor" asp-action="BusinessInformation" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-gear"></i></span>
            <span>Settings</span>
        </a>
    </section>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="BusinessInformation" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-building"></i></span>
            <div>
                <strong>Business Information</strong>
                <span class="rl-profile-nav-desc">Manage your contact details, brokerage and license.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="EditProfileServiceArea" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-location-dot"></i></span>
            <div>
                <strong>Service Area / Market Area</strong>
                <span class="rl-profile-nav-desc">Define the areas and neighborhoods you serve.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="SharedPackages" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-share-nodes"></i></span>
            <div>
                <strong>Shared Packages</strong>
                <span class="rl-profile-nav-desc">View the packages you've shared with clients.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="SupportAccount" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-shield-halved"></i></span>
            <div>
                <strong>Account Settings</strong>
                <span class="rl-profile-nav-desc">Update your preferences and security settings.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    <section class="rl-bottom-grid">
        <form asp-controller="Realtor" asp-action="ProfileNotificationPreferences" method="post" class="rl-settings-card" id="rl-notify-form">
            @Html.AntiForgeryToken()
            <div class="rl-settings-head">
                <span><i class="fas fa-bell"></i> Notifications</span>
                <small>Choose what updates you want to receive.</small>
            </div>
            @if (Model.NotificationsSaved)
            {
                <div class="rl-notify-saved" role="status">Notification preferences saved.</div>
            }
            <label class="rl-toggle-row">
                <span>Email alerts</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="EmailAlertsEnabled" value="false" />
                    <input type="checkbox" name="EmailAlertsEnabled" value="true" class="rl-notify-checkbox" @(Model.EmailAlertsEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
            <label class="rl-toggle-row">
                <span>Quote updates</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="QuoteUpdatesEnabled" value="false" />
                    <input type="checkbox" name="QuoteUpdatesEnabled" value="true" class="rl-notify-checkbox" @(Model.QuoteUpdatesEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
            <label class="rl-toggle-row">
                <span>Report notifications</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="ReportNotificationsEnabled" value="false" />
                    <input type="checkbox" name="ReportNotificationsEnabled" value="true" class="rl-notify-checkbox" @(Model.ReportNotificationsEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
            <label class="rl-toggle-row">
                <span>Package-view alerts</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="PackageViewAlertsEnabled" value="false" />
                    <input type="checkbox" name="PackageViewAlertsEnabled" value="true" class="rl-notify-checkbox" @(Model.PackageViewAlertsEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
        </form>
        <div class="rl-settings-card">
            <div class="rl-settings-head">
                <span><i class="fas fa-chart-line"></i> Performance Snapshot</span>
                <small>Your activity at a glance.</small>
            </div>
            <div class="rl-perf-row">
                <span>Response Time</span>
                <div>
                    <strong>@Model.ResponseTimeLabel</strong>
                    <span class="rl-perf-good">@Model.ResponseTimeStatus</span>
                </div>
            </div>
            <div class="rl-perf-row">
                <span>Files This Month</span>
                <div>
                    <strong>@Model.FilesThisMonth</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.FilesTrendLabel))
                    {
                        <span class="rl-perf-good">@Model.FilesTrendLabel</span>
                    }
                </div>
            </div>
            <div class="rl-perf-row">
                <span>Client Connections</span>
                <div>
                    <strong>@Model.ClientConnections</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.ClientsTrendLabel))
                    {
                        <span class="rl-perf-good">@Model.ClientsTrendLabel</span>
                    }
                </div>
            </div>
            <div class="rl-perf-details" id="rlPerfDetails" hidden>
                @foreach (var insight in Model.Insights)
                {
                    <div class="rl-perf-insight">
                        <i class="fas @insight.Icon"></i>
                        <span>@insight.Text</span>
                    </div>
                }
            </div>
            <button type="button"
                    class="rl-premium-link"
                    id="rlInsightsToggle"
                    aria-expanded="false"
                    aria-controls="rlPerfDetails">
                <span class="rl-insights-toggle-label">View full insights</span>
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </section>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="Network" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-map-location-dot"></i></span>
            <div>
                <strong>Nearby Network</strong>
                <span class="rl-profile-nav-desc">See listings, leads, providers and open houses within 3 miles.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="ProviderNetwork" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-people-group"></i></span>
            <div>
                <strong>Connected Provider Network</strong>
                <span class="rl-profile-nav-desc">Manage and connect with trusted inspectors and providers.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="SupportAccount" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-headset"></i></span>
            <div>
                <strong>Support &amp; Account</strong>
                <span class="rl-profile-nav-desc">Get help, manage your subscription and account.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    @if (Model.CanUpgradeToVerified)
    {
        <section class="rl-verify-banner rl-verify-banner--compact">
            <i class="fas fa-shield-halved"></i>
            <div>
                <strong>Become a Verified Realtor</strong>
                <p>Upload your license and ID to unlock the Verified Realtor badge.</p>
                <a asp-controller="RealtorRegistration" asp-action="Verification" class="ob-btn ob-btn-primary">Verify now</a>
            </div>
        </section>
    }

    <form asp-controller="Account" asp-action="Logout" method="post" class="rl-signout-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="rl-profile-row rl-profile-row--danger rl-profile-row--center">
            <span><i class="fas fa-right-from-bracket"></i> Sign Out</span>
            <i class="fas fa-chevron-right"></i>
        </button>
    </form>

    <a asp-controller="Account" asp-action="DeleteAccount" class="rl-profile-row rl-profile-row--danger rl-profile-row--center">
        <span><i class="fas fa-user-xmark"></i> Delete account</span>
        <i class="fas fa-chevron-right"></i>
    </a>

    <div class="rl-toast" id="rlToast" role="status" aria-live="polite" hidden></div>
</div>

@section Scripts {
<script>
    (function () {
        var toast = document.getElementById('rlToast');
        var toastTimer = null;
        function showToast(message) {
            if (!toast) {
                return;
            }
            toast.textContent = message;
            toast.hidden = false;
            toast.classList.add('is-visible');
            if (toastTimer) {
                clearTimeout(toastTimer);
            }
            toastTimer = setTimeout(function () {
                toast.classList.remove('is-visible');
                toastTimer = setTimeout(function () { toast.hidden = true; }, 250);
            }, 2400);
        }

        var shareBtn = document.getElementById('rlShareBtn');
        if (shareBtn) {
            var shareUrl = window.location.origin + '@Url.Action("PublicProfile", "Realtor")';
            shareBtn.addEventListener('click', async function () {
                var payload = {
                    title: '@Model.FullName - INDOR',
                    text: 'View my realtor profile on INDOR',
                    url: shareUrl
                };
                if (navigator.share) {
                    try { await navigator.share(payload); return; } catch (_) { }
                }
                try {
                    await navigator.clipboard.writeText(shareUrl);
                    showToast('Profile link copied to clipboard.');
                } catch (_) {
                    window.prompt('Copy profile link:', shareUrl);
                }
            });
        }

        var toggle = document.getElementById('rlInsightsToggle');
        var details = document.getElementById('rlPerfDetails');
        if (toggle && details) {
            var label = toggle.querySelector('.rl-insights-toggle-label');
            toggle.addEventListener('click', function () {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
                details.hidden = expanded;
                if (label) {
                    label.textContent = expanded ? 'View full insights' : 'Hide insights';
                }
            });
        }

        var notifyForm = document.getElementById('rl-notify-form');
        if (!notifyForm) {
            return;
        }

        function syncNotifyToggles() {
            notifyForm.querySelectorAll('.rl-toggle-row').forEach(function (row) {
                var checkbox = row.querySelector('.rl-notify-checkbox');
                var track = row.querySelector('.rl-toggle');
                if (!checkbox || !track) {
                    return;
                }

                track.classList.toggle('is-on', checkbox.checked);
            });
        }

        syncNotifyToggles();

        var savedTimer = null;
        function showNotifySaved() {
            var msg = notifyForm.querySelector('.rl-notify-saved');
            if (!msg) {
                msg = document.createElement('div');
                msg.className = 'rl-notify-saved';
                msg.setAttribute('role', 'status');
                var head = notifyForm.querySelector('.rl-settings-head');
                if (head) {
                    head.insertAdjacentElement('afterend', msg);
                } else {
                    notifyForm.prepend(msg);
                }
            }
            msg.textContent = 'Notification preferences saved.';
            msg.hidden = false;
            if (savedTimer) {
                clearTimeout(savedTimer);
            }
            savedTimer = setTimeout(function () { msg.hidden = true; }, 2000);
        }

        function saveNotifyPreferences() {
            // Save in the background so the page doesn't reload and jump to the top.
            fetch(notifyForm.action, {
                method: 'POST',
                body: new FormData(notifyForm),
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin'
            }).then(function (res) {
                if (res.ok) {
                    showNotifySaved();
                }
            }).catch(function () { /* ignore network errors; toggle state is kept */ });
        }

        notifyForm.querySelectorAll('.rl-notify-checkbox').forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                syncNotifyToggles();
                saveNotifyPreferences();
            });
        });

        // Prevent any accidental full-page submit (e.g. Enter key) from scrolling to top.
        notifyForm.addEventListener('submit', function (e) {
            e.preventDefault();
            saveNotifyPreferences();
        });

        var photoForm = document.getElementById('rlProfilePhotoForm');
        var menuBtn = document.getElementById('rlProfilePhotoBtn');
        var menu = document.getElementById('rlProfilePhotoMenu');
        var takeBtn = document.getElementById('rlProfilePhotoTake');
        var chooseBtn = document.getElementById('rlProfilePhotoChoose');
        var cameraInput = document.getElementById('rlProfilePhotoCamera');
        var libraryInput = document.getElementById('rlProfilePhotoLibrary');
        var previewImg = document.getElementById('rlProfilePhotoImg');
        var placeholder = document.getElementById('rlProfilePhotoPlaceholder');

        if (photoForm && menuBtn && menu) {
            function closePhotoMenu() {
                menu.hidden = true;
                menuBtn.setAttribute('aria-expanded', 'false');
            }

            menuBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                var willOpen = menu.hidden;
                menu.hidden = !willOpen;
                menuBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            });

            document.addEventListener('click', closePhotoMenu);
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    closePhotoMenu();
                }
            });

            if (takeBtn && cameraInput) {
                takeBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    closePhotoMenu();
                    cameraInput.click();
                });
            }

            if (chooseBtn && libraryInput) {
                chooseBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    closePhotoMenu();
                    libraryInput.click();
                });
            }

            function showPhotoAlert(message, tone) {
                var wrap = document.getElementById('rlProfilePhotoAlerts');
                if (!wrap) {
                    return;
                }

                wrap.innerHTML = '';
                var alert = document.createElement('div');
                alert.className = 'rl-profile-photo-alert rl-profile-photo-alert--' + tone;
                alert.setAttribute('role', tone === 'success' ? 'status' : 'alert');
                alert.textContent = message;
                wrap.appendChild(alert);
            }

            function handlePhotoSelected(input) {
                if (!input.files || input.files.length === 0) {
                    return;
                }

                var file = input.files[0];
                if (previewImg && file.type.startsWith('image/')) {
                    previewImg.src = URL.createObjectURL(file);
                    previewImg.hidden = false;
                    if (placeholder) {
                        placeholder.hidden = true;
                    }
                }

                var formData = new FormData(photoForm);
                formData.delete('photo');
                formData.append('photo', file);

                fetch(photoForm.action, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                    .then(function (response) {
                        return response.json().then(function (data) {
                            if (!response.ok || !data.ok) {
                                throw new Error(data.message || 'Could not upload photo.');
                            }
                            return data;
                        });
                    })
                    .then(function (data) {
                        if (previewImg && data.photoUrl) {
                            previewImg.src = data.photoUrl;
                            previewImg.hidden = false;
                            if (placeholder) {
                                placeholder.hidden = true;
                            }
                        }
                        showPhotoAlert(data.message || 'Profile photo updated.', 'success');
                    })
                    .catch(function (error) {
                        showPhotoAlert(error.message || 'Could not upload photo.', 'error');
                    })
                    .finally(function () {
                        input.value = '';
                    });
            }

            if (cameraInput) {
                cameraInput.addEventListener('change', function () {
                    handlePhotoSelected(cameraInput);
                });
            }

            if (libraryInput) {
                libraryInput.addEventListener('change', function () {
                    handlePhotoSelected(libraryInput);
                });
            }
        }
    })();
</script>
}
