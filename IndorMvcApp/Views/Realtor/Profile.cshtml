@model IndorMvcApp.ViewModels.RealtorProfileViewModel
@{
    ViewData["Title"] = L["Profile"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "profile";
    var profileCardController = Model.IsVerified ? "Realtor" : "RealtorRegistration";
    var profileCardAction = Model.IsVerified ? "PublicProfile" : "Verification";
}

<div class="rl-dash-shell rl-dash-shell--profile">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <section class="rl-profile-hero">
        <div class="rl-profile-hero-inner">
            <div class="rl-profile-hero-copy">
                <h1 class="rl-profile-hero-title">@L["Profile"]</h1>
                <p class="rl-profile-hero-subtitle">@L["Manage your realtor account, branding, and settings."]</p>
            </div>
            <div class="rl-profile-hero-visual" aria-hidden="true">
                <i class="fas fa-user rl-profile-hero-icon"></i>
            </div>
        </div>
    </section>

    <section class="rl-profile-card-v2 rl-profile-card-v2--overlap">
        <a asp-controller="@profileCardController" asp-action="@profileCardAction" class="rl-profile-card-link">
            <div class="rl-profile-photo-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                {
                    <img src="@Model.ProfilePhotoUrl" alt="" class="rl-profile-photo" />
                }
                else
                {
                    <span class="rl-profile-photo rl-profile-photo--placeholder"><i class="fas fa-user"></i></span>
                }
                @if (Model.IsVerified)
                {
                    <span class="rl-profile-photo-badge" aria-label="@L["Verified"]"><i class="fas fa-circle-check"></i></span>
                }
            </div>
            <div class="rl-profile-card-info">
                <strong>@Model.FullName</strong>
                <div class="rl-home-badge-row">
                    <span class="rl-dash-badge @(Model.IsVerified ? "is-verified" : null)">
                        <i class="fas @(Model.IsVerified ? "fa-circle-check" : "fa-star")"></i>
                        @L[Model.BadgeLabel]
                    </span>
                    @if (!Model.IsVerified)
                    {
                        <span class="rl-verify-link">@L["Verify profile"] <i class="fas fa-chevron-right"></i></span>
                    }
                </div>
            </div>
        </a>
        <div class="rl-profile-stats">
            @foreach (var stat in Model.Stats)
            {
                <div class="rl-profile-stat">
                    <span class="rl-stat-icon rl-stat-icon--@stat.ColorClass"><i class="fas @stat.Icon"></i></span>
                    <strong>@stat.Count</strong>
                    <span>@L[stat.Label]</span>
                </div>
            }
        </div>
    </section>

    <section class="rl-quick-actions rl-quick-actions--profile">
        <a asp-controller="Realtor" asp-action="PublicProfile" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-globe"></i></span>
            <span>@L["Public Profile"]</span>
        </a>
        <button type="button" class="rl-quick-action" id="rlShareBtn">
            <span class="rl-quick-action-icon"><i class="fas fa-share-from-square"></i></span>
            <span>@L["Share"]</span>
        </button>
        <a asp-controller="Realtor" asp-action="BusinessInformation" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-gear"></i></span>
            <span>@L["Settings"]</span>
        </a>
    </section>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="BusinessInformation" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-building"></i></span>
            <div>
                <strong>@L["Business Information"]</strong>
                <span class="rl-profile-nav-desc">@L["Manage your contact details, brokerage and license."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="EditProfileServiceArea" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-location-dot"></i></span>
            <div>
                <strong>@L["Service Area / Market Area"]</strong>
                <span class="rl-profile-nav-desc">@L["Define the areas and neighborhoods you serve."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="SharedPackages" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-share-nodes"></i></span>
            <div>
                <strong>@L["Shared Packages"]</strong>
                <span class="rl-profile-nav-desc">@L["View the packages you've shared with clients."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="SupportAccount" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-shield-halved"></i></span>
            <div>
                <strong>@L["Account Settings"]</strong>
                <span class="rl-profile-nav-desc">@L["Update your preferences and security settings."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    <section class="rl-bottom-grid">
        <form asp-controller="Realtor" asp-action="ProfileNotificationPreferences" method="post" class="rl-settings-card" id="rl-notify-form">
            @Html.AntiForgeryToken()
            <div class="rl-settings-head">
                <span><i class="fas fa-bell"></i> @L["Notifications"]</span>
                <small>@L["Choose what updates you want to receive."]</small>
            </div>
            @if (Model.NotificationsSaved)
            {
                <div class="rl-notify-saved" role="status">@L["Notification preferences saved."]</div>
            }
            <label class="rl-toggle-row">
                <span>@L["Email alerts"]</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="EmailAlertsEnabled" value="false" />
                    <input type="checkbox" name="EmailAlertsEnabled" value="true" class="rl-notify-checkbox" @(Model.EmailAlertsEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
            <label class="rl-toggle-row">
                <span>@L["Quote updates"]</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="QuoteUpdatesEnabled" value="false" />
                    <input type="checkbox" name="QuoteUpdatesEnabled" value="true" class="rl-notify-checkbox" @(Model.QuoteUpdatesEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
            <label class="rl-toggle-row">
                <span>@L["Report notifications"]</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="ReportNotificationsEnabled" value="false" />
                    <input type="checkbox" name="ReportNotificationsEnabled" value="true" class="rl-notify-checkbox" @(Model.ReportNotificationsEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
            <label class="rl-toggle-row">
                <span>@L["Package-view alerts"]</span>
                <span class="rl-toggle-control">
                    <input type="hidden" name="PackageViewAlertsEnabled" value="false" />
                    <input type="checkbox" name="PackageViewAlertsEnabled" value="true" class="rl-notify-checkbox" @(Model.PackageViewAlertsEnabled ? "checked" : null) />
                    <span class="rl-toggle" aria-hidden="true"></span>
                </span>
            </label>
        </form>
        <div class="rl-settings-card">
            <div class="rl-settings-head">
                <span><i class="fas fa-chart-line"></i> @L["Performance Snapshot"]</span>
                <small>@L["Your activity at a glance."]</small>
            </div>
            <div class="rl-perf-row">
                <span>@L["Response Time"]</span>
                <div>
                    <strong>@Model.ResponseTimeLabel</strong>
                    <span class="rl-perf-good">@Model.ResponseTimeStatus</span>
                </div>
            </div>
            <div class="rl-perf-row">
                <span>@L["Files This Month"]</span>
                <div>
                    <strong>@Model.FilesThisMonth</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.FilesTrendLabel))
                    {
                        <span class="rl-perf-good">@Model.FilesTrendLabel</span>
                    }
                </div>
            </div>
            <div class="rl-perf-row">
                <span>@L["Client Connections"]</span>
                <div>
                    <strong>@Model.ClientConnections</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.ClientsTrendLabel))
                    {
                        <span class="rl-perf-good">@Model.ClientsTrendLabel</span>
                    }
                </div>
            </div>
            <div class="rl-perf-details" id="rlPerfDetails" hidden>
                @foreach (var insight in Model.Insights)
                {
                    <div class="rl-perf-insight">
                        <i class="fas @insight.Icon"></i>
                        <span>@insight.Text</span>
                    </div>
                }
            </div>
            <button type="button"
                    class="rl-premium-link"
                    id="rlInsightsToggle"
                    aria-expanded="false"
                    aria-controls="rlPerfDetails">
                <span class="rl-insights-toggle-label">@L["View full insights"]</span>
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </section>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="Network" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-map-location-dot"></i></span>
            <div>
                <strong>@L["Nearby Network"]</strong>
                <span class="rl-profile-nav-desc">@L["See listings, leads, providers and open houses within 3 miles."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="ProviderNetwork" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-people-group"></i></span>
            <div>
                <strong>@L["Connected Provider Network"]</strong>
                <span class="rl-profile-nav-desc">@L["Manage and connect with trusted inspectors and providers."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="SupportAccount" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-headset"></i></span>
            <div>
                <strong>@L["Support &amp; Account"]</strong>
                <span class="rl-profile-nav-desc">@L["Get help, manage your subscription and account."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    @if (Model.CanUpgradeToVerified)
    {
        <section class="rl-verify-banner rl-verify-banner--compact">
            <i class="fas fa-shield-halved"></i>
            <div>
                <strong>@L["Become a Verified Realtor"]</strong>
                <p>@L["Upload your license and ID to unlock the Verified Realtor badge."]</p>
                <a asp-controller="RealtorRegistration" asp-action="Verification" class="ob-btn ob-btn-primary">@L["Verify now"]</a>
            </div>
        </section>
    }

    <form asp-controller="Account" asp-action="Logout" method="post" class="rl-signout-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="rl-profile-row rl-profile-row--danger rl-profile-row--center">
            <span><i class="fas fa-right-from-bracket"></i> @L["Sign Out"]</span>
            <i class="fas fa-chevron-right"></i>
        </button>
    </form>

    <a asp-controller="Account" asp-action="DeleteAccount" class="rl-profile-row rl-profile-row--danger rl-profile-row--center">
        <span><i class="fas fa-user-xmark"></i> @L["Delete account"]</span>
        <i class="fas fa-chevron-right"></i>
    </a>

    <div class="rl-toast" id="rlToast" role="status" aria-live="polite" hidden></div>
</div>

@section Scripts {
<script>
    (function () {
        var toast = document.getElementById('rlToast');
        var toastTimer = null;
        function showToast(message) {
            if (!toast) {
                return;
            }
            toast.textContent = message;
            toast.hidden = false;
            toast.classList.add('is-visible');
            if (toastTimer) {
                clearTimeout(toastTimer);
            }
            toastTimer = setTimeout(function () {
                toast.classList.remove('is-visible');
                toastTimer = setTimeout(function () { toast.hidden = true; }, 250);
            }, 2400);
        }

        var shareBtn = document.getElementById('rlShareBtn');
        if (shareBtn) {
            var shareUrl = window.location.origin + '@Url.Action("PublicProfile", "Realtor")';
            shareBtn.addEventListener('click', async function () {
                var payload = {
                    title: '@Model.FullName - INDOR',
                    text: 'View my realtor profile on INDOR',
                    url: shareUrl
                };
                if (navigator.share) {
                    try { await navigator.share(payload); return; } catch (_) { }
                }
                try {
                    await navigator.clipboard.writeText(shareUrl);
                    showToast('Profile link copied to clipboard.');
                } catch (_) {
                    window.prompt('Copy profile link:', shareUrl);
                }
            });
        }

        var toggle = document.getElementById('rlInsightsToggle');
        var details = document.getElementById('rlPerfDetails');
        if (toggle && details) {
            var label = toggle.querySelector('.rl-insights-toggle-label');
            toggle.addEventListener('click', function () {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
                details.hidden = expanded;
                if (label) {
                    label.textContent = expanded ? 'View full insights' : 'Hide insights';
                }
            });
        }

        var notifyForm = document.getElementById('rl-notify-form');
        if (!notifyForm) {
            return;
        }

        function syncNotifyToggles() {
            notifyForm.querySelectorAll('.rl-toggle-row').forEach(function (row) {
                var checkbox = row.querySelector('.rl-notify-checkbox');
                var track = row.querySelector('.rl-toggle');
                if (!checkbox || !track) {
                    return;
                }

                track.classList.toggle('is-on', checkbox.checked);
            });
        }

        syncNotifyToggles();

        var savedTimer = null;
        function showNotifySaved() {
            var msg = notifyForm.querySelector('.rl-notify-saved');
            if (!msg) {
                msg = document.createElement('div');
                msg.className = 'rl-notify-saved';
                msg.setAttribute('role', 'status');
                var head = notifyForm.querySelector('.rl-settings-head');
                if (head) {
                    head.insertAdjacentElement('afterend', msg);
                } else {
                    notifyForm.prepend(msg);
                }
            }
            msg.textContent = 'Notification preferences saved.';
            msg.hidden = false;
            if (savedTimer) {
                clearTimeout(savedTimer);
            }
            savedTimer = setTimeout(function () { msg.hidden = true; }, 2000);
        }

        function saveNotifyPreferences() {
            // Save in the background so the page doesn't reload and jump to the top.
            fetch(notifyForm.action, {
                method: 'POST',
                body: new FormData(notifyForm),
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin'
            }).then(function (res) {
                if (res.ok) {
                    showNotifySaved();
                }
            }).catch(function () { /* ignore network errors; toggle state is kept */ });
        }

        notifyForm.querySelectorAll('.rl-notify-checkbox').forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                syncNotifyToggles();
                saveNotifyPreferences();
            });
        });

        // Prevent any accidental full-page submit (e.g. Enter key) from scrolling to top.
        notifyForm.addEventListener('submit', function (e) {
            e.preventDefault();
            saveNotifyPreferences();
        });
    })();
</script>
}
