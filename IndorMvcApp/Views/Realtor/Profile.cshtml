@model IndorMvcApp.ViewModels.RealtorProfileViewModel
@{
    ViewData["Title"] = "Profile";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "profile";
}

<div class="rl-dash-shell rl-dash-shell--profile">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <section class="rl-profile-hero">
        <h1 class="rl-profile-hero-title">Profile</h1>
        <p class="rl-profile-hero-subtitle">Manage your realtor account, branding, and settings.</p>
    </section>

    <section class="rl-profile-card-v2 rl-profile-card-v2--overlap">
        <a asp-controller="RealtorRegistration" asp-action="Verification" class="rl-profile-card-link">
            <div class="rl-profile-photo-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                {
                    <img src="@Model.ProfilePhotoUrl" alt="" class="rl-profile-photo" />
                }
                else
                {
                    <span class="rl-profile-photo rl-profile-photo--placeholder"><i class="fas fa-user"></i></span>
                }
                @if (Model.IsVerified)
                {
                    <span class="rl-profile-photo-badge" aria-label="Verified"><i class="fas fa-circle-check"></i></span>
                }
            </div>
            <div class="rl-profile-card-info">
                <strong>@Model.FullName</strong>
                <div class="rl-home-badge-row">
                    <span class="rl-dash-badge @(Model.IsVerified ? "is-verified" : null)">
                        <i class="fas @(Model.IsVerified ? "fa-circle-check" : "fa-star")"></i>
                        @Model.BadgeLabel
                    </span>
                    @if (!Model.IsVerified)
                    {
                        <span class="rl-verify-link">Verify profile <i class="fas fa-chevron-right"></i></span>
                    }
                </div>
            </div>
            <i class="fas fa-chevron-right rl-profile-card-chevron"></i>
        </a>
        <div class="rl-profile-stats">
            @foreach (var stat in Model.Stats)
            {
                <div class="rl-profile-stat">
                    <span class="rl-stat-icon rl-stat-icon--@stat.ColorClass"><i class="fas @stat.Icon"></i></span>
                    <strong>@stat.Count</strong>
                    <span>@stat.Label</span>
                </div>
            }
        </div>
    </section>

    <section class="rl-quick-actions rl-quick-actions--profile">
        <a asp-controller="Realtor" asp-action="PublicProfile" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-globe"></i></span>
            <span>Public Profile</span>
        </a>
        <button type="button" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-share-from-square"></i></span>
            <span>Share</span>
        </button>
        <button type="button" class="rl-quick-action">
            <span class="rl-quick-action-icon"><i class="fas fa-gear"></i></span>
            <span>Settings</span>
        </button>
    </section>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="BusinessInformation" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-building"></i></span>
            <div>
                <strong>Business Information</strong>
                <span class="rl-profile-nav-desc">Manage your contact details, brokerage and license.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <button type="button" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-location-dot"></i></span>
            <div>
                <strong>Service Area / Market Area</strong>
                <span class="rl-profile-nav-desc">Define the areas and neighborhoods you serve.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </button>
        <button type="button" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-tags"></i></span>
            <div>
                <strong>Branding &amp; Shared Packages</strong>
                <span class="rl-profile-nav-desc">Customize your brand and manage shared packages.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </button>
        <button type="button" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-shield-halved"></i></span>
            <div>
                <strong>Account Settings</strong>
                <span class="rl-profile-nav-desc">Update your preferences and security settings.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </button>
    </nav>

    <section class="rl-bottom-grid">
        <div class="rl-settings-card">
            <div class="rl-settings-head">
                <span><i class="fas fa-bell"></i> Notifications</span>
                <small>Choose what updates you want to receive.</small>
            </div>
            <div class="rl-toggle-row">
                <span>Email alerts</span>
                <input type="checkbox" checked />
                <span class="rl-toggle"></span>
            </div>
            <div class="rl-toggle-row">
                <span>Quote updates</span>
                <input type="checkbox" checked />
                <span class="rl-toggle"></span>
            </div>
            <div class="rl-toggle-row">
                <span>Report notifications</span>
                <input type="checkbox" checked />
                <span class="rl-toggle"></span>
            </div>
            <div class="rl-toggle-row">
                <span>Package-view alerts</span>
                <input type="checkbox" />
                <span class="rl-toggle"></span>
            </div>
            <button type="button" class="rl-premium-link">Manage all notifications <i class="fas fa-chevron-right"></i></button>
        </div>
        <div class="rl-settings-card">
            <div class="rl-settings-head">
                <span><i class="fas fa-chart-line"></i> Performance Snapshot</span>
                <small>Your activity at a glance.</small>
            </div>
            <div class="rl-perf-row">
                <span>Response Time</span>
                <div>
                    <strong>@Model.ResponseTimeLabel</strong>
                    <span class="rl-perf-good">@Model.ResponseTimeStatus</span>
                </div>
            </div>
            <div class="rl-perf-row">
                <span>Files This Month</span>
                <div>
                    <strong>@Model.FilesThisMonth</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.FilesTrendLabel))
                    {
                        <span class="rl-perf-good">@Model.FilesTrendLabel</span>
                    }
                </div>
            </div>
            <div class="rl-perf-row">
                <span>Client Connections</span>
                <div>
                    <strong>@Model.ClientConnections</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.ClientsTrendLabel))
                    {
                        <span class="rl-perf-good">@Model.ClientsTrendLabel</span>
                    }
                </div>
            </div>
            <div class="rl-perf-details" id="rlPerfDetails" hidden>
                @foreach (var insight in Model.Insights)
                {
                    <div class="rl-perf-insight">
                        <i class="fas @insight.Icon"></i>
                        <span>@insight.Text</span>
                    </div>
                }
            </div>
            <button type="button"
                    class="rl-premium-link"
                    id="rlInsightsToggle"
                    aria-expanded="false"
                    aria-controls="rlPerfDetails">
                <span class="rl-insights-toggle-label">View full insights</span>
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </section>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="Network" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-map-location-dot"></i></span>
            <div>
                <strong>Nearby Network</strong>
                <span class="rl-profile-nav-desc">See listings, leads, providers and open houses within 3 miles.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Realtor" asp-action="ProviderNetwork" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-people-group"></i></span>
            <div>
                <strong>Connected Provider Network</strong>
                <span class="rl-profile-nav-desc">Manage and connect with trusted inspectors and providers.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <button type="button" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-headset"></i></span>
            <div>
                <strong>Support &amp; Account</strong>
                <span class="rl-profile-nav-desc">Get help, manage your subscription and account.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </button>
    </nav>

    @if (Model.CanUpgradeToVerified)
    {
        <section class="rl-verify-banner rl-verify-banner--compact">
            <i class="fas fa-shield-halved"></i>
            <div>
                <strong>Become a Verified Realtor</strong>
                <p>Upload your license and ID to unlock the Verified Realtor badge.</p>
                <a asp-controller="RealtorRegistration" asp-action="Verification" class="ob-btn ob-btn-primary">Verify now</a>
            </div>
        </section>
    }

    <form asp-controller="Account" asp-action="Logout" method="post" class="rl-signout-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="rl-profile-row rl-profile-row--danger">
            <span><i class="fas fa-right-from-bracket"></i> Sign Out</span>
            <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>

@section Scripts {
<script>
    (function () {
        var toggle = document.getElementById('rlInsightsToggle');
        var details = document.getElementById('rlPerfDetails');
        if (!toggle || !details) {
            return;
        }

        var label = toggle.querySelector('.rl-insights-toggle-label');
        toggle.addEventListener('click', function () {
            var expanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            details.hidden = expanded;
            if (label) {
                label.textContent = expanded ? 'View full insights' : 'Hide insights';
            }
        });
    })();
</script>
}
