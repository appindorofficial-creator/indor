@model IndorMvcApp.ViewModels.RealtorNetworkViewModel
@using IndorMvcApp.Helpers
@{
    ViewData["Title"] = L["Provider Network"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "home";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <header class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Dashboard" class="rl-network-back" aria-label="@L["Back to dashboard"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="rl-page-title">@L["Provider Network"]</h1>
            <p class="rl-page-subtitle">@L["Browse trusted inspectors, contractors, and service providers."]</p>
        </div>
    </header>

    <form asp-action="ProviderNetwork" method="get" class="rl-search-form">
        <div class="rl-search-row">
            <div class="rl-search-bar">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search company or service..."]" />
            </div>
            <button type="submit" class="rl-filter-btn">@L["Search"]</button>
        </div>
        <div class="rl-filter-chips">
            @foreach (var chip in Model.ProviderFilters)
            {
                <a asp-action="ProviderNetwork" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                   class="rl-filter-chip @(Model.ActiveFilter == chip ? "is-active" : null)">@RealtorDisplayLocalization.ProviderFilterLabel(L, chip)</a>
            }
        </div>
    </form>

    <section class="rl-dash-section">
        @if (Model.Providers.Count == 0)
        {
            <div class="rl-dash-empty">@L["No providers match your search yet."]</div>
        }
        else
        {
            @foreach (var provider in Model.Providers)
            {
                <article class="rl-provider-card rl-provider-card--browse">
                    <span class="rl-provider-logo"><i class="fas fa-building"></i></span>
                    <span class="rl-provider-body">
                        <strong>@provider.CompanyName</strong>
                        @if (!string.IsNullOrWhiteSpace(provider.BadgeLabel))
                        {
                            <span class="rl-provider-badge">@provider.BadgeLabel</span>
                        }
                        <span><i class="fas fa-star"></i> @provider.Rating.ToString("0.0") · @UiDisplayLocalization.Localize(L, provider.Categories)</span>
                        <span>@UiDisplayLocalization.Localize(L, provider.DistanceLabel)</span>
                    </span>
                    @if (provider.IsVerified)
                    {
                        <span class="rl-status-pill rl-status-pill--active">@L["Verified"]</span>
                    }
                </article>
            }
        }
    </section>
</div>
