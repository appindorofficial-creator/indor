@model IndorMvcApp.ViewModels.RealtorClientDetailViewModel
@using IndorMvcApp.Helpers
@{
    ViewData["Title"] = Model.FullName;
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "clients";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Clients" class="rl-back-link"><i class="fas fa-chevron-left"></i> @L["Clients"]</a>
        <h1 class="rl-page-title">@Model.FullName</h1>
        <p class="rl-page-subtitle">@L.T("{0} client profile", RealtorDisplayLocalization.ClientRole(L, Model.ClientRole))</p>
    </div>

    <div class="rl-client-detail-hero">
        <div class="rl-client-detail-head">
            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="" class="rl-client-avatar" />
            }
            else
            {
                <span class="rl-client-avatar rl-client-avatar--placeholder">@Model.Initials</span>
            }
            <div class="rl-client-detail-identity">
                <strong>@Model.FullName</strong>
                <span class="rl-role-label">@RealtorDisplayLocalization.ClientRole(L, Model.ClientRole)</span>
                <span class="rl-status-pill rl-status-pill--@Model.StatusCss">@UiDisplayLocalization.Localize(L, Model.StatusBadge)</span>
            </div>
        </div>
        <div class="rl-client-detail-meta">
            @if (!string.IsNullOrWhiteSpace(Model.Email))
            {
                <div class="rl-client-detail-meta--full">
                    <span>@L["Email"]</span>
                    <strong>@Model.Email</strong>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Phone))
            {
                <div class="rl-client-detail-meta--full">
                    <span>@L["Phone"]</span>
                    <strong>@Model.Phone</strong>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.PropertyAddress))
            {
                <div class="rl-client-detail-meta--full">
                    <span>@L["Property"]</span>
                    <strong>@Model.PropertyAddress</strong>
                </div>
            }
            <div><span>@L["Connected"]</span><strong>@UiDisplayLocalization.Localize(L, Model.ConnectedLabel)</strong></div>
            <div><span>@L["Last active"]</span><strong>@UiDisplayLocalization.Localize(L, Model.LastActiveLabel)</strong></div>
            <div><span>@L["Files"]</span><strong>@Model.FilesCount</strong></div>
            <div><span>@L["Quotes"]</span><strong>@Model.QuotesCount</strong></div>
        </div>
    </div>

    <div class="rl-client-detail-actions">
        <a href="@Model.CreateFileUrl" class="ob-btn ob-btn-primary">
            <i class="fas fa-folder-plus"></i> @L["Create File"]
        </a>
        @if (Model.FilesCount > 0)
        {
            <a href="@Model.ViewFilesUrl" class="rl-btn-outline">
                <i class="fas fa-folder-open"></i> @L["View All Files"]
            </a>
        }
    </div>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head">
            <h2>@L["Property Files"]</h2>
        </div>
        @if (Model.Files.Count == 0)
        {
            <div class="rl-dash-empty">@L["No property files yet. Create one to start organizing inspections, quotes, and documents."]</div>
        }
        else
        {
            @foreach (var file in Model.Files)
            {
                <article class="rl-file-card-v2 rl-file-card-v2--compact">
                    <img src="@(file.PhotoUrl ?? "/welcome-house.png")" alt="" />
                    <div class="rl-file-card-body">
                        <div class="rl-file-card-top">
                            <div>
                                <strong>@file.Address</strong>
                                @if (!string.IsNullOrWhiteSpace(file.CityRegion))
                                {
                                    <span class="rl-premium-muted">@file.CityRegion</span>
                                }
                            </div>
                            <span class="rl-status-pill rl-status-pill--@file.StatusCss">@UiDisplayLocalization.Localize(L, file.StatusBadge)</span>
                        </div>
                        <span class="rl-file-code">@file.FileCode</span>
                        <span class="rl-file-updated">@UiDisplayLocalization.Localize(L, file.UpdatedLabel)</span>
                    </div>
                    <a href="@file.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@UiDisplayLocalization.Localize(L, file.ActionLabel)</a>
                </article>
            }
        }
    </section>

    @if (Model.QuotesCount > 0)
    {
        <section class="rl-dash-section">
            <div class="rl-dash-section-head">
                <h2>@L["Quotes"]</h2>
            </div>
            @foreach (var quote in Model.Quotes)
            {
                <article class="rl-client-quote-row">
                    <div>
                        <strong>@quote.Address</strong>
                        <span class="rl-premium-muted">@quote.ServiceType · @quote.QuoteCode</span>
                    </div>
                    <span class="rl-status-pill rl-status-pill--@quote.StatusCss">@UiDisplayLocalization.Localize(L, quote.StatusLabel)</span>
                    <a href="@quote.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@L["View"]</a>
                </article>
            }
        </section>
    }
</div>
