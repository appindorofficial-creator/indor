@model IndorMvcApp.ViewModels.RealtorSharedQuoteTrackingViewModel
@{
    ViewData["Title"] = "Shared Quote";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "quotes";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Quotes" class="rl-back-link"><i class="fas fa-chevron-left"></i> Quotes</a>
        <h1 class="rl-page-title">Shared Quote</h1>
    </div>

    <div class="rl-qshare-success">
        <i class="fas fa-circle-check"></i>
        <strong>Quote Shared Successfully</strong>
        <p>The quote has been shared with the homeowner. You'll be notified when they respond.</p>
    </div>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2><i class="fas fa-chart-line"></i> Status Timeline</h2></div>
        <ul class="rl-qshare-timeline">
            @foreach (var item in Model.Timeline)
            {
                <li class="rl-qshare-timeline-item rl-qshare-timeline-item--@item.State">
                    <span class="rl-qshare-timeline-icon"><i class="fas @item.Icon"></i></span>
                    <div>
                        <strong>@item.Label</strong>
                        @if (!string.IsNullOrWhiteSpace(item.TimestampLabel))
                        {
                            <span>@item.TimestampLabel</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.SubLabel))
                        {
                            <em>@item.SubLabel</em>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.Badge))
                    {
                        <span class="rl-status-pill rl-status-pill--pending">@item.Badge</span>
                    }
                </li>
            }
        </ul>
    </section>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2><i class="fas fa-house"></i> Quote Summary</h2></div>
        <div class="rl-qshare-summary">
            <img src="@Model.PhotoUrl" alt="" />
            <div>
                <div class="rl-qshare-summary-row"><span>Property</span><strong>@Model.Address</strong></div>
                <div class="rl-qshare-summary-row"><span>Homeowner</span><strong>@Model.HomeownerName</strong></div>
                <div class="rl-qshare-summary-row"><span>Provider</span><strong>@Model.ProviderName <i class="fas fa-circle-check rl-verified-mini"></i></strong></div>
                <div class="rl-qshare-summary-row rl-qshare-summary-row--total">
                    <span>Quote Total</span>
                    <strong>@Model.TotalAmountLabel</strong>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.RecentActivityLabel))
    {
        <div class="rl-qshare-activity">
            <i class="fas fa-bell"></i>
            <div>
                <strong>Recent Activity</strong>
                <span>@Model.RecentActivityLabel</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.RecentActivityTime))
            {
                <span class="rl-status-pill rl-status-pill--received">@Model.RecentActivityTime</span>
            }
        </div>
    }

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2>Next Actions</h2></div>
        <div class="rl-qview-actions">
            <button type="button" class="ob-btn ob-btn-primary rl-qview-btn"><i class="fas fa-comment-dots"></i> Message Homeowner</button>
            <a href="@Model.ViewSharedQuoteUrl" target="_blank" class="rl-btn-outline rl-qview-btn"><i class="fas fa-file-lines"></i> View Shared Quote</a>
            <a asp-controller="Realtor" asp-action="Quotes" class="rl-btn-outline rl-qview-btn"><i class="fas fa-arrow-left"></i> Back to Quotes</a>
        </div>
    </section>
</div>
