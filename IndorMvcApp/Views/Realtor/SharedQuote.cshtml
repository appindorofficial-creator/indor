@model IndorMvcApp.ViewModels.RealtorSharedQuoteTrackingViewModel
@{
    ViewData["Title"] = L["Shared Quote"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "quotes";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Quotes" class="rl-back-link"><i class="fas fa-chevron-left"></i> @L["Quotes"]</a>
        <h1 class="rl-page-title">@L["Shared Quote"]</h1>
    </div>

    <div class="rl-qshare-success">
        <i class="fas fa-circle-check"></i>
        <strong>@L["Quote Shared Successfully"]</strong>
        <p>@L["The quote has been shared with the homeowner. You'll be notified when they respond."]</p>
    </div>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2><i class="fas fa-chart-line"></i> @L["Status Timeline"]</h2></div>
        <ul class="rl-qshare-timeline">
            @foreach (var item in Model.Timeline)
            {
                <li class="rl-qshare-timeline-item rl-qshare-timeline-item--@item.State">
                    <span class="rl-qshare-timeline-icon"><i class="fas @item.Icon"></i></span>
                    <div>
                        <strong>@UiDisplayLocalization.Localize(L, item.Label)</strong>
                        @if (!string.IsNullOrWhiteSpace(item.TimestampLabel))
                        {
                            <span>@item.TimestampLabel</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.SubLabel))
                        {
                            <em>@UiDisplayLocalization.Localize(L, item.SubLabel)</em>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.Badge))
                    {
                        <span class="rl-status-pill rl-status-pill--pending">@UiDisplayLocalization.Localize(L, item.Badge)</span>
                    }
                </li>
            }
        </ul>
    </section>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2><i class="fas fa-house"></i> @L["Quote Summary"]</h2></div>
        <div class="rl-qshare-summary">
            <img src="@Model.PhotoUrl" alt="" />
            <div>
                <div class="rl-qshare-summary-row"><span>@L["Property"]</span><strong>@Model.Address</strong></div>
                <div class="rl-qshare-summary-row"><span>@L["Homeowner"]</span><strong>@Model.HomeownerName</strong></div>
                <div class="rl-qshare-summary-row"><span>@L["Provider"]</span><strong>@Model.ProviderName <i class="fas fa-circle-check rl-verified-mini"></i></strong></div>
                <div class="rl-qshare-summary-row rl-qshare-summary-row--total">
                    <span>@L["Quote Total"]</span>
                    <strong>@Model.TotalAmountLabel</strong>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.RecentActivityLabel))
    {
        <div class="rl-qshare-activity">
            <i class="fas fa-bell"></i>
            <div>
                <strong>@L["Recent Activity"]</strong>
                <span>@UiDisplayLocalization.Localize(L, Model.RecentActivityLabel)</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.RecentActivityTime))
            {
                <span class="rl-status-pill rl-status-pill--received">@UiDisplayLocalization.Localize(L, Model.RecentActivityTime)</span>
            }
        </div>
    }

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2>@L["Next Actions"]</h2></div>
        <div class="rl-qview-actions">
            @if (Model.CanMessageHomeowner)
            {
                <a href="@Model.MessageHomeownerUrl" class="ob-btn ob-btn-primary rl-qview-btn">
                    <i class="fas fa-comment-dots"></i> @L["Message Homeowner"]
                </a>
            }
            else
            {
                <span class="ob-btn ob-btn-primary rl-qview-btn rl-soon" role="button" aria-disabled="true"
                      title="@L["Add the homeowner phone or email when sharing the quote."]">
                    <i class="fas fa-comment-dots"></i> @L["Message Homeowner"]
                </span>
            }
            <a href="@Model.ViewSharedQuoteUrl" class="rl-btn-outline rl-qview-btn">
                <i class="fas fa-file-lines"></i> @L["View Shared Quote"]
            </a>
            <a asp-controller="Realtor" asp-action="Quotes" class="rl-btn-outline rl-qview-btn">
                <i class="fas fa-arrow-left"></i> @L["Back to Quotes"]
            </a>
        </div>
    </section>
</div>
