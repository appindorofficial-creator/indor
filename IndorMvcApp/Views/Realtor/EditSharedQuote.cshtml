@model IndorMvcApp.ViewModels.RealtorEditSharedQuoteViewModel
@{
    ViewData["Title"] = L["Edit Shared Quote"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "quotes";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="ViewQuote" asp-route-id="@Model.QuoteId" asp-route-bidId="@Model.BidId" class="rl-back-link">
            <i class="fas fa-chevron-left"></i> Quote Details
        </a>
        <h1 class="rl-page-title">@L["Edit Shared Quote"]</h1>
    </div>

    <div class="rl-qview-hero">
        <img src="@Model.PhotoUrl" alt="" />
        <div>
            <strong>@Model.Address</strong>
            <span class="rl-status-pill rl-status-pill--received">@Model.StatusLabel</span>
        </div>
    </div>

    <form asp-action="EditSharedQuote" method="post" class="rl-qshare-form">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SharedQuoteId" />
        <input type="hidden" asp-for="QuoteId" />
        <input type="hidden" asp-for="BidId" />

        <div class="rl-qshare-recipient">
            <span class="rl-provider-avatar">@Model.HomeownerInitials</span>
            <div>
                <span class="rl-premium-muted">@L["Send to Homeowner"]</span>
                <strong>@Model.HomeownerName</strong>
                <span class="rl-premium-muted">
                    @(string.IsNullOrWhiteSpace(Model.HomeownerEmail) ? "No email on file" : Model.HomeownerEmail)
                    @if (!string.IsNullOrWhiteSpace(Model.HomeownerPhone)) { <text> · @Model.HomeownerPhone</text> }
                </span>
            </div>
            <i class="fas fa-chevron-right rl-profile-card-chevron"></i>
        </div>

        <section class="rl-dash-section">
            <div class="rl-dash-section-head">
                <h2>@L["What to share"] <i class="fas fa-circle-info rl-inline-info"></i></h2>
                <p class="rl-section-caption">@L["Choose what the homeowner will see."]</p>
            </div>
            <div class="rl-qshare-check-grid">
                <label class="rl-qshare-check"><input type="checkbox" asp-for="ShareProviderInfo" /><i class="fas fa-building rl-check-icon rl-check-icon--blue"></i> @L["Provider info"]</label>
                <label class="rl-qshare-check"><input type="checkbox" asp-for="ShareFullPriceBreakdown" /><i class="fas fa-receipt rl-check-icon rl-check-icon--purple"></i> @L["Full price breakdown"]</label>
                <label class="rl-qshare-check"><input type="checkbox" asp-for="ShareScopeOfWork" /><i class="fas fa-clipboard-list rl-check-icon rl-check-icon--blue"></i> @L["Scope of work"]</label>
                <label class="rl-qshare-check"><input type="checkbox" asp-for="ShareWarranty" /><i class="fas fa-shield-halved rl-check-icon rl-check-icon--green"></i> @L["Warranty"]</label>
                <label class="rl-qshare-check"><input type="checkbox" asp-for="ShareIncludedRepairs" /><i class="fas fa-wrench rl-check-icon rl-check-icon--blue"></i> @L["Included repairs"]</label>
                <label class="rl-qshare-check"><input type="checkbox" asp-for="ShareTimeline" /><i class="fas fa-clock rl-check-icon rl-check-icon--purple"></i> @L["Timeline"]</label>
            </div>
        </section>

        <section class="rl-dash-section">
            <div class="rl-dash-section-head"><h2>@L["How should pricing be shown?"]</h2></div>
            <div class="rl-qshare-pricing-pick">
                <label class="rl-qshare-pricing-card @(Model.PricingDisplayMode == "TotalOnly" ? "is-selected" : null)">
                    <input type="radio" asp-for="PricingDisplayMode" value="TotalOnly" />
                    <strong>@L["Show total only"]</strong>
                    <span>@L["Simplified for homeowner"]</span>
                </label>
                <label class="rl-qshare-pricing-card @(Model.PricingDisplayMode == "FullDetails" ? "is-selected" : null)">
                    <input type="radio" asp-for="PricingDisplayMode" value="FullDetails" />
                    <strong>@L["Show full price details"]</strong>
                    <span>@L["Breakdown of costs"]</span>
                </label>
            </div>
        </section>

        <div class="rl-qshare-field">
            <label asp-for="MessageToHomeowner">@L["Message to homeowner"] <span class="rl-char-count">@(Model.MessageToHomeowner.Length)/500</span></label>
            <textarea asp-for="MessageToHomeowner" rows="4" maxlength="500"></textarea>
        </div>

        <div class="rl-qshare-field">
            <label asp-for="InternalNotes">@L["Internal notes (hidden from homeowner)"] <span class="rl-char-count">@(Model.InternalNotes.Length)/500</span></label>
            <textarea asp-for="InternalNotes" rows="3" maxlength="500"></textarea>
        </div>

        <div class="rl-qview-actions">
            <button type="submit" class="ob-btn ob-btn-primary rl-qview-btn"><i class="fas fa-eye"></i> @L["Preview Shared Quote"]</button>
            <button type="submit" name="action" value="draft" class="rl-btn-outline rl-qview-btn"><i class="fas fa-floppy-disk"></i> @L["Save Draft"]</button>
        </div>
    </form>
</div>
