@model IndorMvcApp.ViewModels.RealtorPreviewSharedQuoteViewModel
@{
    ViewData["Title"] = L["Preview Shared Quote"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "quotes";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="EditSharedQuote" asp-route-quoteId="@Model.QuoteId" asp-route-bidId="@Model.BidId" class="rl-back-link">
            <i class="fas fa-chevron-left"></i> Edit
        </a>
        <h1 class="rl-page-title">@L["Preview Shared Quote"]</h1>
    </div>

    <div class="rl-qshare-preview-head">
        <strong>To: @Model.HomeownerName – @Model.HomeownerRole</strong>
        <p>@L["Choose how you'd like to share this quote."]</p>
        <div class="rl-qshare-delivery-icons">
            <span><i class="fas fa-mobile-screen"></i> @L["In-App"]</span>
            <span><i class="fas fa-envelope"></i> @L["Email"]</span>
            <span><i class="fas fa-comment-sms"></i> @L["Text"]</span>
            <span><i class="fas fa-link"></i> @L["Share Link"]</span>
        </div>
    </div>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2>@L["What the homeowner will receive"]</h2></div>
        <div class="rl-qshare-preview-card">
            <div class="rl-qview-hero rl-qview-hero--compact">
                <img src="@Model.PhotoUrl" alt="" />
                <div>
                    <strong>@Model.Address</strong>
                    @if (Model.ShowProviderInfo)
                    {
                        <div class="rl-qshare-mini-provider">
                            <span class="rl-provider-avatar rl-provider-avatar--sm">@Model.ProviderInitials</span>
                            @Model.ProviderName <span class="rl-premium-muted">@L["Verified provider"]</span>
                        </div>
                    }
                </div>
            </div>

            <div class="rl-qview-metrics">
                <div><i class="fas fa-dollar-sign rl-metric-icon rl-metric-icon--blue"></i><span>@L["Total Quote"]</span><strong>@Model.TotalLabel</strong></div>
                @if (!string.IsNullOrWhiteSpace(Model.TimelineLabel))
                {
                    <div><i class="fas fa-calendar-days rl-metric-icon rl-metric-icon--purple"></i><span>@L["Timeline"]</span><strong>@Model.TimelineLabel</strong></div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.WarrantyLabel))
                {
                    <div><i class="fas fa-shield-halved rl-metric-icon rl-metric-icon--green"></i><span>@L["Warranty"]</span><strong>@Model.WarrantyLabel</strong></div>
                }
                <div><i class="fas fa-circle-check rl-metric-icon rl-metric-icon--green"></i><span>@L["Status"]</span><strong>@Model.ReviewStatusLabel</strong></div>
            </div>

            @if (Model.IncludedRepairs.Count > 0)
            {
                <div class="rl-qshare-preview-block">
                    <strong>@L["Included Repairs"]</strong>
                    <ul class="rl-qview-repairs">
                        @foreach (var repair in Model.IncludedRepairs)
                        {
                            <li><i class="fas fa-circle-check"></i> @repair</li>
                        }
                    </ul>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.MessageToHomeowner))
            {
                <div class="rl-qshare-realtor-msg">
                    <i class="fas fa-quote-left"></i>
                    <p>@Model.MessageToHomeowner</p>
                </div>
            }
        </div>
    </section>

    <form asp-action="SendSharedQuote" asp-route-id="@Model.SharedQuoteId" method="post" class="rl-qshare-send-form">
        @Html.AntiForgeryToken()
        <div class="rl-qshare-delivery-tabs">
            <label><input type="radio" name="deliveryMethod" value="InApp" checked /><i class="fas fa-mobile-screen"></i> @L["In-App"]</label>
            <label><input type="radio" name="deliveryMethod" value="Email" /><i class="fas fa-envelope"></i> @L["Email"]</label>
            <label><input type="radio" name="deliveryMethod" value="Text" /><i class="fas fa-comment-sms"></i> @L["Text"]</label>
            <label><input type="radio" name="deliveryMethod" value="Link" /><i class="fas fa-link"></i> @L["Copy Link"]</label>
        </div>
        <button type="submit" class="ob-btn ob-btn-primary rl-qview-btn"><i class="fas fa-paper-plane"></i> @L["Send Quote from INDOR"]</button>
        <a href="@Model.ShareLink" class="rl-btn-outline rl-qview-btn" target="_blank"><i class="fas fa-link"></i> @L["Copy Share Link"]</a>
        <p class="rl-qshare-footnote"><i class="fas fa-shield-halved"></i> @L["The homeowner will see the same quote details directly in INDOR."]</p>
    </form>
</div>
