@model IndorMvcApp.ViewModels.RealtorHomeViewModel
@{
    ViewData["Title"] = L["Home"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "home";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <section class="rl-home-hero">
        <div class="rl-home-hero-user">
            @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
            {
                <img src="@Model.ProfilePhotoUrl" alt="" class="rl-home-avatar" />
            }
            else
            {
                <span class="rl-home-avatar rl-home-avatar--placeholder"><i class="fas fa-user"></i></span>
            }
            <div>
                <h1>@L.T("Hello {0}", Model.DisplayName)</h1>
                <div class="rl-home-badge-row">
                    <span class="rl-dash-badge @(Model.IsVerified ? "is-verified" : null)">
                        <i class="fas @(Model.IsVerified ? "fa-circle-check" : "fa-star")"></i>
                        @Model.BadgeLabel
                    </span>
                    @if (!Model.IsVerified)
                    {
                        <a asp-controller="RealtorRegistration" asp-action="Verification" class="rl-verify-link">@L["Verify profile"] <i class="fas fa-chevron-right"></i></a>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="rl-quick-actions">
        @foreach (var action in Model.QuickActions)
        {
            <a href="@action.Url" class="rl-quick-action">
                <span class="rl-quick-action-icon"><i class="fas @action.Icon"></i></span>
                <span>@action.Label</span>
            </a>
        }
    </section>

    @await Html.PartialAsync("_RealtorStatsRow", Model.Stats)

    <a asp-controller="Realtor" asp-action="ProviderNetwork" class="rl-network-banner rl-network-banner--home rl-network-banner--link">
        <div>
            <strong>@L["Grow with INDOR's Provider Network"]</strong>
            <p>@L["Connect with trusted inspectors, contractors and more."]</p>
            <span class="rl-network-btn">@L["Browse Network"] <i class="fas fa-chevron-right"></i></span>
        </div>
        <span class="rl-network-icon" aria-hidden="true"><i class="fas fa-people-group"></i></span>
    </a>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head">
            <h2>@L["Active Property Files"]</h2>
            <a asp-controller="Realtor" asp-action="Files">@L["View all"] <i class="fas fa-chevron-right"></i></a>
        </div>
        @if (Model.PropertyFiles.Count == 0)
        {
            <div class="rl-dash-empty">@L["No property files yet."]</div>
        }
        else
        {
            <div class="rl-hscroll">
                @foreach (var file in Model.PropertyFiles)
                {
                    <article class="rl-premium-card rl-premium-card--file">
                        <button type="button" class="rl-card-menu" aria-label="@L["Options"]"><i class="fas fa-ellipsis-vertical"></i></button>
                        <div class="rl-premium-card-media">
                            <img src="@file.PhotoUrl" alt="" class="rl-premium-card-img" />
                            <span class="rl-card-image-badge rl-status-pill rl-status-pill--@file.StatusCss">@file.StatusLabel</span>
                        </div>
                        <div class="rl-premium-card-body">
                            <strong>@file.StreetAddress</strong>
                            @if (!string.IsNullOrWhiteSpace(file.CityRegion))
                            {
                                <span class="rl-premium-muted">@file.CityRegion</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(file.ClientName))
                            {
                                <span class="rl-premium-client"><i class="fas fa-user"></i> @file.ClientName</span>
                            }
                            <a href="@file.ActionUrl" class="rl-premium-link">@file.ActionLabel <i class="fas fa-chevron-right"></i></a>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head">
            <h2>@L["Pending Quotes"]</h2>
            <a asp-controller="Realtor" asp-action="Quotes">@L["View all"] <i class="fas fa-chevron-right"></i></a>
        </div>
        @if (Model.PendingQuotes.Count == 0)
        {
            <div class="rl-dash-empty">@L["No pending quote requests."]</div>
        }
        else
        {
            <div class="rl-hscroll">
                @foreach (var quote in Model.PendingQuotes)
                {
                    <article class="rl-premium-card rl-premium-card--quote">
                        <div class="rl-premium-card-media">
                            <img src="@quote.PhotoUrl" alt="" class="rl-premium-card-img" />
                            @if (quote.ProviderQuotesReceived > 0)
                            {
                                <span class="rl-card-image-badge rl-quote-count-badge">@quote.ProviderQuotesReceived Quotes</span>
                            }
                            else
                            {
                                <span class="rl-card-image-badge rl-status-pill rl-status-pill--@quote.StatusCss">@quote.StatusLabel</span>
                            }
                        </div>
                        <div class="rl-premium-card-body">
                            <strong>@quote.StreetAddress</strong>
                            @if (!string.IsNullOrWhiteSpace(quote.CityRegion))
                            {
                                <span class="rl-premium-muted">@quote.CityRegion</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(quote.RequestedLabel))
                            {
                                <span class="rl-premium-muted">@quote.RequestedLabel</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(quote.DueLabel))
                            {
                                <span class="rl-premium-muted">@quote.DueLabel</span>
                            }
                            <a asp-controller="Realtor" asp-action="Quotes" class="rl-premium-link">@quote.ActionLabel <i class="fas fa-chevron-right"></i></a>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="rl-dash-section" id="shared-packages">
        <div class="rl-dash-section-head">
            <h2>@L["Shared Packages"]</h2>
            <a asp-controller="Realtor" asp-action="Files" asp-route-filter="Shared">@L["View all"] <i class="fas fa-chevron-right"></i></a>
        </div>
        @if (Model.SharedPackages.Count == 0)
        {
            <div class="rl-dash-empty">@L["No shared packages yet."]</div>
        }
        else
        {
            <div class="rl-hscroll">
                @foreach (var pkg in Model.SharedPackages)
                {
                    <article class="rl-premium-card rl-premium-card--package">
                        <span class="rl-pkg-folder rl-pkg-folder--@pkg.IconColor"><i class="fas fa-folder"></i></span>
                        <div class="rl-premium-card-body">
                            <strong>@pkg.PackageTitle</strong>
                            <span class="rl-premium-muted">Shared with @pkg.ClientName</span>
                            <span class="rl-status-pill rl-status-pill--@pkg.StatusCss">
                                @if (pkg.StatusCss == "viewed") { <i class="fas fa-circle-check"></i> }
                                else { <i class="fas fa-clock"></i> }
                                @pkg.StatusLabel
                            </span>
                            <span class="rl-premium-muted rl-premium-date">@pkg.SharedLabel</span>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="rl-bottom-grid">
        <div class="rl-insights-card">
            <div class="rl-insights-head">
                <span><i class="fas fa-lightbulb"></i> @L["Smart Insights"]</span>
            </div>
            <ul class="rl-insights-list">
                @foreach (var insight in Model.Insights)
                {
                    <li>
                        @if (!string.IsNullOrWhiteSpace(insight.TargetUrl))
                        {
                            <a href="@insight.TargetUrl" class="rl-insight-link">
                                <span class="rl-insight-icon rl-insight-icon--@insight.ColorClass"><i class="fas @insight.Icon"></i></span>
                                <span>@insight.Text</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        }
                        else
                        {
                            <span class="rl-insight-icon rl-insight-icon--@insight.ColorClass"><i class="fas @insight.Icon"></i></span>
                            <span>@insight.Text</span>
                        }
                    </li>
                }
            </ul>
        </div>
    </section>
</div>
