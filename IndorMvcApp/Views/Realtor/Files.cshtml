@model IndorMvcApp.ViewModels.RealtorFilesViewModel
@{
    ViewData["Title"] = "Property Files";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "files";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header">
        <div>
            <h1 class="rl-page-title">Property Files</h1>
            <p class="rl-page-subtitle">Track each property file from inspection to package sharing.</p>
        </div>
        <a asp-controller="RealtorPropertyFile" asp-action="Details" class="rl-btn-primary rl-btn-primary--sm">
            <i class="fas fa-plus"></i> New File
        </a>
    </div>

    <form asp-action="Files" method="get" class="rl-search-form">
        <div class="rl-search-row">
            <div class="rl-search-bar">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.SearchQuery" placeholder="Search by address, client, or file ID..." />
            </div>
            <button type="button" class="rl-filter-btn"><i class="fas fa-sliders"></i> Filter</button>
        </div>
        <div class="rl-filter-chips">
            @foreach (var chip in Model.Filters)
            {
                <a asp-action="Files" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                   class="rl-filter-chip @(Model.ActiveFilter == chip ? "is-active" : null)">@chip</a>
            }
        </div>
    </form>

    @{
        var statFilterMap = new Dictionary<string, string>
        {
            ["Active Files"] = "Active",
            ["Inspection Uploaded"] = "Inspection",
            ["Quotes In Progress"] = "Quotes",
            ["Shared Packages"] = "Shared",
            ["Closed Files"] = "Closed"
        };
        IReadOnlyList<IndorMvcApp.ViewModels.RealtorStatItemViewModel> visibleStats =
            Model.ActiveFilter == "All"
                ? Model.Stats
                : Model.Stats
                    .Where(s => statFilterMap.TryGetValue(s.Label, out var f) && f == Model.ActiveFilter)
                    .ToList();
    }
    @await Html.PartialAsync("_RealtorStatsRow", visibleStats)

    <section class="rl-dash-section">
        @if (Model.ActiveFiles.Count == 0)
        {
            if (!Model.HasAnyFiles)
            {
                <div class="rl-dash-empty">No files match your filters.</div>
            }
            else if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <div class="rl-dash-empty">No files match &ldquo;@Model.SearchQuery&rdquo;.</div>
            }
            else
            {
                var emptyMessage = Model.ActiveFilter switch
                {
                    "Active" => "No active files right now. Files in progress will show up here.",
                    "Inspection" => "No files in the inspection stage yet.",
                    "Quotes" => "No files with quotes in progress.",
                    "Shared" => "No shared packages yet. Share a file to see it here.",
                    "Closed" => "No closed files yet.",
                    _ => "No files match your filters."
                };
                <div class="rl-dash-empty">@emptyMessage</div>
            }
        }
        else
        {
            @foreach (var file in Model.ActiveFiles)
            {
                <article class="rl-file-card-v2">
                    <img src="@file.PhotoUrl" alt="" />
                    <div class="rl-file-card-body">
                        <div class="rl-file-card-top">
                            <div>
                                <strong>@file.Address</strong>
                                @if (!string.IsNullOrWhiteSpace(file.CityRegion))
                                {
                                    <span class="rl-premium-muted">@file.CityRegion</span>
                                }
                            </div>
                            <button type="button" class="rl-card-menu" aria-label="Options"><i class="fas fa-ellipsis-vertical"></i></button>
                            <span class="rl-status-pill rl-status-pill--@file.StatusCss">@file.StatusBadge</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(file.ClientName))
                        {
                            <span class="rl-premium-client"><i class="fas fa-user"></i> @file.ClientName</span>
                        }
                        <span class="rl-file-code">File ID: @file.FileCode</span>
                        @if (!string.IsNullOrWhiteSpace(file.DetailNote))
                        {
                            <span class="rl-premium-muted">@file.DetailNote</span>
                        }
                        <span class="rl-file-updated">@file.UpdatedLabel</span>
                    </div>
                    <a href="@file.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@file.ActionLabel</a>
                </article>
            }
        }
    </section>

    @if (Model.Insights.Count > 0)
    {
        <section class="rl-dash-section">
            <div class="rl-dash-section-head">
                <h2><i class="fas fa-lightbulb"></i> Smart Insights</h2>
                <a href="#">View all insights <i class="fas fa-chevron-right"></i></a>
            </div>
            <div class="rl-hscroll rl-insight-chips">
                @foreach (var insight in Model.Insights)
                {
                    <div class="rl-insight-chip rl-insight-chip--@insight.ColorClass">
                        <span class="rl-insight-icon rl-insight-icon--@insight.ColorClass"><i class="fas @insight.Icon"></i></span>
                        <span>@insight.Text</span>
                        <i class="fas fa-chevron-right"></i>
                    </div>
                }
            </div>
        </section>
    }
</div>
