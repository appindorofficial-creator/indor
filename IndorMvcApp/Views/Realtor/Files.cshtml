@model IndorMvcApp.ViewModels.RealtorFilesViewModel
@{
    ViewData["Title"] = L["Property Files"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "files";
}

<div class="rl-dash-shell rl-files-shell">
    <div class="rl-portal-page-hero">
        @await Html.PartialAsync("_RealtorTopbar", Model)

        <div class="rl-page-header rl-page-header--hero">
            <div class="rl-page-header-copy">
                <h1 class="rl-page-title">@L["Property Files"]</h1>
                <p class="rl-page-subtitle">@L["Track each property file from inspection to package sharing."]</p>
            </div>
            <a asp-controller="RealtorPropertyFile"
               asp-action="Details"
               asp-route-returnTo="files"
               class="rl-btn-primary rl-btn-primary--sm rl-page-hero-btn"
               id="rlFilesAddBtn"
               aria-label="@L["Create new property file"]">
                <i class="fas fa-plus" aria-hidden="true"></i> @L["New File"]
            </a>
        </div>

        <form asp-action="Files" method="get" class="rl-search-form">
        <div class="rl-search-row">
            <div class="rl-search-bar">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search by address, client, or file ID..."]" />
            </div>
            <div class="rl-filter-wrap">
                <button type="button" class="rl-filter-btn" id="rlFilterBtn" aria-haspopup="true" aria-expanded="false"><i class="fas fa-sliders"></i> @L["Filter"]</button>
                <div class="rl-filter-menu" id="rlFilterMenu" role="menu" hidden>
                    @foreach (var chip in Model.Filters)
                    {
                        <a asp-action="Files" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                           class="rl-filter-menu-item @(Model.ActiveFilter == chip ? "is-active" : null)" role="menuitem">
                            <span>@UiDisplayLocalization.Localize(L, chip)</span>
                            @if (Model.ActiveFilter == chip)
                            {
                                <i class="fas fa-check"></i>
                            }
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="rl-filter-chips">
            @foreach (var chip in Model.Filters)
            {
                <a asp-action="Files" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                   class="rl-filter-chip @(Model.ActiveFilter == chip ? "is-active" : null)">@UiDisplayLocalization.Localize(L, chip)</a>
            }
        </div>
    </form>
    </div>

    @{
        var statFilterMap = new Dictionary<string, string>
        {
            ["Active Files"] = "Active",
            ["Inspection Uploaded"] = "Inspection",
            ["Quotes In Progress"] = "Quotes",
            ["Shared Packages"] = "Shared",
            ["Closed Files"] = "Closed"
        };
        IReadOnlyList<IndorMvcApp.ViewModels.RealtorStatItemViewModel> visibleStats =
            Model.ActiveFilter == "All"
                ? Model.Stats
                : Model.Stats
                    .Where(s => statFilterMap.TryGetValue(s.Label, out var f) && f == Model.ActiveFilter)
                    .ToList();
    }
    @await Html.PartialAsync("_RealtorStatsRow", visibleStats)

    <section class="rl-dash-section">
        @if (Model.ActiveFiles.Count == 0)
        {
            if (!Model.HasAnyFiles)
            {
                <div class="rl-dash-empty">@L["No files match your filters."]</div>
            }
            else if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <div class="rl-dash-empty">@L.T("No files match \"{0}\".", Model.SearchQuery)</div>
            }
            else
            {
                var emptyMessage = Model.ActiveFilter switch
                {
                    "Active" => L["No active files right now. Files in progress will show up here."],
                    "Inspection" => L["No files in the inspection stage yet."],
                    "Quotes" => L["No files with quotes in progress."],
                    "Shared" => L["No shared packages yet. Share a file to see it here."],
                    "Closed" => L["No closed files yet."],
                    _ => L["No files match your filters."]
                };
                <div class="rl-dash-empty">@emptyMessage</div>
            }
        }
        else
        {
            @foreach (var file in Model.ActiveFiles)
            {
                <article class="rl-file-card-v2">
                    <img src="@file.PhotoUrl" alt="" />
                    <div class="rl-file-card-body">
                        <div class="rl-file-card-top">
                            <div>
                                <strong>@file.Address</strong>
                                @if (!string.IsNullOrWhiteSpace(file.CityRegion))
                                {
                                    <span class="rl-premium-muted">@file.CityRegion</span>
                                }
                            </div>
                            <button type="button" class="rl-card-menu" aria-label="@L["Options"]" aria-haspopup="true" aria-expanded="false"><i class="fas fa-ellipsis-vertical"></i></button>
                            <div class="rl-card-menu-dropdown" role="menu" hidden>
                                <a href="@file.ActionUrl" class="rl-card-menu-item" role="menuitem"><i class="fas fa-folder-open"></i> @L["Open file"]</a>
                                <button type="button" class="rl-card-menu-item" data-copy="@file.FileCode" role="menuitem"><i class="fas fa-copy"></i> @L["Copy File ID"]</button>
                            </div>
                            <span class="rl-status-pill rl-status-pill--@file.StatusCss">@UiDisplayLocalization.Localize(L, file.StatusBadge)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(file.ClientName))
                        {
                            <span class="rl-premium-client"><i class="fas fa-user"></i> @file.ClientName</span>
                        }
                        <span class="rl-file-code">@L.T("File ID: {0}", file.FileCode)</span>
                        @if (!string.IsNullOrWhiteSpace(file.DetailNote))
                        {
                            <span class="rl-premium-muted">@UiDisplayLocalization.Localize(L, file.DetailNote)</span>
                        }
                        <span class="rl-file-updated">@UiDisplayLocalization.Localize(L, file.UpdatedLabel)</span>
                    </div>
                    <a href="@file.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@UiDisplayLocalization.Localize(L, file.ActionLabel)</a>
                </article>
            }
        }
    </section>

    @if (Model.Insights.Count > 0)
    {
        <section class="rl-dash-section">
            <div class="rl-dash-section-head">
                <h2><i class="fas fa-lightbulb"></i> @L["Smart Insights"]</h2>
            </div>
            <div class="rl-hscroll rl-insight-chips">
                @foreach (var insight in Model.Insights)
                {
                    <div class="rl-insight-chip rl-insight-chip--@insight.ColorClass">
                        <span class="rl-insight-icon rl-insight-icon--@insight.ColorClass"><i class="fas @insight.Icon"></i></span>
                        <span>@UiDisplayLocalization.Localize(L, insight.Text)</span>
                        <i class="fas fa-chevron-right"></i>
                    </div>
                }
            </div>
        </section>
    }

    <div class="rl-toast" id="rlFilesToast" role="status" aria-live="polite" hidden></div>
</div>

@section Scripts {
<script>
    (function () {
        var fileIdCopiedTemplate = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["File ID copied: {0}"]));
        var copyFileIdPrompt = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Copy File ID:"]));

        function closeAllMenus(except) {
            document.querySelectorAll('.rl-card-menu-dropdown:not([hidden]), #rlFilterMenu:not([hidden])').forEach(function (menu) {
                if (menu === except) { return; }
                menu.hidden = true;
                var btn = menu.previousElementSibling;
                if (btn && btn.hasAttribute('aria-expanded')) {
                    btn.setAttribute('aria-expanded', 'false');
                }
            });
        }

        function toggleMenu(btn, menu) {
            var willOpen = menu.hidden;
            closeAllMenus(willOpen ? menu : null);
            menu.hidden = !willOpen;
            btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        }

        var filterBtn = document.getElementById('rlFilterBtn');
        var filterMenu = document.getElementById('rlFilterMenu');
        if (filterBtn && filterMenu) {
            filterBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                toggleMenu(filterBtn, filterMenu);
            });
        }

        document.querySelectorAll('.rl-card-menu').forEach(function (btn) {
            var menu = btn.nextElementSibling;
            if (!menu || !menu.classList.contains('rl-card-menu-dropdown')) { return; }
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                toggleMenu(btn, menu);
            });
        });

        var toast = document.getElementById('rlFilesToast');
        var toastTimer = null;
        function showToast(message) {
            if (!toast) { return; }
            toast.textContent = message;
            toast.hidden = false;
            toast.classList.add('is-visible');
            if (toastTimer) { clearTimeout(toastTimer); }
            toastTimer = setTimeout(function () {
                toast.classList.remove('is-visible');
                toastTimer = setTimeout(function () { toast.hidden = true; }, 250);
            }, 2200);
        }

        document.querySelectorAll('.rl-card-menu-item[data-copy]').forEach(function (item) {
            item.addEventListener('click', async function (e) {
                e.preventDefault();
                e.stopPropagation();
                var value = item.getAttribute('data-copy') || '';
                try {
                    await navigator.clipboard.writeText(value);
                    showToast(fileIdCopiedTemplate.replace('{0}', value));
                } catch (_) {
                    window.prompt(copyFileIdPrompt, value);
                }
                closeAllMenus(null);
            });
        });

        document.addEventListener('click', function () { closeAllMenus(null); });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeAllMenus(null); }
        });
    })();
</script>
}
