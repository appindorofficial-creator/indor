@model IndorMvcApp.ViewModels.RealtorFilesViewModel
@{
    ViewData["Title"] = "Property Files";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "files";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header">
        <div>
            <h1 class="rl-page-title">Property Files</h1>
            <p class="rl-page-subtitle">Track each property file from inspection to package sharing.</p>
        </div>
        <a asp-controller="RealtorPropertyFile" asp-action="Details" class="rl-btn-primary rl-btn-primary--sm">
            <i class="fas fa-plus"></i> New File
        </a>
    </div>

    <form asp-action="Files" method="get" class="rl-search-form">
        <div class="rl-search-row">
            <div class="rl-search-bar">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.SearchQuery" placeholder="Search by address, client, or file ID..." />
            </div>
            <div class="rl-filter-wrap">
                <button type="button" class="rl-filter-btn" id="rlFilterBtn" aria-haspopup="true" aria-expanded="false"><i class="fas fa-sliders"></i> Filter</button>
                <div class="rl-filter-menu" id="rlFilterMenu" role="menu" hidden>
                    @foreach (var chip in Model.Filters)
                    {
                        <a asp-action="Files" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                           class="rl-filter-menu-item @(Model.ActiveFilter == chip ? "is-active" : null)" role="menuitem">
                            <span>@chip</span>
                            @if (Model.ActiveFilter == chip)
                            {
                                <i class="fas fa-check"></i>
                            }
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="rl-filter-chips">
            @foreach (var chip in Model.Filters)
            {
                <a asp-action="Files" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                   class="rl-filter-chip @(Model.ActiveFilter == chip ? "is-active" : null)">@chip</a>
            }
        </div>
    </form>

    @await Html.PartialAsync("_RealtorStatsRow", Model.Stats)

    <section class="rl-dash-section">
        @if (Model.ActiveFiles.Count == 0)
        {
            <div class="rl-dash-empty">No files match your filters.</div>
        }
        else
        {
            @foreach (var file in Model.ActiveFiles)
            {
                <article class="rl-file-card-v2">
                    <img src="@file.PhotoUrl" alt="" />
                    <div class="rl-file-card-body">
                        <div class="rl-file-card-top">
                            <div>
                                <strong>@file.Address</strong>
                                @if (!string.IsNullOrWhiteSpace(file.CityRegion))
                                {
                                    <span class="rl-premium-muted">@file.CityRegion</span>
                                }
                            </div>
                            <button type="button" class="rl-card-menu" aria-label="Options" aria-haspopup="true" aria-expanded="false"><i class="fas fa-ellipsis-vertical"></i></button>
                            <div class="rl-card-menu-dropdown" role="menu" hidden>
                                <a href="@file.ActionUrl" class="rl-card-menu-item" role="menuitem"><i class="fas fa-folder-open"></i> Open file</a>
                                <button type="button" class="rl-card-menu-item" data-copy="@file.FileCode" role="menuitem"><i class="fas fa-copy"></i> Copy File ID</button>
                            </div>
                            <span class="rl-status-pill rl-status-pill--@file.StatusCss">@file.StatusBadge</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(file.ClientName))
                        {
                            <span class="rl-premium-client"><i class="fas fa-user"></i> @file.ClientName</span>
                        }
                        <span class="rl-file-code">File ID: @file.FileCode</span>
                        @if (!string.IsNullOrWhiteSpace(file.DetailNote))
                        {
                            <span class="rl-premium-muted">@file.DetailNote</span>
                        }
                        <span class="rl-file-updated">@file.UpdatedLabel</span>
                    </div>
                    <a href="@file.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@file.ActionLabel</a>
                </article>
            }
        }
    </section>

    @if (Model.Insights.Count > 0)
    {
        <section class="rl-dash-section">
            <div class="rl-dash-section-head">
                <h2><i class="fas fa-lightbulb"></i> Smart Insights</h2>
                <a href="#">View all insights <i class="fas fa-chevron-right"></i></a>
            </div>
            <div class="rl-hscroll rl-insight-chips">
                @foreach (var insight in Model.Insights)
                {
                    <div class="rl-insight-chip rl-insight-chip--@insight.ColorClass">
                        <span class="rl-insight-icon rl-insight-icon--@insight.ColorClass"><i class="fas @insight.Icon"></i></span>
                        <span>@insight.Text</span>
                        <i class="fas fa-chevron-right"></i>
                    </div>
                }
            </div>
        </section>
    }

    <div class="rl-toast" id="rlFilesToast" role="status" aria-live="polite" hidden></div>
</div>

@section Scripts {
<script>
    (function () {
        function closeAllMenus(except) {
            document.querySelectorAll('.rl-card-menu-dropdown:not([hidden]), #rlFilterMenu:not([hidden])').forEach(function (menu) {
                if (menu === except) { return; }
                menu.hidden = true;
                var btn = menu.previousElementSibling;
                if (btn && btn.hasAttribute('aria-expanded')) {
                    btn.setAttribute('aria-expanded', 'false');
                }
            });
        }

        function toggleMenu(btn, menu) {
            var willOpen = menu.hidden;
            closeAllMenus(willOpen ? menu : null);
            menu.hidden = !willOpen;
            btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        }

        var filterBtn = document.getElementById('rlFilterBtn');
        var filterMenu = document.getElementById('rlFilterMenu');
        if (filterBtn && filterMenu) {
            filterBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                toggleMenu(filterBtn, filterMenu);
            });
        }

        document.querySelectorAll('.rl-card-menu').forEach(function (btn) {
            var menu = btn.nextElementSibling;
            if (!menu || !menu.classList.contains('rl-card-menu-dropdown')) { return; }
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                toggleMenu(btn, menu);
            });
        });

        var toast = document.getElementById('rlFilesToast');
        var toastTimer = null;
        function showToast(message) {
            if (!toast) { return; }
            toast.textContent = message;
            toast.hidden = false;
            toast.classList.add('is-visible');
            if (toastTimer) { clearTimeout(toastTimer); }
            toastTimer = setTimeout(function () {
                toast.classList.remove('is-visible');
                toastTimer = setTimeout(function () { toast.hidden = true; }, 250);
            }, 2200);
        }

        document.querySelectorAll('.rl-card-menu-item[data-copy]').forEach(function (item) {
            item.addEventListener('click', async function (e) {
                e.preventDefault();
                e.stopPropagation();
                var value = item.getAttribute('data-copy') || '';
                try {
                    await navigator.clipboard.writeText(value);
                    showToast('File ID copied: ' + value);
                } catch (_) {
                    window.prompt('Copy File ID:', value);
                }
                closeAllMenus(null);
            });
        });

        document.addEventListener('click', function () { closeAllMenus(null); });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeAllMenus(null); }
        });
    })();
</script>
}
