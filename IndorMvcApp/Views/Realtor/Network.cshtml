@model IndorMvcApp.ViewModels.RealtorNearbyNetworkViewModel
@using System.Text.Json
@{
    ViewData["Title"] = L["Nearby Network"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "network";
    var isMapView = Model.ActiveView == "map";
    var mapConfigJson = isMapView && Model.HasGoogleMaps
        ? JsonSerializer.Serialize(new
        {
            center = new { lat = Model.CenterLatitude, lng = Model.CenterLongitude },
            radiusMiles = Model.RadiusMiles,
            useDeviceLocation = Model.UseDeviceLocation,
            centerLabel = Model.MapCenterLabel,
            activeFilter = Model.ActiveFilter,
            mapDataUrl = Url.Action("NetworkMapData", "Realtor"),
            providers = Model.MapProviders.Select(p => new
            {
                id = p.ProviderId,
                name = p.Name,
                category = p.Category,
                lat = p.Latitude,
                lng = p.Longitude,
                distanceMiles = p.DistanceMiles,
                verified = p.IsVerified
            }),
            listings = Model.MapPins
                .Where(p => p.PinType != "you" && p.Latitude is not null && p.Longitude is not null)
                .Select(p => new
                {
                    label = p.Label,
                    type = p.PinType,
                    lat = p.Latitude,
                    lng = p.Longitude
                }),
            i18n = new
            {
                miAway = L["{0} mi away"],
                provider = L["Provider"],
                listing = L["Listing"],
                mapUnavailable = L["Map unavailable"],
                mapsLoadFailed = L["Google Maps could not load. Check your connection and try again."]
            }
        }, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase })
        : null;
}

<div class="rl-dash-shell rl-network-page @(isMapView ? "rl-network-page--map" : "")">
    <div class="rl-portal-page-hero @(isMapView ? "rl-portal-page-hero--network-map" : "")">
        @await Html.PartialAsync("_RealtorTopbar", Model)

        <div class="rl-page-header rl-page-header--hero rl-network-head">
            <div class="rl-page-header-copy">
                <h1 class="rl-page-title">@UiDisplayLocalization.Localize(L, Model.PageTitle)</h1>
                <p class="rl-page-subtitle">@UiDisplayLocalization.Localize(L, Model.RadiusLabel)</p>
            </div>
            @if (!isMapView)
            {
                <a asp-controller="Realtor" asp-action="Profile" class="rl-btn-outline rl-btn-outline--sm rl-network-profile-btn">
                    <i class="fas fa-user"></i> @L["My Realtor Profile"]
                </a>
            }
        </div>

        <div class="rl-network-view-toggle @(isMapView ? "rl-network-view-toggle--map" : "")" role="tablist" aria-label="@L["Network view"]">
            <a asp-action="Network"
               asp-route-view="map"
               asp-route-filter="@Model.ActiveFilter"
               asp-route-q="@Model.SearchQuery"
               class="rl-network-view-btn @(Model.ActiveView == "map" ? "is-active" : null)"
               role="tab"
               aria-selected="@(Model.ActiveView == "map" ? "true" : "false")"
               data-rl-network-view="map">
                <i class="fas fa-map" aria-hidden="true"></i>
                <span class="rl-network-view-btn-label">@L["Map"]</span>
            </a>
            <a asp-action="Network"
               asp-route-view="feed"
               asp-route-filter="@Model.ActiveFilter"
               asp-route-q="@Model.SearchQuery"
               class="rl-network-view-btn @(Model.ActiveView == "feed" ? "is-active" : null)"
               role="tab"
               aria-selected="@(Model.ActiveView == "feed" ? "true" : "false")"
               data-rl-network-view="feed">
                <i class="fas fa-list" aria-hidden="true"></i>
                <span class="rl-network-view-btn-label">@L["Feed"]</span>
            </a>
        </div>

        @if (isMapView)
        {
            <div class="rl-zillow-map-filters rl-filter-chips rl-filter-chips--scroll">
                @foreach (var chip in Model.Filters)
                {
                    <a asp-action="Network"
                       asp-route-filter="@chip.Value"
                       asp-route-view="map"
                       asp-route-q="@Model.SearchQuery"
                       class="rl-filter-chip @(Model.ActiveFilter == chip.Value ? "is-active" : null)">
                        <i class="fas @chip.Icon"></i> @UiDisplayLocalization.Localize(L, chip.Label)
                    </a>
                }
            </div>
        }
        else
        {
            <form asp-action="Network" method="get" class="rl-search-form">
                <div class="rl-search-row">
                    <div class="rl-search-bar">
                        <i class="fas fa-magnifying-glass"></i>
                        <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search your network..."]" />
                    </div>
                    <input type="hidden" name="view" value="@Model.ActiveView" />
                    <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                </div>
            </form>

            <div class="rl-filter-chips rl-filter-chips--scroll rl-network-filters">
                @foreach (var chip in Model.Filters)
                {
                    <a asp-action="Network"
                       asp-route-filter="@chip.Value"
                       asp-route-view="@Model.ActiveView"
                       asp-route-q="@Model.SearchQuery"
                       class="rl-filter-chip @(Model.ActiveFilter == chip.Value ? "is-active" : null)">
                        <i class="fas @chip.Icon"></i> @UiDisplayLocalization.Localize(L, chip.Label)
                    </a>
                }
            </div>
        }
    </div>

    @if (isMapView)
    {
        @if (Model.HasGoogleMaps)
        {
            <section class="rl-zillow-map-shell" aria-label="@L["Nearby map"]">
                <div id="rlNearbyNetworkMap" class="rl-zillow-map-canvas" style="min-height:420px;" aria-busy="true">
                    <div class="rl-map-loading" role="status">
                        <span class="rl-map-loading-spinner" aria-hidden="true"></span>
                        <strong>@L["Loading map..."]</strong>
                    </div>
                </div>

                <form class="rl-zillow-map-search" id="rlMapSearchForm" autocomplete="off">
                    <div class="rl-zillow-map-search-inner">
                        <i class="fas fa-magnifying-glass"></i>
                        <input type="search"
                               id="rlMapSearchInput"
                               value="@Model.SearchQuery"
                               placeholder="@L["Search address or neighborhood"]" />
                    </div>
                    <div class="rl-zillow-map-filter-wrap">
                        <button type="button"
                                class="rl-zillow-map-filter-btn"
                                id="rlMapFilterBtn"
                                aria-haspopup="true"
                                aria-expanded="false"
                                aria-controls="rlMapFilterMenu"
                                aria-label="@L["Filters"]">
                            <i class="fas fa-sliders"></i>
                        </button>
                        <div class="rl-filter-menu rl-zillow-map-filter-menu" id="rlMapFilterMenu" role="menu" hidden>
                            @foreach (var chip in Model.Filters)
                            {
                                <a asp-action="Network"
                                   asp-route-filter="@chip.Value"
                                   asp-route-view="map"
                                   asp-route-q="@Model.SearchQuery"
                                   class="rl-filter-menu-item @(Model.ActiveFilter == chip.Value ? "is-active" : null)"
                                   role="menuitem">
                                    <span class="rl-zillow-map-filter-menu-label">
                                        <i class="fas @chip.Icon"></i>
                                        @UiDisplayLocalization.Localize(L, chip.Label)
                                    </span>
                                    @if (Model.ActiveFilter == chip.Value)
                                    {
                                        <i class="fas fa-check"></i>
                                    }
                                </a>
                            }
                        </div>
                    </div>
                </form>

                <button type="button" class="rl-zillow-map-locate" id="rlMapLocateBtn" aria-label="@L["My location"]">
                    <i class="fas fa-location-crosshairs"></i>
                </button>

                <div class="rl-zillow-map-sheet" id="rlMapBottomSheet">
                    <div class="rl-zillow-map-sheet-handle"></div>
                    <strong id="rl-map-location-label">@UiDisplayLocalization.Localize(L, Model.MapCenterLabel)</strong>
                    <span id="rl-map-location-meta">@L.T("{0} mi radius · {1} nearby", Model.RadiusMiles.ToString("0.#"), Model.MapNearbyCount)</span>
                </div>

                <script type="application/json" id="rl-network-map-data">@Html.Raw(mapConfigJson)</script>
            </section>
        }
        else
        {
            <section class="rl-network-map-panel" aria-label="@L["Nearby map"]">
                <div class="rl-network-map-stage">
                    <div class="rl-network-map-canvas rl-network-map-canvas--mock">
                        <div class="rl-network-map-radius"></div>
                        @foreach (var pin in Model.MapPins)
                        {
                            <button type="button"
                                    class="rl-network-map-pin rl-network-map-pin--@pin.PinType"
                                    style="top:@pin.TopPercent;left:@pin.LeftPercent"
                                    aria-label="@UiDisplayLocalization.Localize(L, pin.Label)"
                                    title="@UiDisplayLocalization.Localize(L, pin.Label)">
                                <i class="fas @pin.IconClass"></i>
                            </button>
                        }
                    </div>
                </div>
            </section>
        }
    }
    else
    {
        <section class="rl-quick-actions rl-quick-actions--network">
            @foreach (var action in Model.QuickActions)
            {
                <a href="@action.Url" class="rl-quick-action">
                    <span class="rl-quick-action-icon"><i class="fas @action.Icon"></i></span>
                    <span class="rl-quick-action-label">@UiDisplayLocalization.Localize(L, action.Label)</span>
                    @if (!string.IsNullOrWhiteSpace(action.Subtitle))
                    {
                        <span class="rl-quick-action-sub">@UiDisplayLocalization.Localize(L, action.Subtitle)</span>
                    }
                </a>
            }
        </section>

        <section class="rl-network-feed">
            @if (Model.FeedCards.Count == 0)
            {
                <div class="rl-dash-empty">@L["No nearby items match your filters."]</div>
            }
            else
            {
                @foreach (var card in Model.FeedCards)
                {
                    @await Html.PartialAsync("_RealtorNetworkFeedCard", card)
                }
            }
        </section>
    }
</div>

@section Scripts {
    <script>
        (function () {
            // Immediate Map/Feed feedback so the toggle doesn't feel dead while the page loads.
            document.querySelectorAll('[data-rl-network-view]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    if (btn.classList.contains('is-active') && !btn.classList.contains('is-pending')) {
                        return;
                    }

                    var toggle = btn.closest('.rl-network-view-toggle');
                    if (!toggle) {
                        return;
                    }

                    toggle.querySelectorAll('[data-rl-network-view]').forEach(function (other) {
                        other.classList.remove('is-active', 'is-pending');
                        other.setAttribute('aria-selected', 'false');
                        other.removeAttribute('aria-busy');
                    });

                    btn.classList.add('is-active', 'is-pending');
                    btn.setAttribute('aria-selected', 'true');
                    btn.setAttribute('aria-busy', 'true');
                });
            });

            function resolveShareUrl(path) {
                if (!path) {
                    return window.location.href;
                }
                if (/^https?:\/\//i.test(path)) {
                    return path;
                }
                return window.location.origin + (path.startsWith('/') ? path : '/' + path);
            }

            document.querySelectorAll('[data-network-share]').forEach(function (btn) {
                btn.addEventListener('click', async function () {
                    var sharePath = btn.getAttribute('data-share-url') || '';
                    var shareUrl = resolveShareUrl(sharePath);
                    var payload = {
                        title: btn.getAttribute('data-share-title') || document.title,
                        text: btn.getAttribute('data-share-text') || @Html.Raw(JsonSerializer.Serialize(L["View on INDOR"])),
                        url: shareUrl
                    };

                    if (navigator.share) {
                        try {
                            await navigator.share(payload);
                            return;
                        } catch (err) {
                            if (err && err.name === 'AbortError') {
                                return;
                            }
                        }
                    }

                    try {
                        await navigator.clipboard.writeText(shareUrl);
                        var original = btn.textContent;
                        btn.textContent = @Html.Raw(JsonSerializer.Serialize(L["Link copied"]));
                        window.setTimeout(function () { btn.textContent = original; }, 2000);
                    } catch (_) {
                        window.prompt(@Html.Raw(JsonSerializer.Serialize(L["Copy link:"])), shareUrl);
                    }
                });
            });

            var filterBtn = document.getElementById('rlMapFilterBtn');
            var filterMenu = document.getElementById('rlMapFilterMenu');
            if (filterBtn && filterMenu) {
                function closeMapFilterMenu() {
                    filterMenu.hidden = true;
                    filterBtn.setAttribute('aria-expanded', 'false');
                }

                filterBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var willOpen = filterMenu.hidden;
                    filterMenu.hidden = !willOpen;
                    filterBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
                });

                filterMenu.addEventListener('click', function (e) {
                    e.stopPropagation();
                });

                document.addEventListener('click', closeMapFilterMenu);
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') {
                        closeMapFilterMenu();
                    }
                });
            }
        })();
    </script>
    @if (Model.ActiveView == "map" && Model.HasGoogleMaps)
    {
        <script src="@Url.Content("~/js/realtor-nearby-network-map.js")" asp-append-version="true"></script>
        <script>
            window.setTimeout(function () {
                if (!window.rlNearbyNetworkMapReady && window.google && window.google.maps && window.rlInitNearbyNetworkMap) {
                    window.rlInitNearbyNetworkMap();
                }
            }, 8000);
        </script>
        <script async defer src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey&amp;loading=async&amp;callback=rlInitNearbyNetworkMap"></script>
    }
}
