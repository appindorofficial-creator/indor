@model IndorMvcApp.ViewModels.RealtorPublicProfileViewModel
@{
    ViewData["Title"] = "Public Profile";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "profile";
    var aboutText = !string.IsNullOrWhiteSpace(Model.Bio)
        ? Model.Bio
        : !string.IsNullOrWhiteSpace(Model.BrokerageName)
            ? $"{Model.BrokerageName} realtor serving local buyers and sellers through INDOR."
            : $"{Model.FullName} realtor serving local buyers and sellers through INDOR.";
}

<div class="rl-dash-shell rl-public-profile rl-public-profile--v2">
    <section class="rl-public-hero rl-public-hero--banner" aria-label="Public profile header">
        <a asp-controller="Realtor" asp-action="Profile" class="rl-public-hero-back" aria-label="Back to profile">
            <i class="fas fa-chevron-left"></i>
        </a>
        <span class="rl-public-hero-wave" aria-hidden="true"></span>
        <div class="rl-public-hero-main">
            <div class="rl-public-hero-photo-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                {
                    <img src="@Model.ProfilePhotoUrl" alt="" class="rl-public-hero-photo" />
                }
                else
                {
                    <span class="rl-public-hero-photo rl-public-hero-photo--placeholder"><i class="fas fa-user"></i></span>
                }
                @if (Model.IsOwnProfile)
                {
                    <a asp-controller="Realtor" asp-action="EditProfile" class="rl-public-hero-photo-edit" aria-label="Edit photo">
                        <i class="fas fa-camera"></i>
                    </a>
                }
            </div>
            <div class="rl-public-hero-info">
                <h1 class="rl-public-hero-name">@Model.FullName</h1>
                <div class="rl-public-hero-title-row">
                    <span class="rl-public-hero-title">@Model.TitleLabel</span>
                    @if (!string.IsNullOrWhiteSpace(Model.AccountStatusLabel))
                    {
                        <span class="rl-public-status-pill @Model.AccountStatusCss">@Model.AccountStatusLabel</span>
                    }
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.HeroLocationLabel))
                {
                    <p class="rl-public-hero-meta"><i class="fas fa-location-dot"></i> @Model.HeroLocationLabel</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.LicenseLabel))
                {
                    <p class="rl-public-hero-meta"><i class="fas fa-id-card"></i> @Model.LicenseLabel</p>
                }
            </div>
        </div>
        @if (Model.HeroBadges.Any(b => b.IsComplete))
        {
            <div class="rl-public-hero-badges">
                @foreach (var badge in Model.HeroBadges.Where(b => b.IsComplete))
                {
                    <span class="rl-public-hero-badge-pill is-complete">
                        <i class="fas fa-circle-check" aria-hidden="true"></i>
                        @badge.Label
                    </span>
                }
            </div>
        }
    </section>

    @if (Model.IsOwnProfile)
    {
        <section class="rl-public-actions rl-public-actions--split">
            <a asp-controller="Realtor" asp-action="EditProfile" class="rl-public-action-card rl-public-action-card--primary">
                <span class="rl-public-action-icon"><i class="fas fa-user-pen"></i></span>
                <span class="rl-public-action-copy">
                    <strong>Edit Profile</strong>
                    <small>Update photo, license, and bio</small>
                </span>
            </a>
            <button type="button" class="rl-public-action-card rl-public-action-card--secondary" id="rlPublicShareBtn">
                <span class="rl-public-action-icon"><i class="fas fa-share-from-square"></i></span>
                <span class="rl-public-action-copy">
                    <strong>Share Profile</strong>
                    <small>Share your profile link</small>
                </span>
            </button>
        </section>
    }

    @if (Model.Stats.Count > 0)
    {
        <section class="rl-public-stats" aria-label="Profile stats">
            @foreach (var stat in Model.Stats)
            {
                <div class="rl-public-stat">
                    <span class="rl-stat-icon rl-stat-icon--@stat.ColorClass"><i class="fas @stat.Icon"></i></span>
                    <strong>@stat.Count</strong>
                    <span>@stat.Label</span>
                </div>
            }
        </section>
    }

    <section class="rl-public-section rl-public-about">
        <h2>About</h2>
        <p>@aboutText</p>
        @if (!string.IsNullOrWhiteSpace(Model.LicenseLabel))
        {
            <p class="rl-public-license"><i class="fas fa-id-card"></i> @Model.LicenseLabel</p>
        }
        @if (!string.IsNullOrWhiteSpace(Model.HeroLocationLabel))
        {
            <p class="rl-public-license"><i class="fas fa-location-dot"></i> @Model.HeroLocationLabel</p>
        }
    </section>

    @if (Model.ServiceAreaChips.Count > 0)
    {
        <section class="rl-public-section">
            <h2>Service Areas</h2>
            <div class="rl-public-chips">
                @foreach (var area in Model.ServiceAreaChips)
                {
                    <span class="rl-public-chip"><i class="fas fa-location-dot"></i> @area</span>
                }
            </div>
        </section>
    }

    @if (Model.IsOwnProfile && Model.ShowVerificationPrompt && Model.VerificationSteps.Count > 0)
    {
        <section class="rl-public-verify-card">
            <img src="~/welcome-house.png" alt="" class="rl-public-verify-card-art" aria-hidden="true" />
            <div class="rl-public-verify-card-head">
                <span class="rl-public-verify-card-icon"><i class="fas fa-shield-check"></i></span>
                <div>
                    <h3>Become a Verified Realtor</h3>
                    <p>Complete your verification to build trust, improve visibility, and unlock more opportunities in INDOR.</p>
                </div>
            </div>
            <ul class="rl-public-verify-steps">
                @foreach (var step in Model.VerificationSteps)
                {
                    <li class="@(step.IsComplete ? "is-complete" : "")">
                        <span class="rl-public-verify-step-label">
                            <i class="fas @(step.IsComplete ? "fa-circle-check" : "fa-circle")"></i>
                            @step.Label
                        </span>
                        <span class="rl-public-verify-step-status">@step.StatusLabel</span>
                    </li>
                }
            </ul>
            <a asp-controller="Realtor" asp-action="EditProfileLicense" class="rl-public-verify-cta">
                Start Verification <i class="fas fa-arrow-right"></i>
            </a>
        </section>
    }

    @if (Model.ActiveListings.Count > 0)
    {
        <section class="rl-public-section">
            <div class="rl-public-section-head">
                <h2>Active Listings</h2>
                <a asp-controller="Realtor" asp-action="Network" asp-route-view="feed" asp-route-filter="Homes" class="rl-public-section-link">See all</a>
            </div>
            <div class="rl-public-carousel">
                @foreach (var listing in Model.ActiveListings)
                {
                    <article class="rl-public-listing-card">
                        <div class="rl-network-card-media">
                            @if (!string.IsNullOrWhiteSpace(listing.ImageUrl))
                            {
                                <img src="@listing.ImageUrl" alt="" class="rl-network-card-img" />
                            }
                            else
                            {
                                <div class="rl-network-card-icon-wrap"><i class="fas fa-house"></i></div>
                            }
                            @if (!string.IsNullOrWhiteSpace(listing.StatusBadge))
                            {
                                <span class="rl-network-card-badge rl-network-card-badge--listing">@listing.StatusBadge</span>
                            }
                        </div>
                        <div class="rl-network-card-body">
                            <strong class="rl-network-card-price">@listing.PriceLabel</strong>
                            @if (!string.IsNullOrWhiteSpace(listing.Address))
                            {
                                <span class="rl-network-card-sub">@listing.Address</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(listing.SpecsLabel))
                            {
                                <span class="rl-network-card-specs">@listing.SpecsLabel</span>
                            }
                            <a href="@listing.ViewUrl" class="rl-btn-outline rl-btn-outline--sm rl-public-listing-btn">View Listing</a>
                        </div>
                    </article>
                }
            </div>
        </section>
    }

    @if (Model.OpenHouses.Count > 0)
    {
        <section class="rl-public-section">
            <div class="rl-public-section-head">
                <h2>Open Houses</h2>
                <a asp-controller="Realtor" asp-action="Network" asp-route-view="feed" asp-route-filter="OpenHouses" class="rl-public-section-link">See all</a>
            </div>
            <div class="rl-public-openhouses">
                @foreach (var openHouse in Model.OpenHouses)
                {
                    <a href="@openHouse.ViewUrl" class="rl-public-openhouse-card">
                        @if (!string.IsNullOrWhiteSpace(openHouse.ImageUrl))
                        {
                            <img src="@openHouse.ImageUrl" alt="" />
                        }
                        else
                        {
                            <span class="rl-public-openhouse-placeholder"><i class="fas fa-door-open"></i></span>
                        }
                        <div>
                            <strong>@openHouse.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(openHouse.MetaLabel))
                            {
                                <span>@openHouse.MetaLabel</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(openHouse.Address))
                            {
                                <small>@openHouse.Address</small>
                            }
                        </div>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        </section>
    }

    @if (Model.SharedPackages.Count > 0)
    {
        <section class="rl-public-section">
            <div class="rl-public-section-head">
                <h2>Shared Packages</h2>
            </div>
            <p class="rl-public-section-desc">Curated packages and resources shared with clients on INDOR.</p>
            <div class="rl-public-packages">
                @foreach (var package in Model.SharedPackages)
                {
                    <article class="rl-public-package-card">
                        <span class="rl-public-package-icon"><i class="fas fa-box-archive"></i></span>
                        <strong>@package.Title</strong>
                        <span>@package.Subtitle</span>
                        <small>@package.SharedLabel · @package.StatusLabel</small>
                    </article>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var btn = document.getElementById('rlPublicShareBtn');
            if (!btn) return;
            var shareUrl = window.location.origin + '@Model.ShareUrl';
            btn.addEventListener('click', async function () {
                var payload = {
                    title: '@Model.FullName - INDOR',
                    text: 'View my realtor profile on INDOR',
                    url: shareUrl
                };
                if (navigator.share) {
                    try { await navigator.share(payload); return; } catch (_) { }
                }
                try {
                    await navigator.clipboard.writeText(shareUrl);
                    btn.querySelector('strong').textContent = 'Link copied';
                    setTimeout(function () {
                        btn.querySelector('strong').textContent = 'Share Profile';
                    }, 2000);
                } catch (_) {
                    window.prompt('Copy profile link:', shareUrl);
                }
            });
        })();
    </script>
}
