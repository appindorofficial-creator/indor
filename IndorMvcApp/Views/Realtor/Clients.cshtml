@model IndorMvcApp.ViewModels.RealtorClientsViewModel
@{
    ViewData["Title"] = L["Clients"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "clients";
    var showInvitations = Model.ActiveFilter is "Invited" or "Follow-up" or "All";
    var showClients = Model.ActiveFilter != "Invited";
    var hasInvitations = showInvitations && Model.PendingInvitations.Count > 0;
    var hasClients = showClients && Model.ActiveClients.Count > 0;
}

<div class="rl-dash-shell rl-clients-shell">
    <div class="rl-portal-page-hero">
        @await Html.PartialAsync("_RealtorTopbar", Model)

        <div class="rl-page-header rl-page-header--hero">
            <div class="rl-page-header-copy">
                <h1 class="rl-page-title">@L["Clients"]</h1>
                <p class="rl-page-subtitle">@L["Manage buyers, sellers, homeowners, and invitations."]</p>
            </div>
            <a asp-controller="RealtorInviteClient"
               asp-action="New"
               asp-route-returnTo="clients"
               class="rl-btn-primary rl-btn-primary--sm rl-page-hero-btn"
               id="rlClientsAddBtn"
               aria-label="@L["Add client — start invite wizard"]">
                <i class="fas fa-plus" aria-hidden="true"></i> @L["Add Client"]
            </a>
        </div>

        <form asp-action="Clients" method="get" class="rl-search-form">
            <div class="rl-search-row">
                <div class="rl-search-bar">
                    <i class="fas fa-magnifying-glass"></i>
                    <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search clients by name, email or phone"]" />
                </div>
                <div class="rl-filter-wrap">
                    <button type="button" class="rl-filter-btn" id="rlClientsFilterBtn" aria-haspopup="true" aria-expanded="false"><i class="fas fa-sliders"></i> @L["Filter"]</button>
                    <div class="rl-filter-menu" id="rlClientsFilterMenu" role="menu" hidden>
                        @foreach (var chip in Model.Filters)
                        {
                            <a asp-action="Clients" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                               class="rl-filter-menu-item @(Model.ActiveFilter == chip ? "is-active" : null)" role="menuitem">
                                <span>@UiDisplayLocalization.Localize(L, chip)</span>
                                @if (Model.ActiveFilter == chip)
                                {
                                    <i class="fas fa-check"></i>
                                }
                            </a>
                        }
                    </div>
                </div>
            </div>
            <div class="rl-filter-chips">
                @foreach (var chip in Model.Filters)
                {
                    <a asp-action="Clients" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                       class="rl-filter-chip @(Model.ActiveFilter == chip ? "is-active" : null)">@UiDisplayLocalization.Localize(L, chip)</a>
                }
            </div>
        </form>
    </div>

    @await Html.PartialAsync("_RealtorStatsRow", Model.Stats)

    <section class="rl-dash-section rl-clients-qa-section">
        <h2 class="rl-clients-qa-title">@L["Quick Actions"]</h2>
        <div class="rl-qa-grid">
            <a asp-controller="RealtorInviteClient" asp-action="New" asp-route-returnTo="clients" class="rl-qa-card">
                <span class="rl-qa-icon rl-qa-icon--blue"><i class="fas fa-user-plus"></i></span>
                <span class="rl-qa-label">@L["Invite Client"]</span>
                <i class="fas fa-chevron-right rl-qa-chevron"></i>
            </a>
            <a asp-controller="RealtorPropertyFile" asp-action="Details" asp-route-returnTo="clients" class="rl-qa-card">
                <span class="rl-qa-icon rl-qa-icon--green"><i class="fas fa-folder-plus"></i></span>
                <span class="rl-qa-label">@L["Create File"]</span>
                <i class="fas fa-chevron-right rl-qa-chevron"></i>
            </a>
            <a asp-controller="RealtorUrgentQuote" asp-action="Property" class="rl-qa-card">
                <span class="rl-qa-icon rl-qa-icon--purple"><i class="fas fa-file-invoice-dollar"></i></span>
                <span class="rl-qa-label">@L["New Quote"]</span>
                <i class="fas fa-chevron-right rl-qa-chevron"></i>
            </a>
        </div>
    </section>

    <section class="rl-dash-section">
        @if (hasInvitations)
        {
            @if (Model.ActiveFilter == "All")
            {
                <div class="rl-dash-section-head"><h2>@L["Pending Invitations"]</h2></div>
            }

            @foreach (var inv in Model.PendingInvitations)
            {
                <article class="rl-client-card-v2">
                    <span class="rl-client-avatar rl-client-avatar--placeholder">@inv.Initials</span>
                    <div class="rl-client-card-body">
                        <div class="rl-client-card-top">
                            <div>
                                <strong>@inv.FullName</strong>
                                <span class="rl-premium-muted">@inv.Email</span>
                            </div>
                            <span class="rl-status-pill rl-status-pill--invited">@L["Invited"]</span>
                        </div>
                        <span class="rl-premium-muted">@L.T("Sent {0}", inv.SentLabel)</span>
                        <div class="rl-client-card-foot">
                            <span class="rl-premium-muted">@L["Awaiting acceptance"]</span>
                        </div>
                    </div>
                </article>
            }
        }

        @if (hasClients)
        {
            @if (Model.ActiveFilter == "All" && hasInvitations)
            {
                <div class="rl-dash-section-head"><h2>@L["Connected Clients"]</h2></div>
            }

            @foreach (var client in Model.ActiveClients)
            {
                <article class="rl-client-card-v2">
                    @if (!string.IsNullOrWhiteSpace(client.ProfileImageUrl))
                    {
                        <img src="@client.ProfileImageUrl" alt="" class="rl-client-avatar" />
                    }
                    else
                    {
                        <span class="rl-client-avatar rl-client-avatar--placeholder">@client.Initials</span>
                    }
                    <div class="rl-client-card-body">
                        <div class="rl-client-card-top">
                            <div>
                                <strong>@client.FullName</strong>
                                <span class="rl-role-label">@UiDisplayLocalization.Localize(L, client.ClientRole)</span>
                            </div>
                            <span class="rl-status-pill rl-status-pill--@client.StatusCss">@UiDisplayLocalization.Localize(L, client.StatusBadge)</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(client.PropertyAddress))
                        {
                            <span class="rl-client-location"><i class="fas fa-location-dot"></i> @client.PropertyAddress</span>
                        }
                        <div class="rl-client-metrics">
                            @if (client.FilesCount > 0)
                            {
                                <span><i class="fas fa-folder"></i> @L.T(client.FilesCount == 1 ? "{0} File" : "{0} Files", client.FilesCount)</span>
                            }
                            @if (client.QuotesCount > 0)
                            {
                                <span><i class="fas fa-file-invoice-dollar"></i> @L.T(client.QuotesCount == 1 ? "{0} Quote" : "{0} Quotes", client.QuotesCount)</span>
                            }
                        </div>
                        <div class="rl-client-card-foot">
                            @if (string.IsNullOrWhiteSpace(client.ActionUrl) || client.ActionUrl == "#")
                            {
                                <span class="rl-btn-outline rl-btn-outline--sm rl-soon" role="button" aria-disabled="true" title="@L["Not available"]">@UiDisplayLocalization.Localize(L, client.ActionLabel)</span>
                            }
                            else
                            {
                                <a href="@client.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@UiDisplayLocalization.Localize(L, client.ActionLabel)</a>
                            }
                        </div>
                    </div>
                </article>
            }
        }

        @if (!hasInvitations && !hasClients)
        {
            if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <div class="rl-dash-empty">@L.T("No clients match \"{0}\".", Model.SearchQuery)</div>
            }
            else if (Model.ActiveFilter == "All" && !Model.HasAnyClients)
            {
                <div class="rl-clients-empty">
                    <div class="rl-clients-empty-art">
                        <i class="fas fa-address-card"></i>
                        <span class="rl-clients-empty-spark"><i class="fas fa-plus"></i></span>
                    </div>
                    <h3>@L["No clients yet"]</h3>
                    <p>@L["Start by adding your first client or sending an invitation."]</p>
                    <a asp-controller="RealtorInviteClient" asp-action="New" class="rl-btn-primary">@L["Add First Client"]</a>
                </div>
            }
            else
            {
                var emptyMessage = Model.ActiveFilter switch
                {
                    "Buyers" => L["No buyers yet. Invited buyers will show up here."],
                    "Sellers" => L["No sellers yet. Invited sellers will show up here."],
                    "Homeowners" => L["No homeowners yet. Invited homeowners will show up here."],
                    "Invited" => L["No pending invitations right now."],
                    "Connect" => L["No connected clients yet. Accepted invitations will appear here."],
                    "Follow-up" => L["No follow-ups needed right now."],
                    _ => L["No clients match your filters."]
                };
                <div class="rl-dash-empty">@emptyMessage</div>
            }
        }
    </section>

    <section class="rl-dash-section">
        <div class="rl-tips-card">
            <span class="rl-tips-icon"><i class="fas fa-lightbulb"></i></span>
            <div class="rl-tips-body">
                <strong>@L["Tips & Insights"]</strong>
                <p>@L["Invite clients and create files to keep everything organized in one place."]</p>
            </div>
            <a asp-controller="Realtor" asp-action="Files" class="rl-tips-link">@L["Learn more"] <i class="fas fa-chevron-right"></i></a>
        </div>
    </section>

    @if (Model.NextSteps.Count > 0)
    {
        <section class="rl-dash-section">
            <div class="rl-hscroll rl-next-steps">
                @foreach (var step in Model.NextSteps)
                {
                    <a href="@(step.Url ?? "#")" class="rl-next-step rl-next-step--@step.ColorClass">
                        <span class="rl-next-step-main">
                            <span class="rl-next-step-icon"><i class="fas @step.Icon" aria-hidden="true"></i></span>
                            <span class="rl-next-step-text">@UiDisplayLocalization.Localize(L, step.Text)</span>
                        </span>
                        <i class="fas fa-chevron-right" aria-hidden="true"></i>
                    </a>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
<script>
    (function () {
        var filterBtn = document.getElementById('rlClientsFilterBtn');
        var filterMenu = document.getElementById('rlClientsFilterMenu');
        if (!filterBtn || !filterMenu) {
            return;
        }

        function closeMenu() {
            filterMenu.hidden = true;
            filterBtn.setAttribute('aria-expanded', 'false');
        }

        filterBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = filterMenu.hidden;
            filterMenu.hidden = !willOpen;
            filterBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });

        document.addEventListener('click', closeMenu);
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeMenu();
            }
        });
    })();
</script>
}
