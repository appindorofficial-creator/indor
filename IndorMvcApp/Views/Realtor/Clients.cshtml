@model IndorMvcApp.ViewModels.RealtorClientsViewModel
@{
    ViewData["Title"] = "Clients";
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "clients";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header">
        <div>
            <h1 class="rl-page-title">Clients</h1>
            <p class="rl-page-subtitle">Manage buyers, sellers, homeowners, and invitations.</p>
        </div>
        <a asp-controller="RealtorInviteClient" asp-action="New" class="rl-btn-primary rl-btn-primary--sm">
            <i class="fas fa-plus"></i> Add Client
        </a>
    </div>

    <form asp-action="Clients" method="get" class="rl-search-form">
        <div class="rl-search-row">
            <div class="rl-search-bar">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.SearchQuery" placeholder="Search clients by name, email or phone" />
            </div>
            <div class="rl-filter-wrap">
                <button type="button" class="rl-filter-btn" id="rlClientsFilterBtn" aria-haspopup="true" aria-expanded="false"><i class="fas fa-sliders"></i> Filter</button>
                <div class="rl-filter-menu" id="rlClientsFilterMenu" role="menu" hidden>
                    @foreach (var chip in Model.Filters)
                    {
                        <a asp-action="Clients" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                           class="rl-filter-menu-item @(Model.ActiveFilter == chip ? "is-active" : null)" role="menuitem">
                            <span>@chip</span>
                            @if (Model.ActiveFilter == chip)
                            {
                                <i class="fas fa-check"></i>
                            }
                        </a>
                    }
                </div>
            </div>
        </div>
        <div class="rl-filter-chips">
            @foreach (var chip in Model.Filters)
            {
                <a asp-action="Clients" asp-route-filter="@chip" asp-route-q="@Model.SearchQuery"
                   class="rl-filter-chip @(Model.ActiveFilter == chip ? "is-active" : null)">@chip</a>
            }
        </div>
    </form>

    @await Html.PartialAsync("_RealtorStatsRow", Model.Stats)

    <section class="rl-dash-section">
        @if (Model.ActiveFilter == "Invited")
        {
            @if (Model.PendingInvitations.Count == 0)
            {
                if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <div class="rl-dash-empty">No invitations match &ldquo;@Model.SearchQuery&rdquo;.</div>
                }
                else
                {
                    <div class="rl-dash-empty">No pending invitations right now.</div>
                }
            }
            else
            {
                @foreach (var inv in Model.PendingInvitations)
                {
                    <article class="rl-client-card-v2">
                        <span class="rl-client-avatar rl-client-avatar--placeholder">@inv.Initials</span>
                        <div class="rl-client-card-body">
                            <div class="rl-client-card-top">
                                <div>
                                    <strong>@inv.FullName</strong>
                                    <span class="rl-premium-muted">@inv.Email</span>
                                </div>
                                <span class="rl-status-pill rl-status-pill--invited">Invited</span>
                            </div>
                            <span class="rl-premium-muted">Sent @inv.SentLabel</span>
                            <div class="rl-client-card-foot">
                                <a href="#" class="rl-btn-outline rl-btn-outline--sm">Resend</a>
                            </div>
                        </div>
                    </article>
                }
            }
        }
        else if (Model.ActiveClients.Count == 0)
        {
            if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
            {
                <div class="rl-dash-empty">No clients match &ldquo;@Model.SearchQuery&rdquo;.</div>
            }
            else if (Model.ActiveFilter == "All" && !Model.HasAnyClients)
            {
                <div class="rl-dash-empty">No clients match your filters.</div>
            }
            else
            {
                var emptyMessage = Model.ActiveFilter switch
                {
                    "Buyers" => "No buyers yet. Invited buyers will show up here.",
                    "Sellers" => "No sellers yet. Invited sellers will show up here.",
                    "Homeowners" => "No homeowners yet. Invited homeowners will show up here.",
                    "Connect" => "No connected clients yet. Accepted invitations will appear here.",
                    "Follow-up" => "No follow-ups needed right now.",
                    _ => "No clients match your filters."
                };
                <div class="rl-dash-empty">@emptyMessage</div>
            }
        }
        else
        {
            @foreach (var client in Model.ActiveClients)
            {
                <article class="rl-client-card-v2">
                    @if (!string.IsNullOrWhiteSpace(client.ProfileImageUrl))
                    {
                        <img src="@client.ProfileImageUrl" alt="" class="rl-client-avatar" />
                    }
                    else
                    {
                        <span class="rl-client-avatar rl-client-avatar--placeholder">@client.Initials</span>
                    }
                    <div class="rl-client-card-body">
                        <div class="rl-client-card-top">
                            <div>
                                <strong>@client.FullName</strong>
                                <span class="rl-role-label">@client.ClientRole</span>
                            </div>
                            <button type="button" class="rl-card-menu" aria-label="Options"><i class="fas fa-ellipsis-vertical"></i></button>
                            <span class="rl-status-pill rl-status-pill--@client.StatusCss">@client.StatusBadge</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(client.PropertyAddress))
                        {
                            <span class="rl-client-location"><i class="fas fa-location-dot"></i> @client.PropertyAddress</span>
                        }
                        <div class="rl-client-metrics">
                            @if (client.FilesCount > 0)
                            {
                                <span><i class="fas fa-folder"></i> @client.FilesCount File@(client.FilesCount == 1 ? "" : "s")</span>
                            }
                            @if (client.QuotesCount > 0)
                            {
                                <span><i class="fas fa-file-invoice-dollar"></i> @client.QuotesCount Quote@(client.QuotesCount == 1 ? "" : "s")</span>
                            }
                        </div>
                        <div class="rl-client-card-foot">
                            <a href="@client.ActionUrl" class="rl-btn-outline rl-btn-outline--sm">@client.ActionLabel</a>
                        </div>
                    </div>
                </article>
            }
        }
    </section>

    @if (Model.NextSteps.Count > 0)
    {
        <section class="rl-dash-section">
            <div class="rl-hscroll rl-next-steps">
                @foreach (var step in Model.NextSteps)
                {
                    <a href="@(step.Url ?? "#")" class="rl-next-step rl-next-step--@step.ColorClass">
                        <span class="rl-next-step-icon"><i class="fas @step.Icon"></i></span>
                        <span>@step.Text</span>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        </section>
    }
</div>

@section Scripts {
<script>
    (function () {
        var filterBtn = document.getElementById('rlClientsFilterBtn');
        var filterMenu = document.getElementById('rlClientsFilterMenu');
        if (!filterBtn || !filterMenu) {
            return;
        }

        function closeMenu() {
            filterMenu.hidden = true;
            filterBtn.setAttribute('aria-expanded', 'false');
        }

        filterBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = filterMenu.hidden;
            filterMenu.hidden = !willOpen;
            filterBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });

        document.addEventListener('click', closeMenu);
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeMenu();
            }
        });
    })();
</script>
}
