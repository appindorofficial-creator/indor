@model IndorMvcApp.ViewModels.RealtorNetworkListingWizardViewModel

<div class="rl-listing-wizard-topnav">
    @if (Model.DisplayStep == 0)
    {
        <a asp-action="Network" class="rl-listing-wizard-back" aria-label="@L["Back to feed"]">
            <i class="fas fa-chevron-left"></i>
        </a>
    }
    else if (Model.DisplayStep == 1)
    {
        <a asp-action="CreateNetworkListing" class="rl-listing-wizard-back" aria-label="@L["Back"]">
            <i class="fas fa-chevron-left"></i>
        </a>
    }
    else
    {
        <a asp-action="PostListingBenefits" class="rl-listing-wizard-back" aria-label="@L["Back"]">
            <i class="fas fa-chevron-left"></i>
        </a>
    }
    <div class="rl-listing-wizard-topnav-title">
        <h1 class="rl-listing-wizard-title">@Model.Title</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
        {
            <p class="rl-listing-wizard-sub">@Model.Subtitle</p>
        }
    </div>
</div>
