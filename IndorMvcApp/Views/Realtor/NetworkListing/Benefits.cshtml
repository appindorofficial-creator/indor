@model IndorMvcApp.ViewModels.RealtorNetworkListingWizardViewModel

<section class="rl-listing-benefits">
    <div class="rl-listing-benefits-intro">
        <h2 class="rl-listing-section-label">@L["Why post your listing on INDOR?"]</h2>
        <p class="rl-listing-lead">@L["INDOR connects your property with nearby buyers, renters, and realtors who are ready to act."]</p>
    </div>

    <div class="rl-listing-benefit-list">
        <article class="rl-listing-benefit-row">
            <span class="rl-listing-benefit-icon"><i class="fas fa-location-dot"></i></span>
            <div>
                <strong>@L["Local exposure"]</strong>
                <span>@L["Your listing is seen by people actively searching in your area."]</span>
            </div>
        </article>
        <article class="rl-listing-benefit-row">
            <span class="rl-listing-benefit-icon"><i class="fas fa-heart"></i></span>
            <div>
                <strong>@L["Direct interest from buyers and renters"]</strong>
                <span>@L["Get inquiries from motivated people looking for properties like yours."]</span>
            </div>
        </article>
        <article class="rl-listing-benefit-row">
            <span class="rl-listing-benefit-icon"><i class="fas fa-users"></i></span>
            <div>
                <strong>@L["Nearby Network visibility"]</strong>
                <span>@L["Realtors in the INDOR network can see and share your listing with qualified clients."]</span>
            </div>
        </article>
        <article class="rl-listing-benefit-row">
            <span class="rl-listing-benefit-icon"><i class="fas fa-headset"></i></span>
            <div>
                <strong>@L["INDOR Realtor support"]</strong>
                <span>@L["Our team is here to help you get more visibility and better results."]</span>
            </div>
        </article>
    </div>

    <h3 class="rl-listing-section-label">@L["INDOR Programs"]</h3>
    <div class="rl-listing-program-grid rl-listing-program-grid--3">
        <article class="rl-listing-program-card">
            <i class="fas fa-house"></i>
            <strong>@L["Open House Promotion"]</strong>
            <span>@L["We help promote your open house to nearby buyers and renters."]</span>
        </article>
        <article class="rl-listing-program-card">
            <i class="fas fa-handshake"></i>
            <strong>@L["Lead Support"]</strong>
            <span>@L["We follow up with inquiries so you can focus on closing."]</span>
        </article>
        <article class="rl-listing-program-card">
            <i class="fas fa-city"></i>
            <strong>@L["Neighborhood Visibility"]</strong>
            <span>@L["Your listing appears in neighborhood feeds and alerts."]</span>
        </article>
    </div>

    <div class="rl-info-box rl-info-box--muted rl-listing-privacy">
        <i class="fas fa-shield-halved"></i>
        <p>@L["For your privacy and safety, all contact happens through INDOR messaging — not public phone numbers."]</p>
    </div>

    <footer class="rl-listing-benefits-footer">
        <a asp-action="CreateNetworkListing" class="rl-listing-btn-primary">@L["Start posting"]</a>
    </footer>
</section>
