@model IndorMvcApp.ViewModels.RealtorNetworkListingWizardViewModel

<section class="rl-listing-intro">
    <div class="rl-listing-hero rl-listing-hero--split">
        <div class="rl-listing-hero-copy-block">
            <h2 class="rl-listing-hero-title">@L["List smarter."] <span class="rl-listing-hero-accent">@L["Reach closer."]</span></h2>
            <p class="rl-listing-hero-copy">
                INDOR connects your listing with nearby buyers and renters who are actively looking.
            </p>
        </div>
        <div class="rl-listing-hero-visual rl-listing-hero-visual--frame">
            <span class="rl-listing-hero-blob" aria-hidden="true"></span>
            <img src="~/welcome-house.png" alt="" class="rl-listing-hero-img" />
            <span class="rl-listing-hero-pin"><i class="fas fa-location-dot"></i></span>
        </div>
    </div>

    <div class="rl-listing-feature-grid rl-listing-feature-grid--3">
        <article class="rl-listing-feature-card">
            <span class="rl-listing-feature-icon"><i class="fas fa-location-crosshairs"></i></span>
            <strong>@L["Reach nearby homeowners"]</strong>
            <span>@L["Your listing is shown to people living and moving nearby."]</span>
        </article>
        <article class="rl-listing-feature-card">
            <span class="rl-listing-feature-icon"><i class="fas fa-user-check"></i></span>
            <strong>@L["Get qualified leads"]</strong>
            <span>@L["Connect with serious buyers and renters ready to take action."]</span>
        </article>
        <article class="rl-listing-feature-card">
            <span class="rl-listing-feature-icon"><i class="fas fa-bullhorn"></i></span>
            <strong>@L["Promote open houses and listings in your area"]</strong>
            <span>@L["Boost visibility for your listings and events nearby."]</span>
        </article>
    </div>

    <div class="rl-listing-help-section rl-listing-help-card">
        <h3>@L["How INDOR helps"]</h3>
        <ul class="rl-listing-help-list rl-listing-help-list--divided">
            <li>
                <i class="fas fa-circle-check"></i>
                <div>
                    <strong>@L["Show your listing within 3 miles of nearby users"]</strong>
                    <span>@L["Reach people who live, own, or are looking to move nearby."]</span>
                </div>
            </li>
            <li>
                <i class="fas fa-circle-check"></i>
                <div>
                    <strong>@L["Connect buyers and renters directly through INDOR messaging"]</strong>
                    <span>@L["Communicate in-app and respond faster."]</span>
                </div>
            </li>
            <li>
                <i class="fas fa-circle-check"></i>
                <div>
                    <strong>@L["Gain visibility inside the Neighborhood / Nearby Network"]</strong>
                    <span>@L["Be seen by a trusted local network that drives results."]</span>
                </div>
            </li>
        </ul>
    </div>

    <footer class="rl-listing-intro-footer">
        <a asp-action="PostListingBenefits" class="rl-listing-btn-primary">@L["Continue"]</a>
        <a asp-action="Network" class="rl-listing-btn-secondary">@L["Back to Feed"]</a>
    </footer>
</section>
