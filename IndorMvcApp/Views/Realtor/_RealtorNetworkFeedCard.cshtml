@model IndorMvcApp.ViewModels.RealtorNetworkFeedCardViewModel
@if (Model.CardType == "mypost")
{
    <article class="rl-network-card rl-network-card--mypost">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <div class="rl-network-card-media">
                <img src="@Url.Content("~" + Model.ImageUrl)" alt="" class="rl-network-card-img" />
                <span class="rl-network-card-badge rl-network-card-badge--@Model.BadgeCss">@UiDisplayLocalization.Localize(L, Model.BadgeLabel)</span>
            </div>
        }

        <div class="rl-network-card-body">
            <div class="rl-network-card-head">
                <div class="rl-network-card-copy">
                    <strong class="rl-network-card-title">@UiDisplayLocalization.Localize(L, Model.Title)</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                    {
                        <span class="rl-network-card-sub">@UiDisplayLocalization.Localize(L, Model.Subtitle)</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.MetaLabel))
                    {
                        <span class="rl-network-card-meta rl-network-card-meta--address">
                            <i class="fas fa-location-dot"></i> @Model.MetaLabel
                        </span>
                    }
                </div>
                <div class="rl-network-card-side">
                    @if (!string.IsNullOrWhiteSpace(Model.StatusBadge))
                    {
                        <span class="rl-network-status rl-network-status--@Model.StatusCss">@Model.StatusBadge</span>
                    }
                </div>
            </div>

            <div class="rl-network-card-actions">
                @if (string.IsNullOrWhiteSpace(Model.PrimaryActionUrl) || Model.PrimaryActionUrl == "#")
                {
                    <span class="rl-btn-outline rl-btn-outline--sm rl-soon" role="button" aria-disabled="true" title="@L["Not available"]"><span>@UiDisplayLocalization.Localize(L, Model.PrimaryActionLabel)</span><i class="fas fa-lock rl-soon-lock" aria-hidden="true"></i></span>
                }
                else
                {
                    <a href="@Model.PrimaryActionUrl" class="rl-btn-outline rl-btn-outline--sm">@Model.PrimaryActionLabel</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SecondaryActionLabel))
                {
                    if (Model.SecondaryActionOpensShare && !string.IsNullOrWhiteSpace(Model.SecondaryActionUrl) && Model.SecondaryActionUrl != "#")
                    {
                        var shareText = !string.IsNullOrWhiteSpace(Model.Subtitle)
                            ? $"Open house: {Model.Subtitle}"
                            : "Open house on INDOR";
                        <button type="button"
                                class="rl-btn-primary rl-btn-primary--sm"
                                data-network-share
                                data-share-url="@Model.SecondaryActionUrl"
                                data-share-title="@Model.Title"
                                data-share-text="@shareText">
                            @UiDisplayLocalization.Localize(L, Model.SecondaryActionLabel)
                        </button>
                    }
                    else if (string.IsNullOrWhiteSpace(Model.SecondaryActionUrl) || Model.SecondaryActionUrl == "#")
                    {
                        <span class="rl-btn-primary rl-btn-primary--sm rl-soon" role="button" aria-disabled="true" title="@L["Not available"]"><span>@UiDisplayLocalization.Localize(L, Model.SecondaryActionLabel)</span><i class="fas fa-lock rl-soon-lock" aria-hidden="true"></i></span>
                    }
                    else
                    {
                        <a href="@Model.SecondaryActionUrl" class="rl-btn-primary rl-btn-primary--sm">@Model.SecondaryActionLabel</a>
                    }
                }
            </div>
        </div>
    </article>
}
else
{
<article class="rl-network-card rl-network-card--@Model.CardType">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <div class="rl-network-card-media">
            <img src="@Url.Content("~" + Model.ImageUrl)" alt="" class="rl-network-card-img" />
            <span class="rl-network-card-badge rl-network-card-badge--@Model.BadgeCss">@UiDisplayLocalization.Localize(L, Model.BadgeLabel)</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model.IconClass))
    {
        <div class="rl-network-card-icon-wrap rl-network-card-icon-wrap--@Model.BadgeCss">
            <span class="rl-network-card-badge rl-network-card-badge--@Model.BadgeCss">@UiDisplayLocalization.Localize(L, Model.BadgeLabel)</span>
            <i class="fas @Model.IconClass"></i>
        </div>
    }

    <div class="rl-network-card-body">
        <div class="rl-network-card-head">
            <div class="rl-network-card-copy">
                @if (!string.IsNullOrWhiteSpace(Model.PriceLabel))
                {
                    <strong class="rl-network-card-price">@Model.PriceLabel</strong>
                }
                <strong class="rl-network-card-title">@UiDisplayLocalization.Localize(L, Model.Title)</strong>
                @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                {
                    <span class="rl-network-card-sub">@UiDisplayLocalization.Localize(L, Model.Subtitle)</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SpecsLabel))
                {
                    <span class="rl-network-card-specs">@UiDisplayLocalization.Localize(L, Model.SpecsLabel)</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.MetaLabel))
                {
                    <span class="rl-network-card-meta">@Model.MetaLabel</span>
                }
                @if (Model.Tags.Count > 0)
                {
                    <div class="rl-network-card-tags">
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="rl-network-tag">@tag</span>
                        }
                    </div>
                }
            </div>
            <div class="rl-network-card-side">
                @if (!string.IsNullOrWhiteSpace(Model.StatusBadge))
                {
                    <span class="rl-network-status rl-network-status--@Model.StatusCss">@UiDisplayLocalization.Localize(L, Model.StatusBadge)</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.DistanceLabel))
                {
                    <span class="rl-network-distance"><i class="fas fa-location-dot"></i> @Model.DistanceLabel</span>
                }
            </div>
        </div>

            <div class="rl-network-card-actions">
                @if (string.IsNullOrWhiteSpace(Model.PrimaryActionUrl) || Model.PrimaryActionUrl == "#")
                {
                    <span class="rl-btn-outline rl-btn-outline--sm rl-soon" role="button" aria-disabled="true" title="@L["Not available"]"><span>@UiDisplayLocalization.Localize(L, Model.PrimaryActionLabel)</span><i class="fas fa-lock rl-soon-lock" aria-hidden="true"></i></span>
                }
                else
                {
                    <a href="@Model.PrimaryActionUrl" class="rl-btn-outline rl-btn-outline--sm">@Model.PrimaryActionLabel</a>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SecondaryActionLabel))
                {
                    if (Model.SecondaryActionOpensShare && !string.IsNullOrWhiteSpace(Model.SecondaryActionUrl) && Model.SecondaryActionUrl != "#")
                    {
                        var shareText = !string.IsNullOrWhiteSpace(Model.Subtitle)
                            ? $"Open house: {Model.Subtitle}"
                            : "Open house on INDOR";
                        <button type="button"
                                class="rl-btn-primary rl-btn-primary--sm"
                                data-network-share
                                data-share-url="@Model.SecondaryActionUrl"
                                data-share-title="@Model.Title"
                                data-share-text="@shareText">
                            @UiDisplayLocalization.Localize(L, Model.SecondaryActionLabel)
                        </button>
                    }
                    else if (string.IsNullOrWhiteSpace(Model.SecondaryActionUrl) || Model.SecondaryActionUrl == "#")
                    {
                        <span class="rl-btn-primary rl-btn-primary--sm rl-soon" role="button" aria-disabled="true" title="@L["Not available"]"><span>@UiDisplayLocalization.Localize(L, Model.SecondaryActionLabel)</span><i class="fas fa-lock rl-soon-lock" aria-hidden="true"></i></span>
                    }
                    else
                    {
                        <a href="@Model.SecondaryActionUrl" class="rl-btn-primary rl-btn-primary--sm">@Model.SecondaryActionLabel</a>
                    }
                }
            </div>
    </div>
</article>
}
