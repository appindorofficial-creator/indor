@model IndorMvcApp.ViewModels.RealtorNetworkLeadDetailViewModel
@{
    ViewData["Title"] = L["Buyer Lead"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "network";
}

<div class="rl-dash-shell rl-listing-detail-page">
    <header class="rl-listing-detail-head">
        <a asp-action="Network" asp-route-view="feed" asp-route-filter="Leads" class="rl-listing-detail-back" aria-label="@L["Back to Nearby Network"]">
            <i class="fas fa-chevron-left"></i>
        </a>
        <div class="rl-listing-detail-head-copy">
            <h1>@L["Buyer Lead"]</h1>
            <p>@L["Nearby Network"]</p>
        </div>
    </header>

    <section class="rl-listing-detail-card">
        <div class="rl-network-card-icon-wrap rl-network-card-icon-wrap--lead">
            <span class="rl-network-card-badge rl-network-card-badge--lead">@L["NEW LEAD"]</span>
            <i class="fas fa-users"></i>
        </div>

        <div class="rl-listing-detail-summary">
            <div class="rl-listing-detail-summary-top">
                <div>
                    <strong class="rl-listing-detail-address">@Model.Title</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
                    {
                        <p class="rl-listing-detail-specs">@UiDisplayLocalization.Localize(L, Model.Subtitle)</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.SpecsLabel))
                    {
                        <p class="rl-listing-detail-specs">@UiDisplayLocalization.Localize(L, Model.SpecsLabel)</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.MetaLabel))
                    {
                        <p class="rl-listing-detail-specs">@Model.MetaLabel</p>
                    }
                    <span class="rl-listing-detail-distance"><i class="fas fa-location-dot"></i> @UiDisplayLocalization.Localize(L, Model.DistanceLabel)</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.StatusBadge))
                {
                    <span class="rl-network-status rl-network-status--@Model.StatusCss">@UiDisplayLocalization.Localize(L, Model.StatusBadge)</span>
                }
            </div>
        </div>
    </section>

    @if (Model.InterestRecorded)
    {
        <div class="rl-qshare-success">
            <i class="fas fa-circle-check"></i>
            <strong>@L["Contact request saved"]</strong>
            <p>@L["INDOR recorded your follow-up on this buyer lead."]</p>
        </div>
    }

    @if (Model.ShowContactPanel)
    {
        <section class="rl-listing-detail-card">
            <h3>@L["Contact this buyer"]</h3>
            @if (!string.IsNullOrWhiteSpace(Model.BuyerName))
            {
                <p><strong>@Model.BuyerName</strong></p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.BuyerEmail))
            {
                <p class="rl-premium-muted">@Model.BuyerEmail</p>
            }

            <div class="rl-listing-detail-actions">
                @if (Model.RelatedClientId is > 0)
                {
                    <a asp-action="ClientDetail" asp-route-id="@Model.RelatedClientId" class="rl-btn-primary rl-btn-primary--sm">
                        <i class="fas fa-comment-dots"></i> @L["Open Client Profile"]
                    </a>
                }
                else if (Model.InterestRecorded)
                {
                    <span class="rl-btn-primary rl-btn-primary--sm rl-btn-primary--disabled" aria-disabled="true">
                        <i class="fas fa-check"></i> @L["Intro requested"]
                    </span>
                }
                else if (!string.IsNullOrWhiteSpace(Model.ContactUrl))
                {
                    <form asp-action="RequestNetworkLeadIntro" asp-route-id="@Model.ItemId" method="post" class="rl-inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="rl-btn-primary rl-btn-primary--sm">
                            <i class="fas fa-envelope"></i> @UiDisplayLocalization.Localize(L, Model.ContactActionLabel)
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="RequestNetworkLeadIntro" asp-route-id="@Model.ItemId" method="post" class="rl-inline-form">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="rl-btn-primary rl-btn-primary--sm">
                            <i class="fas fa-comment-dots"></i> @L["Request Intro"]
                        </button>
                    </form>
                }
            </div>
        </section>
    }

    <div class="rl-listing-detail-actions">
        @if (!Model.ShowContactPanel && !Model.InterestRecorded)
        {
            <a asp-action="ViewNetworkLead" asp-route-id="@Model.ItemId" asp-route-contact="true" class="rl-btn-primary rl-btn-primary--sm">
                <i class="fas fa-comment-dots"></i> @L["Contact Buyer"]
            </a>
        }
        <a asp-action="Network" asp-route-view="feed" asp-route-filter="Leads" class="rl-btn-outline rl-btn-outline--sm">@L["Back to Leads"]</a>
    </div>
</div>
