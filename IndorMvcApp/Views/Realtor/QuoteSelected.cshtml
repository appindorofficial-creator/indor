@model IndorMvcApp.ViewModels.RealtorQuoteSelectedViewModel
@{
    ViewData["Title"] = L["Quote Selected"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "quotes";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <div class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Quotes" class="rl-back-link"><i class="fas fa-chevron-left"></i> @L["Quotes"]</a>
        <h1 class="rl-page-title">@L["Quote Selected"]</h1>
        <p class="rl-page-subtitle">@L["You've selected a quote. Here are your next steps."]</p>
    </div>

    <div class="rl-qsel-success">
        <i class="fas fa-circle-check"></i>
    </div>

    <div class="rl-qsel-hero">
        <img src="@Model.PhotoUrl" alt="" />
        <div>
            <strong>@Model.Address</strong>
            <span class="rl-status-pill rl-status-pill--selected">Selected: @Model.ProviderName</span>
            <span class="rl-premium-muted">@L["Total Approved Amount"]</span>
            <strong class="rl-qsel-amount">@Model.TotalAmountLabel</strong>
        </div>
    </div>

    <div class="rl-qview-metrics rl-qview-metrics--3">
        <div>
            <i class="fas fa-calendar-days rl-metric-icon rl-metric-icon--blue"></i>
            <span>@L["Approved Date"]</span>
            <strong>@Model.ApprovedLabel</strong>
        </div>
        <div>
            <i class="fas fa-clock rl-metric-icon rl-metric-icon--purple"></i>
            <span>@L["Estimated Timeline"]</span>
            <strong>@Model.TimelineLabel</strong>
        </div>
        <div>
            <i class="fas fa-shield-halved rl-metric-icon rl-metric-icon--green"></i>
            <span>@L["Warranty"]</span>
            <strong>@Model.WarrantyLabel</strong>
        </div>
    </div>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head"><h2>@L["Next Steps"]</h2></div>
        <ul class="rl-qsel-steps">
            @foreach (var step in Model.NextSteps)
            {
                <li>
                    <span class="rl-qsel-step-icon"><i class="fas @step.Icon"></i></span>
                    <span>@step.Label</span>
                    <span class="rl-qsel-step-check"></span>
                </li>
            }
        </ul>
    </section>

    <div class="rl-qview-actions">
        <button type="button" class="ob-btn ob-btn-primary rl-qview-btn"><i class="fas fa-calendar-days"></i> @L["Schedule Work"]</button>
        <a href="@Model.ViewQuoteUrl" class="rl-btn-outline rl-qview-btn">@L["View Selected Quote"]</a>
        <button type="button" class="rl-btn-outline rl-qview-btn"><i class="fas fa-file-invoice-dollar"></i> @L["Create Invoice"]</button>
    </div>
</div>
