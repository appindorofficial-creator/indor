@model IndorMvcApp.ViewModels.RealtorPortalShellViewModel
@{
    ViewData["Title"] = L["Account Settings"];
    Layout = "_RealtorLayout";
    ViewBag.NavActive = "profile";
}

<div class="rl-dash-shell rl-dash-shell--profile">
    @await Html.PartialAsync("_RealtorTopbar", Model)

    <header class="rl-page-header rl-page-header--stack">
        <a asp-controller="Realtor" asp-action="Profile" class="rl-network-back" aria-label="@L["Back to profile"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="rl-page-title">@L["Account Settings"]</h1>
            <p class="rl-page-subtitle">@L["Update your preferences and security settings."]</p>
        </div>
    </header>

    <nav class="rl-profile-nav">
        <a asp-controller="Realtor" asp-action="Profile" asp-fragment="rl-notify-form" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-bell"></i></span>
            <div>
                <strong>@L["Notifications"]</strong>
                <span class="rl-profile-nav-desc">@L["Manage alerts for clients, files, and quote updates."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="RealtorRegistration" asp-action="Verification" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-shield-halved"></i></span>
            <div>
                <strong>@L["Verification"]</strong>
                <span class="rl-profile-nav-desc">@L["Upload license and ID to unlock the Verified Realtor badge."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Perfil" asp-action="Opciones" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-key"></i></span>
            <div>
                <strong>@L["Password & Security"]</strong>
                <span class="rl-profile-nav-desc">@L["Update your password and security preferences."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Account" asp-action="Terms" asp-route-from="realtor-support" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-scale-balanced"></i></span>
            <div>
                <strong>@L["Terms &amp; Conditions"]</strong>
                <span class="rl-profile-nav-desc">@L["Review INDOR platform terms for real estate professionals."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Account" asp-action="Privacy" asp-route-from="realtor-support" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-user-shield"></i></span>
            <div>
                <strong>@L["Privacy Policy"]</strong>
                <span class="rl-profile-nav-desc">@L["How INDOR handles your account and client data."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Account" asp-action="DeleteAccount" class="rl-profile-nav-item">
            <span class="rl-profile-nav-icon"><i class="fas fa-user-xmark"></i></span>
            <div>
                <strong>@L["Delete account"]</strong>
                <span class="rl-profile-nav-desc">@L["Permanently remove your INDOR account and data."]</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    <section class="rl-settings-card">
        <div class="rl-settings-head">
            <span><i class="fas fa-headset"></i> @L["Need help?"]</span>
        </div>
        <p class="rl-support-copy">@L["Contact INDOR support at"] <a href="mailto:support@homeindor.com">support@homeindor.com</a>.</p>
    </section>
</div>
