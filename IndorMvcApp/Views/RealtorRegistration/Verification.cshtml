@using IndorMvcApp.Models
@model IndorMvcApp.ViewModels.RealtorRegistrationStepViewModel
@{
    var slots = ViewBag.DocumentSlots as IReadOnlyList<IndorMvcApp.ViewModels.RealtorDocumentSlotViewModel>
        ?? new List<IndorMvcApp.ViewModels.RealtorDocumentSlotViewModel>();
    var licenseNumber = ViewBag.LicenseNumber as string ?? Model.State.LicenseNumber;
    var uploadFields = new (string DocumentType, string InputName, string Label)[]
    {
        (RealtorDocumentTypes.LicensePhoto, "licensePhotoFile", "License photo"),
        (RealtorDocumentTypes.GovernmentId, "governmentIdFile", "Government ID"),
        (RealtorDocumentTypes.BusinessCard, "businessCardFile", "Business card (optional)")
    };
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

@if (!string.IsNullOrWhiteSpace(licenseNumber))
{
    <div class="rl-success-banner">
        <i class="fas fa-circle-check"></i>
        <span>Saved in Step 2 — License number: <strong>@licenseNumber</strong></span>
    </div>
}

@if (TempData["VerificationError"] is string verificationError && !string.IsNullOrWhiteSpace(verificationError))
{
    <div class="rl-error-banner" role="alert">
        <i class="fas fa-triangle-exclamation"></i>
        <span>@verificationError</span>
    </div>
}
<div class="rl-error-banner is-hidden" id="verificationClientError" role="alert">
    <i class="fas fa-triangle-exclamation"></i>
    <span id="verificationClientErrorText"></span>
</div>

@foreach (var slot in slots)
{
    <div class="rl-doc-card" data-doc-card="@slot.DocumentType">
        <div class="rl-doc-card-icon"><i class="fas fa-id-card"></i></div>
        <div>
            <strong>@slot.Label</strong>
            @if (!slot.Required) { <small>Optional</small> }
            @if (slot.Uploaded)
            {
                <span class="rl-doc-uploaded" data-uploaded-badge><i class="fas fa-check"></i> Uploaded</span>
            }
        </div>
    </div>
}

<form asp-action="Verification" method="post" enctype="multipart/form-data" class="rl-reg-form" id="rlVerificationForm">
    @Html.AntiForgeryToken()

    @foreach (var field in uploadFields)
    {
        var slot = slots.FirstOrDefault(s => s.DocumentType.Equals(field.DocumentType, StringComparison.OrdinalIgnoreCase));
        var uploaded = slot?.Uploaded == true && !string.IsNullOrWhiteSpace(slot.FileUrl);
        var uploadedName = uploaded ? System.IO.Path.GetFileName(slot!.FileUrl!) : null;
        var isImage = uploaded
            && (slot!.FileUrl!.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
                || slot.FileUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                || slot.FileUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
                || slot.FileUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));

        <div class="rl-doc-upload" data-doc-type="@field.DocumentType" data-required="@(slot?.Required == true ? "true" : "false")">
            <span class="rl-doc-upload-label">@field.Label</span>

            <div class="rl-file-attached @(uploaded ? null : "is-hidden")" data-role="attached">
                @if (isImage)
                {
                    <img src="@slot!.FileUrl" alt="" class="rl-file-preview-thumb rl-file-attached-thumb" />
                }
                else
                {
                    <span class="rl-file-preview-icon rl-file-attached-icon"><i class="fas fa-file-pdf"></i></span>
                }
                <span class="rl-file-attached-name">@uploadedName</span>
                <button type="submit"
                        name="action"
                        value="remove"
                        class="rl-file-remove-btn rl-file-remove-uploaded"
                        data-document-type="@field.DocumentType"
                        aria-label="Remove @field.Label">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>

            <div class="rl-file-pending is-hidden" data-role="pending">
                <img src="" alt="" class="rl-file-preview-thumb rl-file-pending-thumb is-hidden" />
                <span class="rl-file-preview-icon rl-file-pending-icon is-hidden"><i class="fas fa-file"></i></span>
                <span class="rl-file-pending-name"></span>
                <button type="button" class="rl-file-remove-btn rl-file-pending-remove" aria-label="Remove selected file">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>

            <label class="rl-file-picker @(uploaded ? "is-hidden" : null)" data-role="picker">
                <input type="file"
                       id="@field.InputName"
                       name="@field.InputName"
                       class="rl-file-picker-input"
                       accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" />
                <span class="rl-file-picker-btn">Choose file</span>
                <span class="rl-file-picker-name">No file selected</span>
            </label>
        </div>
    }

    <input type="hidden" name="documentType" id="removeDocType" value="" />

    <button type="submit" name="action" value="upload" class="ob-btn ob-btn-outline">Upload files</button>
    <button type="submit" name="action" value="continue" class="ob-btn ob-btn-primary">Save and continue</button>
    <button type="submit" name="action" value="skip" class="ob-btn ob-btn-outline">Skip for now</button>

    <div class="rl-info-box">
        <i class="fas fa-circle-info"></i>
        <p>Without these documents, you can continue with a Basic profile and complete your verification later.</p>
    </div>
</form>

@section Scripts {
<script>
    (function () {
        function isImageFile(file) {
            return file.type && file.type.indexOf('image/') === 0;
        }

        function showBlock(block) {
            if (block) {
                block.classList.remove('is-hidden');
            }
        }

        function hideBlock(block) {
            if (block) {
                block.classList.add('is-hidden');
            }
        }

        function resetPendingPreview(pending) {
            if (!pending) {
                return;
            }

            var thumb = pending.querySelector('.rl-file-pending-thumb');
            if (thumb) {
                thumb.classList.add('is-hidden');
                thumb.removeAttribute('src');
            }

            var icon = pending.querySelector('.rl-file-pending-icon');
            if (icon) {
                icon.classList.add('is-hidden');
            }

            var nameEl = pending.querySelector('.rl-file-pending-name');
            if (nameEl) {
                nameEl.textContent = '';
            }
        }

        function clearPendingSelection(uploadBlock) {
            var input = uploadBlock.querySelector('.rl-file-picker-input');
            var pending = uploadBlock.querySelector('[data-role="pending"]');
            var picker = uploadBlock.querySelector('[data-role="picker"]');

            if (input) {
                input.value = '';
            }

            resetPendingPreview(pending);
            hideBlock(pending);

            if (picker) {
                picker.classList.remove('has-file', 'is-concealed');
                showBlock(picker);
                var nameEl = picker.querySelector('.rl-file-picker-name');
                if (nameEl) {
                    nameEl.textContent = 'No file selected';
                }
            }
        }

        function showEmptyPicker(uploadBlock) {
            var attached = uploadBlock.querySelector('[data-role="attached"]');
            var pending = uploadBlock.querySelector('[data-role="pending"]');
            var picker = uploadBlock.querySelector('[data-role="picker"]');

            hideBlock(attached);
            resetPendingPreview(pending);
            hideBlock(pending);

            if (picker) {
                var input = picker.querySelector('.rl-file-picker-input');
                if (input) {
                    input.value = '';
                }
                picker.classList.remove('has-file', 'is-concealed');
                showBlock(picker);
                var nameEl = picker.querySelector('.rl-file-picker-name');
                if (nameEl) {
                    nameEl.textContent = 'No file selected';
                }
            }

            var docType = uploadBlock.getAttribute('data-doc-type');
            if (docType) {
                var docCard = document.querySelector('[data-doc-card="' + docType + '"]');
                var badge = docCard?.querySelector('[data-uploaded-badge]');
                if (badge) {
                    badge.remove();
                }
            }
        }

        function showPendingSelection(uploadBlock, file) {
            var pending = uploadBlock.querySelector('[data-role="pending"]');
            var picker = uploadBlock.querySelector('[data-role="picker"]');
            var attached = uploadBlock.querySelector('[data-role="attached"]');
            if (!pending || !picker) {
                return;
            }

            hideBlock(attached);
            showBlock(pending);
            picker.classList.add('is-concealed');

            var nameEl = pending.querySelector('.rl-file-pending-name');
            if (nameEl) {
                nameEl.textContent = file.name;
            }

            var thumb = pending.querySelector('.rl-file-pending-thumb');
            var icon = pending.querySelector('.rl-file-pending-icon');
            if (isImageFile(file) && thumb) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    thumb.src = e.target.result;
                    thumb.classList.remove('is-hidden');
                };
                reader.readAsDataURL(file);
                if (icon) {
                    icon.classList.add('is-hidden');
                }
            } else {
                if (thumb) {
                    thumb.classList.add('is-hidden');
                    thumb.removeAttribute('src');
                }
                if (icon) {
                    icon.classList.remove('is-hidden');
                }
            }
        }

        document.querySelectorAll('.rl-file-picker-input').forEach(function (input) {
            input.addEventListener('change', function () {
                var uploadBlock = input.closest('.rl-doc-upload');
                var picker = input.closest('.rl-file-picker');
                var nameEl = picker?.querySelector('.rl-file-picker-name');
                var file = input.files && input.files[0];

                if (!uploadBlock || !file) {
                    if (uploadBlock) {
                        clearPendingSelection(uploadBlock);
                    }
                    return;
                }

                if (nameEl) {
                    nameEl.textContent = file.name;
                }
                picker?.classList.add('has-file');
                showPendingSelection(uploadBlock, file);
            });
        });

        document.querySelectorAll('.rl-file-pending-remove').forEach(function (button) {
            button.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var uploadBlock = button.closest('.rl-doc-upload');
                if (uploadBlock) {
                    clearPendingSelection(uploadBlock);
                }
            });
        });

        document.querySelectorAll('.rl-file-remove-uploaded').forEach(function (button) {
            button.addEventListener('click', function () {
                var docType = button.getAttribute('data-document-type');
                var hidden = document.getElementById('removeDocType');
                if (hidden && docType) {
                    hidden.value = docType;
                }

                var uploadBlock = button.closest('.rl-doc-upload');
                if (uploadBlock) {
                    showEmptyPicker(uploadBlock);
                }
            });
        });

        var form = document.getElementById('rlVerificationForm');
        var clientError = document.getElementById('verificationClientError');
        var clientErrorText = document.getElementById('verificationClientErrorText');

        function hideClientError() {
            if (clientError) {
                clientError.classList.add('is-hidden');
            }
            if (clientErrorText) {
                clientErrorText.textContent = '';
            }
            document.querySelectorAll('.rl-doc-upload.is-error').forEach(function (block) {
                block.classList.remove('is-error');
            });
        }

        function showClientError(message) {
            if (clientErrorText) {
                clientErrorText.textContent = message;
            }
            if (clientError) {
                clientError.classList.remove('is-hidden');
                clientError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function hasDocumentAttached(uploadBlock) {
            if (!uploadBlock) {
                return false;
            }

            var attached = uploadBlock.querySelector('[data-role="attached"]');
            if (attached && !attached.classList.contains('is-hidden')) {
                return true;
            }

            var pending = uploadBlock.querySelector('[data-role="pending"]');
            if (pending && !pending.classList.contains('is-hidden')) {
                return true;
            }

            var input = uploadBlock.querySelector('.rl-file-picker-input');
            return !!(input && input.files && input.files.length > 0);
        }

        function validateContinue() {
            hideClientError();
            var missing = [];
            document.querySelectorAll('.rl-doc-upload[data-required="true"]').forEach(function (block) {
                if (!hasDocumentAttached(block)) {
                    missing.push(block);
                }
            });

            if (!missing.length) {
                return true;
            }

            missing.forEach(function (block) {
                block.classList.add('is-error');
            });
            showClientError(
                missing.length === 1
                    ? 'Please attach your ' + (missing[0].querySelector('.rl-doc-upload-label')?.textContent?.trim().toLowerCase() || 'document') + ' before continuing, or choose Skip for now.'
                    : 'No required documents attached. Please upload your license photo and government ID, or choose Skip for now.'
            );
            return false;
        }

        if (form) {
            form.addEventListener('submit', function (e) {
                var submitter = e.submitter;
                if (submitter && submitter.name === 'action' && submitter.value === 'continue' && !validateContinue()) {
                    e.preventDefault();
                }
            });
        }

        document.querySelectorAll('.rl-file-picker-input').forEach(function (input) {
            input.addEventListener('change', hideClientError);
        });
    })();
</script>
}
