@using IndorMvcApp.Validation
@model IndorMvcApp.ViewModels.RealtorRegistrationStepViewModel
@{
    var s = Model.State;
    string FieldError(string key) => ViewData.ModelState[key]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
    var brokerageError = FieldError("brokerageName");
    var licenseError = FieldError("licenseNumber");
    var licenseStateError = FieldError("licenseState");
    var termsError = FieldError("professionalTermsAccepted");
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<form asp-action="Profile" method="post" class="rl-reg-form" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="ob-summary"></div>

    <label class="rl-field @(brokerageError.Length > 0 ? "is-error" : "")">
        <i class="fas fa-building"></i>
        <input type="text"
               name="brokerageName"
               value="@s.BrokerageName"
               placeholder="Brokerage / broker name"
               autocomplete="organization" />
    </label>
    @if (brokerageError.Length > 0)
    {
        <span class="rl-field-error">@brokerageError</span>
    }
    else
    {
        <span class="rl-field-hint">Use your brokerage or broker name (letters required, @BrokerageNameAttribute.MinLength–@BrokerageNameAttribute.MaxLength characters).</span>
    }

    <label class="rl-field @(licenseError.Length > 0 ? "is-error" : "")">
        <i class="fas fa-id-card"></i>
        <input type="text"
               name="licenseNumber"
               value="@s.LicenseNumber"
               placeholder="License number (e.g. BRE123456)"
               inputmode="text"
               autocomplete="off" />
    </label>
    @if (licenseError.Length > 0)
    {
        <span class="rl-field-error">@licenseError</span>
    }
    else
    {
        <span class="rl-field-hint">@RealtorLicenseNumberAttribute.MinLength–@RealtorLicenseNumberAttribute.MaxLength alphanumeric characters; include at least one letter.</span>
    }

    <label class="rl-field @(licenseStateError.Length > 0 ? "is-error" : "")">
        <i class="fas fa-shield-halved"></i>
        <select name="licenseState">
            <option value="">License state</option>
            @foreach (var st in Model.LicenseStates)
            {
                <option value="@st" selected="@(s.LicenseState == st)">@st</option>
            }
        </select>
    </label>
    @if (licenseStateError.Length > 0)
    {
        <span class="rl-field-error">@licenseStateError</span>
    }

    <label class="rl-field">
        <i class="fas fa-map"></i>
        <input type="text" name="serviceAreas" value="@s.ServiceAreas" placeholder="Ex. Miami, Fort Lauderdale, West Palm Beach" />
    </label>

    <div class="rl-info-box">
        <i class="fas fa-circle-info"></i>
        <p>With this number, we validate that you are a realtor. Full verification can be completed now or later.</p>
    </div>

    <label class="rl-terms @(termsError.Length > 0 ? "is-error" : "")">
        <input type="checkbox" name="professionalTermsAccepted" value="true" @(s.ProfessionalTermsAccepted ? "checked" : null) />
        <span>I accept the Professional Terms and authorize validation of my license. <a asp-controller="Account" asp-action="Terms">View terms</a></span>
    </label>
    @if (termsError.Length > 0)
    {
        <span class="rl-field-error">@termsError</span>
    }

    <button type="submit" class="ob-btn ob-btn-primary">Continue</button>
</form>
