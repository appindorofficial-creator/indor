@using IndorMvcApp.Helpers
@using IndorMvcApp.Validation
@model IndorMvcApp.ViewModels.RealtorRegistrationStepViewModel
@{
    var s = Model.State;

    string FieldError(string key)
    {
        var raw = ViewData.ModelState[key]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
        return string.IsNullOrWhiteSpace(raw) ? "" : UiDisplayLocalization.Localize(L, raw);
    }

    var brokerageError = FieldError("brokerageName");
    var formErrors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .Select(m => UiDisplayLocalization.Localize(L, m))
        .ToList();
}

<div class="ob-head-block">
    <h1>@UiDisplayLocalization.Localize(L, Model.Title)</h1>
    <p>@UiDisplayLocalization.Localize(L, Model.Subtitle)</p>
</div>

@if (formErrors.Count > 0)
{
    <div class="rl-error-banner" role="alert">
        <i class="fas fa-triangle-exclamation"></i>
        <div>
            <span>@L["Please fix the following before continuing:"]</span>
            <ul class="rl-error-list">
                @foreach (var msg in formErrors)
                {
                    <li>@UiDisplayLocalization.Localize(L, msg)</li>
                }
            </ul>
        </div>
    </div>
}

<form asp-action="Profile" method="post" class="rl-reg-form" id="rlRegProfileForm" novalidate>
    @Html.AntiForgeryToken()

    <div class="rl-field-block">
        <span class="rl-field-label">@L["Brokerage / Company"] <span class="rl-required" aria-hidden="true">*</span></span>
        <label class="rl-field @(brokerageError.Length > 0 ? "is-error" : "")">
            <i class="fas fa-building"></i>
            <input type="text"
                   name="brokerageName"
                   value="@s.BrokerageName"
                   placeholder="@L["Keller Williams Realty"]"
                   autocomplete="organization"
                   aria-required="true"
                   aria-invalid="@(brokerageError.Length > 0)"
                   @(brokerageError.Length > 0 ? Html.Raw("aria-describedby=\"brokerageNameError\"") : null) />
        </label>
        <span class="rl-field-error" id="brokerageNameError">@UiDisplayLocalization.Localize(L, brokerageError)</span>
    </div>

    <p class="rl-field-hint" style="margin-top:4px;margin-bottom:16px;">
        @L["Complete the rest from your profile later"]
    </p>

    <button type="submit" id="rlRegProfileContinueBtn" class="ob-btn ob-btn-primary">@L["Continue"]</button>
</form>

@section Scripts {
<script>
(function () {
    var form = document.getElementById('rlRegProfileForm');
    if (!form) return;

    form.addEventListener('submit', function (e) {
        var input = form.querySelector('input[name="brokerageName"]');
        var errorEl = document.getElementById('brokerageNameError');
        var field = input?.closest('.rl-field');
        var value = (input?.value || '').trim();
        if (!value) {
            e.preventDefault();
            if (errorEl) errorEl.textContent = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Brokerage / Company Name is required."].ToString()));
            if (field) field.classList.add('is-error');
            input?.focus();
            return;
        }
        if (errorEl) errorEl.textContent = '';
        if (field) field.classList.remove('is-error');
    });
})();
</script>
}
