@using IndorMvcApp.Validation

@model IndorMvcApp.ViewModels.RealtorRegistrationStepViewModel

@{

    var s = Model.State;

    string FieldError(string key) => ViewData.ModelState[key]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";

    var brokerageError = FieldError("brokerageName");

    var licenseError = FieldError("licenseNumber");

    var licenseStateError = FieldError("licenseState");

    var languagesError = FieldError("languages");

    var termsError = FieldError("professionalTermsAccepted");
    var serviceAreasError = FieldError("serviceAreas");
    var officeAddressError = FieldError("officeAddress");

    var selectedLanguages = (s.Languages ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

}

<div class="ob-head-block">

    <h1>@Model.Title</h1>

    <p>@Model.Subtitle</p>

</div>



<form asp-action="Profile" method="post" class="rl-reg-form" id="rlRegProfileForm" novalidate>

    @Html.AntiForgeryToken()

    <div class="rl-field-block">

        <span class="rl-field-label">Brokerage / Company Name <span class="rl-required" aria-hidden="true">*</span></span>

        <label class="rl-field @(brokerageError.Length > 0 ? "is-error" : "")">

            <i class="fas fa-building"></i>

            <input type="text"

                   name="brokerageName"

                   value="@s.BrokerageName"

                   placeholder="Keller Williams Realty"

                   autocomplete="organization"

                   aria-required="true"

                   aria-invalid="@(brokerageError.Length > 0)"

                   @(brokerageError.Length > 0 ? Html.Raw("aria-describedby=\"brokerageNameError\"") : null) />

        </label>

        <span class="rl-field-error" id="brokerageNameError">@brokerageError</span>
    </div>



    <div class="rl-field-block">

        <span class="rl-field-label">Real Estate License Number <span class="rl-required" aria-hidden="true">*</span></span>

        <label class="rl-field @(licenseError.Length > 0 ? "is-error" : "")">

            <i class="fas fa-id-card"></i>

            <input type="text"

                   name="licenseNumber"

                   value="@s.LicenseNumber"

                   placeholder="BRE123456"

                   inputmode="text"

                   autocomplete="off"

                   aria-required="true"

                   aria-invalid="@(licenseError.Length > 0)"

                   @(licenseError.Length > 0 ? Html.Raw("aria-describedby=\"licenseNumberError\"") : null) />

        </label>

        <span class="rl-field-error" id="licenseNumberError">@licenseError</span>
    </div>



    <div class="rl-field-block">

        <span class="rl-field-label">License State <span class="rl-required" aria-hidden="true">*</span></span>

        <label class="rl-field @(licenseStateError.Length > 0 ? "is-error" : "")">

            <i class="fas fa-shield-halved"></i>

            <select name="licenseState"

                    aria-required="true"

                    aria-invalid="@(licenseStateError.Length > 0)"

                    @(licenseStateError.Length > 0 ? Html.Raw("aria-describedby=\"licenseStateError\"") : null)>

                <option value="">Select state</option>

                @foreach (var st in Model.LicenseStates)

                {

                    <option value="@st" selected="@(s.LicenseState == st)">@st</option>

                }

            </select>

        </label>

        <span class="rl-field-error" id="licenseStateError">@licenseStateError</span>
    </div>

    <div class="rl-field-block">
        <span class="rl-field-label">City / Market Area <span class="rl-required" aria-hidden="true">*</span></span>
        <label class="rl-field @(serviceAreasError.Length > 0 ? "is-error" : "")">
            <i class="fas fa-map"></i>
            <input type="text"
                   name="serviceAreas"
                   value="@s.ServiceAreas"
                   placeholder="Charlotte, NC"
                   aria-required="true"
                   aria-invalid="@(serviceAreasError.Length > 0)"
                   @(serviceAreasError.Length > 0 ? Html.Raw("aria-describedby=\"serviceAreasError\"") : null) />
        </label>
        <span class="rl-field-error" id="serviceAreasError">@serviceAreasError</span>
    </div>

    <div class="rl-field-block">
        <span class="rl-field-label">Office Address <span class="rl-required" aria-hidden="true">*</span></span>
        <label class="rl-field @(officeAddressError.Length > 0 ? "is-error" : "")">
            <i class="fas fa-location-dot"></i>
            <input type="text"
                   name="officeAddress"
                   value="@s.OfficeAddress"
                   placeholder="123 Business Ave, Miami, FL 33131"
                   autocomplete="street-address"
                   aria-required="true"
                   aria-invalid="@(officeAddressError.Length > 0)"
                   @(officeAddressError.Length > 0 ? Html.Raw("aria-describedby=\"officeAddressError\"") : null) />
        </label>
        <span class="rl-field-error" id="officeAddressError">@officeAddressError</span>
    </div>



    <div class="rl-field-block">

        <span class="rl-field-label">Languages <span class="rl-required" aria-hidden="true">*</span></span>

        <p class="rl-field-hint">Select one or more: English and Spanish only.</p>

        <div class="rl-lang-options @(languagesError.Length > 0 ? "is-error" : "")"

             id="rlSupportedLanguages"

             data-supported-languages="@string.Join(",", Model.SupportedLanguages)"

             @(languagesError.Length > 0 ? Html.Raw("aria-describedby=\"languagesError\"") : null)>

            @foreach (var lang in Model.SupportedLanguages)

            {

                <label class="rl-lang-option">

                    <input type="checkbox"

                           name="languages"

                           value="@lang"

                           checked="@selectedLanguages.Contains(lang)" />

                    <i class="fas fa-globe"></i>

                    <span>@lang</span>

                </label>

            }

        </div>

        <span class="rl-field-error" id="languagesError">@languagesError</span>
    </div>



    <div class="rl-info-box">

        <i class="fas fa-circle-info"></i>

        <div>

            <strong class="rl-info-box-title">License Verification</strong>

            <p>Your realtor license verification may take up to 24 hours. You can continue using Home Indor while we review your information. If there is any issue with your license or we need more information, we will notify you.</p>

        </div>

    </div>



    <label class="rl-terms @(termsError.Length > 0 ? "is-error" : "")">

        <input type="checkbox"

               name="professionalTermsAccepted"

               value="true"

               aria-required="true"

               aria-invalid="@(termsError.Length > 0)"

               @(s.ProfessionalTermsAccepted ? "checked" : null)

               @(termsError.Length > 0 ? Html.Raw("aria-describedby=\"termsError\"") : null) />

        <span>I authorize Home Indor to verify my real estate license using the information provided. <span class="rl-required" aria-hidden="true">*</span></span>

    </label>

    <span class="rl-field-error rl-field-error--terms" id="termsError">@termsError</span>



    <button type="submit" class="ob-btn ob-btn-primary">Continue</button>

</form>



@section Scripts {
<script src="~/js/realtor-license-number.js" asp-append-version="true"></script>
<script>
(function () {
    var form = document.getElementById('rlRegProfileForm');
    if (!form) {
        return;
    }

    function scrollToFirstError() {
        var firstFieldError = form.querySelector('.rl-field-error:not(:empty)');
        var scrollTarget = firstFieldError
            || form.querySelector('.rl-field.is-error, .rl-terms.is-error, .rl-lang-options.is-error');
        if (scrollTarget) {
            scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    }

    scrollToFirstError();

    var supportedRoot = document.getElementById('rlSupportedLanguages');
    var supported = (supportedRoot?.dataset.supportedLanguages || 'English,Spanish')
        .split(',')
        .map(function (item) { return item.trim(); })
        .filter(Boolean);

    function setFieldError(errorId, fieldSelector, message) {
        var errorEl = document.getElementById(errorId);
        var field = form.querySelector(fieldSelector)?.closest('.rl-field');
        if (errorEl) {
            errorEl.textContent = message || '';
        }
        if (field) {
            field.classList.toggle('is-error', !!message);
        }
        return !!message;
    }

    function setLanguagesError(message) {
        var errorEl = document.getElementById('languagesError');
        if (errorEl) {
            errorEl.textContent = message || '';
        }
        if (supportedRoot) {
            supportedRoot.classList.toggle('is-error', !!message);
        }
        return !!message;
    }

    function setTermsError(message) {
        var errorEl = document.getElementById('termsError');
        var terms = form.querySelector('.rl-terms');
        if (errorEl) {
            errorEl.textContent = message || '';
        }
        if (terms) {
            terms.classList.toggle('is-error', !!message);
        }
        return !!message;
    }

    function setLicenseError(message) {
        return setFieldError('licenseNumberError', 'input[name="licenseNumber"]', message);
    }

    function clearAllFieldErrors() {
        setFieldError('brokerageNameError', 'input[name="brokerageName"]', '');
        setLicenseError('');
        setFieldError('licenseStateError', 'select[name="licenseState"]', '');
        setFieldError('serviceAreasError', 'input[name="serviceAreas"]', '');
        setFieldError('officeAddressError', 'input[name="officeAddress"]', '');
        setLanguagesError('');
        setTermsError('');
    }

    function validateProfileForm() {
        var hasError = false;
        clearAllFieldErrors();

        var brokerage = form.querySelector('input[name="brokerageName"]');
        if (!brokerage || !brokerage.value.trim()) {
            hasError = setFieldError(
                'brokerageNameError',
                'input[name="brokerageName"]',
                'Brokerage / Company Name is required.') || hasError;
        }

        var licenseInput = form.querySelector('input[name="licenseNumber"]');
        if (licenseInput && window.IndorRealtorLicense) {
            var licenseMessage = window.IndorRealtorLicense.validate(licenseInput.value);
            if (licenseMessage) {
                hasError = setLicenseError(licenseMessage) || hasError;
            }
        } else if (licenseInput && !licenseInput.value.trim()) {
            hasError = setLicenseError('License number is required.') || hasError;
        }

        var licenseState = form.querySelector('select[name="licenseState"]');
        if (!licenseState || !licenseState.value.trim()) {
            hasError = setFieldError(
                'licenseStateError',
                'select[name="licenseState"]',
                'Please select your license state.') || hasError;
        }

        var serviceAreas = form.querySelector('input[name="serviceAreas"]');
        if (!serviceAreas || !serviceAreas.value.trim()) {
            hasError = setFieldError(
                'serviceAreasError',
                'input[name="serviceAreas"]',
                'City / market area is required.') || hasError;
        }

        var officeAddress = form.querySelector('input[name="officeAddress"]');
        if (!officeAddress || !officeAddress.value.trim()) {
            hasError = setFieldError(
                'officeAddressError',
                'input[name="officeAddress"]',
                'Office address is required.') || hasError;
        }

        var checkedLanguages = form.querySelectorAll('input[name="languages"]:checked');
        if (!checkedLanguages.length) {
            hasError = setLanguagesError('Select at least one language.') || hasError;
        } else {
            checkedLanguages.forEach(function (input) {
                if (supported.indexOf(input.value) === -1) {
                    hasError = setLanguagesError('Only English and Spanish are supported.') || hasError;
                }
            });
        }

        var terms = form.querySelector('input[name="professionalTermsAccepted"][type="checkbox"]');
        if (!terms || !terms.checked) {
            hasError = setTermsError('Please check the authorization box to verify your license before continuing.') || hasError;
        }

        if (hasError) {
            scrollToFirstError();
            return false;
        }

        return true;
    }

    var licenseInput = form.querySelector('input[name="licenseNumber"]');
    if (licenseInput && window.IndorRealtorLicense) {
        window.IndorRealtorLicense.attach(licenseInput, {
            errorEl: document.getElementById('licenseNumberError'),
            validateOnLoad: false
        });
    }

    [
        'input[name="brokerageName"]',
        'input[name="serviceAreas"]',
        'input[name="officeAddress"]',
        'select[name="licenseState"]'
    ].forEach(function (selector) {
        var input = form.querySelector(selector);
        if (!input) {
            return;
        }
        var errorId = input.name === 'licenseState'
            ? 'licenseStateError'
            : input.name + 'Error';
        input.addEventListener('input', function () {
            setFieldError(errorId, selector, '');
        });
        input.addEventListener('change', function () {
            setFieldError(errorId, selector, '');
        });
    });

    if (licenseInput) {
        licenseInput.addEventListener('input', function () {
            setLicenseError('');
        });
    }

    form.addEventListener('submit', function (e) {
        if (!validateProfileForm()) {
            e.preventDefault();
        }
    });

    form.querySelectorAll('input[name="languages"]').forEach(function (input) {
        input.addEventListener('change', function () {
            setLanguagesError('');
        });
    });

    var termsCheckbox = form.querySelector('input[name="professionalTermsAccepted"][type="checkbox"]');
    if (termsCheckbox) {
        termsCheckbox.addEventListener('change', function () {
            setTermsError('');
        });
    }
})();
</script>
}

