@model IndorMvcApp.ViewModels.RealtorReadyViewModel
@{
    ViewData["RealtorStep"] = new IndorMvcApp.ViewModels.RealtorRegistrationStepViewModel
    {
        DisplayStep = Model.Step,
        TotalSteps = Model.TotalSteps,
        Title = "Your profile is ready"
    };
}

<section class="rl-ready-hero">
    <h1>@L["Your profile is ready"]</h1>
    <p>@L["You can now enter as a Realtor."]</p>
    <span class="rl-badge"><i class="fas fa-star"></i> @UiDisplayLocalization.Localize(L, Model.BadgeLabel)</span>
</section>

<ul class="rl-ready-checklist">
    <li class="@(Model.LicenseNumberSaved ? "is-done" : null)">
        <i class="fas fa-circle-check" aria-hidden="true"></i>
        <span>@L["License number saved"]</span>
    </li>
    <li class="@(Model.ProfileCreated ? "is-done" : null)">
        <i class="fas fa-circle-check" aria-hidden="true"></i>
        <span>@L["Profile created"]</span>
    </li>
    <li class="@(Model.LicensePhotoUploaded ? "is-done" : null)">
        <i class="fas fa-circle-check" aria-hidden="true"></i>
        <span>@L["License photo"]</span>
    </li>
    <li class="@(Model.GovernmentIdUploaded ? "is-done" : null)">
        <i class="fas fa-circle-check" aria-hidden="true"></i>
        <span>@L["Government ID"]</span>
    </li>
</ul>

<div class="rl-ready-actions">
    <a asp-controller="Realtor" asp-action="Dashboard" class="ob-btn ob-btn-primary">@L["Go to Home"]</a>
</div>
