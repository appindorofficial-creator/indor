@model IndorMvcApp.ViewModels.RealtorReadyViewModel
@{
    ViewData["RealtorStep"] = new IndorMvcApp.ViewModels.RealtorRegistrationStepViewModel
    {
        DisplayStep = Model.Step,
        TotalSteps = Model.TotalSteps,
        Title = "Welcome, realtor!"
    };
}

<section class="rl-ready-hero">
    <div class="rl-ready-check" aria-hidden="true"><i class="fas fa-check"></i></div>
    <h1>@L["Welcome, realtor!"]</h1>
    <p>@L["You can now enter the INDOR ecosystem. Complete license, market, and documents later from your profile."]</p>
    <span class="rl-badge"><i class="fas fa-star"></i> @UiDisplayLocalization.Localize(L, Model.BadgeLabel)</span>
</section>

<div class="rl-ready-actions">
    <a asp-controller="Realtor" asp-action="Dashboard" class="ob-btn ob-btn-primary">@L["Enter the INDOR ecosystem"]</a>
    <a asp-controller="Realtor" asp-action="Profile" class="rl-later-link">@L["Complete profile later"]</a>
</div>
