@model IndorMvcApp.ViewModels.CrawlspaceCheckScheduleViewModel
@{
    ViewData["Title"] = "Schedule crawlspace check - INDOR";
var concernCodes = new[] { "StandingWater", "MustyOdor", "MoldMildew", "AirLeaks", "PestSigns", "Cracks", "PipeLeaks", "DamagedDucts" };
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("CrawlspaceCheckSetup", "CrawlspaceCheck", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;

}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">What should we look for?</h1>
    <p class="page-lead" style="margin-bottom:16px;">Select any concerns and tell us when you'd like the check.</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="csc-schedule-form" asp-action="CrawlspaceCheckSchedule" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="PreocupacionesSeleccionadas" id="PreocupacionesSeleccionadas" />
        <input type="hidden" asp-for="TimingPreferido" id="TimingPreferido" />

        @if (Model.ConcernOptions.Count > 0)
        {
            <div class="field-card">
                <div class="field-head"><i class="fas fa-magnifying-glass"></i><span>What should we look for?</span></div>
                <div class="concern-grid">
                    @for (var i = 0; i < Model.ConcernOptions.Count; i++)
                    {
                        var item = Model.ConcernOptions[i];
                        var code = i < concernCodes.Length ? concernCodes[i] : item.Text.Replace(" ", "");
                        <button type="button" class="concern-card" data-concern="@code">
                            <span class="check"><i class="fas fa-check"></i></span>
                            <i class="fas @item.Icon main"></i>
                            <span class="label">@item.Text</span>
                        </button>
                    }
                </div>
                <span asp-validation-for="PreocupacionesSeleccionadas" class="text-danger"></span>
            </div>
        }

        <div class="field-card">
            <div class="field-head"><i class="fas fa-clock"></i><span>Preferred timing</span></div>
            <div class="timing-row">
                <button type="button" class="timing-card" data-timing="AsSoonAsPossible">
                    <span class="radio"></span>
                    <i class="fas fa-bolt main"></i><span class="label">As soon as possible</span>
                </button>
                <button type="button" class="timing-card" data-timing="ThisMonth">
                    <span class="radio"></span>
                    <i class="fas fa-calendar main"></i><span class="label">This month</span>
                </button>
                <button type="button" class="timing-card" data-timing="YearlyReminder">
                    <span class="radio"></span>
                    <i class="fas fa-bell main"></i><span class="label">Just a yearly reminder</span>
                </button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>Preferred date</span></div>
            <div class="date-picker-card">
                <div class="field-head" style="margin-bottom:8px;"><i class="fas fa-calendar-day"></i><span>Preferred date</span></div>
                <p class="sub">Tell us when it works best for you.</p>
                <input asp-for="FechaPreferida" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" style="margin-top:10px;" />
                <span asp-validation-for="FechaPreferida" class="text-danger"></span>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-note-sticky"></i><span>Notes (optional)</span></div>
            <textarea asp-for="Notas" placeholder="Add any details" maxlength="300"></textarea>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.TipTexto))
        {
            <div class="tip-box">
                <i class="fas fa-lightbulb"></i>
                <span>@Model.TipTexto</span>
            </div>
        }

        <button type="submit" name="action" value="continue" class="btn-primary">
            Review request <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        var concernsInput = document.getElementById('PreocupacionesSeleccionadas');
        var timingInput = document.getElementById('TimingPreferido');

        function getConcerns() {
            return concernsInput.value ? concernsInput.value.split('|').filter(Boolean) : [];
        }

        function setConcerns(values) {
            concernsInput.value = values.join('|');
        }

        document.querySelectorAll('[data-concern]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var code = btn.getAttribute('data-concern');
                var current = getConcerns();
                if (current.indexOf(code) >= 0) {
                    current = current.filter(function (v) { return v !== code; });
                    btn.classList.remove('active');
                } else {
                    current.push(code);
                    btn.classList.add('active');
                }
                setConcerns(current);
            });
            if (getConcerns().indexOf(btn.getAttribute('data-concern')) >= 0) btn.classList.add('active');
        });

        document.querySelectorAll('[data-timing]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-timing]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                timingInput.value = btn.getAttribute('data-timing');
            });
            if (btn.getAttribute('data-timing') === timingInput.value) btn.classList.add('active');
        });
    })();

</script>
}
