@model IndorMvcApp.ViewModels.CrawlspaceCheckConfirmedViewModel
@{
    ViewData["Title"] = L["Crawlspace Check Scheduled - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.NombreServicio);
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}



<div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">@L["Crawlspace Check Scheduled"]</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">@L["Your crawlspace inspection request has been submitted."]</p>
    </div>

    <div class="summary-grid">
        <div class="summary-mini">
            <i class="fas fa-layer-group"></i>
            <div class="summary-label">@L["Encapsulation"]</div>
            <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.EncapsulacionLabel)</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-scroll"></i>
            <div class="summary-label">@L["Insulation"]</div>
            <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.AislamientoLabel)</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-droplet"></i>
            <div class="summary-label">@L["Vapor barrier"]</div>
            <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.BarreraVaporLabel)</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-bug"></i>
            <div class="summary-label">@L["Concerns"]</div>
            <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.ConcernsLabel)</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-calendar"></i>
            <div class="summary-label">@L["Timing"]</div>
            <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.TimingLabel)</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-clock-rotate-left"></i>
            <div class="summary-label">@L["Reminder"]</div>
            <div class="summary-value">@UiDisplayLocalization.Localize(L, Model.ReminderLabel)</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.FrequencyTexto))
    {
        var frequencyRaw = Model.FrequencyTexto.Trim();
        var frequencyDisplay = frequencyRaw.StartsWith("Recommended frequency:", StringComparison.OrdinalIgnoreCase)
            ? frequencyRaw
            : $"Recommended frequency: {frequencyRaw}";
        <div class="info-box-blue">
            <i class="fas fa-circle-info"></i>
            <span>@L.Catalog(frequencyDisplay)</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResumenServicioTexto))
    {
        <div class="service-desc-box">
            <i class="fas fa-shield-halved"></i>
            <span>@L.Catalog(Model.ResumenServicioTexto)</span>
        </div>
    }

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Index" asp-route-id="@Model.PropiedadId" class="btn-primary">
            <i class="fas fa-house"></i> @L["Go to My Home"]
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-primary">
            <i class="fas fa-house"></i> @L["Go to My Home"]
        </a>
    }

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-bell"></i> @L["View reminders"]
        </a>
    }
