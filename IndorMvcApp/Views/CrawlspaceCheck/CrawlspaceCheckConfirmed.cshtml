@model IndorMvcApp.ViewModels.CrawlspaceCheckConfirmedViewModel
@{
    ViewData["Title"] = "Crawlspace Check Scheduled - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_CrawlspaceCheckStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.NombreServicio</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_CrawlspaceCheckStepper", 4)

    <div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Crawlspace Check Scheduled</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">Your crawlspace inspection request has been submitted.</p>
    </div>

    <div class="summary-grid">
        <div class="summary-mini">
            <i class="fas fa-layer-group"></i>
            <div class="summary-label">Encapsulation</div>
            <div class="summary-value">@Model.EncapsulacionLabel</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-scroll"></i>
            <div class="summary-label">Insulation</div>
            <div class="summary-value">@Model.AislamientoLabel</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-droplet"></i>
            <div class="summary-label">Vapor barrier</div>
            <div class="summary-value">@Model.BarreraVaporLabel</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-bug"></i>
            <div class="summary-label">Concerns</div>
            <div class="summary-value">@Model.ConcernsLabel</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-calendar"></i>
            <div class="summary-label">Timing</div>
            <div class="summary-value">@Model.TimingLabel</div>
        </div>
        <div class="summary-mini">
            <i class="fas fa-clock-rotate-left"></i>
            <div class="summary-label">Reminder</div>
            <div class="summary-value">@Model.ReminderLabel</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.FrequencyTexto))
    {
        <div class="info-box-blue">
            <i class="fas fa-circle-info"></i>
            <span>Recommended frequency: @Model.FrequencyTexto</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ResumenServicioTexto))
    {
        <div class="service-desc-box">
            <i class="fas fa-shield-halved"></i>
            <span>@Model.ResumenServicioTexto</span>
        </div>
    }

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Index" asp-route-id="@Model.PropiedadId" class="btn-primary">
            <i class="fas fa-house"></i> Go to My Home
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-primary">
            <i class="fas fa-house"></i> Go to My Home
        </a>
    }

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-bell"></i> View reminders
        </a>
    }
</div>
</body>
</html>
