@model IndorMvcApp.ViewModels.CrawlspaceCheckSetupViewModel
@{
    ViewData["Title"] = L["Tell us about your crawlspace - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("CrawlspaceCheckService", "CrawlspaceCheck", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Tell us about your crawlspace"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@L["A few details help us prepare the right inspection. Select an answer for each question below."]</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="csc-setup-form" asp-action="CrawlspaceCheckSetup" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="Encapsulacion" id="Encapsulacion" />
        <input type="hidden" asp-for="Aislamiento" id="Aislamiento" />
        <input type="hidden" asp-for="BarreraVapor" id="BarreraVapor" />
        <input type="hidden" asp-for="TipoAcceso" id="TipoAcceso" />
        <input type="hidden" asp-for="UltimaRevision" id="UltimaRevision" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-layer-group"></i><span>@L["Do you have encapsulation?"]</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-enc="Yes"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-check main"></i><span class="label">@L["Yes"]</span></button>
                <button type="button" class="choice-card" data-enc="No"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-xmark main"></i><span class="label">@L["No"]</span></button>
                <button type="button" class="choice-card" data-enc="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-scroll"></i><span>@L["Is there insulation?"]</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-ins="Yes"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-check main"></i><span class="label">@L["Yes"]</span></button>
                <button type="button" class="choice-card" data-ins="No"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-xmark main"></i><span class="label">@L["No"]</span></button>
                <button type="button" class="choice-card" data-ins="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-droplet"></i><span>@L["Ground vapor barrier"]</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-vap="Yes"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-check main"></i><span class="label">@L["Yes"]</span></button>
                <button type="button" class="choice-card" data-vap="No"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-xmark main"></i><span class="label">@L["No"]</span></button>
                <button type="button" class="choice-card" data-vap="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-door-open"></i><span>@L["Access type"]</span></div>
            <div class="access-grid">
                <button type="button" class="choice-card" data-access="InteriorHatch"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-square main"></i><span class="label">@L["Interior hatch"]</span></button>
                <button type="button" class="choice-card" data-access="ExteriorDoor"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-door-closed main"></i><span class="label">@L["Exterior door"]</span></button>
                <button type="button" class="choice-card" data-access="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>@L["Last crawlspace check"]</span></div>
            <div class="segment-row">
                <button type="button" class="segment-btn" data-last="Within1Year"><i class="fas fa-calendar"></i> @L["Within 1 year"]</button>
                <button type="button" class="segment-btn" data-last="OneToTwoYears"><i class="fas fa-calendar"></i> @L["1–2 years"]</button>
                <button type="button" class="segment-btn" data-last="TwoPlusYears"><i class="fas fa-calendar"></i> @L["2+ years"]</button>
                <button type="button" class="segment-btn" data-last="NotSure"><i class="fas fa-circle-question"></i> @L["Not sure"]</button>
            </div>
        </div>

        <div class="info-box-blue">
            <i class="fas fa-circle-info"></i>
            <span>@L["Annual checks help catch moisture, air leaks, and structural issues early."]</span>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            Continue <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        bindSingle('[data-enc]', 'data-enc', document.getElementById('Encapsulacion'));
        bindSingle('[data-ins]', 'data-ins', document.getElementById('Aislamiento'));
        bindSingle('[data-vap]', 'data-vap', document.getElementById('BarreraVapor'));
        bindSingle('[data-access]', 'data-access', document.getElementById('TipoAcceso'));
        bindSingle('[data-last]', 'data-last', document.getElementById('UltimaRevision'));

        var form = document.getElementById('csc-setup-form');
        var requiredFields = [
            { id: 'Encapsulacion', message: 'Please indicate whether you have encapsulation.' },
            { id: 'Aislamiento', message: 'Please indicate whether there is insulation.' },
            { id: 'BarreraVapor', message: 'Please indicate whether you have a ground vapor barrier.' },
            { id: 'TipoAcceso', message: 'Please select an access type.' },
            { id: 'UltimaRevision', message: 'Please indicate when your crawlspace was last checked.' }
        ];

        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') {
                return;
            }

            var firstMissing = null;
            requiredFields.forEach(function (field) {
                var input = document.getElementById(field.id);
                if (!input) return;
                var empty = !input.value || !String(input.value).trim();
                if (empty && !firstMissing) {
                    firstMissing = field;
                }
            });

            if (firstMissing) {
                e.preventDefault();
                alert(firstMissing.message);
            }
        });
    })();

</script>
}
