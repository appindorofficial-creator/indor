@model IndorMvcApp.ViewModels.CrawlspaceCheckSetupViewModel
@{
    ViewData["Title"] = "Tell us about your crawlspace - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_CrawlspaceCheckStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <button type="submit" form="csc-setup-form" name="action" value="back" class="back-btn" style="border:none;background:transparent;">
            <i class="fas fa-chevron-left"></i>
        </button>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_CrawlspaceCheckStepper", 2)

    <h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">Tell us about your crawlspace</h1>
    <p class="page-lead" style="margin-bottom:16px;">A few details help us prepare the right inspection.</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="csc-setup-form" asp-action="CrawlspaceCheckSetup" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="Encapsulacion" id="Encapsulacion" />
        <input type="hidden" asp-for="Aislamiento" id="Aislamiento" />
        <input type="hidden" asp-for="BarreraVapor" id="BarreraVapor" />
        <input type="hidden" asp-for="TipoAcceso" id="TipoAcceso" />
        <input type="hidden" asp-for="UltimaRevision" id="UltimaRevision" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-layer-group"></i><span>Do you have encapsulation?</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-enc="Yes"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-check main"></i><span class="label">Yes</span></button>
                <button type="button" class="choice-card" data-enc="No"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-xmark main"></i><span class="label">No</span></button>
                <button type="button" class="choice-card" data-enc="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">Not sure</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-scroll"></i><span>Is there insulation?</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-ins="Yes"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-check main"></i><span class="label">Yes</span></button>
                <button type="button" class="choice-card" data-ins="No"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-xmark main"></i><span class="label">No</span></button>
                <button type="button" class="choice-card" data-ins="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">Not sure</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-droplet"></i><span>Ground vapor barrier</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-vap="Yes"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-check main"></i><span class="label">Yes</span></button>
                <button type="button" class="choice-card" data-vap="No"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-xmark main"></i><span class="label">No</span></button>
                <button type="button" class="choice-card" data-vap="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">Not sure</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-door-open"></i><span>Access type</span></div>
            <div class="access-grid">
                <button type="button" class="choice-card" data-access="InteriorHatch"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-square main"></i><span class="label">Interior hatch</span></button>
                <button type="button" class="choice-card" data-access="ExteriorDoor"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-door-closed main"></i><span class="label">Exterior door</span></button>
                <button type="button" class="choice-card" data-access="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">Not sure</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>Last crawlspace check</span></div>
            <div class="segment-row">
                <button type="button" class="segment-btn" data-last="Within1Year"><i class="fas fa-calendar"></i> Within 1 year</button>
                <button type="button" class="segment-btn" data-last="OneToTwoYears"><i class="fas fa-calendar"></i> 1–2 years</button>
                <button type="button" class="segment-btn" data-last="TwoPlusYears"><i class="fas fa-calendar"></i> 2+ years</button>
                <button type="button" class="segment-btn" data-last="NotSure"><i class="fas fa-circle-question"></i> Not sure</button>
            </div>
        </div>

        <div class="info-box-blue">
            <i class="fas fa-circle-info"></i>
            <span>Annual checks help catch moisture, air leaks, and structural issues early.</span>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            Continue <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        bindSingle('[data-enc]', 'data-enc', document.getElementById('Encapsulacion'));
        bindSingle('[data-ins]', 'data-ins', document.getElementById('Aislamiento'));
        bindSingle('[data-vap]', 'data-vap', document.getElementById('BarreraVapor'));
        bindSingle('[data-access]', 'data-access', document.getElementById('TipoAcceso'));
        bindSingle('[data-last]', 'data-last', document.getElementById('UltimaRevision'));
    })();
</script>
</body>
</html>
