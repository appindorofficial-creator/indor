@model IndorMvcApp.ViewModels.CrawlspaceCheckServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}


@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="hvac-hero-icon"><i class="fas fa-warehouse"></i></span>
        </div>
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@Model.LandingTitulo</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@Model.LandingTagline</div>
            }
        </div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.CheckItems.Count > 0)
    {
        <div class="includes-box">
            <div class="includes-label">What we'll check</div>
            <p class="csc-check-hint">Tap to choose the areas you want included in your check.</p>
            <div class="csc-check-grid" id="checkAreasGroup">
                @foreach (var item in Model.CheckItems)
                {
                    <button type="button" class="csc-check-item" data-check="@item.Value" aria-pressed="false">
                        <span class="check"><i class="fas fa-check" aria-hidden="true"></i></span>
                        <i class="fas @item.Icon main" aria-hidden="true"></i>
                        <span class="label">@item.Text</span>
                    </button>
                }
            </div>
            <span id="checkAreasClientError" class="field-error" hidden>Select at least one area to check.</span>
            <span asp-validation-for="CheckAreasSeleccionadas" class="field-error"></span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.BestPracticeTexto))
    {
        <div class="best-practice-box">
            <i class="fas fa-shield-halved"></i>
            <div>
                <strong>Best practice</strong>
                <p>@Model.BestPracticeTexto</p>
            </div>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="CrawlspaceCheckService" method="post" id="csc-service-form">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="CheckAreasSeleccionadas" id="CheckAreasSeleccionadas" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        var hidden = document.getElementById('CheckAreasSeleccionadas');
        var form = document.getElementById('csc-service-form');
        if (!hidden) return;

        function getSelected() {
            return hidden.value ? hidden.value.split('|').filter(Boolean) : [];
        }

        function setSelected(values) {
            hidden.value = values.join('|');
        }

        function syncButtons() {
            var selected = getSelected();
            document.querySelectorAll('[data-check]').forEach(function (btn) {
                var code = btn.getAttribute('data-check');
                var active = selected.indexOf(code) >= 0;
                btn.classList.toggle('active', active);
                btn.setAttribute('aria-pressed', active ? 'true' : 'false');
            });
        }

        document.querySelectorAll('[data-check]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var code = btn.getAttribute('data-check');
                var current = getSelected();
                if (current.indexOf(code) >= 0) {
                    current = current.filter(function (v) { return v !== code; });
                } else {
                    current.push(code);
                }
                setSelected(current);
                syncButtons();
                var clientError = document.getElementById('checkAreasClientError');
                if (clientError) clientError.hidden = current.length > 0;
            });
        });

        if (!hidden.value) {
            var defaults = Array.from(document.querySelectorAll('[data-check]'))
                .map(function (btn) { return btn.getAttribute('data-check'); })
                .filter(Boolean);
            setSelected(defaults);
        }

        syncButtons();

        form?.addEventListener('submit', function (e) {
            var clientError = document.getElementById('checkAreasClientError');
            if (getSelected().length === 0) {
                e.preventDefault();
                if (clientError) clientError.hidden = false;
            } else if (clientError) {
                clientError.hidden = true;
            }
        });
    })();

</script>
}
