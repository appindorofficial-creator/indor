@model IndorMvcApp.ViewModels.RemodelingDetailsViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("RemodelingService", "RemodelingServicio", new { id = Model.ServicioId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


<h2 class="page-heading" style="font-size:1.1rem;text-align:center;">@L["Project details"]</h2>
    <p class="page-lead" style="margin-top:-8px;text-align:center;">@L["Help us prepare an accurate quote for your home."]</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form id="remodeling-details-form" asp-action="RemodelingDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioId" />
        <input type="hidden" asp-for="AlcanceProyecto" id="AlcanceProyecto" />
        <input type="hidden" asp-for="VentanaTiempo" id="VentanaTiempo" />
        <input type="hidden" asp-for="PresupuestoEstimado" id="PresupuestoEstimado" />
        <input type="hidden" asp-for="ContactoPreferido" id="ContactoPreferido" />

        <div class="location-card">
            <i class="fas fa-house main"></i>
            <div class="meta">
                <input asp-for="DireccionPropiedad" placeholder="@L["Project address"]" required style="border:none;background:transparent;width:100%;font-family:inherit;font-weight:600;font-size:0.88rem;" />
            </div>
        </div>
        <span asp-validation-for="DireccionPropiedad" style="color:#B91C1C;font-size:0.82rem;display:block;margin:-8px 0 12px;"></span>

        <div class="field-card">
            <span class="field-label">@L["Project scope"]</span>
            <div class="help-grid" id="scopeGroup">
                <button type="button" class="help-tile" data-value="FullRemodel"><i class="fas fa-hammer"></i>@L["Full remodel"]</button>
                <button type="button" class="help-tile" data-value="PartialUpdate"><i class="fas fa-paint-roller"></i>@L["Partial update"]</button>
                <button type="button" class="help-tile" data-value="DesignConsult"><i class="fas fa-compass-drafting"></i>@L["Design consult"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["When do you want to start?"]</span>
            <div class="chip-scroll" id="timingGroup">
                <button type="button" class="chip-option" data-value="ASAP"><i class="fas fa-bolt"></i> @L["ASAP"]</button>
                <button type="button" class="chip-option" data-value="OneToThreeMonths"><i class="fas fa-calendar"></i> @L["1–3 mo"]</button>
                <button type="button" class="chip-option" data-value="ThreeToSixMonths"><i class="fas fa-calendar-week"></i> @L["3–6 mo"]</button>
                <button type="button" class="chip-option" data-value="Flexible"><i class="fas fa-clock"></i> @L["Flexible"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Estimated budget"]</span>
            <div class="chip-scroll" id="budgetGroup">
                <button type="button" class="chip-option" data-value="Under5k">@L["Under $5k"]</button>
                <button type="button" class="chip-option" data-value="5kTo15k">@L["$5k–15k"]</button>
                <button type="button" class="chip-option" data-value="15kTo50k">@L["$15k–50k"]</button>
                <button type="button" class="chip-option" data-value="Over50k">@L["$50k+"]</button>
                <button type="button" class="chip-option" data-value="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Describe your project"]</span>
            <textarea asp-for="Descripcion" rows="4" maxlength="500" placeholder="@L["Size, materials, goals, anything we should know..."]" style="width:100%;border:1.5px solid #E5E7EB;border-radius:12px;padding:12px;font-family:inherit;font-size:0.88rem;"></textarea>
            <span asp-validation-for="Descripcion" style="color:#B91C1C;font-size:0.82rem;"></span>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Preferred contact"]</span>
            <div class="chip-scroll" id="contactGroup">
                <button type="button" class="chip-option" data-value="Text"><i class="fas fa-comment"></i> @L["Text"]</button>
                <button type="button" class="chip-option" data-value="Call"><i class="fas fa-phone"></i> @L["Call"]</button>
                <button type="button" class="chip-option" data-value="Email"><i class="fas fa-envelope"></i> @L["Email"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Photos (optional)"]</span>
            <input type="file" name="files" accept="image/jpeg,image/png" multiple />
            @if (Model.ArchivosExistentes.Count > 0)
            {
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="included-row" style="margin-top:8px;"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
                }
            }
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">@L["Continue to review"]</button>
        <button type="submit" name="action" value="back" class="btn-outline" formnovalidate>@L["Back"]</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        function initSingle(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const seed = (initial && String(initial).trim()) || '';
            if (!seed) {
                hidden.value = '';
            }

            document.querySelectorAll('#' + groupId + ' .help-tile, #' + groupId + ' .chip-option').forEach(btn => {
                if (seed && btn.dataset.value === seed) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' .help-tile, #' + groupId + ' .chip-option').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                });
            });
            if (seed) hidden.value = seed;
        }
        initSingle('scopeGroup', 'AlcanceProyecto', '@Model.AlcanceProyecto');
        initSingle('timingGroup', 'VentanaTiempo', '@Model.VentanaTiempo');
        initSingle('budgetGroup', 'PresupuestoEstimado', '@Model.PresupuestoEstimado');
        initSingle('contactGroup', 'ContactoPreferido', '@Model.ContactoPreferido');

        const form = document.getElementById('remodeling-details-form');
        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') return;

            const checks = [
                { id: 'AlcanceProyecto', message: @Html.Raw(Json.Serialize(L["Select a project scope."].ToString())) },
                { id: 'VentanaTiempo', message: @Html.Raw(Json.Serialize(L["Select when you want to start."].ToString())) },
                { id: 'PresupuestoEstimado', message: @Html.Raw(Json.Serialize(L["Select an estimated budget."].ToString())) },
                { id: 'ContactoPreferido', message: @Html.Raw(Json.Serialize(L["Select a preferred contact method."].ToString())) }
            ];

            for (const check of checks) {
                const input = document.getElementById(check.id);
                if (!input || !input.value || !input.value.trim()) {
                    e.preventDefault();
                    alert(check.message);
                    return;
                }
            }
        });
    })();

</script>
}
