@model IndorMvcApp.ViewModels.RemodelingDetailsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_RemodelingServicioStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="RemodelingService" asp-route-id="@Model.ServicioId" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_RemodelingServicioStepper", 2)

    <h2 class="page-heading" style="font-size:1.1rem;text-align:center;">Project details</h2>
    <p class="page-lead" style="margin-top:-8px;text-align:center;">Help us prepare an accurate quote for your home.</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="RemodelingDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioId" />
        <input type="hidden" asp-for="AlcanceProyecto" id="AlcanceProyecto" />
        <input type="hidden" asp-for="VentanaTiempo" id="VentanaTiempo" />
        <input type="hidden" asp-for="PresupuestoEstimado" id="PresupuestoEstimado" />
        <input type="hidden" asp-for="ContactoPreferido" id="ContactoPreferido" />

        <div class="location-card">
            <i class="fas fa-house main"></i>
            <div class="meta">
                <input asp-for="DireccionPropiedad" placeholder="Project address" required style="border:none;background:transparent;width:100%;font-family:inherit;font-weight:600;font-size:0.88rem;" />
            </div>
        </div>
        <span asp-validation-for="DireccionPropiedad" style="color:#B91C1C;font-size:0.82rem;display:block;margin:-8px 0 12px;"></span>

        <div class="field-card">
            <span class="field-label">Project scope</span>
            <div class="help-grid" id="scopeGroup">
                <button type="button" class="help-tile" data-value="FullRemodel"><i class="fas fa-hammer"></i>Full remodel</button>
                <button type="button" class="help-tile" data-value="PartialUpdate"><i class="fas fa-paint-roller"></i>Partial update</button>
                <button type="button" class="help-tile" data-value="DesignConsult"><i class="fas fa-compass-drafting"></i>Design consult</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">When do you want to start?</span>
            <div class="chip-scroll" id="timingGroup">
                <button type="button" class="chip-option" data-value="ASAP"><i class="fas fa-bolt"></i> ASAP</button>
                <button type="button" class="chip-option" data-value="OneToThreeMonths"><i class="fas fa-calendar"></i> 1–3 mo</button>
                <button type="button" class="chip-option" data-value="ThreeToSixMonths"><i class="fas fa-calendar-week"></i> 3–6 mo</button>
                <button type="button" class="chip-option" data-value="Flexible"><i class="fas fa-clock"></i> Flexible</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Estimated budget</span>
            <div class="chip-scroll" id="budgetGroup">
                <button type="button" class="chip-option" data-value="Under5k">Under $5k</button>
                <button type="button" class="chip-option" data-value="5kTo15k">$5k–15k</button>
                <button type="button" class="chip-option" data-value="15kTo50k">$15k–50k</button>
                <button type="button" class="chip-option" data-value="Over50k">$50k+</button>
                <button type="button" class="chip-option" data-value="NotSure">Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Describe your project</span>
            <textarea asp-for="Descripcion" rows="4" maxlength="500" placeholder="Size, materials, goals, anything we should know..." style="width:100%;border:1.5px solid #E5E7EB;border-radius:12px;padding:12px;font-family:inherit;font-size:0.88rem;"></textarea>
            <span asp-validation-for="Descripcion" style="color:#B91C1C;font-size:0.82rem;"></span>
        </div>

        <div class="field-card">
            <span class="field-label">Preferred contact</span>
            <div class="chip-scroll" id="contactGroup">
                <button type="button" class="chip-option" data-value="Text"><i class="fas fa-comment"></i> Text</button>
                <button type="button" class="chip-option" data-value="Call"><i class="fas fa-phone"></i> Call</button>
                <button type="button" class="chip-option" data-value="Email"><i class="fas fa-envelope"></i> Email</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Photos (optional)</span>
            <input type="file" name="files" accept="image/jpeg,image/png" multiple />
            @if (Model.ArchivosExistentes.Count > 0)
            {
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="included-row" style="margin-top:8px;"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
                }
            }
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">Continue to review</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>
</div>
<script>
    (function () {
        function initSingle(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' .help-tile, #' + groupId + ' .chip-option').forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' .help-tile, #' + groupId + ' .chip-option').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                });
            });
        }
        initSingle('scopeGroup', 'AlcanceProyecto', '@Model.AlcanceProyecto');
        initSingle('timingGroup', 'VentanaTiempo', '@Model.VentanaTiempo');
        initSingle('budgetGroup', 'PresupuestoEstimado', '@Model.PresupuestoEstimado');
        initSingle('contactGroup', 'ContactoPreferido', '@Model.ContactoPreferido');
    })();
</script>
</body>
</html>
