@model IndorMvcApp.ViewModels.RemodelingReviewViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("RemodelingDetails", "RemodelingServicio", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;

}


<h2 class="page-heading" style="font-size:1.1rem;text-align:center;">Review your request</h2>
    <p class="page-lead" style="margin-top:-8px;text-align:center;">Confirm before we send it to our remodeling team.</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="summary-card">
        <strong style="font-size:0.92rem;display:block;margin-bottom:10px;">Project summary</strong>
        <div class="summary-row"><i class="fas fa-screwdriver-wrench"></i><div><div class="summary-label">Service</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">Address</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-hammer"></i><div><div class="summary-label">Scope</div><div class="summary-value">@Model.AlcanceLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">Timeline</div><div class="summary-value">@Model.VentanaTiempoLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-tags"></i><div><div class="summary-label">Budget</div><div class="summary-value">@Model.PresupuestoLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-comment"></i><div><div class="summary-label">Contact</div><div class="summary-value">@Model.ContactoPreferidoLabel</div></div></div>
        @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
        {
            <div class="summary-row"><i class="fas fa-note-sticky"></i><div><div class="summary-label">Details</div><div class="summary-value">@Model.Descripcion</div></div></div>
        }
    </div>

    @if (Model.ArchivosExistentes.Count > 0)
    {
        <div class="field-card">
            <span class="field-label">Photos</span>
            @foreach (var file in Model.ArchivosExistentes)
            {
                <div class="included-row"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
            }
        </div>
    }

    <form asp-action="RemodelingReview" method="post">
        <input type="hidden" name="id" value="@Model.SolicitudId" />
        <button type="submit" name="action" value="submit" class="btn-primary">Submit for quote</button>
        <button type="submit" name="action" value="edit" class="btn-outline">Edit details</button>
    </form>
