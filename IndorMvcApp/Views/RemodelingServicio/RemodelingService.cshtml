@model IndorMvcApp.ViewModels.RemodelingServiceViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = HomeNavigationUrls.ServicesTab(Url, "services");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}


@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@L.Catalog(Model.LandingTitulo)" class="hero-img" />
        </div>
    }

    <h1 class="page-heading" style="font-size:1.2rem;margin-bottom:4px;">@L.Catalog(Model.LandingTitulo)</h1>
    @if (!string.IsNullOrWhiteSpace(Model.LandingSubtitulo))
    {
        <p class="page-lead">@L.Catalog(Model.LandingSubtitulo)</p>
    }

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="includes-box">
            <strong style="font-size:0.85rem;">@L["What's included"]</strong>
            <ul>
                @foreach (var item in Model.IncludedItems)
                {
                    <li><i class="fas fa-check"></i>@item</li>
                }
            </ul>
        </div>
    }

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L["Tell us about your project and we'll connect you with a licensed remodeling pro for a custom quote."]</span></div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="RemodelingService" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioId" />
        <button type="submit" name="action" value="continue" class="btn-primary"><i class="fas fa-arrow-right"></i> @L.Catalog(Model.CtaTexto)</button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back to Services"]</button>
    </form>
