@model IndorMvcApp.ViewModels.RemodelingServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_RemodelingServicioStyles")
    <style>
        .hero-wrap { position: relative; border-radius: 16px; overflow: hidden; margin-bottom: 16px; }
        .hero-img { width: 100%; height: 180px; object-fit: cover; display: block; }
        .includes-box { background: #F8FAFC; border: 1px solid #E5E7EB; border-radius: 14px; padding: 14px 16px; margin-bottom: 16px; }
        .includes-box ul { margin: 8px 0 0; padding: 0; list-style: none; }
        .includes-box li { font-size: 0.82rem; color: #475569; padding: 4px 0; }
        .includes-box li i { color: #0066CC; margin-right: 8px; }
    </style>
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" asp-fragment="services" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_RemodelingServicioStepper", 1)

    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
        </div>
    }

    <h1 class="page-heading" style="font-size:1.2rem;margin-bottom:4px;">@Model.LandingTitulo</h1>
    @if (!string.IsNullOrWhiteSpace(Model.LandingSubtitulo))
    {
        <p class="page-lead">@Model.LandingSubtitulo</p>
    }

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="includes-box">
            <strong style="font-size:0.85rem;">What's included</strong>
            <ul>
                @foreach (var item in Model.IncludedItems)
                {
                    <li><i class="fas fa-check"></i>@item</li>
                }
            </ul>
        </div>
    }

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>Tell us about your project and we'll connect you with a licensed remodeling pro for a custom quote.</span></div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="RemodelingService" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="ServicioId" />
        <button type="submit" name="action" value="continue" class="btn-primary"><i class="fas fa-arrow-right"></i> @Model.CtaTexto</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back to Services</button>
    </form>
</div>
</body>
</html>
