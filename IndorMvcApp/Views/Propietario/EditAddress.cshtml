@model IndorMvcApp.ViewModels.PropertyInfoViewModel
@using IndorMvcApp.Services
@using IndorMvcApp.ViewModels
@{
    ViewData["Title"] = "Edit Address - INDOR";
    Layout = null;
    var devices = Model.Devices ?? new List<IndorMvcApp.ViewModels.DeviceInfoViewModel>();
    var houseFact = HouseFactDisplayService.BuildProfile(Model.AttomRawJson, Model.DataSource, Model.FormattedAddress);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    @await Html.PartialAsync("_IndorStandalonePageHead")

    <link rel="stylesheet" href="~/css/app-back-button.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            min-height: 100vh;
            padding: 20px 16px 32px;
            color: #0A2540;
        }

        .page-container {
            width: 100%;
            max-width: 520px;
            margin: 0 auto;
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }


        .top-bar-spacer { width: 44px; }

        .smart-home-logo {
            max-height: 42px;
            width: auto;
            display: block;
        }

        .brand-section {
            text-align: center;
            margin-bottom: 20px;
        }

        .brand-tagline {
            font-size: 0.9rem;
            color: #6B7280;
        }

        .brand-tagline .highlight {
            color: #0066CC;
            font-weight: 600;
        }

        .form-card {
            background: #FFFFFF;
            border-radius: 20px;
            padding: 22px 18px;
            box-shadow: 0 12px 40px rgba(10, 37, 64, 0.08);
            border: 1px solid rgba(229, 231, 235, 0.7);
            margin-bottom: 16px;
        }

        .form-alert {
            border-radius: 12px;
            padding: 12px 14px;
            margin-bottom: 14px;
            font-size: 0.88rem;
            line-height: 1.45;
        }

        .form-alert.error {
            background: #FEF2F2;
            border: 1px solid #FECACA;
            color: #991B1B;
        }

        .form-alert.error ul {
            margin: 0;
            padding-left: 18px;
        }

        .section-head {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }

        .section-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, rgba(0, 102, 204, 0.12), rgba(0, 79, 163, 0.12));
            color: #0066CC;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .page-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #0A2540;
            margin: 0;
        }

        .page-subtitle {
            font-size: 0.82rem;
            color: #6B7280;
            margin: 2px 0 0;
        }

        .field-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0 14px;
            width: 100%;
            min-width: 0;
        }

        @@media (min-width: 560px) {
            .field-grid.two-col { grid-template-columns: 1fr 1fr; }
        }

        .field-group { margin-bottom: 14px; min-width: 0; }
        .field-group.full { grid-column: 1 / -1; }

        .input-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: #0A2540;
            margin-bottom: 7px;
        }

        .input-wrapper { position: relative; width: 100%; min-width: 0; max-width: 100%; }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9CA3AF;
            font-size: 0.9rem;
            pointer-events: none;
        }

        .form-input {
            width: 100%;
            max-width: 100%;
            min-width: 0;
            padding: 13px 14px 13px 42px;
            border: 1.5px solid #E5E7EB;
            border-radius: 12px;
            font-size: 0.92rem;
            font-family: 'Inter', sans-serif;
            color: #0A2540;
            background: #F9FAFB;
            transition: all 0.25s ease;
            outline: none;
        }

        .form-input[type="date"] {
            display: block;
            padding-right: 10px;
            -webkit-appearance: none;
            appearance: none;
        }

        .form-input[type="date"]::-webkit-date-and-time-value {
            text-align: left;
        }

        .form-input.no-icon { padding-left: 14px; }

        .form-input::placeholder { color: #9CA3AF; }

        .form-input:focus {
            border-color: #0066CC;
            background: #FFFFFF;
            box-shadow: 0 0 0 4px rgba(0, 102, 204, 0.1);
        }

        .device-form-card {
            background: #F8FAFC;
            border: 1.5px dashed #CBD5E1;
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 12px;
            overflow: hidden;
            max-width: 100%;
        }

        .device-saved-card {
            background: #FFFFFF;
            border: 1px solid #E5E7EB;
            border-left: 4px solid #0066CC;
            border-radius: 12px;
            padding: 14px;
            margin-bottom: 10px;
            box-shadow: 0 4px 14px rgba(10, 37, 64, 0.06);
        }

        .device-saved-meta {
            display: flex;
            flex-direction: column;
            gap: 6px;
            font-size: 0.86rem;
            color: #374151;
            margin-bottom: 10px;
        }

        .device-saved-meta strong { color: #0A2540; }

        .btn-row {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 12px 18px;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.25s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: none;
            text-decoration: none;
        }

        .btn-primary {
            width: 100%;
            padding: 15px 22px;
            border-radius: 14px;
            font-size: 1rem;
            background: linear-gradient(135deg, #0066CC 0%, #004FA3 100%);
            color: #FFFFFF;
            box-shadow: 0 8px 24px rgba(0, 102, 204, 0.25);
            margin-top: 6px;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 28px rgba(0, 102, 204, 0.32);
        }

        .btn-secondary {
            background: #EFF6FF;
            color: #004FA3;
            border: 1px solid #BFDBFE;
        }

        .btn-secondary:hover { background: #DBEAFE; }

        .btn-danger-outline {
            background: transparent;
            color: #DC2626;
            border: 1px solid #FECACA;
            padding: 8px 12px;
            font-size: 0.82rem;
        }

        .btn-danger-outline:hover {
            background: #FEF2F2;
        }

        .empty-devices {
            font-size: 0.84rem;
            color: #6B7280;
            text-align: center;
            padding: 12px;
            background: #F9FAFB;
            border-radius: 10px;
            margin-bottom: 10px;
        }

        @@media (max-width: 480px) {
            .form-card { padding: 18px 14px; }
        }
    </style>
</head>
<body>
    <div class="page-container">
        <div class="top-bar">
            <a asp-controller="Propietario" asp-action="PropertyDetails" class="app-back-btn" aria-label="Back">
                <i class="fas fa-chevron-left"></i>
            </a>
            <img src="~/logoindor.png" alt="Indor" class="smart-home-logo" />
            <div style="width:44px;"></div>
        </div>

        <div class="brand-section">
            <p class="brand-tagline">Review and <span class="highlight">confirm</span> your property details</p>
        </div>

        @if (houseFact.HasData)
        {
            <div style="margin-bottom:18px;">
                @await Html.PartialAsync("_HouseFactProfile", houseFact, new ViewDataDictionary(ViewData) { { "Compact", true }, { "ShowJson", false } })
            </div>
        }

        <form asp-action="EditAddress" method="post" id="mainForm">
            <input type="hidden" name="OriginalJson" value='@((TempData["PropertyInfoJson"] ?? "").ToString())' />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="form-alert error" role="alert">
                    @Html.ValidationSummary(excludePropertyErrors: false, message: "We couldn't save your property yet. Please review the fields and try again.")
                </div>
            }

            <div class="form-card">
                <div class="section-head">
                    <div class="section-icon"><i class="fas fa-map-marker-alt"></i></div>
                    <div>
                        <h2 class="page-title">Address</h2>
                        <p class="page-subtitle">Verify the location information</p>
                    </div>
                </div>

                <div class="field-grid">
                    <div class="field-group full">
                        <label asp-for="FormattedAddress" class="input-label">Full address</label>
                        <div class="input-wrapper">
                            <i class="fas fa-location-dot input-icon"></i>
                            <input asp-for="FormattedAddress" class="form-input" placeholder="123 Main Street, Miami, FL" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label asp-for="Street" class="input-label">Street</label>
                        <div class="input-wrapper">
                            <i class="fas fa-road input-icon"></i>
                            <input asp-for="Street" class="form-input" placeholder="Main Street" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label asp-for="HouseNumber" class="input-label">Number</label>
                        <div class="input-wrapper">
                            <i class="fas fa-hashtag input-icon"></i>
                            <input asp-for="HouseNumber" class="form-input" placeholder="123" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label asp-for="City" class="input-label">City</label>
                        <div class="input-wrapper">
                            <i class="fas fa-city input-icon"></i>
                            <input asp-for="City" class="form-input" placeholder="Miami" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label asp-for="State" class="input-label">State / Province</label>
                        <div class="input-wrapper">
                            <i class="fas fa-flag input-icon"></i>
                            <input asp-for="State" class="form-input" placeholder="FL" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label asp-for="PostalCode" class="input-label">Postal code</label>
                        <div class="input-wrapper">
                            <i class="fas fa-mail-bulk input-icon"></i>
                            <input asp-for="PostalCode" class="form-input" placeholder="33101" />
                        </div>
                    </div>
                    <div class="field-group full">
                        <label asp-for="Country" class="input-label">Country</label>
                        <div class="input-wrapper">
                            <i class="fas fa-globe input-icon"></i>
                            <input asp-for="Country" class="form-input" placeholder="United States" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="section-head">
                    <div class="section-icon"><i class="fas fa-house"></i></div>
                    <div>
                        <h2 class="page-title">Property details</h2>
                        <p class="page-subtitle">Optional information about your home</p>
                    </div>
                </div>

                <div class="field-grid two-col">
                    <div class="field-group">
                        <label class="input-label">Year built</label>
                        <div class="input-wrapper">
                            <i class="fas fa-calendar input-icon"></i>
                            <input name="PropertyDetails.YearBuilt" class="form-input property-number" type="number" min="1800" max="2100"
                                   data-range-message="Enter a year between 1800 and 2100."
                                   placeholder="1998"
                                   value="@(Model.PropertyDetails?.YearBuilt)" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="input-label">Living area (sq ft)</label>
                        <div class="input-wrapper">
                            <i class="fas fa-ruler-combined input-icon"></i>
                            <input name="PropertyDetails.LivingArea" class="form-input property-number" type="number" min="0"
                                   data-range-message="Living area must be 0 or greater."
                                   placeholder="1800"
                                   value="@(Model.PropertyDetails?.LivingArea)" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="input-label">Lot size (acres)</label>
                        <div class="input-wrapper">
                            <i class="fas fa-tree input-icon"></i>
                            <input name="PropertyDetails.LotSize" class="form-input property-number" type="number" min="0" max="10000" step="0.01"
                                   data-range-message="Lot size must be between 0 and 10,000 acres."
                                   placeholder="0.25"
                                   value="@(Model.PropertyDetails?.LotSize)" />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="input-label">Lot size (sq ft)</label>
                        <div class="input-wrapper">
                            <i class="fas fa-draw-polygon input-icon"></i>
                            <input name="PropertyDetails.LotSizeSqFt" class="form-input property-number" type="number" min="0"
                                   data-range-message="Lot size must be 0 or greater."
                                   placeholder="10890"
                                   value="@(Model.PropertyDetails?.LotSizeSqFt)" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-card">
                <div class="section-head">
                    <div class="section-icon"><i class="fas fa-microchip"></i></div>
                    <div>
                        <h2 class="page-title">Devices</h2>
                        <p class="page-subtitle">Add appliances and equipment with warranty dates</p>
                    </div>
                </div>

                <div class="device-form-card">
                    <div class="field-grid two-col">
                        <div class="field-group">
                            <label class="input-label" for="deviceType">Device type</label>
                            <div class="input-wrapper">
                                <i class="fas fa-fan input-icon"></i>
                                <input id="deviceType" class="form-input" placeholder="Air conditioner" />
                            </div>
                        </div>
                        <div class="field-group">
                            <label class="input-label" for="deviceSerial">Serial</label>
                            <div class="input-wrapper">
                                <i class="fas fa-barcode input-icon"></i>
                                <input id="deviceSerial" class="form-input" placeholder="Serial number" />
                            </div>
                        </div>
                        <div class="field-group full">
                            <label class="input-label" for="deviceWarranty">Warranty date</label>
                            <div class="input-wrapper">
                                <i class="fas fa-shield-halved input-icon"></i>
                                <input id="deviceWarranty" class="form-input" type="date" />
                            </div>
                        </div>
                    </div>
                    <div class="btn-row" style="justify-content: flex-end; margin-top: 4px;">
                        <button type="button" class="btn btn-secondary" onclick="saveDevice()">
                            <i class="fas fa-plus"></i> Add device
                        </button>
                    </div>
                </div>

                <div id="devices-list">
                    @if (devices.Count == 0)
                    {
                        <div class="empty-devices" id="devicesEmpty">No devices added yet.</div>
                    }
                    else
                    {
                        @for (var i = 0; i < devices.Count; i++)
                        {
                            var dev = devices[i];
                            var warrantyText = dev.WarrantyDate.HasValue ? dev.WarrantyDate.Value.ToString("yyyy-MM-dd") : "No date";
                            var warrantyValue = dev.WarrantyDate.HasValue ? dev.WarrantyDate.Value.ToString("yyyy-MM-dd") : "";

                            <div class="device-saved-card device-item">
                                <div class="device-saved-meta">
                                    <div><strong>Type:</strong> <span class="device-type">@dev.Type</span></div>
                                    <div><strong>Serial:</strong> <span class="device-serial">@(string.IsNullOrWhiteSpace(dev.Serial) ? "N/A" : dev.Serial)</span></div>
                                    <div><strong>Warranty:</strong> <span class="device-warranty">@warrantyText</span></div>
                                </div>
                                <button type="button" class="btn btn-danger-outline" onclick="removeDevice(this)">
                                    <i class="fas fa-trash-alt"></i> Remove
                                </button>
                                <input type="hidden" name="Devices[@i].Type" class="device-type-input" value="@dev.Type" />
                                <input type="hidden" name="Devices[@i].Serial" class="device-serial-input" value="@dev.Serial" />
                                <input type="hidden" name="Devices[@i].WarrantyDate" class="device-warranty-input" value="@warrantyValue" />
                            </div>
                        }
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-check"></i>
                Save changes
            </button>
        </form>
    </div>

    <template id="device-template">
        <div class="device-saved-card device-item">
            <div class="device-saved-meta">
                <div><strong>Type:</strong> <span class="device-type"></span></div>
                <div><strong>Serial:</strong> <span class="device-serial"></span></div>
                <div><strong>Warranty:</strong> <span class="device-warranty"></span></div>
            </div>
            <button type="button" class="btn btn-danger-outline" onclick="removeDevice(this)">
                <i class="fas fa-trash-alt"></i> Remove
            </button>
            <input type="hidden" name="Devices[__index__].Type" class="device-type-input" />
            <input type="hidden" name="Devices[__index__].Serial" class="device-serial-input" />
            <input type="hidden" name="Devices[__index__].WarrantyDate" class="device-warranty-input" />
        </div>
    </template>

    <script>
        let deviceIndex = @devices.Count;

        function bindEnglishNumberValidation(input) {
            const rangeMessage = input.getAttribute('data-range-message') || 'Enter a valid value.';
            const max = input.max !== '' ? Number(input.max) : null;
            const min = input.min !== '' ? Number(input.min) : null;

            function validateRange() {
                input.setCustomValidity('');
                const raw = input.value.trim();
                if (!raw) return;

                const val = Number(raw);
                if (Number.isNaN(val)) {
                    input.setCustomValidity('Enter a valid number.');
                    return;
                }
                if (min !== null && val < min) {
                    input.setCustomValidity(rangeMessage);
                } else if (max !== null && val > max) {
                    input.setCustomValidity(rangeMessage);
                }
            }

            input.addEventListener('input', validateRange);
            input.addEventListener('invalid', () => {
                if (input.validity.rangeUnderflow || input.validity.rangeOverflow) {
                    input.setCustomValidity(rangeMessage);
                } else if (input.validity.badInput || input.validity.stepMismatch) {
                    input.setCustomValidity('Enter a valid number.');
                }
            });
        }

        document.querySelectorAll('.property-number').forEach(bindEnglishNumberValidation);

        function hideDevicesEmpty() {
            const empty = document.getElementById('devicesEmpty');
            if (empty) empty.remove();
        }

        function reindexDevices() {
            document.querySelectorAll('#devices-list .device-item').forEach((card, idx) => {
                card.querySelector('.device-type-input').setAttribute('name', `Devices[${idx}].Type`);
                card.querySelector('.device-serial-input').setAttribute('name', `Devices[${idx}].Serial`);
                card.querySelector('.device-warranty-input').setAttribute('name', `Devices[${idx}].WarrantyDate`);
            });
            deviceIndex = document.querySelectorAll('#devices-list .device-item').length;
        }

        function saveDevice() {
            const type = document.getElementById('deviceType').value.trim();
            const serial = document.getElementById('deviceSerial').value.trim();
            const warranty = document.getElementById('deviceWarranty').value;

            if (!type) {
                alert('Device type is required.');
                return;
            }

            hideDevicesEmpty();

            const template = document.getElementById('device-template').innerHTML;
            const html = template.replace(/__index__/g, deviceIndex);
            const div = document.createElement('div');
            div.innerHTML = html;
            const card = div.firstElementChild;
            card.querySelector('.device-type').textContent = type;
            card.querySelector('.device-serial').textContent = serial || 'N/A';
            card.querySelector('.device-warranty').textContent = warranty || 'No date';
            card.querySelector('.device-type-input').value = type;
            card.querySelector('.device-serial-input').value = serial;
            card.querySelector('.device-warranty-input').value = warranty;

            document.getElementById('devices-list').appendChild(card);
            reindexDevices();

            document.getElementById('deviceType').value = '';
            document.getElementById('deviceSerial').value = '';
            document.getElementById('deviceWarranty').value = '';
        }

        function removeDevice(btn) {
            btn.closest('.device-item').remove();
            reindexDevices();
            if (deviceIndex === 0) {
                const list = document.getElementById('devices-list');
                list.innerHTML = '<div class="empty-devices" id="devicesEmpty">No devices added yet.</div>';
            }
        }
    </script>
</body>
</html>
