@model IndorMvcApp.ViewModels.AddPropertyViewModel
@using IndorMvcApp.Localization
@{
    ViewData["Title"] = L["Add Your Property - INDOR"];
    Layout = null;
    ViewBag.OnboardingStep = 4;
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    @await Html.PartialAsync("_NavigationLoadingHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
</head>
<body class="ob-page">
    <div class="ob-shell">
        <div class="ob-shell-inner">
            @await Html.PartialAsync("_OnboardingNav")
            @await Html.PartialAsync("_OnboardingStepper")

            <div class="ob-head-block">
                <h1>@L["Add Your Property"]</h1>
                <p>@L["Let's add the address of the property you own."]</p>
            </div>

            <div class="ob-form-card">
                <div class="ob-field">
                    <label class="ob-label">@L["Property Address"]</label>
                    <div class="ob-search">
                        <i class="fas fa-magnifying-glass"></i>
                        <input type="text" readonly value="@Model.Address" />
                    </div>
                </div>

                <div class="ob-address-card">
                    <i class="fas fa-location-dot"></i>
                    <div class="addr">@Model.Address</div>
                </div>

                <form asp-action="ConfirmProperty" method="post">
                    @Html.AntiForgeryToken()
                    <div class="ob-field">
                        <label for="unit" class="ob-label">@L["Apt, Suite, Unit"] <span style="font-weight:400;color:#94A3B8;">(@L["Optional"])</span></label>
                        <input type="text" name="unit" id="unit" class="ob-control" value="@Model.Unit" placeholder="@L["e.g. Apt 4B"]" maxlength="50" />
                    </div>

                    <button type="submit" class="ob-btn ob-btn-primary">@L["Continue"]</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
