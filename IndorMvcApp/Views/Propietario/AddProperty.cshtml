@model IndorMvcApp.ViewModels.AddPropertyViewModel
@{
    ViewData["Title"] = "Add Your Property - INDOR";
    Layout = null;
    ViewBag.OnboardingStep = 3;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/property-loading.css" asp-append-version="true" />
</head>
<body class="ob-page">
    <div class="ob-shell">
        <div class="ob-shell-inner">
            @await Html.PartialAsync("_OnboardingNav")
            @await Html.PartialAsync("_OnboardingStepper")

            <div class="ob-head-block">
                <h1>Add Your Property</h1>
                <p>Let's add the address of the property you own.</p>
            </div>

            <div class="ob-form-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="ob-summary"></div>
                }

                <form asp-action="AddProperty" method="post" data-property-research-loading>
                    @Html.AntiForgeryToken()
                    <div class="ob-field">
                        <label asp-for="Address" class="ob-label">Property Address</label>
                        <div class="ob-search">
                            <i class="fas fa-magnifying-glass"></i>
                            <input asp-for="Address" placeholder="Search your address..." autocomplete="street-address" />
                        </div>
                        <span asp-validation-for="Address" class="ob-error"></span>
                    </div>

                    <button type="submit" class="ob-btn ob-btn-primary">Search Address</button>
                </form>
            </div>
        </div>
    </div>
    @await Html.PartialAsync("_PropertyResearchLoading")
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
