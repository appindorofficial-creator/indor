@model IndorMvcApp.ViewModels.AddPropertyViewModel
@using IndorMvcApp.Models
@{
    ViewData["Title"] = "Add Your Property - INDOR";
    Layout = null;
    ViewBag.OnboardingStep = 3;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    @await Html.PartialAsync("_AppVersionHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/property-loading.css" asp-append-version="true" />
</head>
<body class="ob-page">
    <div class="ob-shell">
        <div class="ob-shell-inner">
            @await Html.PartialAsync("_OnboardingNav")
            @await Html.PartialAsync("_OnboardingStepper")

            <div class="ob-head-block">
                <h1>Add Your Property</h1>
                <p>Start with the house number and street name. We'll auto-fill the city, state, ZIP code, and property details when available.</p>
            </div>

            <div class="ob-form-card">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="ob-summary"></div>
                }

                <form asp-action="AddProperty" method="post" data-property-research-loading autocomplete="on">
                    @Html.AntiForgeryToken()

                    <div class="ob-field">
                        <label asp-for="StreetAddress" class="ob-label">Street Address</label>
                        <div class="ob-search">
                            <i class="fas fa-magnifying-glass"></i>
                            <input asp-for="StreetAddress"
                                   id="street-address"
                                   name="StreetAddress"
                                   placeholder="Enter house number and street name"
                                   autocomplete="address-line1"
                                   inputmode="text"
                                   data-address-autocomplete
                                   data-ac-street-only="true"
                                   data-ac-city="city"
                                   data-ac-state="state"
                                   data-ac-zip="zip" />
                        </div>
                        <span asp-validation-for="StreetAddress" class="ob-error"></span>
                    </div>

                    <div class="ob-address-row ob-address-row--2">
                        <div class="ob-field">
                            <label asp-for="City" class="ob-label">City</label>
                            <input asp-for="City"
                                   id="city"
                                   name="City"
                                   class="ob-control"
                                   placeholder="City"
                                   autocomplete="address-level2" />
                            <span asp-validation-for="City" class="ob-error"></span>
                        </div>
                        <div class="ob-field">
                            <label asp-for="State" class="ob-label">State</label>
                            <select asp-for="State"
                                    id="state"
                                    name="State"
                                    class="ob-control ob-control--select"
                                    autocomplete="address-level1">
                                <option value="">State</option>
                                @foreach (var stateCode in PropertyAdministratorCatalog.UsStateCodes)
                                {
                                    <option value="@stateCode">@stateCode</option>
                                }
                            </select>
                            <span asp-validation-for="State" class="ob-error"></span>
                        </div>
                    </div>

                    <div class="ob-address-row ob-address-row--2">
                        <div class="ob-field">
                            <label asp-for="ZipCode" class="ob-label">ZIP Code</label>
                            <input asp-for="ZipCode"
                                   id="zip"
                                   name="ZipCode"
                                   class="ob-control"
                                   placeholder="ZIP Code"
                                   autocomplete="postal-code"
                                   inputmode="numeric"
                                   maxlength="10" />
                            <span asp-validation-for="ZipCode" class="ob-error"></span>
                        </div>
                        <div class="ob-field">
                            <label asp-for="Unit" class="ob-label">Unit / Apt <span class="ob-label-optional">(Optional)</span></label>
                            <input asp-for="Unit"
                                   id="unit"
                                   name="Unit"
                                   class="ob-control"
                                   placeholder="Unit, Apt, Suite, etc."
                                   autocomplete="address-line2" />
                            <span asp-validation-for="Unit" class="ob-error"></span>
                        </div>
                    </div>

                    <p class="ob-address-hint">
                        <i class="fas fa-circle-info" aria-hidden="true"></i>
                        As you type your street address, we'll automatically find and fill the city, state, ZIP, and property info when available.
                    </p>

                    <button type="submit" class="ob-btn ob-btn-primary">Find Property</button>
                </form>
            </div>
        </div>
    </div>
    @await Html.PartialAsync("_PropertyResearchLoading")
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @await Html.PartialAsync("_AddressAutocompleteScripts")
</body>
</html>
