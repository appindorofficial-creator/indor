@model IndorMvcApp.ViewModels.UtilitiesSetupUtilitiesViewModel
@{
    ViewData["Title"] = L[Model.PageTitle] + " - INDOR";
    string PhoneHref(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return "#";
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        return string.IsNullOrEmpty(digits) ? "#" : $"tel:{digits}";
    }
    ViewData["WizardTitle"] = L[Model.PageTitle];
    ViewData["WizardBackUrl"] = Url.Action("UtilitiesSetupInternet", "UtilitiesSetup", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;
}

<h2 class="page-heading" style="font-size:1.1rem;">@L["Your Utility Contacts"]</h2>
    <p class="page-lead" style="margin-top:-8px;">@L["Providers that serve"] @Model.DireccionPropiedad</p>

    <div class="location-card">
        <div class="thumb"><i class="fas fa-house" style="color:#0066CC;"></i></div>
        <div class="meta">
            <div class="addr">@Model.DireccionPropiedad</div>
            <div class="sub"><i class="fas fa-calendar"></i> @Model.FechaServicioLabel</div>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="field-card">
        @if (Model.Contactos.Count == 0)
        {
            <p style="font-size:0.88rem;color:#64748B;">@L["No utility contacts found for the selected services."]</p>
        }
        else
        {
            @foreach (var contact in Model.Contactos)
            {
                <div class="utility-row">
                    <i class="fas @contact.Icon icon"></i>
                    <div class="body">
                        <div class="type">@contact.TipoLabel</div>
                        <div class="name">@contact.Nombre</div>
                        <div class="meta">
                            @if (!string.IsNullOrWhiteSpace(contact.Telefono))
                            {
                                <div><i class="fas fa-phone"></i> @contact.Telefono</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(contact.Website))
                            {
                                <div><i class="fas fa-globe"></i> @contact.Website.Replace("https://", "").Replace("http://", "")</div>
                            }
                        </div>
                    </div>
                    <div class="utility-actions">
                        @if (!string.IsNullOrWhiteSpace(contact.Telefono))
                        {
                            <a href="@PhoneHref(contact.Telefono)"><i class="fas fa-phone"></i> @L["Call"]</a>
                        }
                        @if (!string.IsNullOrWhiteSpace(contact.Website))
                        {
                            <a href="@contact.Website" target="_blank" rel="noopener"><i class="fas fa-globe"></i> @L["Website"]</a>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L["These contacts will be included in your setup summary and saved to My Home if you choose that option."]</span></div>

    <form asp-action="UtilitiesSetupUtilities" method="post">
        <input type="hidden" name="id" value="@Model.SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">@L["Continue"]</button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>
</div>
