@model IndorMvcApp.ViewModels.UtilitiesSetupUtilitiesViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
    string PhoneHref(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return "#";
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        return string.IsNullOrEmpty(digits) ? "#" : $"tel:{digits}";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_UtilitiesSetupStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="UtilitiesSetupInternet" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_UtilitiesSetupStepper", 3)

    <h2 class="page-heading" style="font-size:1.1rem;">Your Utility Contacts</h2>
    <p class="page-lead" style="margin-top:-8px;">Providers that serve @Model.DireccionPropiedad</p>

    <div class="location-card">
        <div class="thumb"><i class="fas fa-house" style="color:#0066CC;"></i></div>
        <div class="meta">
            <div class="addr">@Model.DireccionPropiedad</div>
            <div class="sub"><i class="fas fa-calendar"></i> @Model.FechaServicioLabel</div>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="field-card">
        @if (Model.Contactos.Count == 0)
        {
            <p style="font-size:0.88rem;color:#64748B;">No utility contacts found for the selected services.</p>
        }
        else
        {
            @foreach (var contact in Model.Contactos)
            {
                <div class="utility-row">
                    <i class="fas @contact.Icon icon"></i>
                    <div class="body">
                        <div class="type">@contact.TipoLabel</div>
                        <div class="name">@contact.Nombre</div>
                        <div class="meta">
                            @if (!string.IsNullOrWhiteSpace(contact.Telefono))
                            {
                                <div><i class="fas fa-phone"></i> @contact.Telefono</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(contact.Website))
                            {
                                <div><i class="fas fa-globe"></i> @contact.Website.Replace("https://", "").Replace("http://", "")</div>
                            }
                        </div>
                    </div>
                    <div class="utility-actions">
                        @if (!string.IsNullOrWhiteSpace(contact.Telefono))
                        {
                            <a href="@PhoneHref(contact.Telefono)"><i class="fas fa-phone"></i> Call</a>
                        }
                        @if (!string.IsNullOrWhiteSpace(contact.Website))
                        {
                            <a href="@contact.Website" target="_blank" rel="noopener"><i class="fas fa-globe"></i> Website</a>
                        }
                    </div>
                </div>
            }
        }
    </div>

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>These contacts will be included in your setup summary and saved to My Home if you choose that option.</span></div>

    <form asp-action="UtilitiesSetupUtilities" method="post">
        <input type="hidden" name="id" value="@Model.SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">Continue</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>
</div>
</body>
</html>
