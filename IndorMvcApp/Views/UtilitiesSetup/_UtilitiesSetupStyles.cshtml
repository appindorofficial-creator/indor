@await Html.PartialAsync("../Cleaning/_CleaningStyles")
<style>
    .service-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
    .service-tile { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 14px; padding: 12px 6px; font-weight: 600; font-size: 0.68rem; color: #64748B; cursor: pointer; text-align: center; position: relative; line-height: 1.25; }
    .service-tile i { display: block; font-size: 1rem; margin-bottom: 6px; color: #94A3B8; }
    .service-tile.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .service-tile.active i { color: #0066CC; }
    .service-tile .check { position: absolute; top: 6px; right: 6px; width: 16px; height: 16px; border-radius: 50%; background: #0066CC; color: #FFF; display: none; align-items: center; justify-content: center; font-size: 0.55rem; }
    .service-tile.active .check { display: flex; }
    .pref-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .pref-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 14px; padding: 14px 10px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; }
    .pref-btn i { display: block; font-size: 1rem; margin-bottom: 6px; color: #94A3B8; }
    .pref-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .pref-btn.active i { color: #0066CC; }
    .provider-card { border: 1.5px solid #E5E7EB; border-radius: 16px; padding: 14px; margin-bottom: 10px; background: #FFF; cursor: pointer; }
    .provider-card.selected { border-color: #0066CC; background: rgba(0,102,204,0.04); }
    .provider-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
    .provider-head strong { font-size: 0.95rem; }
    .provider-badge { border-radius: 999px; padding: 4px 10px; font-size: 0.68rem; font-weight: 700; }
    .badge-blue { background: rgba(0,102,204,0.1); color: #0066CC; }
    .badge-green { background: rgba(34,197,94,0.12); color: #15803D; }
    .badge-purple { background: rgba(139,92,246,0.12); color: #7C3AED; }
    .provider-meta { font-size: 0.78rem; color: #64748B; margin-bottom: 8px; }
    .provider-price { font-size: 0.88rem; font-weight: 700; margin-bottom: 10px; }
    .provider-actions { display: flex; gap: 8px; align-items: center; }
    .provider-actions .mini { border: 1.5px solid #E5E7EB; background: #FFF; border-radius: 999px; padding: 8px 12px; font-size: 0.72rem; font-weight: 600; color: #64748B; }
    .provider-actions .selected-pill { border: none; background: #0066CC; color: #FFF; border-radius: 999px; padding: 8px 14px; font-size: 0.72rem; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; }
    .cable-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .cable-card { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 14px; padding: 12px 8px; text-align: center; cursor: pointer; font-size: 0.72rem; font-weight: 600; color: #64748B; position: relative; }
    .cable-card i { display: block; font-size: 1rem; margin-bottom: 6px; color: #94A3B8; }
    .cable-card .sub { display: block; font-size: 0.65rem; font-weight: 500; color: #94A3B8; margin-top: 4px; }
    .cable-card.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .cable-card.active i { color: #0066CC; }
    .cable-card .radio { position: absolute; top: 8px; right: 8px; width: 14px; height: 14px; border-radius: 50%; border: 2px solid #CBD5E1; }
    .cable-card.active .radio { border-color: #0066CC; background: #0066CC; box-shadow: inset 0 0 0 2px #FFF; }
    .utility-row { display: flex; align-items: flex-start; gap: 12px; padding: 14px 0; border-bottom: 1px solid #F1F5F9; }
    .utility-row:last-child { border-bottom: none; }
    .utility-row i.icon { color: #0066CC; width: 20px; text-align: center; margin-top: 2px; }
    .utility-row .body { flex: 1; min-width: 0; }
    .utility-row .type { font-size: 0.72rem; color: #94A3B8; font-weight: 600; margin-bottom: 2px; }
    .utility-row .name { font-size: 0.92rem; font-weight: 700; margin-bottom: 4px; }
    .utility-row .meta { font-size: 0.78rem; color: #64748B; line-height: 1.4; }
    .utility-actions { display: flex; gap: 8px; flex-shrink: 0; }
