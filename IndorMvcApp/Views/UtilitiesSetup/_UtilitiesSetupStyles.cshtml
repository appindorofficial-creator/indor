    .status-selected { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; background: rgba(34,197,94,0.12); color: #15803D; font-size: 0.68rem; font-weight: 700; }
    .success-banner { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 18px; font-size: 0.86rem; line-height: 1.45; }
    .success-banner i { color: #16A34A; margin-top: 2px; flex-shrink: 0; }
    .completed-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
    .completed-card { background: #FFF; border: 1px solid #E5E7EB; border-radius: 14px; padding: 14px; position: relative; font-size: 0.78rem; }
    .completed-card .check-corner { position: absolute; top: 10px; right: 10px; color: #16A34A; font-size: 0.85rem; }
    .completed-card i.main { color: #0066CC; font-size: 1.1rem; margin-bottom: 8px; display: block; }
    .completed-card .label { font-size: 0.68rem; color: #94A3B8; font-weight: 600; margin-bottom: 4px; }
    .completed-card .provider { font-weight: 700; margin-bottom: 6px; }
    .completed-card .link { color: #0066CC; font-size: 0.72rem; word-break: break-all; }
