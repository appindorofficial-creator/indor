    .us-step { flex: 1; min-width: 68px; text-align: center; }
    .us-step-dot { width: 28px; height: 28px; border-radius: 50%; margin: 0 auto 6px; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; border: 2px solid #CBD5E1; color: #94A3B8; background: #FFF; }
    .us-step.done .us-step-dot { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .us-step.active .us-step-dot { border-color: #0066CC; color: #0066CC; background: #FFF; }
    .us-step-label { font-size: 0.58rem; font-weight: 600; color: #94A3B8; line-height: 1.2; }
    .us-step.active .us-step-label, .us-step.done .us-step-label { color: #0066CC; }
    .location-card { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border: 1.5px solid #E5E7EB; border-radius: 12px; background: #FFF; margin-bottom: 16px; }
    .location-card .thumb { width: 48px; height: 48px; border-radius: 10px; object-fit: cover; background: rgba(0,102,204,0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .location-card .meta { flex: 1; min-width: 0; }
    .location-card .addr { font-weight: 600; font-size: 0.88rem; line-height: 1.3; }
    .location-card .sub { font-size: 0.78rem; color: #64748B; margin-top: 2px; }
</style>
