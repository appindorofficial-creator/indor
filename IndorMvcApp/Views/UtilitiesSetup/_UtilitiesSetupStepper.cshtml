@model int
@{
    var steps = new[] { "Address", "Internet", "Utilities", "Confirm" };
}
<div class="us-stepper">
    @for (var i = 0; i < steps.Length; i++)
    {
        var stepNum = i + 1;
        var css = stepNum < Model ? "us-step done" : stepNum == Model ? "us-step active" : "us-step";
        <div class="@css">
            <div class="us-step-dot">
                @if (stepNum < Model)
                {
                    <i class="fas fa-check" style="font-size:0.7rem;"></i>
                }
                else
                {
                    @stepNum
                }
            </div>
            <div class="us-step-label">@steps[i]</div>
        </div>
    }
</div>
