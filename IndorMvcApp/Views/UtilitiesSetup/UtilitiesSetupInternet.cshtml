@model IndorMvcApp.ViewModels.UtilitiesSetupInternetViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = "Internet & Cable Options - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("UtilitiesSetupAddress", "UtilitiesSetup", new { id = Model.MovingSetupServicioId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


<h2 class="page-heading" style="font-size:1.1rem;">Internet & Cable Options</h2>
    <p class="page-lead" style="margin-top:-8px;">Available at your address: @Model.DireccionPropiedad</p>

    <div class="address-card">
        <div class="left"><i class="fas fa-house" style="color:#0066CC;"></i><span style="font-weight:600;font-size:0.92rem;">@Model.DireccionPropiedad</span></div>
        <a asp-action="UtilitiesSetupAddress" asp-route-id="@Model.MovingSetupServicioId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;"><i class="fas fa-pen"></i> Edit</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="UtilitiesSetupInternet" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ProveedorInternetId" id="ProveedorInternetId" />
        <input type="hidden" asp-for="OpcionCable" id="OpcionCable" />

        @foreach (var provider in Model.Proveedores)
        {
            var badgeClass = UtilitiesSetupDisplayLabels.ProviderBadgeClass(provider.Etiqueta);
            <div class="provider-card @(provider.Selected ? "selected" : "")" data-provider-id="@provider.Id">
                <div class="provider-head">
                    <strong>@provider.Nombre</strong>
                    @if (!string.IsNullOrWhiteSpace(provider.Etiqueta))
                    {
                        <span class="provider-badge @badgeClass">@provider.Etiqueta</span>
                    }
                </div>
                <div class="provider-meta">@provider.Velocidad · @provider.DetalleExtra</div>
                <div class="provider-price">From $@provider.PrecioDesde.ToString("0.00") /mo</div>
                <div class="provider-actions">
                    <span class="mini">View plans</span>
                    @if (provider.Selected)
                    {
                        <span class="selected-pill"><i class="fas fa-check"></i> Selected</span>
                    }
                    else
                    {
                        <span class="mini">Choose</span>
                    }
                </div>
            </div>
        }

        <div class="field-card">
            <span class="field-label">How would you like to get cable? (Optional)</span>
            <div class="cable-grid" id="cableGroup">
                <button type="button" class="cable-card" data-value="InternetOnly"><span class="radio"></span><i class="fas fa-desktop"></i>Internet only<span class="sub">No TV service</span></button>
                <button type="button" class="cable-card" data-value="InternetTv"><span class="radio"></span><i class="fas fa-tv"></i>Internet + TV<span class="sub">Add TV service</span></button>
                <button type="button" class="cable-card" data-value="BringMyOwn"><span class="radio"></span><i class="fas fa-router"></i>Bring my own<span class="sub">I'll use my provider</span></button>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">Continue</button>
        <button type="submit" name="action" value="skip" class="btn-outline">Skip internet for now</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        const providerHidden = document.getElementById('ProveedorInternetId');
        const cableHidden = document.getElementById('OpcionCable');

        document.querySelectorAll('.provider-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.provider-card').forEach(c => {
                    c.classList.remove('selected');
                    const actions = c.querySelector('.provider-actions');
                    if (actions) {
                        actions.innerHTML = '<span class="mini">View plans</span><span class="mini">Choose</span>';
                    }
                });
                card.classList.add('selected');
                providerHidden.value = card.dataset.providerId;
                const actions = card.querySelector('.provider-actions');
                if (actions) {
                    actions.innerHTML = '<span class="mini">View plans</span><span class="selected-pill"><i class="fas fa-check"></i> Selected</span>';
                }
            });
        });

        document.querySelectorAll('#cableGroup .cable-card').forEach(btn => {
            if (btn.dataset.value === cableHidden.value) btn.classList.add('active');
            btn.addEventListener('click', () => {
                document.querySelectorAll('#cableGroup .cable-card').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                cableHidden.value = btn.dataset.value;
            });
        });
    })();

</script>
}
