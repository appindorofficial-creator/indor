@model IndorMvcApp.ViewModels.UtilitiesSetupInternetViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = L["Internet & Cable Options - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("UtilitiesSetupAddress", "UtilitiesSetup", new { id = Model.MovingSetupServicioId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;
    var viewPlansLabel = L["View plans"].ToString();
    var chooseLabel = L["Choose"].ToString();
    var selectedLabel = L["Selected"].ToString();
}

<h2 class="page-heading" style="font-size:1.1rem;">@L["Internet & Cable Options"]</h2>
    <p class="page-lead" style="margin-top:-8px;">@L["Available at your address:"] @Model.DireccionPropiedad</p>

    <div class="address-card">
        <div class="left"><i class="fas fa-house" style="color:#0066CC;"></i><span style="font-weight:600;font-size:0.92rem;">@Model.DireccionPropiedad</span></div>
        <a asp-action="UtilitiesSetupAddress" asp-route-id="@Model.MovingSetupServicioId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;"><i class="fas fa-pen"></i> @L["Edit"]</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="UtilitiesSetupInternet" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ProveedorInternetId" id="ProveedorInternetId" />
        <input type="hidden" asp-for="OpcionCable" id="OpcionCable" />

        @foreach (var provider in Model.Proveedores)
        {
            var badgeClass = UtilitiesSetupDisplayLabels.ProviderBadgeClass(provider.Etiqueta);
            <div class="provider-card @(provider.Selected ? "selected" : "")" data-provider-id="@provider.Id">
                <div class="provider-head">
                    <strong>@provider.Nombre</strong>
                    @if (!string.IsNullOrWhiteSpace(provider.Etiqueta))
                    {
                        <span class="provider-badge @badgeClass">@L[provider.Etiqueta]</span>
                    }
                </div>
                <div class="provider-meta">@provider.Velocidad · @provider.DetalleExtra</div>
                <div class="provider-price">@L["From $"]@provider.PrecioDesde.ToString("0.00") @L["/mo"]</div>
                <div class="provider-actions">
                    <span class="mini">@L["View plans"]</span>
                    @if (provider.Selected)
                    {
                        <span class="selected-pill"><i class="fas fa-check"></i> @L["Selected"]</span>
                    }
                    else
                    {
                        <span class="mini">@L["Choose"]</span>
                    }
                </div>
            </div>
        }

        <div class="field-card">
            <span class="field-label">@L["How would you like to get cable? (Optional)"]</span>
            <div class="cable-grid" id="cableGroup">
                <button type="button" class="cable-card" data-value="InternetOnly"><span class="radio"></span><i class="fas fa-desktop"></i>@L["Internet only"]<span class="sub">@L["No TV service"]</span></button>
                <button type="button" class="cable-card" data-value="InternetTv"><span class="radio"></span><i class="fas fa-tv"></i>@L["Internet + TV"]<span class="sub">@L["Add TV service"]</span></button>
                <button type="button" class="cable-card" data-value="BringMyOwn"><span class="radio"></span><i class="fas fa-router"></i>@L["Bring my own"]<span class="sub">@L["I'll use my provider"]</span></button>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">@L["Continue"]</button>
        <button type="submit" name="action" value="skip" class="btn-outline">@L["Skip internet for now"]</button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        const providerHidden = document.getElementById('ProveedorInternetId');
        const cableHidden = document.getElementById('OpcionCable');
        const viewPlans = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(viewPlansLabel));
        const choose = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chooseLabel));
        const selected = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(selectedLabel));

        document.querySelectorAll('.provider-card').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.provider-card').forEach(c => {
                    c.classList.remove('selected');
                    const actions = c.querySelector('.provider-actions');
                    if (actions) {
                        actions.innerHTML = '<span class="mini">' + viewPlans + '</span><span class="mini">' + choose + '</span>';
                    }
                });
                card.classList.add('selected');
                providerHidden.value = card.dataset.providerId;
                const actions = card.querySelector('.provider-actions');
                if (actions) {
                    actions.innerHTML = '<span class="mini">' + viewPlans + '</span><span class="selected-pill"><i class="fas fa-check"></i> ' + selected + '</span>';
                }
            });
        });

        document.querySelectorAll('#cableGroup .cable-card').forEach(btn => {
            if (btn.dataset.value === cableHidden.value) btn.classList.add('active');
            btn.addEventListener('click', () => {
                document.querySelectorAll('#cableGroup .cable-card').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                cableHidden.value = btn.dataset.value;
            });
        });
    })();

</script>
}
