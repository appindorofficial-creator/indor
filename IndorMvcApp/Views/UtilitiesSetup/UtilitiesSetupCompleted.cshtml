@model IndorMvcApp.ViewModels.UtilitiesSetupCompletedViewModel
@{
    ViewData["Title"] = L["Utilities Setup Completed - INDOR"];
    string PhoneHref(string? phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return "#";
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        return string.IsNullOrEmpty(digits) ? "#" : $"tel:{digits}";
    }
    ViewData["WizardTitle"] = L["Utilities Setup"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
}

<div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading" style="text-align:center;font-size:1.2rem;">@L["Utilities Setup Completed"]</h1>
    <p class="page-lead" style="text-align:center;color:#0066CC;font-weight:600;">@L["Congratulations! Your home setup is ready."]</p>
    <p class="page-lead" style="text-align:center;margin-top:-10px;">@L["We organized your utility and internet information for this property."]</p>

    <div class="location-card">
        <div class="thumb"><i class="fas fa-house" style="color:#0066CC;"></i></div>
        <div class="meta">
            <div class="addr">@Model.DireccionPropiedad</div>
            <div class="sub"><i class="fas fa-calendar"></i> @Model.FechaServicioLabel</div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.InternetProviderName))
    {
        <div class="summary-card" style="margin-bottom:12px;">
            <div class="summary-row"><i class="fas fa-wifi"></i><div><div class="summary-label">@L["Internet"]</div><div class="summary-value">@Model.InternetProviderName</div><div class="summary-value" style="font-size:0.78rem;color:#64748B;font-weight:500;">@L["Saved as preferred provider"]</div></div></div>
        </div>
    }

    <div class="completed-grid">
        @foreach (var card in Model.ServiceCards)
        {
            <div class="completed-card">
                <i class="fas fa-check check-corner"></i>
                <i class="fas @card.Icon main"></i>
                <div class="label">@card.Label</div>
                <div class="provider">@card.ProviderName</div>
                @if (!string.IsNullOrWhiteSpace(card.Phone))
                {
                    <div><a href="@PhoneHref(card.Phone)" style="color:#64748B;text-decoration:none;">@card.Phone</a></div>
                }
                @if (!string.IsNullOrWhiteSpace(card.Website))
                {
                    <div class="link">@card.Website.Replace("https://", "").Replace("http://", "")</div>
                }
                @if (!string.IsNullOrWhiteSpace(card.ExtraNote))
                {
                    <div style="color:#94A3B8;margin-top:4px;">@card.ExtraNote</div>
                }
            </div>
        }
    </div>

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L["You can call providers directly or return later from My Home."]</span></div>

    <a asp-controller="MyHome" asp-action="Index" class="btn-primary">@L["Go to My Home"]</a>
    <a asp-action="UtilitiesSetupReview" asp-route-id="@Model.SolicitudId" class="btn-outline">@L["View setup details"]</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline">@L["Done"]</a>
</div>
