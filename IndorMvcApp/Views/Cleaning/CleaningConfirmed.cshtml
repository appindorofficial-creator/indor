@model IndorMvcApp.ViewModels.CleaningConfirmedViewModel
@{
    ViewData["Title"] = L["Booking Confirmed - INDOR"];
    ViewData["WizardTitle"] = L["Booking Confirmed"];
}

<div class="cl-success-wrap">
    <div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading">@L["Booking Confirmed"]</h1>
    <p class="page-lead">@L["Your moving cleaning has been scheduled. We've sent your request and reserved your appointment."]</p>
</div>

<div class="summary-card">
    <div class="summary-row"><i class="fas fa-sparkles"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@Model.TipoLimpiezaLabel</div></div></div>
    <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
    <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Date"]</div><div class="summary-value">@Model.FechaServicioLabel</div></div></div>
    <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Time"]</div><div class="summary-value">@Model.VentanaHorarioLabel</div></div></div>
    <div class="summary-row"><i class="fas fa-wand-magic-sparkles"></i><div><div class="summary-label">@L["Focus areas"]</div><div class="summary-value">@Model.AreasResumen</div></div></div>
    <div class="summary-row"><i class="fas fa-plus-circle"></i><div><div class="summary-label">@L["Extras"]</div><div class="summary-value">@Model.TareasResumen</div></div></div>
    <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">@L["Status"]</div><div class="summary-value" style="color:#16A34A;">@Model.EstadoLabel</div></div></div>
</div>

<div class="info-banner">
    <i class="fas fa-circle-info"></i>
    <span>@L["Your provider will review your selected tasks and any uploaded photos before arrival."]</span>
</div>

<div class="cl-form-actions">
    <a asp-action="CleaningReview" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-calendar"></i> @L["View appointment"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-calendar"></i> @L["Go to Schedule"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="MyHome" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Go to My Home"] <i class="fas fa-chevron-right"></i></a>
</div>
