@model IndorMvcApp.ViewModels.CleaningServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
{
    <img src="@Model.ImagenUrl" alt="@Model.LandingTitulo" class="cl-landing-hero" />
}

<div class="title-row">
    <div class="left">
        <h1 class="page-heading" style="margin-bottom:4px;"><i class="fas fa-sparkles" style="color:#0066CC;font-size:1rem;margin-right:6px;"></i>@Model.LandingTitulo</h1>
        @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
        {
            <div class="tagline">@Model.LandingTagline</div>
        }
    </div>
    <div class="price-from">Starting at $@Model.PrecioDesde.ToString("0")</div>
</div>
<p class="page-lead">@Model.LandingSubtitulo</p>

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

<form asp-action="CleaningService" method="post" class="cl-form-actions">
    <input type="hidden" asp-for="MovingSetupServicioId" />
    <input type="hidden" asp-for="SolicitudId" />
    <input type="hidden" asp-for="NombreServicio" />
    <input type="hidden" asp-for="BestForSelection" id="BestForSelection" />

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="field-card">
            <span class="field-label">@L["What's included"]</span>
            <div class="included-inline">
                @foreach (var item in Model.IncludedItems)
                {
                    <span><i class="fas @item.Icon"></i> @item.Text</span>
                }
            </div>
        </div>
    }

    <div class="field-card">
        <span class="field-label">@Model.BestForLabel</span>
        <div class="chip-row" id="bestForGroup" style="flex-wrap:wrap;">
            @foreach (var opt in Model.BestForOptions)
            {
                <button type="button" class="chip-btn @(opt.Value == Model.BestForSelection ? "active" : "")" data-value="@opt.Value">
                    <i class="fas @opt.Icon"></i> @opt.Label
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTitulo))
    {
        <div class="info-box-blue">
            <i class="fas fa-circle-info"></i>
            <div>
                <strong>@Model.InfoBoxTitulo</strong><br />
                @Model.InfoBoxTexto
            </div>
        </div>
    }

    <button type="submit" name="action" value="continue" class="btn-primary">
        @Model.CtaContinueTexto <i class="fas fa-chevron-right"></i>
    </button>
    <button type="submit" name="action" value="upload" class="btn-outline">
        <i class="fas fa-cloud-arrow-up"></i> @Model.CtaUploadTexto
    </button>
</form>

@section Scripts {
<script>
    (function () {
        const hidden = document.getElementById('BestForSelection');
        document.querySelectorAll('#bestForGroup .chip-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('#bestForGroup .chip-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                hidden.value = btn.dataset.value;
            });
        });
    })();
</script>
}
