@model int
@{
    var steps = new[] { "Details", "Tasks", "Review" };
}
<style>
    .cl-stepper { display: flex; gap: 4px; margin-bottom: 18px; overflow-x: auto; padding-bottom: 4px; }
    .cl-step { flex: 1; min-width: 56px; text-align: center; }
    .cl-step-dot {
        width: 28px; height: 28px; border-radius: 50%; margin: 0 auto 6px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.78rem; font-weight: 700; border: 2px solid #CBD5E1; color: #94A3B8; background: #FFF;
    }
    .cl-step.done .cl-step-dot { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .cl-step.active .cl-step-dot { border-color: #0066CC; color: #0066CC; background: #FFF; }
    .cl-step-label { font-size: 0.68rem; font-weight: 600; color: #94A3B8; line-height: 1.2; }
    .cl-step.active .cl-step-label, .cl-step.done .cl-step-label { color: #0066CC; }
</style>
<div class="cl-stepper">
    @for (var i = 0; i < steps.Length; i++)
    {
        var stepNum = i + 1;
        var css = stepNum < Model ? "cl-step done" : stepNum == Model ? "cl-step active" : "cl-step";
        <div class="@css">
            <div class="cl-step-dot">
                @if (stepNum < Model)
                {
                    <i class="fas fa-check" style="font-size:0.7rem;"></i>
                }
                else
                {
                    @stepNum
                }
            </div>
            <div class="cl-step-label">@steps[i]</div>
        </div>
    }
</div>
