@model IndorMvcApp.ViewModels.CleaningDetailsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;
    ViewData["WizardBackUrl"] = Url.Action("CleaningService", "Cleaning", new { id = Model.MovingSetupServicioId });
}

<div class="cl-wizard-heading">
    <h2>Tell us about your cleaning request</h2>
    <p>Help INDOR send the right cleaning crew for your move.</p>
</div>

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

<form asp-action="CleaningDetails" method="post" id="cleaningDetailsForm" class="iw-step-form">
    <input type="hidden" asp-for="SolicitudId" />
    <input type="hidden" asp-for="MovingSetupServicioId" />
    <input type="hidden" asp-for="NombreServicio" />
    <input type="hidden" asp-for="TipoLimpieza" id="TipoLimpieza" />
    <input type="hidden" asp-for="TipoPropiedad" id="TipoPropiedad" />
    <input type="hidden" asp-for="NumeroHabitaciones" id="NumeroHabitaciones" />
    <input type="hidden" asp-for="NumeroBanos" id="NumeroBanos" />
    <input type="hidden" asp-for="CondicionActual" id="CondicionActual" />
    <input type="hidden" asp-for="VentanaHorario" id="VentanaHorario" />

    <div class="address-card" id="addressCard">
        <div class="left">
            <i class="fas fa-location-dot" style="color:#0066CC;"></i>
            <input asp-for="DireccionPropiedad" id="DireccionPropiedad" class="address-input"
                   placeholder="123 Main St, Charlotte, NC 28202" required readonly
                   data-address-autocomplete autocomplete="off" />
        </div>
        <button type="button" class="address-edit-btn" id="editAddressBtn" aria-controls="DireccionPropiedad">Edit ></button>
    </div>
    <span asp-validation-for="DireccionPropiedad" class="field-error"></span>

    <div class="field-card">
        <span class="field-label">Cleaning type</span>
        <div class="tile-grid" data-target="TipoLimpieza">
            <button type="button" class="type-card" data-value="MoveIn"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-house-circle-check"></i>Move-In Cleaning</button>
            <button type="button" class="type-card" data-value="MoveOut"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-house-circle-xmark"></i>Move-Out Cleaning</button>
            <button type="button" class="type-card" data-value="Both"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-arrows-rotate"></i>Both</button>
        </div>
    </div>

    <div class="field-card">
        <span class="field-label">Property type</span>
        <div class="segment-row" data-target="TipoPropiedad">
            <button type="button" class="segment-btn" data-value="House"><i class="fas fa-house"></i> House</button>
            <button type="button" class="segment-btn" data-value="Apartment"><i class="fas fa-building"></i> Apartment</button>
            <button type="button" class="segment-btn" data-value="Condo"><i class="fas fa-city"></i> Condo</button>
            <button type="button" class="segment-btn" data-value="Townhome"><i class="fas fa-house-chimney"></i> Townhome</button>
        </div>
    </div>

    <div class="field-card">
        <span class="field-label">Home size</span>
        <div style="margin-bottom:10px;font-size:0.78rem;font-weight:600;color:#64748B;">Bedrooms</div>
        <div class="segment-row" data-target="NumeroHabitaciones" style="margin-bottom:14px;">
            <button type="button" class="segment-btn" data-value="One">1 bed</button>
            <button type="button" class="segment-btn" data-value="Two">2 bed</button>
            <button type="button" class="segment-btn" data-value="Three">3 bed</button>
            <button type="button" class="segment-btn" data-value="FourPlus">4+ bed</button>
        </div>
        <div style="margin-bottom:10px;font-size:0.78rem;font-weight:600;color:#64748B;">Bathrooms</div>
        <div class="segment-row" data-target="NumeroBanos">
            <button type="button" class="segment-btn" data-value="One">1 bath</button>
            <button type="button" class="segment-btn" data-value="Two">2 bath</button>
            <button type="button" class="segment-btn" data-value="ThreePlus">3+ bath</button>
        </div>
    </div>

    <div class="field-card">
        <span class="field-label">Current condition</span>
        <div class="tile-grid" data-target="CondicionActual">
            <button type="button" class="type-card" data-value="Empty"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-box-open"></i>Empty property</button>
            <button type="button" class="type-card" data-value="LightlyFurnished"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-couch"></i>Lightly furnished</button>
            <button type="button" class="type-card" data-value="Occupied"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-users"></i>Occupied</button>
        </div>
    </div>

    <div class="picker-row">
        <div class="left"><i class="fas fa-calendar" style="color:#0066CC;"></i><input asp-for="FechaServicio" type="date" /></div>
    </div>
    <div class="picker-row">
        <div class="left">
            <i class="fas fa-clock" style="color:#0066CC;"></i>
            <select id="VentanaHorarioSelect">
                <option value="Morning">10:00 AM – 12:00 PM</option>
                <option value="MidMorning">12:00 PM – 2:00 PM</option>
                <option value="Afternoon">2:00 PM – 4:00 PM</option>
                <option value="Evening">4:00 PM – 6:00 PM</option>
            </select>
        </div>
    </div>

    <div class="cl-form-actions">
        <button type="submit" class="btn-primary">Continue <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="skip" class="btn-outline">Skip date for now</button>
    </div>
</form>

@section Scripts {
<script>
    (function () {
        function initCards(containerSelector, hiddenId, initial, cardClass) {
            const hidden = document.getElementById(hiddenId);
            const container = document.querySelector(containerSelector);
            if (!container || !hidden) return;
            const buttons = container.querySelectorAll('.' + cardClass);
            function setActive(value) {
                hidden.value = value;
                buttons.forEach(b => b.classList.toggle('active', b.dataset.value === value));
            }
            buttons.forEach(btn => btn.addEventListener('click', () => setActive(btn.dataset.value)));
            setActive(initial || hidden.value || '');
        }

        function initSegments(containerSelector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const container = document.querySelector(containerSelector);
            if (!container || !hidden) return;
            const buttons = container.querySelectorAll('.segment-btn');
            function setActive(value) {
                hidden.value = value;
                buttons.forEach(b => b.classList.toggle('active', b.dataset.value === value));
            }
            buttons.forEach(btn => btn.addEventListener('click', () => setActive(btn.dataset.value)));
            setActive(initial || hidden.value || '');
        }

        initCards('[data-target="TipoLimpieza"]', 'TipoLimpieza', '@Model.TipoLimpieza', 'type-card');
        initSegments('[data-target="TipoPropiedad"]', 'TipoPropiedad', '@Model.TipoPropiedad');
        initSegments('[data-target="NumeroHabitaciones"]', 'NumeroHabitaciones', '@Model.NumeroHabitaciones');
        initSegments('[data-target="NumeroBanos"]', 'NumeroBanos', '@Model.NumeroBanos');
        initCards('[data-target="CondicionActual"]', 'CondicionActual', '@Model.CondicionActual', 'type-card');

        const timeHidden = document.getElementById('VentanaHorario');
        const timeSelect = document.getElementById('VentanaHorarioSelect');
        timeSelect.value = timeHidden.value || 'Morning';
        timeSelect.addEventListener('change', () => timeHidden.value = timeSelect.value);

        const addressInput = document.getElementById('DireccionPropiedad');
        const addressCard = document.getElementById('addressCard');
        const editAddressBtn = document.getElementById('editAddressBtn');

        function enableAddressEdit() {
            if (!addressInput) return;
            addressInput.removeAttribute('readonly');
            addressCard?.classList.add('editing');
            addressInput.focus();
            try {
                addressInput.setSelectionRange(0, addressInput.value.length);
            } catch (_) { }
        }

        editAddressBtn?.addEventListener('click', enableAddressEdit);
        addressInput?.addEventListener('focus', function () {
            addressInput.removeAttribute('readonly');
            addressCard?.classList.add('editing');
        });

        const addressMessage = 'Please enter a complete street address (e.g. 123 Main St, Charlotte, NC).';

        function isValidStreetAddress(value) {
            const address = String(value || '').trim();
            if (address.length < 5) return false;
            if (!/\p{L}/u.test(address)) return false;
            if (/^[\d\s.,#-]+$/.test(address)) return false;
            const tokens = address.split(/\s+/).filter(Boolean);
            const hasDigit = /\d/.test(address);
            const wordParts = tokens.filter(part => /\p{L}/u.test(part)).length;
            if (!hasDigit || wordParts < 2) return false;
            const hasComma = address.includes(',');
            const hasZip = tokens.slice(1).some(t => /^\d{5}(-\d{4})?$/.test(t.replace(/[.,]+$/, '')));
            return hasComma || hasZip;
        }

        function addressValidity() {
            if (!addressInput) return '';
            const empty = !addressInput.value || !addressInput.value.trim();
            if (empty) return 'Please enter the property address.';
            if (!isValidStreetAddress(addressInput.value)) return addressMessage;
            return '';
        }

        addressInput?.addEventListener('input', function () {
            addressInput.setCustomValidity(addressValidity());
        });

        const cleaningForm = document.getElementById('cleaningDetailsForm');
        cleaningForm?.addEventListener('submit', function (e) {
            const message = addressValidity();
            addressInput.setCustomValidity(message);
            if (message) {
                e.preventDefault();
                addressInput.removeAttribute('readonly');
                addressCard?.classList.add('editing');
                addressInput.reportValidity();
            }
        });
    })();
</script>
@await Html.PartialAsync("_AddressAutocompleteScripts")
}
