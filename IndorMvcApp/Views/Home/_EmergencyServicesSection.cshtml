@model IndorMvcApp.ViewModels.EmergencyServicesSectionViewModel
@using System.Text.Json
@using IndorMvcApp.Services
@if (Model.Items.Count > 0)
{
    var selected = Model.SelectedId.HasValue
        ? Model.Items.FirstOrDefault(i => i.Id == Model.SelectedId.Value)
        : null;
    var selectedAction = selected != null ? EmergencyFlowRules.GetDetailsActionName(selected.Nombre) : null;
    var selectedStartUrl = selected != null && selectedAction != null
        ? Url.Action(selectedAction, "Inspecciones", new { id = selected.Id })
        : string.Empty;
    var allCardsLinked = Model.Items.All(item => EmergencyFlowRules.GetDetailsActionName(item.Nombre) != null);
    var requestHelpLabel = L["Request help"];

    <div class="emergency-section" id="emergency-services" data-ho-service-section data-ho-filter-section="emergency" data-emergency-section data-emergency-direct-nav="@(allCardsLinked ? "true" : "false")">
        <div class="emergency-header">
            <div class="emergency-header-left">
                <div class="emergency-title-row">
                    <span class="emergency-siren"><i class="fas fa-truck-medical"></i></span>
                    <h3 class="emergency-title">@L["Emergency Services"]</h3>
                    <span class="emergency-badge-247">24/7</span>
                </div>
                <p class="emergency-subtitle">@L["Fast help for urgent home problems."]</p>
            </div>
            <a href="@(Model.ViewAllUrl ?? Url.Action("EmergencyGuide", "Home"))"
               class="emergency-view-all"
               data-emergency-view-all>
                @L["View all"] <i class="fas fa-chevron-right"></i>
            </a>
        </div>

        <div class="emergency-grid" role="list" aria-label="@L["Emergency services"]">
            @foreach (var item in Model.Items)
            {
                var imgSrc = !string.IsNullOrWhiteSpace(item.ImagenUrl)
                    ? Url.Content("~" + (item.ImagenUrl.StartsWith("/") ? item.ImagenUrl : "/" + item.ImagenUrl))
                    : "";
                var isActive = selected != null && item.Id == selected.Id;
                var itemAction = EmergencyFlowRules.GetDetailsActionName(item.Nombre);
                var startUrl = itemAction != null
                    ? Url.Action(itemAction, "Inspecciones", new { id = item.Id })
                    : string.Empty;
                var cardClass = $"emergency-card{(isActive ? " active" : "")}";
                var featuresData = string.Join("|", item.Caracteristicas.Select(c => $"{c.Icon}:{L.Catalog(c.Text)}"));
                var displayLabel = L.Catalog(item.TituloEmergencia);
                var displayDesc = L.Catalog(item.Descripcion);
                var displayBadge = L.Catalog(item.BadgeTexto);
                var displayCta = L.Catalog(item.CtaTexto);

                if (!string.IsNullOrWhiteSpace(startUrl))
                {
                    <a href="@startUrl"
                       class="@cardClass"
                       aria-label="@L.T("{0} emergency service", item.Nombre)"
                       data-ho-service-item
                       data-filter="emergency"
                       data-search="@item.Nombre @displayLabel @displayDesc"
                       data-id="@item.Id"
                       data-nombre="@item.Nombre"
                       data-start-url="@startUrl"
                       data-title="@displayLabel"
                       data-desc="@displayDesc"
                       data-arrival="@item.TiempoLlegadaMinutos"
                       data-icon="@item.IconoClase"
                       data-badge="@(displayBadge ?? "")"
                       data-cta="@(displayCta ?? requestHelpLabel)"
                       data-features="@featuresData">
                        <div class="emergency-card-media">
                            @if (!string.IsNullOrWhiteSpace(imgSrc))
                            {
                                <img src="@imgSrc" alt="@displayLabel" loading="lazy" />
                            }
                            else
                            {
                                <div class="emergency-card-fallback"><i class="fas @item.IconoClase"></i></div>
                            }
                            <span class="emergency-card-icon"><i class="fas @item.IconoClase"></i></span>
                        </div>
                        <span class="emergency-card-label">@displayLabel</span>
                        <span class="emergency-card-247">24/7</span>
                    </a>
                }
                else
                {
                    <button type="button"
                            class="@cardClass"
                            role="option"
                            aria-selected="@(isActive ? "true" : "false")"
                            aria-label="@L.T("{0} emergency service", item.Nombre)"
                            data-ho-service-item
                            data-filter="emergency"
                            data-search="@item.Nombre @displayLabel @displayDesc"
                            data-id="@item.Id"
                            data-nombre="@item.Nombre"
                            data-start-url=""
                            data-title="@displayLabel"
                            data-desc="@displayDesc"
                            data-arrival="@item.TiempoLlegadaMinutos"
                            data-icon="@item.IconoClase"
                            data-badge="@(displayBadge ?? "")"
                            data-cta="@(displayCta ?? requestHelpLabel)"
                            data-features="@featuresData">
                        <div class="emergency-card-media">
                            @if (!string.IsNullOrWhiteSpace(imgSrc))
                            {
                                <img src="@imgSrc" alt="@displayLabel" loading="lazy" />
                            }
                            else
                            {
                                <div class="emergency-card-fallback"><i class="fas @item.IconoClase"></i></div>
                            }
                            <span class="emergency-card-icon"><i class="fas @item.IconoClase"></i></span>
                        </div>
                        <span class="emergency-card-label">@displayLabel</span>
                        <span class="emergency-card-247">24/7</span>
                    </button>
                }
            }
        </div>

        @if (!allCardsLinked)
        {
            <div class="emergency-detail @(selected == null ? "emergency-detail-empty" : "")">
                @if (selected == null)
                {
                    <p class="emergency-detail-prompt" data-emergency-detail-prompt>
                        @L["Select an emergency service above to view details and request help."]
                    </p>
                }
                <div class="emergency-detail-content" data-emergency-detail-content @(selected == null ? "hidden" : "")>
                    <div class="emergency-detail-main">
                        <div class="emergency-detail-icon"><i class="fas @(selected?.IconoClase ?? "fa-truck-medical")" data-emergency-detail-icon></i></div>
                        <div class="emergency-detail-copy">
                            @if (!string.IsNullOrWhiteSpace(selected?.BadgeTexto))
                            {
                                <span class="emergency-detail-badge" data-emergency-detail-badge>@L.Catalog(selected.BadgeTexto)</span>
                            }
                            else
                            {
                                <span class="emergency-detail-badge hidden" data-emergency-detail-badge></span>
                            }
                            <div class="emergency-detail-title" data-emergency-detail-title>@L.Catalog(selected?.TituloEmergencia)</div>
                            <div class="emergency-detail-desc" data-emergency-detail-desc>@L.Catalog(selected?.Descripcion)</div>
                        </div>
                        <div class="emergency-detail-arrival">
                            <span class="arrival-label">@L["Avg. arrival"]</span>
                            <span class="arrival-time" data-emergency-detail-arrival>@(selected != null ? $"{selected.TiempoLlegadaMinutos} min" : "")</span>
                        </div>
                    </div>

                    <div class="emergency-features" data-emergency-detail-features>
                        @if (selected != null)
                        {
                            @foreach (var feature in selected.Caracteristicas)
                            {
                                <div class="emergency-feature">
                                    <i class="fas @feature.Icon"></i>
                                    <span>@L.Catalog(feature.Text)</span>
                                </div>
                            }
                        }
                    </div>

                    <button type="button"
                            class="emergency-cta @(string.IsNullOrWhiteSpace(selectedStartUrl) ? "nav-jump" : "")"
                            data-emergency-detail-cta
                            data-start-url="@selectedStartUrl"
                            data-target="section-more"
                            data-default-cta="@requestHelpLabel">
                        <i class="fas fa-paper-plane"></i> @(L.Catalog(selected?.CtaTexto) ?? requestHelpLabel)
                    </button>
                </div>
            </div>
        }
    </div>
}
