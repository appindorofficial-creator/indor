        .notif-section .ns-badge {
            background: #EFF6FF; color: #004FA3; border: 1px solid #BFDBFE;
            border-radius: 999px; padding: 2px 10px; font-size: 0.72rem; font-weight: 700;
        }
        .notif-section .notif-list { max-height: none; }
        .notif-section .notif-item { padding: 10px 0; }

        /* === Schedule tab === */
        .schedule-list { display: flex; flex-direction: column; gap: 12px; }
        .schedule-card {
            background: #FFF; border-radius: 16px; padding: 14px 16px;
            border: 1px solid #EEF2F7;
            box-shadow: 0 6px 18px rgba(10, 37, 64, 0.06);
        }
        .schedule-card-head {
            display: flex; align-items: center; justify-content: space-between;
            gap: 10px; margin-bottom: 8px;
        }
        .schedule-card-head strong { font-size: 0.95rem; color: #0A2540; }
        .schedule-card-date {
            font-size: 0.84rem; color: #475569;
            display: flex; align-items: center; gap: 8px; margin-bottom: 6px;
        }
        .schedule-card-notes {
            font-size: 0.82rem; color: #64748B; margin-bottom: 10px; line-height: 1.4;
        }
        .schedule-edit-link {
            font-size: 0.82rem; font-weight: 600; color: #0066CC;
            text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
        }
        .alert-schedule-ok {
            background: #DCFCE7; color: #15803D; border-radius: 12px;
            padding: 12px 14px; font-size: 0.85rem; margin-bottom: 14px;
            border: 1px solid #BBF7D0;
        }

        /* === Sección More (Perfil) === */
        .more-card {
            background: #FFF; border-radius: 18px; padding: 16px;
            box-shadow: 0 6px 18px rgba(10, 37, 64, .08);
            border: 1px solid #EEF2F7; margin-bottom: 14px;
        }
        .more-card h3 { font-size: 0.95rem; color: #0A2540; margin: 0 0 10px; display: flex; align-items: center; gap: 8px; }
        .more-card h3 i { color: #0066CC; }
        .user-card { display: flex; gap: 18px; align-items: center; padding: 6px 4px; }
        .user-avatar-lg {
            width: 128px; height: 128px; border-radius: 50%; overflow: hidden; flex-shrink: 0;
            background: #E8EEF9; color: #6C8BD6;
            display: flex; align-items: flex-end; justify-content: center;
            font-size: 4.2rem; font-weight: 700; line-height: 1;
            box-shadow: inset 0 0 0 1px #DCE5F5;
        }
        .user-avatar-lg img { width: 100%; height: 100%; object-fit: cover; }
        .user-avatar-lg .avatar-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: flex-end; justify-content: center;
            color: #6C8BD6;
        }
        .user-avatar-lg .avatar-placeholder i { font-size: 5.4rem; transform: translateY(6px); }
        .user-info { flex: 1; min-width: 0; }
        .user-info .uline {
            display: flex; align-items: center; justify-content: space-between;
            gap: 12px; padding: 10px 2px;
            border-bottom: 1px solid #E5E9F0;
            font-size: 1rem; color: #0A2540; min-height: 38px;
        }
        .user-info .uline:last-child { border-bottom: none; }
        .user-info .uline .ulabel {
            display: flex; align-items: center; gap: 8px;
            min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
            font-weight: 500;
        }
        .user-info .uline .ulabel .lead-icon { color: #6C8BD6; font-size: 1rem; }
        .user-info .uline .uicon { color: #6C8BD6; font-size: 1.05rem; flex-shrink: 0; }
        .user-info .uline.muted .ulabel { color: #9AA4B2; }
        .membership-pill {
            display: inline-flex; align-items: center; gap: 6px;
            background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF;
            font-size: 0.72rem; font-weight: 700; padding: 3px 10px; border-radius: 999px;
        }
        .membership-pill.none { background: #F1F5F9; color: #6B7280; }
        @@media (max-width: 480px) {
            .user-avatar-lg { width: 96px; height: 96px; }
            .user-avatar-lg .avatar-placeholder i { font-size: 4rem; }
            .user-info .uline { font-size: 0.92rem; }
        }

        .opt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .opt-btn {
            background: #F8FAFC; border: 1px solid #EEF2F7; border-radius: 12px;
            padding: 12px; display: flex; flex-direction: column; align-items: center; gap: 6px;
            color: #0A2540; cursor: pointer; font-size: 0.78rem; font-weight: 600;
            transition: transform .15s ease, box-shadow .15s ease;
        }
        .opt-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 14px rgba(10, 37, 64, .08); }
        .opt-btn i { font-size: 1.1rem; color: #0066CC; }
        .opt-btn.danger { color: #B91C1C; }
        .opt-btn.danger i { color: #B91C1C; }

        /* === Menú de links del More === */
        .more-menu { display: flex; flex-direction: column; gap: 8px; }
        .more-link {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 12px; border-radius: 14px;
            background: #F8FAFC; border: 1px solid #EEF2F7;
            color: #0A2540; text-decoration: none;
            transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
        }
        .more-link:hover {
            background: #FFF; transform: translateY(-1px);
            box-shadow: 0 6px 14px rgba(10, 37, 64, .08);
            text-decoration: none; color: #0A2540;
        }
        .more-link .ml-icon {
            width: 38px; height: 38px; border-radius: 12px;
            background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(0, 102, 204, .25);
        }
        .more-link .ml-text {
            flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px;
        }
        .more-link .ml-text strong { font-size: .92rem; font-weight: 700; }
        .more-link .ml-text small { font-size: .72rem; color: #6B7280; line-height: 1.3; }
        .more-link .ml-arrow { color: #9CA3AF; font-size: .85rem; flex-shrink: 0; }

        .perfil-form { display: none; flex-direction: column; gap: 8px; margin-top: 12px; }
        .perfil-form.open { display: flex; }
        .perfil-form input, .perfil-form select {
            border: 1px solid #E5E7EB; border-radius: 10px; padding: 10px 12px;
            font-size: 0.85rem; font-family: inherit;
        }
        .perfil-form button {
            background: #0066CC; color: #FFF; border: 0; border-radius: 10px; padding: 10px;
            font-weight: 600; cursor: pointer; font-size: 0.85rem;
        }
        .perfil-form .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .alert-ok { background: #DCFCE7; color: #15803D; padding: 10px 12px; border-radius: 10px; font-size: 0.82rem; margin-bottom: 12px; }
        .alert-err { background: #FEE2E2; color: #B91C1C; padding: 10px 12px; border-radius: 10px; font-size: 0.82rem; margin-bottom: 12px; }

        .pay-list, .hist-list, .pm-list { display: flex; flex-direction: column; gap: 8px; }
        .pay-item, .hist-item, .pm-item {
            background: #F8FAFC; border: 1px solid #EEF2F7; border-radius: 12px;
            padding: 10px 12px; display: flex; justify-content: space-between; align-items: center; gap: 10px;
        }
        .pay-item .pi-left, .hist-item .hi-left, .pm-item .pmi-left { flex: 1; min-width: 0; }
        .pay-item .pi-title, .hist-item .hi-title, .pm-item .pmi-title { font-size: 0.88rem; font-weight: 700; color: #0A2540; }
        .pay-item .pi-sub, .hist-item .hi-sub, .pm-item .pmi-sub { font-size: 0.72rem; color: #6B7280; margin-top: 2px; }
        .pay-amount { font-weight: 800; color: #0A2540; }
        .badge {
            font-size: 0.68rem; font-weight: 700; padding: 3px 8px; border-radius: 999px;
        }
        .badge-pendiente { background: #FEF3C7; color: #B45309; }
        .badge-completado { background: #DCFCE7; color: #15803D; }
        .badge-financiado { background: #DBEAFE; color: #004FA3; }
        .badge-vencido { background: #FEE2E2; color: #B91C1C; }
        .badge-default { background: #F1F5F9; color: #475569; }

        .plan-grid { display: flex; flex-direction: column; gap: 10px; }
        .plan-card {
            background: #FFF; border: 1px solid #EEF2F7; border-radius: 14px; padding: 14px;
            position: relative;
        }
        .plan-card.recommended { border-color: #0066CC; box-shadow: 0 8px 18px rgba(0, 102, 204, .15); }
        .plan-card.active { border-color: #0066CC; }
        .plan-card .pc-flag {
            position: absolute; top: -10px; right: 12px;
            background: #0066CC; color: #FFF; font-size: 0.65rem; font-weight: 700;
            padding: 3px 8px; border-radius: 999px;
        }
        .plan-card.active .pc-flag { background: #0066CC; }
        .plan-card h4 { font-size: 0.95rem; color: #0A2540; margin: 0; }
        .plan-card .pc-sub { font-size: 0.75rem; color: #6B7280; margin-top: 2px; }
        .plan-card .pc-price { margin: 8px 0; font-size: 1.2rem; font-weight: 800; color: #0A2540; }
        .plan-card .pc-price small { font-size: 0.72rem; color: #6B7280; font-weight: 500; }
        .plan-card ul { list-style: none; padding: 0; margin: 8px 0 12px; }
        .plan-card li { font-size: 0.78rem; color: #475569; padding: 3px 0; display: flex; gap: 6px; align-items: flex-start; }
        .plan-card li i { color: #0066CC; font-size: 0.7rem; margin-top: 4px; }
        .plan-card .pc-action {
            width: 100%; background: #0066CC; color: #FFF; border: 0; border-radius: 10px;
            padding: 10px; font-weight: 600; cursor: pointer; font-size: 0.85rem;
        }
        .plan-card.active .pc-action { background: #0066CC; }

        .hist-tabs { display: flex; gap: 6px; margin-bottom: 10px; }
        .hist-tab {
            flex: 1; background: #F8FAFC; border: 1px solid #EEF2F7; color: #475569;
            border-radius: 10px; padding: 8px; font-size: 0.75rem; font-weight: 600; cursor: pointer;
        }
        .hist-tab.active { background: #0066CC; color: #FFF; border-color: #0066CC; }

        .internet-row { display: grid; grid-template-columns: 1fr; gap: 10px; }
        .internet-card {
            background: #F8FAFC; border: 1px solid #EEF2F7; border-radius: 12px; padding: 12px;
        }
        .internet-card.current { background: linear-gradient(135deg, #E8F1FB, #D6E8F9); border-color: #0066CC; }
        .internet-card .ic-head { display: flex; justify-content: space-between; align-items: center; }
        .internet-card .ic-prov { font-size: 0.75rem; color: #6B7280; text-transform: uppercase; letter-spacing: .5px; }
        .internet-card .ic-name { font-size: 0.95rem; font-weight: 700; color: #0A2540; }
        .internet-card .ic-speed { font-size: 0.85rem; color: #0066CC; font-weight: 700; margin-top: 4px; }
        .internet-card .ic-price { font-size: 1.05rem; font-weight: 800; color: #0A2540; }
        .internet-card .ic-feats { font-size: 0.75rem; color: #475569; margin-top: 6px; }
        .internet-card .ic-tag { font-size: 0.65rem; font-weight: 700; padding: 3px 8px; border-radius: 999px; background: #0066CC; color: #FFF; }

        .chat-box {
            background: #F8FAFC; border: 1px solid #EEF2F7; border-radius: 12px;
            padding: 10px; max-height: 280px; overflow-y: auto; margin-bottom: 10px;
            display: flex; flex-direction: column; gap: 8px;
        }
        .chat-msg { display: flex; flex-direction: column; max-width: 85%; }
        .chat-msg.usuario { align-self: flex-end; align-items: flex-end; }
        .chat-msg.soporte { align-self: flex-start; align-items: flex-start; }
        .chat-bubble {
            padding: 8px 12px; border-radius: 12px; font-size: 0.82rem; line-height: 1.35;
        }
        .chat-msg.usuario .chat-bubble { background: #0066CC; color: #FFF; border-bottom-right-radius: 4px; }
        .chat-msg.soporte .chat-bubble { background: #FFF; color: #0A2540; border: 1px solid #EEF2F7; border-bottom-left-radius: 4px; }
        .chat-time { font-size: 0.65rem; color: #94A3B8; margin-top: 2px; }
        .chat-empty { text-align: center; color: #6B7280; font-size: 0.82rem; padding: 16px; }
        .chat-form { display: flex; gap: 6px; }
        .chat-form input { flex: 1; border: 1px solid #E5E7EB; border-radius: 10px; padding: 10px 12px; font-size: 0.85rem; font-family: inherit; }
        .chat-form button { background: #0066CC; color: #FFF; border: 0; border-radius: 10px; padding: 10px 14px; cursor: pointer; }
    </style>
</head>
<body>
    <header class="top-bar">
        <a class="hd-brand" asp-controller="Home" asp-action="Index" aria-label="INDOR">
            IND
            <svg class="hd-brand-house" viewBox="0 0 28 28" aria-hidden="true" focusable="false">
                <path d="M14 3 L26 14 V26 H2 V14 Z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
            </svg>
            R
        </a>
        <div class="search-bar"><i class="fas fa-search"></i><span>Search your home...</span></div>
        <div class="bell" id="bellToggle" role="button" aria-label="Notifications">
            <i class="far fa-bell"></i>
            @if (notificaciones.Count > 0)
            {
                <span class="bell-count">@(notificaciones.Count > 9 ? "9+" : notificaciones.Count.ToString())</span>
            }
        </div>
    </header>

    <div class="notif-panel" id="notifPanel" role="dialog" aria-label="Notifications">
        <div class="notif-header">
            <strong><i class="far fa-bell"></i> Notifications</strong>
            <button type="button" class="notif-clear" id="notifClose">Close</button>
        </div>
        <div class="notif-list">
            @if (notificaciones.Count == 0)
            {
                <div class="notif-empty">You have no notifications right now.</div>
            }
            else
            {
                @foreach (var n in notificaciones)
                {
                    <div class="notif-item">
                        <div class="notif-icon @n.Severity"><i class="fas @n.Icon"></i></div>
                        <div class="notif-text">
                            <div class="nt-title">@n.Title</div>
                            <div class="nt-sub">@n.Subtitle</div>
                            <div class="nt-date"><i class="far fa-calendar"></i> @n.Date.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- ====== HOME ====== -->
    <section class="section active" id="section-home">
        @{
            var homeDashboard = ViewBag.HomeDashboard as IndorMvcApp.ViewModels.HomeDashboardViewModel;
        }
        @if (TempData["ScheduleSaved"] is string scheduleMsg)
        {
            <div class="alert-schedule-ok" style="margin:12px 0;"><i class="fas fa-check-circle"></i> @scheduleMsg</div>
        }
        @if (TempData["InspectionSaved"] is string inspectionMsg)
        {
            <div class="alert-schedule-ok" style="margin:12px 0;"><i class="fas fa-check-circle"></i> @inspectionMsg</div>
        }
        @if (homeDashboard != null)
        {
            @await Html.PartialAsync("_HomeDashboard", homeDashboard)
        }
    </section>

    <!-- ====== SERVICES ====== -->
    <section class="section" id="section-services">
        <div class="section-title">
            Available services
            <span class="services-count">@((((IEnumerable<IndorMvcApp.Models.Microservicio>?)ViewBag.Microservicios)?.Count() ?? 0) + (((IEnumerable<IndorMvcApp.Models.Servicio>?)ViewBag.Servicios)?.Count() ?? 0) + (((IEnumerable<IndorMvcApp.Models.Inspeccion>?)ViewBag.Inspecciones)?.Count() ?? 0))</span>
        </div>

        @{
            var microservicios = (IEnumerable<IndorMvcApp.Models.Microservicio>?)ViewBag.Microservicios
                                 ?? Enumerable.Empty<IndorMvcApp.Models.Microservicio>();
            var servicios = (IEnumerable<IndorMvcApp.Models.Servicio>?)ViewBag.Servicios
                             ?? Enumerable.Empty<IndorMvcApp.Models.Servicio>();
            var inspecciones = (IEnumerable<IndorMvcApp.Models.Inspeccion>?)ViewBag.Inspecciones
                                ?? Enumerable.Empty<IndorMvcApp.Models.Inspeccion>();
            var serviciosEmergencia = (IEnumerable<IndorMvcApp.Models.ServicioEmergencia>?)ViewBag.ServiciosEmergencia
                                      ?? Enumerable.Empty<IndorMvcApp.Models.ServicioEmergencia>();
            var movingSetupSection = ViewBag.MovingSetupSection as IndorMvcApp.ViewModels.MovingSetupSectionViewModel;
            var homeCarePrioritiesSection = ViewBag.HomeCarePrioritiesSection as IndorMvcApp.ViewModels.HomeCarePrioritiesSectionViewModel;
            var totalOfferings = microservicios.Count() + servicios.Count() + inspecciones.Count();
        }

        @if (totalOfferings == 0)
        {
            <div class="empty-state">
                <i class="fas fa-tools"></i>
                <p>Coming soon.</p>
            </div>
        }
        else
        {
            <div class="services-catalog">
                <div class="services-hero">
                    <div class="services-hero-text">
                        <strong>Take care of your home effortlessly</strong>
                        <small>Verified professionals with transparent pricing.</small>
                    </div>
                    <div class="services-hero-icon"><i class="fas fa-house-chimney-medical"></i></div>
                </div>

                @if (microservicios.Any())
                {
                    @await Html.PartialAsync("_OfferingCarousel", BuildMicroCarousel(microservicios, $"{microservicios.Count()} services available for your home"))
                }

                @if (homeCarePrioritiesSection != null)
                {
                    @await Html.PartialAsync("_HomeCarePrioritiesSection", homeCarePrioritiesSection)
                }

                @if (movingSetupSection != null)
                {
                    @await Html.PartialAsync("_MovingSetupSection", movingSetupSection)
                }

                @if (servicios.Any())
                {
                    @await Html.PartialAsync("_OfferingCarousel", BuildServicioCarousel(servicios, $"{servicios.Count()} remodeling and installation projects"))
                }

                @if (inspecciones.Any())
                {
                    @await Html.PartialAsync("_OfferingCarousel", BuildInspeccionCarousel(inspecciones, $"{inspecciones.Count()} professional inspections for your home"))
                }

                @if (serviciosEmergencia.Any())
                {
                    @await Html.PartialAsync("_EmergencyServicesSection", BuildEmergencySection(serviciosEmergencia))
                }
            </div>
        }
    </section>
    <section class="section" id="section-myhome">
        @{
            var houseFactProfile = ViewBag.HouseFactProfile as HouseFactProfileViewModel;
            var houseFactPreviewMode = ViewBag.HouseFactPreviewMode as bool? == true;
            var houseFactPropiedadId = ViewBag.HouseFactPropiedadId as int?;
        }
        <div class="section-title">
            House Facts
            @if (hasProperties && primaryProp != null)
            {
                <a asp-controller="MyHome" asp-action="Index" asp-route-id="@primaryProp.Id">My Property</a>
            }
            else if (houseFactPreviewMode)
            {
                <a asp-controller="Propietario" asp-action="PropertyDetails">Continue setup</a>
            }
            else
            {
                <a asp-controller="Propietario" asp-action="AddProperty">+ Add</a>
            }
        </div>

        @if (houseFactProfile != null && houseFactProfile.HasData)
        {
            if (houseFactPreviewMode)
            {
                ViewData["HouseFactPreview"] = true;
            }
            else if (houseFactPropiedadId.HasValue)
            {
                ViewData["PropiedadId"] = houseFactPropiedadId.Value;
                ViewData["EditUrl"] = Url.Action("Edit", "MyHome", new { id = houseFactPropiedadId.Value });
            }

            @await Html.PartialAsync("_HouseFactProfile", houseFactProfile)

            @if (hasProperties && primaryProp != null)
            {
                <div class="results-card" style="margin-top:16px;padding:16px;">
                    <div class="results-title" style="margin-bottom:10px;">Property management</div>
                    <div class="hf-quick-grid">
                        <a asp-controller="MyHome" asp-action="History" asp-route-id="@primaryProp.Id" class="hf-quick-link"><i class="fas fa-clock-rotate-left"></i> History</a>
                        <a asp-controller="MyHome" asp-action="Documents" asp-route-id="@primaryProp.Id" class="hf-quick-link"><i class="fas fa-file-lines"></i> Documents</a>
                        <a asp-controller="MyHome" asp-action="Providers" asp-route-id="@primaryProp.Id" class="hf-quick-link"><i class="fas fa-user-group"></i> Providers</a>
                        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@primaryProp.Id" class="hf-quick-link"><i class="fas fa-clipboard-check"></i> Maintenance</a>
                    </div>
                </div>
            }
            else if (houseFactPreviewMode)
            {
                <div class="results-card" style="margin-top:16px;padding:16px;">
                    <div class="results-title" style="margin-bottom:8px;">Ready to save this property?</div>
                    <p style="color:#64748B;font-size:0.88rem;margin-bottom:12px;">Confirm the address to add it to your account and unlock full property management.</p>
                    <a asp-controller="Propietario" asp-action="PropertyDetails" class="btn-primary-link" style="display:inline-flex;align-items:center;gap:8px;">
                        <i class="fas fa-check"></i> Continue to confirm property
                    </a>
                </div>
            }
        }
        else if (!hasProperties && !houseFactPreviewMode)
        {
            <div class="empty-state">
                <i class="fas fa-house-circle-exclamation"></i>
                <p>You have no registered properties yet.</p>
                <a asp-controller="Propietario" asp-action="AddProperty" class="btn-primary-link">
                    <i class="fas fa-plus"></i> Add property
                </a>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-file-circle-question"></i>
                <p>No House Fact data is available yet for this property.</p>
                @if (hasProperties && primaryProp != null)
                {
                    <a asp-controller="MyHome" asp-action="Details" asp-route-id="@primaryProp.Id" asp-route-tab="attom" class="btn-primary-link">
                        <i class="fas fa-rotate"></i> Refresh property data
                    </a>
                }
                else
                {
                    <a asp-controller="Propietario" asp-action="AddProperty" class="btn-primary-link">
                        <i class="fas fa-magnifying-glass"></i> Search an address
                    </a>
                }
            </div>
        }
    </section>

    <!-- ====== SCHEDULE ====== -->
    <section class="section" id="section-schedule">
        <div class="section-title">Schedule</div>
        @{
            var agendaItems = ViewBag.ProgramacionesMicroservicio as List<IndorMvcApp.Models.ProgramacionMicroservicio>
                              ?? new List<IndorMvcApp.Models.ProgramacionMicroservicio>();
            var inspectionItems = ViewBag.SolicitudesInspeccion as List<IndorMvcApp.Models.SolicitudInspeccion>
                                  ?? new List<IndorMvcApp.Models.SolicitudInspeccion>();
            var electricalItems = ViewBag.SolicitudesInspeccionElectrica as List<IndorMvcApp.Models.SolicitudInspeccionElectrica>
                                  ?? new List<IndorMvcApp.Models.SolicitudInspeccionElectrica>();
            var completeItems = ViewBag.SolicitudesInspeccionCompleta as List<IndorMvcApp.Models.SolicitudInspeccionCompleta>
