        .prop-est-link {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.35);
            border-radius: 8px;
            color: #FFF;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            white-space: nowrap;
            padding: 6px 10px;
            transition: background 0.2s ease;
        }
        .prop-est-link:hover { background: rgba(255, 255, 255, 0.25); }

        .prop-card {
            background: #FFFFFF;
            border-radius: 18px;
            padding: 18px 16px;
            box-shadow: 0 8px 24px rgba(10, 37, 64, 0.07);
            border: 1px solid #EEF2F7;
            color: #0A2540;
        }
        .prop-card-title {
            font-size: 1.02rem;
            font-weight: 700;
            margin: 0 0 14px;
            color: #0A2540;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .prop-card-title i { color: #0066CC; font-size: 0.95rem; }

        .facts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .fact-item {
            display: flex;
            align-items: flex-start;
