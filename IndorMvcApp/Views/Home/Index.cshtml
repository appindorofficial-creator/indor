            color: #0066CC;
            font-size: 0.82rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .fact-item .fact-label {
            font-size: 0.68rem;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            display: block;
