                <button type="submit" class="pf-btn danger" style="width:100%;">
                    <i class="fas fa-right-from-bracket"></i> @L["Sign out"]
                </button>
            </form>
        </div>
        </div>
    </section>

	<!-- ====== BOTTOM NAV ====== -->
    @{
        ViewBag.PropiedadId = primaryProp?.Id;
        ViewBag.BottomNavActive = "nearby";
        ViewBag.BottomNavSpa = true;
    }
    @await Html.PartialAsync("_HomeownerBottomNav")

    <script>
        const hoI18n = {
            requestHelp: @Html.Raw(JsonSerializer.Serialize(L["Request help"])),
            showLess: @Html.Raw(JsonSerializer.Serialize(L["Show less"])),
            showMore: @Html.Raw(JsonSerializer.Serialize(L["Show more"])),
            noResults: @Html.Raw(JsonSerializer.Serialize(L["No results. Try another term."])),
            service: @Html.Raw(JsonSerializer.Serialize(L["Service"])),
            emergencyService: @Html.Raw(JsonSerializer.Serialize(L["Emergency service"])),
            emergency: @Html.Raw(JsonSerializer.Serialize(L["Emergency"])),
            requestService: @Html.Raw(JsonSerializer.Serialize(L["Request Service"])),
            browseServices: @Html.Raw(JsonSerializer.Serialize(L["Browse all available services"])),
            emergencyHelp: @Html.Raw(JsonSerializer.Serialize(L["Emergency Help"])),
            urgentProblems: @Html.Raw(JsonSerializer.Serialize(L["24/7 urgent home problems"])),
            houseFacts: @Html.Raw(JsonSerializer.Serialize(L["House Facts"])),
            propertyOverview: @Html.Raw(JsonSerializer.Serialize(L["Property overview and details"])),
            schedule: @Html.Raw(JsonSerializer.Serialize(L["Schedule"])),
            upcomingVisits: @Html.Raw(JsonSerializer.Serialize(L["Upcoming visits and requests"])),
            documents: @Html.Raw(JsonSerializer.Serialize(L["Documents"])),
            inspectionReports: @Html.Raw(JsonSerializer.Serialize(L["Inspection reports and files"])),
            homeMaintenance: @Html.Raw(JsonSerializer.Serialize(L["Home Maintenance"])),
            tasksReminders: @Html.Raw(JsonSerializer.Serialize(L["Tasks and reminders"])),
            propertyHistory: @Html.Raw(JsonSerializer.Serialize(L["Property History"])),
            pastWork: @Html.Raw(JsonSerializer.Serialize(L["Past work on your home"]))
        };

        function syncBottomNavOffset() {
            const nav = document.querySelector('.bottom-nav');
            if (!nav) return;
            const navH = Math.ceil(nav.getBoundingClientRect().height);
            if (navH > 0) {
                document.documentElement.style.setProperty('--homeowner-bottom-nav-h', `${navH}px`);
            }
        }

        function activateSection(sectionId, scrollTargetId) {
            if (!sectionId) return;
            const section = document.getElementById(sectionId);
            if (!section) return;
            document.querySelectorAll('.bottom-nav .nav-item').forEach(b => {
                b.classList.toggle('active', b.dataset.target === sectionId);
            });
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            section.classList.add('active');
            const isLandingHome = sectionId === 'section-home' && section.classList.contains('hn-v4-landing');
            document.body.classList.toggle('hn-landing-active', isLandingHome);
            document.body.style.overflow = '';
            if (isLandingHome) {
                syncBottomNavOffset();
            }

            const scrollTarget = scrollTargetId
                ? document.getElementById(scrollTargetId)
                : null;
            if (scrollTarget) {
                window.setTimeout(() => {
                    scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }, 80);
                return;
            }

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function buildSectionHash(target) {
            const base = window.location.pathname;
            if (target === 'section-home') {
                return base + '#section-home';
            }
            return base + '#' + target;
        }

        // === Bottom nav ===
        document.querySelectorAll('.bottom-nav .nav-item[data-target]').forEach(btn => {
            btn.addEventListener('click', () => {
                const target = btn.dataset.target;
                if (target === 'section-home' && window.location.search) {
                    window.location.href = window.location.pathname + '#section-home';
                    return;
                }
                activateSection(target);
                if (target?.startsWith('section-')) {
                    history.replaceState(null, '', buildSectionHash(target));
                }
            });
        });

        function applyRouteFromHash() {
            const params = new URLSearchParams(window.location.search);
            if (params.has('filter') || params.has('view') || params.has('q')) {
                activateSection('section-home');
                const base = window.location.pathname + window.location.search;
                if (window.location.hash !== '#section-home') {
                    history.replaceState(null, '', base + '#section-home');
                }
                const isLanding = document.getElementById('section-home')?.classList.contains('hn-v4-landing');
                const feed = document.getElementById('hn-network-feed');
                if (feed && !isLanding && getComputedStyle(feed).display !== 'none') {
                    window.setTimeout(() => feed.scrollIntoView({ behavior: 'smooth', block: 'start' }), 120);
                } else {
                    window.scrollTo({ top: 0, behavior: 'auto' });
                }
                return;
            }

            const hash = window.location.hash.replace('#', '');
            const servicesScrollTargets = ['emergency-services', 'home-care-essentials', 'home-care-priorities', 'inspections', 'services'];
            if (servicesScrollTargets.includes(hash) && document.getElementById(hash)) {
                activateSection('section-services', hash);
            } else if (hash === 'section-mydashboard' || hash === 'mydashboard') {
                activateSection('section-mydashboard');
            } else if (hash === 'section-more' || hash === 'more') {
                activateSection('section-more');
            } else if (hash) {
                activateSection(hash.startsWith('section-') ? hash : 'section-' + hash);
            }
        }

        applyRouteFromHash();
        syncBottomNavOffset();
        window.addEventListener('resize', syncBottomNavOffset);
        window.addEventListener('orientationchange', () => window.setTimeout(syncBottomNavOffset, 120));
        window.visualViewport?.addEventListener('resize', syncBottomNavOffset);
        window.visualViewport?.addEventListener('scroll', syncBottomNavOffset);
        window.addEventListener('hashchange', applyRouteFromHash);

        // === Slider por propiedad ===
        function initSlider(idx) {
            const track = document.querySelector(`[data-track="${idx}"]`);
            if (!track) return;
            const total = track.children.length;
            const counter = document.querySelector(`[data-counter="${idx}"]`);
            const dots = document.querySelectorAll(`[data-dots="${idx}"] .dot`);
            const btnPrev = document.querySelector(`[data-prev="${idx}"]`);
            const btnNext = document.querySelector(`[data-next="${idx}"]`);
            let cur = 0;

            function update() {
                track.style.transform = `translateX(-${cur * 100}%)`;
                if (counter) counter.textContent = `${cur + 1} / ${total}`;
                if (btnPrev) btnPrev.disabled = cur === 0;
                if (btnNext) btnNext.disabled = cur === total - 1;
                dots.forEach((d, i) => d.classList.toggle('active', i === cur));
            }
            btnNext && btnNext.addEventListener('click', () => { if (cur < total - 1) { cur++; update(); } });
            btnPrev && btnPrev.addEventListener('click', () => { if (cur > 0) { cur--; update(); } });
            dots.forEach((d, i) => d.addEventListener('click', () => { cur = i; update(); }));

            // swipe
            const vp = track.parentElement;
            let startX = 0;
            vp.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
            vp.addEventListener('touchend', e => {
                const dx = e.changedTouches[0].clientX - startX;
                if (dx < -40 && cur < total - 1) { cur++; update(); }
                else if (dx > 40 && cur > 0) { cur--; update(); }
            });
            update();
        }

        document.querySelectorAll('[data-track]').forEach(t => initSlider(t.dataset.track));

        // === Emergency Services cards (preview panel only for cards without direct links) ===
        document.querySelectorAll('[data-emergency-section]').forEach(section => {
            if (section.dataset.emergencyDirectNav === 'true') {
                return;
            }

            const cards = section.querySelectorAll('button.emergency-card');
            const detailEl = section.querySelector('.emergency-detail');
            const promptEl = section.querySelector('[data-emergency-detail-prompt]');
            const contentEl = section.querySelector('[data-emergency-detail-content]');
            const iconEl = section.querySelector('[data-emergency-detail-icon]');
            const badgeEl = section.querySelector('[data-emergency-detail-badge]');
            const titleEl = section.querySelector('[data-emergency-detail-title]');
            const descEl = section.querySelector('[data-emergency-detail-desc]');
            const arrivalEl = section.querySelector('[data-emergency-detail-arrival]');
            const featuresEl = section.querySelector('[data-emergency-detail-features]');
            const ctaEl = section.querySelector('[data-emergency-detail-cta]');

            function renderFeatures(raw) {
                if (!featuresEl) return;
                featuresEl.innerHTML = '';
                (raw || '').split('|').filter(Boolean).forEach(entry => {
                    const parts = entry.split(':');
                    const icon = parts[0] || 'fa-clock';
                    const text = parts.slice(1).join(':') || '';
                    const item = document.createElement('div');
                    item.className = 'emergency-feature';
                    item.innerHTML = `<i class="fas ${icon}"></i><span>${text}</span>`;
                    featuresEl.appendChild(item);
                });
            }

            cards.forEach(card => {
                card.addEventListener('click', () => {
                    cards.forEach(c => {
                        c.classList.remove('active');
                        c.setAttribute('aria-selected', 'false');
                    });
                    card.classList.add('active');
                    card.setAttribute('aria-selected', 'true');

                    if (detailEl) detailEl.classList.remove('emergency-detail-empty');
                    if (promptEl) promptEl.classList.add('hidden');
                    if (contentEl) contentEl.classList.remove('hidden');

                    if (iconEl) iconEl.className = `fas ${card.dataset.icon}`;
                    if (titleEl) titleEl.textContent = card.dataset.title || '';
                    if (descEl) descEl.textContent = card.dataset.desc || '';
                    if (arrivalEl) arrivalEl.textContent = `${card.dataset.arrival || '45'} min`;

                    const badge = card.dataset.badge || '';
                    if (badgeEl) {
                        if (badge) {
                            badgeEl.textContent = badge;
                            badgeEl.classList.remove('hidden');
                        } else {
                            badgeEl.textContent = '';
                            badgeEl.classList.add('hidden');
                        }
                    }

                    renderFeatures(card.dataset.features);
                    if (ctaEl) {
                        ctaEl.innerHTML = `<i class="fas fa-paper-plane"></i> ${card.dataset.cta || hoI18n.requestHelp}`;
                        const startUrl = card.dataset.startUrl || '';
                        ctaEl.dataset.startUrl = startUrl;
                        if (startUrl) {
                            ctaEl.classList.remove('nav-jump');
                        } else {
                            ctaEl.classList.add('nav-jump');
                            ctaEl.dataset.target = 'section-more';
                        }
                    }
                });
            });

            if (ctaEl) {
                ctaEl.addEventListener('click', (e) => {
                    const startUrl = ctaEl.dataset.startUrl || '';
                    if (startUrl) {
                        e.preventDefault();
                        e.stopPropagation();
                        window.location.href = startUrl;
                    }
                });
            }
        });

        // === Atajos desde Home a otras secciones ===
        document.querySelectorAll('.home-shortcut[data-target], .nav-jump[data-target]').forEach(el => {
            el.addEventListener('click', () => {
                const target = el.dataset.target;
                activateSection(target, el.dataset.scrollTarget || null);
                if (target?.startsWith('section-')) {
                    history.replaceState(null, '', buildSectionHash(target));
                }
            });
        });

        // === Facts & features expand ===
        (function () {
            const btn = document.getElementById('btnShowFacts');
            const panel = document.getElementById('propDetailsExpand');
            if (!btn || !panel) return;
            btn.addEventListener('click', () => {
                const open = panel.hasAttribute('hidden');
                if (open) {
                    panel.removeAttribute('hidden');
                    btn.setAttribute('aria-expanded', 'true');
                    btn.innerHTML = hoI18n.showLess + ' <i class="fas fa-chevron-up"></i>';
                } else {
                    panel.setAttribute('hidden', '');
                    btn.setAttribute('aria-expanded', 'false');
                    btn.innerHTML = hoI18n.showMore + ' <i class="fas fa-chevron-right"></i>';
                }
            });
        })();

        // === Home search ===
        (function () {
            const openButtons = document.querySelectorAll('.js-home-search-open');
            const overlay = document.getElementById('homeSearchOverlay');
            const input = document.getElementById('homeSearchInput');
            const resultsEl = document.getElementById('homeSearchResults');
            const closeBtn = document.getElementById('homeSearchClose');
            if (!overlay || !input || !resultsEl || openButtons.length === 0) return;

            const propiedadId = @(primaryProp?.Id.ToString() ?? "null");
            let searchIndex = null;

            function shortcutItems() {
                const items = [
                    { title: hoI18n.requestService, subtitle: hoI18n.browseServices, icon: 'fa-screwdriver-wrench', section: 'section-services' },
                    { title: hoI18n.emergencyHelp, subtitle: hoI18n.urgentProblems, icon: 'fa-triangle-exclamation', section: 'section-services', scrollTarget: 'emergency-services' },
                    { title: hoI18n.houseFacts, subtitle: hoI18n.propertyOverview, icon: 'fa-house-circle-check', section: 'section-myhome' },
                    { title: hoI18n.schedule, subtitle: hoI18n.upcomingVisits, icon: 'fa-clipboard-list', section: 'section-schedule' }
                ];
                if (propiedadId) {
                    items.push(
                        { title: hoI18n.documents, subtitle: hoI18n.inspectionReports, icon: 'fa-file-lines', url: '@(primaryProp != null ? Url.Action("Documents", "MyHome", new { id = primaryProp.Id }) : "#")' },
                        { title: hoI18n.homeMaintenance, subtitle: hoI18n.tasksReminders, icon: 'fa-clipboard-check', url: '@(primaryProp != null ? Url.Action("Maintenance", "MyHome", new { id = primaryProp.Id, from = "home" }) : "#")' },
                        { title: hoI18n.propertyHistory, subtitle: hoI18n.pastWork, icon: 'fa-clock-rotate-left', url: '@(primaryProp != null ? Url.Action("History", "MyHome", new { id = primaryProp.Id }) : "#")' }
                    );
                }
                return items;
            }

            function collectCatalogItems() {
                const seen = new Set();
                const items = [];

                function add(item) {
                    const key = (item.url || '') + '|' + item.title + '|' + (item.section || '');
                    if (seen.has(key)) return;
                    seen.add(key);
                    items.push(item);
                }

                document.querySelectorAll('#section-services a.offering-card[href]').forEach(function (el) {
                    const title = el.querySelector('.offering-card-label')?.textContent?.trim();
                    if (!title) return;
                    add({ title: title, subtitle: hoI18n.service, icon: 'fa-wrench', url: el.href });
                });

                document.querySelectorAll('.emergency-card[data-start-url]').forEach(function (el) {
                    const url = (el.dataset.startUrl || '').trim();
                    if (!url) return;
                    const title = (el.dataset.nombre || el.querySelector('.emergency-card-label')?.textContent || hoI18n.emergency).trim();
                    add({ title: title, subtitle: hoI18n.emergencyService, icon: 'fa-truck-medical', url: url });
                });

                return items;
            }

            function buildIndex() {
                return shortcutItems().concat(collectCatalogItems());
            }

            function renderResults(query) {
                const q = (query || '').trim().toLowerCase();
                const pool = !q ? shortcutItems() : (searchIndex || []);
                const matches = pool.filter(function (item) {
                    if (!q) return true;
                    const hay = (item.title + ' ' + item.subtitle).toLowerCase();
                    return hay.includes(q);
                });

                resultsEl.innerHTML = '';
                if (matches.length === 0) {
                    resultsEl.innerHTML = '<div class="home-search-empty">' + hoI18n.noResults + '</div>';
                    return;
                }

                matches.slice(0, 25).forEach(function (item) {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'home-search-item';
                    btn.innerHTML =
                        '<span class="home-search-item-icon"><i class="fas ' + (item.icon || 'fa-circle') + '"></i></span>' +
                        '<span class="home-search-item-body">' +
                        '<div class="home-search-item-title"></div>' +
                        '<div class="home-search-item-sub"></div></span>';
                    btn.querySelector('.home-search-item-title').textContent = item.title;
                    btn.querySelector('.home-search-item-sub').textContent = item.subtitle;
                    btn.addEventListener('click', function () {
                        closeSearch();
                        if (item.url) {
                            window.location.href = item.url;
                        } else if (item.section) {
                            activateSection(item.section, item.scrollTarget || null);
                        }
                    });
                    resultsEl.appendChild(btn);
                });
            }

            function openSearch() {
                if (!searchIndex) searchIndex = buildIndex();
                overlay.classList.add('open');
                overlay.setAttribute('aria-hidden', 'false');
                input.value = '';
                renderResults('');
                window.setTimeout(function () { input.focus(); }, 50);
            }

            function closeSearch() {
                overlay.classList.remove('open');
                overlay.setAttribute('aria-hidden', 'true');
            }

            openButtons.forEach(function (btn) {
                btn.addEventListener('click', openSearch);
            });
            closeBtn.addEventListener('click', closeSearch);
            overlay.addEventListener('click', function (e) {
                if (e.target === overlay) closeSearch();
            });
            input.addEventListener('input', function () {
                renderResults(input.value);
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && overlay.classList.contains('open')) closeSearch();
            });
        })();

        // === Notificaciones (campanita) ===
        (function () {
            const panel = document.getElementById('notifPanel');
            if (!panel) return;
            const bells = document.querySelectorAll('.js-home-bell');
            function closePanel() {
                panel.classList.remove('open');
                bells.forEach(b => b.setAttribute('aria-expanded', 'false'));
            }
            bells.forEach(bell => {
                bell.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const willOpen = !panel.classList.contains('open');
                    panel.classList.toggle('open', willOpen);
                    bells.forEach(b => b.setAttribute('aria-expanded', willOpen ? 'true' : 'false'));
                });
            });
            document.addEventListener('click', (e) => {
                if (!panel.contains(e.target) && !e.target.closest('.js-home-bell')) {
                    closePanel();
                }
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closePanel();
            });
        })();

        // === More: toggle de formularios del perfil ===
        document.querySelectorAll('.opt-btn[data-form]').forEach(btn => {
            btn.addEventListener('click', () => {
                const id = btn.dataset.form;
                document.querySelectorAll('.perfil-form').forEach(f => {
                    if (f.id === id) f.classList.toggle('open');
                    else f.classList.remove('open');
                });
            });
        });

        // === More: tabs de historial ===
        document.querySelectorAll('.hist-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.hist-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const target = tab.dataset.hist;
                document.querySelectorAll('[data-hist-list]').forEach(l => {
                    l.style.display = l.dataset.histList === target ? '' : 'none';
                });
            });
        });

        // === Services tab: MPA-style search + category pills ===
        (function () {
            const catalog = document.querySelector('[data-ho-services-catalog]');
            if (!catalog) return;

            const searchRoot = catalog.querySelector('[data-ho-service-search]');
            const input = searchRoot?.querySelector('input[type="search"]');
            const empty = catalog.querySelector('[data-ho-service-search-empty]');
            const hero = catalog.querySelector('.services-hero');
            const pills = Array.from(catalog.querySelectorAll('[data-ho-svc-filter]'));
            let activeFilter = 'all';

            function foldText(value) {
                return String(value || '')
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '');
            }

            function applyServiceFilters() {
                const query = foldText(input?.value || '');
                let visibleCount = 0;

                catalog.querySelectorAll('[data-ho-service-section]').forEach(function (section) {
                    const sectionKey = section.getAttribute('data-ho-filter-section');
                    const items = Array.from(section.querySelectorAll('[data-ho-service-item]'));
                    let sectionVisible = 0;

                    if (sectionKey) {
                        const catMatch = activeFilter === 'all' || activeFilter === sectionKey;
                        if (!catMatch) {
                            section.hidden = true;
                            items.forEach(function (item) { item.hidden = true; });
                            return;
                        }

                        items.forEach(function (item) {
                            const haystack = foldText(item.getAttribute('data-search') || item.textContent);
                            const match = !query || haystack.indexOf(query) !== -1;
                            item.hidden = !match;
                            if (match) {
                                sectionVisible += 1;
                                visibleCount += 1;
                            }
                        });

                        if (query && sectionVisible === 0 && items.length === 0) {
                            const sectionMatch = foldText(section.textContent).indexOf(query) !== -1;
                            section.hidden = !sectionMatch;
                            if (sectionMatch) visibleCount += 1;
                            return;
                        }

                        if (query && sectionVisible === 0) {
                            const sectionMatch = foldText(section.textContent).indexOf(query) !== -1;
                            section.hidden = !sectionMatch;
                            if (sectionMatch) {
                                items.forEach(function (item) { item.hidden = false; });
                                visibleCount += items.length || 1;
                            }
                            return;
                        }

                        section.hidden = false;
                        return;
                    }

                    items.forEach(function (item) {
                        const key = item.getAttribute('data-filter') || 'homecare';
                        const catMatch = activeFilter === 'all' || key === activeFilter;
                        const haystack = foldText(item.getAttribute('data-search') || item.textContent);
                        const textMatch = !query || haystack.indexOf(query) !== -1;
                        const show = catMatch && textMatch;
                        item.hidden = !show;
                        if (show) {
                            sectionVisible += 1;
                            visibleCount += 1;
                        }
                    });

                    section.hidden = sectionVisible === 0;
                });

                if (hero) {
                    hero.hidden = activeFilter !== 'all' || query.length > 0;
                }
                if (empty) {
                    empty.hidden = !(visibleCount === 0);
                }
            }

            pills.forEach(function (pill) {
                pill.addEventListener('click', function () {
                    activeFilter = pill.getAttribute('data-ho-svc-filter') || 'all';
                    pills.forEach(function (p) {
                        const on = p === pill;
                        p.classList.toggle('is-active', on);
                        p.setAttribute('aria-selected', on ? 'true' : 'false');
                    });
                    applyServiceFilters();
                });
            });

            if (input) {
                input.addEventListener('input', applyServiceFilters);
                input.addEventListener('search', applyServiceFilters);
            }

            const focusBtn = searchRoot?.querySelector('[data-ho-service-search-focus]');
            if (focusBtn && input) {
                focusBtn.addEventListener('click', function () {
                    input.focus();
                    input.select();
                });
            }

            // Deep-link: #section-services with ?svcFilter=emergency (avoid clash with nearby ?filter=)
            const params = new URLSearchParams(window.location.search);
            const svcFilter = (params.get('svcFilter') || '').toLowerCase();
            if (svcFilter && pills.some(function (p) { return p.getAttribute('data-ho-svc-filter') === svcFilter; })) {
                const target = pills.find(function (p) { return p.getAttribute('data-ho-svc-filter') === svcFilter; });
                target?.click();
            }
        })();

        // === Si llegamos con ?section=more, abrir directamente esa seccion ===
        (function () {
            const params = new URLSearchParams(window.location.search);
            const sec = params.get('section');
            if (sec) {
                const btn = document.querySelector(`.bottom-nav .nav-item[data-target="section-${sec}"]`);
                if (btn) btn.click();
            }
            // Auto-scroll del chat al final
            const chat = document.getElementById('chatBox');
            if (chat) chat.scrollTop = chat.scrollHeight;
        })();

        // === Selector de propiedad (tabs) ===
        document.querySelectorAll('#propertySelector .property-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                const idx = tab.dataset.propIndex;
                document.querySelectorAll('#propertySelector .property-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                // Ocultar todos los paneles principales y extras
                document.querySelectorAll('[data-prop-panel]').forEach(p => p.style.display = 'none');
                document.querySelectorAll(`[data-prop-panel="${idx}"]`).forEach(p => p.style.display = 'block');
            });
        });

    </script>
</body>
</html>
