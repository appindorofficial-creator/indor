@using IndorMvcApp.Localization
@model IEnumerable<IndorMvcApp.Models.Propiedad>
@using System.Text.Json
@using IndorMvcApp.Services
@using IndorMvcApp.ViewModels
@{
    ViewData["Title"] = L["Home - InDor"];
    Layout = null;

    bool IsPrePurchaseInspection(string? name) =>
        string.Equals(name?.Trim(), "Pre-Purchase Home Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsElectricalInspection(string? name) =>
        string.Equals(name?.Trim(), "Electrical Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsCompleteHomeInspection(string? name) =>
        string.Equals(name?.Trim(), "Complete Home Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsPlumbingInspection(string? name) =>
        string.Equals(name?.Trim(), "Plumbing Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsHvacInspection(string? name) =>
        string.Equals(name?.Trim(), "HVAC Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsStructuralInspection(string? name) =>
        string.Equals(name?.Trim(), "Structural Inspection", StringComparison.OrdinalIgnoreCase)
        || string.Equals(name?.Trim(), "Foundation Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsRoofInspection(string? name) =>
        string.Equals(name?.Trim(), "Roof Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsMoldMoistureInspection(string? name) =>
        string.Equals(name?.Trim(), "Mold and Moisture Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsWindowsInsulationInspection(string? name) =>
        string.Equals(name?.Trim(), "Windows and Insulation Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsHomeSafetyInspection(string? name) =>
        string.Equals(name?.Trim(), "Home Safety Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsInvestorInspection(string? name) =>
        string.Equals(name?.Trim(), "Investor Inspection", StringComparison.OrdinalIgnoreCase);

    bool HasInspectionFlow(string? name) =>
        IsPrePurchaseInspection(name) || IsElectricalInspection(name)
        || IsCompleteHomeInspection(name) || IsPlumbingInspection(name)
        || IsHvacInspection(name) || IsStructuralInspection(name) || IsRoofInspection(name)
        || IsMoldMoistureInspection(name) || IsWindowsInsulationInspection(name)
        || IsHomeSafetyInspection(name) || IsInvestorInspection(name);

    string GetInspectionFlowAction(string? name) =>
        IsPrePurchaseInspection(name) ? "PurchaseDetails"
        : IsElectricalInspection(name) ? "ElectricalDetails"
        : IsCompleteHomeInspection(name) ? "HomeReviewDetails"
        : IsPlumbingInspection(name) ? "PlumbingDetails"
        : IsHvacInspection(name) ? "HvacDetails"
        : IsStructuralInspection(name) ? "StructuralDetails"
        : IsRoofInspection(name) ? "RoofDetails"
        : IsMoldMoistureInspection(name) ? "MoldMoistureDetails"
        : IsWindowsInsulationInspection(name) ? "WindowsInsulationDetails"
        : IsHomeSafetyInspection(name) ? "HomeSafetyDetails"
        : IsInvestorInspection(name) ? "InvestorDetails"
        : "PurchaseDetails";

    string Money(decimal? v) => v.HasValue ? string.Format(System.Globalization.CultureInfo.GetCultureInfo("en-US"), "{0:C0}", v.Value) : "\u2014";
    string Num(decimal? v) => v.HasValue ? v.Value.ToString("0.##") : "\u2014";
    string Date(DateTime? d) => d.HasValue ? d.Value.ToString("dd/MM/yyyy") : "\u2014";
    string PricePerSqft(decimal? value, int? sqft)
    {
        if (!value.HasValue || !sqft.HasValue || sqft.Value <= 0) return "\u2014";
        return string.Format(System.Globalization.CultureInfo.GetCultureInfo("en-US"), "${0:N0}/sqft", value.Value / sqft.Value);
    }
    string[] SplitIncludes(string? incluye) => string.IsNullOrWhiteSpace(incluye)
        ? Array.Empty<string>()
        : incluye.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    string BedsLabel(int? beds) => beds.HasValue
        ? (beds.Value == 1 ? L.T("{0} bed", beds.Value) : L.T("{0} beds", beds.Value))
        : "";
    string BathsLabel(decimal? baths) => baths.HasValue
        ? (baths.Value == 1 ? L.T("{0} bath", Num(baths)) : L.T("{0} baths", Num(baths)))
        : "";

    bool IsSafeAirMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 1 || string.Equals(s.Nombre, "Safe Air 365", StringComparison.OrdinalIgnoreCase);

    bool IsLawnMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 2 || string.Equals(s.Nombre, "Always Perfect Lawn", StringComparison.OrdinalIgnoreCase);

    bool IsTrashMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 3 || string.Equals(s.Nombre, "Stress-Free Trash", StringComparison.OrdinalIgnoreCase);

    bool IsCleaningProMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 4 || string.Equals(s.Nombre, "Cleaning Pro", StringComparison.OrdinalIgnoreCase);

    string GetMicroserviceLinkController(IndorMvcApp.Models.Microservicio s) =>
        IsSafeAirMicroservice(s) ? "SafeAir"
        : IsLawnMicroservice(s) ? "Lawn"
        : IsTrashMicroservice(s) ? "Trash"
        : IsCleaningProMicroservice(s) ? "CleaningPro"
        : "Microservicios";

    string GetMicroserviceLinkAction(IndorMvcApp.Models.Microservicio s) =>
        IsSafeAirMicroservice(s) ? "SafeAirService"
        : IsLawnMicroservice(s) ? "LawnService"
        : IsTrashMicroservice(s) ? "TrashService"
        : IsCleaningProMicroservice(s) ? "CleaningProService"
        : "Schedule";

    bool HasDedicatedMicroserviceFlow(IndorMvcApp.Models.Microservicio s) =>
        IsSafeAirMicroservice(s) || IsLawnMicroservice(s) || IsTrashMicroservice(s) || IsCleaningProMicroservice(s);

    OfferingCarouselViewModel BuildMicroCarousel(IEnumerable<IndorMvcApp.Models.Microservicio> items, string subtitle)
    {
        var es = L.IsSpanish;
        return new OfferingCarouselViewModel
        {
            Title = L["Home Care Essentials"],
            Subtitle = subtitle,
            Icon = "fa-layer-group",
            BlockId = "home-care-essentials",
            Items = items.Select(s => new OfferingCardViewModel
            {
                Name = s.LocalizedNombre(es),
                Subtitle = s.LocalizedSubtitulo(es),
                Description = CatalogText.PickWithUiFallback(s.Descripcion, s.DescripcionEs, es),
                Includes = SplitIncludes(CatalogText.PickPipeListWithUiFallback(s.Incluye, s.IncluyeEs, es)),
                Frequency = CatalogText.PickWithUiFallback(s.Frecuencia, s.FrecuenciaEs, es),
                Price = s.Valor,
                PricePrefix = CatalogText.PickWithUiFallback(s.PrecioPrefijo, s.PrecioPrefijoEs, es),
                Currency = s.Moneda,
                Cta = string.IsNullOrWhiteSpace(s.LocalizedCtaTexto(es)) ? L["Schedule service"] : s.LocalizedCtaTexto(es)!,
                ImageUrl = s.ImagenUrl,
                ImageBase64 = s.ImagenBase64,
                SourceId = s.Id,
                EnableSchedule = !HasDedicatedMicroserviceFlow(s),
                EnableLink = true,
                LinkController = GetMicroserviceLinkController(s),
                LinkAction = GetMicroserviceLinkAction(s),
                FilterKey = HomeownerServiceFilter.Classify(s.Nombre),
                SearchText = HomeownerServiceFilter.BuildSearchBlob(s.Nombre, s.LocalizedNombre(es), s.LocalizedSubtitulo(es))
            }).ToList()
        };
    }

    OfferingCarouselViewModel BuildServicioCarousel(
        IEnumerable<IndorMvcApp.Models.Servicio> items,
        string subtitle,
        IReadOnlyDictionary<string, int> homeCarePriorityIds)
    {
        var es = L.IsSpanish;
        return new OfferingCarouselViewModel
        {
            Title = L["Services"],
            Subtitle = subtitle,
            Icon = "fa-screwdriver-wrench",
            BlockId = "services",
            BlockClass = "category-block-services",
            IconClass = "category-icon-alt",
            BadgeClass = "category-badge-alt",
            Items = items.Select(sv =>
            {
                var link = ServicioFlowRules.BuildOfferingLink(sv, homeCarePriorityIds);

                return new OfferingCardViewModel
                {
                    Name = sv.LocalizedNombre(es),
                    Subtitle = sv.LocalizedSubtitulo(es),
                    Description = CatalogText.PickWithUiFallback(sv.Descripcion, sv.DescripcionEs, es),
                    Includes = SplitIncludes(CatalogText.PickPipeListWithUiFallback(sv.Incluye, sv.IncluyeEs, es)),
                    Frequency = CatalogText.PickWithUiFallback(sv.Frecuencia, sv.FrecuenciaEs, es),
                    Price = sv.Valor,
                    PricePrefix = CatalogText.PickWithUiFallback(sv.PrecioPrefijo, sv.PrecioPrefijoEs, es),
                    PriceText = CatalogText.PickWithUiFallback(sv.PrecioTexto, sv.PrecioTextoEs, es),
                    Currency = sv.Moneda,
                    Cta = string.IsNullOrWhiteSpace(sv.LocalizedCtaTexto(es)) ? L["Request quote"] : sv.LocalizedCtaTexto(es)!,
                    ImageUrl = sv.ImagenUrl,
                    FreqIcon = "fa-clock",
                    CtaIcon = ServicioFlowRules.HasFlow(sv.Nombre, sv.Orden) ? "fa-arrow-right" : "fa-paper-plane",
                    SourceId = link.RouteId,
                    EnableLink = true,
                    LinkController = link.Controller,
                    LinkAction = link.Action,
                    FilterKey = HomeownerServiceFilter.Classify(sv.Nombre),
                    SearchText = HomeownerServiceFilter.BuildSearchBlob(sv.Nombre, sv.LocalizedNombre(es), sv.LocalizedSubtitulo(es))
                };
            }).ToList()
        };
    }

    OfferingCarouselViewModel BuildInspeccionCarousel(IEnumerable<IndorMvcApp.Models.Inspeccion> items, string subtitle)
    {
        var es = L.IsSpanish;
        return new OfferingCarouselViewModel
        {
            Title = L["Inspections"],
            Subtitle = subtitle,
            Icon = "fa-magnifying-glass-chart",
            BlockId = "inspections",
            BlockClass = "category-block-inspections",
            IconClass = "category-icon-insp",
            BadgeClass = "category-badge-insp",
            Items = items.Select(ins => new OfferingCardViewModel
            {
                Name = ins.LocalizedNombre(es),
                Subtitle = CatalogText.PickWithUiFallback(ins.Subtitulo, ins.SubtituloEs, es),
                Description = ins.LocalizedDescripcion(es),
                Includes = SplitIncludes(CatalogText.PickPipeListWithUiFallback(ins.Incluye, ins.IncluyeEs, es)),
                Frequency = CatalogText.PickWithUiFallback(ins.Frecuencia, ins.FrecuenciaEs, es),
                Price = ins.Valor,
                PricePrefix = CatalogText.PickWithUiFallback(ins.PrecioPrefijo, ins.PrecioPrefijoEs, es),
                PriceText = CatalogText.PickWithUiFallback(ins.PrecioTexto, ins.PrecioTextoEs, es),
                Currency = ins.Moneda,
                Cta = HasInspectionFlow(ins.Nombre)
                    ? L["Continue"]
                    : (string.IsNullOrWhiteSpace(ins.LocalizedCtaTexto(es)) ? L["Schedule inspection"] : ins.LocalizedCtaTexto(es)!),
                ImageUrl = ins.ImagenUrl,
                FreqIcon = "fa-clipboard-check",
                CtaIcon = HasInspectionFlow(ins.Nombre)
                    ? "fa-arrow-right"
                    : "fa-calendar-check",
                SourceId = ins.Id,
                EnableLink = HasInspectionFlow(ins.Nombre),
                LinkController = "Inspecciones",
                LinkAction = GetInspectionFlowAction(ins.Nombre),
                FilterKey = HomeownerServiceFilter.Classify(ins.Nombre),
                SearchText = HomeownerServiceFilter.BuildSearchBlob(ins.Nombre, ins.LocalizedNombre(es), CatalogText.PickWithUiFallback(ins.Subtitulo, ins.SubtituloEs, es))
            }).ToList()
        };
    }

    // === Construir slides agrupados desde PropertyInfoViewModel ===
    List<(string Title, string Icon, List<(string Label, string Value)> Items)> BuildGroupsFor(PropertyInfoViewModel info)
    {
        var groups = new List<(string Title, string Icon, List<(string Label, string Value)> Items)>();

        // 1. Direccion
        var dir = new List<(string, string)>();
        if (!string.IsNullOrWhiteSpace(info.FormattedAddress)) dir.Add((L["Full address"], info.FormattedAddress));
        if (!string.IsNullOrWhiteSpace(info.HouseNumber)) dir.Add((L["House number"], info.HouseNumber!));
        if (!string.IsNullOrWhiteSpace(info.Street)) dir.Add((L["Street"], info.Street!));
        if (!string.IsNullOrWhiteSpace(info.City)) dir.Add((L["City"], info.City!));
        if (!string.IsNullOrWhiteSpace(info.County)) dir.Add((L["County"], info.County!));
        if (!string.IsNullOrWhiteSpace(info.State)) dir.Add((L["State"], info.State!));
        if (!string.IsNullOrWhiteSpace(info.PostalCode)) dir.Add((L["Postal code"], info.PostalCode!));
        if (!string.IsNullOrWhiteSpace(info.Country)) dir.Add((L["Country"], info.Country!));
        if (dir.Count > 0) groups.Add((L["Address"], "fa-map-marker-alt", dir));

        // 2. Coordenadas
        var coords = new List<(string, string)>
        {
            (L["Latitude"], info.Latitude.ToString("0.######")),
            (L["Longitude"], info.Longitude.ToString("0.######"))
        };
        if (info.BoundingBox != null)
        {
            coords.Add((L["Area (lat min/max)"], $"{info.BoundingBox.MinLat:0.####} / {info.BoundingBox.MaxLat:0.####}"));
            coords.Add((L["Area (lon min/max)"], $"{info.BoundingBox.MinLon:0.####} / {info.BoundingBox.MaxLon:0.####}"));
        }
        groups.Add((L["Coordinates"], "fa-location-crosshairs", coords));

        // 3. Detalles de la propiedad
        if (info.PropertyDetails != null)
        {
            var d = info.PropertyDetails;
            var det = new List<(string, string)>();
            if (!string.IsNullOrWhiteSpace(d.PropertyType)) det.Add((L["Property type"], d.PropertyType));
            if (d.YearBuilt.HasValue) det.Add((L["Year built"], d.YearBuilt.Value.ToString()));
            if (d.YearRenovated.HasValue) det.Add((L["Year renovated"], d.YearRenovated.Value.ToString()));
            if (d.LivingArea.HasValue) det.Add((L["Living area"], $"{d.LivingArea} sq ft"));
            if (d.LotSize.HasValue) det.Add((L["Lot size"], $"{d.LotSize} acres"));
            if (d.Bedrooms.HasValue) det.Add((L["Bedrooms"], d.Bedrooms.Value.ToString()));
            if (d.Bathrooms.HasValue) det.Add((L["Bathrooms"], Num(d.Bathrooms)));
            if (d.Floors.HasValue) det.Add((L["Floors"], d.Floors.Value.ToString()));
            if (!string.IsNullOrWhiteSpace(d.ArchitecturalStyle)) det.Add((L["Style"], d.ArchitecturalStyle));
            if (d.Features != null && d.Features.Count > 0) det.Add((L["Features"], string.Join(", ", d.Features)));
            if (det.Count > 0) groups.Add((L["Property details"], "fa-house", det));

            // 4. Valor e impuestos
            var val = new List<(string, string)>();
            if (d.EstimatedValue.HasValue) val.Add((L.T("Estimated value ({0})", d.EstimatedValueYear), Money(d.EstimatedValue)));
            if (d.LastSalePrice.HasValue) val.Add((L["Last sale price"], Money(d.LastSalePrice)));
            if (d.LastSaleDate.HasValue) val.Add((L["Last sale date"], Date(d.LastSaleDate)));
            if (d.AnnualTaxAmount.HasValue) val.Add((L.T("Annual taxes ({0})", d.TaxYear), Money(d.AnnualTaxAmount)));
            if (!string.IsNullOrWhiteSpace(d.ParcelNumber)) val.Add((L["Parcel number"], d.ParcelNumber!));
            if (!string.IsNullOrWhiteSpace(d.Zoning)) val.Add((L["Zoning"], d.Zoning!));
            if (val.Count > 0) groups.Add((L["Value and taxes"], "fa-dollar-sign", val));
        }

        return groups;
    }

    // === Servicios publicos como tarjetas ricas ===
    List<UtilityCard> BuildUtilities(UtilityProvidersInfo? u)
    {
        var list = new List<UtilityCard>();
        if (u == null) return list;
        void Add(UtilityProvider? p, string icon)
        {
            if (p == null || string.IsNullOrWhiteSpace(p.Name)) return;
            list.Add(new UtilityCard { Icon = icon, Provider = p });
        }
        Add(u.Electric, "fa-bolt");
        Add(u.Water, "fa-droplet");
        Add(u.Sewer, "fa-water");
        Add(u.Gas, "fa-fire-flame-curved");
        if (u.Internet != null) foreach (var p in u.Internet) Add(p, "fa-wifi");
        if (u.CableTV != null) foreach (var p in u.CableTV) Add(p, "fa-tv");
        return list;
    }

    // === Garantias / seguros como tarjetas ricas ===
    List<WarrantyCard> BuildWarranties(HomeWarrantiesInfo? w)
    {
        var list = new List<WarrantyCard>();
        if (w == null) return list;
        void Add(HomeWarranty? hw, string icon)
        {
            if (hw == null || string.IsNullOrWhiteSpace(hw.SystemName)) return;
            list.Add(new WarrantyCard { Icon = icon, Warranty = hw });
        }
        Add(w.HomeWarrantyPolicy, "fa-shield-halved");
        Add(w.HVACSystem, "fa-temperature-half");
        Add(w.WaterHeater, "fa-fire");
        Add(w.Roof, "fa-house-chimney");
        Add(w.Appliances, "fa-blender");
        Add(w.Plumbing, "fa-faucet");
        Add(w.Electrical, "fa-plug");
        return list;
    }

    var jsonOpts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

    // Cada slide tiene un Kind: "group" | "utilities" | "warranties"
    var propertiesGrouped = new List<(
        IndorMvcApp.Models.Propiedad Prop,
        List<SlideEntry> Slides)>();

    foreach (var p in Model)
    {
        PropertyInfoViewModel? info = null;
        if (!string.IsNullOrWhiteSpace(p.DatosJson))
        {
            try { info = JsonSerializer.Deserialize<PropertyInfoViewModel>(p.DatosJson, jsonOpts); }
            catch { info = null; }
        }

        var slides = new List<SlideEntry>();

        if (info != null)
        {
            // Slides agrupados de informacion basica
            foreach (var g in BuildGroupsFor(info))
            {
                slides.Add(new SlideEntry
                {
                    Kind = "group",
                    Title = g.Title,
                    Icon = g.Icon,
                    Items = g.Items
                });
            }

            // Slide de servicios publicos (asociados a esta direccion)
            var utils = BuildUtilities(info.UtilityProviders);
            if (utils.Count > 0)
            {
                slides.Add(new SlideEntry
                {
                    Kind = "utilities",
                    Title = L["Utilities"],
                    Icon = "fa-plug-circle-bolt",
                    Utilities = utils
                });
            }

            // Slide de seguros / garantias (asociados a esta direccion)
            var warrs = BuildWarranties(info.HomeWarranties);
            if (warrs.Count > 0)
            {
                slides.Add(new SlideEntry
                {
                    Kind = "warranties",
                    Title = L["Insurance and warranties"],
                    Icon = "fa-shield-halved",
                    Warranties = warrs
                });
            }
        }
        else
        {
            // Compatibilidad con propiedades viejas
            slides.Add(new SlideEntry
            {
                Kind = "group",
                Title = L["Address"],
                Icon = "fa-map-marker-alt",
                Items = new List<(string, string)> { (L["Address"], p.Direccion ?? "\u2014") }
            });
        }

        propertiesGrouped.Add((p, slides));
    }
    var hasProperties = propertiesGrouped.Count > 0;

    // === Informacion basica de la propiedad principal (la mas reciente) ===
    PropertyInfoViewModel? primaryInfo = null;
    IndorMvcApp.Models.Propiedad? primaryProp = null;
    if (hasProperties)
    {
        primaryProp = propertiesGrouped[0].Prop;
        if (!string.IsNullOrWhiteSpace(primaryProp.DatosJson))
        {
            try { primaryInfo = JsonSerializer.Deserialize<PropertyInfoViewModel>(primaryProp.DatosJson, jsonOpts); }
            catch { primaryInfo = null; }
        }
    }

    // === Notificaciones derivadas de las garantias guardadas ===
    var notificaciones = new List<NotificationItem>();
    foreach (var entry in propertiesGrouped)
    {
        var p = entry.Prop;
        PropertyInfoViewModel? infoP = null;
        if (!string.IsNullOrWhiteSpace(p.DatosJson))
        {
            try { infoP = JsonSerializer.Deserialize<PropertyInfoViewModel>(p.DatosJson, jsonOpts); }
            catch { infoP = null; }
        }
        if (infoP?.HomeWarranties == null) continue;

        void EvalWarranty(HomeWarranty? w, string defaultIcon)
        {
            if (w == null || string.IsNullOrWhiteSpace(w.SystemName)) return;
            if (!w.CoverageEndDate.HasValue) return;
            var end = w.CoverageEndDate.Value.Date;
            var today = DateTime.Today;
            var days = (end - today).Days;
            string severity;
            string icon = defaultIcon;
            string title;
            if (days < 0)
            {
                severity = "expired";
                title = L.T("{0} expired", w.SystemName);
            }
            else if (days <= 30)
            {
                severity = "soon";
                title = days == 1
                    ? L.T("{0} expires in {1} day", w.SystemName, days)
                    : L.T("{0} expires in {1} days", w.SystemName, days);
            }
            else if (days <= 90)
            {
                severity = "upcoming";
                title = L.T("{0} expires in {1} days", w.SystemName, days);
            }
            else
            {
                return;
            }
            notificaciones.Add(new NotificationItem
            {
                Icon = icon,
                Severity = severity,
                Title = title,
                Subtitle = $"{(string.IsNullOrWhiteSpace(w.WarrantyProvider) ? L["Warranty"] : w.WarrantyProvider)} \u00B7 {p.Direccion}",
                Date = end,
                DaysRemaining = days
            });
        }

        var hw = infoP.HomeWarranties;
        EvalWarranty(hw.HomeWarrantyPolicy, "fa-shield-halved");
        EvalWarranty(hw.HVACSystem, "fa-temperature-half");
        EvalWarranty(hw.WaterHeater, "fa-fire");
        EvalWarranty(hw.Roof, "fa-house-chimney");
        EvalWarranty(hw.Appliances, "fa-blender");
        EvalWarranty(hw.Plumbing, "fa-faucet");
        EvalWarranty(hw.Electrical, "fa-plug");
    }

    var programacionesMs = ViewBag.ProgramacionesMicroservicio as List<IndorMvcApp.Models.ProgramacionMicroservicio>
                             ?? new List<IndorMvcApp.Models.ProgramacionMicroservicio>();
    foreach (var prog in programacionesMs)
    {
        var scheduled = prog.FechaProgramada.Date;
        var days = (scheduled - DateTime.Today).Days;
        var serviceName = prog.Microservicio != null
            ? prog.Microservicio.LocalizedNombre(L.IsSpanish)
            : L["Microservice"];
        string severity;
        string title;
        if (days < 0)
        {
            severity = "expired";
            var overdueDays = Math.Abs(days);
            title = overdueDays == 1
                ? L.T("{0} overdue by {1} day", serviceName, overdueDays)
                : L.T("{0} overdue by {1} days", serviceName, overdueDays);
        }
        else if (days == 0)
        {
            severity = "soon";
            title = L.T("{0} due today", serviceName);
        }
        else if (days <= 30)
        {
            severity = "soon";
            title = days == 1
                ? L.T("{0} due in {1} day", serviceName, days)
                : L.T("{0} due in {1} days", serviceName, days);
        }
        else if (days <= 90)
        {
            severity = "upcoming";
            title = L.T("{0} scheduled in {1} days", serviceName, days);
        }
        else
        {
            continue;
        }

        notificaciones.Add(new NotificationItem
        {
            Icon = "fa-calendar-check",
            Severity = severity,
            Title = title,
            Subtitle = string.IsNullOrWhiteSpace(prog.Propiedad?.Direccion)
                ? L["Home maintenance reminder"]
                : prog.Propiedad!.Direccion!,
            Date = scheduled,
            DaysRemaining = days
        });
    }

    notificaciones = notificaciones.OrderBy(n => n.DaysRemaining).ToList();
    var homeNotificationItems = notificaciones.Select(n => new IndorMvcApp.ViewModels.HomeNotificationItemViewModel
    {
        Icon = n.Icon,
        Severity = n.Severity,
        Title = n.Title,
        Subtitle = n.Subtitle,
        Date = n.Date
    }).ToList();

    // Prepend persisted in-app notifications (e.g. "a provider took your request").
    var persistedNotifications = ViewBag.PersistedNotifications as IReadOnlyList<IndorMvcApp.Services.AppNotificationView>;
    if (persistedNotifications != null && persistedNotifications.Count > 0)
    {
        var persistedItems = persistedNotifications.Select(pn => new IndorMvcApp.ViewModels.HomeNotificationItemViewModel
        {
            Icon = string.IsNullOrWhiteSpace(pn.IconClass) ? "fa-bell" : pn.IconClass,
            Severity = pn.IsRead ? "upcoming" : "soon",
            Title = pn.Title,
            Subtitle = pn.Body ?? "",
            Date = pn.FechaCreacion.ToLocalTime(),
            TimeLabel = pn.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy"),
            Url = pn.TargetUrl,
            IsPreLocalized = true
        }).ToList();
        homeNotificationItems = persistedItems.Concat(homeNotificationItems).ToList();
    }
    var moreProfileShell = (IndorMvcApp.ViewModels.MoreProfileViewModel?)ViewBag.MoreProfile
        ?? new IndorMvcApp.ViewModels.MoreProfileViewModel();
    ViewData["HomeNotificationCount"] = homeNotificationItems.Count;
    ViewData["HomeNotificationItems"] = homeNotificationItems;

    var homeNearbyNetworkModel = ViewBag.HomeNearbyNetwork as IndorMvcApp.ViewModels.HomeownerNearbyNetworkViewModel;
    var isHomeMapView = homeNearbyNetworkModel?.ActiveView == "map";
    var isHomeLanding = homeNearbyNetworkModel?.ActiveFilter == IndorMvcApp.Models.NearbyNetworkHomeownerFilters.All
        && string.IsNullOrWhiteSpace(homeNearbyNetworkModel?.SearchQuery)
        && !isHomeMapView;
}

@functions {
    public class UtilityCard
    {
        public string Icon { get; set; } = "";
        public UtilityProvider Provider { get; set; } = new();
    }
    public class WarrantyCard
    {
        public string Icon { get; set; } = "";
        public HomeWarranty Warranty { get; set; } = new();
    }
    public class SlideEntry
    {
        public string Kind { get; set; } = "group";
        public string Title { get; set; } = "";
        public string Icon { get; set; } = "fa-circle-info";
        public List<(string Label, string Value)> Items { get; set; } = new();
        public List<UtilityCard> Utilities { get; set; } = new();
        public List<WarrantyCard> Warranties { get; set; } = new();
    }
    public class NotificationItem
    {
        public string Icon { get; set; } = "fa-bell";
        public string Severity { get; set; } = "upcoming"; // expired | soon | upcoming
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public DateTime Date { get; set; }
        public int DaysRemaining { get; set; }
    }
}
<!DOCTYPE html>
<html lang="@(L.IsSpanish ? "es" : "en")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>@ViewData["Title"]</title>
    @await Html.PartialAsync("_IndorDesignHead")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/home-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-nearby-network.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile-more.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/schedule-section.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/homeowner-bottom-nav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-portal-header.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-portal.css" asp-append-version="true" />
    @await Html.PartialAsync("_AppVersionHead")
    <link rel="stylesheet" href="~/css/home-index.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-nearby-network-v4.css" asp-append-version="true" />
    @await Html.PartialAsync("_TabletResponsiveHead")
</head>
<body class="rl-dash-page @(isHomeLanding ? "hn-landing-active" : "")">
    <div class="home-search-overlay" id="homeSearchOverlay" role="dialog" aria-label="@L["Search"]" aria-hidden="true">
        <div class="home-search-panel">
            <div class="home-search-head">
                <input type="search" id="homeSearchInput" placeholder="@L["Search services, inspections, emergencies..."]" autocomplete="off" />
                <button type="button" class="home-search-cancel" id="homeSearchClose">@L["Cancel"]</button>
            </div>
            <div class="home-search-results" id="homeSearchResults"></div>
        </div>
    </div>

    <div class="ho-notify-wrap ho-notify-wrap--global" id="hoNotifyWrap">
        @{
            var notifyCount = ViewData["HomeNotificationCount"] as int? ?? 0;
            var notifyItems = ViewData["HomeNotificationItems"] as IReadOnlyList<IndorMvcApp.ViewModels.HomeNotificationItemViewModel>
                ?? Array.Empty<IndorMvcApp.ViewModels.HomeNotificationItemViewModel>();
        }
        <div class="ho-notify-panel" id="notifPanel" role="dialog" aria-label="@L["Notifications"]">
            <div class="ho-notify-panel-head">
                <strong>@L["Notifications"]</strong>
                @if (notifyCount > 0)
                {
                    <span class="ho-notify-badge">@L["New"]</span>
                }
            </div>
            @if (notifyCount == 0)
            {
                <div class="ho-notify-empty">@L["You have no notifications right now."]</div>
            }
            else
            {
                <div class="ho-notify-list">
                    @await Html.PartialAsync("_HomeownerNotificationItems", notifyItems)
                </div>
            }
        </div>
    </div>

    <!-- ====== HOME (Nearby Network) ====== -->
    <section class="section ho-portal-section active hn-v4 @(isHomeMapView ? "hn-map-active" : "") @(isHomeLanding ? "hn-v4-landing" : "")" id="section-home">
        @{
            var homeNearbyNetwork = homeNearbyNetworkModel;
        }
        <div class="rl-dash-shell rl-network-page @(isHomeMapView ? "rl-network-page--map" : "")">
            @await Html.PartialAsync("_HomeNetworkHeader", homeNearbyNetwork)

            @if (TempData["NeighborRequestSaved"] is string neighborMsg)
            {
                <div class="alert-schedule-ok hn-v4-alert"><i class="fas fa-check-circle"></i> @neighborMsg</div>
            }
            @if (TempData["PerfilOk"] != null)
            {
                <div class="alert-schedule-ok hn-v4-alert"><i class="fas fa-check-circle"></i> @TempData["PerfilOk"]</div>
            }

            @if (homeNearbyNetwork != null)
            {
                @await Html.PartialAsync("_HomeNearbyNetworkHero", homeNearbyNetwork)
            }

            <div class="ho-view-switcher-wrap">
                @{
                    ViewData["HomeViewSwitcherActive"] = "network";
                }
                @await Html.PartialAsync("_HomeViewSwitcher")
            </div>

            @if (homeNearbyNetwork != null)
            {
                @await Html.PartialAsync("_HomeNearbyNetwork", homeNearbyNetwork)
            }
        </div>
    </section>

    <!-- ====== MY HOME (property dashboard) ====== -->
    <section class="section hn-v4-myhome" id="section-mydashboard">
        @{
            var homeDashboard = ViewBag.HomeDashboard as IndorMvcApp.ViewModels.HomeDashboardViewModel;
        }
        <div class="rl-dash-shell">
            <div class="rl-portal-page-hero ho-home-hero">
                @await Html.PartialAsync("_HomeownerTopbar")
                <div class="ho-home-hero-user">
                    @if (!string.IsNullOrWhiteSpace(moreProfileShell.PhotoUrl))
                    {
                        <img src="@Url.Content("~" + moreProfileShell.PhotoUrl)" alt="" class="ho-home-avatar" asp-append-version="true" />
                    }
                    else
                    {
                        <span class="ho-home-avatar ho-home-avatar--placeholder"><i class="fas fa-user"></i></span>
                    }
                    <div>
                        <h1>@L["Hello"] @(string.IsNullOrWhiteSpace(moreProfileShell.FullName) || moreProfileShell.FullName == "Your name" ? L["there"] : moreProfileShell.FullName)</h1>
                        <span class="ho-home-badge"><i class="fas fa-house"></i> @L["Homeowner"]</span>
                    </div>
                </div>
            </div>

            @if (TempData["InspectionSaved"] is string inspectionMsg)
            {
                <div class="alert-schedule-ok" style="margin:0 0 12px;"><i class="fas fa-check-circle"></i> @inspectionMsg</div>
            }
            @if (TempData["PropertySaved"] is string propertySavedMsg)
            {
                <div class="alert-schedule-ok" style="margin:0 0 12px;"><i class="fas fa-check-circle"></i> @propertySavedMsg</div>
            }
            <div class="ho-view-switcher-wrap">
                @{
                    ViewData["HomeViewSwitcherActive"] = "myhome";
                }
                @await Html.PartialAsync("_HomeViewSwitcher")
            </div>
            @if (homeDashboard != null)
            {
                @await Html.PartialAsync("_HomeDashboard", homeDashboard)
            }
        </div>
    </section>

    <!-- ====== SERVICES ====== -->
    <section class="section ho-portal-section" id="section-services">
        <div class="rl-dash-shell">
        @await Html.PartialAsync("_HomeownerSectionHero", new IndorMvcApp.ViewModels.HomeownerSectionHeroViewModel
        {
            Title = L["Services"],
            Subtitle = L["Verified professionals for your home"]
        })
        @{
            var microservicios = (IEnumerable<IndorMvcApp.Models.Microservicio>?)ViewBag.Microservicios
                                 ?? Enumerable.Empty<IndorMvcApp.Models.Microservicio>();
            var servicios = (IEnumerable<IndorMvcApp.Models.Servicio>?)ViewBag.Servicios
                             ?? Enumerable.Empty<IndorMvcApp.Models.Servicio>();
            var inspecciones = (IEnumerable<IndorMvcApp.Models.Inspeccion>?)ViewBag.Inspecciones
                                ?? Enumerable.Empty<IndorMvcApp.Models.Inspeccion>();
            var serviciosEmergencia = (IEnumerable<IndorMvcApp.Models.ServicioEmergencia>?)ViewBag.ServiciosEmergencia
                                      ?? Enumerable.Empty<IndorMvcApp.Models.ServicioEmergencia>();
            var movingSetupSection = ViewBag.MovingSetupSection as IndorMvcApp.ViewModels.MovingSetupSectionViewModel;
            var homeCarePrioritiesSection = ViewBag.HomeCarePrioritiesSection as IndorMvcApp.ViewModels.HomeCarePrioritiesSectionViewModel;
            var homeCarePriorityIds = ViewBag.HomeCarePriorityIds as IReadOnlyDictionary<string, int>
                                      ?? new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            var homeCareGuideCount = homeCarePrioritiesSection?.Items.Count ?? 0;
            var movingSetupCount = movingSetupSection?.Servicios.Count ?? 0;
            var emergencyCount = serviciosEmergencia.Count(s => s.Activo);
            var totalOfferings = microservicios.Count()
                + servicios.Count()
                + inspecciones.Count()
                + homeCareGuideCount
                + movingSetupCount
                + emergencyCount;
        }

        @if (totalOfferings == 0)
        {
            <div class="empty-state">
                <i class="fas fa-tools"></i>
                <p>@L["No services available right now."]</p>
            </div>
        }
        else
        {
            <div class="services-catalog" data-ho-services-catalog>
                <div class="services-hero">
                    <div class="services-hero-text">
                        <strong>@L["Take care of your home effortlessly"]</strong>
                        <small>@L["Verified professionals with transparent pricing."]</small>
                    </div>
                    <div class="services-hero-icon"><i class="fas fa-house-chimney-medical"></i></div>
                </div>

                @{
                    var serviceFilters = new[]
                    {
                        ("all", L["All services"].ToString(), "fa-grid-2"),
                        ("emergency", L["Emergency"].ToString(), "fa-truck-medical"),
                        ("homecare", L["Homecare"].ToString(), "fa-house-chimney"),
                        ("cleaning", L["Cleaning"].ToString(), "fa-broom"),
                        ("outdoor", L["Outdoor"].ToString(), "fa-seedling"),
                        ("moving", L["Moving"].ToString(), "fa-truck")
                    };
                    var svcSearchPlaceholder = L["Search services (e.g., plumbing, cleaning)"].ToString();
                    var svcSearchAria = L["Search services"].ToString();
                    var svcFilterBtnAria = L["Filter"].ToString();
                    var svcFilterListAria = L["Filter services"].ToString();
                }
                <div class="ho-svc-search" data-ho-service-search>
                    <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                    <input type="search" id="ho-service-search"
                           placeholder="@svcSearchPlaceholder"
                           aria-label="@svcSearchAria"
                           autocomplete="off" />
                    <button type="button" class="ho-svc-search-btn" data-ho-service-search-focus aria-label="@svcFilterBtnAria">
                        <i class="fas fa-sliders" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="ho-svc-filter-pills" role="tablist" aria-label="@svcFilterListAria">
                    @foreach (var (key, label, icon) in serviceFilters)
                    {
                        <button type="button"
                                class="ho-svc-filter-pill @(key == "all" ? "is-active" : null)"
                                data-ho-svc-filter="@key"
                                role="tab"
                                aria-selected="@(key == "all" ? "true" : "false")">
                            <i class="fas @icon" aria-hidden="true"></i> @label
                        </button>
                    }
                </div>
                <p class="ho-svc-search-empty" data-ho-service-search-empty hidden>@L["No services match your search."]</p>

                @if (microservicios.Any())
                {
                    @await Html.PartialAsync("_OfferingCarousel", BuildMicroCarousel(microservicios, L.T("{0} services available for your home", microservicios.Count())))
                }

                @if (homeCarePrioritiesSection != null)
                {
                    @await Html.PartialAsync("_HomeCarePrioritiesSection", homeCarePrioritiesSection)
                }

                @if (movingSetupSection != null)
                {
                    @await Html.PartialAsync("_MovingSetupSection", movingSetupSection)
                }

                @if (servicios.Any())
                {
                    @await Html.PartialAsync("_OfferingCarousel", BuildServicioCarousel(servicios, L.T("{0} remodeling and installation projects", servicios.Count()), homeCarePriorityIds))
                }

                @if (inspecciones.Any())
                {
                    @await Html.PartialAsync("_OfferingCarousel", BuildInspeccionCarousel(inspecciones, L.T("{0} professional inspections for your home", inspecciones.Count())))
                }

                @{
                    var emergencySection = EmergencyServicesDisplayService.BuildSection(serviciosEmergencia, Url, L.IsSpanish);
                }
                @if (emergencySection != null)
                {
                    @await Html.PartialAsync("_EmergencyServicesSection", emergencySection)
                }
            </div>
        }
        </div>
    </section>
    <section class="section ho-portal-section" id="section-myhome">
        <div class="rl-dash-shell">
        @await Html.PartialAsync("_HomeownerSectionHero", new IndorMvcApp.ViewModels.HomeownerSectionHeroViewModel
        {
            Title = L["House Facts"],
            Subtitle = L["Your property overview and details"]
        })
        @{
            var houseFactProfile = ViewBag.HouseFactProfile as HouseFactProfileViewModel;
            var houseFactPreviewMode = ViewBag.HouseFactPreviewMode as bool? == true;
            var houseFactPropiedadId = ViewBag.HouseFactPropiedadId as int?;
        }

        @if (houseFactProfile != null && houseFactProfile.HasData)
        {
            if (houseFactPreviewMode)
            {
                ViewData["HouseFactPreview"] = true;
            }
            else if (houseFactPropiedadId.HasValue)
            {
                ViewData["PropiedadId"] = houseFactPropiedadId.Value;
                ViewData["EditUrl"] = Url.Action("Edit", "MyHome", new { id = houseFactPropiedadId.Value });
                ViewData["MyPropertyUrl"] = Url.Action("Index", "MyHome", new { id = houseFactPropiedadId.Value });
            }

            @await Html.PartialAsync("_HouseFactProfile", houseFactProfile)

            @if (houseFactPreviewMode)
            {
                <div class="results-card" style="margin-top:16px;padding:16px;">
                    <div class="results-title" style="margin-bottom:8px;">@L["Ready to save this property?"]</div>
                    <p style="color:#64748B;font-size:0.88rem;margin-bottom:12px;">@L["Confirm the address to add it to your account and unlock full property management."]</p>
                    <a asp-controller="Propietario" asp-action="PropertyDetails" class="btn-primary-link" style="display:inline-flex;align-items:center;gap:8px;">
                        <i class="fas fa-check"></i> @L["Continue to confirm property"]
                    </a>
                </div>
            }
        }
        else if (!hasProperties && !houseFactPreviewMode)
        {
            <div class="hn-network-empty">
                <i class="fas fa-house"></i>
                <p>@L["You have no registered properties yet."]</p>
                <a asp-controller="Perfil" asp-action="EditarPerfil" asp-fragment="home" class="hn-btn-primary">@L["Add property"]</a>
            </div>
        }
        else
        {
            <div class="hn-network-empty">
                <i class="fas fa-file-circle-question"></i>
                <p>@L["No House Fact data is available yet for this property."]</p>
                @if (hasProperties && primaryProp != null)
                {
                    <a asp-controller="MyHome" asp-action="Details" asp-route-id="@primaryProp.Id" asp-route-tab="attom" class="hn-btn-primary">
                        @L["Refresh property data"]
                    </a>
                }
                else
                {
                    <a asp-controller="Perfil" asp-action="EditarPerfil" asp-fragment="home" class="hn-btn-primary">
                        @L["Search an address"]
                    </a>
                }
            </div>
        }
        </div>
    </section>

    <!-- ====== SCHEDULE ====== -->
    @{
        var scheduleSection = ViewBag.ScheduleSection as IndorMvcApp.ViewModels.ScheduleSectionViewModel
            ?? new IndorMvcApp.ViewModels.ScheduleSectionViewModel();
    }
    @await Html.PartialAsync("_ScheduleSection", scheduleSection)

    <!-- ====== MORE ====== -->
    <section class="section ho-portal-section" id="section-more">
        <div class="rl-dash-shell">
        @await Html.PartialAsync("_HomeownerSectionHero", new IndorMvcApp.ViewModels.HomeownerSectionHeroViewModel
        {
            Title = L["More"],
            Subtitle = L["Account, homes, and preferences"]
        })
        @{
            var moreProfile = (IndorMvcApp.ViewModels.MoreProfileViewModel?)ViewBag.MoreProfile
                ?? new IndorMvcApp.ViewModels.MoreProfileViewModel();
            var homeLabel = moreProfile.HomeCount == 1 ? L["1 Home"] : L.T("{0} Homes", moreProfile.HomeCount);
            var docLabel = moreProfile.DocumentCount == 1 ? L["1 Document"] : L.T("{0} Documents", moreProfile.DocumentCount);
            var svcLabel = moreProfile.ServiceCount == 1 ? L["1 Service"] : L.T("{0} Services", moreProfile.ServiceCount);
        }

        @if (TempData["PerfilOk"] != null)
        {
            <div class="alert-ok"><i class="fas fa-check-circle"></i> @TempData["PerfilOk"]</div>
        }
        @if (TempData["PerfilError"] != null)
        {
            <div class="alert-err"><i class="fas fa-exclamation-triangle"></i> @TempData["PerfilError"]</div>
        }

        <div class="more-hub">
            @{
                ViewData["ShowActions"] = true;
            }
            @await Html.PartialAsync("~/Views/Perfil/_MoreProfileHero.cshtml", moreProfile)

            <div class="more-stats">
                @if (ProfileDisplayService.PaidMembershipEnabled)
                {
                    <div class="more-stat">
                        <i class="fas fa-shield-alt more-stat-ic"></i>
                        <div class="ms-label">@L["Membership status"]</div>
                        <div class="ms-value">@moreProfile.MembershipLabel</div>
                        <i class="fas fa-shield-alt more-stat-art" aria-hidden="true"></i>
                    </div>
                }
                <div class="more-stat">
                    <i class="fas fa-house more-stat-ic"></i>
                    <div class="ms-label">@L["Home Added"]</div>
                    <div class="ms-value">@homeLabel</div>
                    <i class="fas fa-house more-stat-art" aria-hidden="true"></i>
                </div>
                <div class="more-stat">
                    <i class="fas fa-file-lines more-stat-ic"></i>
                    <div class="ms-label">@L["Documents"]</div>
                    <div class="ms-value">@docLabel</div>
                    <i class="fas fa-book-open more-stat-art" aria-hidden="true"></i>
                </div>
                <div class="more-stat">
                    <i class="fas fa-screwdriver-wrench more-stat-ic"></i>
                    <div class="ms-label">@L["Services"]</div>
                    <div class="ms-value">@svcLabel</div>
                    <i class="fas fa-toolbox more-stat-art" aria-hidden="true"></i>
                </div>
            </div>

            <p class="more-section-title">@L["Account"]</p>
            <div class="more-menu-card">
                <a class="more-menu-item" asp-controller="Perfil" asp-action="Opciones">
                    <span class="mm-icon"><i class="fas fa-user"></i></span>
                    <span class="mm-body">
                        <strong>@L["Profile Options"]</strong>
                        <small>@L["Edit details, photo, password and payment methods"]</small>
                    </span>
                    <i class="fas fa-chevron-right mm-chevron"></i>
                </a>
                <a class="more-menu-item" asp-controller="Perfil" asp-action="Pagos">
                    <span class="mm-icon"><i class="fas fa-wallet"></i></span>
                    <span class="mm-body">
                        <strong>@L["Payments"]</strong>
                        <small>@L["View payments, financing and billing history"]</small>
                    </span>
                    <i class="fas fa-chevron-right mm-chevron"></i>
                </a>
                @if (ProfileDisplayService.PaidMembershipEnabled)
                {
                    <a class="more-menu-item" asp-controller="Perfil" asp-action="Suscripciones">
                        <span class="mm-icon"><i class="fas fa-crown"></i></span>
                        <span class="mm-body">
                            <strong>@L["Subscriptions"]</strong>
                            <small>@L["Manage plans, add-ons and renewals"]</small>
                        </span>
                        <i class="fas fa-chevron-right mm-chevron"></i>
                    </a>
                }
                <a class="more-menu-item" asp-controller="Perfil" asp-action="Historial">
                    <span class="mm-icon"><i class="fas fa-clock-rotate-left"></i></span>
                    <span class="mm-body">
                        <strong>@L["History"]</strong>
                        <small>@L["Microservices, inspections and past services"]</small>
                    </span>
                    <i class="fas fa-chevron-right mm-chevron"></i>
                </a>
            </div>

            <p class="more-section-title">@L["Home & Services"]</p>
            <div class="more-menu-card">
                <a class="more-menu-item" asp-controller="Perfil" asp-action="Internet">
                    <span class="mm-icon"><i class="fas fa-wifi"></i></span>
                    <span class="mm-body">
                        <strong>@L["Internet Comparison"]</strong>
                        <small>@L["Compare internet plans and providers"]</small>
                    </span>
                    <i class="fas fa-chevron-right mm-chevron"></i>
                </a>
                <a class="more-menu-item" asp-controller="Perfil" asp-action="Opciones" asp-fragment="notifications">
                    <span class="mm-icon"><i class="fas fa-bell"></i></span>
                    <span class="mm-body">
                        <strong>@L["Notifications & Security"]</strong>
                        <small>@L["Manage alerts, preferences and account security"]</small>
                    </span>
                    <i class="fas fa-chevron-right mm-chevron"></i>
                </a>
                <a class="more-menu-item" asp-controller="Account" asp-action="DeleteAccount">
                    <span class="mm-icon" style="color:#B91C1C;"><i class="fas fa-user-xmark"></i></span>
                    <span class="mm-body">
                        <strong style="color:#B91C1C;">@L["Delete Account"]</strong>
                        <small>@L["Permanently delete your account and all data"]</small>
                    </span>
                    <i class="fas fa-chevron-right mm-chevron"></i>
                </a>
