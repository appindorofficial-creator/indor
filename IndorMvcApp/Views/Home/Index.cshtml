            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 12px 0 10px;
        }
        .prop-stats span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #FFFFFF;
            border: 1px solid #E2E8F0;
            color: #334155;
            font-size: 0.82rem;
            font-weight: 600;
            padding: 6px 12px;
            border-radius: 999px;
            box-shadow: 0 2px 6px rgba(10, 37, 64, 0.04);
        }
        .prop-stats i { color: #0066CC; font-size: 0.78rem; }
        .prop-address {
            color: #64748B;
            font-size: 0.88rem;
            line-height: 1.5;
            margin-bottom: 14px;
        }
        .prop-est-bar {
            background: linear-gradient(135deg, #0066CC 0%, #004FA3 100%);
            border-radius: 12px;
            padding: 12px 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            font-size: 0.84rem;
            color: #FFF;
            box-shadow: 0 6px 16px rgba(0, 102, 204, 0.25);
        }
