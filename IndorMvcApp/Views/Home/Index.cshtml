@model IEnumerable<IndorMvcApp.Models.Propiedad>
@using System.Text.Json
@using IndorMvcApp.ViewModels
@{
    ViewData["Title"] = "Home - InDor";
    Layout = null;

    bool IsPrePurchaseInspection(string? name) =>
        string.Equals(name?.Trim(), "Pre-Purchase Home Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsElectricalInspection(string? name) =>
        string.Equals(name?.Trim(), "Electrical Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsCompleteHomeInspection(string? name) =>
        string.Equals(name?.Trim(), "Complete Home Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsPlumbingInspection(string? name) =>
        string.Equals(name?.Trim(), "Plumbing Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsHvacInspection(string? name) =>
        string.Equals(name?.Trim(), "HVAC Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsStructuralInspection(string? name) =>
        string.Equals(name?.Trim(), "Structural Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsRoofInspection(string? name) =>
        string.Equals(name?.Trim(), "Roof Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsMoldMoistureInspection(string? name) =>
        string.Equals(name?.Trim(), "Mold and Moisture Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsWindowsInsulationInspection(string? name) =>
        string.Equals(name?.Trim(), "Windows and Insulation Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsHomeSafetyInspection(string? name) =>
        string.Equals(name?.Trim(), "Home Safety Inspection", StringComparison.OrdinalIgnoreCase);

    bool IsInvestorInspection(string? name) =>
        string.Equals(name?.Trim(), "Investor Inspection", StringComparison.OrdinalIgnoreCase);

    bool HasInspectionFlow(string? name) =>
        IsPrePurchaseInspection(name) || IsElectricalInspection(name)
        || IsCompleteHomeInspection(name) || IsPlumbingInspection(name)
        || IsHvacInspection(name) || IsStructuralInspection(name) || IsRoofInspection(name)
        || IsMoldMoistureInspection(name) || IsWindowsInsulationInspection(name)
        || IsHomeSafetyInspection(name) || IsInvestorInspection(name);

    string GetInspectionFlowAction(string? name) =>
        IsPrePurchaseInspection(name) ? "PurchaseDetails"
        : IsElectricalInspection(name) ? "ElectricalDetails"
        : IsCompleteHomeInspection(name) ? "HomeReviewDetails"
        : IsPlumbingInspection(name) ? "PlumbingDetails"
        : IsHvacInspection(name) ? "HvacDetails"
        : IsStructuralInspection(name) ? "StructuralDetails"
        : IsRoofInspection(name) ? "RoofDetails"
        : IsMoldMoistureInspection(name) ? "MoldMoistureDetails"
        : IsWindowsInsulationInspection(name) ? "WindowsInsulationDetails"
        : IsHomeSafetyInspection(name) ? "HomeSafetyDetails"
        : IsInvestorInspection(name) ? "InvestorDetails"
        : "PurchaseDetails";

    string Money(decimal? v) => v.HasValue ? string.Format(System.Globalization.CultureInfo.GetCultureInfo("en-US"), "{0:C0}", v.Value) : "—";
    string Num(decimal? v) => v.HasValue ? v.Value.ToString("0.##") : "—";
    string Date(DateTime? d) => d.HasValue ? d.Value.ToString("dd/MM/yyyy") : "—";
    string PricePerSqft(decimal? value, int? sqft)
    {
        if (!value.HasValue || !sqft.HasValue || sqft.Value <= 0) return "—";
        return string.Format(System.Globalization.CultureInfo.GetCultureInfo("en-US"), "${0:N0}/sqft", value.Value / sqft.Value);
    }
    string[] SplitIncludes(string? incluye) => string.IsNullOrWhiteSpace(incluye)
        ? Array.Empty<string>()
        : incluye.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    string BedsLabel(int? beds) => beds.HasValue ? $"{beds} bed{(beds.Value == 1 ? "" : "s")}" : "";
    string BathsLabel(decimal? baths) => baths.HasValue ? $"{Num(baths)} bath{(baths.Value == 1 ? "" : "s")}" : "";

    bool IsSafeAirMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 1 || string.Equals(s.Nombre, "Safe Air 365", StringComparison.OrdinalIgnoreCase);

    bool IsLawnMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 2 || string.Equals(s.Nombre, "Always Perfect Lawn", StringComparison.OrdinalIgnoreCase);

    bool IsTrashMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 3 || string.Equals(s.Nombre, "Stress-Free Trash", StringComparison.OrdinalIgnoreCase);

    bool IsCleaningProMicroservice(IndorMvcApp.Models.Microservicio s) =>
        s.Id == 4 || string.Equals(s.Nombre, "Cleaning Pro", StringComparison.OrdinalIgnoreCase);

    string GetMicroserviceLinkController(IndorMvcApp.Models.Microservicio s) =>
        IsSafeAirMicroservice(s) ? "SafeAir"
        : IsLawnMicroservice(s) ? "Lawn"
        : IsTrashMicroservice(s) ? "Trash"
        : IsCleaningProMicroservice(s) ? "CleaningPro"
        : "Microservicios";

    string GetMicroserviceLinkAction(IndorMvcApp.Models.Microservicio s) =>
        IsSafeAirMicroservice(s) ? "SafeAirService"
        : IsLawnMicroservice(s) ? "LawnService"
        : IsTrashMicroservice(s) ? "TrashService"
        : IsCleaningProMicroservice(s) ? "CleaningProService"
        : "Schedule";

    bool HasDedicatedMicroserviceFlow(IndorMvcApp.Models.Microservicio s) =>
        IsSafeAirMicroservice(s) || IsLawnMicroservice(s) || IsTrashMicroservice(s) || IsCleaningProMicroservice(s);

    OfferingCarouselViewModel BuildMicroCarousel(IEnumerable<IndorMvcApp.Models.Microservicio> items, string subtitle)
    {
        return new OfferingCarouselViewModel
        {
            Title = "Home Care Essentials",
            Subtitle = subtitle,
            Icon = "fa-layer-group",
            Items = items.Select(s => new OfferingCardViewModel
            {
                Name = s.Nombre,
                Subtitle = s.Subtitulo,
                Description = s.Descripcion,
                Includes = SplitIncludes(s.Incluye),
                Frequency = s.Frecuencia,
                Price = s.Valor,
                PricePrefix = s.PrecioPrefijo,
                Currency = s.Moneda,
                Cta = string.IsNullOrWhiteSpace(s.CtaTexto) ? "Schedule service" : s.CtaTexto,
                ImageUrl = s.ImagenUrl,
                ImageBase64 = s.ImagenBase64,
                SourceId = s.Id,
                EnableSchedule = !HasDedicatedMicroserviceFlow(s),
                EnableLink = true,
                LinkController = GetMicroserviceLinkController(s),
                LinkAction = GetMicroserviceLinkAction(s)
            }).ToList()
        };
    }

    OfferingCarouselViewModel BuildServicioCarousel(IEnumerable<IndorMvcApp.Models.Servicio> items, string subtitle)
    {
        return new OfferingCarouselViewModel
        {
            Title = "Services",
            Subtitle = subtitle,
            Icon = "fa-screwdriver-wrench",
            BlockClass = "category-block-services",
            IconClass = "category-icon-alt",
            BadgeClass = "category-badge-alt",
            Items = items.Select(sv => new OfferingCardViewModel
            {
                Name = sv.Nombre,
                Subtitle = sv.Subtitulo,
                Description = sv.Descripcion,
                Includes = SplitIncludes(sv.Incluye),
                Frequency = sv.Frecuencia,
                Price = sv.Valor,
                PricePrefix = sv.PrecioPrefijo,
                PriceText = sv.PrecioTexto,
                Currency = sv.Moneda,
                Cta = string.IsNullOrWhiteSpace(sv.CtaTexto) ? "Request quote" : sv.CtaTexto,
                ImageUrl = sv.ImagenUrl,
                FreqIcon = "fa-clock",
                CtaIcon = "fa-paper-plane"
            }).ToList()
        };
    }

    OfferingCarouselViewModel BuildInspeccionCarousel(IEnumerable<IndorMvcApp.Models.Inspeccion> items, string subtitle)
    {
        return new OfferingCarouselViewModel
        {
            Title = "Inspections",
            Subtitle = subtitle,
            Icon = "fa-magnifying-glass-chart",
            BlockClass = "category-block-inspections",
            IconClass = "category-icon-insp",
            BadgeClass = "category-badge-insp",
            Items = items.Select(ins => new OfferingCardViewModel
            {
                Name = ins.Nombre,
                Subtitle = ins.Subtitulo,
                Description = ins.Descripcion,
                Includes = SplitIncludes(ins.Incluye),
                Frequency = ins.Frecuencia,
                Price = ins.Valor,
                PricePrefix = ins.PrecioPrefijo,
                PriceText = ins.PrecioTexto,
                Currency = ins.Moneda,
                Cta = HasInspectionFlow(ins.Nombre)
                    ? "Continue"
                    : (string.IsNullOrWhiteSpace(ins.CtaTexto) ? "Schedule inspection" : ins.CtaTexto),
                ImageUrl = ins.ImagenUrl,
                FreqIcon = "fa-clipboard-check",
                CtaIcon = HasInspectionFlow(ins.Nombre)
                    ? "fa-arrow-right"
                    : "fa-calendar-check",
                SourceId = ins.Id,
                EnableLink = HasInspectionFlow(ins.Nombre),
                LinkController = "Inspecciones",
                LinkAction = GetInspectionFlowAction(ins.Nombre)
            }).ToList()
        };
    }

    EmergencyServicesSectionViewModel BuildEmergencySection(IEnumerable<IndorMvcApp.Models.ServicioEmergencia> items)
    {
        var cards = items.Select(s =>
        {
            var texts = SplitIncludes(s.Caracteristicas);
            var icons = SplitIncludes(s.IconosCaracteristicas);
            var features = new List<EmergencyServiceFeatureViewModel>();
            for (var i = 0; i < texts.Length; i++)
            {
                features.Add(new EmergencyServiceFeatureViewModel
                {
                    Icon = i < icons.Length && !string.IsNullOrWhiteSpace(icons[i]) ? icons[i] : "fa-clock",
                    Text = texts[i]
                });
            }

            return new EmergencyServiceCardViewModel
            {
                Id = s.Id,
                Nombre = s.Nombre,
                TituloEmergencia = s.TituloEmergencia,
                Descripcion = s.Descripcion,
                TiempoLlegadaMinutos = s.TiempoLlegadaMinutos,
                IconoClase = s.IconoClase,
                ImagenUrl = s.ImagenUrl,
                BadgeTexto = s.BadgeTexto,
                CtaTexto = string.IsNullOrWhiteSpace(s.CtaTexto) ? "Request help" : s.CtaTexto,
                Caracteristicas = features
            };
        }).ToList();

        var defaultItem = items.FirstOrDefault(s => s.EsPredeterminado) ?? items.FirstOrDefault();
        return new EmergencyServicesSectionViewModel
        {
            Items = cards,
            SelectedId = defaultItem?.Id ?? cards.FirstOrDefault()?.Id ?? 0
        };
    }

    // === Construir slides agrupados desde PropertyInfoViewModel ===
    List<(string Title, string Icon, List<(string Label, string Value)> Items)> BuildGroupsFor(PropertyInfoViewModel info)
    {
        var groups = new List<(string Title, string Icon, List<(string Label, string Value)> Items)>();

        // 1. Dirección
        var dir = new List<(string, string)>();
        if (!string.IsNullOrWhiteSpace(info.FormattedAddress)) dir.Add(("Full address", info.FormattedAddress));
        if (!string.IsNullOrWhiteSpace(info.HouseNumber)) dir.Add(("House number", info.HouseNumber!));
        if (!string.IsNullOrWhiteSpace(info.Street)) dir.Add(("Street", info.Street!));
        if (!string.IsNullOrWhiteSpace(info.City)) dir.Add(("City", info.City!));
        if (!string.IsNullOrWhiteSpace(info.County)) dir.Add(("County", info.County!));
        if (!string.IsNullOrWhiteSpace(info.State)) dir.Add(("State", info.State!));
        if (!string.IsNullOrWhiteSpace(info.PostalCode)) dir.Add(("Postal code", info.PostalCode!));
        if (!string.IsNullOrWhiteSpace(info.Country)) dir.Add(("Country", info.Country!));
        if (dir.Count > 0) groups.Add(("Address", "fa-map-marker-alt", dir));

        // 2. Coordenadas
        var coords = new List<(string, string)>
        {
            ("Latitude", info.Latitude.ToString("0.######")),
            ("Longitude", info.Longitude.ToString("0.######"))
        };
        if (info.BoundingBox != null)
        {
            coords.Add(("Area (lat min/max)", $"{info.BoundingBox.MinLat:0.####} / {info.BoundingBox.MaxLat:0.####}"));
            coords.Add(("Area (lon min/max)", $"{info.BoundingBox.MinLon:0.####} / {info.BoundingBox.MaxLon:0.####}"));
        }
        groups.Add(("Coordinates", "fa-location-crosshairs", coords));

        // 3. Detalles de la propiedad
        if (info.PropertyDetails != null)
        {
            var d = info.PropertyDetails;
            var det = new List<(string, string)>();
            if (!string.IsNullOrWhiteSpace(d.PropertyType)) det.Add(("Property type", d.PropertyType));
            if (d.YearBuilt.HasValue) det.Add(("Year built", d.YearBuilt.Value.ToString()));
            if (d.YearRenovated.HasValue) det.Add(("Year renovated", d.YearRenovated.Value.ToString()));
            if (d.LivingArea.HasValue) det.Add(("Living area", $"{d.LivingArea} sq ft"));
            if (d.LotSize.HasValue) det.Add(("Lot size", $"{d.LotSize} acres"));
            if (d.Bedrooms.HasValue) det.Add(("Bedrooms", d.Bedrooms.Value.ToString()));
            if (d.Bathrooms.HasValue) det.Add(("Bathrooms", Num(d.Bathrooms)));
            if (d.Floors.HasValue) det.Add(("Floors", d.Floors.Value.ToString()));
            if (!string.IsNullOrWhiteSpace(d.ArchitecturalStyle)) det.Add(("Style", d.ArchitecturalStyle));
            if (d.Features != null && d.Features.Count > 0) det.Add(("Features", string.Join(", ", d.Features)));
            if (det.Count > 0) groups.Add(("Property details", "fa-house", det));

            // 4. Valor e impuestos
            var val = new List<(string, string)>();
            if (d.EstimatedValue.HasValue) val.Add(($"Valor estimado ({d.EstimatedValueYear})", Money(d.EstimatedValue)));
            if (d.LastSalePrice.HasValue) val.Add(("Last sale price", Money(d.LastSalePrice)));
            if (d.LastSaleDate.HasValue) val.Add(("Last sale date", Date(d.LastSaleDate)));
            if (d.AnnualTaxAmount.HasValue) val.Add(($"Impuestos anuales ({d.TaxYear})", Money(d.AnnualTaxAmount)));
            if (!string.IsNullOrWhiteSpace(d.ParcelNumber)) val.Add(("Parcel number", d.ParcelNumber!));
            if (!string.IsNullOrWhiteSpace(d.Zoning)) val.Add(("Zoning", d.Zoning!));
            if (val.Count > 0) groups.Add(("Value and taxes", "fa-dollar-sign", val));
        }

        return groups;
    }

    // === Servicios públicos como tarjetas ricas ===
    List<UtilityCard> BuildUtilities(UtilityProvidersInfo? u)
    {
        var list = new List<UtilityCard>();
        if (u == null) return list;
        void Add(UtilityProvider? p, string icon)
        {
            if (p == null || string.IsNullOrWhiteSpace(p.Name)) return;
            list.Add(new UtilityCard { Icon = icon, Provider = p });
        }
        Add(u.Electric, "fa-bolt");
        Add(u.Water, "fa-droplet");
        Add(u.Sewer, "fa-water");
        Add(u.Gas, "fa-fire-flame-curved");
        if (u.Internet != null) foreach (var p in u.Internet) Add(p, "fa-wifi");
        if (u.CableTV != null) foreach (var p in u.CableTV) Add(p, "fa-tv");
        return list;
    }

    // === Garantías / seguros como tarjetas ricas ===
    List<WarrantyCard> BuildWarranties(HomeWarrantiesInfo? w)
    {
        var list = new List<WarrantyCard>();
        if (w == null) return list;
        void Add(HomeWarranty? hw, string icon)
        {
            if (hw == null || string.IsNullOrWhiteSpace(hw.SystemName)) return;
            list.Add(new WarrantyCard { Icon = icon, Warranty = hw });
        }
        Add(w.HomeWarrantyPolicy, "fa-shield-halved");
        Add(w.HVACSystem, "fa-temperature-half");
        Add(w.WaterHeater, "fa-fire");
        Add(w.Roof, "fa-house-chimney");
        Add(w.Appliances, "fa-blender");
        Add(w.Plumbing, "fa-faucet");
        Add(w.Electrical, "fa-plug");
        return list;
    }

    var jsonOpts = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

    // Cada slide tiene un Kind: "group" | "utilities" | "warranties"
    var propertiesGrouped = new List<(
        IndorMvcApp.Models.Propiedad Prop,
        List<SlideEntry> Slides)>();

    foreach (var p in Model)
    {
        PropertyInfoViewModel? info = null;
        if (!string.IsNullOrWhiteSpace(p.DatosJson))
        {
            try { info = JsonSerializer.Deserialize<PropertyInfoViewModel>(p.DatosJson, jsonOpts); }
            catch { info = null; }
        }

        var slides = new List<SlideEntry>();

        if (info != null)
        {
            // Slides agrupados de información básica
            foreach (var g in BuildGroupsFor(info))
            {
                slides.Add(new SlideEntry
                {
                    Kind = "group",
                    Title = g.Title,
                    Icon = g.Icon,
                    Items = g.Items
                });
            }

            // Slide de servicios públicos (asociados a esta dirección)
            var utils = BuildUtilities(info.UtilityProviders);
            if (utils.Count > 0)
            {
                slides.Add(new SlideEntry
                {
                    Kind = "utilities",
                    Title = "Utilities",
                    Icon = "fa-plug-circle-bolt",
                    Utilities = utils
                });
            }

            // Slide de seguros / garantías (asociados a esta dirección)
            var warrs = BuildWarranties(info.HomeWarranties);
            if (warrs.Count > 0)
            {
                slides.Add(new SlideEntry
                {
                    Kind = "warranties",
                    Title = "Insurance and warranties",
                    Icon = "fa-shield-halved",
                    Warranties = warrs
                });
            }
        }
        else
        {
            // Compatibilidad con propiedades viejas
            slides.Add(new SlideEntry
            {
                Kind = "group",
                Title = "Address",
                Icon = "fa-map-marker-alt",
                Items = new List<(string, string)> { ("Address", p.Direccion ?? "—") }
            });
        }

        propertiesGrouped.Add((p, slides));
    }
    var hasProperties = propertiesGrouped.Count > 0;

    // === Información básica de la propiedad principal (la más reciente) ===
    PropertyInfoViewModel? primaryInfo = null;
    IndorMvcApp.Models.Propiedad? primaryProp = null;
    if (hasProperties)
    {
        primaryProp = propertiesGrouped[0].Prop;
        if (!string.IsNullOrWhiteSpace(primaryProp.DatosJson))
        {
            try { primaryInfo = JsonSerializer.Deserialize<PropertyInfoViewModel>(primaryProp.DatosJson, jsonOpts); }
            catch { primaryInfo = null; }
        }
    }

    // === Notificaciones derivadas de las garantías guardadas ===
    var notificaciones = new List<NotificationItem>();
    foreach (var entry in propertiesGrouped)
    {
        var p = entry.Prop;
        PropertyInfoViewModel? infoP = null;
        if (!string.IsNullOrWhiteSpace(p.DatosJson))
        {
            try { infoP = JsonSerializer.Deserialize<PropertyInfoViewModel>(p.DatosJson, jsonOpts); }
            catch { infoP = null; }
        }
        if (infoP?.HomeWarranties == null) continue;

        void EvalWarranty(HomeWarranty? w, string defaultIcon)
        {
            if (w == null || string.IsNullOrWhiteSpace(w.SystemName)) return;
            if (!w.CoverageEndDate.HasValue) return;
            var end = w.CoverageEndDate.Value.Date;
            var today = DateTime.Today;
            var days = (end - today).Days;
            string severity;
            string icon = defaultIcon;
            string title;
            if (days < 0)
            {
                severity = "expired";
                title = $"{w.SystemName} expired";
            }
            else if (days <= 30)
            {
                severity = "soon";
                title = $"{w.SystemName} expires in {days} day{(days == 1 ? "" : "s")}";
            }
            else if (days <= 90)
            {
                severity = "upcoming";
                title = $"{w.SystemName} expires in {days} days";
            }
            else
            {
                return;
            }
            notificaciones.Add(new NotificationItem
            {
                Icon = icon,
                Severity = severity,
                Title = title,
                Subtitle = $"{(string.IsNullOrWhiteSpace(w.WarrantyProvider) ? "Warranty" : w.WarrantyProvider)} · {p.Direccion}",
                Date = end,
                DaysRemaining = days
            });
        }

        var hw = infoP.HomeWarranties;
        EvalWarranty(hw.HomeWarrantyPolicy, "fa-shield-halved");
        EvalWarranty(hw.HVACSystem, "fa-temperature-half");
        EvalWarranty(hw.WaterHeater, "fa-fire");
        EvalWarranty(hw.Roof, "fa-house-chimney");
        EvalWarranty(hw.Appliances, "fa-blender");
        EvalWarranty(hw.Plumbing, "fa-faucet");
        EvalWarranty(hw.Electrical, "fa-plug");
    }

    var programacionesMs = ViewBag.ProgramacionesMicroservicio as List<IndorMvcApp.Models.ProgramacionMicroservicio>
                             ?? new List<IndorMvcApp.Models.ProgramacionMicroservicio>();
    foreach (var prog in programacionesMs)
    {
        var scheduled = prog.FechaProgramada.Date;
        var days = (scheduled - DateTime.Today).Days;
        var serviceName = prog.Microservicio?.Nombre ?? "Microservice";
        string severity;
        string title;
        if (days < 0)
        {
            severity = "expired";
            title = $"{serviceName} overdue by {Math.Abs(days)} day{(Math.Abs(days) == 1 ? "" : "s")}";
        }
        else if (days == 0)
        {
            severity = "soon";
            title = $"{serviceName} due today";
        }
        else if (days <= 30)
        {
            severity = "soon";
            title = $"{serviceName} due in {days} day{(days == 1 ? "" : "s")}";
        }
        else if (days <= 90)
        {
            severity = "upcoming";
            title = $"{serviceName} scheduled in {days} days";
        }
        else
        {
            continue;
        }

        notificaciones.Add(new NotificationItem
        {
            Icon = "fa-calendar-check",
            Severity = severity,
            Title = title,
            Subtitle = string.IsNullOrWhiteSpace(prog.Propiedad?.Direccion)
                ? "Home maintenance reminder"
                : prog.Propiedad!.Direccion!,
            Date = scheduled,
            DaysRemaining = days
        });
    }

    notificaciones = notificaciones.OrderBy(n => n.DaysRemaining).ToList();
}

@functions {
    public class UtilityCard
    {
        public string Icon { get; set; } = "";
        public UtilityProvider Provider { get; set; } = new();
    }
    public class WarrantyCard
    {
        public string Icon { get; set; } = "";
        public HomeWarranty Warranty { get; set; } = new();
    }
    public class SlideEntry
    {
        public string Kind { get; set; } = "group";
        public string Title { get; set; } = "";
        public string Icon { get; set; } = "fa-circle-info";
        public List<(string Label, string Value)> Items { get; set; } = new();
        public List<UtilityCard> Utilities { get; set; } = new();
        public List<WarrantyCard> Warranties { get; set; } = new();
    }
    public class NotificationItem
    {
        public string Icon { get; set; } = "fa-bell";
        public string Severity { get; set; } = "upcoming"; // expired | soon | upcoming
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public DateTime Date { get; set; }
        public int DaysRemaining { get; set; }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-dashboard.css" asp-append-version="true" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #FFFFFF;
            color: #0A2540;
            min-height: 100vh;
            padding-bottom: 90px; /* espacio para el bottom nav */
        }

        /* === Top bar === */
        .top-bar {
            background: #FFFFFF;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            position: sticky;
            top: 0;
            z-index: 50;
            box-shadow: 0 2px 8px rgba(10, 37, 64, 0.05);
        }

        .hd-brand {
            flex-shrink: 0;
            text-decoration: none;
            font-size: 1.125rem;
            font-weight: 800;
            letter-spacing: -0.04em;
            color: #0A2540;
            display: flex;
            align-items: center;
            gap: 1px;
        }

        .hd-brand-house {
            width: 1.1rem;
            height: 1.1rem;
            color: #1867F2;
        }

        .search-bar {
            flex: 1;
            background: #F3F4F6;
            border-radius: 999px;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            color: #6B7280;
            font-size: 0.9rem;
        }

        .bell {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: #F3F4F6;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0A2540;
            flex-shrink: 0;
        }

        /* === Sections === */
        .section { display: none; padding: 16px; max-width: 480px; margin: 0 auto; }
        .section.active { display: block; }

        .section-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .section-title a { font-size: 0.8rem; color: #0066CC; text-decoration: none; font-weight: 600; }

        /* Cards de la pantalla Home */
        .info-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }

        .info-card {
            background: #FFF;
            border-radius: 14px;
            padding: 14px;
            box-shadow: 0 4px 12px rgba(10, 37, 64, 0.05);
        }
        .info-card .label { font-size: 0.72rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
        .info-card .value { font-size: 1rem; font-weight: 700; color: #0A2540; line-height: 1.2; margin-bottom: 6px; }
        .info-card .sub { font-size: 0.72rem; color: #6B7280; margin-bottom: 10px; }
        .info-card .pill { display: inline-block; font-size: 0.72rem; font-weight: 600; padding: 4px 10px; border-radius: 999px; }
        .pill-green { background: #DCFCE7; color: #15803D; }
        .pill-blue { background: #DBEAFE; color: #004FA3; }
        .pill-yellow { background: #FEF3C7; color: #B45309; }

        .service-card {
            background: #FFF;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 4px 12px rgba(10, 37, 64, 0.05);
        }
        .service-card .img { height: 110px; background: linear-gradient(135deg, #0066CC, #004FA3); display: flex; align-items: center; justify-content: center; color: #FFF; font-size: 2.4rem; }
        .service-card .body { padding: 12px; }
        .service-card .title { font-weight: 700; font-size: 0.95rem; margin-bottom: 4px; }
        .service-card .desc { font-size: 0.75rem; color: #6B7280; margin-bottom: 10px; }
        .btn-book { width: 100%; background: #0066CC; color: #FFF; border: none; padding: 8px; border-radius: 10px; font-weight: 600; font-size: 0.85rem; cursor: pointer; }

        .verified {
            background: #FFF;
            border-radius: 14px;
            padding: 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 4px 12px rgba(10, 37, 64, 0.05);
            margin-top: 16px;
        }
        .verified .icon { width: 40px; height: 40px; border-radius: 12px; background: #DBEAFE; color: #0066CC; display: flex; align-items: center; justify-content: center; }
        .verified .text strong { display: block; font-size: 0.9rem; }
        .verified .text small { color: #6B7280; font-size: 0.75rem; }

        /* === MyHome (slider con datos del JSON) === */
        #section-myhome .hf-app { margin-bottom: 8px; }
        #section-myhome .hf-json-panel-app { margin-bottom: 80px; }
        .hf-quick-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .hf-quick-link { background: #FFF; border: 1px solid #E5E7EB; border-radius: 12px; padding: 12px; text-decoration: none; color: #0A2540; font-weight: 700; font-size: 0.82rem; display: flex; align-items: center; gap: 8px; }
        .hf-quick-link i { color: #0066CC; }
        .property-selector {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 8px;
            margin-bottom: 12px;
        }
        .property-tab {
            flex: 0 0 auto;
            background: #FFF;
            border: 1.5px solid #E5E7EB;
            color: #0A2540;
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
        }
        .property-tab.active { background: #0A2540; color: #FFF; border-color: #0A2540; }

        .results-card {
            background: #FFFFFF;
            border-radius: 18px;
            padding: 18px 14px;
            box-shadow: 0 8px 24px rgba(10, 37, 64, 0.08);
        }
        .results-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .results-title { font-size: 0.95rem; font-weight: 700; color: #0A2540; }
        .slide-counter { font-size: 0.75rem; font-weight: 600; color: #0066CC; background: rgba(0,102,204,0.1); padding: 4px 10px; border-radius: 999px; }

        .slider-viewport { overflow: hidden; border-radius: 14px; background: #F9FAFB; }
        .slider-track { display: flex; transition: transform .45s cubic-bezier(.4,0,.2,1); will-change: transform; }
        .result-card { flex: 0 0 100%; min-width: 100%; padding: 22px 18px; display: flex; flex-direction: column; min-height: 240px; max-height: 60vh; overflow-y: auto; }
        .group-header { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
        .field-icon { width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, rgba(0,102,204,.12), rgba(0,79,163,.12)); color: #0066CC; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; }
        .group-title { font-size: 1.05rem; font-weight: 700; color: #0A2540; }
        .group-list { display: flex; flex-direction: column; gap: 10px; }
        .group-item { display: flex; flex-direction: column; padding: 10px 12px; background: #FFFFFF; border-radius: 10px; border: 1px solid #EEF2F7; }
        .group-item .k { font-size: 0.72rem; color: #6B7280; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 2px; font-weight: 600; }
        .group-item .v { font-size: 0.95rem; color: #0A2540; font-weight: 600; word-break: break-word; }

        .slider-controls { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-top: 14px; }
        .nav-button { width: 40px; height: 40px; border-radius: 50%; border: 1.5px solid #E5E7EB; background: #FFF; color: #0A2540; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: .25s; }
        .nav-button:hover:not(:disabled) { border-color: #0066CC; color: #0066CC; }
        .nav-button:disabled { opacity: .4; cursor: not-allowed; }
        .dots-container { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; max-width: 220px; }
        .dot { width: 7px; height: 7px; border-radius: 50%; background: #E5E7EB; cursor: pointer; transition: .3s; }
        .dot.active { background: #0066CC; width: 20px; border-radius: 4px; }

        .empty-state { background: #FFF; border-radius: 14px; padding: 40px 20px; text-align: center; box-shadow: 0 4px 12px rgba(10, 37, 64, 0.05); }
        .empty-state i { font-size: 2.5rem; color: #9CA3AF; margin-bottom: 12px; }
        .empty-state p { color: #6B7280; margin-bottom: 14px; }
        .btn-primary-link {
            display: inline-flex; align-items: center; gap: 8px;
            background: linear-gradient(135deg, #0066CC, #004FA3);
            color: #FFF; text-decoration: none;
            padding: 10px 18px; border-radius: 12px; font-weight: 600; font-size: 0.9rem;
        }

        /* === Bottom navigation === */
        .bottom-nav {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            background: #FFFFFF;
            display: flex;
            justify-content: space-around;
            padding: 10px 6px calc(env(safe-area-inset-bottom, 0) + 10px);
            box-shadow: 0 -4px 16px rgba(10, 37, 64, 0.08);
            z-index: 100;
        }
        .nav-item {
            flex: 1;
            border: none;
            background: transparent;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 6px 2px;
            color: #9CA3AF;
            cursor: pointer;
            font-size: 0.7rem;
            font-weight: 500;
            transition: color .2s;
        }
        .nav-item i { font-size: 1.2rem; }
        .nav-item.active { color: #1867F2; }
        .nav-item.active i { transform: none; }
        .nav-item.active::after {
            content: '';
            display: block;
            width: 22px;
            height: 3px;
            margin-top: 4px;
            border-radius: 999px;
            background: #1867F2;
        }

        @@media (max-width: 480px) {
            .field-value { font-size: 1.2rem; }
        }

        /* === Servicios públicos === */
        .extra-title { font-size: 1rem; font-weight: 700; color: #0A2540; margin: 18px 0 10px; display: flex; align-items: center; gap: 8px; }
        .extra-title i { color: #0066CC; }

        .utility-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
        .utility-card { background: #FFF; border-radius: 14px; padding: 14px; box-shadow: 0 4px 12px rgba(10,37,64,.05); border: 1px solid #EEF2F7; }
        .utility-head { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
        .util-icon { width: 40px; height: 40px; border-radius: 10px; background: linear-gradient(135deg, rgba(0,102,204,.15), rgba(0,79,163,.15)); color: #0066CC; display: flex; align-items: center; justify-content: center; font-size: 1.05rem; flex-shrink: 0; }
        .utility-name { font-weight: 700; font-size: 0.95rem; color: #0A2540; }
        .utility-type { font-size: 0.75rem; color: #6B7280; }
        .utility-cov { font-size: 0.8rem; color: #6B7280; margin-bottom: 8px; }
        .utility-actions { display: flex; flex-wrap: wrap; gap: 6px; }
        .util-btn { display: inline-flex; align-items: center; gap: 6px; background: #F3F4F6; color: #0A2540; padding: 6px 10px; border-radius: 8px; font-size: 0.78rem; font-weight: 600; text-decoration: none; }
        .util-btn:hover { background: #E5E7EB; }

        /* === Garantías === */
        .warranty-list { display: flex; flex-direction: column; gap: 12px; }
        .warranty-card { background: #FFF; border-radius: 14px; padding: 14px; box-shadow: 0 4px 12px rgba(10,37,64,.05); border: 1px solid #EEF2F7; }
        .warranty-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .warranty-titles { flex: 1; min-width: 0; }
        .warranty-name { font-weight: 700; font-size: 0.95rem; color: #0A2540; }
        .warranty-prov { font-size: 0.75rem; color: #6B7280; }
        .pill-red { background: #FEE2E2; color: #B91C1C; }
        .warranty-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 10px; }
        .wg-item { background: #F9FAFB; border-radius: 8px; padding: 8px 10px; display: flex; flex-direction: column; }
        .wg-item .k { font-size: 0.65rem; color: #6B7280; text-transform: uppercase; letter-spacing: .4px; font-weight: 600; }
        .wg-item .v { font-size: 0.82rem; color: #0A2540; font-weight: 600; word-break: break-word; }
        .warranty-extra { font-size: 0.78rem; color: #4B5563; margin-bottom: 8px; line-height: 1.4; }
        .warranty-extra strong { color: #0A2540; }

        /* === Servicios (Microservicios desde DB) === */
        .services-count {
            background: #0066CC; color: #FFF; font-size: 0.72rem; font-weight: 700;
            padding: 3px 10px; border-radius: 999px;
        }

        .services-hero {
            background: linear-gradient(135deg, #EFF6FF 0%, #FFFFFF 100%);
            color: #0A2540;
            border: 1px solid #DBEAFE;
            border-radius: 18px;
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: 0 8px 24px rgba(0, 102, 204, 0.08);
        }
        .services-hero-text { flex: 1; display: flex; flex-direction: column; gap: 2px; }
        .services-hero-text strong { font-size: 1rem; font-weight: 700; color: #0A2540; }
        .services-hero-text small { font-size: 0.78rem; color: #64748B; }
        .services-hero-icon {
            width: 46px; height: 46px; border-radius: 12px;
            background: linear-gradient(135deg, #0066CC, #004FA3);
            color: #FFF;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; flex-shrink: 0;
            box-shadow: 0 6px 14px rgba(0, 102, 204, 0.25);
        }

        /* === Carrusel horizontal (tarjetas compactas deslizables) === */
        .offering-grid,
        .emergency-grid,
        .moving-setup-grid {
            --scroll-gap: 10px;
            --scroll-visible: 4;
            display: flex;
            gap: var(--scroll-gap);
            overflow-x: auto;
            overflow-y: hidden;
            scroll-snap-type: x proximity;
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            overscroll-behavior-x: contain;
            touch-action: pan-x;
            margin: 0 -14px;
            padding: 0 14px 4px;
        }
        .offering-grid::-webkit-scrollbar,
        .emergency-grid::-webkit-scrollbar,
        .moving-setup-grid::-webkit-scrollbar {
            display: none;
        }
        .offering-card,
        .emergency-card,
        .moving-setup-grid-item {
            flex: 0 0 calc((100% - (var(--scroll-visible) - 1) * var(--scroll-gap)) / var(--scroll-visible));
            min-width: 72px;
            scroll-snap-align: start;
        }

        /* === Tarjetas compactas (Microservicios / Servicios / Inspecciones) === */
        .offering-card {
            border: 1px solid #E5E7EB;
            background: #FFF;
            border-radius: 14px;
            padding: 0;
            cursor: pointer;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: 6px;
            box-shadow: 0 2px 8px rgba(10, 37, 64, .06);
            transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease;
            text-decoration: none;
            color: inherit;
            font: inherit;
        }
        .offering-card:hover {
            border-color: #BFDBFE;
            box-shadow: 0 4px 12px rgba(0, 102, 204, .12);
            transform: translateY(-1px);
        }
        .offering-card-media {
            position: relative;
            height: 72px;
            border-radius: 12px 12px 0 0;
            overflow: hidden;
            background: linear-gradient(135deg, #E8F1FB 0%, #D6E8F9 100%);
        }
        .offering-card-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .offering-card-fallback {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0066CC;
            font-size: 1.4rem;
        }
        .offering-card-label {
            font-size: 0.72rem;
            font-weight: 700;
            color: #0A2540;
            line-height: 1.2;
            padding: 0 4px 8px;
        }

        /* === Contenedor de categoría (Microservicios) === */
        .category-block {
            background: #FFFFFF;
            border: 1px solid #E5E7EB;
            border-radius: 20px;
            padding: 16px 14px 18px;
            box-shadow: 0 6px 20px rgba(10, 37, 64, .06);
            position: relative;
        }
        .category-header {
            display: flex; align-items: center; gap: 12px;
            padding-bottom: 14px; margin-bottom: 14px;
            border-bottom: 1px dashed #E5E7EB;
        }
        .category-icon {
            width: 42px; height: 42px; border-radius: 12px;
            background: linear-gradient(135deg, #0066CC, #004FA3);
            color: #FFF; display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0;
            box-shadow: 0 6px 14px rgba(0, 102, 204, .25);
        }
        .category-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
        .category-title {
            font-size: 1rem; font-weight: 800; color: #0A2540;
            letter-spacing: .2px; margin: 0;
        }
        .category-sub { font-size: 0.72rem; color: #6B7280; }
        .category-badge {
            background: #ECFDF5; color: #15803D;
            font-size: 0.72rem; font-weight: 700;
            padding: 4px 10px; border-radius: 999px;
            border: 1px solid #A7F3D0;
        }

        /* Variante para la categoría "Servicios" */
        .category-block-services { margin-top: 18px; }
        .category-icon-alt {
            background: linear-gradient(135deg, #0066CC, #004FA3) !important;
            box-shadow: 0 6px 14px rgba(219, 39, 119, .25) !important;
        }
        .category-badge-alt {
            background: #FFF7ED; color: #C2410C; border-color: #FED7AA;
        }
        /* Variante para la categoría "Inspecciones" */
        .category-block-inspections { margin-top: 18px; }
        .category-icon-insp {
            background: linear-gradient(135deg, #0066CC, #004FA3) !important;
            box-shadow: 0 6px 14px rgba(29, 78, 216, .25) !important;
        }
        .category-badge-insp {
            background: #EFF6FF; color: #004FA3; border-color: #BFDBFE;
        }

        /* === Home Care Guide === */
        .category-block-priorities { margin-top: 18px; }
        .category-icon-priorities {
            background: linear-gradient(135deg, #0066CC, #004FA3) !important;
            box-shadow: 0 6px 14px rgba(0, 102, 204, .25) !important;
        }
        .priorities-view-all {
            border: none;
            background: transparent;
            color: #0066CC;
            font-size: 0.72rem;
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            padding: 0;
        }
        .home-care-card-sub {
            font-size: 0.62rem;
            font-weight: 600;
            color: #0066CC;
            line-height: 1.2;
            padding: 0 4px 8px;
            display: block;
            margin-top: -2px;
        }
        .category-block-priorities .offering-card-label {
            padding-bottom: 2px;
        }

        @@media (max-width: 380px) {
            .offering-grid,
            .emergency-grid,
            .moving-setup-grid { --scroll-gap: 8px; }
            .offering-card-media { height: 58px; }
            .offering-card-label { font-size: 0.62rem; }
        }

        /* === Banner Home === */
        .home-banner {
            padding: 16px 16px 0;
            margin-bottom: 0;
            background: #FFF;
        }
        .home-banner img { width: 100%; max-width: 320px; height: auto; display: block; margin: 0 auto; }

        /* === Home & Services — modern light layout === */
        #section-home { padding: 16px; }
        .home-content { display: flex; flex-direction: column; gap: 14px; }

        .prop-hero {
            background: linear-gradient(145deg, #FFFFFF 0%, #F0F7FF 55%, #E8F2FC 100%);
            border: 1px solid #DBEAFE;
            border-radius: 20px;
            padding: 20px 18px;
            box-shadow: 0 10px 32px rgba(0, 102, 204, 0.1);
        }
        .prop-price {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.1;
            color: #0A2540;
        }
