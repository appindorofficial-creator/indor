    <!-- ====== MORE ====== -->
    <section class="section" id="section-more">
        @{
            var usr = (IndorMvcApp.Models.ApplicationUser?)ViewBag.UsuarioActual;
            var membresia = (IndorMvcApp.Models.MembresiaUsuario?)ViewBag.MembresiaActual;
            var planes = (IEnumerable<IndorMvcApp.Models.PlanMembresia>?)ViewBag.Planes ?? Enumerable.Empty<IndorMvcApp.Models.PlanMembresia>();
            var metodosPago = (IEnumerable<IndorMvcApp.Models.MetodoPago>?)ViewBag.MetodosPago ?? Enumerable.Empty<IndorMvcApp.Models.MetodoPago>();
            var pagos = (IEnumerable<IndorMvcApp.Models.Pago>?)ViewBag.Pagos ?? Enumerable.Empty<IndorMvcApp.Models.Pago>();
            var planesInternet = (IEnumerable<IndorMvcApp.Models.PlanInternet>?)ViewBag.PlanesInternet ?? Enumerable.Empty<IndorMvcApp.Models.PlanInternet>();
            var historial = (IEnumerable<IndorMvcApp.Models.HistorialServicio>?)ViewBag.Historial ?? Enumerable.Empty<IndorMvcApp.Models.HistorialServicio>();
            var mensajes = (IEnumerable<IndorMvcApp.Models.MensajeSoporte>?)ViewBag.MensajesSoporte ?? Enumerable.Empty<IndorMvcApp.Models.MensajeSoporte>();

            string PrimerNombre(string? n) => string.IsNullOrWhiteSpace(n) ? "" : n.Split(' ')[0];
            string Inicial(string? s) => string.IsNullOrWhiteSpace(s) ? "U" : s.Substring(0, 1).ToUpper();
            string EstadoBadgeClass(string? estado) => (estado ?? "").ToLower() switch
            {
                "completado" => "badge badge-completado",
                "pendiente" => "badge badge-pendiente",
                "financiado" => "badge badge-financiado",
                "vencido" => "badge badge-vencido",
                _ => "badge badge-default"
            };

            var pagosPendientes = pagos.Where(p => p.Estado == "Pendiente" || p.Estado == "Vencido").ToList();
            var pagosFinanciados = pagos.Where(p => p.Estado == "Financiado").ToList();
            var pagosHistorial = pagos.Where(p => p.Estado == "Completado").ToList();
        }

        @if (TempData["PerfilOk"] != null)
        {
            <div class="alert-ok"><i class="fas fa-check-circle"></i> @TempData["PerfilOk"]</div>
        }
        @if (TempData["PerfilError"] != null)
        {
            <div class="alert-err"><i class="fas fa-exclamation-triangle"></i> @TempData["PerfilError"]</div>
        }

        <!-- 1. Tarjeta del usuario -->
        <div class="more-card">
            <div class="user-card">
                <div class="user-avatar-lg">
                    @if (!string.IsNullOrWhiteSpace(usr?.FotoUrl))
                    {
                        <img src="@Url.Content("~" + usr!.FotoUrl)" alt="Foto de perfil" />
                    }
                    else
                    {
                        <span class="avatar-placeholder"><i class="fas fa-user"></i></span>
                    }
                </div>
                <div class="user-info">
                    @{
                        var fullName = $"{PrimerNombre(usr?.Nombre)} {PrimerNombre(usr?.Apellidos)}".Trim();
                        var hasName = !string.IsNullOrWhiteSpace(fullName);
                        var hasEmail = !string.IsNullOrWhiteSpace(usr?.Email);
                        var hasPhone = !string.IsNullOrWhiteSpace(usr?.Telefono);
                    }
                    <div class="uline @(hasName ? "" : "muted")">
                        <span class="ulabel">@(hasName ? fullName : "Name")</span>
                        <i class="far fa-user uicon"></i>
                    </div>
                    <div class="uline @(hasEmail ? "" : "muted")">
                        <span class="ulabel">@(hasEmail ? usr!.Email : "Email")</span>
                        <i class="far fa-envelope uicon"></i>
                    </div>
                    <div class="uline @(hasPhone ? "" : "muted")">
                        <span class="ulabel">
                            <i class="fas fa-phone-alt lead-icon"></i>
                            @(hasPhone ? usr!.Telefono : "Phone")
                        </span>
                        <i class="fas fa-phone-alt uicon"></i>
                    </div>
                    <div class="uline">
                        <span class="ulabel">
                            @if (membresia?.Plan != null)
                            {
                                <span class="membership-pill"><i class="fas fa-crown"></i> @membresia.Plan.Nombre</span>
                            }
                            else
                            {
                                <span class="membership-pill none">No active membership</span>
                            }
                        </span>
                        <i class="fas fa-shield-alt uicon"></i>
                    </div>
                </div>
            </div>
        </div>

		<!-- 2. MenÃº del perfil (links a vistas separadas) -->
		<div class="more-card">
			<h3><i class="fas fa-bars"></i> My account</h3>
			<nav class="more-menu">
				<a class="more-link" asp-controller="Perfil" asp-action="Opciones">
					<span class="ml-icon"><i class="fas fa-user-gear"></i></span>
					<span class="ml-text">
						<strong>Profile options</strong>
						<small>Edit details, photo, password, and payment methods</small>
					</span>
					<i class="fas fa-chevron-right ml-arrow"></i>
				</a>
				<a class="more-link" asp-controller="Perfil" asp-action="Pagos">
					<span class="ml-icon"><i class="fas fa-money-bill-wave"></i></span>
					<span class="ml-text">
						<strong>Payments</strong>
						<small>Pending, financing, and history</small>
					</span>
					<i class="fas fa-chevron-right ml-arrow"></i>
				</a>
				<a class="more-link" asp-controller="Perfil" asp-action="Suscripciones">
					<span class="ml-icon"><i class="fas fa-crown"></i></span>
					<span class="ml-text">
						<strong>Subscriptions</strong>
						<small>Plans and descriptions</small>
					</span>
					<i class="fas fa-chevron-right ml-arrow"></i>
				</a>
				<a class="more-link" asp-controller="Perfil" asp-action="Historial">
					<span class="ml-icon"><i class="fas fa-clock-rotate-left"></i></span>
					<span class="ml-text">
						<strong>History</strong>
						<small>Microservices, inspections, and services</small>
					</span>
					<i class="fas fa-chevron-right ml-arrow"></i>
				</a>
				<a class="more-link" asp-controller="Perfil" asp-action="Internet">
					<span class="ml-icon"><i class="fas fa-wifi"></i></span>
					<span class="ml-text">
						<strong>Internet comparison</strong>
						<small>Current plan vs market plans</small>
					</span>
					<i class="fas fa-chevron-right ml-arrow"></i>
				</a>
				<a class="more-link" asp-controller="Perfil" asp-action="Soporte">
					<span class="ml-icon"><i class="fas fa-headset"></i></span>
					<span class="ml-text">
						<strong>Support</strong>
						<small>Chat with our team</small>
					</span>
					<i class="fas fa-chevron-right ml-arrow"></i>
				</a>
			</nav>

			<form method="post" asp-controller="Account" asp-action="Logout" style="margin-top:12px;">
				@Html.AntiForgeryToken()
				<button type="submit" class="opt-btn danger" style="width:100%;flex-direction:row;justify-content:center;">
					<i class="fas fa-right-from-bracket"></i> Sign out
				</button>
			</form>
		</div>
	</section>

	<!-- ====== BOTTOM NAV ====== -->
    <nav class="bottom-nav">
        <button class="nav-item active" data-target="section-home"><i class="fas fa-house"></i><span>Home</span></button>
        <button class="nav-item" data-target="section-services"><i class="fas fa-screwdriver-wrench"></i><span>Services</span></button>
        <button class="nav-item" data-target="section-myhome"><i class="fas fa-house-circle-arrow-up"></i><span>House Facts</span></button>
        <button class="nav-item" data-target="section-schedule"><i class="fas fa-clipboard-list"></i><span>Schedule</span></button>
        <button class="nav-item" data-target="section-more"><i class="fas fa-ellipsis"></i><span>More</span></button>
    </nav>

    <script>
        function activateSection(sectionId) {
            if (!sectionId) return;
            const section = document.getElementById(sectionId);
            if (!section) return;
            document.querySelectorAll('.bottom-nav .nav-item').forEach(b => {
                b.classList.toggle('active', b.dataset.target === sectionId);
            });
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            section.classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // === Bottom nav ===
        document.querySelectorAll('.bottom-nav .nav-item').forEach(btn => {
            btn.addEventListener('click', () => {
                activateSection(btn.dataset.target);
            });
        });

        const initialHash = window.location.hash.replace('#', '');
        if (initialHash) {
            activateSection(initialHash);
        }

        // === Slider por propiedad ===
        function initSlider(idx) {
            const track = document.querySelector(`[data-track="${idx}"]`);
            if (!track) return;
            const total = track.children.length;
            const counter = document.querySelector(`[data-counter="${idx}"]`);
            const dots = document.querySelectorAll(`[data-dots="${idx}"] .dot`);
            const btnPrev = document.querySelector(`[data-prev="${idx}"]`);
            const btnNext = document.querySelector(`[data-next="${idx}"]`);
            let cur = 0;

            function update() {
                track.style.transform = `translateX(-${cur * 100}%)`;
                if (counter) counter.textContent = `${cur + 1} / ${total}`;
                if (btnPrev) btnPrev.disabled = cur === 0;
                if (btnNext) btnNext.disabled = cur === total - 1;
                dots.forEach((d, i) => d.classList.toggle('active', i === cur));
            }
            btnNext && btnNext.addEventListener('click', () => { if (cur < total - 1) { cur++; update(); } });
            btnPrev && btnPrev.addEventListener('click', () => { if (cur > 0) { cur--; update(); } });
            dots.forEach((d, i) => d.addEventListener('click', () => { cur = i; update(); }));

            // swipe
            const vp = track.parentElement;
            let startX = 0;
            vp.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
            vp.addEventListener('touchend', e => {
                const dx = e.changedTouches[0].clientX - startX;
                if (dx < -40 && cur < total - 1) { cur++; update(); }
                else if (dx > 40 && cur > 0) { cur--; update(); }
            });
            update();
        }

        document.querySelectorAll('[data-track]').forEach(t => initSlider(t.dataset.track));

        // === Emergency Services cards ===
        document.querySelectorAll('[data-emergency-section]').forEach(section => {
            const cards = section.querySelectorAll('.emergency-card');
            const iconEl = section.querySelector('[data-emergency-detail-icon]');
            const badgeEl = section.querySelector('[data-emergency-detail-badge]');
            const titleEl = section.querySelector('[data-emergency-detail-title]');
            const descEl = section.querySelector('[data-emergency-detail-desc]');
            const arrivalEl = section.querySelector('[data-emergency-detail-arrival]');
            const featuresEl = section.querySelector('[data-emergency-detail-features]');
            const ctaEl = section.querySelector('[data-emergency-detail-cta]');

            function renderFeatures(raw) {
                if (!featuresEl) return;
                featuresEl.innerHTML = '';
                (raw || '').split('|').filter(Boolean).forEach(entry => {
                    const parts = entry.split(':');
                    const icon = parts[0] || 'fa-clock';
                    const text = parts.slice(1).join(':') || '';
                    const item = document.createElement('div');
                    item.className = 'emergency-feature';
                    item.innerHTML = `<i class="fas ${icon}"></i><span>${text}</span>`;
                    featuresEl.appendChild(item);
                });
            }

            cards.forEach(card => {
                card.addEventListener('click', () => {
                    cards.forEach(c => {
                        c.classList.remove('active');
                        c.setAttribute('aria-selected', 'false');
                    });
                    card.classList.add('active');
                    card.setAttribute('aria-selected', 'true');

                    if (iconEl) iconEl.className = `fas ${card.dataset.icon}`;
                    if (titleEl) titleEl.textContent = card.dataset.title || '';
                    if (descEl) descEl.textContent = card.dataset.desc || '';
                    if (arrivalEl) arrivalEl.textContent = `${card.dataset.arrival || '45'} min`;

                    const badge = card.dataset.badge || '';
                    if (badgeEl) {
                        if (badge) {
                            badgeEl.textContent = badge;
                            badgeEl.classList.remove('hidden');
                        } else {
                            badgeEl.textContent = '';
                            badgeEl.classList.add('hidden');
                        }
                    }

                    renderFeatures(card.dataset.features);
                    if (ctaEl) {
                        ctaEl.innerHTML = `<i class="fas fa-paper-plane"></i> ${card.dataset.cta || 'Request help'}`;
                        const startUrl = card.dataset.startUrl || '';
                        ctaEl.dataset.startUrl = startUrl;
                        if (startUrl) {
                            ctaEl.classList.remove('nav-jump');
                        } else {
                            ctaEl.classList.add('nav-jump');
                            ctaEl.dataset.target = 'section-more';
                        }
                    }
                });
            });

            if (ctaEl) {
                ctaEl.addEventListener('click', (e) => {
                    const startUrl = ctaEl.dataset.startUrl || '';
                    if (startUrl) {
                        e.preventDefault();
                        e.stopPropagation();
                        window.location.href = startUrl;
                    }
                });
            }
        });

        // === Atajos desde Home a otras secciones ===
        document.querySelectorAll('.home-shortcut[data-target], .nav-jump[data-target]').forEach(el => {
            el.addEventListener('click', () => {
                const target = el.dataset.target;
                const navBtn = document.querySelector(`.bottom-nav .nav-item[data-target="${target}"]`);
                if (navBtn) navBtn.click();
            });
        });

        // === Facts & features expand ===
        (function () {
            const btn = document.getElementById('btnShowFacts');
            const panel = document.getElementById('propDetailsExpand');
            if (!btn || !panel) return;
            btn.addEventListener('click', () => {
                const open = panel.hasAttribute('hidden');
                if (open) {
                    panel.removeAttribute('hidden');
                    btn.setAttribute('aria-expanded', 'true');
                    btn.innerHTML = 'Show less <i class="fas fa-chevron-up"></i>';
                } else {
                    panel.setAttribute('hidden', '');
                    btn.setAttribute('aria-expanded', 'false');
                    btn.innerHTML = 'Show more <i class="fas fa-chevron-right"></i>';
                }
            });
        })();

        // === Notificaciones (campanita) ===
        (function () {
            const bell = document.getElementById('bellToggle');
            const panel = document.getElementById('notifPanel');
            const closeBtn = document.getElementById('notifClose');
            if (!bell || !panel) return;
            bell.addEventListener('click', (e) => {
                e.stopPropagation();
                panel.classList.toggle('open');
            });
            closeBtn && closeBtn.addEventListener('click', () => panel.classList.remove('open'));
            document.addEventListener('click', (e) => {
                if (!panel.contains(e.target) && e.target !== bell) {
                    panel.classList.remove('open');
                }
            });
        })();

        // === More: toggle de formularios del perfil ===
        document.querySelectorAll('.opt-btn[data-form]').forEach(btn => {
            btn.addEventListener('click', () => {
                const id = btn.dataset.form;
                document.querySelectorAll('.perfil-form').forEach(f => {
                    if (f.id === id) f.classList.toggle('open');
                    else f.classList.remove('open');
                });
            });
        });

        // === More: tabs de historial ===
        document.querySelectorAll('.hist-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.hist-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                const target = tab.dataset.hist;
                document.querySelectorAll('[data-hist-list]').forEach(l => {
                    l.style.display = l.dataset.histList === target ? '' : 'none';
                });
            });
        });

        // === Si llegamos con ?section=more, abrir directamente esa sección ===
        (function () {
            const params = new URLSearchParams(window.location.search);
            const sec = params.get('section');
            if (sec) {
                const btn = document.querySelector(`.bottom-nav .nav-item[data-target="section-${sec}"]`);
                if (btn) btn.click();
            }
            // Auto-scroll del chat al final
            const chat = document.getElementById('chatBox');
            if (chat) chat.scrollTop = chat.scrollHeight;
        })();

        // === Selector de propiedad (tabs) ===
        document.querySelectorAll('#propertySelector .property-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                const idx = tab.dataset.propIndex;
                document.querySelectorAll('#propertySelector .property-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                // Ocultar todos los paneles principales y extras
                document.querySelectorAll('[data-prop-panel]').forEach(p => p.style.display = 'none');
                document.querySelectorAll(`[data-prop-panel="${idx}"]`).forEach(p => p.style.display = 'block');
            });
        });

    </script>
</body>
</html>
