@model IndorMvcApp.ViewModels.HomeCarePrioritiesSectionViewModel
@if (Model.Items.Count > 0)
{
<div class="category-block category-block-priorities" id="home-care-priorities" data-ho-service-section>
    <div class="category-header">
        <div class="category-icon category-icon-priorities"><i class="fas @Model.IconClass"></i></div>
        <div class="category-info">
            <h3 class="category-title">@Model.Title</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
            {
                <span class="category-sub">@Model.Subtitle</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ViewAllUrl))
        {
            <a href="@Model.ViewAllUrl" class="priorities-view-all">@Model.ViewAllText <i class="fas fa-chevron-right"></i></a>
        }
        else
        {
            <button type="button" class="priorities-view-all nav-jump" data-target="section-myhome">@Model.ViewAllText <i class="fas fa-chevron-right"></i></button>
        }
        <span class="category-badge category-badge-priorities">@Model.Items.Count</span>
    </div>

    <div class="offering-grid">
        @foreach (var item in Model.Items)
        {
            var imgSrc = !string.IsNullOrWhiteSpace(item.ImageUrl)
                ? Url.Content("~" + (item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/" + item.ImageUrl))
                : null;

            if (!string.IsNullOrWhiteSpace(item.Url))
            {
                <a href="@item.Url" class="offering-card" data-ho-service-item data-filter="@IndorMvcApp.Services.HomeownerServiceFilter.Classify(item.Title)" data-search="@item.Title @item.Subtitle">
                    <div class="offering-card-media">
                        <span class="offering-card-order">@item.Orden</span>
                        @if (!string.IsNullOrWhiteSpace(imgSrc))
                        {
                            <img src="@imgSrc" alt="@item.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="offering-card-fallback"><i class="fas @item.Icon"></i></div>
                        }
                    </div>
                    <span class="offering-card-label">@item.Title</span>
                    @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                    {
                        <span class="home-care-card-sub">@item.Subtitle</span>
                    }
                </a>
            }
            else
            {
                <button type="button" class="offering-card nav-jump" data-target="section-myhome" data-ho-service-item data-filter="@IndorMvcApp.Services.HomeownerServiceFilter.Classify(item.Title)" data-search="@item.Title @item.Subtitle">
                    <div class="offering-card-media">
                        <span class="offering-card-order">@item.Orden</span>
                        @if (!string.IsNullOrWhiteSpace(imgSrc))
                        {
                            <img src="@imgSrc" alt="@item.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="offering-card-fallback"><i class="fas @item.Icon"></i></div>
                        }
                    </div>
                    <span class="offering-card-label">@item.Title</span>
                    @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                    {
                        <span class="home-care-card-sub">@item.Subtitle</span>
                    }
                </button>
            }
        }
    </div>
</div>
}
