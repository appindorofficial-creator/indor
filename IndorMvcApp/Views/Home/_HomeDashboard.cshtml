@model IndorMvcApp.ViewModels.HomeDashboardViewModel
@using IndorMvcApp.Services

<div class="hd-greeting">
    <h1>@L[Model.Greeting], @Model.UserFirstName</h1>
    <p>@L["Here's your home dashboard."]</p>
</div>

@if (!Model.HasProperty)
{
    <div class="hn-network-empty">
        <i class="fas fa-house"></i>
        <p>@L["Add your home to start your dashboard."]</p>
        <a asp-controller="Perfil" asp-action="EditarPerfil" asp-fragment="home" class="hn-btn-primary">@L["Add your home"]</a>
    </div>
}
else
{
    <article class="hd-property-card">
        <img class="hd-property-photo" src="@Url.Content($"~{Model.ImageUrl}")" alt="@L["Your home"]" />
        <div class="hd-property-body">
            <p class="hd-property-address">@Model.Address</p>
            <p class="hd-value-label">@L["Home Value"]</p>
            <p class="hd-value">@Model.HomeValue</p>
            @if (!string.IsNullOrEmpty(Model.BedsLabel) || !string.IsNullOrEmpty(Model.BathsLabel) || !string.IsNullOrEmpty(Model.SqftLabel))
            {
                <div class="hd-specs">
                    @if (!string.IsNullOrEmpty(Model.BedsLabel))
                    {
                        <span class="hd-spec"><i class="fas fa-bed"></i> @UiDisplayLocalization.Localize(L, Model.BedsLabel)</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.BathsLabel))
                    {
                        <span class="hd-spec"><i class="fas fa-bath"></i> @UiDisplayLocalization.Localize(L, Model.BathsLabel)</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.SqftLabel))
                    {
                        <span class="hd-spec"><i class="fas fa-ruler-combined"></i> @UiDisplayLocalization.Localize(L, Model.SqftLabel)</span>
                    }
                </div>
            }
            <a href="@Model.HouseFactsUrl" class="hd-house-facts-btn">
                @L["View House Facts"]
                <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    </article>

    <h2 class="hd-section-title">@L["Start here"]</h2>
    <div class="hd-start-grid">
        @foreach (var action in Model.QuickActions)
        {
            if (!string.IsNullOrWhiteSpace(action.Url))
            {
                <a href="@action.Url" class="hd-start-item @(action.Tone == "red" ? "red" : "")">
                    <i class="fas @action.Icon"></i>
                    @L[action.Label]
                </a>
            }
            else
            {
                <button type="button" class="hd-start-item @(action.Tone == "red" ? "red" : "") nav-jump" data-target="@action.TargetSection" data-scroll-target="@(action.ScrollTarget ?? "")">
                    <i class="fas @action.Icon"></i>
                    @L[action.Label]
                </button>
            }
        }
    </div>

    @if (Model.MaintenanceSection is { Items.Count: > 0 } maintenanceSection)
    {
        @await Html.PartialAsync("_HomeMaintenanceAlerts", maintenanceSection)
    }

    @if (Model.TodayTasks.Count > 0)
    {
        <h2 class="hd-section-title">@L["For your home today"]</h2>
        <div class="hd-task-list">
            @foreach (var todayTask in Model.TodayTasks)
            {
                var isHash = todayTask.Url.StartsWith("#");
                if (isHash)
                {
                    <button type="button" class="hd-task nav-jump" data-target="@todayTask.Url.TrimStart('#')" style="width:100%;border:none;background:transparent;text-align:left;cursor:pointer;">
                        <span class="hd-task-icon"><i class="@PropertyMaintenanceIconResolver.EnsureCssClass(todayTask.Icon, todayTask.Category, todayTask.Title)"></i></span>
                        <span class="hd-task-body">
                            <span class="hd-task-title">@UiDisplayLocalization.Localize(L, todayTask.Title)</span>
                            <span class="hd-task-sub">
                                @if (!string.IsNullOrEmpty(todayTask.Badge))
                                {
                                    @($"{UiDisplayLocalization.Localize(L, todayTask.Subtitle.Split('•')[0].Trim())} • ")
                                    <span class="badge">@UiDisplayLocalization.Localize(L, todayTask.Badge)</span>
                                }
                                else
                                {
                                    @UiDisplayLocalization.Localize(L, todayTask.Subtitle)
                                }
                            </span>
                        </span>
                        <i class="fas fa-chevron-right hd-task-chevron"></i>
                    </button>
                }
                else
                {
                    <a href="@todayTask.Url" class="hd-task">
                        <span class="hd-task-icon"><i class="@PropertyMaintenanceIconResolver.EnsureCssClass(todayTask.Icon, todayTask.Category, todayTask.Title)"></i></span>
                        <span class="hd-task-body">
                            <span class="hd-task-title">@UiDisplayLocalization.Localize(L, todayTask.Title)</span>
                            <span class="hd-task-sub">
                                @if (!string.IsNullOrEmpty(todayTask.Badge))
                                {
                                    @($"{UiDisplayLocalization.Localize(L, todayTask.Subtitle.Split('•')[0].Trim())} • ")
                                    <span class="badge">@UiDisplayLocalization.Localize(L, todayTask.Badge)</span>
                                }
                                else
                                {
                                    @UiDisplayLocalization.Localize(L, todayTask.Subtitle)
                                }
                            </span>
                        </span>
                        <i class="fas fa-chevron-right hd-task-chevron"></i>
                    </a>
                }
            }
        </div>
    }

    @if (Model.RecentDocuments.Count > 0)
    {
        <section class="hd-panel-section" aria-labelledby="hd-recent-docs-title">
            <div class="hd-panel-head">
                <h3 id="hd-recent-docs-title">@L["Recent documents"]</h3>
                <a asp-controller="MyHome" asp-action="Documents" asp-route-id="@Model.PropiedadId" class="hd-link">@L["View all"]</a>
            </div>
            <div class="hd-doc-list">
                @foreach (var doc in Model.RecentDocuments)
                {
                    <a href="@doc.Url" class="hd-doc-card">
                        <span class="hd-doc-icon"><i class="fas @doc.Icon"></i></span>
                        <span class="hd-doc-text">
                            <span class="hd-doc-title">@UiDisplayLocalization.Localize(L, doc.Title)</span>
                            <span class="hd-doc-meta">@UiDisplayLocalization.Localize(L, doc.Meta)</span>
                        </span>
                        <i class="fas fa-chevron-right hd-doc-chevron" aria-hidden="true"></i>
                    </a>
                }
            </div>
        </section>
    }

    @if (Model.RecentActivity.Count > 0)
    {
        <section class="hd-panel-section" aria-labelledby="hd-home-activity-title">
            <div class="hd-panel-head">
                <h3 id="hd-home-activity-title">@L["Home activity"]</h3>
                <a asp-controller="MyHome" asp-action="History" asp-route-id="@Model.PropiedadId" class="hd-link">@L["View all"]</a>
            </div>
            <div class="hd-activity-timeline">
                @foreach (var act in Model.RecentActivity)
                {
                    <div class="hd-activity-item">
                        <span class="hd-activity-dot"><i class="fas @act.Icon"></i></span>
                        <div class="hd-activity-body">
                            <div class="hd-activity-title">@UiDisplayLocalization.Localize(L, act.Title)</div>
                            <div class="hd-activity-time">@act.Timestamp</div>
                            @if (!string.IsNullOrWhiteSpace(act.Description))
                            {
                                <div class="hd-activity-desc">@UiDisplayLocalization.Localize(L, act.Description)</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <div class="hd-realtor-card">
        <div class="hd-realtor-content">
            <strong>@L["Need help with finding a professional realtor?"]</strong>
            <p>@L["Our team can help connect you with a trusted real estate professional."]</p>
            <div class="hd-realtor-actions">
                <a asp-controller="RealtorRequest" asp-action="Request" asp-route-propiedadId="@Model.PropiedadId" class="hd-btn-primary-sm">@L["Request"]</a>
                <button type="button" class="hd-btn-outline-sm nav-jump" data-target="section-more">@L["Contact Support"]</button>
            </div>
        </div>
        <div class="hd-realtor-art" aria-hidden="true">
            <span class="hd-realtor-house"><i class="fas fa-house"></i></span>
            <span class="hd-realtor-tree hd-realtor-tree--l"><i class="fas fa-tree"></i></span>
            <span class="hd-realtor-tree hd-realtor-tree--r"><i class="fas fa-tree"></i></span>
        </div>
    </div>
}
