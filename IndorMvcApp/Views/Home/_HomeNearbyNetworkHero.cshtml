@model IndorMvcApp.ViewModels.HomeownerNearbyNetworkViewModel
@{
    var isMapView = Model.ActiveView == "map";
    string BuildViewUrl(string view) =>
        (Url.Action("Index", "Home", new { filter = Model.ActiveFilter, view, q = Model.SearchQuery }) ?? "/") + "#section-home";
}

<div class="hn-v4-view-tabs @(isMapView ? "hn-v4-view-tabs--map" : "hn-v4-view-tabs--feed")" role="tablist" aria-label="@L["Network view"]">
    <a href="@BuildViewUrl("map")"
       class="hn-v4-view-tab @(Model.ActiveView == "map" ? "is-active" : null)"
       role="tab"
       aria-selected="@(Model.ActiveView == "map" ? "true" : "false")">
        <span class="hn-v4-view-tab-icon"><i class="fas fa-map"></i></span>
        <span class="hn-v4-view-tab-copy">
            <strong>@UiDisplayLocalization.Localize(L, "Map")</strong>
            <small>@UiDisplayLocalization.Localize(L, "See nearby places")</small>
        </span>
    </a>
    <a href="@BuildViewUrl("feed")"
       class="hn-v4-view-tab @(Model.ActiveView == "feed" ? "is-active" : null)"
       role="tab"
       aria-selected="@(Model.ActiveView == "feed" ? "true" : "false")">
        <span class="hn-v4-view-tab-icon"><i class="fas fa-list"></i></span>
        <span class="hn-v4-view-tab-copy">
            <strong>@UiDisplayLocalization.Localize(L, "Feed")</strong>
            <small>@UiDisplayLocalization.Localize(L, "See local updates")</small>
        </span>
    </a>
</div>
