@model IndorMvcApp.ViewModels.OfferingCarouselViewModel
@if (Model.Items.Count > 0)
{
<div class="category-block @(Model.BlockClass)">
    <div class="category-header">
        <div class="category-icon @(Model.IconClass)"><i class="fas @Model.Icon"></i></div>
        <div class="category-info">
            <h3 class="category-title">@Model.Title</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Subtitle))
            {
                <span class="category-sub">@Model.Subtitle</span>
            }
        </div>
        <span class="category-badge @(Model.BadgeClass)">@Model.Items.Count</span>
    </div>

    <div class="offering-grid">
        @foreach (var item in Model.Items)
        {
            var imgSrc = !string.IsNullOrWhiteSpace(item.ImageUrl)
                ? Url.Content("~" + (item.ImageUrl.StartsWith("/") ? item.ImageUrl : "/" + item.ImageUrl))
                : item.ImageBase64;

            if (item.EnableLink && item.SourceId.HasValue && !string.IsNullOrWhiteSpace(item.LinkController) && !string.IsNullOrWhiteSpace(item.LinkAction))
            {
                <a asp-controller="@item.LinkController" asp-action="@item.LinkAction" asp-route-id="@item.SourceId" class="offering-card">
                    <div class="offering-card-media">
                        @if (!string.IsNullOrWhiteSpace(imgSrc))
                        {
                            <img src="@imgSrc" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="offering-card-fallback"><i class="fas @item.CtaIcon"></i></div>
                        }
                    </div>
                    <span class="offering-card-label">@item.Name</span>
                </a>
            }
            else if (item.EnableSchedule && item.SourceId.HasValue)
            {
                <a asp-controller="Microservicios" asp-action="Schedule" asp-route-id="@item.SourceId" class="offering-card">
                    <div class="offering-card-media">
                        @if (!string.IsNullOrWhiteSpace(imgSrc))
                        {
                            <img src="@imgSrc" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="offering-card-fallback"><i class="fas @item.CtaIcon"></i></div>
                        }
                    </div>
                    <span class="offering-card-label">@item.Name</span>
                </a>
            }
            else
            {
                <button type="button" class="offering-card">
                    <div class="offering-card-media">
                        @if (!string.IsNullOrWhiteSpace(imgSrc))
                        {
                            <img src="@imgSrc" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <div class="offering-card-fallback"><i class="fas @item.CtaIcon"></i></div>
                        }
                    </div>
                    <span class="offering-card-label">@item.Name</span>
                </button>
            }
        }
    </div>
</div>
}
