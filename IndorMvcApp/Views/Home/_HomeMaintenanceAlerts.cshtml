@model IndorMvcApp.ViewModels.PropertyMaintenanceSectionViewModel
@using IndorMvcApp.Services

@if (Model.IsAiGenerated && Model.Items.Count > 0)
{
    <section class="hd-maint-alerts" id="hd-maintenance-alerts" aria-labelledby="hd-maint-title">
        <div class="hd-maint-head">
            <div>
                <p class="hd-maint-eyebrow"><i class="fas fa-wand-magic-sparkles"></i> @L["AI Maintenance Plan"]</p>
                <h3 id="hd-maint-title">@L["Recommended for your home"]</h3>
                @if (!string.IsNullOrWhiteSpace(Model.Summary))
                {
                    <p class="hd-maint-summary">@UiDisplayLocalization.Localize(L, Model.Summary)</p>
                }
            </div>
            @if (Model.ShowAlerts)
            {
                <span class="hd-maint-alert-pill">
                    <i class="fas fa-bell"></i>
                    @L.T("{0} alerts", Model.UrgentCount + Model.HighCount)
                </span>
            }
        </div>

        <div class="hd-maint-list">
            @foreach (var item in Model.Items)
            {
                var tone = item.Priority switch
                {
                    "Urgent" => "urgent",
                    "High" => "high",
                    _ => "routine"
                };
                if (item.HasScheduleLink)
                {
                    <a href="@item.ScheduleUrl" class="hd-maint-item hd-maint-item--@tone hd-maint-item--link">
                        <span class="hd-maint-icon"><i class="@PropertyMaintenanceIconResolver.EnsureCssClass(item.Icon, item.Category, item.Title)"></i></span>
                        <div class="hd-maint-body">
                            <div class="hd-maint-row">
                                <strong>@UiDisplayLocalization.Localize(L, item.Title)</strong>
                                <span class="hd-maint-priority">@L[item.Priority]</span>
                            </div>
                            <p>@UiDisplayLocalization.Localize(L, item.Description)</p>
                            <div class="hd-maint-tags">
                                <span>@UiDisplayLocalization.Localize(L, item.Category)</span>
                                <span>@UiDisplayLocalization.Localize(L, item.Frequency)</span>
                            </div>
                            <span class="hd-maint-schedule">
                                @UiDisplayLocalization.Localize(L, item.ScheduleActionLabel)
                                <i class="fas fa-chevron-right" aria-hidden="true"></i>
                            </span>
                        </div>
                    </a>
                }
                else
                {
                    <article class="hd-maint-item hd-maint-item--@tone">
                        <span class="hd-maint-icon"><i class="@PropertyMaintenanceIconResolver.EnsureCssClass(item.Icon, item.Category, item.Title)"></i></span>
                        <div class="hd-maint-body">
                            <div class="hd-maint-row">
                                <strong>@UiDisplayLocalization.Localize(L, item.Title)</strong>
                                <span class="hd-maint-priority">@L[item.Priority]</span>
                            </div>
                            <p>@UiDisplayLocalization.Localize(L, item.Description)</p>
                            <div class="hd-maint-tags">
                                <span>@UiDisplayLocalization.Localize(L, item.Category)</span>
                                <span>@UiDisplayLocalization.Localize(L, item.Frequency)</span>
                            </div>
                        </div>
                    </article>
                }
            }
        </div>

        <a href="@($"{Url.Action("Index", "Home")}#home-care-priorities")" class="hd-maint-cta">
            @L["Browse all maintenance services"]
            <i class="fas fa-chevron-right"></i>
        </a>
    </section>
}
