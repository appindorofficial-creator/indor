@model IndorMvcApp.ViewModels.PropertyMaintenanceSectionViewModel
@using IndorMvcApp.Services

@if (Model.IsAiGenerated && Model.Items.Count > 0)
{
    <section class="hd-maint-alerts" id="hd-maintenance-alerts" aria-labelledby="hd-maint-title">
        <div class="hd-maint-head">
            <div>
                <p class="hd-maint-eyebrow"><i class="fas fa-wand-magic-sparkles"></i> AI Maintenance Plan</p>
                <h3 id="hd-maint-title">Recommended for your home</h3>
                @if (!string.IsNullOrWhiteSpace(Model.Summary))
                {
                    <p class="hd-maint-summary">@Model.Summary</p>
                }
            </div>
            @if (Model.ShowAlerts)
            {
                <span class="hd-maint-alert-pill">
                    <i class="fas fa-bell"></i>
                    @(Model.UrgentCount + Model.HighCount) alerts
                </span>
            }
        </div>

        <div class="hd-maint-list">
            @foreach (var item in Model.Items)
            {
                var tone = item.Priority switch
                {
                    "Urgent" => "urgent",
                    "High" => "high",
                    _ => "routine"
                };
                <article class="hd-maint-item hd-maint-item--@tone">
                    <span class="hd-maint-icon"><i class="@PropertyMaintenanceIconResolver.EnsureCssClass(item.Icon, item.Category, item.Title)"></i></span>
                    <div class="hd-maint-body">
                        <div class="hd-maint-row">
                            <strong>@item.Title</strong>
                            <span class="hd-maint-priority">@item.Priority</span>
                        </div>
                        <p>@item.Description</p>
                        <div class="hd-maint-tags">
                            <span>@item.Category</span>
                            <span>@item.Frequency</span>
                        </div>
                    </div>
                </article>
            }
        </div>

        <button type="button" class="hd-maint-cta nav-jump" data-target="section-services">
            Request a professional
            <i class="fas fa-chevron-right"></i>
        </button>
    </section>
}
