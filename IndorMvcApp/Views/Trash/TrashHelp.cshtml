@model IndorMvcApp.ViewModels.TrashHelpViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("TrashSetup", "Trash", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 3;
}

<h2 class="page-heading" style="font-size:1.05rem;">@L["How should INDOR help?"]</h2>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="TrashHelp" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="TipoAyuda" id="TipoAyuda" />
        <input type="hidden" asp-for="RecordatorioCuando" id="RecordatorioCuando" />
        <input type="hidden" asp-for="VentanaRecoleccion" id="VentanaRecoleccion" />

        <div class="field-card">
            <div class="help-list" id="helpGroup">
                <button type="button" class="help-row" data-value="ReminderOnly">
                    <i class="fas fa-bell main"></i>
                    <span class="copy"><strong>@L["Reminder only"]</strong><span>@L["Get notified before pickup day"]</span></span>
                    <span class="radio"></span>
                </button>
                <button type="button" class="help-row" data-value="TakeOut">
                    <i class="fas fa-trash-can main"></i>
                    <span class="copy"><strong>@L["Take bins out"]</strong><span>@L["INDOR takes bins to the curb"]</span></span>
                    <span class="radio"></span>
                </button>
                <button type="button" class="help-row" data-value="TakeOutReturn">
                    <i class="fas fa-arrows-rotate main"></i>
                    <span class="copy"><strong>@L["Take out + bring back"]</strong><span>@L["Full weekly service"]</span></span>
                    <span class="radio"></span>
                </button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Reminder settings"]</span>
            <div class="reminder-row" id="reminderGroup">
                <button type="button" class="reminder-btn" data-value="OneDayBefore"><i class="fas fa-bell"></i> @L["1 day before"]</button>
                <button type="button" class="reminder-btn" data-value="EveningBefore"><i class="fas fa-moon"></i> @L["Evening before"]</button>
                <button type="button" class="reminder-btn" data-value="MorningOf"><i class="fas fa-sun"></i> @L["Morning of"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Pickup time window"]</span>
            <div class="picker-row">
                <div class="left">
                    <i class="fas fa-clock" style="color:#0066CC;"></i>
                    <select id="VentanaRecoleccionSelect" aria-label="@L["Pickup time window"]">
                        <option value="Morning7_12">@L["07:00 &ndash; 12:00"]</option>
                        <option value="Afternoon12_5">@L["12:00 &ndash; 17:00"]</option>
                        <option value="Flexible">@L["Flexible"]</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <span class="field-label">@L["Special notes (optional)"]</span>
            <div class="input-wrap">
                <i class="fas fa-pen"></i>
                <input asp-for="NotasEspeciales" placeholder="@L["Gate code, where bins are stored"]" />
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar-plus"></i> @L["Review request"]
        </button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>

@section Scripts {
<script>
    (function () {
        function initSingle(groupId, selector, hiddenId, initial, onChange) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' ' + selector).forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' ' + selector).forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                    if (onChange) onChange(btn);
                });
            });
        }

        initSingle('helpGroup', '.help-row', 'TipoAyuda', '@Model.TipoAyuda');
        initSingle('reminderGroup', '.reminder-btn', 'RecordatorioCuando', '@Model.RecordatorioCuando');

        const windowHidden = document.getElementById('VentanaRecoleccion');
        const windowSelect = document.getElementById('VentanaRecoleccionSelect');
        if (windowHidden && windowSelect) {
            windowSelect.value = windowHidden.value || 'Morning7_12';
            windowSelect.addEventListener('change', () => { windowHidden.value = windowSelect.value; });
        }
    })();

</script>
}
