@model IndorMvcApp.ViewModels.TrashSetupViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
    var selectedBins = (Model.BinsSeleccionados ?? "Trash").Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_TrashStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="TrashService" asp-route-id="@Model.MicroservicioId" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_TrashStepper", 1)

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="TrashSetup" method="post" id="setupForm">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="BinsSeleccionados" id="BinsSeleccionados" />
        <input type="hidden" asp-for="CantidadBins" id="CantidadBins" />
        <input type="hidden" asp-for="Frecuencia" id="Frecuencia" />
        <input type="hidden" asp-for="DiaRecoleccion" id="DiaRecoleccion" />
        <input type="hidden" asp-for="PrecioMensual" id="PrecioMensual" />

        <div class="field-card">
            <span class="field-label">What bins should we manage?</span>
            <p class="page-lead" style="margin-top:-6px;margin-bottom:10px;">Select all that apply.</p>
            <div class="bin-grid" id="binGroup">
                @foreach (var bin in TrashPricingService.BinOptions)
                {
                    <button type="button" class="bin-card @(selectedBins.Contains(bin.Code) ? "active" : "")" data-code="@bin.Code">
                        <span class="check"><i class="fas fa-check"></i></span>
                        <div class="thumb"><i class="fas @bin.Icon"></i></div>
                        <div class="label">@bin.Label</div>
                    </button>
                }
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How many bins?</span>
            <div class="count-grid" id="countGroup">
                <button type="button" class="count-card" data-value="One" data-price="20"><span class="check"><i class="fas fa-check"></i></span><strong>1 bin</strong><span>$20 /mo</span></button>
                <button type="button" class="count-card" data-value="Two" data-price="25"><span class="check"><i class="fas fa-check"></i></span><strong>2 bins</strong><span>$25 /mo</span></button>
                <button type="button" class="count-card" data-value="Three" data-price="30"><span class="check"><i class="fas fa-check"></i></span><strong>3 bins</strong><span>$30 /mo</span></button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">How often?</span>
            <div class="freq-grid" id="freqGroup">
                <button type="button" class="freq-card" data-value="OneTime"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-calendar-day"></i>One-time</button>
                <button type="button" class="freq-card" data-value="Weekly"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-rotate"></i>Weekly</button>
                <button type="button" class="freq-card" data-value="ReminderOnly"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-bell"></i>Reminder only</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Your pickup day</span>
            <p class="page-lead" style="margin-top:-6px;margin-bottom:10px;">You can update this anytime.</p>
            <div class="day-row" id="dayGroup">
                @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                {
                    <button type="button" class="day-btn" data-value="@day">@day</button>
                }
            </div>
        </div>

        <div class="sticky-total">
            <div class="sticky-total-row">
                <span class="label">Monthly total</span>
                <span class="value" id="totalDisplay">$@Model.PrecioMensual.ToString("0")</span>
            </div>
            <button type="submit" name="action" value="continue" class="btn-primary">Continue <i class="fas fa-chevron-right"></i></button>
            <button type="submit" name="action" value="back" class="btn-outline">Back</button>
        </div>
    </form>
</div>
<script>
    (function () {
        const selectedBins = new Set((document.getElementById('BinsSeleccionados').value || 'Trash').split('|').map(s => s.trim()).filter(Boolean));

        function syncBins() {
            document.getElementById('BinsSeleccionados').value = Array.from(selectedBins).join('|');
        }

        document.querySelectorAll('#binGroup .bin-card').forEach(card => {
            card.addEventListener('click', () => {
                const code = card.dataset.code;
                if (selectedBins.has(code)) {
                    if (selectedBins.size > 1) {
                        selectedBins.delete(code);
                        card.classList.remove('active');
                    }
                } else {
                    selectedBins.add(code);
                    card.classList.add('active');
                }
                syncBins();
            });
        });

        function initSingle(groupId, selector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' ' + selector).forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' ' + selector).forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                    if (hiddenId === 'CantidadBins') updateTotal(btn.dataset.price);
                });
            });
        }

        function updateTotal(price) {
            const p = price || document.querySelector('#countGroup .count-card.active')?.dataset.price || '20';
            document.getElementById('PrecioMensual').value = p;
            document.getElementById('totalDisplay').textContent = '$' + p;
        }

        initSingle('countGroup', '.count-card', 'CantidadBins', '@Model.CantidadBins');
        initSingle('freqGroup', '.freq-card', 'Frecuencia', '@Model.Frecuencia');
        initSingle('dayGroup', '.day-btn', 'DiaRecoleccion', '@Model.DiaRecoleccion');
        updateTotal();
        syncBins();
    })();
</script>
</body>
</html>
