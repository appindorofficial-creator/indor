@model IndorMvcApp.ViewModels.TrashSetupViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("TrashService", "Trash", new { id = Model.MicroservicioId });
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;
    var selectedBins = (Model.BinsSeleccionados ?? string.Empty).Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
    var dayLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Sun"] = L["Sun"],
        ["Mon"] = L["Mon"],
        ["Tue"] = L["Tue"],
        ["Wed"] = L["Wed"],
        ["Thu"] = L["Thu"],
        ["Fri"] = L["Fri"],
        ["Sat"] = L["Sat"]
    };
}

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="TrashSetup" method="post" id="setupForm">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="BinsSeleccionados" id="BinsSeleccionados" />
        <input type="hidden" asp-for="CantidadBins" id="CantidadBins" />
        <input type="hidden" asp-for="Frecuencia" id="Frecuencia" />
        <input type="hidden" asp-for="DiaRecoleccion" id="DiaRecoleccion" />
        <input type="hidden" asp-for="PrecioMensual" id="PrecioMensual" />

        <div class="field-card">
            <span class="field-label">@L["What bins should we manage?"]</span>
            <p class="page-lead" style="margin-top:-6px;margin-bottom:10px;">@L["Select all that apply."]</p>
            <div class="bin-grid" id="binGroup">
                @foreach (var bin in TrashPricingService.BinOptions)
                {
                    <button type="button" class="bin-card @(selectedBins.Contains(bin.Code) ? "active" : "")" data-code="@bin.Code">
                        <span class="check"><i class="fas fa-check"></i></span>
                        <div class="thumb tone-@bin.ThumbTone">
                            @if (!string.IsNullOrWhiteSpace(bin.ImageUrl))
                            {
                                <img src="@Url.Content("~" + bin.ImageUrl)" alt="@L[bin.Label]" loading="lazy" />
                            }
                            else
                            {
                                <i class="fas @bin.Icon"></i>
                            }
                        </div>
                        <div class="label">@L[bin.Label]</div>
                    </button>
                }
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How many bins?"]</span>
            <div class="count-grid" id="countGroup">
                <button type="button" class="count-card" data-value="One" data-price="20"><span class="check"><i class="fas fa-check"></i></span><strong>@L["1 bin"]</strong><span>@L["$20 /mo"]</span></button>
                <button type="button" class="count-card" data-value="Two" data-price="25"><span class="check"><i class="fas fa-check"></i></span><strong>@L["2 bins"]</strong><span>@L["$25 /mo"]</span></button>
                <button type="button" class="count-card" data-value="Three" data-price="30"><span class="check"><i class="fas fa-check"></i></span><strong>@L["3 bins"]</strong><span>@L["$30 /mo"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How often?"]</span>
            <div class="freq-grid" id="freqGroup">
                <button type="button" class="freq-card" data-value="OneTime">
                    <span class="freq-card-head"><span class="check"><i class="fas fa-check"></i></span></span>
                    <i class="fas fa-calendar-day"></i>
                    <span class="freq-label">@L["One-time"]</span>
                </button>
                <button type="button" class="freq-card" data-value="Weekly">
                    <span class="freq-card-head"><span class="check"><i class="fas fa-check"></i></span></span>
                    <i class="fas fa-rotate"></i>
                    <span class="freq-label">@L["Weekly"]</span>
                </button>
                <button type="button" class="freq-card" data-value="ReminderOnly">
                    <span class="freq-card-head"><span class="check"><i class="fas fa-check"></i></span></span>
                    <i class="fas fa-bell"></i>
                    <span class="freq-label">@L["Reminder only"]</span>
                </button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Your pickup day"]</span>
            <p class="page-lead" style="margin-top:-6px;margin-bottom:10px;">@L["You can update this anytime."]</p>
            <div class="day-row" id="dayGroup">
                @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                {
                    <button type="button" class="day-btn" data-value="@day">@dayLabels[day]</button>
                }
            </div>
        </div>

        <div class="sticky-total">
            <div class="sticky-total-row">
                <span class="label">@L["Monthly total"]</span>
                <span class="value" id="totalDisplay">$@Model.PrecioMensual.ToString("0")</span>
            </div>
            <button type="submit" name="action" value="continue" class="btn-primary">@L["Continue"] <i class="fas fa-chevron-right"></i></button>
            <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
        </div>
    </form>

@section Scripts {
<script>
    (function () {
        const selectedBins = new Set((document.getElementById('BinsSeleccionados').value || '').split('|').map(s => s.trim()).filter(Boolean));

        function syncBins() {
            document.getElementById('BinsSeleccionados').value = Array.from(selectedBins).join('|');
        }

        document.querySelectorAll('#binGroup .bin-card').forEach(card => {
            card.addEventListener('click', () => {
                const code = card.dataset.code;
                if (selectedBins.has(code)) {
                    selectedBins.delete(code);
                    card.classList.remove('active');
                } else {
                    selectedBins.add(code);
                    card.classList.add('active');
                }
                syncBins();
            });
        });

        function initSingle(groupId, selector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const initialValue = (initial || hidden.value || '').trim();
            document.querySelectorAll('#' + groupId + ' ' + selector).forEach(btn => {
                if (initialValue && btn.dataset.value === initialValue) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' ' + selector).forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                    if (hiddenId === 'CantidadBins') updateTotal(btn.dataset.price);
                });
            });
        }

        function updateTotal(price) {
            const p = price || document.querySelector('#countGroup .count-card.active')?.dataset.price || '0';
            document.getElementById('PrecioMensual').value = p;
            document.getElementById('totalDisplay').textContent = '$' + p;
        }

        initSingle('countGroup', '.count-card', 'CantidadBins', '@Model.CantidadBins');
        initSingle('freqGroup', '.freq-card', 'Frecuencia', '@Model.Frecuencia');
        initSingle('dayGroup', '.day-btn', 'DiaRecoleccion', '@Model.DiaRecoleccion');
        updateTotal();
        syncBins();
    })();

</script>
}
