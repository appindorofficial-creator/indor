@model IndorMvcApp.ViewModels.RealtorQuoteRequestSuccessViewModel

@{

    Layout = "_RealtorLayout";

    ViewData["Title"] = "Quote Request Sent";

    ViewBag.NavActive = "quotes";

}



<div class="rl-dash-shell">

    @await Html.PartialAsync("_RealtorTopbar", new IndorMvcApp.ViewModels.RealtorPortalShellViewModel())



    <section class="rl-success-hero">

        <div class="rl-success-icon-wrap">

            <span class="rl-success-icon"><i class="fas fa-check"></i></span>

        </div>

        <h1>Quote Request Sent</h1>

        <p>Your request was sent successfully.</p>

    </section>



    <nav class="rl-invite-stepper rl-invite-stepper--success" aria-label="Completed steps">

        @foreach (var step in new[] { "Property", "Items & Details", "Providers", "Review & Send" })

        {

            <div class="rl-invite-step is-done">

                <i class="fas fa-check"></i>

                <small>@step</small>

            </div>

            @if (step != "Review & Send")

            {

                <div class="rl-invite-step-line is-done"></div>

            }

        }

    </nav>



    <div class="rl-success-card rl-success-card--quote">

        <div class="rl-success-quote-head">

            <i class="fas fa-circle-check"></i>

            <strong>Request sent to @Model.ProviderCount provider@(Model.ProviderCount == 1 ? "" : "s")</strong>

        </div>

        <div class="rl-success-detail"><strong>Property:</strong> @Model.PropertyAddress</div>

        <div class="rl-success-detail"><strong>Request Type:</strong> @Model.RequestTypeLabel</div>

        <div class="rl-success-detail"><strong>Sent To:</strong> @Model.ProvidersSummary</div>

        <div class="rl-success-detail"><strong>Sent When:</strong> @Model.SentWhenLabel</div>

        <div class="rl-success-detail"><strong>Response Deadline:</strong> @Model.ResponseDeadlineHours hours</div>

    </div>



    <div class="rl-review-card">

        <h2 class="rl-invite-section-title">What happens next?</h2>

        <ol class="rl-next-steps">

            <li><span>1</span> Providers receive the request in INDOR Pro.</li>

            <li><span>2</span> They review the file or selected repair items.</li>

            <li><span>3</span> They send a full quote or itemized quote back.</li>

            <li><span>4</span> You compare the quotes and choose the best one.</li>

        </ol>

    </div>



    <div class="rl-review-card rl-provider-preview-card">

        <h2 class="rl-invite-section-title">Provider view preview</h2>

        <div class="rl-open-quote-card">

            <img src="@Model.PhotoUrl" alt="" />

            <div>

                <strong>@Model.PropertyAddress</strong>

                <span>@Model.RequestTypeLabel</span>

                @if (Model.ItemCount > 0)

                {

                    <span><i class="fas fa-box"></i> @Model.ItemCount items</span>

                }

                <span class="rl-status-badge rl-status-badge--pending">New Request</span>

                <span><i class="fas fa-clock"></i> Deadline @Model.ResponseDeadlineHours h</span>

            </div>

            <i class="fas fa-chevron-right rl-card-chevron"></i>

        </div>

    </div>



    <a asp-controller="Realtor" asp-action="Quotes" class="ob-btn ob-btn-primary rl-done-btn">Track Quotes</a>

    <a asp-controller="Realtor" asp-action="Quotes" class="rl-later-link">Done</a>

</div>

