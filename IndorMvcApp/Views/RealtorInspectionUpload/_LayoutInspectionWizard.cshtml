@using IndorMvcApp.Localization
@{
    var stepModel = Model as IndorMvcApp.ViewModels.RealtorInspectionUploadStepViewModel;
    var pageTitle = L[stepModel?.Title ?? "Upload Inspection Report"];
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#0066CC" />
    <title>@pageTitle - INDOR</title>
    @await Html.PartialAsync("_RealtorPortalHead")
</head>
<body class="rl-dash-page">
    <div class="rl-invite-shell">
        @if (stepModel != null)
        {
            @await Html.PartialAsync("_InspectionStepper", stepModel)
        }
        @RenderBody()
    </div>
    @await Html.PartialAsync("~/Views/Realtor/_RealtorBottomNav.cshtml")
    @RenderSection("Scripts", required: false)
</body>
</html>
