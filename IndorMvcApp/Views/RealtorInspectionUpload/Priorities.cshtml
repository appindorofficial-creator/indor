@model IndorMvcApp.ViewModels.RealtorInspectionPrioritiesViewModel

<h2 class="rl-insp-page-address">@Model.PropertyDisplay</h2>

@if (!string.IsNullOrWhiteSpace(Model.ReportFileName) && !string.IsNullOrWhiteSpace(Model.ReportPdfUrl))
{
    <a asp-action="ViewReport"
       asp-route-filter="@Model.ActiveFilter"
       asp-route-sort="@Model.SortBy"
       class="rl-insp-report-link">
        <i class="fas fa-file-pdf"></i>
        <span>@Model.ReportFileName</span>
        <i class="fas fa-chevron-right"></i>
    </a>
}
else if (!string.IsNullOrWhiteSpace(Model.ReportFileName))
{
    <p class="rl-insp-report-link rl-insp-report-link--static">
        <i class="fas fa-file-pdf"></i>
        <span>@Model.ReportFileName</span>
    </p>
}

<div class="rl-insp-findings-hero">
    <div class="rl-insp-findings-hero-glow" aria-hidden="true"></div>
    <div class="rl-insp-findings-hero-inner">
        <div class="rl-insp-findings-hero-top">
            <span class="rl-insp-findings-badge"><i class="fas fa-wand-magic-sparkles"></i> @L["AI Analysis Complete"]</span>
            <span class="rl-insp-findings-hero-icon" aria-hidden="true"><i class="fas fa-house-circle-check"></i></span>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.AnalysisSummary))
        {
            <p class="rl-insp-findings-summary">@UiDisplayLocalization.Localize(L, Model.AnalysisSummary)</p>
        }
        <div class="rl-insp-findings-meta">
            <div class="rl-insp-findings-meta-item">
                <i class="fas fa-calendar"></i>
                <small>@L["Report date"]</small>
                <strong>@Model.ReportDateLabel</strong>
            </div>
            <div class="rl-insp-findings-meta-item">
                <i class="fas fa-user-tie"></i>
                <small>@L["Inspector"]</small>
                <strong>@L.Catalog(Model.InspectorLabel)</strong>
            </div>
            <div class="rl-insp-findings-meta-item">
                <i class="fas fa-wand-magic-sparkles"></i>
                <small>@L["Analyzed"]</small>
                <strong>@L.Catalog(Model.AnalyzedLabel)</strong>
            </div>
        </div>
    </div>
</div>

<div class="rl-insp-stats">
    <div class="rl-insp-stat">
        <span class="rl-insp-stat-num">@Model.TotalFindings</span>
        <span class="rl-insp-stat-label">@L["Total issues"]</span>
    </div>
    <div class="rl-insp-stat rl-insp-stat--urgent">
        <span class="rl-insp-stat-num">@Model.UrgentCount</span>
        <span class="rl-insp-stat-label">@L["Urgent"]</span>
    </div>
    <div class="rl-insp-stat rl-insp-stat--high">
        <span class="rl-insp-stat-num">@Model.HighCount</span>
        <span class="rl-insp-stat-label">@L["High"]</span>
    </div>
    <div class="rl-insp-stat rl-insp-stat--moderate">
        <span class="rl-insp-stat-num">@Model.ModerateCount</span>
        <span class="rl-insp-stat-label">@L["Moderate"]</span>
    </div>
</div>

<form asp-action="Priorities" method="get" class="rl-priorities-toolbar">
    <div class="rl-filter-chips rl-filter-chips--scroll">
        @foreach (var chip in Model.Filters)
        {
            <a asp-action="Priorities" asp-route-filter="@chip" asp-route-sort="@Model.SortBy"
               class="rl-filter-chip rl-filter-chip--@chip.ToLowerInvariant() @(Model.ActiveFilter == chip ? "is-active" : null)">
                @L[chip]
                @if (chip == "Urgent" && Model.UrgentCount > 0) { <text> (@Model.UrgentCount)</text> }
                @if (chip == "High" && Model.HighCount > 0) { <text> (@Model.HighCount)</text> }
                @if (chip == "Moderate" && Model.ModerateCount > 0) { <text> (@Model.ModerateCount)</text> }
            </a>
        }
    </div>
    <select name="sort" class="rl-field-select rl-field-select--full" onchange="this.form.submit()">
        <option value="Priority" selected="@(Model.SortBy == "Priority")">@L["By urgency"]</option>
        <option value="Trade" selected="@(Model.SortBy == "Trade")">@L["By trade"]</option>
        <option value="Score" selected="@(Model.SortBy == "Score")">@L["By AI score"]</option>
    </select>
</form>

@if (Model.Findings.Count == 0)
{
    <div class="rl-info-box rl-info-box--warn">
        <i class="fas fa-circle-exclamation"></i>
        <p>@L["No findings match this filter. Try \"All\" or upload a more detailed inspection report."]</p>
    </div>
}
else
{
    <form id="prioritiesForm" asp-action="Priorities" method="post" class="rl-invite-form">
        @Html.AntiForgeryToken()

        <div class="rl-insp-select-bar">
            <span id="inspSelectedCount">@L.T("{0} issues found — tap to select", Model.TotalFindings)</span>
            <div class="rl-insp-select-actions">
                <button type="button" class="rl-insp-link-btn" id="inspSelectAll">@L["Select all"]</button>
                <button type="button" class="rl-insp-link-btn" id="inspClearAll">@L["Clear selection"]</button>
            </div>
        </div>

        <div class="rl-insp-findings-list">
            @foreach (var finding in Model.Findings)
            {
                <label class="rl-insp-finding-card rl-insp-finding-card--@finding.PriorityCss">
                    <input type="checkbox" name="selectedFindingIds" value="@finding.Id" />

                    <div class="rl-insp-finding-card-head">
                        <span class="rl-insp-finding-alert rl-insp-finding-alert--@finding.PriorityCss">
                            <i class="fas fa-circle-exclamation"></i>
                        </span>
                        <div class="rl-insp-finding-head-copy">
                            <strong>@UiDisplayLocalization.Localize(L, finding.Title)</strong>
                            <div class="rl-insp-finding-badges">
                                @if (!string.IsNullOrWhiteSpace(finding.SourceSectionNumber))
                                {
                                    <span class="rl-insp-section-index" title="@L["Report index"]">@finding.SourceSectionNumber</span>
                                }
                                <span class="rl-priority-tag rl-priority-tag--@finding.PriorityCss">@L[finding.Priority]</span>
                                <span class="rl-insp-ai-score"><i class="fas fa-check"></i> @finding.AiScore</span>
                            </div>
                        </div>
                        <span class="rl-insp-finding-check"><i class="fas fa-check"></i></span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(finding.Description))
                    {
                        <p class="rl-insp-finding-desc">@UiDisplayLocalization.Localize(L, finding.Description)</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(finding.SourceExcerpt)
                         || finding.SourcePage is > 0
                         || !string.IsNullOrWhiteSpace(finding.SourceSection)
                         || !string.IsNullOrWhiteSpace(finding.SourceSectionNumber))
                    {
                        <div class="rl-insp-report-source">
                            <h4>@L["Found in Inspection Report"]</h4>

                            <div class="rl-insp-report-grid">
                                @if (!string.IsNullOrWhiteSpace(finding.SourceSectionNumber))
                                {
                                    <div class="rl-insp-report-field rl-insp-report-field--index">
                                        <i class="fas fa-list-ol"></i>
                                        <span><small>@L["Report index"]</small><strong>@finding.SourceSectionNumber</strong></span>
                                    </div>
                                }
                                <div class="rl-insp-report-field">
                                    <i class="fas fa-calendar"></i>
                                    <span><small>@L["Report date"]</small><strong>@Model.ReportDateLabel</strong></span>
                                </div>
                                @if (finding.SourcePage is > 0)
                                {
                                    <div class="rl-insp-report-field">
                                        <i class="fas fa-file-lines"></i>
                                        <span><small>@L["Page"]</small><strong>@finding.SourcePage</strong></span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(finding.TradeLabel))
                                {
                                    <div class="rl-insp-report-field">
                                        <i class="fas fa-layer-group"></i>
                                        <span><small>@L["Section"]</small><strong>@UiDisplayLocalization.Localize(L, finding.TradeLabel)</strong></span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(finding.SourceSection))
                                {
                                    <div class="rl-insp-report-field">
                                        <i class="fas fa-bookmark"></i>
                                        <span><small>@L["Subsection"]</small><strong>@UiDisplayLocalization.Localize(L, finding.SourceSection)</strong></span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(finding.SourceLineItem))
                                {
                                    <div class="rl-insp-report-field rl-insp-report-field--wide">
                                        <i class="fas fa-list-ul"></i>
                                        <span><small>@L["Line / Item"]</small><strong>@UiDisplayLocalization.Localize(L, finding.SourceLineItem)</strong></span>
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(finding.SourceExcerpt))
                            {
                                <div class="rl-insp-inspector-wording">
                                    <span class="rl-insp-inspector-wording-label"><i class="fas fa-quote-left"></i> @L["Inspector wording"]</span>
                                    <blockquote class="rl-insp-finding-quote">@UiDisplayLocalization.Localize(L, finding.SourceExcerpt)</blockquote>
                                </div>
                            }

                            @if (finding.SourcePage is > 0 && !string.IsNullOrWhiteSpace(Model.ReportPdfUrl))
                            {
                                <a asp-action="ViewReport"
                                   asp-route-page="@finding.SourcePage"
                                   asp-route-filter="@Model.ActiveFilter"
                                   asp-route-sort="@Model.SortBy"
                                   class="rl-insp-open-page-btn">
                                    <i class="fas fa-file-pdf"></i>
                                    @L.T("Open report page {0}", finding.SourcePage)
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            }

                            <p class="rl-insp-source-confirmed"><i class="fas fa-circle-check"></i> @L["Source confirmed from report PDF"]</p>
                        </div>
                    }

                    <div class="rl-insp-finding-meta">
                        <span class="rl-trade-chip rl-trade-chip--@finding.TradeCss">
                            <i class="fas @finding.TradeIcon"></i> @UiDisplayLocalization.Localize(L, finding.TradeLabel)
                        </span>
                    </div>
                </label>
            }
        </div>

        <div class="rl-info-box">
            <i class="fas fa-circle-info"></i>
            <p>@L["Select the issues you want to include. Only checked findings will be grouped by trade and sent to matching INDOR providers."]</p>
        </div>

        <div class="rl-insp-sticky-actions">
            <a asp-action="Analyze" class="rl-invite-cancel"><i class="fas fa-chevron-left"></i> @L["Back"]</a>
            <button type="submit" id="inspSendProvidersBtn" class="ob-btn ob-btn-primary rl-insp-send-btn">
                <i class="fas fa-paper-plane"></i> @L["Send to providers"]
            </button>
        </div>
        <div class="rl-insp-change-doc-wrap">
            @await Html.PartialAsync("_ChangeInspectionDocument")
        </div>
    </form>
}

@if (Model.Findings.Count == 0)
{
    <div class="rl-invite-actions">
        <a asp-action="Analyze" class="rl-invite-cancel"><i class="fas fa-chevron-left"></i> @L["Back"]</a>
    </div>
}

@section Scripts {
<script>
    (function () {
        const form = document.getElementById('prioritiesForm');
        if (!form) return;

        const checkboxes = form.querySelectorAll('input[name="selectedFindingIds"]');
        const countEl = document.getElementById('inspSelectedCount');
        const sendBtn = document.getElementById('inspSendProvidersBtn');
        const totalIssues = @Model.TotalFindings;
        const msgTapToSelect = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L.T("{0} issues found — tap to select", Model.TotalFindings)));
        const msgSelectedTpl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["{0} of {1} selected"]));
        const msgSelectOne = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Select at least one issue"]));
        const msgSendTpl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Send to providers ({0})"]));
        const msgPreparing = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Preparing providers..."]));

        function formatTpl(template, ...args) {
            return String(template).replace(/\{(\d+)\}/g, function (_, i) { return args[i] ?? ''; });
        }

        function updateUi() {
            const selected = Array.from(checkboxes).filter(c => c.checked).length;
            if (countEl) {
                countEl.textContent = selected === 0
                    ? msgTapToSelect
                    : formatTpl(msgSelectedTpl, selected, totalIssues);
            }
            checkboxes.forEach(cb => {
                cb.closest('.rl-insp-finding-card')?.classList.toggle('is-selected', cb.checked);
            });
            if (sendBtn) {
                sendBtn.disabled = selected === 0;
                sendBtn.innerHTML = selected === 0
                    ? '<i class="fas fa-paper-plane"></i> ' + msgSelectOne
                    : '<i class="fas fa-paper-plane"></i> ' + formatTpl(msgSendTpl, selected);
            }
        }

        checkboxes.forEach(cb => cb.addEventListener('change', updateUi));

        document.getElementById('inspSelectAll')?.addEventListener('click', () => {
            checkboxes.forEach(c => { c.checked = true; });
            updateUi();
        });

        document.getElementById('inspClearAll')?.addEventListener('click', () => {
            checkboxes.forEach(c => { c.checked = false; });
            updateUi();
        });

        form.addEventListener('submit', (e) => {
            const selected = Array.from(checkboxes).filter(c => c.checked).length;
            if (selected === 0) {
                e.preventDefault();
                return;
            }
            if (sendBtn) {
                sendBtn.disabled = true;
                sendBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ' + msgPreparing;
            }
        });

        updateUi();
    })();
</script>
}
