@model IndorMvcApp.ViewModels.RealtorInspectionAnalyzeViewModel



@if (TempData["AnalysisError"] is string analysisError && !string.IsNullOrWhiteSpace(analysisError))
{
    <div class="rl-info-box rl-info-box--warn">
        <i class="fas fa-triangle-exclamation"></i>
        <p>@analysisError</p>
    </div>
}

<div class="rl-info-box rl-info-box--ai">

    <i class="fas fa-wand-magic-sparkles"></i>

    <p>@Model.AnalysisIntroMessage</p>

</div>



<div class="rl-analyze-card">

    <div class="rl-analyze-progress-ring" style="--progress: @Model.AnalysisProgress">

        <span>@Model.AnalysisProgress%</span>

        <small>Analyzing</small>

    </div>

    <div class="rl-analyze-meta">

        <strong>@Model.ReportFileName</strong>

        <span>@Model.PropertyDisplay</span>

        <span>@Model.ReportCountLabel · @Model.UploadedLabel</span>

    </div>

</div>



<ul class="rl-analyze-tasks">

    @foreach (var task in Model.Tasks)

    {

        var icon = task.Status switch

        {

            "Done" => "fa-circle-check",

            "InProgress" => "fa-circle-notch fa-spin",

            _ => "fa-circle"

        };

        <li class="rl-analyze-task rl-analyze-task--@task.Status.ToLowerInvariant()">

            <i class="fas @icon"></i>

            <span>

                <strong>@task.Label</strong>

                <small>@task.Detail</small>

            </span>

        </li>

    }

</ul>



@if (Model.DetectedCategories.Count > 0)

{

    <h2 class="rl-invite-section-title">Detected categories (so far)</h2>

    <div class="rl-trade-chips">

        @foreach (var cat in Model.DetectedCategories)

        {

            <span class="rl-trade-chip rl-trade-chip--@cat.Css"><i class="fas @cat.Icon"></i> @cat.Label</span>

        }

    </div>

}



<div class="rl-analyze-actions" id="analyzeActions">
    @if (Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Complete)
    {
        <form asp-action="Analyze" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" name="action" value="continue" class="ob-btn ob-btn-primary rl-analyze-btn rl-analyze-btn--full">
                <strong><i class="fas fa-list-check"></i> View AI findings</strong>
                <span>Review issues, urgency, and priority before sending to providers.</span>
            </button>
        </form>
    }
    else if (Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Failed)
    {
        <div class="rl-info-box rl-info-box--warn" id="analyzeErrorBox">
            <i class="fas fa-triangle-exclamation"></i>
            <p>@(string.IsNullOrWhiteSpace(Model.AnalysisSummary) ? "Analysis could not be completed." : Model.AnalysisSummary)</p>
        </div>
        <button type="button" id="analyzeRetryBtn" class="ob-btn ob-btn-primary rl-analyze-btn rl-analyze-btn--full">
            <strong><i class="fas fa-rotate-right"></i> Retry analysis</strong>
            <span>Run AI extraction again on your inspection report.</span>
        </button>
    }
    else
    {
        <div class="rl-analyze-running">
            <i class="fas fa-wand-magic-sparkles fa-spin"></i>
            <p>@Model.AnalysisRunningMessage</p>
        </div>
        <form asp-action="Analyze" method="post" class="rl-analyze-secondary">
            @Html.AntiForgeryToken()
            <button type="submit" name="action" value="background" class="ob-btn ob-btn-outline rl-analyze-btn">
                <strong>Run in background</strong>
                <span>Return to dashboard — we'll keep analyzing.</span>
            </button>
        </form>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var isComplete = @(Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Complete ? "true" : "false");
            var isFailed = @(Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Failed ? "true" : "false");
            if (isComplete) return;

            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            var pollMs = 4000;

            function runAnalysis() {
                return fetch('@Url.Action("RunAnalysis", "RealtorInspectionUpload")', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token,
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: '__RequestVerificationToken=' + encodeURIComponent(token || '')
                }).then(function (r) { return r.json(); });
            }

            function poll() {
                runAnalysis()
                .then(function (data) {
                    var ring = document.querySelector('.rl-analyze-progress-ring span');
                    if (ring && data.progress) ring.textContent = data.progress + '%';
                    if (data.complete) {
                        window.location.reload();
                        return;
                    }
                    if (data.failed) {
                        window.location.reload();
                        return;
                    }
                    setTimeout(poll, pollMs);
                })
                .catch(function () { setTimeout(poll, pollMs * 2); });
            }

            var retryBtn = document.getElementById('analyzeRetryBtn');
            if (retryBtn) {
                retryBtn.addEventListener('click', function () {
                    retryBtn.disabled = true;
                    runAnalysis().then(function () { window.location.reload(); });
                });
                return;
            }

            if (!isFailed) {
                setTimeout(poll, 800);
            }
        })();
    </script>
}

