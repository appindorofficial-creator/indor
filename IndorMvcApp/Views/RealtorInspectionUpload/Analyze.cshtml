@model IndorMvcApp.ViewModels.RealtorInspectionAnalyzeViewModel



@if (TempData["AnalysisError"] is string analysisError && !string.IsNullOrWhiteSpace(analysisError))
{
    <div class="rl-info-box rl-info-box--warn">
        <i class="fas fa-triangle-exclamation"></i>
        <p>@analysisError</p>
    </div>
}

<div class="rl-info-box rl-info-box--ai">

    <i class="fas fa-wand-magic-sparkles"></i>

    <p>@Model.AnalysisIntroMessage</p>

</div>



<div class="rl-analyze-card">

    <div class="rl-analyze-progress-ring" style="--progress: @Model.AnalysisProgress">

        <span>@Model.AnalysisProgress%</span>

        <small>@(Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Failed ? L["Stopped"] : L["Analyzing"])</small>

    </div>

    <div class="rl-analyze-meta">

        <strong>@Model.ReportFileName</strong>

        <span>@Model.PropertyDisplay</span>

        <span>@Model.ReportCountLabel · @Model.UploadedLabel</span>

    </div>

</div>



<ul class="rl-analyze-tasks">

    @foreach (var task in Model.Tasks)

    {

        var icon = task.Status switch

        {

            "Done" => "fa-circle-check",

            "InProgress" => "fa-circle-notch fa-spin",

            _ => "fa-circle"

        };

        <li class="rl-analyze-task rl-analyze-task--@task.Status.ToLowerInvariant()">

            <i class="fas @icon"></i>

            <span>

                <strong>@L[task.Label]</strong>
                <small>@L[task.Detail]</small>

            </span>

        </li>

    }

</ul>



@if (Model.DetectedCategories.Count > 0)

{

    <h2 class="rl-invite-section-title">@L["Detected categories (so far)"]</h2>

    <div class="rl-trade-chips">

        @foreach (var cat in Model.DetectedCategories)

        {

            <span class="rl-trade-chip rl-trade-chip--@cat.Css"><i class="fas @cat.Icon"></i> @cat.Label</span>

        }

    </div>

}



<div class="rl-analyze-actions" id="analyzeActions">
    @await Html.PartialAsync("_ChangeInspectionDocument")
    @if (Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Complete)
    {
        <form asp-action="Analyze" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" name="action" value="continue" class="ob-btn ob-btn-primary rl-analyze-btn rl-analyze-btn--full">
                <strong><i class="fas fa-list-check"></i> @L["View AI findings"]</strong>
                <span>@L["Review issues, urgency, and priority before sending to providers."]</span>
            </button>
        </form>
    }
    else if (Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Failed)
    {
        <div class="rl-info-box rl-info-box--warn" id="analyzeErrorBox">
            <i class="fas fa-triangle-exclamation"></i>
            <p>@(string.IsNullOrWhiteSpace(Model.AnalysisSummary) ? L["Analysis could not be completed."] : Model.AnalysisSummary)</p>
        </div>
        <button type="button" id="analyzeRetryBtn" class="ob-btn ob-btn-primary rl-analyze-btn rl-analyze-btn--full">
            <strong><i class="fas fa-rotate-right"></i> @L["Retry analysis"]</strong>
            <span>@L["Run AI extraction again on your inspection report."]</span>
        </button>
    }
    else
    {
        <div class="rl-analyze-running">
            <i class="fas fa-wand-magic-sparkles fa-spin"></i>
            <p>@Model.AnalysisRunningMessage</p>
        </div>
        <form asp-action="Analyze" method="post" class="rl-analyze-secondary">
            @Html.AntiForgeryToken()
            <button type="submit" name="action" value="background" class="ob-btn ob-btn-outline rl-analyze-btn">
                <strong>@L["Run in background"]</strong>
                <span>@L["Return to dashboard — we'll keep analyzing."]</span>
            </button>
        </form>
    }
</div>

@section Scripts {
    <script>
        (function () {
            var isComplete = @(Model.AnalysisStatus == IndorMvcApp.Models.RealtorInspectionAnalysisStatuses.Complete ? "true" : "false");
            if (isComplete) return;

            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            var pollMs = 4000;
            var actionsEl = document.getElementById('analyzeActions');
            var runningHtml = actionsEl
                ? actionsEl.querySelector('.rl-analyze-running')?.outerHTML
                    || '<div class="rl-analyze-running"><i class="fas fa-wand-magic-sparkles fa-spin"></i><p>@L["INDOR AI is reading your report and extracting repair items."]</p></div>'
                : '';

            function updateProgress(progress) {
                var ring = document.querySelector('.rl-analyze-progress-ring');
                var label = ring && ring.querySelector('span');
                var status = ring && ring.querySelector('small');
                if (ring && typeof progress === 'number') {
                    ring.style.setProperty('--progress', progress);
                }
                if (label) label.textContent = progress + '%';
                if (status) status.textContent = '@L["Analyzing"]';
            }

            function showRunningState() {
                var errorBox = document.getElementById('analyzeErrorBox');
                var retryBtn = document.getElementById('analyzeRetryBtn');
                if (errorBox) errorBox.remove();
                if (retryBtn) retryBtn.remove();
                if (actionsEl && !actionsEl.querySelector('.rl-analyze-running')) {
                    actionsEl.insertAdjacentHTML('beforeend', runningHtml);
                }
                updateProgress(10);
            }

            function postAnalysis(url) {
                return fetch(url, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token,
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: '__RequestVerificationToken=' + encodeURIComponent(token || '')
                }).then(function (r) {
                    if (!r.ok) {
                        throw new Error('Analysis request failed (' + r.status + ')');
                    }
                    return r.json();
                });
            }

            function runAnalysis() {
                return postAnalysis('@Url.Action("RunAnalysis", "RealtorInspectionUpload")');
            }

            function retryAnalysis() {
                return postAnalysis('@Url.Action("RetryAnalysis", "RealtorInspectionUpload")');
            }

            function poll() {
                runAnalysis()
                .then(function (data) {
                    if (typeof data.progress === 'number') {
                        updateProgress(data.progress);
                    }
                    if (data.complete || data.failed) {
                        window.location.reload();
                        return;
                    }
                    setTimeout(poll, pollMs);
                })
                .catch(function () { setTimeout(poll, pollMs * 2); });
            }

            var retryBtn = document.getElementById('analyzeRetryBtn');
            if (retryBtn) {
                retryBtn.addEventListener('click', function () {
                    retryBtn.disabled = true;
                    showRunningState();
                    retryAnalysis()
                        .then(function (data) {
                            if (typeof data.progress === 'number') {
                                updateProgress(data.progress);
                            }
                            if (data.complete || data.failed) {
                                window.location.reload();
                                return;
                            }
                            setTimeout(poll, pollMs);
                        })
                        .catch(function () {
                            retryBtn.disabled = false;
                            if (actionsEl && !document.getElementById('analyzeErrorBox')) {
                                actionsEl.insertAdjacentHTML('afterbegin',
                                    '<div class="rl-info-box rl-info-box--warn" id="analyzeErrorBox"><i class="fas fa-triangle-exclamation"></i><p>@L["Could not restart analysis. Please try again."]</p></div>');
                            }
                            var running = actionsEl && actionsEl.querySelector('.rl-analyze-running');
                            if (running) running.remove();
                        });
                });
                return;
            }

            setTimeout(poll, 800);
        })();
    </script>
}

