<form asp-controller="RealtorInspectionUpload" asp-action="ChangeDocument" method="post" class="rl-analyze-change-doc">
    @Html.AntiForgeryToken()
    <button type="submit" class="rl-analyze-change-doc-btn">
        <i class="fas fa-arrow-left" aria-hidden="true"></i> @L["Change document"]
    </button>
    <p class="rl-analyze-change-doc-hint">@L["Go back to upload a different PDF, scan, or photo."]</p>
</form>
