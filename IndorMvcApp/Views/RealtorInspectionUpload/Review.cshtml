@model IndorMvcApp.ViewModels.RealtorInspectionReviewViewModel



<div class="rl-info-box">

    <i class="fas fa-circle-info"></i>

    <p>@L["Before sending, review which findings will be sent, which trades are included, and how INDOR will create separate quote requests by trade."]</p>

</div>



<div class="rl-prop-summary-card">

    <img src="@(Model.PhotoUrl ?? "/welcome-house.png")" alt="" />

    <div>

        <strong>@Model.PropertyAddress</strong>

        @if (!string.IsNullOrWhiteSpace(Model.ClientName))

        {

            <span><i class="fas fa-user"></i> @Model.ClientName</span>

        }

        @if (!string.IsNullOrWhiteSpace(Model.CityRegion))

        {

            <span><i class="fas fa-location-dot"></i> @Model.CityRegion</span>

        }

    </div>

</div>



<div class="rl-review-card">

    <div class="rl-review-row"><span class="rl-review-label">@L["Findings selected"]</span><strong>@Model.FindingsSelected</strong></div>

    <div class="rl-review-row"><span class="rl-review-label">@L["Urgent items"]</span><strong>@Model.UrgentItems</strong></div>

    <div class="rl-review-row"><span class="rl-review-label">@L["Trades included"]</span><span>@Model.TradesIncluded</span></div>

    <div class="rl-review-row"><span class="rl-review-label">@L["Providers selected"]</span><strong>@Model.ProvidersSelected</strong></div>

    <div class="rl-review-row"><span class="rl-review-label">@L["Response deadline"]</span><strong>@L.T("{0} hours", Model.ResponseDeadlineHours)</strong></div>

</div>



<h2 class="rl-invite-section-title">@L["Requests to be created"]</h2>

<div class="rl-review-card">

    @foreach (var req in Model.RequestsToCreate)

    {

        <div class="rl-review-request-row">

            <span><i class="fas fa-file-invoice"></i> @req.TradeLabel</span>

            <span class="rl-priority-tag rl-priority-tag--@req.PriorityCss">@req.PriorityTag</span>

            <span>@L.T(req.ProviderCount == 1 ? "{0} provider" : "{0} providers", req.ProviderCount)</span>

            <i class="fas fa-chevron-right"></i>

        </div>

    }

</div>



<form id="reviewForm" asp-action="CreateRequests" method="post">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="All" class="ob-summary"></div>

</form>



<div class="rl-info-box rl-info-box--muted">

    <i class="fas fa-circle-info"></i>

    <p>@L["INDOR creates separate requests by trade so each contractor receives only the relevant items."]</p>

</div>



<div class="rl-invite-actions">

    <a asp-action="Providers" class="rl-invite-cancel">@L["Back"]</a>

    <button type="submit" form="reviewForm" class="ob-btn ob-btn-primary">@L["Create Quote Requests"]</button>

</div>




