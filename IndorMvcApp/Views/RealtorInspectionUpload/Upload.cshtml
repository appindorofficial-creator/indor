@model IndorMvcApp.ViewModels.RealtorInspectionUploadViewModel
@using IndorMvcApp.Helpers
@using IndorMvcApp.Services
@{
    var maxFileBytes = RealtorInspectionUploadLimits.MaxFileBytes;
    var maxFileLabel = RealtorInspectionUploadLimits.MaxFileSizeLabel;
    var hasSavedProperties = Model.Properties.Count > 0;
    // New-property mode when explicitly selected, returning after validation with new details,
    // or when the realtor has no saved properties yet.
    var useNewProperty = Model.SelectedPropertyFileId is null or <= 0
        && (!hasSavedProperties
            || !string.IsNullOrWhiteSpace(Model.NewPropertyAddress)
            || !string.IsNullOrWhiteSpace(Model.NewPropertyCityRegion));
    var formErrors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(e => e.ErrorMessage))
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .Select(m => UiDisplayLocalization.Localize(L, m))
        .ToList();
}

<div class="rl-info-box">
    <i class="fas fa-circle-info"></i>
    <p>@L["First select the property. Then upload the report as a PDF, scanned pages, or photos."]</p>
</div>

<h2 class="rl-invite-section-title">@L["1. Select Property"]</h2>

<form asp-action="Upload" method="get" class="rl-search-form">
    <div class="rl-search-bar">
        <i class="fas fa-magnifying-glass"></i>
        <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search by address or first property numbers"]" />
    </div>
    <p class="rl-search-hint">@L["Search for a saved property or enter a new address."]</p>
</form>

<form id="inspUploadForm" asp-action="Upload" method="post" enctype="multipart/form-data" class="rl-invite-form" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary" hidden></div>
    @if (formErrors.Count > 0)
    {
        <div class="ob-summary" role="alert">
            <ul>
                @foreach (var msg in formErrors)
                {
                    <li>@msg</li>
                }
            </ul>
        </div>
    }
    <div id="inspClientError" class="ob-summary" role="alert" hidden></div>

    @if (hasSavedProperties)
    {
        var firstProp = true;
        @foreach (var prop in Model.Properties)
        {
            var selected = !useNewProperty
                && (Model.SelectedPropertyFileId == prop.Id
                    || ((Model.SelectedPropertyFileId is null or 0) && firstProp));
            firstProp = false;
            <label class="rl-property-pick rl-property-pick--card @(selected ? "is-selected" : "")">
                <input type="radio" name="propertyFileId" value="@prop.Id" @(selected ? "checked" : null) />
                <img src="@(prop.PhotoUrl ?? "/welcome-house.png")" alt="" class="rl-property-pick-thumb" />
                <span class="rl-property-pick-body">
                    <strong>@prop.DisplayAddress</strong>
                    @if (!string.IsNullOrWhiteSpace(prop.SpecsLabel))
                    {
                        <span>@prop.SpecsLabel</span>
                    }
                </span>
                <span class="rl-card-status rl-card-status--active">@L["Active"]</span>
            </label>
        }

        <label class="rl-property-pick rl-property-pick--card rl-property-pick--new @(useNewProperty ? "is-selected" : "")" id="inspNewPropertyPick">
            <input type="radio" name="propertyFileId" value="0" @(useNewProperty ? "checked" : null) />
            <span class="rl-property-pick-thumb rl-property-pick-thumb--icon" aria-hidden="true">
                <i class="fas fa-plus"></i>
            </span>
            <span class="rl-property-pick-body">
                <strong>@L["Or Add New Property"]</strong>
                <span>@L["Enter street address and city below"]</span>
            </span>
        </label>
    }
    else
    {
        <input type="hidden" name="propertyFileId" value="0" />
    }

    <div id="inspPropertyDetailsSection" @(useNewProperty || !hasSavedProperties ? null : "hidden")>
        <h2 class="rl-invite-section-title">@L["2. Property Details"]</h2>

        <div class="rl-property-fields">
            <label class="rl-field-icon">
                <i class="fas fa-location-dot" aria-hidden="true"></i>
                <input type="text"
                       name="newPropertyAddress"
                       id="newPropertyAddress"
                       value="@Model.NewPropertyAddress"
                       placeholder="@L["e.g. 123 Maple Street"]"
                       autocomplete="street-address"
                       aria-required="true" />
            </label>
            <label class="rl-field-icon">
                <i class="fas fa-building" aria-hidden="true"></i>
                <input type="text"
                       name="newPropertyCityRegion"
                       id="newPropertyCityRegion"
                       value="@Model.NewPropertyCityRegion"
                       placeholder="@L["e.g. Toronto, ON"]"
                       autocomplete="address-level2"
                       aria-required="true" />
            </label>
            <label class="rl-field-icon">
                <i class="fas fa-user" aria-hidden="true"></i>
                <input type="text"
                       name="newPropertyClientName"
                       value="@Model.NewPropertyClientName"
                       placeholder="@L["Client name (optional)"]"
                       autocomplete="name" />
            </label>
        </div>
    </div>

    <h2 class="rl-invite-section-title" id="inspAddReportTitle"
        data-title-with-details="@L["3. Add Report"]"
        data-title-without-details="@L["2. Add Report"]">@(useNewProperty || !hasSavedProperties ? L["3. Add Report"] : L["2. Add Report"])</h2>

    <div class="rl-upload-method-grid">
        <label class="rl-upload-method rl-upload-method--picker @(Model.UploadMethod == "Pdf" ? "is-selected" : "")">
            <input type="radio" name="uploadMethod" value="Pdf" @(Model.UploadMethod == "Pdf" ? "checked" : null) />
            <i class="fas fa-file-pdf rl-upload-method-icon rl-upload-method-icon--pdf"></i>
            <strong>@L["Upload PDF"]</strong>
            <span>@L["Best for full inspection reports."]</span>
        </label>
        <label class="rl-upload-method rl-upload-method--picker @(Model.UploadMethod == "Scan" ? "is-selected" : "")">
            <input type="radio" name="uploadMethod" value="Scan" @(Model.UploadMethod == "Scan" ? "checked" : null) />
            <i class="fas fa-camera rl-upload-method-icon"></i>
            <strong>@L["Scan Pages"]</strong>
            <span>@L["Use your camera to scan pages."]</span>
        </label>
        <label class="rl-upload-method rl-upload-method--picker @(Model.UploadMethod == "Photos" ? "is-selected" : "")">
            <input type="radio" name="uploadMethod" value="Photos" @(Model.UploadMethod == "Photos" ? "checked" : null) />
            <i class="fas fa-image rl-upload-method-icon"></i>
            <strong>@L["Add Photos"]</strong>
            <span>@L["Upload report photos or findings."]</span>
        </label>
    </div>

    <div class="rl-file-drop-wrap">
        <label class="rl-file-drop" id="rlFileDrop" for="reportFileInput">
            <input type="file" id="reportFileInput" name="reportFile" class="rl-file-drop-input" />
            <div class="rl-file-drop-body">
                <i class="fas fa-cloud-arrow-up" id="rlFileDropIcon"></i>
                <strong id="rlFileDropTitle">@L["Tap to choose your inspection report"]</strong>
                <span id="rlFileDropHint">@L.T("PDF recommended • Up to {0}", maxFileLabel)</span>
                <span id="rlFileDropName" class="rl-file-drop-name" hidden></span>
            </div>
        </label>
        <button type="button" id="rlFileRemove" class="rl-file-drop-remove" hidden aria-label="@L["Remove selected file"]">
            <i class="fas fa-xmark"></i>
        </button>
    </div>

    <div class="rl-info-box rl-info-box--ai">
        <i class="fas fa-wand-magic-sparkles"></i>
        <p>@L["INDOR AI reads your inspection report, detects findings, sorts them by urgency, and groups them by trade."]</p>
    </div>

    <div class="rl-invite-actions">
        <button type="button" class="rl-invite-cancel" id="inspCancelBtn">@L["Cancel"]</button>
        <button type="submit" id="inspContinueBtn" class="ob-btn ob-btn-primary">
            @L["Continue"] <i class="fas fa-chevron-right"></i>
        </button>
    </div>
</form>

<form id="inspCancelForm" asp-action="Cancel" method="post" hidden>
    @Html.AntiForgeryToken()
</form>

@section Scripts {
<div id="inspUploadI18n" hidden
     data-pdf-title="@L["Tap to choose your inspection report"]"
     data-pdf-hint="@L.T("PDF recommended • Up to {0}", maxFileLabel)"
     data-scan-title="@L["Tap to scan a page with your camera"]"
     data-scan-hint="@L.T("Use your rear camera • Up to {0}", maxFileLabel)"
     data-photos-title="@L["Tap to add report photos"]"
     data-photos-hint="@L.T("Select one or more images • Up to {0}", maxFileLabel)"
     data-files-selected="@L["{0} files selected"]"
     data-mb-selected="@L["{0} MB selected"]"
     data-error-property="@L["Select a property or enter the street address and city/state to continue."]"
     data-error-new-details="@L["Enter the street address and city/state to continue."]"
     data-error-file="@L["Add an inspection report PDF or image to continue."]"
     data-error-size="@L["The file is too large. Maximum size is {0}."]"
     data-uploading="@L["Uploading..."]"
     data-continue="@L["Continue"]"></div>
<script>
    (function () {
        const form = document.getElementById('inspUploadForm');
        const fileInput = document.getElementById('reportFileInput');
        const fileNameEl = document.getElementById('rlFileDropName');
        const fileTitleEl = document.getElementById('rlFileDropTitle');
        const fileHintEl = document.getElementById('rlFileDropHint');
        const fileDropIcon = document.getElementById('rlFileDropIcon');
        const fileRemoveBtn = document.getElementById('rlFileRemove');
        const clientError = document.getElementById('inspClientError');
        const continueBtn = document.getElementById('inspContinueBtn');
        const cancelBtn = document.getElementById('inspCancelBtn');
        const cancelForm = document.getElementById('inspCancelForm');
        const propertyRadios = form.querySelectorAll('input[name="propertyFileId"][type="radio"]');
        const detailsSection = document.getElementById('inspPropertyDetailsSection');
        const addReportTitle = document.getElementById('inspAddReportTitle');
        const newAddressInput = form.querySelector('input[name="newPropertyAddress"]');
        const newCityInput = form.querySelector('input[name="newPropertyCityRegion"]');
        const newClientInput = form.querySelector('input[name="newPropertyClientName"]');
        const searchInput = document.querySelector('.rl-search-form input[name="q"]');
        const methodRadios = form.querySelectorAll('.rl-upload-method--picker input[type=radio]');
        const maxFileBytes = @maxFileBytes;
        const maxFileLabel = '@maxFileLabel';
        const i18n = document.getElementById('inspUploadI18n')?.dataset || {};
        const methodCopy = {
            Pdf: {
                title: i18n.pdfTitle || 'Tap to choose your inspection report',
                hint: (i18n.pdfHint || 'PDF recommended • Up to {0}').replace('{0}', maxFileLabel),
                icon: 'fa-cloud-arrow-up'
            },
            Scan: {
                title: i18n.scanTitle || 'Tap to scan a page with your camera',
                hint: (i18n.scanHint || 'Use your rear camera • Up to {0}').replace('{0}', maxFileLabel),
                icon: 'fa-camera'
            },
            Photos: {
                title: i18n.photosTitle || 'Tap to add report photos',
                hint: (i18n.photosHint || 'Select one or more images • Up to {0}').replace('{0}', maxFileLabel),
                icon: 'fa-image'
            }
        };

        function getSelectedPropertyId() {
            const checked = form.querySelector('input[name="propertyFileId"]:checked');
            if (checked) {
                return parseInt(checked.value, 10) || 0;
            }
            const hidden = form.querySelector('input[name="propertyFileId"][type="hidden"]');
            return hidden ? (parseInt(hidden.value, 10) || 0) : 0;
        }

        function isNewPropertyMode() {
            return getSelectedPropertyId() <= 0;
        }

        function syncPropertyDetailsVisibility() {
            const showDetails = isNewPropertyMode();
            if (detailsSection) {
                detailsSection.hidden = !showDetails;
            }
            if (addReportTitle) {
                addReportTitle.textContent = showDetails
                    ? (addReportTitle.dataset.titleWithDetails || '3. Add Report')
                    : (addReportTitle.dataset.titleWithoutDetails || '2. Add Report');
            }
        }

        function selectNewPropertyMode() {
            const newRadio = form.querySelector('input[name="propertyFileId"][value="0"]');
            if (newRadio) {
                newRadio.checked = true;
                document.querySelectorAll('.rl-property-pick').forEach(p => p.classList.remove('is-selected'));
                newRadio.closest('.rl-property-pick')?.classList.add('is-selected');
            }
            syncPropertyDetailsVisibility();
        }

        function getUploadMethod() {
            return form.querySelector('input[name="uploadMethod"]:checked')?.value || 'Pdf';
        }

        function updateMethodCopy() {
            const copy = methodCopy[getUploadMethod()] || methodCopy.Pdf;
            if (fileTitleEl) fileTitleEl.textContent = copy.title;
            if (fileDropIcon) fileDropIcon.className = `fas ${copy.icon}`;
            if (!fileInput.files?.length && fileHintEl) {
                fileHintEl.textContent = copy.hint;
            }
        }

        function showClientError(message) {
            clientError.textContent = message;
            clientError.hidden = false;
            clientError.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function clearClientError() {
            clientError.hidden = true;
            clientError.textContent = '';
        }

        function updateFileAccept() {
            const method = getUploadMethod();
            if (method === 'Pdf') {
                fileInput.accept = '.pdf,application/pdf';
                fileInput.removeAttribute('multiple');
                fileInput.removeAttribute('capture');
            } else if (method === 'Scan') {
                // Open the device camera directly so the user can scan report pages.
                fileInput.accept = 'image/*';
                fileInput.removeAttribute('multiple');
                fileInput.setAttribute('capture', 'environment');
            } else {
                // Photos: let the user pick one or more images from the gallery/camera.
                fileInput.accept = 'image/*';
                fileInput.setAttribute('multiple', 'multiple');
                fileInput.removeAttribute('capture');
            }
            updateMethodCopy();
        }

        function updateFileLabel() {
            const files = fileInput.files;
            const file = files?.[0];
            if (file) {
                if (files.length > 1) {
                    fileNameEl.textContent = (i18n.filesSelected || '{0} files selected').replace('{0}', files.length);
                    const totalBytes = Array.from(files).reduce((sum, f) => sum + f.size, 0);
                    fileHintEl.textContent = (i18n.mbSelected || '{0} MB selected').replace('{0}', (totalBytes / (1024 * 1024)).toFixed(1));
                } else {
                    fileNameEl.textContent = file.name;
                    fileHintEl.textContent = (i18n.mbSelected || '{0} MB selected').replace('{0}', (file.size / (1024 * 1024)).toFixed(1));
                }
                fileNameEl.hidden = false;
                document.getElementById('rlFileDrop')?.classList.add('has-file');
                if (fileRemoveBtn) fileRemoveBtn.hidden = false;
            } else {
                fileNameEl.hidden = true;
                updateMethodCopy();
                document.getElementById('rlFileDrop')?.classList.remove('has-file');
                if (fileRemoveBtn) fileRemoveBtn.hidden = true;
            }
        }

        function clearSelectedFile() {
            fileInput.value = '';
            if (fileNameEl) {
                fileNameEl.textContent = '';
            }
            updateFileLabel();
            clearClientError();
        }

        propertyRadios.forEach(r => {
            r.addEventListener('change', () => {
                document.querySelectorAll('.rl-property-pick').forEach(p => p.classList.remove('is-selected'));
                r.closest('.rl-property-pick')?.classList.add('is-selected');
                if (parseInt(r.value, 10) > 0) {
                    if (newAddressInput) newAddressInput.value = '';
                    if (newCityInput) newCityInput.value = '';
                    if (newClientInput) newClientInput.value = '';
                }
                syncPropertyDetailsVisibility();
                clearClientError();
            });
        });

        [newAddressInput, newCityInput].forEach(input => {
            input?.addEventListener('input', () => {
                if (input.value.trim()) {
                    selectNewPropertyMode();
                }
                clearClientError();
            });
        });

        methodRadios.forEach(r => {
            r.addEventListener('change', () => {
                document.querySelectorAll('.rl-upload-method').forEach(p => p.classList.remove('is-selected'));
                r.closest('.rl-upload-method')?.classList.add('is-selected');
                clearSelectedFile();
                updateFileAccept();
            });
        });

        fileInput.addEventListener('change', () => {
            updateFileLabel();
            clearClientError();
        });

        fileRemoveBtn?.addEventListener('mousedown', (e) => {
            e.preventDefault();
        });

        fileRemoveBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            clearSelectedFile();
        });

        cancelBtn?.addEventListener('click', () => cancelForm?.submit());

        form.addEventListener('submit', (e) => {
            clearClientError();

            const selectedId = getSelectedPropertyId();
            const hasSavedProperty = selectedId > 0;
            let hasNewAddress = (newAddressInput?.value?.trim().length ?? 0) > 0;
            let hasNewCity = (newCityInput?.value?.trim().length ?? 0) > 0;

            // If creating a new property and the address field is empty but search has a value, use it.
            if (!hasSavedProperty && !hasNewAddress && newAddressInput && (searchInput?.value?.trim().length ?? 0) > 0) {
                newAddressInput.value = searchInput.value.trim();
                hasNewAddress = true;
                selectNewPropertyMode();
            }

            hasNewCity = (newCityInput?.value?.trim().length ?? 0) > 0;
            const hasFile = (fileInput.files?.length ?? 0) > 0;

            if (!hasSavedProperty && !(hasNewAddress && hasNewCity)) {
                e.preventDefault();
                selectNewPropertyMode();
                showClientError(
                    hasNewAddress || hasNewCity
                        ? (i18n.errorNewDetails || 'Enter the street address and city/state to continue.')
                        : (i18n.errorProperty || 'Select a property or enter the street address and city/state to continue.')
                );
                return;
            }

            if (!hasFile) {
                e.preventDefault();
                showClientError(i18n.errorFile || 'Add an inspection report PDF or image to continue.');
                return;
            }

            const oversized = Array.from(fileInput.files).some(f => f.size > maxFileBytes);
            if (oversized) {
                e.preventDefault();
                showClientError((i18n.errorSize || 'The file is too large. Maximum size is {0}.').replace('{0}', maxFileLabel));
                return;
            }

            continueBtn.disabled = true;
            continueBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ' + (i18n.uploading || 'Uploading...');
        });

        syncPropertyDetailsVisibility();
        updateFileAccept();
        updateFileLabel();
        updateMethodCopy();
    })();
</script>
}
