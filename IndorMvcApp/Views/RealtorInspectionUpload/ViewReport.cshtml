@model IndorMvcApp.ViewModels.RealtorInspectionReportViewViewModel
@{
    Layout = "_RealtorLayout";
    ViewData["Title"] = "Inspection Report";
    ViewBag.NavActive = "home";
}

<div class="rl-dash-shell rl-insp-report-view-page">
    <header class="rl-listing-detail-head">
        <a href="@Model.BackUrl" class="rl-listing-detail-back" aria-label="Back to inspection findings">
            <i class="fas fa-chevron-left"></i>
        </a>
        <div class="rl-listing-detail-head-copy">
            <h1>@Model.ReportFileName</h1>
            <p>@(Model.SourcePage is > 0 ? $"Page {Model.SourcePage}" : "Inspection report")</p>
        </div>
    </header>

    <iframe src="@Model.ReportUrl"
            class="rl-insp-report-frame"
            title="@Model.ReportFileName"
            loading="lazy"></iframe>
</div>
