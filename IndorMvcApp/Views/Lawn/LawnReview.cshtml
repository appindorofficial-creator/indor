@model IndorMvcApp.ViewModels.LawnReviewViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("LawnSchedule", "Lawn", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;
}

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="review-summary-list">
        <article class="review-summary-card">
            <span class="review-summary-icon"><i class="fas fa-seedling"></i></span>
            <div><span class="k">Service</span><strong>@Model.ServiceName</strong></div>
        </article>
        <article class="review-summary-card">
            <span class="review-summary-icon"><i class="fas fa-rotate"></i></span>
            <div><span class="k">Frequency</span><strong>@Model.FrequencyLabel</strong></div>
        </article>
        <article class="review-summary-card">
            <span class="review-summary-icon"><i class="fas fa-house"></i></span>
            <div><span class="k">Area</span><strong>@Model.AreaLabel</strong></div>
        </article>
        <article class="review-summary-card">
            <span class="review-summary-icon"><i class="fas fa-calendar"></i></span>
            <div><span class="k">First visit</span><strong>@Model.ScheduledLabel</strong></div>
        </article>
        <article class="review-summary-card">
            <span class="review-summary-icon"><i class="fas fa-bell"></i></span>
            <div><span class="k">Reminder</span><strong>@Model.ReminderLabel</strong></div>
        </article>
        <article class="review-summary-card">
            <span class="review-summary-icon"><i class="fas fa-location-dot"></i></span>
            <div><span class="k">Address</span><strong>@Model.DireccionPropiedad</strong></div>
        </article>
    </div>

    @if (!Model.IsReminderOnly)
    {
        <div class="field-card">
            <span class="field-label">Price breakdown</span>
            <div class="breakdown-line">
                <span class="left"><i class="fas fa-seedling"></i> Base service</span>
                <span>$@Model.PrecioBase.ToString("0.00")</span>
            </div>
            @foreach (var line in Model.AddonLines)
            {
                <div class="breakdown-line">
                    <span class="left"><i class="fas @line.Icon"></i> @line.Label</span>
                    <span>$@line.Amount.ToString("0.00")</span>
                </div>
            }
            @if (Model.DescuentoSuscripcion > 0)
            {
                <div class="breakdown-line discount">
                    <span class="left"><i class="fas fa-tag"></i> Subscription discount</span>
                    <span>-$@Model.DescuentoSuscripcion.ToString("0.00")</span>
                </div>
            }
            <div class="breakdown-total">
                <strong>Total</strong>
                <span class="value">$@Model.PrecioTotal.ToString("0.00") USD</span>
            </div>
        </div>
    }

    <form asp-action="LawnReview" asp-route-id="@Model.SolicitudId" method="post">
        <button type="submit" name="action" value="continue" class="btn-primary">
            @(Model.IsReminderOnly ? "Activate reminder" : "Confirm service")
        </button>
        <button type="submit" name="action" value="back" class="btn-outline">Edit</button>
    </form>
