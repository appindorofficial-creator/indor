@model IndorMvcApp.ViewModels.LawnServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home", new { fragment = "home-care-essentials" });
}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="lawn-hero-icon"><i class="fas fa-seedling"></i></span>
        </div>
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@Model.LandingTitulo</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@Model.LandingTagline</div>
            }
        </div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="includes-box">
            <div class="includes-label">What's included</div>
            <ul>
                @foreach (var item in Model.IncludedItems)
                {
                    <li><i class="fas @item.Icon"></i><span>@item.Text</span></li>
                }
            </ul>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.PrecioTexto))
    {
        <div class="lawn-price-row">
            <span class="prefix">Starting at</span>
            <span class="amount">$@Model.PrecioDesde.ToString("0")</span>
            <span class="prefix">USD</span>
        </div>
    }

    <div class="reminder-card">
        <div class="reminder-card-head">
            <span class="reminder-icon"><i class="fas fa-bell"></i></span>
            <div>
                <strong>@Model.ReminderBannerTitulo</strong>
                <p>@Model.ReminderBannerTexto</p>
            </div>
            <label class="toggle-switch">
                <input type="checkbox" id="reminderToggle" @(Model.RecordatorioActivo ? "checked" : null) />
                <span class="toggle-slider"></span>
            </label>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="LawnService" method="post" id="serviceForm">
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="RecordatorioActivo" id="RecordatorioActivo" value="@(Model.RecordatorioActivo ? "true" : "false")" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-sliders"></i> @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
        <button type="submit" name="action" value="remindOnly" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-bell"></i> @Model.RemindOnlyCtaTexto
        </button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTexto))
    {
        <div class="info-box-blue" style="margin-top:14px;">
            <i class="fas fa-circle-info"></i>
            <span>@Model.InfoBoxTexto</span>
        </div>
    }

@section Scripts {
<script>
    (function () {
        const toggle = document.getElementById('reminderToggle');
        const hidden = document.getElementById('RecordatorioActivo');
        if (toggle && hidden) {
            toggle.addEventListener('change', () => {
                hidden.value = toggle.checked ? 'true' : 'false';
            });
        }
    })();

</script>
}
