@model IndorMvcApp.ViewModels.LawnScheduleViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("LawnSetup", "Lawn", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;
}

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="LawnSchedule" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MicroservicioId" />
        <input type="hidden" asp-for="FechaPreferida" id="FechaPreferida" />
        <input type="hidden" asp-for="VentanaHorario" id="VentanaHorario" />
        <input type="hidden" asp-for="RecordatorioActivo" id="RecordatorioActivo" value="@(Model.RecordatorioActivo ? "true" : "false")" />
        <input type="hidden" asp-for="RecordatorioAvisoDias" id="RecordatorioAvisoDias" />
        <input type="hidden" asp-for="RecordatorioCanales" id="RecordatorioCanales" value="@Model.RecordatorioCanales" />

        <div class="review-card">
            @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
            {
                <img src="@Url.Content("~" + Model.ImagenUrl)" alt="Lawn service" loading="lazy" />
            }
            <div class="review-list">
                <div class="review-item"><i class="fas fa-rotate"></i><span>@Model.FrequencyLabel</span></div>
                <div class="review-item"><i class="fas fa-house"></i><span>@Model.AreaLabel</span></div>
                <div class="review-item"><i class="fas fa-tag"></i><span>@L["Estimated total"] <strong>$@Model.PrecioTotal.ToString("0")</strong></span></div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Choose the first date"]</span>
            <div class="date-scroll" id="dateGroup">
                @foreach (var date in Model.DateOptions)
                {
                    <button type="button"
                            class="date-chip @(date.Selected ? "active" : "")"
                            data-date="@date.Date.ToString("yyyy-MM-dd")">
                        <div class="day">@date.DayLabel</div>
                        <div class="num">@date.DateLabel</div>
                        <div class="day" style="font-size:.62rem;">@date.MonthLabel</div>
                    </button>
                }
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Time window"]</span>
            <div class="time-grid" id="timeGroup">
                @foreach (var slot in Model.TimeWindowOptions)
                {
                    <button type="button" class="time-btn" data-value="@slot.Code">
                        @slot.Label<span class="check"><i class="fas fa-check"></i></span>
                    </button>
                }
            </div>
        </div>

        <div class="reminder-card">
            <div class="reminder-card-head">
                <span class="reminder-icon"><i class="fas fa-bell"></i></span>
                <div>
                    <strong>@L["Active reminder"]</strong>
                    <p>@L["We will notify you to schedule or repeat the service."]</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" id="reminderToggle" @(Model.RecordatorioActivo ? "checked" : null) />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="reminder-settings" id="reminderSettings">
                <div class="reminder-setting-row">
                    <span>@L["Repeat reminder"]</span>
                    <strong id="repeatLabel">@Model.FrequencyLabel</strong>
                </div>
                <div class="field-card" style="margin:10px 0 0;padding:10px 0 0;border:none;box-shadow:none;">
                    <span class="field-label" style="font-size:.78rem;">@L["Notify me"]</span>
                    <div class="segment-group" id="leadGroup">
                        @foreach (var lead in Model.ReminderLeadOptions)
                        {
                            <button type="button" class="segment-btn" data-value="@lead.Code">@lead.Label</button>
                        }
                    </div>
                </div>
                <div class="field-card" style="margin:0;padding:10px 0 0;border:none;box-shadow:none;">
                    <span class="field-label" style="font-size:.78rem;">@L["Reminder channel"]</span>
                    <div class="segment-group" id="channelGroup">
                        @foreach (var channel in Model.ReminderChannelOptions)
                        {
                            var selected = Model.RecordatorioCanales.Contains(channel.Code, StringComparison.OrdinalIgnoreCase);
                            <button type="button" class="segment-btn @(selected ? "active" : "")" data-value="@channel.Code">@channel.Label</button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">@L["Continue"]</button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>

@section Scripts {
<script>
    (function () {
        const channels = new Set((document.getElementById('RecordatorioCanales').value || 'Push').split('|').filter(Boolean));

        function initSingle(groupId, selector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' ' + selector).forEach(btn => {
                const val = btn.dataset.value || btn.dataset.date;
                if (val === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' ' + selector).forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value || btn.dataset.date;
                });
            });
        }

        initSingle('dateGroup', '.date-chip', 'FechaPreferida', '@Model.FechaPreferida.ToString("yyyy-MM-dd")');
        initSingle('timeGroup', '.time-btn', 'VentanaHorario', '@Model.VentanaHorario');
        initSingle('leadGroup', '.segment-btn', 'RecordatorioAvisoDias', '@Model.RecordatorioAvisoDias');

        document.querySelectorAll('#channelGroup .segment-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const code = btn.dataset.value;
                if (channels.has(code)) {
                    channels.delete(code);
                    btn.classList.remove('active');
                } else {
                    channels.add(code);
                    btn.classList.add('active');
                }
                if (channels.size === 0) {
                    channels.add('Push');
                    document.querySelector('#channelGroup .segment-btn[data-value="Push"]')?.classList.add('active');
                }
                document.getElementById('RecordatorioCanales').value = Array.from(channels).join('|');
            });
        });

        const toggle = document.getElementById('reminderToggle');
        const hiddenReminder = document.getElementById('RecordatorioActivo');
        const settings = document.getElementById('reminderSettings');
        function syncReminder() {
            const on = toggle.checked;
            hiddenReminder.value = on ? 'true' : 'false';
            settings.style.opacity = on ? '1' : '0.45';
            settings.style.pointerEvents = on ? 'auto' : 'none';
        }
        toggle.addEventListener('change', syncReminder);
        syncReminder();
    })();

</script>
}
