@model IndorMvcApp.ViewModels.LawnConfirmedViewModel
@{
    ViewData["Title"] = Model.IsReminderOnly ? L["Reminder activated - INDOR"] : L["Service scheduled - INDOR"];
    ViewData["WizardTitle"] = L["Booking Confirmed"];
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
}

<div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">
            @(Model.IsReminderOnly ? L["Your reminder is active!"] : L["Your service is scheduled!"])
        </h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">
            @if (Model.RecordatorioActivo)
            {
                <text>@L.T("We also activated your {0} reminder.", Model.FrequencyLabel.ToLower())</text>
            }
            else if (Model.IsReminderOnly)
            {
                <text>@L["We will notify you when it is time to schedule lawn care."]</text>
            }
            else
            {
                <text>@L["We sent your request to a local provider."]</text>
            }
        </p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-seedling"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@L.Catalog(Model.NombreServicio)</div></div></div>
        <div class="summary-row"><i class="fas fa-rotate"></i><div><div class="summary-label">@L["Frequency"]</div><div class="summary-value">@Model.FrequencyLabel</div></div></div>
        @if (!Model.IsReminderOnly)
        {
            <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">@L["Area"]</div><div class="summary-value">@Model.AreaLabel</div></div></div>
            <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Next visit"]</div><div class="summary-value">@Model.ScheduledLabel</div></div></div>
        }
        @if (Model.RecordatorioActivo)
        {
            <div class="summary-row"><i class="fas fa-bell"></i><div><div class="summary-label">@L["Next reminder"]</div><div class="summary-value">@Model.NextReminderLabel</div></div></div>
            <div class="summary-row"><i class="fas fa-mobile-screen"></i><div><div class="summary-label">@L["Notification method"]</div><div class="summary-value">@Model.NotificationMethodLabel</div></div></div>
        }
        @if (!Model.IsReminderOnly)
        {
            <div class="summary-row"><i class="fas fa-tag"></i><div><div class="summary-label">@L["Estimated total"]</div><div class="summary-value" style="color:#0066CC;font-size:1rem;">$@Model.PrecioTotal.ToString("0") @Model.Moneda</div></div></div>
        }
    </div>

    <div class="status-row">
        <span class="status-pill green"><i class="fas fa-check"></i> @L["Request received"]</span>
        @if (!Model.IsReminderOnly)
        {
            <span class="status-pill blue"><i class="fas fa-user-check"></i> @L["Assigning provider"]</span>
        }
        @if (Model.RecordatorioActivo)
        {
            <span class="status-pill purple"><i class="fas fa-bell"></i> @L["Reminder active"]</span>
        }
    </div>

    <a asp-controller="Home" asp-action="Index" asp-fragment="section-schedule" class="btn-primary">
        <i class="fas fa-calendar"></i> View schedule
    </a>
    <a asp-action="LawnSchedule" asp-route-id="@Model.SolicitudId" class="btn-outline"><i class="fas fa-gear"></i> @L["Manage reminder"]</a>
