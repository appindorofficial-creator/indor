@model IndorMvcApp.ViewModels.LawnConfirmedViewModel
@{
    ViewData["Title"] = "Service Requested - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_LawnStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">Service requested</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_LawnStepper", 4)

    <div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Your lawn service is booked!</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">We sent your request to a local provider.</p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-rotate"></i><div><div class="summary-value">@Model.SubscriptionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-value">@Model.AreaLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-leaf"></i><div><div class="summary-label">Add-ons</div><div class="summary-value">@Model.AddonsLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">Scheduled for</div><div class="summary-value">@Model.ScheduledLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-tag"></i><div><div class="summary-label">Estimated total</div><div class="summary-value" style="color:#0066CC;font-size:1rem;">$@Model.PrecioTotal.ToString("0") @Model.Moneda</div></div></div>
    </div>

    <div class="status-row">
        <span class="status-pill green"><i class="fas fa-check"></i> Request received</span>
        <span class="status-pill blue"><i class="fas fa-spinner"></i> Provider matching</span>
        <span class="status-pill purple"><i class="fas fa-bell"></i> Next reminder active</span>
    </div>

    <a asp-controller="Home" asp-action="Index" asp-fragment="section-schedule" class="btn-primary">
        <i class="fas fa-calendar"></i> View schedule <i class="fas fa-chevron-right"></i>
    </a>
    <a asp-action="LawnSetup" asp-route-id="@Model.SolicitudId" class="btn-outline"><i class="fas fa-pen"></i> Edit service</a>
</div>
</body>
</html>
