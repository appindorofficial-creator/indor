@await Html.PartialAsync("../Cleaning/_CleaningStyles")
<style>
    .lawn-stepper { display: flex; align-items: center; gap: 0; margin-bottom: 18px; }
    .lawn-stepper .line { flex: 1; height: 2px; background: #E5E7EB; }
    .lawn-stepper .line.done { background: #0066CC; }
    .lawn-step-dot { width: 28px; height: 28px; border-radius: 50%; border: 2px solid #CBD5E1; color: #94A3B8; background: #FFF; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; flex-shrink: 0; }
    .lawn-step-dot.active, .lawn-step-dot.done { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .lawn-hero-icon { position: absolute; top: 10px; left: 10px; width: 34px; height: 34px; border-radius: 10px; background: #0066CC; color: #FFF; display: flex; align-items: center; justify-content: center; font-size: 0.95rem; box-shadow: 0 4px 10px rgba(0,102,204,0.25); }
    .hero-wrap { position: relative; margin-bottom: 16px; }
    .hero-wrap .hero-img { margin-bottom: 0; }
    .includes-box { background: #F9FAFB; border: 1px solid #E5E7EB; border-radius: 14px; padding: 12px 14px; margin-bottom: 14px; }
    .includes-box .includes-label { font-size: 0.65rem; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; color: #6B7280; margin-bottom: 8px; }
    .includes-box li { list-style: none; display: flex; align-items: center; gap: 8px; font-size: 0.82rem; font-weight: 600; padding: 4px 0; }
    .includes-box li i { color: #0066CC; font-size: 0.72rem; }
    .lawn-price-row { display: flex; align-items: baseline; gap: 6px; margin-bottom: 14px; }
    .lawn-price-row .prefix { font-size: 0.68rem; font-weight: 700; letter-spacing: .8px; color: #6B7280; text-transform: uppercase; }
    .lawn-price-row .amount { font-size: 1.5rem; font-weight: 800; color: #0066CC; }
    .segment-group { display: flex; gap: 8px; flex-wrap: wrap; }
    .segment-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 999px; padding: 10px 14px; font-weight: 600; font-size: 0.82rem; color: #64748B; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .segment-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .area-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .area-card { border: 1.5px solid #E5E7EB; background: #FFF; border-radius: 14px; padding: 12px; cursor: pointer; position: relative; text-align: left; min-height: 110px; }
    .area-card.active { border-color: #0066CC; box-shadow: 0 0 0 1px rgba(0,102,204,0.15); }
    .area-card .radio { position: absolute; top: 10px; right: 10px; width: 18px; height: 18px; border-radius: 50%; border: 2px solid #CBD5E1; }
    .area-card.active .radio { border-color: #0066CC; background: #0066CC; box-shadow: inset 0 0 0 3px #FFF; }
    .area-card i.main { color: #0066CC; font-size: 1.1rem; margin-bottom: 8px; display: block; }
    .area-card .label { font-size: 0.78rem; font-weight: 700; line-height: 1.25; margin-bottom: 4px; }
    .area-card .price { font-size: 0.72rem; color: #64748B; font-weight: 600; }
    .sticky-total { position: sticky; bottom: 0; background: rgba(255,255,255,0.96); backdrop-filter: blur(6px); border-top: 1px solid #E5E7EB; padding: 12px 0 0; margin-top: 12px; }
    .sticky-total-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .sticky-total-row .label { font-size: 0.78rem; color: #64748B; font-weight: 600; }
    .sticky-total-row .value { font-size: 1.4rem; font-weight: 800; color: #0066CC; }
    .addon-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .addon-card { border: 1.5px solid #E5E7EB; background: #FFF; border-radius: 14px; padding: 12px; cursor: pointer; position: relative; min-height: 72px; display: flex; align-items: center; gap: 10px; }
    .addon-card.active { border-color: #0066CC; background: rgba(0,102,204,0.06); }
    .addon-card .check { position: absolute; top: 8px; right: 8px; width: 18px; height: 18px; border-radius: 50%; border: 2px solid #CBD5E1; display: flex; align-items: center; justify-content: center; font-size: 0.55rem; color: transparent; }
    .addon-card.active .check { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .addon-card .emoji { font-size: 1.2rem; width: 28px; text-align: center; flex-shrink: 0; }
    .addon-card .copy { flex: 1; min-width: 0; }
    .addon-card .copy strong { display: block; font-size: 0.76rem; line-height: 1.25; }
    .addon-card .copy span { font-size: 0.72rem; color: #0066CC; font-weight: 700; }
    .price-summary { background: #FFF; border: 1px solid #E5E7EB; border-radius: 16px; padding: 14px; margin-bottom: 14px; }
    .price-line { display: flex; justify-content: space-between; gap: 10px; font-size: 0.82rem; padding: 6px 0; }
    .price-line.sub { color: #64748B; font-size: 0.76rem; padding-left: 8px; }
    .price-line.discount { color: #15803D; }
    .price-line.total { border-top: 1px dashed #E5E7EB; margin-top: 8px; padding-top: 10px; font-weight: 800; font-size: 0.95rem; }
    .price-line.total .value { color: #0066CC; font-size: 1.2rem; }
    .review-card { background: #FFF; border: 1px solid #E5E7EB; border-radius: 16px; padding: 14px; margin-bottom: 14px; display: flex; gap: 12px; }
    .review-card img { width: 72px; height: 72px; border-radius: 12px; object-fit: cover; flex-shrink: 0; }
    .review-list { flex: 1; }
    .review-item { display: flex; align-items: flex-start; gap: 8px; font-size: 0.78rem; padding: 4px 0; line-height: 1.35; }
    .review-item i { color: #0066CC; width: 16px; margin-top: 2px; }
    .date-scroll { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; margin-bottom: 12px; }
    .date-chip { flex-shrink: 0; min-width: 52px; border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 10px 8px; text-align: center; cursor: pointer; }
    .date-chip.active { border-color: #0066CC; background: #0066CC; color: #FFF; }
    .date-chip .day { font-size: 0.68rem; font-weight: 600; opacity: 0.85; }
    .date-chip .num { font-size: 0.95rem; font-weight: 800; }
    .time-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .time-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px; font-weight: 600; font-size: 0.78rem; color: #64748B; cursor: pointer; text-align: center; position: relative; }
    .time-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .time-btn .check { position: absolute; top: 8px; right: 8px; color: #0066CC; font-size: 0.72rem; display: none; }
    .time-btn.active .check { display: block; }
    .breakdown-line { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; border-bottom: 1px solid #F1F5F9; font-size: 0.82rem; }
    .breakdown-line:last-child { border-bottom: none; }
    .breakdown-line .left { display: flex; align-items: center; gap: 8px; }
    .breakdown-line .left i { color: #0066CC; width: 16px; }
    .breakdown-line.discount .left, .breakdown-line.discount .right { color: #15803D; }
    .breakdown-total { display: flex; justify-content: space-between; align-items: center; padding-top: 12px; margin-top: 4px; border-top: 1px dashed #E5E7EB; }
    .breakdown-total .value { font-size: 1.3rem; font-weight: 800; color: #0066CC; }
    .status-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .status-pill { border-radius: 999px; padding: 6px 10px; font-size: 0.68rem; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; }
    .status-pill.green { background: rgba(34,197,94,0.12); color: #15803D; }
    .status-pill.blue { background: rgba(0,102,204,0.12); color: #0066CC; }
    .status-pill.purple { background: rgba(139,92,246,0.12); color: #6D28D9; }
</style>
