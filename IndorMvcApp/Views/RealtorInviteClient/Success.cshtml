@model IndorMvcApp.ViewModels.RealtorInviteSuccessViewModel
@{
    Layout = "_RealtorLayout";
    ViewData["Title"] = "Invitation Sent";
    ViewBag.NavActive = "clients";
}

<div class="rl-dash-shell">
    @await Html.PartialAsync("~/Views/Realtor/_RealtorTopbar.cshtml", new IndorMvcApp.ViewModels.RealtorPortalShellViewModel())

    <section class="rl-success-hero">
        <div class="rl-success-icon-wrap">
            <span class="rl-success-icon"><i class="fas fa-check"></i></span>
        </div>
        <h1>Invitation Sent</h1>
        <p>Your client has been invited successfully</p>
    </section>

    <div class="rl-success-card">
        <p>Invitation sent to <strong class="rl-success-name">@Model.FullName</strong></p>
        <div class="rl-success-detail"><i class="fas fa-envelope"></i> @Model.Email</div>
        @if (!string.IsNullOrWhiteSpace(Model.Phone))
        {
            <div class="rl-success-detail"><i class="fas fa-phone"></i> @Model.Phone</div>
        }
        <div class="rl-success-detail"><i class="fas fa-house"></i> @Model.PropertyDisplay</div>
        <div class="rl-success-detail">
            <i class="fas fa-clock"></i>
            <span class="rl-card-status rl-card-status--pending">@Model.StatusLabel</span>
        </div>
    </div>

    <div class="rl-success-links">
        <a asp-controller="Realtor" asp-action="Clients" class="rl-success-link-row">
            <i class="fas fa-eye"></i> View Pending Invitation <i class="fas fa-chevron-right"></i>
        </a>
        <button type="button" class="rl-success-link-row" id="copyInviteLink" data-link="@Model.InviteLink">
            <i class="fas fa-link"></i> Copy Invite Link <i class="fas fa-chevron-right"></i>
        </button>
        <a asp-controller="RealtorInviteClient" asp-action="ClientInfo" class="rl-success-link-row">
            <i class="fas fa-user-plus"></i> Invite Another Client <i class="fas fa-chevron-right"></i>
        </a>
    </div>

    <section class="rl-dash-section">
        <div class="rl-dash-section-head">
            <h2>Pending Invitations</h2>
            <a asp-controller="Realtor" asp-action="Clients" asp-route-filter="Pending">View all <i class="fas fa-chevron-right"></i></a>
        </div>
        @foreach (var inv in Model.PendingInvitations)
        {
            <article class="rl-invite-card">
                <span class="rl-invite-initials">@inv.Initials</span>
                <div>
                    <strong>@inv.FullName</strong>
                    <span>@inv.Email</span>
                    <span class="rl-card-status rl-card-status--pending">Invitation sent</span>
                </div>
                <a href="#" class="rl-resend-link">Resend</a>
            </article>
        }
    </section>

    <a asp-controller="Realtor" asp-action="Clients" class="ob-btn ob-btn-primary rl-done-btn">Done</a>
</div>

@section Scripts {
<script>
    document.getElementById('copyInviteLink')?.addEventListener('click', async function () {
        const link = this.dataset.link;
        try {
            await navigator.clipboard.writeText(link);
            this.querySelector('i.fa-link').className = 'fas fa-check';
        } catch { window.prompt('Copy invite link:', link); }
    });
</script>
}
