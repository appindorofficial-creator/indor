@model IndorMvcApp.ViewModels.RealtorInviteClientInfoViewModel
@using IndorMvcApp.Helpers
@{
    string FieldError(string key) => ViewData.ModelState[key]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
    var fullNameError = FieldError("fullName");
    var emailError = FieldError("email");
    var phoneError = FieldError("phone");
    var clientRoleError = FieldError("clientRole");
    var formErrors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(e => e.ErrorMessage))
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<form id="inviteClientForm" asp-action="ClientInfo" method="post" class="rl-invite-form" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary" role="alert"></div>

    <div class="rl-error-banner @(formErrors.Count == 0 ? "is-hidden" : null)" role="alert" id="inviteClientFormErrors">
        <i class="fas fa-circle-exclamation"></i>
        <div>
            <strong>@L["Please fix the following to continue:"]</strong>
            <ul class="rl-error-list" id="inviteClientFormErrorList">
                @foreach (var msg in formErrors)
                {
                    <li>@L[msg]</li>
                }
            </ul>
        </div>
    </div>

    <h2 class="rl-invite-section-title">@L["Client Information"]</h2>

    <label class="rl-field @(fullNameError.Length > 0 ? "is-error" : null)" for="inviteClientFullName">
        <i class="fas fa-user"></i>
        <input type="text"
               id="inviteClientFullName"
               name="fullName"
               value="@Model.FullName"
               placeholder="@L["Enter full name"]"
               autocomplete="name"
               aria-required="true"
               aria-invalid="@(fullNameError.Length > 0)"
               @(fullNameError.Length > 0 ? Html.Raw("aria-describedby=\"fullNameError\"") : null) />
    </label>
    <span class="rl-field-error" id="fullNameError" data-client-error="fullName">@L[fullNameError]</span>

    <label class="rl-field @(emailError.Length > 0 ? "is-error" : null)" for="inviteClientEmail">
        <i class="fas fa-envelope"></i>
        <input type="email"
               id="inviteClientEmail"
               name="email"
               value="@Model.Email"
               placeholder="@L["Enter email address (e.g. name@email.com)"]"
               autocomplete="email"
               inputmode="email"
               aria-required="true"
               aria-invalid="@(emailError.Length > 0)"
               @(emailError.Length > 0 ? Html.Raw("aria-describedby=\"emailError\"") : null) />
    </label>
    <span class="rl-field-error" id="emailError" data-client-error="email">@L[emailError]</span>

    <label class="rl-field @(phoneError.Length > 0 ? "is-error" : null)" for="inviteClientPhone">
        <i class="fas fa-phone"></i>
        <input type="text"
               id="inviteClientPhone"
               name="phone"
               value="@Model.Phone"
               placeholder="@L["Enter 10-digit phone number"]"
               autocomplete="tel"
               inputmode="numeric"
               maxlength="10"
               pattern="[0-9]{10}"
               data-phone-input
               data-phone-required="true"
               aria-required="true"
               aria-invalid="@(phoneError.Length > 0)"
               @(phoneError.Length > 0 ? Html.Raw("aria-describedby=\"phoneError\"") : null) />
    </label>
    <span class="rl-field-error" id="phoneError" data-client-error="phone">@L[phoneError]</span>

    <p class="rl-invite-section-title">@L["Client Role"] <span class="rl-required" aria-hidden="true">*</span></p>
    <div class="rl-role-pills">
        @foreach (var role in Model.ClientRoles)
        {
            <label class="rl-role-pill @(Model.ClientRole == role ? "is-selected" : "")">
                <input type="radio" name="clientRole" value="@role" @(Model.ClientRole == role ? "checked" : null) />
                <span>@RealtorDisplayLocalization.ClientRole(L, role)</span>
            </label>
        }
    </div>
    <span class="rl-field-error" id="clientRoleError" data-client-error="clientRole">@L[clientRoleError]</span>

    <p class="rl-invite-section-title">@L["Quick Note"] <small>(@L["optional"])</small></p>
    <label class="rl-field rl-field--textarea">
        <i class="fas fa-note-sticky"></i>
        <textarea name="quickNote" maxlength="250" placeholder="@L["Add a note about this client..."]" rows="3">@Model.QuickNote</textarea>
    </label>
    <span class="rl-char-count"><span id="noteCount">@Model.QuickNote.Length</span>/250</span>

    <div class="rl-info-box">
        <i class="fas fa-shield-halved"></i>
        <p>@L["The client will receive an invitation by email or text and can securely access shared property information."]</p>
    </div>

    <div class="rl-invite-actions">
        <button type="submit" formaction="@Url.Action("Cancel")" formnovalidate class="rl-invite-cancel">@L["Cancel"]</button>
        <button type="submit" id="inviteNextBtn" class="ob-btn ob-btn-primary">@L["Next"]</button>
    </div>
</form>

@section Scripts {
<script>
(function () {
    var banner = document.getElementById('inviteClientFormErrors');
    if (banner && !banner.classList.contains('is-hidden')) {
        banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
    }
    var summary = document.querySelector('#inviteClientForm .ob-summary:not(.validation-summary-valid)');
    var firstFieldError = document.querySelector('#inviteClientForm .rl-field-error:not(:empty), #inviteClientForm .rl-field.is-error');
    var scrollTarget = summary || firstFieldError;
    if (scrollTarget) {
        scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
})();
</script>
}
