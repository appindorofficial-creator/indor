@{
    var stepModel = Model as IndorMvcApp.ViewModels.RealtorInviteStepViewModel;
    var pageTitle = stepModel?.Title ?? "Invite Client";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@pageTitle - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-portal.css" asp-append-version="true" />
</head>
<body class="rl-dash-page">
    <div class="rl-invite-shell">
        @if (stepModel != null)
        {
            @await Html.PartialAsync("_InviteStepper", stepModel)
        }
        @RenderBody()
    </div>
    @await Html.PartialAsync("~/Views/Realtor/_RealtorBottomNav.cshtml")
    @RenderSection("Scripts", required: false)
</body>
</html>
