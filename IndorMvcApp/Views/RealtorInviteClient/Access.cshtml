@model IndorMvcApp.ViewModels.RealtorInviteAccessViewModel
@using IndorMvcApp.Helpers
@{
    string FieldError(string key) => ViewData.ModelState[key]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
    var collaborationError = FieldError("CollaborationLevel");
    var formErrors = ViewData.ModelState
        .Where(x => x.Value?.Errors.Count > 0)
        .SelectMany(x => x.Value!.Errors.Select(e => e.ErrorMessage))
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<form asp-action="Access" method="post" class="rl-invite-form" id="inviteAccessForm" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary" role="alert"></div>

    @if (formErrors.Count > 0)
    {
        <div class="rl-error-banner" role="alert" id="inviteAccessFormErrors">
            <i class="fas fa-circle-exclamation"></i>
            <div>
                <strong>@L["Please fix the following to continue:"]</strong>
                <ul class="rl-error-list">
                    @foreach (var msg in formErrors)
                    {
                        <li>@L[msg]</li>
                    }
                </ul>
            </div>
        </div>
    }

    <p class="rl-page-subtitle rl-invite-access-intro">@L["Choose what this client can see and how they can collaborate. Nothing is shared until you turn it on."]</p>

    <h2 class="rl-invite-section-title">@L["Access & Permissions"]</h2>
    <div class="rl-toggle-list">
        <label class="rl-toggle-row">
            <span>@L["Property Overview"]</span>
            <input type="checkbox" name="AccessPropertyOverview" value="true" @(Model.AccessPropertyOverview ? "checked" : null) />
            <span class="rl-toggle"></span>
        </label>
        <label class="rl-toggle-row">
            <span>@L["Files & Reports"]</span>
            <input type="checkbox" name="AccessFilesReports" value="true" @(Model.AccessFilesReports ? "checked" : null) />
            <span class="rl-toggle"></span>
        </label>
        <label class="rl-toggle-row">
            <span>@L["Quotes & Estimates"]</span>
            <input type="checkbox" name="AccessQuotesEstimates" value="true" @(Model.AccessQuotesEstimates ? "checked" : null) />
            <span class="rl-toggle"></span>
        </label>
        <label class="rl-toggle-row">
            <span>@L["Messages"]</span>
            <input type="checkbox" name="AccessMessages" value="true" @(Model.AccessMessages ? "checked" : null) />
            <span class="rl-toggle"></span>
        </label>
        <label class="rl-toggle-row">
            <span>@L["Project Updates"]</span>
            <input type="checkbox" name="AccessProjectUpdates" value="true" @(Model.AccessProjectUpdates ? "checked" : null) />
            <span class="rl-toggle"></span>
        </label>
        <label class="rl-toggle-row">
            <span>@L["Payments"] <small>(@L["optional"])</small></span>
            <input type="checkbox" name="AccessPayments" value="true" @(Model.AccessPayments ? "checked" : null) />
            <span class="rl-toggle"></span>
        </label>
    </div>

    <h2 class="rl-invite-section-title">@L["Collaboration Level"] <span class="rl-cp-req">*</span></h2>
    <div class="rl-collab-grid @(collaborationError.Length > 0 ? "is-error" : null)">
        @foreach (var opt in Model.CollaborationOptions)
        {
            var selected = Model.CollaborationLevel == opt.Value;
            <label class="rl-collab-card @(selected ? "is-selected" : "")">
                <input type="radio" name="CollaborationLevel" value="@opt.Value" @(selected ? "checked" : null) />
                <i class="fas @opt.Icon"></i>
                <span>@L[opt.Label]</span>
                @if (selected) { <i class="fas fa-circle-check rl-collab-check"></i> }
            </label>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(collaborationError))
    {
        <span class="rl-field-error">@L[collaborationError]</span>
    }

    <h2 class="rl-invite-section-title">@L["Invitation Delivery"] <span class="rl-cp-req">*</span></h2>
    <div class="rl-delivery-row">
        <label class="rl-delivery-btn @(Model.DeliveryEmail ? "is-selected" : "")">
            <input type="checkbox" name="DeliveryEmail" value="true" @(Model.DeliveryEmail ? "checked" : null) />
            @L["Email"]
        </label>
        <label class="rl-delivery-btn @(Model.DeliveryText ? "is-selected" : "")">
            <input type="checkbox" name="DeliveryText" value="true" @(Model.DeliveryText ? "checked" : null) />
            @L["Text Message"]
        </label>
    </div>

    <h2 class="rl-invite-section-title">@L["Custom Welcome Message"] <small>(@L["optional"])</small></h2>
    <label class="rl-field rl-field--textarea">
        <textarea name="WelcomeMessage" maxlength="250" rows="4">@Model.WelcomeMessage</textarea>
    </label>
    <span class="rl-char-count">@Model.WelcomeMessage.Length/250</span>

    <div class="rl-info-box rl-info-box--muted">
        <i class="fas fa-circle-info"></i>
        <p>@L["You can update permissions later from the client profile."]</p>
    </div>

</form>

<div class="rl-invite-actions">
    <a asp-action="BackToProperty" class="rl-invite-cancel">@L["Back"]</a>
    <button type="submit" form="inviteAccessForm" id="inviteAccessNextBtn" class="ob-btn ob-btn-primary">@L["Next"]</button>
</div>

@section Scripts {
<script>
(function () {
    var banner = document.getElementById('inviteAccessFormErrors');
    var summary = document.querySelector('#inviteAccessForm .ob-summary:not(.validation-summary-valid)');
    var scrollTarget = banner || summary || document.querySelector('#inviteAccessForm .rl-field-error:not(:empty), #inviteAccessForm .rl-collab-grid.is-error');
    if (scrollTarget) {
        scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    document.querySelectorAll('.rl-collab-card input').forEach(function (r) {
        r.addEventListener('change', function () {
            document.querySelectorAll('.rl-collab-card').forEach(function (c) { c.classList.remove('is-selected'); });
            r.closest('.rl-collab-card')?.classList.add('is-selected');
            document.querySelector('.rl-collab-grid')?.classList.remove('is-error');
        });
    });
    document.querySelectorAll('.rl-delivery-btn input').forEach(function (c) {
        c.addEventListener('change', function () {
            c.closest('.rl-delivery-btn')?.classList.toggle('is-selected', c.checked);
        });
    });
})();
</script>
}
