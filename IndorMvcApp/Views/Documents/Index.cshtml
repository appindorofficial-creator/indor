@model IndorMvcApp.ViewModels.DocumentsIndexViewModel
@{
    ViewData["Title"] = "Documents";
    var hfPreview = ViewBag.HouseFactPreview as bool? == true;
    var addressParts = Model.Address.Split(',', 2);
    var line1 = addressParts[0].Trim();
    var line2 = addressParts.Length > 1 ? addressParts[1].Trim() : string.Empty;
}
@section Head {
    <link rel="stylesheet" href="~/css/documents.css" asp-append-version="true" />
}

<div class="doc-head">
    <h1 class="doc-title">Documents</h1>
    <p class="doc-sub">Reports, disclosures, permits & saved files.</p>
</div>

<div class="doc-property">
    <div class="doc-property-top">
        <div class="doc-thumb"><i class="fas fa-house"></i></div>
        <div class="doc-property-body">
            <div class="doc-kicker">INDOR HOUSE FACT</div>
            <div class="doc-address">
                @line1
                @if (!string.IsNullOrWhiteSpace(line2))
                {
                    <div>@line2</div>
                }
            </div>
            <div class="doc-stats">
                <span class="doc-stat blue"><i class="fas fa-folder-open"></i> @Model.TotalDocuments documents</span>
                @if (hfPreview)
                {
                    <a asp-controller="HouseFactPreview" asp-action="DocumentsRequests" class="doc-stat orange" style="text-decoration:none;">
                        <i class="fas fa-clock"></i> @Model.PendingCount pending
                    </a>
                }
                else
                {
                    <a asp-action="Requests" asp-route-id="@Model.PropiedadId" class="doc-stat orange" style="text-decoration:none;">
                        <i class="fas fa-clock"></i> @Model.PendingCount pending
                    </a>
                }
                <span class="doc-stat purple"><i class="fas fa-users"></i> @Model.SharedCount shared</span>
            </div>
        </div>
        <div class="doc-photo"><i class="fas fa-image"></i></div>
    </div>
</div>

<div class="doc-tabs">
    @foreach (var tab in Model.Tabs)
    {
        if (hfPreview)
        {
            <a class="doc-tab @(Model.ActiveTab == tab.Key ? "active" : "")"
               asp-controller="HouseFactPreview" asp-action="Documents"
               asp-route-tab="@tab.Key">@tab.Label</a>
        }
        else
        {
            <a class="doc-tab @(Model.ActiveTab == tab.Key ? "active" : "")"
               asp-action="Index"
               asp-route-id="@Model.PropiedadId"
               asp-route-tab="@tab.Key">@tab.Label</a>
        }
    }
</div>

<div class="doc-list">
    @foreach (var doc in Model.Documents)
    {
        if (hfPreview)
        {
            <a class="doc-row" asp-controller="HouseFactPreview" asp-action="DocumentsDetail" asp-route-documentId="@doc.DocumentId">
                <div class="doc-row-icon @doc.IconTone"><i class="fas @doc.Icon"></i></div>
                <div class="doc-row-body">
                    <div class="doc-row-title">@doc.Title</div>
                    <div class="doc-row-meta">@doc.CategoryLabel • @doc.UpdatedLabel</div>
                </div>
                <span class="doc-badge @doc.StatusTone">@doc.Status</span>
                <i class="fas fa-chevron-right" style="color:#CBD5E1;font-size:.75rem;"></i>
            </a>
        }
        else
        {
            <a class="doc-row" asp-action="Detail" asp-route-id="@Model.PropiedadId" asp-route-documentId="@doc.DocumentId">
                <div class="doc-row-icon @doc.IconTone"><i class="fas @doc.Icon"></i></div>
                <div class="doc-row-body">
                    <div class="doc-row-title">@doc.Title</div>
                    <div class="doc-row-meta">@doc.CategoryLabel • @doc.UpdatedLabel</div>
                </div>
                <span class="doc-badge @doc.StatusTone">@doc.Status</span>
                <i class="fas fa-chevron-right" style="color:#CBD5E1;font-size:.75rem;"></i>
            </a>
        }
    }
</div>

@if (hfPreview)
{
    <a class="doc-btn-primary" asp-controller="HouseFactPreview" asp-action="DocumentsAdd">
        <i class="fas fa-plus"></i> Add document
    </a>
}
else
{
    <a class="doc-btn-primary" asp-action="Add" asp-route-id="@Model.PropiedadId">
        <i class="fas fa-plus"></i> Add document
    </a>
}

<div class="doc-link-row">
    @if (hfPreview)
    {
        <a asp-controller="HouseFactPreview" asp-action="DocumentsRequests">View document requests</a>
    }
    else
    {
        <a asp-action="Requests" asp-route-id="@Model.PropiedadId">View document requests</a>
    }
</div>
