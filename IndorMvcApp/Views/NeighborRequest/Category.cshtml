@model IndorMvcApp.ViewModels.NeighborRequestCategoryStepViewModel
@{
    ViewData["Title"] = "Post Quick Job";
}

<form asp-action="Category" method="post" class="nr-step-form" id="nrStep1Form" autocomplete="off">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PropiedadId" />
    <input type="hidden" asp-for="ResumeDraft" />

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-briefcase"></i></span>
            <span class="nr-card-head-text">
                <h2>What do you need help with?</h2>
                <p class="nr-card-sub">Choose the kind of help you need.</p>
            </span>
        </header>

        @if (Model.Categories.Count == 0)
        {
            <div class="nr-empty">
                <p>Categories are not available yet. Run the database script and try again.</p>
            </div>
        }
        else
        {
            <div class="nr-cat-grid" role="radiogroup" aria-label="Job category">
                @foreach (var category in Model.Categories)
                {
                    var isSelected = Model.CategoryId == category.Id || Model.SelectedCategoryId == category.Id;
                    <label class="nr-cat-tile @(isSelected ? "is-selected" : null)">
                        <input type="radio" name="CategoryId" value="@category.Id" @(isSelected ? "checked" : null) required />
                        <span class="nr-cat-tile-ill @(string.IsNullOrWhiteSpace(category.ImageUrl) ? category.IllustrationClass : "has-image")" aria-hidden="true">
                            @if (!string.IsNullOrWhiteSpace(category.ImageUrl))
                            {
                                <img src="@Url.Content("~" + category.ImageUrl)" alt="" loading="lazy" decoding="async" asp-append-version="true" />
                            }
                        </span>
                        <span class="nr-cat-tile-body">
                            <span class="nr-cat-tile-label">@category.Label</span>
                            @if (!string.IsNullOrWhiteSpace(category.Description))
                            {
                                <span class="nr-cat-tile-desc">@category.Description</span>
                            }
                        </span>
                        @if (isSelected)
                        {
                            <span class="nr-cat-tile-check"><i class="fas fa-check"></i></span>
                        }
                    </label>
                }
            </div>
            <span asp-validation-for="CategoryId" class="field-validation-error"></span>

            <div class="nr-cat-tip">
                <span class="nr-cat-tip-icon"><i class="fas fa-lightbulb"></i></span>
                <span><strong>Tip:</strong> Pick the option that best matches the type of labor help you need.</span>
            </div>
        }
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-users"></i></span>
            <h2>Job title</h2>
        </header>
        <div class="nr-field nr-field--count">
            <input asp-for="Title" class="nr-input" placeholder="Need help moving a sofa" maxlength="60" autocomplete="off" />
            <span class="nr-char-count"><span id="nrTitleCount">0</span>/60</span>
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-comment-dots"></i></span>
            <h2>Describe the job</h2>
        </header>
        <div class="nr-field nr-field--count">
            <textarea asp-for="Description" class="nr-textarea" maxlength="300" placeholder="Share timing, scope, or anything helpful for helpers." autocomplete="off"></textarea>
            <span class="nr-char-count"><span id="nrDescCount">0</span>/300</span>
        </div>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-location-dot"></i></span>
            <h2>Location</h2>
        </header>
        <label class="nr-location-picker">
            <span class="nr-location-picker-icon"><i class="fas fa-house"></i></span>
            <input asp-for="LocationAddress" class="nr-location-picker-input" />
            <i class="fas fa-chevron-right" aria-hidden="true"></i>
        </label>
        <span asp-validation-for="LocationAddress" class="field-validation-error"></span>

        <label class="nr-home-toggle">
            <input type="checkbox" asp-for="UseHomeAddress" />
            <span class="nr-home-toggle-copy">
                <strong>Use my home address</strong>
                <small>Helpers will see your approximate location.</small>
            </span>
            <i class="fas fa-circle-info" aria-hidden="true"></i>
        </label>
    </section>
</form>

@section WizardFooter {
    @{ ViewData["NrWizardFormId"] = "nrStep1Form"; ViewData["NrWizardContinueLabel"] = "Continue"; ViewData["NrWizardContinueIconAfter"] = "fa-arrow-right"; }
    @await Html.PartialAsync("_NrWizardFooter")
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function bindCounter(selector, counterId, max) {
                var field = document.querySelector(selector);
                var counter = document.getElementById(counterId);
                var counterWrap = counter ? counter.closest('.nr-char-count') : null;
                if (!field || !counter) return;
                var update = function () {
                    var length = field.value.length;
                    counter.textContent = String(length);
                    if (counterWrap) {
                        counterWrap.classList.toggle('is-over-limit', length > max);
                    }
                };
                field.addEventListener('input', update);
                update();
            }
            bindCounter('[name="Title"]', 'nrTitleCount', 60);
            bindCounter('[name="Description"]', 'nrDescCount', 300);

            document.querySelectorAll('.nr-cat-tile input').forEach(function (input) {
                input.addEventListener('change', function () {
                    document.querySelectorAll('.nr-cat-tile').forEach(function (tile) {
                        tile.classList.toggle('is-selected', tile.querySelector('input')?.checked);
                    });
                });
            });

            var homeToggle = document.querySelector('[name="UseHomeAddress"]');
            var addressInput = document.querySelector('[name="LocationAddress"]');
            if (homeToggle && addressInput) {
                homeToggle.addEventListener('change', function () {
                    addressInput.readOnly = homeToggle.checked;
                });
                addressInput.readOnly = homeToggle.checked;
            }
        })();
    </script>
}
