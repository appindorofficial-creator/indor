@model IndorMvcApp.ViewModels.NeighborRequestCategoryStepViewModel

<form asp-action="Category" method="post" class="nr-step-form" id="nrStep1Form" autocomplete="off">
    @Html.AntiForgeryToken()
    @if (!Model.HasMultipleProperties)
    {
        <input type="hidden" asp-for="PropiedadId" />
    }
    <input type="hidden" asp-for="ResumeDraft" />

    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-briefcase"></i></span>
            <span class="nr-card-head-text">
                <h2>@L["What do you need help with?"]</h2>
                <p class="nr-card-sub">@L["Choose the kind of help you need."]</p>
            </span>
        </header>

        @if (Model.Categories.Count == 0)
        {
            <div class="nr-empty">
                <p>@L["Categories are not available yet. Run the database script and try again."]</p>
            </div>
        }
        else
        {
            <div class="nr-cat-grid" role="radiogroup" aria-label="@L["Job category"]">
                @foreach (var category in Model.Categories)
                {
                    var isSelected = Model.CategoryId == category.Id || Model.SelectedCategoryId == category.Id;
                    <label class="nr-cat-tile @(isSelected ? "is-selected" : null)">
                        <input type="radio" name="CategoryId" value="@category.Id" @(isSelected ? "checked" : null) required />
                        <span class="nr-cat-tile-ill @(string.IsNullOrWhiteSpace(category.ImageUrl) ? category.IllustrationClass : "has-image")" aria-hidden="true">
                            @if (!string.IsNullOrWhiteSpace(category.ImageUrl))
                            {
                                <img src="@Url.Content("~" + category.ImageUrl)" alt="" loading="lazy" decoding="async" asp-append-version="true" />
                            }
                        </span>
                        <span class="nr-cat-tile-body">
                            <span class="nr-cat-tile-label">@category.Label</span>
                            @if (!string.IsNullOrWhiteSpace(category.Description))
                            {
                                <span class="nr-cat-tile-desc">@category.Description</span>
                            }
                        </span>
                        @if (isSelected)
                        {
                            <span class="nr-cat-tile-check"><i class="fas fa-check"></i></span>
                        }
                    </label>
                }
            </div>
            <span asp-validation-for="CategoryId" class="field-validation-error"></span>

            <div class="nr-cat-tip">
                <span class="nr-cat-tip-icon"><i class="fas fa-lightbulb"></i></span>
                <span><strong>@L["Tip:"]</strong> @L["Pick the option that best matches the type of labor help you need."]</span>
            </div>
        }
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-users"></i></span>
            <h2>@L["Job title"]</h2>
        </header>
        <div class="nr-field nr-field--count">
            <div class="nr-counted-control">
                <input asp-for="JobTitle" class="nr-input" placeholder="@L["Need help moving a sofa"]" maxlength="60" autocomplete="off" />
            </div>
            <span class="nr-char-count"><span id="nrTitleCount">0</span>/60</span>
            <span asp-validation-for="JobTitle" class="field-validation-error"></span>
        </div>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-comment-dots"></i></span>
            <h2>@L["Describe the job"]</h2>
        </header>
        <div class="nr-field nr-field--count">
            <div class="nr-counted-control">
                <textarea asp-for="Description" class="nr-textarea" maxlength="300" placeholder="@L["Share timing, scope, or anything helpful for helpers."]" autocomplete="off"></textarea>
            </div>
            <span class="nr-char-count"><span id="nrDescCount">0</span>/300</span>
        </div>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-location-dot"></i></span>
            <h2>@L["Location"]</h2>
        </header>

        @if (Model.HasMultipleProperties)
        {
            <p class="nr-location-hint">@L["Choose which property this job is for."]</p>
            <div class="nr-property-chooser" role="radiogroup" aria-label="@L["Property"]" id="nrPropertyChooser">
                @foreach (var property in Model.AvailableProperties)
                {
                    var isSelected = property.Id == Model.PropiedadId;
                    <label class="nr-property-choice @(isSelected ? "is-selected" : null)">
                        <input type="radio"
                               name="PropiedadId"
                               value="@property.Id"
                               data-address="@property.Address"
                               @(isSelected ? "checked" : null)
                               required />
                        <span class="nr-property-choice-icon" aria-hidden="true"><i class="fas fa-house"></i></span>
                        <span class="nr-property-choice-copy">
                            <span class="nr-property-choice-label">@property.Label</span>
                            @if (!string.IsNullOrWhiteSpace(property.Address)
                                 && !string.Equals(property.Address, property.Label, StringComparison.OrdinalIgnoreCase))
                            {
                                <span class="nr-property-choice-address">@property.Address</span>
                            }
                        </span>
                        <span class="nr-property-choice-check" aria-hidden="true"><i class="fas fa-check"></i></span>
                    </label>
                }
            </div>
        }

        <label class="nr-location-picker @(Model.HasMultipleProperties ? "nr-location-picker--custom" : null)"
               id="nrLocationAddressWrap"
               @(Model.HasMultipleProperties && Model.UseHomeAddress ? "hidden" : null)>
            <span class="nr-location-picker-icon"><i class="fas fa-location-dot"></i></span>
            <input asp-for="LocationAddress"
                   id="nrLocationAddress"
                   class="nr-location-picker-input"
                   readonly="@Model.UseHomeAddress"
                   tabindex="@(Model.UseHomeAddress ? "-1" : null)" />
        </label>
        <span asp-validation-for="LocationAddress" class="field-validation-error"></span>

        <label class="nr-home-toggle">
            <input type="checkbox" asp-for="UseHomeAddress" />
            <span class="nr-home-toggle-copy">
                <strong>@L["Use my home address"]</strong>
                <small>@L["Helpers will see your approximate location."]</small>
            </span>
        </label>
    </section>
</form>

@section WizardFooter {
    @{ ViewData["NrWizardFormId"] = "nrStep1Form"; ViewData["NrWizardContinueLabel"] = L["Continue"]; ViewData["NrWizardContinueIconAfter"] = "fa-arrow-right"; }
    @await Html.PartialAsync("_NrWizardFooter")
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function bindCounter(selector, counterId, max) {
                var field = document.querySelector(selector);
                var counter = document.getElementById(counterId);
                var counterWrap = counter ? counter.closest('.nr-char-count') : null;
                if (!field || !counter) return;
                var update = function () {
                    if (field.value.length > max) {
                        field.value = field.value.slice(0, max);
                    }
                    var length = field.value.length;
                    counter.textContent = String(length);
                    if (counterWrap) {
                        counterWrap.classList.toggle('is-over-limit', length > max);
                    }
                };
                field.addEventListener('input', update);
                update();
            }
            bindCounter('[name="JobTitle"]', 'nrTitleCount', 60);
            bindCounter('[name="Description"]', 'nrDescCount', 300);

            document.querySelectorAll('.nr-cat-tile input').forEach(function (input) {
                input.addEventListener('change', function () {
                    document.querySelectorAll('.nr-cat-tile').forEach(function (tile) {
                        tile.classList.toggle('is-selected', tile.querySelector('input')?.checked);
                    });
                });
            });

            var homeToggle = document.querySelector('[name="UseHomeAddress"]');
            var addressInput = document.getElementById('nrLocationAddress')
                || document.querySelector('[name="LocationAddress"]');
            var propertyRadios = document.querySelectorAll('#nrPropertyChooser input[name="PropiedadId"]');
            var addressWrap = document.getElementById('nrLocationAddressWrap');
            var hasPropertyChooser = propertyRadios.length > 0;

            function selectedPropertyAddress() {
                if (!hasPropertyChooser) return '';
                var checked = document.querySelector('#nrPropertyChooser input[name="PropiedadId"]:checked');
                return checked ? (checked.getAttribute('data-address') || '').trim() : '';
            }

            function syncPropertyChoiceUi() {
                document.querySelectorAll('#nrPropertyChooser .nr-property-choice').forEach(function (choice) {
                    var input = choice.querySelector('input[type="radio"]');
                    choice.classList.toggle('is-selected', !!(input && input.checked));
                });
            }

            function syncHomeAddressState() {
                if (!homeToggle || !addressInput) return;
                var useHome = homeToggle.checked;
                addressInput.readOnly = useHome;
                if (useHome) {
                    addressInput.setAttribute('tabindex', '-1');
                    var homeAddress = selectedPropertyAddress();
                    if (homeAddress) {
                        addressInput.value = homeAddress;
                    }
                } else {
                    addressInput.removeAttribute('tabindex');
                }
                if (addressWrap) {
                    addressWrap.classList.toggle('is-home-locked', useHome);
                    addressWrap.hidden = useHome && hasPropertyChooser;
                }
            }

            if (homeToggle && addressInput) {
                homeToggle.addEventListener('change', syncHomeAddressState);
            }

            propertyRadios.forEach(function (radio) {
                radio.addEventListener('change', function () {
                    syncPropertyChoiceUi();
                    if (homeToggle && homeToggle.checked) {
                        var homeAddress = selectedPropertyAddress();
                        if (homeAddress) {
                            addressInput.value = homeAddress;
                        }
                    }
                });
            });

            syncPropertyChoiceUi();
            syncHomeAddressState();
        })();
    </script>
}
