@model IndorMvcApp.ViewModels.NeighborRequestDescribeStepViewModel
@{
    ViewData["Title"] = L["Post Quick Job"];
}

<form asp-action="Describe" method="post" enctype="multipart/form-data" class="nr-step-form" id="nrDescribeForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PropiedadId" />

    <section class="nr-card">
        <header class="nr-card-head nr-card-head--stack">
            <h2>@L["Add photos"]</h2>
            <p>@L["Show helpers what the job looks like. Photos are optional but recommended."]</p>
        </header>

        <div class="nr-photo-strip">
            <div class="nr-photo-grid" id="nrPhotoGrid">
                @foreach (var photo in Model.ExistingPhotoUrls)
                {
                    <div class="nr-photo-thumb nr-photo-thumb--existing">
                        <img src="@Url.Content("~" + photo)" alt="" />
                    </div>
                }
            </div>
            <div class="nr-photo-add-wrap" id="nrPhotoAddWrap">
                <button type="button"
                        class="nr-photo-add"
                        id="nrPhotoAddBtn"
                        aria-haspopup="true"
                        aria-expanded="false"
                        aria-controls="nrPhotoMenu">
                    <i class="fas fa-plus"></i>
                    <span>@L["Add more"]</span>
                </button>
                <div class="nr-photo-menu" id="nrPhotoMenu" role="menu" hidden>
                    <button type="button" class="nr-photo-menu-item" data-nr-photo-source="library" role="menuitem">
                        <i class="fas fa-images"></i> @L["Photo Library"]
                    </button>
                    <button type="button" class="nr-photo-menu-item" data-nr-photo-source="camera" role="menuitem">
                        <i class="fas fa-camera"></i> @L["Take Photo"]
                    </button>
                    <button type="button" class="nr-photo-menu-item" data-nr-photo-source="files" role="menuitem">
                        <i class="fas fa-folder"></i> @L["Choose Files"]
                    </button>
                </div>
                @* Separate inputs so the in-app menu can open camera / gallery / files without the OS English sheet. *@
                <input type="file" id="nrPhotoInputCamera" accept="image/jpeg,image/png,image/webp,image/*" capture="environment" multiple hidden />
                <input type="file" id="nrPhotoInputLibrary" accept="image/jpeg,image/png,image/webp,image/*" multiple hidden />
                <input type="file" id="nrPhotoInputFiles" accept="image/jpeg,image/png,image/webp,image/*,.pdf,application/pdf" multiple hidden />
                <input type="file" asp-for="PhotoFiles" id="nrPhotoInput" accept="image/jpeg,image/png,image/webp" multiple hidden />
            </div>
        </div>
    </section>

    <section class="nr-card" id="nrToolsBlock">
        <header class="nr-card-head nr-card-head--stack">
            <h2>@L["What should the helper bring?"] <span class="nr-required" aria-hidden="true">*</span></h2>
            <p>@L["Select all that apply."]</p>
        </header>
        <div class="nr-chip-grid">
            @foreach (var tool in Model.ToolOptions)
            {
                var isSelected = Model.SelectedTools.Contains(tool.Value);
                <label class="nr-chip @(isSelected ? "is-selected" : null)">
                    <input type="checkbox" name="SelectedTools" value="@tool.Value" @(isSelected ? "checked" : null) />
                    <i class="fas @tool.IconClass"></i>
                    <span>@L[tool.Label]</span>
                </label>
            }
        </div>
        <span asp-validation-for="SelectedTools" class="field-validation-error" id="nrToolsError"></span>
    </section>

    <section class="nr-card">
        <header class="nr-card-head nr-card-head--stack">
            <h2>@L["Special notes"]</h2>
            <p>@L["Anything else helpers should know before they arrive?"]</p>
        </header>
        <div class="nr-field nr-field--count">
            <div class="nr-counted-control">
                <textarea asp-for="SpecialNotes" class="nr-textarea" maxlength="250" placeholder="@L["Please be careful with the wooden floors..."]"></textarea>
            </div>
            <span class="nr-char-count"><span id="nrNotesCount">0</span>/250</span>
        </div>
    </section>

    <section class="nr-card" id="nrSafetyBlock">
        <header class="nr-card-head nr-card-head--stack">
            <h2>@L["Safety & access"] <span class="nr-required" aria-hidden="true">*</span></h2>
            <p>@L["Help helpers arrive prepared and stay safe on your property."]</p>
        </header>
        <div class="nr-safety-grid">
            <label class="nr-safety-item">
                <span class="nr-safety-icon"><i class="fas fa-paw"></i></span>
                <span class="nr-safety-label">@L["Pets on property"]</span>
                <select asp-for="PetsOnProperty" class="nr-safety-select" aria-required="true">
                    <option value="">@L["Select"]</option>
                    <option value="No">@L["No"]</option>
                    <option value="Yes">@L["Yes"]</option>
                </select>
            </label>
            <label class="nr-safety-item">
                <span class="nr-safety-icon"><i class="fas fa-stairs"></i></span>
                <span class="nr-safety-label">@L["Stairs"]</span>
                <select asp-for="HasStairs" class="nr-safety-select" aria-required="true">
                    <option value="">@L["Select"]</option>
                    <option value="No">@L["No"]</option>
                    <option value="Yes">@L["Yes"]</option>
                </select>
            </label>
            <label class="nr-safety-item">
                <span class="nr-safety-icon"><i class="fas fa-lock"></i></span>
                <span class="nr-safety-label">@L["Gate code"]</span>
                <input asp-for="GateCode" class="nr-safety-input" placeholder="@L["Optional"]" />
            </label>
            <label class="nr-safety-item">
                <span class="nr-safety-icon"><i class="fas fa-car"></i></span>
                <span class="nr-safety-label">@L["Parking available"]</span>
                <select asp-for="ParkingAvailable" class="nr-safety-select" aria-required="true">
                    <option value="">@L["Select"]</option>
                    <option value="Yes">@L["Yes"]</option>
                    <option value="No">@L["No"]</option>
                </select>
            </label>
        </div>
        <span asp-validation-for="PetsOnProperty" class="field-validation-error"></span>
        <span asp-validation-for="HasStairs" class="field-validation-error"></span>
        <span asp-validation-for="ParkingAvailable" class="field-validation-error"></span>
        <span class="field-validation-error" id="nrSafetyError"></span>
    </section>
</form>

@section WizardFooter {
    @{ ViewData["NrWizardFormId"] = "nrDescribeForm"; ViewData["NrWizardContinueLabel"] = L["Review request"]; ViewData["NrWizardContinueIconAfter"] = "fa-arrow-right"; }
    @await Html.PartialAsync("_NrWizardFooter")
}

@section Scripts {
    <script>
        (function () {
            var textarea = document.querySelector('[name="SpecialNotes"]');
            var counter = document.getElementById('nrNotesCount');
            var counterWrap = counter ? counter.closest('.nr-char-count') : null;
            if (textarea && counter) {
                var max = parseInt(textarea.getAttribute('maxlength'), 10) || 250;
                var update = function () {
                    if (textarea.value.length > max) {
                        textarea.value = textarea.value.slice(0, max);
                    }
                    var length = textarea.value.length;
                    counter.textContent = String(length);
                    if (counterWrap) {
                        counterWrap.classList.toggle('is-over-limit', length > max);
                    }
                };
                textarea.addEventListener('input', update);
                update();
            }

            document.querySelectorAll('.nr-chip input').forEach(function (input) {
                input.addEventListener('change', function () {
                    input.closest('.nr-chip')?.classList.toggle('is-selected', input.checked);
                    var toolsError = document.getElementById('nrToolsError');
                    if (toolsError && document.querySelectorAll('.nr-chip input:checked').length) {
                        toolsError.textContent = '';
                        document.getElementById('nrToolsBlock')?.classList.remove('is-error');
                    }
                });
            });

            var form = document.getElementById('nrDescribeForm');
            if (form) {
                var safetyMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Complete Safety & access: pets, stairs, and parking."]));
                var petsSelect = document.querySelector('[name="PetsOnProperty"]');
                var stairsSelect = document.querySelector('[name="HasStairs"]');
                var parkingSelect = document.querySelector('[name="ParkingAvailable"]');
                var safetyError = document.getElementById('nrSafetyError');
                var safetyBlock = document.getElementById('nrSafetyBlock');

                function clearSafetyError() {
                    if (safetyError) safetyError.textContent = '';
                    safetyBlock?.classList.remove('is-error');
                    [petsSelect, stairsSelect, parkingSelect].forEach(function (el) {
                        el?.closest('.nr-safety-item')?.classList.remove('is-error');
                    });
                }

                function safetyFilled() {
                    return !!(petsSelect?.value && stairsSelect?.value && parkingSelect?.value);
                }

                [petsSelect, stairsSelect, parkingSelect].forEach(function (el) {
                    el?.addEventListener('change', function () {
                        if (safetyFilled()) clearSafetyError();
                    });
                });

                form.addEventListener('submit', function (e) {
                    var hasError = false;
                    var checked = document.querySelectorAll('.nr-chip input:checked').length;
                    var toolsError = document.getElementById('nrToolsError');
                    var toolsBlock = document.getElementById('nrToolsBlock');
                    if (!checked) {
                        hasError = true;
                        if (toolsError) {
                            toolsError.textContent = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Select what the helper should bring."]));
                        }
                        toolsBlock?.classList.add('is-error');
                    }

                    if (!safetyFilled()) {
                        hasError = true;
                        if (safetyError) safetyError.textContent = safetyMsg;
                        safetyBlock?.classList.add('is-error');
                        [petsSelect, stairsSelect, parkingSelect].forEach(function (el) {
                            if (el && !el.value) {
                                el.closest('.nr-safety-item')?.classList.add('is-error');
                            }
                        });
                    }

                    if (hasError) {
                        e.preventDefault();
                        var first = (!checked ? toolsBlock : null) || safetyBlock;
                        first?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                });
            }

            var submitInput = document.getElementById('nrPhotoInput');
            var grid = document.getElementById('nrPhotoGrid');
            var addWrap = document.getElementById('nrPhotoAddWrap');
            var addBtn = document.getElementById('nrPhotoAddBtn');
            var menu = document.getElementById('nrPhotoMenu');
            var cameraInput = document.getElementById('nrPhotoInputCamera');
            var libraryInput = document.getElementById('nrPhotoInputLibrary');
            var filesInput = document.getElementById('nrPhotoInputFiles');
            if (!submitInput || !grid || !addBtn || !menu) return;

            var selected = [];
            var urls = [];

            function setMenuOpen(open) {
                menu.hidden = !open;
                addBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
            }

            function closeMenu() {
                setMenuOpen(false);
            }

            function openFileInput(input) {
                if (!input) return;
                input.value = '';
                input.click();
            }

            function syncInput() {
                if (typeof DataTransfer === 'undefined') return;
                var dt = new DataTransfer();
                selected.forEach(function (f) { dt.items.add(f); });
                submitInput.files = dt.files;
            }

            function clearUrls() {
                urls.forEach(function (u) { URL.revokeObjectURL(u); });
                urls = [];
            }

            function renderNew() {
                grid.querySelectorAll('.nr-photo-thumb--new').forEach(function (el) { el.remove(); });
                clearUrls();
                selected.forEach(function (file, index) {
                    var url = URL.createObjectURL(file);
                    urls.push(url);
                    var item = document.createElement('div');
                    item.className = 'nr-photo-thumb nr-photo-thumb--new';
                    var isImage = !file.type || file.type.indexOf('image/') === 0;
                    item.innerHTML = isImage
                        ? '<img src="' + url + '" alt="" /><button type="button" class="nr-photo-remove" aria-label="@L["Remove"]"><i class="fas fa-xmark"></i></button>'
                        : '<span class="nr-photo-file"><i class="fas fa-file"></i></span><button type="button" class="nr-photo-remove" aria-label="@L["Remove"]"><i class="fas fa-xmark"></i></button>';
                    item.querySelector('button').addEventListener('click', function () {
                        selected.splice(index, 1);
                        syncInput();
                        renderNew();
                    });
                    grid.appendChild(item);
                });
            }

            function ingestFiles(fileList) {
                if (!fileList) return;
                Array.prototype.forEach.call(fileList, function (file) {
                    if (file.type && file.type.indexOf('image/') === 0) {
                        selected.push(file);
                    }
                });
                syncInput();
                renderNew();
            }

            addBtn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                setMenuOpen(menu.hidden);
            });

            menu.querySelectorAll('[data-nr-photo-source]').forEach(function (item) {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var source = item.getAttribute('data-nr-photo-source');
                    closeMenu();
                    if (source === 'camera') {
                        openFileInput(cameraInput);
                    } else if (source === 'files') {
                        openFileInput(filesInput);
                    } else {
                        openFileInput(libraryInput);
                    }
                });
            });

            document.addEventListener('click', function (e) {
                if (addWrap && !addWrap.contains(e.target)) {
                    closeMenu();
                }
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    closeMenu();
                }
            });

            [cameraInput, libraryInput, filesInput].forEach(function (input) {
                if (!input) return;
                input.addEventListener('change', function () {
                    ingestFiles(input.files);
                });
            });
        })();
    </script>
}
