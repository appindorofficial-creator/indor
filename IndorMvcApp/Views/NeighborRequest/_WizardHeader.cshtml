@model IndorMvcApp.ViewModels.NeighborRequestWizardShellViewModel
<header class="nr-wizard-top">
    @if (!string.IsNullOrWhiteSpace(Model.BackUrl))
    {
        <a href="@Model.BackUrl" class="nr-wizard-nav-btn" aria-label="@L["Back"]" @(Model.IsEditMode ? null : Html.Raw("data-nr-history-back"))><i class="fas fa-arrow-left"></i></a>
    }
    else
    {
        <span class="nr-wizard-nav-btn nr-wizard-nav-btn--spacer"></span>
    }
    <div class="nr-wizard-top-center">
        <strong class="nr-wizard-top-title">@L[Model.PageTitle]</strong>
        @if (Model.DisplayStep > 0 && Model.TotalSteps > 0)
        {
            <span class="nr-wizard-top-sub">@L.T("Step {0} of {1}", Model.DisplayStep, Model.TotalSteps)</span>
        }
    </div>
    @if (Model.IsEditMode)
    {
        <span class="nr-wizard-nav-btn nr-wizard-nav-btn--spacer"></span>
    }
    else
    {
        <a href="@Model.CloseUrl" class="nr-wizard-nav-btn" aria-label="@L["Close"]"><i class="fas fa-xmark"></i></a>
    }
</header>
@await Html.PartialAsync("_WizardStepper", Model)
