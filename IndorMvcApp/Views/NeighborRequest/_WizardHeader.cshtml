@model IndorMvcApp.ViewModels.NeighborRequestWizardShellViewModel
<header class="nr-wizard-top">
    @if (!string.IsNullOrWhiteSpace(Model.BackUrl))
    {
        <a href="@Model.BackUrl" class="nr-wizard-nav-btn" aria-label="Back" @(Model.IsEditMode ? null : Html.Raw("data-nr-history-back"))><i class="fas fa-arrow-left"></i></a>
    }
    else
    {
        <span class="nr-wizard-nav-btn nr-wizard-nav-btn--spacer"></span>
    }
    <div class="nr-wizard-top-center">
        <strong class="nr-wizard-top-title">@Model.PageTitle</strong>
        @if (Model.DisplayStep > 0 && Model.TotalSteps > 0)
        {
            <span class="nr-wizard-top-sub">Step @Model.DisplayStep of @Model.TotalSteps</span>
        }
    </div>
    @if (Model.IsEditMode || Model.DisplayStep >= Model.TotalSteps)
    {
        <span class="nr-wizard-nav-btn nr-wizard-nav-btn--spacer"></span>
    }
    else
    {
        <a href="@Model.CloseUrl" class="nr-wizard-nav-btn" aria-label="Close"><i class="fas fa-xmark"></i></a>
    }
</header>
@await Html.PartialAsync("_WizardStepper", Model)
