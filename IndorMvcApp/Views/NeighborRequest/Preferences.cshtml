@using System.Globalization
@model IndorMvcApp.ViewModels.NeighborRequestPreferencesStepViewModel
@{
    ViewData["Title"] = Model.IsEditMode ? L["Edit request"] : L["Post Quick Job"];
}

<form asp-action="Preferences" method="post" class="nr-step-form" id="nrPreferencesForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PropiedadId" />
    <input type="hidden" asp-for="IsEditMode" />
    <input type="hidden" asp-for="RequestId" />

  @if (!Model.IsEditMode)
  {
    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-calendar-day"></i></span>
            <h2>@L["When do you need help?"]</h2>
        </header>
        <div class="nr-option-grid nr-option-grid--3">
            @foreach (var option in Model.WhenOptions)
            {
                <label class="nr-option-tile">
                    <input type="radio" name="WhenCode" value="@option.Value" @(Model.WhenCode == option.Value ? "checked" : null) />
                    <span class="nr-option-tile-body">
                        <i class="fas @option.IconClass" aria-hidden="true"></i>
                        <span>@L[option.Label]</span>
                    </span>
                </label>
            }
        </div>
        <div class="nr-pick-date" id="nrPickDateWrap" hidden>
            <span class="nr-pick-date-label">@L["Pick a date"]</span>
            <label class="nr-pick-date-control" for="NeededByDate">
                <span class="nr-pick-date-icon" aria-hidden="true"><i class="far fa-calendar"></i></span>
                <input name="NeededByDate"
                       id="NeededByDate"
                       type="date"
                       class="nr-pick-date-native"
                       min="@Model.MinNeededByDateIso"
                       data-min-date="@Model.MinNeededByDateIso"
                       value="@(Model.NeededByDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? "")"
                       aria-label="@L["Pick a date"]" />
                <span class="nr-pick-date-value" id="nrPickDateValue">
                    @(Model.NeededByDate?.ToString("dddd, MMMM d", CultureInfo.CurrentUICulture) ?? L["Select a date"].ToString())
                </span>
                <i class="fas fa-chevron-right nr-pick-date-chevron" aria-hidden="true"></i>
            </label>
            <span asp-validation-for="NeededByDate" class="field-validation-error"></span>
        </div>
        <span asp-validation-for="WhenCode" class="field-validation-error"></span>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-clock"></i></span>
            <h2>@L["Preferred time"]</h2>
        </header>
        <div class="nr-option-grid nr-option-grid--4">
            @foreach (var option in Model.PreferredTimeOptions)
            {
                <label class="nr-option-tile">
                    <input type="radio" name="PreferredTimeCode" value="@option.Value" @(Model.PreferredTimeCode == option.Value ? "checked" : null) />
                    <span class="nr-option-tile-body">
                        <i class="fas @option.IconClass" aria-hidden="true"></i>
                        <span>@L[option.Label]</span>
                    </span>
                </label>
            }
        </div>
        <span asp-validation-for="PreferredTimeCode" class="field-validation-error"></span>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-user-group"></i></span>
            <h2>@L["How many helpers?"]</h2>
        </header>
        <div class="nr-option-grid nr-option-grid--3">
            @foreach (var option in Model.HelperCountOptions)
            {
                <label class="nr-option-tile">
                    <input type="radio" name="HelperCount" value="@option.Value" @(Model.HelperCount == option.Value ? "checked" : null) />
                    <span class="nr-option-tile-body">
                        <i class="fas @option.IconClass" aria-hidden="true"></i>
                        <span>@L[option.Label]</span>
                    </span>
                </label>
            }
        </div>
        <span asp-validation-for="HelperCount" class="field-validation-error"></span>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-hourglass-half"></i></span>
            <h2>@L["Estimated time"]</h2>
        </header>
        <div class="nr-option-grid nr-option-grid--4">
            @foreach (var option in Model.DurationOptions)
            {
                <label class="nr-option-tile">
                    <input type="radio" name="DurationCode" value="@option.Value" @(Model.DurationCode == option.Value ? "checked" : null) />
                    <span class="nr-option-tile-body">
                        <i class="fas @option.IconClass" aria-hidden="true"></i>
                        <span>@L[option.Label]</span>
                    </span>
                </label>
            }
        </div>
        <span asp-validation-for="DurationCode" class="field-validation-error"></span>
    </section>

    <section class="nr-card">
        <header class="nr-card-head">
            <span class="nr-card-icon"><i class="fas fa-dollar-sign"></i></span>
            <h2>@L["Pay"]</h2>
        </header>
        <div class="nr-pay-toggle" role="tablist">
            <label class="nr-pay-toggle-btn @(Model.PayTypeCode == "Hourly" ? "is-active" : null)">
                <input type="radio" name="PayTypeCode" value="Hourly" @(Model.PayTypeCode == "Hourly" ? "checked" : null) />
                @L["Hourly"]
            </label>
            <label class="nr-pay-toggle-btn @(Model.PayTypeCode == "Fixed" ? "is-active" : null)">
                <input type="radio" name="PayTypeCode" value="Fixed" @(Model.PayTypeCode == "Fixed" ? "checked" : null) />
                @L["Fixed price"]
            </label>
        </div>
        <div class="nr-budget-card" id="nrBudgetBlock">
            <label asp-for="BudgetAmount">@L["Your budget"] <span class="nr-required" aria-hidden="true">*</span></label>
            <div class="nr-budget-display">
                <input asp-for="BudgetAmount" type="number" min="1" step="1" class="nr-budget-input" placeholder="25" inputmode="numeric" aria-required="true" />
                <span class="nr-budget-suffix" id="nrBudgetSuffix">@L["/hr"]</span>
                <span class="nr-budget-icon"><i class="fas fa-dollar-sign"></i></span>
            </div>
            <p class="nr-budget-hint">@L["This is the amount helpers will see in your job post."]</p>
        </div>
        <span asp-validation-for="PayTypeCode" class="field-validation-error"></span>
        <span asp-validation-for="BudgetAmount" class="field-validation-error" id="nrBudgetError"></span>
    </section>
  }
  else
  {
    <div class="nr-pref-card">
        <div class="nr-section-title">
            <span class="nr-section-icon"><i class="fas fa-clock"></i></span>
            <span>@L["Estimated time"]<br /><small class="nr-section-sub">@L["When do you need help?"]</small></span>
        </div>
        <div class="nr-pref-options">
            @foreach (var option in Model.TimelineOptions)
            {
                <label class="nr-pref-option">
                    <input type="radio" name="TimelineCode" value="@option.Value" @(Model.TimelineCode == option.Value ? "checked" : null) />
                    <span class="nr-pref-option-body">
                        <span class="nr-option-radio"></span>
                        <span>@L[option.Label]</span>
                    </span>
                </label>
            }
        </div>
        <span asp-validation-for="TimelineCode" class="field-validation-error"></span>
    </div>
  }

    <div class="nr-wizard-scroll-spacer" aria-hidden="true"></div>
</form>

@section WizardFooter {
    @{ ViewData["NrWizardFormId"] = "nrPreferencesForm"; ViewData["NrWizardContinueLabel"] = L["Continue"]; ViewData["NrWizardContinueIconAfter"] = "fa-arrow-right"; }
    @await Html.PartialAsync("_NrWizardFooter")
}

@section Scripts {
    <script>
        (function () {
            var pickDateWrap = document.getElementById('nrPickDateWrap');
            var neededByDate = document.getElementById('NeededByDate');
            var pickDateValue = document.getElementById('nrPickDateValue');
            var minDate = neededByDate?.getAttribute('data-min-date') || neededByDate?.getAttribute('min') || '';
            var selectDateLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Select a date"]));
            var dateLocale = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L.CurrentCulture));

            function formatPickDate(value) {
                if (!value) return selectDateLabel;
                var date = new Date(value + 'T12:00:00');
                return date.toLocaleDateString(dateLocale, { weekday: 'long', month: 'long', day: 'numeric' });
            }

            function syncPickDateLabel() {
                if (pickDateValue) {
                    pickDateValue.textContent = formatPickDate(neededByDate?.value || '');
                }
            }

            function clampNeededByDate() {
                if (!neededByDate || !minDate) return;
                neededByDate.setAttribute('min', minDate);
                if (neededByDate.value && neededByDate.value < minDate) {
                    neededByDate.value = minDate;
                }
                syncPickDateLabel();
            }

            clampNeededByDate();
            if (neededByDate) {
                neededByDate.addEventListener('change', clampNeededByDate);
                neededByDate.addEventListener('input', clampNeededByDate);
            }

            document.querySelectorAll('[name="WhenCode"]').forEach(function (input) {
                input.addEventListener('change', function () {
                    if (pickDateWrap) {
                        pickDateWrap.hidden = input.value !== 'PickDate' || !input.checked;
                    }
                    document.querySelectorAll('.nr-option-tile').forEach(function (tile) {
                        var radio = tile.querySelector('input[type="radio"]');
                        if (radio && radio.name === 'WhenCode') {
                            tile.classList.toggle('is-selected', radio.checked);
                        }
                    });
                    if (input.value === 'PickDate' && input.checked) {
                        clampNeededByDate();
                    }
                });
                if (input.checked && input.value === 'PickDate' && pickDateWrap) {
                    pickDateWrap.hidden = false;
                    clampNeededByDate();
                }
            });

            document.querySelectorAll('.nr-option-tile input, .nr-pay-toggle-btn input').forEach(function (input) {
                input.addEventListener('change', function () {
                    var tile = input.closest('.nr-option-tile, .nr-pay-toggle-btn');
                    if (tile && tile.classList.contains('nr-option-tile')) {
                        var group = input.name;
                        document.querySelectorAll('.nr-option-tile input[name="' + group + '"]').forEach(function (r) {
                            r.closest('.nr-option-tile')?.classList.toggle('is-selected', r.checked);
                        });
                    }
                    if (input.name === 'PayTypeCode') {
                        document.querySelectorAll('.nr-pay-toggle-btn').forEach(function (btn) {
                            btn.classList.toggle('is-active', btn.querySelector('input')?.checked);
                        });
                        var suffix = document.getElementById('nrBudgetSuffix');
                        if (suffix) {
                            suffix.textContent = input.value === 'Fixed' ? '' : @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["/hr"]));
                        }
                    }
                });
            });

            document.querySelectorAll('.nr-option-tile input:checked').forEach(function (input) {
                input.closest('.nr-option-tile')?.classList.add('is-selected');
            });

            document.querySelectorAll('.nr-pay-toggle-btn input:checked').forEach(function (input) {
                input.closest('.nr-pay-toggle-btn')?.classList.add('is-active');
            });

            var form = document.getElementById('nrPreferencesForm');
            var budgetInput = document.querySelector('[name="BudgetAmount"]');
            var budgetError = document.getElementById('nrBudgetError');
            var budgetBlock = document.getElementById('nrBudgetBlock');
            var budgetRequiredMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Enter your budget."]));

            function clearBudgetError() {
                if (budgetError) budgetError.textContent = '';
                budgetBlock?.classList.remove('is-error');
            }

            function setBudgetError() {
                if (budgetError) budgetError.textContent = budgetRequiredMsg;
                budgetBlock?.classList.add('is-error');
                budgetBlock?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            if (budgetInput) {
                budgetInput.addEventListener('input', function () {
                    if (parseFloat(budgetInput.value) > 0) clearBudgetError();
                });
            }

            if (form && budgetInput) {
                form.addEventListener('submit', function (e) {
                    var amount = parseFloat(budgetInput.value);
                    if (!budgetInput.value || isNaN(amount) || amount <= 0) {
                        e.preventDefault();
                        setBudgetError();
                    }
                });
            }

            function scrollCardIntoView(el) {
                if (!el) return;
                var card = el.closest('.nr-card, .nr-pref-card');
                if (card) {
                    card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            }

            document.querySelectorAll('.nr-option-tile, .nr-pay-toggle-btn, .nr-input').forEach(function (el) {
                el.addEventListener('click', function () { scrollCardIntoView(el); });
                el.addEventListener('focus', function () { scrollCardIntoView(el); });
            });
        })();
    </script>
}
