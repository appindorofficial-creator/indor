@model IndorMvcApp.ViewModels.NeighborRequestWizardShellViewModel
@if (Model.TotalSteps <= 3)
{
    <nav class="nr-stepper" aria-label="Progress">
        @for (var step = 1; step <= Model.TotalSteps; step++)
        {
            var label = Model.StepLabels.Count >= step ? Model.StepLabels[step - 1] : $"Step {step}";
            var isActive = step == Model.DisplayStep;
            var isComplete = step < Model.DisplayStep;
            <div class="nr-stepper-item@(isActive ? " is-active" : string.Empty)@(isComplete ? " is-complete" : string.Empty)">
                <span class="nr-stepper-dot">@step</span>
                <span class="nr-stepper-label">@label</span>
            </div>
            @if (step < Model.TotalSteps)
            {
                <span class="nr-stepper-line@(isComplete ? " is-complete" : string.Empty)" aria-hidden="true"></span>
            }
        }
    </nav>
}
