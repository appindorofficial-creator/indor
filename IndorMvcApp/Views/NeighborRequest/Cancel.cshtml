@model IndorMvcApp.ViewModels.NeighborRequestCancelViewModel
@{
    ViewData["Title"] = L["Cancel request"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@L["Cancel request"] - INDOR</title>
    @await Html.PartialAsync("_IndorStandalonePageHead")
    <link rel="stylesheet" href="~/css/neighbor-request-cancel.css" asp-append-version="true" />
</head>
<body class="nr-cancel-page">
    <div class="nr-cancel-shell">
        <header class="nr-cancel-top">
            <a href="@Model.BackUrl" class="nr-cancel-nav-btn" aria-label="@L["Back"]">
                <i class="fas fa-arrow-left"></i>
            </a>
            <strong class="nr-cancel-top-title">@L["Cancel request"]</strong>
            <span class="nr-cancel-nav-btn nr-cancel-nav-btn--spacer" aria-hidden="true"></span>
        </header>

        <section class="nr-cancel-hero">
            <div class="nr-cancel-warning" aria-hidden="true">
                <i class="fas fa-triangle-exclamation"></i>
            </div>
            <h1>@L["Cancel this request?"]</h1>
            <p>@L["Your request will no longer be visible and you will stop receiving new offers."]</p>
        </section>

        <article class="nr-cancel-summary">
            <div class="nr-cancel-summary-head">
                <span class="nr-cancel-icon" aria-hidden="true">
                    <i class="fas @Model.IconClass"></i>
                </span>
                <div class="nr-cancel-title-wrap">
                    <h2 class="nr-cancel-title">@Model.Title</h2>
                </div>
                <span class="nr-cancel-status @Model.StatusCss">@Model.StatusLabel</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.LocationAddress))
            {
                <div class="nr-cancel-location">
                    <i class="fas fa-location-dot" aria-hidden="true"></i>
                    <span>@Model.LocationAddress</span>
                </div>
            }

            @if (Model.DetailStats.Count > 0)
            {
                <div class="nr-cancel-stats">
                    @for (var i = 0; i < Model.DetailStats.Count; i++)
                    {
                        var stat = Model.DetailStats[i];
                        if (i > 0)
                        {
                            <span class="nr-cancel-stat-divider" aria-hidden="true"></span>
                        }
                        <div class="nr-cancel-stat">
                            <i class="fas @stat.IconClass" aria-hidden="true"></i>
                            <span>@stat.Label</span>
                        </div>
                    }
                </div>
            }
        </article>

        <form asp-action="Cancel" method="post" class="nr-cancel-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PropiedadId" />

            <div class="nr-cancel-field">
                <label for="CancelReasonCode">@L["Reason"] <span>@L["(optional)"]</span></label>
                <div class="nr-cancel-select-wrap">
                    <select asp-for="CancelReasonCode" class="nr-cancel-select" id="CancelReasonCode">
                        <option value="">@L["Select a reason"]</option>
                        @foreach (var reason in Model.ReasonOptions)
                        {
                            <option value="@reason.Value">@reason.Label</option>
                        }
                    </select>
                    <i class="fas fa-chevron-down" aria-hidden="true"></i>
                </div>
            </div>

            <div class="nr-cancel-field">
                <label for="CancelNote">@L["Add note"] <span>@L["(optional)"]</span></label>
                <textarea asp-for="CancelNote" class="nr-cancel-textarea" id="CancelNote" maxlength="500" placeholder="@L["Add note"]"></textarea>
            </div>

            <p class="nr-cancel-hint">@L["You can create a new request anytime."]</p>

            <div class="nr-cancel-actions">
                <button type="submit" class="nr-cancel-submit">
                    <i class="far fa-trash-can" aria-hidden="true"></i>
                    <span>@L["Cancel request"]</span>
                </button>
                <a href="@Model.KeepUrl" class="nr-cancel-keep">@L["Keep request"]</a>
            </div>
        </form>
    </div>
</body>
</html>
