@{
    var formId = ViewData["NrWizardFormId"] as string;
    var href = ViewData["NrWizardContinueHref"] as string;
    var label = ViewData["NrWizardContinueLabel"] as string ?? L["Continue"];
    var iconBefore = ViewData["NrWizardContinueIconBefore"] as string;
    var iconAfter = ViewData["NrWizardContinueIconAfter"] as string;
    if (iconAfter == null && iconBefore == null && string.IsNullOrWhiteSpace(href))
    {
        iconAfter = "fa-arrow-right";
    }
}

<div class="nr-wizard-footer">
    <div class="nr-wizard-footer-inner">
        @if (!string.IsNullOrWhiteSpace(href))
        {
            <a href="@href" class="nr-btn-primary">
                @if (!string.IsNullOrWhiteSpace(iconBefore))
                {
                    <i class="fas @iconBefore"></i>
                }
                @label
                @if (!string.IsNullOrWhiteSpace(iconAfter))
                {
                    <i class="fas @iconAfter"></i>
                }
            </a>
        }
        else
        {
            @* type=button + data-nr-wizard-submit: sticky footer lives outside <form>.
               Native form="…" association drops fields / hangs loading on some WebViews. *@
            <button type="button"
                    class="nr-btn-primary"
                    data-nr-wizard-submit="@formId"
                    @(string.IsNullOrWhiteSpace(formId) ? null : Html.Raw($"aria-controls=\"{formId}\""))>
                @if (!string.IsNullOrWhiteSpace(iconBefore))
                {
                    <i class="fas @iconBefore"></i>
                }
                @label
                @if (!string.IsNullOrWhiteSpace(iconAfter))
                {
                    <i class="fas @iconAfter"></i>
                }
            </button>
        }
    </div>
</div>
