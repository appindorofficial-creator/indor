@{
    var wizardModel = Model as IndorMvcApp.ViewModels.NeighborRequestWizardShellViewModel;
    var pageTitleKey = wizardModel?.PageTitle ?? ViewData["Title"] as string ?? "Post a Request";
    var pageTitle = L[pageTitleKey];
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@pageTitle - INDOR</title>
    @await Html.PartialAsync("_AppVersionHead")
    @await Html.PartialAsync("_IndorDesignHead")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/neighbor-request-wizard.css" asp-append-version="true" />
    @await Html.PartialAsync("_TabletResponsiveHead")
</head>
<body class="nr-wizard-page">
    <div class="nr-wizard-shell">
        @if (wizardModel != null)
        {
            @await Html.PartialAsync("_WizardHeader", wizardModel)
        }
        @RenderBody()
    </div>
    @RenderSection("WizardFooter", required: false)
    <script src="~/js/neighbor-request-wizard.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
