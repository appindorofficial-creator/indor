@model IndorMvcApp.ViewModels.NeighborRequestReviewStepViewModel
@{
    ViewData["Title"] = Model.IsEditMode ? L["Edit request"] : L["Review request"];
}

@if (!Model.IsEditMode)
{
    <div class="nr-wizard-heading">
        <h1>@L["Review request"]</h1>
        <p>@L["Confirm everything looks right before publishing"]</p>
    </div>
}

<div class="nr-review-list">
    <article class="nr-review-card">
        <span class="nr-review-icon"><i class="fas @Model.CategoryIconClass"></i></span>
        <div class="nr-review-copy">
            <span class="nr-review-label">@L["Category"]</span>
            <span class="nr-review-value">@UiDisplayLocalization.Localize(L, Model.CategoryLabel)</span>
        </div>
    </article>

    <article class="nr-review-card">
        <span class="nr-review-icon"><i class="fas fa-font"></i></span>
        <div class="nr-review-copy">
            <span class="nr-review-label">@L["Title"]</span>
            <span class="nr-review-value nr-review-value--text">@Model.Title</span>
        </div>
    </article>

    @if (!string.IsNullOrWhiteSpace(Model.DetailsSummary))
    {
        <article class="nr-review-card">
            <span class="nr-review-icon"><i class="fas fa-list"></i></span>
            <div class="nr-review-copy">
                <span class="nr-review-label">@L["Details"]</span>
                <span class="nr-review-value nr-review-value--text">@UiDisplayLocalization.Localize(L, Model.DetailsSummary)</span>
            </div>
        </article>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <article class="nr-review-card">
            <span class="nr-review-icon"><i class="fas fa-align-left"></i></span>
            <div class="nr-review-copy">
                <span class="nr-review-label">@L["Description"]</span>
                <span class="nr-review-value nr-review-value--text">@Model.Description</span>
            </div>
        </article>
    }

    @if (Model.PhotoUrls.Count > 0)
    {
        <article class="nr-review-card">
            <span class="nr-review-icon"><i class="fas fa-image"></i></span>
            <div class="nr-review-copy">
                <span class="nr-review-label">@L["Photos"]</span>
                <div class="nr-review-photos">
                    @foreach (var photo in Model.PhotoUrls)
                    {
                        <img src="@Url.Content("~" + photo)" alt="" />
                    }
                </div>
            </div>
        </article>
    }

    <article class="nr-review-card">
        <span class="nr-review-icon"><i class="fas fa-location-dot"></i></span>
        <div class="nr-review-copy">
            <span class="nr-review-label">@L["Location"]</span>
            <span class="nr-review-value nr-review-value--text">@Model.LocationAddress</span>
        </div>
    </article>

    <article class="nr-review-card">
        <span class="nr-review-icon"><i class="fas fa-calendar"></i></span>
        <div class="nr-review-copy">
            <span class="nr-review-label">@L["Timeline"]</span>
            <span class="nr-review-value">@UiDisplayLocalization.Localize(L, Model.TimelineLabel)</span>
        </div>
    </article>

    <article class="nr-review-card">
        <span class="nr-review-icon"><i class="fas fa-users"></i></span>
        <div class="nr-review-copy">
            <span class="nr-review-label">@L["Who can help?"]</span>
            <span class="nr-review-value">@UiDisplayLocalization.Localize(L, Model.AudienceLabel)</span>
        </div>
    </article>

    @if (!string.IsNullOrWhiteSpace(Model.NeededByLabel))
    {
        <article class="nr-review-card">
            <span class="nr-review-icon"><i class="fas fa-calendar-day"></i></span>
            <div class="nr-review-copy">
                <span class="nr-review-label">@L["Needed by"]</span>
                <span class="nr-review-value">@Model.NeededByLabel</span>
            </div>
        </article>
    }

    @if (!string.IsNullOrWhiteSpace(Model.TimeWindowLabel))
    {
        <article class="nr-review-card">
            <span class="nr-review-icon"><i class="fas fa-clock"></i></span>
            <div class="nr-review-copy">
                <span class="nr-review-label">@L["Time window"]</span>
                <span class="nr-review-value">@UiDisplayLocalization.Localize(L, Model.TimeWindowLabel)</span>
            </div>
        </article>
    }

    @if (!string.IsNullOrWhiteSpace(Model.BudgetLabel))
    {
        <article class="nr-review-card">
            <span class="nr-review-icon"><i class="fas fa-dollar-sign"></i></span>
            <div class="nr-review-copy">
                <span class="nr-review-label">@L["Budget"]</span>
                <span class="nr-review-value">@UiDisplayLocalization.Localize(L, Model.BudgetLabel)</span>
            </div>
        </article>
    }
</div>

<form asp-action="Publish" method="post" id="nrReviewPublishForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="propiedadId" value="@Model.PropiedadId" />
    @if (Model.RequestId is > 0)
    {
        <input type="hidden" name="requestId" value="@Model.RequestId" />
    }
</form>

@section WizardFooter {
    @{
        ViewData["NrWizardFormId"] = "nrReviewPublishForm";
        ViewData["NrWizardContinueLabel"] = L[Model.PublishButtonLabel];
        ViewData["NrWizardContinueIconAfter"] = "";
        ViewData["NrWizardContinueIconBefore"] = "";
    }
    @await Html.PartialAsync("_NrWizardFooter")
}
