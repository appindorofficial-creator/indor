@model IndorMvcApp.ViewModels.RealtorUrgentQuotePhotosViewModel

@await Html.PartialAsync("_UrgentQuoteSummary", Model.Property)



<div class="rl-info-box">

    <i class="fas fa-circle-info"></i>

    <p>@L["Add 1–3 photos if you have them. This helps providers reply faster, but for urgent requests you can also skip this step."]</p>

</div>



<form id="urgentPhotosForm" asp-action="Photos" method="post" enctype="multipart/form-data" class="rl-invite-form">

    @Html.AntiForgeryToken()



    <h2 class="rl-invite-section-title">@L["Photos"]</h2>

    <div class="rl-photo-upload-grid">

        @foreach (var photo in Model.Photos)

        {

            <div class="rl-photo-thumb-wrap">

                <img src="@photo.FileUrl" alt="" />

                <button type="submit" form="removePhoto@(photo.Id)" class="rl-photo-remove"><i class="fas fa-xmark"></i></button>

            </div>

        }

        @if (Model.Photos.Count < 3)

        {

            <label class="rl-photo-add">

                <input type="file" name="photos" accept="image/*" multiple />

                <i class="fas fa-plus"></i>

                <span>@L["Add photo"]</span>

            </label>

        }

    </div>



    <div class="rl-photo-actions">

        <label class="ob-btn ob-btn-outline rl-photo-btn">

            <input type="file" name="photos" accept="image/*" capture="environment" /> @L["Take photo"]

        </label>

        <label class="ob-btn ob-btn-outline rl-photo-btn">

            <input type="file" name="photos" accept="image/*" multiple /> @L["Choose from library"]

        </label>

        <button type="submit" name="skipPhotos" value="true" class="rl-skip-link">@L["Skip for now"]</button>

    </div>



    <h2 class="rl-invite-section-title">@L["Optional note"]</h2>

    <textarea name="optionalNote" class="rl-note-area" maxlength="250" rows="3"

              placeholder="@L["Client is in closing and needs a quote response today."]">@Model.OptionalNote</textarea>

    <div class="rl-char-count"><span id="noteCount">@Model.OptionalNote.Length</span> / 250</div>



    <div class="rl-info-box rl-info-box--muted">

        <i class="fas fa-circle-info"></i>

        <p>@L["INDOR can still send the request even if you only add one photo or no photo."]</p>

    </div>

</form>



@foreach (var photo in Model.Photos)

{

    <form id="removePhoto@(photo.Id)" asp-action="RemovePhoto" method="post" style="display:none">

        @Html.AntiForgeryToken()

        <input type="hidden" name="photoId" value="@photo.Id" />

    </form>

}



<div class="rl-invite-actions">

    <a asp-action="Issue" class="rl-invite-cancel">@L["Back"]</a>

    <button type="submit" form="urgentPhotosForm" class="ob-btn ob-btn-primary">@L["Continue"]</button>

</div>



@section Scripts {

<script>

    const note = document.querySelector('[name="optionalNote"]');

    const count = document.getElementById('noteCount');

    note?.addEventListener('input', () => { count.textContent = note.value.length; });

</script>

}

