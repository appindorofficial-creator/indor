@using IndorMvcApp.Helpers
@model IndorMvcApp.ViewModels.RealtorUrgentQuoteSuccessViewModel

@{

    Layout = "_RealtorLayout";

    ViewData["Title"] = L["Urgent Quote Sent"];

    ViewBag.NavActive = "quotes";

}



<div class="rl-dash-shell">

    @await Html.PartialAsync("~/Views/Realtor/_RealtorTopbar.cshtml", new IndorMvcApp.ViewModels.RealtorPortalShellViewModel { HideNotifications = true })



    <section class="rl-success-hero">

        <div class="rl-success-icon-wrap">

            <span class="rl-success-icon"><i class="fas fa-check"></i></span>

        </div>

        <h1>@L["Urgent Quote Sent"]</h1>

        <p>@(Model.ProviderCount == 1
            ? L.T("Your urgent request was sent to {0} provider.", Model.ProviderCount)
            : L.T("Your urgent request was sent to {0} providers.", Model.ProviderCount))</p>

    </section>



    <div class="rl-success-card rl-success-card--quote">

        <div class="rl-success-quote-head">

            <i class="fas fa-bolt"></i>

            <strong>@L.T("Quote #{0}", Model.QuoteCode)</strong>

        </div>

        <div class="rl-success-detail"><strong>@L["Property:"]</strong> @Model.PropertyAddress</div>

        <div class="rl-success-detail"><strong>@L["Issue:"]</strong> @L[Model.ServiceType ?? ""]</div>

        <div class="rl-success-detail"><strong>@L["Response needed:"]</strong> @L[Model.UrgencyLabel ?? ""]</div>

        <div class="rl-success-detail"><strong>@L["Sent:"]</strong> @UiDisplayLocalization.Localize(L, Model.SentWhenLabel)</div>

    </div>



    <a asp-controller="Realtor" asp-action="Quotes" class="ob-btn ob-btn-primary rl-done-btn">@L["Track Quotes"]</a>

    <a asp-controller="Realtor" asp-action="Dashboard" class="rl-later-link">@L["Done"]</a>

</div>
