@model IndorMvcApp.ViewModels.PackingDetailsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_PackingStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="PackingAbout" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_PackingStepper", 2)

    <h2 class="page-heading" style="font-size:1.1rem;">What needs packing?</h2>
    <p class="page-lead" style="margin-top:-8px;">Select rooms, item types, and supplies.</p>

    <div class="address-card">
        <div class="left"><i class="fas fa-house" style="color:#0066CC;"></i><span style="font-weight:600;font-size:0.92rem;">@Model.DireccionPropiedad</span></div>
        <a asp-action="PackingAbout" asp-route-id="@Model.SolicitudId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;">Edit</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="PackingDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="HabitacionesEmpacar" id="HabitacionesEmpacar" />
        <input type="hidden" asp-for="ItemsEspeciales" id="ItemsEspeciales" />
        <input type="hidden" asp-for="SuministrosNecesarios" id="SuministrosNecesarios" />
        <input type="hidden" asp-for="DetallesAcceso" id="DetallesAcceso" />

        <div class="field-card">
            <span class="field-label">Rooms to pack</span>
            <div class="tile-grid" id="roomsGroup">
                <button type="button" class="tile-btn" data-value="Kitchen"><i class="fas fa-kitchen-set"></i>Kitchen</button>
                <button type="button" class="tile-btn" data-value="Bedroom"><i class="fas fa-bed"></i>Bedroom</button>
                <button type="button" class="tile-btn" data-value="LivingRoom"><i class="fas fa-couch"></i>Living room</button>
                <button type="button" class="tile-btn" data-value="Bathroom"><i class="fas fa-bath"></i>Bathroom</button>
                <button type="button" class="tile-btn" data-value="Closet"><i class="fas fa-door-closed"></i>Closet</button>
                <button type="button" class="tile-btn" data-value="Garage"><i class="fas fa-warehouse"></i>Garage</button>
                <button type="button" class="tile-btn" data-value="Office"><i class="fas fa-desktop"></i>Office</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Special items</span>
            <div class="tile-grid" id="specialGroup" style="grid-template-columns:repeat(4,1fr);">
                <button type="button" class="tile-btn" data-value="TVs"><i class="fas fa-tv"></i>TVs</button>
                <button type="button" class="tile-btn" data-value="Glassware"><i class="fas fa-wine-glass"></i>Glassware</button>
                <button type="button" class="tile-btn" data-value="Artwork"><i class="fas fa-image"></i>Artwork</button>
                <button type="button" class="tile-btn" data-value="Electronics"><i class="fas fa-plug"></i>Electronics</button>
                <button type="button" class="tile-btn" data-value="Books"><i class="fas fa-book"></i>Books</button>
                <button type="button" class="tile-btn" data-value="Clothing"><i class="fas fa-shirt"></i>Clothing</button>
                <button type="button" class="tile-btn" data-value="Kitchenware"><i class="fas fa-utensils"></i>Kitchenware</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Supplies needed</span>
            <div class="tile-grid" id="suppliesGroup" style="grid-template-columns:repeat(3,1fr);">
                <button type="button" class="tile-btn" data-value="Boxes"><i class="fas fa-box"></i>Boxes</button>
                <button type="button" class="tile-btn" data-value="Tape"><i class="fas fa-tape"></i>Tape</button>
                <button type="button" class="tile-btn" data-value="BubbleWrap"><i class="fas fa-burst"></i>Bubble wrap</button>
                <button type="button" class="tile-btn" data-value="WardrobeBoxes"><i class="fas fa-shirt"></i>Wardrobe boxes</button>
                <button type="button" class="tile-btn" data-value="Labels"><i class="fas fa-tag"></i>Labels</button>
                <button type="button" class="tile-btn" data-value="NotSure"><i class="fas fa-circle-question"></i>Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Access details</span>
            <div class="chip-row" id="accessGroup" style="flex-wrap:wrap;">
                <button type="button" class="chip-btn" data-value="Stairs"><i class="fas fa-stairs"></i> Stairs</button>
                <button type="button" class="chip-btn" data-value="Elevator"><i class="fas fa-elevator"></i> Elevator</button>
                <button type="button" class="chip-btn" data-value="LongWalk"><i class="fas fa-person-walking"></i> Long walk</button>
                <button type="button" class="chip-btn" data-value="EasyAccess"><i class="fas fa-check"></i> Easy access</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Extra notes</span>
            <div class="input-wrap"><i class="fas fa-note-sticky"></i><textarea asp-for="NotaCorta" rows="3" maxlength="500" placeholder="Need help packing kitchen, glass items, and 2 TVs. Third-floor apartment with elevator."></textarea></div>
        </div>

        <div class="upload-zone">
            <i class="fas fa-cloud-arrow-up"></i>
            <p><strong>Upload photos or item list</strong></p>
            <input type="file" name="files" accept=".jpg,.jpeg,.png,.pdf,.txt" multiple style="margin-top:10px;width:100%;" />
        </div>
        @foreach (var file in Model.ArchivosExistentes)
        {
            <div class="included-row"><i class="fas fa-file"></i><span>@file.NombreArchivo</span></div>
        }

        <button type="submit" class="btn-primary">Next</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>
</div>
<script>
    (function () {
        function initMulti(groupId, hiddenId, initial, single) {
            const hidden = document.getElementById(hiddenId);
            const selected = new Set((initial || hidden.value || '').split('|').filter(Boolean));
            document.querySelectorAll('#' + groupId + ' .tile-btn, #' + groupId + ' .chip-btn').forEach(btn => {
                if (selected.has(btn.dataset.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    const value = btn.dataset.value;
                    if (single) {
                        selected.clear();
                        document.querySelectorAll('#' + groupId + ' .chip-btn').forEach(b => b.classList.remove('active'));
                        selected.add(value);
                        btn.classList.add('active');
                    } else {
                        if (selected.has(value)) { selected.delete(value); btn.classList.remove('active'); }
                        else { selected.add(value); btn.classList.add('active'); }
                    }
                    hidden.value = Array.from(selected).join('|');
                });
            });
            hidden.value = Array.from(selected).join('|');
        }

        initMulti('roomsGroup', 'HabitacionesEmpacar', '@Model.HabitacionesEmpacar');
        initMulti('specialGroup', 'ItemsEspeciales', '@Model.ItemsEspeciales');
        initMulti('suppliesGroup', 'SuministrosNecesarios', '@Model.SuministrosNecesarios');
        initMulti('accessGroup', 'DetallesAcceso', '@Model.DetallesAcceso', true);
    })();
</script>
</body>
</html>
