@await Html.PartialAsync("../Cleaning/_CleaningStyles")
<style>
    .packing-type-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }

    .packing-type-grid .type-card {
        padding: 30px 10px 14px;
        min-height: 96px;
        font-size: 0.74rem;
        line-height: 1.3;
    }

    .packing-type-grid .type-card > i {
        font-size: 1rem;
        margin-bottom: 6px;
    }

    .packing-type-grid .type-card .check {
        top: 6px;
        right: 6px;
        width: 20px;
        height: 20px;
        border-width: 1.5px;
        box-sizing: border-box;
        z-index: 1;
    }

    .packing-type-grid .type-card:not(.active) .check {
        opacity: 0;
    }

    .packing-type-grid .type-card.active .check {
        opacity: 1;
        border-color: #0066CC;
        background: #0066CC;
        box-shadow: none;
    }

    .packing-type-grid .type-card .check i {
        font-size: 0.62rem;
        line-height: 1;
    }
</style>
