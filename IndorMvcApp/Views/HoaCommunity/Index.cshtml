@model IndorMvcApp.ViewModels.HoaCommunityViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle);
    var hfPreview = ViewBag.HouseFactPreview as bool? == true;
    var addressParts = Model.Address.Split(',', 2);
    var line1 = addressParts[0].Trim();
    var line2 = addressParts.Length > 1 ? addressParts[1].Trim() : string.Empty;
}
@section Head {
    <link rel="stylesheet" href="~/css/hoa-community.css" asp-append-version="true" />
}

<div class="hoa-step">@L.T("Step {0} of {1}", Model.CurrentStep, Model.TotalSteps)</div>

<div class="hoa-head">
    <h1 class="hoa-title">@L.Catalog(Model.PageTitle)</h1>
    <p class="hoa-sub">@L.Catalog(Model.PageSubtitle)</p>
</div>

<div class="hoa-property-card">
    <div class="hoa-property-top">
        <div class="hoa-thumb"><i class="fas fa-people-roof"></i></div>
        <div class="hoa-address">
            @line1
            @if (!string.IsNullOrWhiteSpace(line2))
            {
                <div class="line2">@line2</div>
            }
        </div>
        <div class="hoa-photo"><i class="fas fa-image"></i></div>
    </div>
    <div class="hoa-metrics">
        <div class="hoa-metric">
            <div class="k">@L["HOA Status"]</div>
            <div class="v"><span class="hoa-pill @Model.HoaStatusTone">@L.Catalog(Model.HoaStatus)</span></div>
        </div>
        <div class="hoa-metric">
            <div class="k">@L["HOA Name"]</div>
            <div class="v">@Model.HoaName</div>
        </div>
        <div class="hoa-metric">
            <div class="k">@L["Estimated Fee"]</div>
            <div class="v">@Model.EstimatedFee</div>
        </div>
        <div class="hoa-metric">
            <div class="k">@L["Confidence"]</div>
            <div class="v"><span class="hoa-pill @Model.ConfidenceTone">@L.Catalog(Model.Confidence)</span></div>
        </div>
    </div>
</div>

<div class="hoa-tabs">
    @foreach (var tab in Model.Tabs)
    {
        if (hfPreview)
        {
            <a class="hoa-tab @(Model.ActiveTab == tab.Key ? "active" : "")"
               asp-controller="HouseFactPreview" asp-action="HoaCommunity"
               asp-route-tab="@tab.Key">@L.Catalog(tab.Label)</a>
        }
        else
        {
            <a class="hoa-tab @(Model.ActiveTab == tab.Key ? "active" : "")"
               asp-action="Index"
               asp-route-id="@Model.PropiedadId"
               asp-route-tab="@tab.Key">@L.Catalog(tab.Label)</a>
        }
    }
</div>

@if (!Model.HasData)
{
    <div class="hoa-empty-note">
        <i class="fas fa-people-roof" style="font-size:2rem;color:#94A3B8;margin-bottom:10px;"></i>
        <div>@L["No HOA or community data found in your saved House Fact profile."]</div>
        @if (hfPreview)
        {
            <a asp-controller="Propietario" asp-action="PropertyDetails" class="hoa-btn-primary" style="margin-top:16px;">@L["Refresh property data"]</a>
        }
        else
        {
            <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="hoa-btn-primary" style="margin-top:16px;">@L["Refresh property data"]</a>
        }
    </div>
}
else if (Model.ActiveTab == "amenities")
{
    <div class="hoa-amenity-grid">
        @foreach (var amenity in Model.Amenities)
        {
            <div class="hoa-amenity">
                <div class="icon"><i class="fas @amenity.Icon"></i></div>
                <div class="t">@L.Catalog(amenity.Title)</div>
                <div class="s">@L.Catalog(amenity.Description)</div>
            </div>
        }
    </div>
}
else if (Model.ActiveTab == "contacts" && Model.Management != null)
{
    <div class="hoa-mgmt">
        <div class="hoa-mgmt-head">
            <div class="icon"><i class="fas fa-building"></i></div>
            <div>
                <div class="k">@L["Management Company"]</div>
                <div class="v">@Model.Management.Name</div>
                <span class="hoa-pill @Model.Management.BadgeTone" style="margin-top:6px;">@L.Catalog(Model.Management.Badge)</span>
            </div>
        </div>
        @foreach (var contact in Model.Management.Contacts)
        {
            <div class="hoa-contact">
                <div class="icon"><i class="fas @contact.Icon"></i></div>
                <div style="flex:1;">
                    <div class="k">@L.Catalog(contact.Label)</div>
                    <div class="v">
                        @if (contact.IsExternalLink)
                        {
                            <span>@contact.Value <i class="fas fa-arrow-up-right-from-square" style="font-size:.7rem;color:#0066CC;"></i></span>
                        }
                        else
                        {
                            @contact.Value
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(contact.Badge))
                    {
                        <span class="hoa-pill @contact.BadgeTone" style="margin-top:6px;">@L.Catalog(contact.Badge)</span>
                    }
                </div>
            </div>
        }
    </div>

    <div class="hoa-section-title">@L["HOA Documents"]</div>
    <div class="hoa-doc-grid">
        @foreach (var doc in Model.Documents)
        {
            <div class="hoa-doc">
                <i class="fas @doc.Icon"></i>
                <span class="t">@L.Catalog(doc.Title)</span>
                <i class="fas fa-chevron-right hoa-chev"></i>
            </div>
        }
    </div>
}
else
{
    <div class="hoa-panel">
        @foreach (var row in Model.Rows)
        {
            <div class="hoa-row">
                <div class="icon"><i class="fas @row.Icon"></i></div>
                <div class="body">
                    <div class="t">@L.Catalog(row.Title)</div>
                    <div class="s">@L.Catalog(row.Subtitle)</div>
                    @if (!string.IsNullOrWhiteSpace(row.Badge))
                    {
                        <span class="badge @row.BadgeTone">@L.Catalog(row.Badge)</span>
                    }
                </div>
                @if (row.ShowChevron)
                {
                    <i class="fas fa-chevron-right hoa-chev"></i>
                }
            </div>
        }
    </div>
}

<div class="hoa-banner">
    <i class="fas fa-circle-info"></i>
    <div>@L.Catalog(Model.InfoBanner)</div>
</div>

<div class="hoa-btn-row">
    @if (hfPreview)
    {
        <a asp-controller="Propietario" asp-action="PropertyDetails" class="hoa-btn-secondary">
            <i class="fas @Model.SecondaryActionIcon"></i> @L.Catalog(Model.SecondaryActionLabel)
        </a>
        <a asp-controller="Propietario" asp-action="PropertyDetails" class="hoa-btn-primary">
            <i class="fas @Model.PrimaryActionIcon"></i> @L.Catalog(Model.PrimaryActionLabel)
        </a>
    }
    else
    {
        <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="hoa-btn-secondary">
            <i class="fas @Model.SecondaryActionIcon"></i> @L.Catalog(Model.SecondaryActionLabel)
        </a>
        <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="hoa-btn-primary">
            <i class="fas @Model.PrimaryActionIcon"></i> @L.Catalog(Model.PrimaryActionLabel)
        </a>
    }
</div>
