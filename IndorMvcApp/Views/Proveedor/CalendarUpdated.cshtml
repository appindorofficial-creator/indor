@model IndorMvcApp.ViewModels.ProviderProCalendarUpdatedViewModel
@{
    ViewData["Title"] = L["Calendar Updated - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "jobs";
}

<div class="prv-pro-shell prv-pro-shell--calendar prv-pro-shell--report-success">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <section class="prv-pro-job-success-hero">
        <div class="prv-pro-job-success-icon"><i class="fas fa-circle-check"></i></div>
        <h1>@L["Schedule Updated Successfully!"]</h1>
        <p>@L["Your schedule changes have been saved. The customer and technician have been notified."]</p>
    </section>

    <section class="prv-pro-job-success-card">
        <div class="prv-pro-job-success-card-head">
            <h3>@Model.Title</h3>
            <span class="prv-pro-pill prv-pro-pill--connected">@UiDisplayLocalization.Localize(L, Model.StatusLabel)</span>
        </div>
        <p class="prv-pro-calendar-updated-address">@Model.Address</p>
        <dl class="prv-pro-job-success-list">
            <div><dt><i class="fas fa-calendar"></i> @L["Updated Date"]</dt><dd>@Model.UpdatedDateLabel</dd></div>
            <div><dt><i class="fas fa-clock"></i> @L["Updated Time"]</dt><dd>@Model.UpdatedTimeLabel</dd></div>
            <div><dt><i class="fas fa-user-gear"></i> @L["Assigned Technician"]</dt><dd>@Model.AssignedTechnician</dd></div>
            <div><dt><i class="fas fa-tag"></i> @L["Status"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.StatusLabel)</dd></div>
        </dl>
    </section>

    <div class="prv-pro-customer-success-actions">
        <a asp-controller="Proveedor" asp-action="Calendar" class="prv-pro-btn prv-pro-btn--primary prv-pro-btn--block"><i class="fas fa-calendar-week"></i> @L["View Calendar"]</a>
        <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" asp-route-fromCalendar="true" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block"><i class="fas fa-briefcase"></i> @L["View Job"]</a>
        <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block"><i class="fas fa-message"></i> @L["Message Customer"]</a>
        <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-customer-add-another"><i class="fas fa-chevron-left"></i> @L["Back to Home"]</a>
    </div>
</div>
