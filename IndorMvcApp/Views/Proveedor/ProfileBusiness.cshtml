@model IndorMvcApp.ViewModels.ProviderProfileBusinessViewModel
@{
    ViewData["Title"] = "Business Profile - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
    ViewBag.ProfileFlowStep = 2;
    string TriChecked(string pref, bool fallback) =>
        string.Equals(pref, "yes", StringComparison.OrdinalIgnoreCase) || (pref == null && fallback) ? "checked" : "";
    string TriNa(string pref) => string.Equals(pref, "na", StringComparison.OrdinalIgnoreCase) ? "checked" : "";
    string TriNo(string pref, bool fallback) =>
        string.Equals(pref, "no", StringComparison.OrdinalIgnoreCase) || (pref == null && !fallback) ? "checked" : "";
}

<div class="prv-pro-shell prv-pro-shell--profile prv-flow-shell">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head prv-flow-page-head">
        <a asp-controller="Proveedor" asp-action="ProfileCompletion" class="prv-pro-lead-back" aria-label="Back">
            <i class="fas fa-chevron-left"></i>
        </a>
        <div>
            <h1>Business profile</h1>
            <p>Complete your business's main information.</p>
        </div>
    </header>

    @if (TempData["ProfileSaved"] is true)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success">
            <i class="fas fa-circle-check"></i> Business profile saved.
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @Model.ErrorMessage
        </div>
    }

    <form asp-controller="Proveedor" asp-action="ProfileBusiness" method="post" class="prv-pro-edit-profile-form prv-flow-form" novalidate>
        @Html.AntiForgeryToken()

        <section class="prv-pro-wizard-card">
            <h2>Basic information</h2>
            <div class="prv-pro-edit-profile-fields">
                <label>
                    <span>Business name</span>
                    <input type="text" name="BusinessName" value="@Model.BusinessName" placeholder="Legal business name" required />
                </label>
                <label>
                    <span>Category</span>
                    <select name="PrimaryCategoryId">
                        <option value="">Select category</option>
                        @foreach (var cat in Model.CategoryOptions)
                        {
                            if (cat.Id == Model.PrimaryCategoryId)
                            {
                                <option value="@cat.Id" selected="selected">@cat.Label</option>
                            }
                            else
                            {
                                <option value="@cat.Id">@cat.Label</option>
                            }
                        }
                    </select>
                </label>
                <label>
                    <span>Phone</span>
                    <input type="tel" name="Phone" value="@Model.Phone" placeholder="(555) 555-5555" />
                </label>
                <label>
                    <span>Email</span>
                    <input type="email" name="Email" value="@Model.Email" placeholder="you@company.com" />
                </label>
                <label class="prv-flow-website-row">
                    <span>Website</span>
                    <input type="url" name="Website" value="@Model.Website" placeholder="https://" @(Model.WebsiteNotApplicable ? "disabled" : "") id="prvFlowWebsite" />
                    <label class="prv-flow-inline-check">
                        <input type="checkbox" name="WebsiteNotApplicable" value="true" @(Model.WebsiteNotApplicable ? "checked" : "") id="prvFlowWebsiteNa" />
                        Not applicable
                    </label>
                </label>
                <label>
                    <span>Description</span>
                    <textarea name="ServiceDescription" rows="3" placeholder="Short summary of your business">@Model.ServiceDescription</textarea>
                </label>
                <label>
                    <span>Hours</span>
                    <input type="text" name="PreferredHours" value="@Model.PreferredHours" placeholder="Mon–Fri, 8:00 a.m. – 6:00 p.m." />
                </label>
            </div>
        </section>

        <section class="prv-pro-wizard-card">
            <h2>Service options</h2>
            <div class="prv-flow-tri-group">
                <div class="prv-flow-tri">
                    <span>Emergency service</span>
                    <div class="prv-flow-tri-btns">
                        <label><input type="radio" name="EmergencyPreference" value="yes" @TriChecked(Model.EmergencyPreference, Model.EmergencyService) /> Yes</label>
                        <label><input type="radio" name="EmergencyPreference" value="no" @TriNo(Model.EmergencyPreference, Model.EmergencyService) /> No</label>
                        <label><input type="radio" name="EmergencyPreference" value="na" @TriNa(Model.EmergencyPreference) /> N/A</label>
                    </div>
                </div>
                <div class="prv-flow-tri">
                    <span>Same-day jobs</span>
                    <div class="prv-flow-tri-btns">
                        <label><input type="radio" name="SameDayPreference" value="yes" @TriChecked(Model.SameDayPreference, Model.SameDayJobs) /> Yes</label>
                        <label><input type="radio" name="SameDayPreference" value="no" @TriNo(Model.SameDayPreference, Model.SameDayJobs) /> No</label>
                        <label><input type="radio" name="SameDayPreference" value="na" @TriNa(Model.SameDayPreference) /> N/A</label>
                    </div>
                </div>
            </div>
        </section>

        <section class="prv-pro-wizard-card" id="services">
            <h2>Services offered</h2>
            <p>Select the services you provide. These appear on your public profile.</p>
            <div class="prv-pro-profile-tags prv-pro-edit-profile-service-grid">
                @foreach (var option in Model.ServiceOptions)
                {
                    <label class="prv-pro-edit-profile-service-chip @(option.IsSelected ? "is-selected" : "")">
                        <input type="checkbox" name="ServiceIds" value="@option.Id" @(option.IsSelected ? "checked" : "") />
                        <i class="fas @option.IconClass"></i>
                        <span>@option.Label</span>
                    </label>
                }
            </div>
        </section>

        <section class="prv-pro-wizard-card" id="areas">
            <h2>Service areas</h2>
            <div class="prv-pro-edit-profile-fields">
                <label>
                    <span>Primary city</span>
                    <input type="text" name="PrimaryCity" value="@Model.PrimaryCity" placeholder="Charlotte, NC" />
                </label>
                <label>
                    <span>ZIP codes / neighborhoods</span>
                    <input type="text" name="ServiceZipCodes" value="@Model.ServiceZipCodes" placeholder="28202, 28203, Matthews" />
                </label>
            </div>
        </section>

        <p class="prv-flow-tip prv-flow-tip--inline">
            <i class="fas fa-circle-info"></i>
            Missing something? Mark Not applicable or save and finish later.
        </p>

        <footer class="prv-flow-footer prv-flow-footer--form">
            <button type="submit" name="SaveMode" value="save" class="prv-pro-btn prv-pro-btn--primary prv-flow-cta">
                <i class="fas fa-floppy-disk"></i> Save changes
            </button>
            <button type="submit" name="SaveMode" value="continue" class="prv-pro-btn prv-pro-btn--ghost">Save &amp; continue</button>
            <button type="submit" name="SaveMode" value="exit" class="prv-flow-exit">Save &amp; exit</button>
        </footer>
    </form>

    <section class="prv-flow-next-card">
        <h3>What's next</h3>
        <p>After this step, continue to <strong>Documents &amp; verification</strong>.</p>
        <a asp-controller="Proveedor" asp-action="ProfileDocuments" class="prv-flow-next-link">Go to documents <i class="fas fa-arrow-right"></i></a>
    </section>

    @await Html.PartialAsync("_ProfileFlowStepper")
</div>

@section Scripts {
    <script src="~/js/provider-profile-flow.js" asp-append-version="true"></script>
}
