@model IndorMvcApp.ViewModels.MyRequestsViewModel
@{
    ViewData["Title"] = L["My Requests"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-requests.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-req-shell">
    <header class="prv-req-hero">
        <div class="prv-req-hero-top">
            <a asp-controller="Proveedor" asp-action="Network" class="prv-req-brand" aria-label="@L["INDOR PRO"]">
                <span class="prv-req-brand-word">@L["INDOR"]</span>
                <span class="prv-req-brand-pro">@L["PRO"]</span>
            </a>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>
        <div class="prv-req-hero-title">
            <h1>@L["My Requests"]</h1>
            <p>@L["Track posted jobs, quotes, and hiring progress."]</p>
        </div>
        <form method="get" asp-controller="Proveedor" asp-action="MyRequests" class="prv-req-searchbar">
            <input type="hidden" name="tab" value="@Model.ActiveTab" />
            <div class="prv-req-search">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.Query" placeholder="@L["Search my requests..."]" />
            </div>
            <button type="submit" class="prv-req-filter"><i class="fas fa-sliders"></i> @L["Filter"]</button>
        </form>
    </header>

    <div class="prv-req-tabs">
        @foreach (var t in Model.Tabs)
        {
            <a asp-controller="Proveedor" asp-action="MyRequests" asp-route-tab="@t.Id" asp-route-q="@Model.Query"
               class="prv-req-tab @(Model.ActiveTab == t.Id ? "is-active" : "")">@UiDisplayLocalization.Localize(L, t.Label)</a>
        }
    </div>

    @if (Model.Requests.Count == 0)
    {
        <div class="prv-req-empty">
            <i class="fas fa-clipboard-list"></i>
            <strong>@L["No requests yet"]</strong>
            <span>@L["Post a job to start receiving quotes from verified subcontractors."]</span>
            <a asp-controller="Proveedor" asp-action="PostNetworkJob" class="prv-req-empty-btn"><i class="fas fa-plus"></i> @L["Post a Job"]</a>
        </div>
    }
    else
    {
        <div class="prv-req-list">
            @foreach (var r in Model.Requests)
            {
                <div class="prv-req-card">
                    <div class="prv-req-card-top">
                        <span class="prv-req-ico prv-req-ico--@r.IconTone"><i class="fas @r.IconClass"></i></span>
                        <div class="prv-req-card-id">
                            <div class="prv-req-title">@r.Title</div>
                            @if (!string.IsNullOrWhiteSpace(r.TradeLabel))
                            {
                                <div class="prv-req-meta"><i class="fas fa-screwdriver-wrench"></i> @UiDisplayLocalization.Localize(L, r.TradeLabel)</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(r.LocationLabel))
                            {
                                <div class="prv-req-meta"><i class="fas fa-location-dot"></i> @UiDisplayLocalization.Localize(L, r.LocationLabel)</div>
                            }
                        </div>
                        <div class="prv-req-card-right">
                            <span class="prv-req-pill prv-req-pill--@r.StatusKind">
                                @(r.QuoteCount > 0 && r.StatusKind == "green" ? L.T("{0} Quotes Received", r.QuoteCount) : UiDisplayLocalization.Localize(L, r.StatusLabel))
                            </span>
                            @if (!string.IsNullOrWhiteSpace(r.BudgetRange))
                            {
                                <div class="prv-req-budget-mini"><span>@L["Budget"]</span><strong>@r.BudgetRange</strong></div>
                            }
                            <div class="prv-req-posted"><span>@L["Posted"]</span><strong>@r.PostedLabel</strong></div>
                        </div>
                    </div>

                    @await Html.PartialAsync("_RequestStepper", r.Steps)

                    <a asp-controller="Proveedor" asp-action="RequestDetails" asp-route-id="@r.Id" class="prv-req-view">
                        @L["View Request"] <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        </div>
    }
</div>
