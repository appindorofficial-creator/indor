@model IndorMvcApp.ViewModels.ProviderProCustomersPageViewModel
@{
    ViewData["Title"] = "Customers - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "customers";
    var tabs = new[] {
        ("all", "All"),
        ("connected", "Connected"),
        ("needsinvite", "Needs Invite"),
        ("activehomes", "Active Homes"),
        ("approvals", "Approvals")
    };
    var statCards = new[] {
        ("all", "fa-users", "blue", Model.TotalCustomers, "Customers"),
        ("connected", "fa-link", "green", Model.ConnectedCount, "Connected"),
        ("needsinvite", "fa-envelope", "purple", Model.NeedsInviteCount, "Needs Invite"),
        ("activehomes", "fa-house", "blue", Model.ActiveHomesCount, "Active Homes"),
        ("approvals", "fa-clock", "purple", Model.PendingApprovalCount, "Approvals")
    };
    var visibleStatCards = Model.ActiveTab == "all"
        ? statCards
        : statCards.Where(card => card.Item1 == Model.ActiveTab);
}

<div class="prv-pro-shell prv-pro-shell--customers prv-pro-shell--customers-v2">
    <div class="prv-pro-portal-page-hero">
        <div class="prv-pro-jobs-hero-top">
            <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-brand prv-pro-brand--link prv-pro-brand--hero" aria-label="INDOR PRO home">
                <i class="fas fa-house" aria-hidden="true"></i>
                <span class="prv-pro-brand-indor">INDOR</span>
                <span class="prv-pro-brand-pro">PRO</span>
            </a>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>
        <div class="prv-pro-jobs-hero-header">
            <div class="prv-pro-jobs-hero-title-row">
                <h1>Customers</h1>
                <a asp-controller="Proveedor" asp-action="AddCustomer" asp-route-fresh="true" class="prv-pro-jobs-create-btn" aria-label="Add customer">
                    <i class="fas fa-plus" aria-hidden="true"></i> Add Customer
                </a>
            </div>
            <p>Manage homeowners, properties, and connected home records.</p>
        </div>

        <form method="get" asp-controller="Proveedor" asp-action="Customers" class="prv-pro-jobs-hero-search">
            <div class="prv-pro-jobs-search-row">
                <div class="prv-pro-search-wrap">
                    <i class="fas fa-magnifying-glass"></i>
                    <input type="search" name="q" value="@Model.SearchQuery" placeholder="Search customers, properties, phone, address..." />
                </div>
                <div class="prv-pro-filter-wrap">
                    <button type="button" class="prv-pro-filter-btn prv-pro-filter-btn--labeled" id="prvCustomersFilterBtn" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-sliders"></i> Filter
                    </button>
                    <div class="prv-pro-filter-menu" id="prvCustomersFilterMenu" role="menu" hidden>
                        @foreach (var (id, label) in tabs)
                        {
                            <a asp-controller="Proveedor" asp-action="Customers"
                               asp-route-tab="@id"
                               asp-route-q="@Model.SearchQuery"
                               class="prv-pro-filter-menu-item @(Model.ActiveTab == id ? "is-active" : null)"
                               role="menuitem">
                                <span>@label</span>
                                @if (Model.ActiveTab == id)
                                {
                                    <i class="fas fa-check"></i>
                                }
                            </a>
                        }
                    </div>
                </div>
            </div>
            <div class="prv-pro-jobs-filter-chips">
                @foreach (var (id, label) in tabs)
                {
                    <a asp-controller="Proveedor" asp-action="Customers"
                       asp-route-tab="@id"
                       asp-route-q="@Model.SearchQuery"
                       class="prv-pro-jobs-filter-chip @(Model.ActiveTab == id ? "is-active" : null)">@label</a>
                }
            </div>
        </form>
    </div>

    <section class="prv-pro-jobs-stats prv-pro-jobs-stats--overview @(Model.ActiveTab == "all" ? null : "prv-pro-jobs-stats--single")">
        @foreach (var (tabId, icon, tone, count, label) in visibleStatCards)
        {
            <a asp-controller="Proveedor" asp-action="Customers" asp-route-tab="@tabId" asp-route-q="@Model.SearchQuery"
               class="prv-pro-jobs-stat @(Model.ActiveTab == tabId ? "is-highlighted" : null)">
                <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--@tone"><i class="fas @icon"></i></span>
                <div class="prv-pro-jobs-stat-copy">
                    <strong>@count</strong>
                    <span>@label</span>
                </div>
                @if (Model.ActiveTab != "all")
                {
                    <i class="fas fa-chevron-right prv-pro-jobs-stat-chevron" aria-hidden="true"></i>
                }
            </a>
        }
    </section>

    <section class="prv-pro-customers-list">
        @if (Model.Customers.Count == 0)
        {
            <div class="prv-pro-customers-empty">
                <img src="~/images/customers-empty.png" alt="" class="prv-pro-customers-empty-art" asp-append-version="true" />
                <h2>No customers yet</h2>
                <p>When you add customers, they'll appear here along with their properties, connection status, and recent activity.</p>
                <a asp-controller="Proveedor" asp-action="AddCustomer" asp-route-fresh="true" class="prv-pro-customers-empty-btn">
                    <i class="fas fa-plus" aria-hidden="true"></i> Add Your First Customer
                </a>
            </div>
        }
        else
        {
            @foreach (var customer in Model.Customers)
            {
                <article class="prv-pro-customer-card">
                    <button type="button" class="prv-pro-job-card-menu" aria-label="More options"><i class="fas fa-ellipsis-vertical"></i></button>

                    <div class="prv-pro-customer-card-top">
                        <div class="prv-pro-customer-card-avatar"><i class="fas fa-user"></i></div>
                        <div class="prv-pro-customer-card-info">
                            <div class="prv-pro-customer-card-name-row">
                                <strong>@customer.Name</strong>
                                <span class="prv-pro-pill prv-pro-pill--@customer.ConnectionClass">@customer.ConnectionLabel</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(customer.Address))
                            {
                                <small class="prv-pro-customer-card-address">@customer.Address</small>
                            }
                            <div class="prv-pro-customer-indicators">
                                @if (customer.IsPropertyVerified)
                                {
                                    <span><i class="fas fa-circle-check"></i> Property verified</span>
                                }
                                @if (customer.IsAppConnected)
                                {
                                    <span><i class="fas fa-mobile-screen"></i> App connected</span>
                                }
                                <span><i class="fas fa-house"></i> @customer.PropertiesCount propert@(customer.PropertiesCount == 1 ? "y" : "ies")</span>
                            </div>
                        </div>
                    </div>

                    @if (customer.ShowJobSection)
                    {
                        <div class="prv-pro-customer-job-section">
                            <div class="prv-pro-customer-job-main">
                                <span class="prv-pro-pill prv-pro-pill--@customer.JobStatusClass">@customer.JobStatusLabel</span>
                                <strong>@customer.JobTitle</strong>
                                @if (customer.JobMetaLines.Count > 0)
                                {
                                    <div class="prv-pro-job-card-meta">
                                        @foreach (var meta in customer.JobMetaLines)
                                        {
                                            <span class="prv-pro-meta-line prv-pro-meta-line--@meta.Tone">
                                                <i class="fas @meta.IconClass"></i> @meta.Text
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="prv-pro-job-quick-links">
                                <span><i class="fas fa-briefcase"></i> Jobs</span>
                                <span><i class="fas fa-message"></i> Messages</span>
                                <span><i class="fas fa-house"></i> Property</span>
                                @if (customer.ShowPhotosLink)
                                {
                                    <span><i class="fas fa-camera"></i> Photos</span>
                                }
                                <span><i class="fas fa-clipboard-list"></i> House Facts</span>
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(customer.ActivityNote))
                    {
                        <div class="prv-pro-customer-activity-note">
                            <i class="fas fa-phone"></i> @customer.ActivityNote
                        </div>
                    }

                    <div class="prv-pro-customer-card-actions">
                        <button type="button" class="prv-pro-btn prv-pro-btn--@customer.PrimaryActionClass">@customer.PrimaryAction</button>
                        @if (!string.IsNullOrWhiteSpace(customer.SecondaryAction))
                        {
                            <button type="button" class="prv-pro-btn prv-pro-btn--ghost">@customer.SecondaryAction</button>
                        }
                    </div>
                </article>
            }
        }
    </section>

    @if (Model.ConnectionInsights.Count > 0 && Model.Customers.Count > 0)
    {
        <section class="prv-pro-smart-suggestions prv-pro-connection-insights">
            <div class="prv-pro-panel-head">
                <div>
                    <h2><i class="fas fa-wand-magic-sparkles"></i> Connection Insights</h2>
                    <p>Grow customer engagement and home record quality.</p>
                </div>
            </div>
            <div class="prv-pro-smart-scroll">
                @foreach (var tip in Model.ConnectionInsights)
                {
                    <article class="prv-pro-smart-card prv-pro-smart-card--@tip.Tone">
                        <i class="fas @tip.IconClass"></i>
                        <span>@tip.Text</span>
                    </article>
                }
            </div>
        </section>
    }

    <a asp-controller="Proveedor" asp-action="AddCustomer" asp-route-fresh="true" class="prv-pro-fab" aria-label="Add customer"><i class="fas fa-plus"></i></a>
</div>

@section Scripts {
<script>
    (function () {
        var filterBtn = document.getElementById('prvCustomersFilterBtn');
        var filterMenu = document.getElementById('prvCustomersFilterMenu');
        if (!filterBtn || !filterMenu) {
            return;
        }

        function closeMenu() {
            filterMenu.hidden = true;
            filterBtn.setAttribute('aria-expanded', 'false');
        }

        filterBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = filterMenu.hidden;
            filterMenu.hidden = !willOpen;
            filterBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });

        document.addEventListener('click', closeMenu);
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeMenu();
            }
        });
    })();
</script>
}
