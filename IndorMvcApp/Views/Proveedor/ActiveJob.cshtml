@model IndorMvcApp.ViewModels.ProviderProActiveJobViewModel
@{
    ViewData["Title"] = L["Active Job - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "jobs";
}

<div class="prv-pro-shell prv-pro-shell--workflow">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head">
        <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Active Job"]</h1>
            <small>@Model.Title</small>
        </div>
    </header>

    <section class="prv-pro-active-summary">
        <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Job" />
        <div>
            <strong>@Model.Title</strong>
            <small>@Model.Address</small>
            <div class="prv-pro-active-badges">
                <span class="prv-pro-pill prv-pro-pill--progress">@L["In Progress"]</span>
                <span class="prv-pro-pill prv-pro-pill--scheduled">@UiDisplayLocalization.Localize(L, Model.StartedLabel)</span>
                <span class="prv-pro-pill prv-pro-pill--connected"><i class="fas fa-stopwatch"></i> @Model.ElapsedLabel</span>
                <span class="prv-pro-pill prv-pro-pill--scheduled"><i class="fas fa-wrench"></i> @UiDisplayLocalization.Localize(L, Model.ServiceType)</span>
                @if (!string.IsNullOrWhiteSpace(Model.DistanceLabel))
                {
                    <span class="prv-pro-pill prv-pro-pill--connected">@UiDisplayLocalization.Localize(L, Model.DistanceLabel)</span>
                }
            </div>
        </div>
    </section>

    <section class="prv-pro-lead-section">
        <h3>@L["Service Checklist"]<small>@L.T("{0} steps", Model.Checklist.Count)</small></h3>
        <ul class="prv-pro-checklist prv-pro-checklist--full">
            @foreach (var item in Model.Checklist)
            {
                <li class="@(item.IsCompleted ? "is-done" : item.IsInProgress ? "is-active" : "")">
                    <i class="fas @(item.IsCompleted ? "fa-circle-check" : item.IsInProgress ? "fa-spinner" : "fa-circle")"></i>
                    <div>
                        @UiDisplayLocalization.Localize(L, item.Label)
                        @if (item.IsInProgress)
                        {
                            <span class="prv-pro-pill prv-pro-pill--progress">@L["In Progress"]</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(item.CompletedLabel))
                        {
                            <small>@item.CompletedLabel</small>
                        }
                    </div>
                </li>
            }
        </ul>
    </section>

    @if (Model.PhotoLabels.Count > 0)
    {
        <section class="prv-pro-lead-section">
            <h3>@L["Photo Evidence"]</h3>
            <div class="prv-pro-active-photos">
                @foreach (var label in Model.PhotoLabels)
                {
                    <div class="prv-pro-active-photo">
                        <img src="@Url.Content($"~{Model.ImageUrl}")" alt="@UiDisplayLocalization.Localize(L, label)" />
                        <span>@UiDisplayLocalization.Localize(L, label)</span>
                    </div>
                }
            </div>
        </section>
    }

    @if (Model.Materials.Count > 0)
    {
        <section class="prv-pro-lead-section">
            <h3>@L["Materials Used"]</h3>
            <ul class="prv-pro-materials-list">
                @foreach (var material in Model.Materials)
                {
                    <li><strong>@material.Name</strong> <span>@material.Quantity</span></li>
                }
            </ul>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.JobNotes))
    {
        <section class="prv-pro-lead-section">
            <h3>@L["Job Notes"]</h3>
            <p class="prv-pro-lead-description">@Model.JobNotes</p>
        </section>
    }

    <section class="prv-pro-lead-section">
        <h3>@L["Homeowner Approval"]<span class="prv-pro-pill prv-pro-pill--urgency">@L["Required"]</span></h3>
        @if (Model.HasSignature)
        {
            <p class="prv-pro-signature">@Model.HomeownerSignature</p>
            <small class="prv-pro-signature-meta"><i class="fas fa-circle-check"></i> @UiDisplayLocalization.Localize(L, Model.SignatureLabel)</small>
        }
        else
        {
            <p class="prv-pro-lead-description">@L["Work completed to satisfaction — awaiting signature."]</p>
        }
    </section>

    <footer class="prv-pro-job-footer">
        <button type="button" class="prv-pro-btn prv-pro-btn--ghost prv-pro-job-action-btn"><i class="fas fa-camera"></i> @L["Add Photos"]</button>
        <form asp-controller="Proveedor" asp-action="CompleteJob" method="post" class="prv-pro-job-footer-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.JobId" />
            <button type="submit" class="prv-pro-btn prv-pro-btn--success prv-pro-job-action-btn">
                <i class="fas fa-circle-check"></i> @L["Complete Job"]</button>
        </form>
        <a asp-controller="Proveedor" asp-action="MessageJob" asp-route-id="@Model.JobId" class="prv-pro-btn prv-pro-btn--ghost prv-pro-job-action-btn"><i class="fas fa-message"></i> @L["Message Homeowner"]</a>
    </footer>
</div>
