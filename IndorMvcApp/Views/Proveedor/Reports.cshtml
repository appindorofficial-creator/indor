@model IndorMvcApp.ViewModels.ProviderProReportsPageViewModel
@{
    ViewData["Title"] = L["Reports - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "reports";
    ViewData["ProviderProExtraCss"] = "reports-v2.css";
    var tabs = new[] {
        ("all", "All Reports"),
        ("draft", "Draft"),
        ("ready", "Ready"),
        ("approval", "Approval"),
        ("approved", "Approved"),
        ("housefacts", "House Facts")
    };
    var quickActions = new (string icon, string label, string color, string? action)[] {
        ("fa-plus", "Create Report", "blue", "ReportTemplates"),
        ("fa-cloud-arrow-up", "Upload Photos", "green", "UploadPhotos"),
        ("fa-paper-plane", "Send Reports", "indigo", null),
        ("fa-layer-group", "Templates", "purple", "Templates"),
        ("fa-file-export", "Export", "orange", "ExportReport")
    };
}

<div class="prv-pro-shell prv-pro-shell--reports prv-pro-shell--reports-v2">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    @if (TempData["ProviderProToast"] is string toast && !string.IsNullOrWhiteSpace(toast))
    {
        <div class="prv-pro-toast"><i class="fas fa-circle-check"></i> @toast</div>
    }

    <section class="prv-pro-jobs-head">
        <div class="prv-pro-reports-title-row">
            <span class="prv-pro-reports-title-badge"><i class="fas fa-chart-simple"></i></span>
            <h1>@L["Reports"]</h1>
        </div>
        <p>@L["Manage completion reports and home records."]</p>
        <a asp-controller="Proveedor" asp-action="ReportTemplates" class="prv-pro-create-btn">
            <i class="fas fa-plus"></i> @L["Create Report"]
        </a>
    </section>

    <form method="get" asp-controller="Proveedor" asp-action="Reports" class="prv-pro-jobs-search">
        <input type="hidden" name="tab" value="@Model.ActiveTab" />
        <div class="prv-pro-search-wrap">
            <i class="fas fa-magnifying-glass"></i>
            <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search reports, jobs, or properties"]" />
        </div>
        <button type="button" class="prv-pro-filter-btn prv-pro-filter-btn--labeled" title="@L["Filters"]">
            <i class="fas fa-sliders"></i> @L["Filters"]
        </button>
    </form>

    <section class="prv-pro-jobs-stats">
        <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="draft" class="prv-pro-jobs-stat prv-pro-jobs-stat--blue">
            <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--blue"><i class="fas fa-file-lines"></i></span>
            <strong>@Model.DraftCount</strong>
            <span>@L["Draft Reports"]</span>
        </a>
        <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="ready" class="prv-pro-jobs-stat prv-pro-jobs-stat--green">
            <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--green"><i class="fas fa-paper-plane"></i></span>
            <strong>@Model.ReadyCount</strong>
            <span>@L["Ready to Send"]</span>
        </a>
        <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="approval" class="prv-pro-jobs-stat prv-pro-jobs-stat--orange">
            <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--orange"><i class="fas fa-clock"></i></span>
            <strong>@Model.ApprovalCount</strong>
            <span>@L["Awaiting Approval"]</span>
        </a>
        <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="approved" class="prv-pro-jobs-stat prv-pro-jobs-stat--purple">
            <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--purple"><i class="fas fa-circle-check"></i></span>
            <strong>@Model.ApprovedCount</strong>
            <span>@L["Approved"]</span>
        </a>
        <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="housefacts" class="prv-pro-jobs-stat prv-pro-jobs-stat--indigo">
            <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--indigo"><i class="fas fa-house"></i></span>
            <strong>@Model.HouseFactsCount</strong>
            <span>@L["Added to House Facts"]</span>
        </a>
    </section>

    <nav class="prv-pro-jobs-tabs">
        @foreach (var (id, label) in tabs)
        {
            <a asp-controller="Proveedor" asp-action="Reports"
               asp-route-tab="@id"
               asp-route-q="@Model.SearchQuery"
               class="@(Model.ActiveTab == id ? "is-active" : "")">@UiDisplayLocalization.Localize(L, label)</a>
        }
    </nav>

    <section class="prv-pro-reports-list">
        @if (Model.Reports.Count == 0)
        {
            <div class="prv-pro-reports-empty">
                <img src="~/images/reports-empty-folder.png" alt="" class="prv-pro-reports-empty-img" loading="lazy" decoding="async" asp-append-version="true" />
                <div class="prv-pro-reports-empty-text">
                    <strong>@L["No reports in this view yet."]</strong>
                    <p>@L["Completion reports for your jobs will appear here."]</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var report in Model.Reports)
            {
                <article class="prv-pro-report-card">
                    <button type="button" class="prv-pro-job-card-menu" aria-label="@L["More options"]"><i class="fas fa-ellipsis-vertical"></i></button>

                    <div class="prv-pro-report-card-main">
                        <div class="prv-pro-job-card-icon"><i class="fas @report.IconClass"></i></div>
                        <div class="prv-pro-report-card-body">
                            <div class="prv-pro-report-title-row">
                                <strong>@report.Title</strong>
                                <span class="prv-pro-pill prv-pro-pill--@report.StatusClass">@UiDisplayLocalization.Localize(L, report.StatusLabel)</span>
                            </div>
                            <small class="prv-pro-report-address">@report.Address</small>
                            <small class="prv-pro-report-meta">@report.CustomerJobLabel</small>
                            <small class="prv-pro-report-meta">@report.CompletedLabel</small>

                            <div class="prv-pro-report-attachments">
                                @if (report.PhotosCount > 0)
                                {
                                    <span><i class="fas fa-image"></i> @report.PhotosCount</span>
                                }
                                @if (report.HasChecklist)
                                {
                                    <span><i class="fas fa-list-check"></i></span>
                                }
                                @if (report.HasWarranty)
                                {
                                    <span><i class="fas fa-shield-halved"></i></span>
                                }
                                @if (report.HasDocuments)
                                {
                                    <span><i class="fas fa-file-lines"></i></span>
                                }
                            </div>
                        </div>
                        <div class="prv-pro-report-action">
                            <button type="button" class="prv-pro-btn prv-pro-btn--@report.ActionClass">@UiDisplayLocalization.Localize(L, report.ActionLabel)</button>
                        </div>
                    </div>
                </article>
            }
        }
    </section>

    <section class="prv-pro-quick prv-pro-quick--reports">
        <h2>@L["Quick Actions"]</h2>
        <div class="prv-pro-quick-grid prv-pro-quick-grid--reports">
            @foreach (var (icon, label, color, action) in quickActions)
            {
                if (!string.IsNullOrEmpty(action))
                {
                    <a asp-controller="Proveedor" asp-action="@action" class="prv-pro-quick-item prv-pro-quick-item--@color">
                        <i class="fas @icon"></i><span>@UiDisplayLocalization.Localize(L, label)</span>
                    </a>
                }
                else
                {
                    <button type="button" class="prv-pro-quick-item prv-pro-quick-item--@color">
                        <i class="fas @icon"></i><span>@UiDisplayLocalization.Localize(L, label)</span>
                    </button>
                }
            }
        </div>
    </section>

    @if (Model.ReportInsights.Count > 0)
    {
        <section class="prv-pro-smart-suggestions prv-pro-connection-insights">
            <div class="prv-pro-panel-head">
                <div>
                    <h2><i class="fas fa-wand-magic-sparkles"></i> Report Insights</h2>
                </div>
            </div>
            <div class="prv-pro-smart-scroll">
                @foreach (var tip in Model.ReportInsights)
                {
                    <article class="prv-pro-smart-card prv-pro-smart-card--@tip.Tone">
                        <i class="fas @tip.IconClass"></i>
                        <span>@tip.Text</span>
                    </article>
                }
            </div>
        </section>
    }

    <a asp-controller="Proveedor" asp-action="ReportTemplates" class="prv-pro-fab" aria-label="@L["Create report"]"><i class="fas fa-plus"></i></a>
</div>
