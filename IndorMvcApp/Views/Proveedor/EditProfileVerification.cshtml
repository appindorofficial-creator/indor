@model IndorMvcApp.ViewModels.ProviderProEditProfileVerificationViewModel
@{
    ViewData["Title"] = L["Verification & Documents - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--edit-profile">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Verification &amp; Documents"]</h1>
            <p>@L["Upload credentials so INDOR can verify your provider account."]</p>
        </div>
    </header>

    @if (TempData["ProfileSaved"] is true)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success">
            <i class="fas fa-circle-check"></i> @L["Document uploaded successfully."]</div>
    }
    @if (TempData["ProfileSectionError"] is string sectionError)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @UiDisplayLocalization.Localize(L, sectionError)
        </div>
    }

    <section class="prv-pro-wizard-card">
        <h2>@L["Verification status"]</h2>
        @foreach (var item in Model.Items)
        {
            <div class="prv-pro-profile-check @(item.IsComplete ? "is-complete" : "")">
                <i class="fas @(item.IsComplete ? "fa-circle-check" : "fa-circle")"></i>
                <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
            </div>
        }
    </section>

    @foreach (var slot in Model.DocumentSlots)
    {
        var fileUrl = string.IsNullOrWhiteSpace(slot.FileUrl) ? null : Url.Content($"~{slot.FileUrl}");
        var isImage = slot.IsUploaded
            && !string.IsNullOrWhiteSpace(slot.FileUrl)
            && (slot.FileUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase)
                || slot.FileUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)
                || slot.FileUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase)
                || slot.FileUrl.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
        var isPdf = slot.IsUploaded
            && !string.IsNullOrWhiteSpace(slot.FileUrl)
            && slot.FileUrl.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
        var fileInputId = $"prvDocFile_{slot.DocumentType.Replace(" ", "", StringComparison.Ordinal).Replace("/", "", StringComparison.Ordinal)}";

        <section class="prv-pro-wizard-card prv-pro-doc-slot @(slot.IsUploaded ? "is-uploaded" : "is-empty")" data-doc-slot="@slot.DocumentType">
            <div class="prv-pro-edit-profile-doc-head">
                <div>
                    <h2>@UiDisplayLocalization.Localize(L, slot.Label)</h2>
                </div>
                @if (slot.IsUploaded)
                {
                    <span class="prv-pro-pill prv-pro-pill--on-file">@L["On file"]</span>
                }
                else
                {
                    <span class="prv-pro-pill prv-pro-pill--pending">@L["Required"]</span>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(fileUrl))
            {
                <div class="prv-pro-doc-on-file" data-role="on-file">
                    <a href="@fileUrl" target="_blank" rel="noopener" class="prv-pro-doc-attached" data-role="attached">
                        @if (isImage)
                        {
                            <img src="@fileUrl" alt="" class="prv-pro-doc-file-thumb" />
                        }
                        else
                        {
                            <span class="prv-pro-doc-file-icon @(isPdf ? "is-pdf" : "")">
                                <i class="fas @(isPdf ? "fa-file-pdf" : "fa-file-lines")"></i>
                            </span>
                        }
                        <span class="prv-pro-doc-file-meta">
                            <span>@L["Tap to open full document"]</span>
                        </span>
                        <span class="prv-pro-doc-file-open" aria-hidden="true"><i class="fas fa-arrow-up-right-from-square"></i></span>
                    </a>
                    <label class="prv-pro-doc-replace-btn" for="@fileInputId" data-role="file-trigger">
                        <span class="prv-pro-doc-empty-icon prv-pro-doc-empty-icon--btn" aria-hidden="true">
                            <i class="fas fa-cloud-arrow-up"></i>
                        </span>
                        <span>@L["Replace"]</span>
                    </label>
                </div>
            }

            <form asp-controller="Proveedor" asp-action="EditProfileVerification" method="post" enctype="multipart/form-data" class="prv-pro-edit-profile-doc-form prv-pro-doc-upload-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="documentType" value="@slot.DocumentType" />

                <input type="file"
                       id="@fileInputId"
                       name="documentFile"
                       class="prv-pro-doc-file-input"
                       data-role="file-input"
                       accept="image/jpeg,image/png,image/webp,application/pdf,.pdf,.jpg,.jpeg,.png,.webp"
                       @(slot.IsUploaded ? null : "required") />

                @if (!slot.IsUploaded)
                {
                    <label class="prv-pro-doc-empty" for="@fileInputId" data-role="file-trigger">
                        <span class="prv-pro-doc-empty-icon" aria-hidden="true"><i class="fas fa-cloud-arrow-up"></i></span>
                        <div class="prv-pro-doc-empty-copy">
                            <strong>@L["Upload a clear photo or PDF"]</strong>
                            <span>@L["JPG, PNG, WEBP or PDF · Max 10 MB"]</span>
                        </div>
                    </label>
                }

                <div class="prv-pro-doc-pending is-hidden" data-role="pending" aria-live="polite">
                    <img src="" alt="" class="prv-pro-doc-file-thumb prv-pro-doc-pending-thumb is-hidden" />
                    <span class="prv-pro-doc-file-icon prv-pro-doc-pending-icon is-hidden"><i class="fas fa-file"></i></span>
                    <span class="prv-pro-doc-file-meta">
                        <strong class="prv-pro-doc-pending-name"></strong>
                        <span>@L["Ready to upload"]</span>
                    </span>
                    <button type="button" class="prv-pro-doc-pending-clear" data-role="clear-pending" aria-label="@L["Clear selected file"]">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>

                <button type="submit" class="prv-pro-btn prv-pro-btn--primary is-hidden" data-role="upload-btn">
                    <i class="fas fa-cloud-arrow-up"></i> @L["Upload"]</button>
            </form>
        </section>
    }

    <footer class="prv-pro-edit-profile-actions">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-btn prv-pro-btn--primary">@L["Back to profile"]</a>
    </footer>
</div>

@section Scripts {
<script>
(function () {
    function isImageFile(file) {
        return file && file.type && file.type.startsWith('image/');
    }

    function isPdfFile(file) {
        return file && ((file.type && file.type === 'application/pdf') || /\.pdf$/i.test(file.name || ''));
    }

    document.querySelectorAll('.prv-pro-doc-upload-form').forEach(function (form) {
        var input = form.querySelector('[data-role="file-input"]');
        var slot = form.closest('.prv-pro-doc-slot');
        var fileTrigger = slot ? slot.querySelector('[data-role="file-trigger"]') : null;
        var onFile = slot ? slot.querySelector('[data-role="on-file"]') : null;
        var uploadBtn = form.querySelector('[data-role="upload-btn"]');
        var pending = form.querySelector('[data-role="pending"]');
        var pendingThumb = pending ? pending.querySelector('.prv-pro-doc-pending-thumb') : null;
        var pendingIcon = pending ? pending.querySelector('.prv-pro-doc-pending-icon') : null;
        var pendingName = pending ? pending.querySelector('.prv-pro-doc-pending-name') : null;
        var clearBtn = pending ? pending.querySelector('[data-role="clear-pending"]') : null;
        var previewUrl = null;

        if (!input || !pending) {
            return;
        }

        function revokePreview() {
            if (previewUrl) {
                URL.revokeObjectURL(previewUrl);
                previewUrl = null;
            }
        }

        function hidePending() {
            revokePreview();
            pending.classList.add('is-hidden');
            if (pendingThumb) {
                pendingThumb.classList.add('is-hidden');
                pendingThumb.removeAttribute('src');
            }
            if (pendingIcon) {
                pendingIcon.classList.add('is-hidden');
            }
            if (pendingName) {
                pendingName.textContent = '';
            }
            if (fileTrigger) {
                fileTrigger.classList.remove('is-hidden');
            }
            if (onFile) {
                onFile.classList.remove('is-hidden');
            }
            if (uploadBtn) {
                uploadBtn.classList.add('is-hidden');
            }
        }

        function showPending(file) {
            if (!file) {
                hidePending();
                return;
            }

            revokePreview();
            pendingName.textContent = file.name;
            pending.classList.remove('is-hidden');
            if (fileTrigger) {
                fileTrigger.classList.add('is-hidden');
            }
            if (onFile) {
                onFile.classList.add('is-hidden');
            }
            if (uploadBtn) {
                uploadBtn.classList.remove('is-hidden');
            }

            if (isImageFile(file)) {
                previewUrl = URL.createObjectURL(file);
                pendingThumb.src = previewUrl;
                pendingThumb.classList.remove('is-hidden');
                pendingIcon.classList.add('is-hidden');
            } else {
                pendingThumb.classList.add('is-hidden');
                pendingIcon.classList.remove('is-hidden');
                pendingIcon.classList.toggle('is-pdf', isPdfFile(file));
                pendingIcon.querySelector('i').className = isPdfFile(file) ? 'fas fa-file-pdf' : 'fas fa-file-lines';
            }
        }

        input.addEventListener('change', function () {
            var file = input.files && input.files[0];
            if (!file) {
                hidePending();
                return;
            }

            showPending(file);
        });

        if (clearBtn) {
            clearBtn.addEventListener('click', function () {
                input.value = '';
                hidePending();
            });
        }

        form.addEventListener('submit', revokePreview);
    });
})();
</script>
}
