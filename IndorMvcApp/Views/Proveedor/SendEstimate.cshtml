@model IndorMvcApp.ViewModels.ProviderProSendEstimatePageViewModel
@using System.Globalization
@{
    ViewData["Title"] = L["Send Estimate - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
    var deliveryOptions = new (string Id, string Label, string Hint)[] {
        ("indor", L["Send in INDOR"].ToString(), L["Send securely inside the INDOR app."].ToString()),
        ("sms", L["Text message"].ToString(), L["Send a link via SMS to the customer."].ToString()),
        ("email", L["Email"].ToString(), L["Send the estimate via email."].ToString())
    };
    var postSendOptions = new (string Id, string Label, string Hint, bool IsDefault)[] {
        ("job_only", L["Create job only"].ToString(), L["Create the job without sending for approval."].ToString(), false),
        ("wait_approval", L["Send estimate and wait for approval"].ToString(), L["Customer reviews and approves before the job is created."].ToString(), true),
        ("request_deposit", L["Request deposit"].ToString(), L["Request a deposit before starting the job."].ToString(), false)
    };
}

<div class="prv-pro-shell prv-pro-shell--estimate prv-pro-shell--estimate-wizard">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-wizard-head">
        <a asp-controller="Proveedor" asp-action="ReviewEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L.T("Step {0} of {1} · Send Estimate", Model.StepNumber, Model.TotalSteps)</h1>
            <p>@L["Choose how to deliver the estimate and what happens after you send."]</p>
        </div>
    </header>

    @await Html.PartialAsync("_ProviderProWizardStepper", Model.WizardSteps)

    <section class="prv-pro-est-review-job">
        <span class="prv-pro-wizard-type-icon prv-pro-wizard-type-icon--@Model.ServiceTone">
            <i class="fas @Model.ServiceIcon"></i>
        </span>
        <div>
            <strong>@UiDisplayLocalization.Localize(L, Model.Title)</strong>
            <small>@Model.CustomerName</small>
            <small>@Model.Address</small>
            <small>@UiDisplayLocalization.Localize(L, Model.DateLabel)</small>
            <div class="prv-pro-est-send-total">
                <span>@L["Total estimate"]</span>
                <strong>@Model.TotalAmount.ToString("C2", money)</strong>
            </div>
        </div>
    </section>

    <form asp-controller="Proveedor" asp-action="SendEstimate" method="post" class="prv-pro-est-send-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="EstimateId" value="@Model.EstimateId" />

        <section class="prv-pro-wizard-card">
            <h2>@L["Delivery method"]</h2>
            @foreach (var (id, label, hint) in deliveryOptions)
            {
                <label class="prv-pro-est-radio">
                    <input type="radio" name="DeliveryMethod" value="@id" checked="@(Model.DeliveryMethod == id)" />
                    <span>
                        <strong>@label</strong>
                        <small>@hint</small>
                    </span>
                </label>
            }
        </section>

        <section class="prv-pro-wizard-card">
            <h2>@L["Message to customer"]</h2>
            <textarea name="CustomerMessage" rows="4" maxlength="250">@UiDisplayLocalization.Localize(L, Model.CustomerMessage)</textarea>
            <small class="prv-pro-wizard-hint">@(Model.CustomerMessage.Length)/250</small>
        </section>

        <section class="prv-pro-wizard-card">
            <h2>@L["Attachments (included)"]</h2>
            <ul class="prv-pro-est-send-attachments">
                @if (Model.HasEstimatePdf)
                {
                    <li><i class="fas fa-circle-check"></i> @L["Estimate PDF"]</li>
                }
                @if (Model.HasAiSummary)
                {
                    <li><i class="fas fa-circle-check"></i> @L["AI summary"]</li>
                }
                @if (Model.HasVoiceTranscript)
                {
                    <li><i class="fas fa-circle-check"></i> @L["Voice transcript"]</li>
                }
            </ul>
        </section>

        <section class="prv-pro-wizard-card">
            <h2>@L["Next step after send"]</h2>
            @foreach (var option in postSendOptions)
            {
                <label class="prv-pro-est-radio">
                    <input type="radio" name="PostSendAction" value="@option.Id" checked="@(Model.PostSendAction == option.Id || (option.IsDefault && Model.PostSendAction == "wait_approval"))" />
                    <span>
                        <strong>@option.Label @(option.IsDefault ? L["(Recommended)"] : "")</strong>
                        <small>@option.Hint</small>
                    </span>
                </label>
            }
        </section>

        <footer class="prv-pro-est-review-actions">
            <button type="submit" name="SaveAsDraft" value="true" class="prv-pro-btn prv-pro-btn--ghost">
                <i class="fas fa-floppy-disk"></i> @L["Save draft"]
            </button>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-paper-plane"></i> @L["Send estimate"]
            </button>
        </footer>
    </form>
</div>
