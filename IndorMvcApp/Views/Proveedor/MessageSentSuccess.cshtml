@model IndorMvcApp.ViewModels.ProviderProMessageSentSuccessViewModel
@{
    ViewData["Title"] = "Message Sent - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
}

<div class="prv-pro-shell prv-pro-shell--message-success">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <section class="prv-pro-job-success-hero">
        <div class="prv-pro-job-success-icon"><i class="fas fa-circle-check"></i></div>
        <h1>Message sent successfully</h1>
    </section>

    <section class="prv-pro-job-success-card">
        <dl class="prv-pro-job-success-list">
            <div><dt><i class="fas fa-user"></i> Recipient</dt><dd>@Model.CustomerName</dd></div>
            <div><dt><i class="fas fa-briefcase"></i> Job</dt><dd>@Model.JobTitle</dd></div>
            <div><dt><i class="fas fa-file-lines"></i> Sent item</dt><dd>@Model.SentItemLabel</dd></div>
        </dl>
    </section>

    <div class="prv-pro-customer-success-actions">
        <a asp-controller="Proveedor" asp-action="Conversation" asp-route-id="@Model.ConversationId" class="prv-pro-btn prv-pro-btn--primary prv-pro-btn--block">
            <i class="fas fa-message"></i> View conversation
        </a>
        @if (Model.JobId.HasValue)
        {
            <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block">
                <i class="fas fa-briefcase"></i> View job
            </a>
        }
        <a asp-controller="Proveedor" asp-action="Messages" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block">
            <i class="fas fa-arrow-left"></i> Back to messages
        </a>
    </div>
</div>
