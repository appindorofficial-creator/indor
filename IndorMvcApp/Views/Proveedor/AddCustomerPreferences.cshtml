@model IndorMvcApp.ViewModels.ProviderProAddCustomerPreferencesViewModel
@{
    ViewData["Title"] = L["Preferences & Notes - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "customers";
    var deliveryOpts = new[] { ("Email", L["Email"].ToString()), ("SMS", L["SMS"].ToString()), ("Both", L["Both"].ToString()) };
    var languageOpts = new[] { ("English", L["English"].ToString()), ("Spanish", L["Spanish"].ToString()) };
    var sources = new[] { ("INDOR Lead", "fa-bullseye"), ("Manual Entry", "fa-pen"), ("Referral", "fa-user-group"), ("Realtor", "fa-building") };
    var tagOptions = new[] { "VIP", "Repeat Customer", "New Customer", "Realtor Client" };
}

<div class="prv-pro-shell prv-pro-shell--add-customer">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="AddCustomerProperty" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Preferences &amp; Notes"]</h1>
            <small>@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</small>
        </div>
        <span class="prv-pro-step-badge">@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</span>
    </header>

    <form asp-controller="Proveedor" asp-action="AddCustomerPreferences" method="post" class="prv-pro-add-customer-form">
        @Html.AntiForgeryToken()

        <section class="prv-pro-add-customer-section">
            <h3>@L["Communication Preferences"]</h3>
            <label class="prv-pro-form-label">@L["Estimate Delivery"]<div class="prv-pro-segmented">
                    @foreach (var (optKey, optLabel) in deliveryOpts)
                    {
                        <label class="@(Model.EstimateDeliveryPref == optKey ? "is-selected" : "")">
                            <input type="radio" name="EstimateDeliveryPref" value="@optKey" @(Model.EstimateDeliveryPref == optKey ? "checked" : "") /> @optLabel
                        </label>
                    }
                </div>
            </label>
            <label class="prv-pro-form-label">@L["Invoice Delivery"]<div class="prv-pro-segmented">
                    @foreach (var (optKey, optLabel) in deliveryOpts)
                    {
                        <label class="@(Model.InvoiceDeliveryPref == optKey ? "is-selected" : "")">
                            <input type="radio" name="InvoiceDeliveryPref" value="@optKey" @(Model.InvoiceDeliveryPref == optKey ? "checked" : "") /> @optLabel
                        </label>
                    }
                </div>
            </label>
            <label class="prv-pro-form-label">@L["Language"]<div class="prv-pro-segmented">
                    @foreach (var (optKey, optLabel) in languageOpts)
                    {
                        <label class="@(Model.PreferredLanguage == optKey ? "is-selected" : "")">
                            <input type="radio" name="PreferredLanguage" value="@optKey" @(Model.PreferredLanguage == optKey ? "checked" : "") /> @optLabel
                        </label>
                    }
                </div>
            </label>
        </section>

        <section class="prv-pro-add-customer-section">
            <h3>@L["Customer Source"]</h3>
            <div class="prv-pro-customer-type-grid prv-pro-customer-type-grid--4">
                @foreach (var (source, icon) in sources)
                {
                    <label class="prv-pro-customer-type-card @(Model.CustomerSource == source ? "is-selected" : "")">
                        <input type="radio" name="CustomerSource" value="@source" @(Model.CustomerSource == source ? "checked" : "") />
                        <i class="fas @icon"></i>
                        <span>@L[source]</span>
                    </label>
                }
            </div>
        </section>

        <section class="prv-pro-add-customer-section">
            <h3>@L["Tags"]</h3>
            <div class="prv-pro-tag-pills">
                @foreach (var tag in tagOptions)
                {
                    var selected = Model.Tags.Contains(tag);
                    <label class="prv-pro-tag-pill @(selected ? "is-selected" : "")">
                        <input type="checkbox" name="Tags" value="@tag" @(selected ? "checked" : "") /> @L[tag]
                    </label>
                }
            </div>
        </section>

        <label class="prv-pro-form-label">@L["Internal Notes"]<textarea name="InternalNotes" rows="4" maxlength="500" placeholder="@L["Preferences, follow-up notes..."]">@Model.InternalNotes</textarea>
        </label>

        <label class="prv-pro-create-toggle">
            <div><i class="fas fa-link"></i><div><strong>@L["Send INDOR invite link"]</strong></div></div>
            <input type="checkbox" name="SendIndorInvite" value="true" @(Model.SendIndorInvite ? "checked" : "") />
        </label>
        <label class="prv-pro-create-toggle">
            <div><i class="fas fa-bell"></i><div><strong>@L["Allow service updates"]</strong></div></div>
            <input type="checkbox" name="AllowServiceUpdates" value="true" @(Model.AllowServiceUpdates ? "checked" : "") />
        </label>

        <div class="prv-pro-add-customer-actions">
            <a asp-controller="Proveedor" asp-action="AddCustomerProperty" class="prv-pro-btn prv-pro-btn--outline">@L["Back"]</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">@L["Next"]</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function bindSelectGroup(selector) {
            document.querySelectorAll(selector).forEach(function (el) {
                el.addEventListener('click', function () {
                    var parent = el.parentElement;
                    parent.querySelectorAll(selector).forEach(function (i) { i.classList.remove('is-selected'); });
                    el.classList.add('is-selected');
                });
            });
        }
        bindSelectGroup('.prv-pro-customer-type-card');
        bindSelectGroup('.prv-pro-segmented label');
        document.querySelectorAll('.prv-pro-tag-pill').forEach(function (el) {
            el.addEventListener('click', function () { el.classList.toggle('is-selected'); });
        });
    </script>
}
