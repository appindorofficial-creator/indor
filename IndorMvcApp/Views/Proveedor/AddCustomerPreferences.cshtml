@model IndorMvcApp.ViewModels.ProviderProAddCustomerPreferencesViewModel
@{
    ViewData["Title"] = "Preferences & Notes - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "customers";
    var sources = new[] { ("INDOR Lead", "fa-bullseye"), ("Manual Entry", "fa-pen"), ("Referral", "fa-user-group"), ("Realtor", "fa-building") };
    var tagOptions = new[] { "VIP", "Repeat Customer", "New Customer", "Realtor Client" };
}

<div class="prv-pro-shell prv-pro-shell--add-customer">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="AddCustomerProperty" class="prv-pro-lead-back"><i class="fas fa-arrow-left"></i></a>
        <div>
            <h1>Preferences &amp; Notes</h1>
            <small>Step @Model.StepNumber of @Model.TotalSteps</small>
        </div>
        <span class="prv-pro-step-badge">Step @Model.StepNumber of @Model.TotalSteps</span>
    </header>

    <form asp-controller="Proveedor" asp-action="AddCustomerPreferences" method="post" class="prv-pro-add-customer-form">
        @Html.AntiForgeryToken()

        <section class="prv-pro-add-customer-section">
            <h3>Communication Preferences</h3>
            <label class="prv-pro-form-label">Estimate Delivery
                <div class="prv-pro-segmented">
                    @foreach (var opt in new[] { "Email", "SMS", "Both" })
                    {
                        <label class="@(Model.EstimateDeliveryPref == opt ? "is-selected" : "")">
                            <input type="radio" name="EstimateDeliveryPref" value="@opt" @(Model.EstimateDeliveryPref == opt ? "checked" : "") /> @opt
                        </label>
                    }
                </div>
            </label>
            <label class="prv-pro-form-label">Invoice Delivery
                <div class="prv-pro-segmented">
                    @foreach (var opt in new[] { "Email", "SMS", "Both" })
                    {
                        <label class="@(Model.InvoiceDeliveryPref == opt ? "is-selected" : "")">
                            <input type="radio" name="InvoiceDeliveryPref" value="@opt" @(Model.InvoiceDeliveryPref == opt ? "checked" : "") /> @opt
                        </label>
                    }
                </div>
            </label>
            <label class="prv-pro-form-label">Language
                <div class="prv-pro-segmented">
                    @foreach (var opt in new[] { "English", "Spanish" })
                    {
                        <label class="@(Model.PreferredLanguage == opt ? "is-selected" : "")">
                            <input type="radio" name="PreferredLanguage" value="@opt" @(Model.PreferredLanguage == opt ? "checked" : "") /> @opt
                        </label>
                    }
                </div>
            </label>
        </section>

        <section class="prv-pro-add-customer-section">
            <h3>Customer Source</h3>
            <div class="prv-pro-customer-type-grid prv-pro-customer-type-grid--4">
                @foreach (var (source, icon) in sources)
                {
                    <label class="prv-pro-customer-type-card @(Model.CustomerSource == source ? "is-selected" : "")">
                        <input type="radio" name="CustomerSource" value="@source" @(Model.CustomerSource == source ? "checked" : "") />
                        <i class="fas @icon"></i>
                        <span>@source</span>
                    </label>
                }
            </div>
        </section>

        <section class="prv-pro-add-customer-section">
            <h3>Tags</h3>
            <div class="prv-pro-tag-pills">
                @foreach (var tag in tagOptions)
                {
                    var selected = Model.Tags.Contains(tag);
                    <label class="prv-pro-tag-pill @(selected ? "is-selected" : "")">
                        <input type="checkbox" name="Tags" value="@tag" @(selected ? "checked" : "") /> @tag
                    </label>
                }
            </div>
        </section>

        <label class="prv-pro-form-label">Internal Notes
            <textarea name="InternalNotes" rows="4" maxlength="500" placeholder="Preferences, follow-up notes...">@Model.InternalNotes</textarea>
        </label>

        <label class="prv-pro-create-toggle">
            <div><i class="fas fa-link"></i><div><strong>Send INDOR invite link</strong></div></div>
            <input type="checkbox" name="SendIndorInvite" value="true" @(Model.SendIndorInvite ? "checked" : "") />
        </label>
        <label class="prv-pro-create-toggle">
            <div><i class="fas fa-bell"></i><div><strong>Allow service updates</strong></div></div>
            <input type="checkbox" name="AllowServiceUpdates" value="true" @(Model.AllowServiceUpdates ? "checked" : "") />
        </label>

        <div class="prv-pro-add-customer-actions">
            <a asp-controller="Proveedor" asp-action="AddCustomerProperty" class="prv-pro-btn prv-pro-btn--outline">Back</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">Next</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function bindSelectGroup(selector) {
            document.querySelectorAll(selector).forEach(function (el) {
                el.addEventListener('click', function () {
                    var parent = el.parentElement;
                    parent.querySelectorAll(selector).forEach(function (i) { i.classList.remove('is-selected'); });
                    el.classList.add('is-selected');
                });
            });
        }
        bindSelectGroup('.prv-pro-customer-type-card');
        bindSelectGroup('.prv-pro-segmented label');
        document.querySelectorAll('.prv-pro-tag-pill').forEach(function (el) {
            el.addEventListener('click', function () { el.classList.toggle('is-selected'); });
        });
    </script>
}
