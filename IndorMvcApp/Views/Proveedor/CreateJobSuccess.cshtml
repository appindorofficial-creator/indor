@model IndorMvcApp.ViewModels.ProviderProCreateJobSuccessViewModel
@{
    ViewData["Title"] = L["Job Created - INDOR PRO"];
    Layout = "_ProviderProLayout";
    var createJobFrom = (ViewBag.CreateJobFrom as string) ?? "jobs";
    ViewBag.NavActive = createJobFrom;
}

<div class="prv-pro-shell prv-pro-shell--create-job prv-pro-shell--job-success">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <section class="prv-pro-job-success-hero">
        <div class="prv-pro-job-success-icon"><i class="fas fa-circle-check"></i></div>
        <h1>@L["Job Created Successfully!"]</h1>
        <p>@L["Your job has been scheduled and is ready to go."]</p>
    </section>

    <section class="prv-pro-job-success-card">
        <div class="prv-pro-job-success-card-head">
            <h3><i class="fas fa-clipboard-list"></i> @L["Job Summary"]</h3>
            <span class="prv-pro-pill prv-pro-pill--@Model.StatusClass">@UiDisplayLocalization.Localize(L, Model.StatusLabel)</span>
        </div>
        <dl class="prv-pro-job-success-list">
            <div><dt><i class="fas fa-wrench"></i> @L["Service"]</dt><dd>@Model.Title</dd></div>
            <div><dt><i class="fas fa-calendar"></i> @L["Date &amp; Time"]</dt><dd>@Model.ScheduleLabel</dd></div>
            <div><dt><i class="fas fa-location-dot"></i> @L["Address"]</dt><dd>@Model.Address</dd></div>
            <div><dt><i class="fas fa-hashtag"></i> @L["Job Number"]</dt><dd>@Model.JobCode</dd></div>
            <div><dt><i class="fas fa-clock"></i> @L["Status"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.StatusLabel)</dd></div>
        </dl>
    </section>

    <div class="prv-pro-job-success-actions">
        <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block">
            @L["View Job Details"]
        </a>
        <a asp-controller="Proveedor" asp-action="CreateJob" asp-route-from="@createJobFrom" class="prv-pro-btn prv-pro-btn--primary prv-pro-btn--block">
            @L["Create Another Job"]
        </a>
    </div>
</div>
