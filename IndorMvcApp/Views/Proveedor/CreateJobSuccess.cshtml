@model IndorMvcApp.ViewModels.ProviderProCreateJobSuccessViewModel
@{
    ViewData["Title"] = "Job Created - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
}

<div class="prv-pro-shell prv-pro-shell--create-job prv-pro-shell--job-success">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <section class="prv-pro-job-success-hero">
        <div class="prv-pro-job-success-icon"><i class="fas fa-circle-check"></i></div>
        <h1>Job Created Successfully!</h1>
        <p>Your job has been scheduled and is ready to go.</p>
    </section>

    <section class="prv-pro-job-success-card">
        <div class="prv-pro-job-success-card-head">
            <h3><i class="fas fa-clipboard-list"></i> Job Summary</h3>
            <span class="prv-pro-pill prv-pro-pill--@Model.StatusClass">@Model.StatusLabel</span>
        </div>
        <dl class="prv-pro-job-success-list">
            <div><dt><i class="fas fa-wrench"></i> Service</dt><dd>@Model.Title</dd></div>
            <div><dt><i class="fas fa-calendar"></i> Date &amp; Time</dt><dd>@Model.ScheduleLabel</dd></div>
            <div><dt><i class="fas fa-location-dot"></i> Address</dt><dd>@Model.Address</dd></div>
            <div><dt><i class="fas fa-hashtag"></i> Job Number</dt><dd>@Model.JobCode</dd></div>
            <div><dt><i class="fas fa-clock"></i> Status</dt><dd>@Model.StatusLabel</dd></div>
        </dl>
    </section>

    <div class="prv-pro-job-success-actions">
        <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block">
            View Job Details
        </a>
        <a asp-controller="Proveedor" asp-action="CreateJob" class="prv-pro-btn prv-pro-btn--primary prv-pro-btn--block">
            Create Another Job
        </a>
    </div>
</div>
