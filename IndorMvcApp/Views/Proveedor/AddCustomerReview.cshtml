@model IndorMvcApp.ViewModels.ProviderProAddCustomerReviewViewModel
@{
    ViewData["Title"] = L["Review Customer - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "customers";
}

<div class="prv-pro-shell prv-pro-shell--add-customer">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="AddCustomerPreferences" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Review Customer"]</h1>
            <small>@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</small>
        </div>
        <span class="prv-pro-step-badge">@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</span>
    </header>

    <section class="prv-pro-review-card">
        <div class="prv-pro-review-card-head">
            <h3>@L["Customer Information"]</h3>
            <a asp-controller="Proveedor" asp-action="AddCustomer" class="prv-pro-btn prv-pro-btn--ghost"><i class="fas fa-pen"></i> @L["Edit"]</a>
        </div>
        <dl class="prv-pro-review-list">
            <div><dt>@L["Customer Type"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.CustomerType)</dd></div>
            <div><dt>@L["Name"]</dt><dd>@Model.FullName</dd></div>
            <div><dt>@L["Phone"]</dt><dd>@Model.Phone</dd></div>
            <div><dt>@L["Email"]</dt><dd>@Model.Email</dd></div>
            <div><dt>@L["Preferred Contact"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.PreferredContactMethod)</dd></div>
        </dl>
    </section>

    <section class="prv-pro-review-card">
        <div class="prv-pro-review-card-head">
            <h3>@L["Property Details"]</h3>
            <a asp-controller="Proveedor" asp-action="AddCustomerProperty" class="prv-pro-btn prv-pro-btn--ghost"><i class="fas fa-pen"></i> @L["Edit"]</a>
        </div>
        <dl class="prv-pro-review-list">
            <div><dt>@L["Address"]</dt><dd>@Model.FullAddress</dd></div>
            <div><dt>@L["Property Type"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.PropertyType)</dd></div>
            <div><dt>@L["Beds / Baths"]</dt><dd>@Model.BedsBathsLabel</dd></div>
            <div><dt>@L["Billing same as property"]</dt><dd>@Model.BillingLabel</dd></div>
        </dl>
    </section>

    <section class="prv-pro-review-card">
        <div class="prv-pro-review-card-head">
            <h3>@L["Preferences"]</h3>
            <a asp-controller="Proveedor" asp-action="AddCustomerPreferences" class="prv-pro-btn prv-pro-btn--ghost"><i class="fas fa-pen"></i> @L["Edit"]</a>
        </div>
        <dl class="prv-pro-review-list">
            <div><dt>@L["Estimate Delivery"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.EstimateDeliveryPref)</dd></div>
            <div><dt>@L["Invoice Delivery"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.InvoiceDeliveryPref)</dd></div>
            <div><dt>@L["Language"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.PreferredLanguage)</dd></div>
            <div><dt>@L["Source"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.CustomerSource)</dd></div>
            @if (Model.Tags.Count > 0)
            {
                <div><dt>@L["Tags"]</dt><dd>@string.Join(", ", Model.Tags.Select(t => UiDisplayLocalization.Localize(L, t)))</dd></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.InternalNotes))
            {
                <div><dt>@L["Notes"]</dt><dd>@Model.InternalNotes</dd></div>
            }
        </dl>
    </section>

    <form asp-controller="Proveedor" asp-action="ConfirmAddCustomer" method="post" class="prv-pro-add-customer-actions">
        @Html.AntiForgeryToken()
        <a asp-controller="Proveedor" asp-action="AddCustomerPreferences" class="prv-pro-btn prv-pro-btn--outline">@L["Back"]</a>
        <button type="submit" class="prv-pro-btn prv-pro-btn--primary">@L["Save Customer"]</button>
    </form>
</div>
