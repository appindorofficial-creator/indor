@model IndorMvcApp.ViewModels.RequestDetailsViewModel
@{
    ViewData["Title"] = "Request Details";
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-requests.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-req-shell">
    <header class="prv-req-hero prv-req-hero--detail">
        <div class="prv-req-hero-top">
            <a asp-controller="Proveedor" asp-action="MyRequests" class="prv-req-back" aria-label="Back"><i class="fas fa-arrow-left"></i></a>
            <span class="prv-req-brand-word">INDOR</span>
            <span class="prv-req-brand-pro">PRO</span>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>
        <div class="prv-req-hero-title">
            <div>
                <h1>Request Details</h1>
                <p>See status, timeline, and activity.</p>
            </div>
            <span class="prv-req-hero-status prv-req-hero-status--@Model.StatusKind">
                <i class="fas fa-quote-right"></i> @Model.StatusLabel
            </span>
        </div>
    </header>

    <section class="prv-req-jobcard">
        <div class="prv-req-jobcard-head">
            <span class="prv-req-ico prv-req-ico--@Model.IconTone prv-req-ico--lg"><i class="fas @Model.IconClass"></i></span>
            <div class="prv-req-card-id">
                <div class="prv-req-title prv-req-title--lg">@Model.Title</div>
                @if (!string.IsNullOrWhiteSpace(Model.TradeLabel))
                {
                    <div class="prv-req-meta"><i class="fas fa-screwdriver-wrench"></i> @Model.TradeLabel</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.LocationLabel))
                {
                    <div class="prv-req-meta"><i class="fas fa-location-dot"></i> @Model.LocationLabel</div>
                }
            </div>
            <div class="prv-req-budget">
                <span>Budget</span>
                <strong>@(Model.BudgetRange ?? "—")</strong>
                <span class="prv-req-posted-inline">Posted @Model.PostedLabel</span>
            </div>
        </div>

        @if (Model.Photos.Count > 0)
        {
            <div class="prv-req-photos">
                @foreach (var photo in Model.Photos.Take(3))
                {
                    <span class="prv-req-photo" style="background-image:url('@photo')"></span>
                }
            </div>
        }

        <div class="prv-req-jobcard-foot">
            @await Html.PartialAsync("_RequestStepper", Model.Steps)
        </div>
    </section>

    <section class="prv-req-panel">
        <h2 class="prv-req-panel-title">Activity</h2>
        <div class="prv-req-activity">
            @foreach (var a in Model.Activity)
            {
                <div class="prv-req-act">
                    <span class="prv-req-act-ic prv-req-act-ic--@a.Tone"><i class="fas @a.IconClass"></i></span>
                    <div class="prv-req-act-body">
                        <strong>@a.Title</strong>
                        @if (!string.IsNullOrWhiteSpace(a.Detail))
                        {
                            <span>@a.Detail</span>
                        }
                    </div>
                    <span class="prv-req-act-time">@a.TimeLabel</span>
                </div>
            }
        </div>
    </section>

    <section class="prv-req-panel">
        <div class="prv-req-panel-head">
            <h2 class="prv-req-panel-title">Quotes Available <span class="prv-req-count">@Model.QuoteCount</span></h2>
            @if (Model.QuoteCount > 0)
            {
                <a asp-controller="Proveedor" asp-action="CompareQuotes" asp-route-id="@Model.Id" class="prv-req-link">View all quotes <i class="fas fa-chevron-right"></i></a>
            }
        </div>

        @if (Model.QuoteCount == 0)
        {
            <div class="prv-req-nowuotes">
                <i class="fas fa-hourglass-half"></i>
                <span>Waiting for subcontractors to send quotes. We'll notify you as they arrive.</span>
            </div>
        }
        else
        {
            <div class="prv-req-quotes">
                @foreach (var qt in Model.Quotes)
                {
                    <a asp-controller="Proveedor" asp-action="CompareQuotes" asp-route-id="@Model.Id" class="prv-req-quote">
                        <span class="prv-req-ico prv-req-ico--@Model.IconTone"><i class="fas @qt.IconClass"></i></span>
                        <div class="prv-req-quote-id">
                            <div class="prv-req-quote-name">
                                @qt.Name
                                @if (qt.IsVerified)
                                {
                                    <i class="fas fa-circle-check prv-req-verified"></i>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(qt.LocationLabel))
                            {
                                <div class="prv-req-meta">@qt.LocationLabel</div>
                            }
                            <div class="prv-req-badges">
                                @if (qt.IsVerified)
                                {
                                    <span class="prv-req-badge prv-req-badge--blue"><i class="fas fa-circle-check"></i> Verified</span>
                                }
                                @if (qt.IsInsured)
                                {
                                    <span class="prv-req-badge prv-req-badge--green"><i class="fas fa-shield-halved"></i> Insurance Active</span>
                                }
                                @if (qt.IsDocsReady)
                                {
                                    <span class="prv-req-badge prv-req-badge--purple"><i class="fas fa-file-lines"></i> Docs Ready</span>
                                }
                            </div>
                        </div>
                        <div class="prv-req-quote-price">
                            <strong>@qt.RangeLabel</strong>
                            <span>@qt.ResponseLabel</span>
                        </div>
                    </a>
                }
            </div>

            <a asp-controller="Proveedor" asp-action="CompareQuotes" asp-route-id="@Model.Id" class="prv-req-btn prv-req-btn--primary prv-req-btn--block">
                Compare Quotes
            </a>
        }
    </section>
</div>
