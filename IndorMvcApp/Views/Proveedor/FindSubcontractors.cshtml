@model IndorMvcApp.ViewModels.FindSubcontractorsViewModel
@{
    ViewData["Title"] = L["Find Subcontractors"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-network.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-net-shell">
    <header class="prv-net-hero">
        <div class="prv-net-hero-top">
            <a asp-controller="Proveedor" asp-action="Network" class="prv-net-back"><i class="fas fa-chevron-left"></i> @L["Network"]</a>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>

        <div class="prv-net-hero-title">
            <div>
                <h1>@L["Verified Subcontractors"]</h1>
                <p>@L["Browse trusted pros near you."]</p>
            </div>
        </div>

        <form method="get" asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-net-searchbar">
            <input type="hidden" name="trade" value="@Model.ActiveTrade" />
            <input type="hidden" name="view" value="@Model.ActiveView" />
            @if (Model.FilterNearby) { <input type="hidden" name="nearby" value="true" /> }
            @if (Model.FilterInsuredOnly) { <input type="hidden" name="insured" value="true" /> }
            @if (Model.FilterAvailableNow) { <input type="hidden" name="available" value="true" /> }
            @if (Model.FilterDocsReady) { <input type="hidden" name="docs" value="true" /> }
            <div class="prv-net-search">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.Query" placeholder="@L["Search subcontractors, trades, or services"]" />
            </div>
            <button type="submit" class="prv-net-filter"><i class="fas fa-sliders"></i></button>
        </form>

        <div class="prv-net-toggle" style="margin:14px 0 0;background:rgba(255,255,255,.16);">
            <a asp-controller="Proveedor" asp-action="FindSubcontractors"
               asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="map"
               asp-route-nearby="@Model.FilterNearby" asp-route-insured="@Model.FilterInsuredOnly" asp-route-available="@Model.FilterAvailableNow"
               class="@(Model.ActiveView == "map" ? "is-active" : null)" style="color:@(Model.ActiveView == "map" ? "" : "#fff")"><i class="fas fa-map-location-dot"></i> @L["Map"]</a>
            <a asp-controller="Proveedor" asp-action="FindSubcontractors"
               asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="list"
               asp-route-nearby="@Model.FilterNearby" asp-route-insured="@Model.FilterInsuredOnly" asp-route-available="@Model.FilterAvailableNow"
               class="@(Model.ActiveView == "list" ? "is-active" : null)" style="color:@(Model.ActiveView == "list" ? "" : "#fff")"><i class="fas fa-list"></i> @L["List"]</a>
        </div>
    </header>

    @if (Model.TradeChips.Count > 0)
    {
        <div class="prv-net-chips">
            <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-q="@Model.Query" asp-route-view="@Model.ActiveView"
               class="prv-net-chip @(Model.ActiveTrade == "all" ? "is-active" : null)"><i class="fas fa-border-all"></i> @L["All"]</a>
            @foreach (var chip in Model.TradeChips)
            {
                <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-q="@Model.Query" asp-route-trade="@chip.Id" asp-route-view="@Model.ActiveView"
                   class="prv-net-chip @(Model.ActiveTrade == chip.Id ? "is-active" : null)">
                    <i class="fas @chip.IconClass"></i> @UiDisplayLocalization.Localize(L, chip.Label)
                </a>
            }
        </div>
    }

    @{
        var noFilters = !Model.FilterNearby && !Model.FilterInsuredOnly && !Model.FilterAvailableNow && !Model.FilterDocsReady;
    }
    <div class="prv-net-fpills">
        <a asp-controller="Proveedor" asp-action="FindSubcontractors"
           asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="@Model.ActiveView"
           class="prv-net-fpill @(noFilters ? "is-active" : null)"><i class="fas fa-border-all"></i> @L["All"]</a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors"
           asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="@Model.ActiveView"
           asp-route-nearby="@Model.FilterNearby" asp-route-insured="@Model.FilterInsuredOnly" asp-route-available="@(!Model.FilterAvailableNow)" asp-route-docs="@Model.FilterDocsReady"
           class="prv-net-fpill @(Model.FilterAvailableNow ? "is-active" : null)"><i class="fas fa-clock"></i> @L["Available Now"]</a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors"
           asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="@Model.ActiveView"
           asp-route-nearby="@Model.FilterNearby" asp-route-insured="@(!Model.FilterInsuredOnly)" asp-route-available="@Model.FilterAvailableNow" asp-route-docs="@Model.FilterDocsReady"
           class="prv-net-fpill @(Model.FilterInsuredOnly ? "is-active" : null)"><i class="fas fa-shield-halved"></i> @L["Insurance Active"]</a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors"
           asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="@Model.ActiveView"
           asp-route-nearby="@Model.FilterNearby" asp-route-insured="@Model.FilterInsuredOnly" asp-route-available="@Model.FilterAvailableNow" asp-route-docs="@(!Model.FilterDocsReady)"
           class="prv-net-fpill @(Model.FilterDocsReady ? "is-active" : null)"><i class="fas fa-file-lines"></i> @L["Docs Ready"]</a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors"
           asp-route-q="@Model.Query" asp-route-trade="@Model.ActiveTrade" asp-route-view="@Model.ActiveView"
           asp-route-nearby="@(!Model.FilterNearby)" asp-route-insured="@Model.FilterInsuredOnly" asp-route-available="@Model.FilterAvailableNow" asp-route-docs="@Model.FilterDocsReady"
           class="prv-net-fpill @(Model.FilterNearby ? "is-active" : null)"><i class="fas fa-location-dot"></i> @L["Nearby"]</a>
    </div>

    <div class="prv-net-count">
        <span>@L.T("{0} subcontractor(s) found", Model.ResultCount)@(Model.HasLocation ? $" {L["near you"]}" : "")</span>
        <span>@L["Sort by:"]<strong>@UiDisplayLocalization.Localize(L, Model.SortLabel)</strong></span>
    </div>

    @if (Model.ActiveView == "map")
    {
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
              integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <div class="prv-net-map">
            <div id="prvNetMap" class="prv-net-map-canvas"></div>
            <div class="prv-net-map-note" id="prvNetMapNote">
                <i class="fas fa-location-crosshairs"></i> @L["Locating you…"]</div>
        </div>
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
                integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
        <script>
            (function () {
                var el = document.getElementById('prvNetMap');
                var note = document.getElementById('prvNetMapNote');
                if (!el || typeof L === 'undefined') { return; }

                var fallback = [39.8283, -98.5795]; // center of US
                var map = L.map(el, { zoomControl: true, attributionControl: true }).setView(fallback, 4);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                function showCurrentLocation() {
                    if (!navigator.geolocation) {
                        note.innerHTML = '<i class="fas fa-triangle-exclamation"></i> @L["Location not available on this device."]';
                        return;
                    }
                    navigator.geolocation.getCurrentPosition(function (pos) {
                        var lat = pos.coords.latitude, lng = pos.coords.longitude;
                        map.setView([lat, lng], 13);
                        L.circle([lat, lng], { radius: 400, color: '#2E8BFF', fillColor: '#2E8BFF', fillOpacity: .15, weight: 1 }).addTo(map);
                        L.marker([lat, lng]).addTo(map).bindPopup('@L["You are here"]').openPopup();
                        note.innerHTML = '<i class="fas fa-location-dot"></i> @L["Showing your current location."]';
                    }, function () {
                        note.innerHTML = '<i class="fas fa-triangle-exclamation"></i> @L["Enable location access to see your position on the map."]';
                    }, { enableHighAccuracy: true, timeout: 8000, maximumAge: 60000 });
                }

                // Leaflet needs a re-measure once the container is laid out.
                setTimeout(function () { map.invalidateSize(); showCurrentLocation(); }, 150);
            })();
        </script>
    }

    @if (Model.Results.Count == 0)
    {
        <div class="prv-net-empty">
            <i class="fas fa-magnifying-glass"></i>
            <h3>@L["No matches found"]</h3>
            <p>@L["Try a different trade or remove some filters to see more verified subcontractors."]</p>
        </div>
    }
    else if (Model.ActiveView != "map")
    {
        <div class="prv-net-list">
            @foreach (var sub in Model.Results)
            {
                @await Html.PartialAsync("_NetworkSubcontractorCard", sub)
            }
        </div>
    }
    else
    {
        <div class="prv-net-list">
            @foreach (var sub in Model.Results.Take(5))
            {
                @await Html.PartialAsync("_NetworkSubcontractorCard", sub)
            }
        </div>
    }

    <section class="prv-net-why">
        <div class="prv-net-why-head"><i class="fas fa-circle-info"></i> @L["Why contractors use INDOR"]</div>
        <div class="prv-net-why-grid">
            <div class="prv-net-why-item"><i class="fas fa-circle-check"></i> @L["Verified"]</div>
            <div class="prv-net-why-item"><i class="fas fa-shield-halved"></i> @L["Insurance Active"]</div>
            <div class="prv-net-why-item"><i class="fas fa-file-lines"></i> @L["Docs Ready"]</div>
            <div class="prv-net-why-item"><i class="fas fa-bolt"></i> @L["Faster Hiring"]</div>
        </div>
    </section>
</div>
