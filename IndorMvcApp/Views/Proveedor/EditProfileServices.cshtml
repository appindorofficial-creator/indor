@model IndorMvcApp.ViewModels.ProviderProEditProfileServicesViewModel
@{
    ViewData["Title"] = L["Edit Services - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--edit-profile">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Services Offered"]</h1>
            <p>@L["Select the categories and services your business provides."]</p>
        </div>
    </header>

    @if (TempData["ProfileSectionError"] is string sectionError)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @UiDisplayLocalization.Localize(L, sectionError)
        </div>
    }

    <form asp-controller="Proveedor" asp-action="EditProfileServices" method="post" class="prv-pro-edit-profile-form" novalidate>
        @Html.AntiForgeryToken()

        <section class="prv-pro-wizard-card">
            <h2>@L["What services do you offer?"]</h2>
            <p>@L["Select at least one category or service. These appear on your public profile."]</p>
            <div class="prv-pro-profile-tags prv-pro-edit-profile-service-grid">
                @foreach (var option in Model.Options)
                {
                    <div class="prv-pro-edit-profile-service-chip @(option.IsSelected ? "is-selected" : "")"
                         role="checkbox"
                         tabindex="0"
                         aria-checked="@(option.IsSelected ? "true" : "false")"
                         aria-pressed="@(option.IsSelected ? "true" : "false")">
                        <input type="checkbox" name="serviceIds" value="@option.Id" tabindex="-1" @(option.IsSelected ? "checked" : "") />
                        <i class="fas @option.IconClass" aria-hidden="true"></i>
                        <span>@UiDisplayLocalization.Localize(L, option.Label)</span>
                        @if (option.IsCategory)
                        {
                            <small>@L["Category"]</small>
                        }
                    </div>
                }
            </div>
        </section>

        <footer class="prv-pro-edit-profile-actions">
            <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-btn prv-pro-btn--ghost">@L["Cancel"]</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-floppy-disk"></i> @L["Save services"]</button>
        </footer>
    </form>
</div>

@section Scripts {
    <script src="~/js/provider-profile-flow.js" asp-append-version="true"></script>
}
