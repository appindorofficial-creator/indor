@model IndorMvcApp.ViewModels.ProviderProUploadReportSelectJobViewModel
@{
    ViewData["Title"] = L["Select Job - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "reports";
    var filters = new[] { ("all", "All", ""), ("completed", "Completed", "fa-circle-check"), ("inprogress", "In Progress", "fa-clock"), ("recent", "Recent", "fa-clock-rotate-left") };
}

<div class="prv-pro-shell prv-pro-shell--upload-report">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="Reports" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Select Job or Property"]</h1>
            <small>@L["Choose the completed or active job this report belongs to."]</small>
        </div>
        <span class="prv-pro-step-badge">@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</span>
    </header>

    @if (TempData["UploadReportError"] is string uploadReportError && !string.IsNullOrWhiteSpace(uploadReportError))
    {
        <div class="prv-pro-form-error-banner" role="alert">@uploadReportError</div>
    }

    <p class="prv-pro-upload-report-hint">@L["Search for a job, then tap"] <strong>@L["Select"]</strong> @L["on the matching card to continue."]</p>

    <form method="get" asp-controller="Proveedor" asp-action="UploadReport" class="prv-pro-upload-report-search">
        <div class="prv-pro-search-wrap">
            <i class="fas fa-magnifying-glass"></i>
            <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search by address, service, or job ID..."]" />
        </div>
        <input type="hidden" name="filter" value="@Model.ActiveFilter" />
        <button type="submit" class="prv-pro-btn prv-pro-btn--primary prv-pro-upload-report-search-btn">@L["Search"]</button>
    </form>

    <div class="prv-pro-upload-report-filters">
        @foreach (var (key, label, icon) in filters)
        {
            <a asp-controller="Proveedor" asp-action="UploadReport" asp-route-filter="@key" asp-route-q="@Model.SearchQuery"
               class="prv-pro-upload-report-filter @(Model.ActiveFilter == key ? "is-active" : "")">
                @if (!string.IsNullOrEmpty(icon)) { <i class="fas @icon"></i> }
                @L[label]
            </a>
        }
    </div>

    <div class="prv-pro-upload-report-jobs">
        @if (Model.Jobs.Count == 0)
        {
            <div class="prv-pro-upload-report-empty">
                @if (Model.HasSearchWithNoResults)
                {
                    <p>@L["No jobs matched"] <strong>@Model.SearchQuery</strong>.</p>
                    <p>@L["Try a shorter address, job ID, or customer name, or clear the search to see all jobs."]</p>
                    <a asp-controller="Proveedor" asp-action="UploadReport" asp-route-filter="@Model.ActiveFilter" class="prv-pro-btn prv-pro-btn--outline">@L["Clear search"]</a>
                }
                else if (Model.TotalJobsAvailable == 0)
                {
                    <p>@L["You don't have any jobs yet. Create a job first, then return here to upload a report."]</p>
                    <a asp-controller="Proveedor" asp-action="Reports" class="prv-pro-btn prv-pro-btn--outline">@L["Back to Reports"]</a>
                }
                else
                {
                    <p>@L["No jobs match the current filter. Try"] <strong>@L["All"]</strong> @L["or another filter."]</p>
                    <a asp-controller="Proveedor" asp-action="UploadReport" asp-route-q="@Model.SearchQuery" class="prv-pro-btn prv-pro-btn--outline">@L["Show all jobs"]</a>
                }
            </div>
        }
        else
        {
            @foreach (var job in Model.Jobs)
            {
                <form asp-controller="Proveedor" asp-action="UploadReport" method="post" class="prv-pro-upload-report-job-card">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="JobId" value="@job.JobId" />
                    <input type="hidden" name="Search" value="@Model.SearchQuery" />
                    <input type="hidden" name="Filter" value="@Model.ActiveFilter" />
                    @if (!string.IsNullOrWhiteSpace(job.ImageUrl))
                    {
                        <img src="@job.ImageUrl" alt="" class="prv-pro-upload-report-job-thumb" />
                    }
                    else
                    {
                        <div class="prv-pro-upload-report-job-thumb prv-pro-upload-report-job-thumb--icon">
                            <i class="fas @job.IconClass"></i>
                        </div>
                    }
                    <div class="prv-pro-upload-report-job-body">
                        <strong>@job.Address</strong>
                        <span><i class="fas @job.IconClass"></i> @UiDisplayLocalization.Localize(L, job.ServiceType)</span>
                        <span>@job.DateLabel · @job.JobCode</span>
                        <span class="prv-pro-pill prv-pro-pill--@job.StatusClass">@UiDisplayLocalization.Localize(L, job.StatusLabel)</span>
                    </div>
                    <button type="submit" class="prv-pro-btn prv-pro-btn--outline">@L["Select"]</button>
                </form>
            }
        }
    </div>

    <div class="prv-pro-upload-report-actions">
        <a asp-controller="Proveedor" asp-action="Reports" class="prv-pro-btn prv-pro-btn--outline">@L["Cancel"]</a>
    </div>
</div>
