@model IndorMvcApp.ViewModels.ProviderProProfilePageViewModel
@{
    ViewData["Title"] = L["Subscription - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--support">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head prv-pro-settings-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back" aria-label="@L["Back to profile"]">
            <i class="fas fa-chevron-left"></i>
        </a>
        <div>
            <h1>@L["Subscription / Plan"]</h1>
            <p>@L["Your INDOR Pro plan and activation status."]</p>
        </div>
    </header>

    <section class="prv-pro-subscription-hero">
        <span class="prv-pro-subscription-badge"><i class="fas fa-crown"></i> @L["Current plan"]</span>
        <h2>@UiDisplayLocalization.Localize(L, Model.SubscriptionPlan)</h2>
        <p>@(Model.IsApproved ? L["Your provider profile is active for INDOR opportunities."] : L["Complete verification to unlock INDOR job leads."])</p>
    </section>

    <section class="prv-pro-profile-card">
        <header class="prv-pro-profile-card-head"><h3><i class="fas fa-check-circle"></i> @L["Included with INDOR Pro"]</h3></header>
        <div class="prv-pro-profile-kv"><i class="fas fa-users"></i><span>@L["Clients &amp; CRM"]</span></div>
        <div class="prv-pro-profile-kv"><i class="fas fa-briefcase"></i><span>@L["Jobs, photos &amp; scheduling"]</span></div>
        <div class="prv-pro-profile-kv"><i class="fas fa-file-invoice-dollar"></i><span>@L["Estimates &amp; invoices"]</span></div>
        <div class="prv-pro-profile-kv"><i class="fas fa-file-lines"></i><span>@L["Reports &amp; property history"]</span></div>
    </section>

    <section class="prv-pro-profile-card">
        <header class="prv-pro-profile-card-head"><h3><i class="fas fa-shield-halved"></i> @L["Activation status"]</h3></header>
        <div class="prv-pro-profile-kv-row">
            <span>@L["Provider verification"]</span>
            <strong class="@(Model.IsVerified ? "prv-pro-status-ok" : "")">@(Model.IsVerified ? L["Verified"] : L["Pending"])</strong>
        </div>
        <div class="prv-pro-profile-kv-row">
            <span>@L["Documents uploaded"]</span>
            <strong>@Model.DocumentsUploaded / @Model.DocumentsRequired</strong>
        </div>
        <div class="prv-pro-profile-kv-row">
            <span>@L["Payment processing"]</span>
            <strong class="@(Model.PaymentProcessingActive ? "prv-pro-status-ok" : "")">@(Model.PaymentProcessingActive ? L["Active"] : L["Inactive"])</strong>
        </div>
    </section>

    @if (!Model.IsApproved)
    {
        <a asp-controller="ProviderRegistration" asp-action="ActivationCall" class="prv-pro-btn prv-pro-btn--primary prv-pro-subscription-cta">
            @L["Complete activation"]
        </a>
    }
</div>
