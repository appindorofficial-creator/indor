@model IndorMvcApp.ViewModels.ProviderProAddCustomerSuccessViewModel
@{
    ViewData["Title"] = L["Customer Added - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "customers";
}

<div class="prv-pro-shell prv-pro-shell--add-customer prv-pro-shell--customer-success">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <section class="prv-pro-job-success-hero">
        <div class="prv-pro-job-success-icon"><i class="fas fa-circle-check"></i></div>
        <h1>@L["Customer Added Successfully!"]</h1>
        <p>@L["Your new customer is now saved and ready to use."]</p>
    </section>

    <section class="prv-pro-job-success-card">
        <div class="prv-pro-job-success-card-head">
            <h3>@L["Customer Summary"]</h3>
            <span class="prv-pro-pill prv-pro-pill--connected">@UiDisplayLocalization.Localize(L, Model.StatusLabel)</span>
        </div>
        <dl class="prv-pro-job-success-list">
            <div><dt><i class="fas fa-user"></i> @L["Name"]</dt><dd>@Model.FullName</dd></div>
            <div><dt><i class="fas fa-id-badge"></i> @L["Customer Type"]</dt><dd>@UiDisplayLocalization.Localize(L, Model.CustomerType)</dd></div>
            <div><dt><i class="fas fa-phone"></i> @L["Phone"]</dt><dd>@Model.Phone</dd></div>
            <div><dt><i class="fas fa-location-dot"></i> @L["Address"]</dt><dd>@Model.Address</dd></div>
            <div><dt><i class="fas fa-hashtag"></i> @L["Customer ID"]</dt><dd>@Model.CustomerCode</dd></div>
        </dl>
    </section>

    <div class="prv-pro-customer-success-actions">
        <a asp-controller="Proveedor" asp-action="Customers" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block">@L["View Customer Profile"]</a>
        <a asp-controller="Proveedor" asp-action="CreateJob" asp-route-clienteId="@Model.CustomerId" class="prv-pro-btn prv-pro-btn--outline prv-pro-btn--block">@L["Create Job for Customer"]</a>
        <a asp-controller="Proveedor" asp-action="CreateEstimate" asp-route-clienteId="@Model.CustomerId" class="prv-pro-btn prv-pro-btn--primary prv-pro-btn--block">@L["Create Estimate"]</a>
        <a asp-controller="Proveedor" asp-action="AddCustomer" class="prv-pro-customer-add-another">@L["+ Add Another Customer"]</a>
    </div>
</div>
