@model IndorMvcApp.ViewModels.ProviderProCreateJobCategoriesViewModel
@{
    ViewData["Title"] = L["Create Job - INDOR PRO"];
    Layout = "_ProviderProLayout";
    var createJobCancelAction = (ViewBag.CreateJobCancelAction as string) ?? "Jobs";
    var selectedId = Model.SelectedCategoryId ?? Model.Categories.FirstOrDefault()?.Id;
    var selectedCategory = Model.Categories.FirstOrDefault(c => c.Id == selectedId) ?? Model.Categories.FirstOrDefault();
    var jobTitle = !string.IsNullOrWhiteSpace(Model.JobTitle)
        ? Model.JobTitle
        : selectedCategory?.SuggestedJobName ?? "";
}

<div class="prv-pro-shell prv-pro-shell--create-job prv-pro-shell--wizard">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    @{
        ViewBag.WizardStepLine = Model.StepSubtitle;
        ViewBag.WizardSteps = Model.WizardSteps;
    }
    @await Html.PartialAsync("_CreateJobWizardHead")

    <form asp-controller="Proveedor" asp-action="CreateJob" method="post" class="prv-pro-wizard-form" id="createJobStep1Form">
        @Html.AntiForgeryToken()

        <section class="prv-pro-wizard-card">
            <h2>@L["What type of job are you creating?"]</h2>
            <p>@L["Choose a category so INDOR can organize the work and prepare the right quote flow."]</p>

            <div class="prv-pro-type-grid" role="radiogroup" aria-label="@L["Job type"]">
                @foreach (var cat in Model.Categories)
                {
                    var isSelected = cat.Id == selectedId;
                    <label class="prv-pro-type-tile @(isSelected ? "is-selected" : "")" data-suggested="@UiDisplayLocalization.Localize(L, cat.SuggestedJobName)">
                        <input type="radio" name="ServiceCategoryId" value="@cat.Id" @(isSelected ? "checked" : "") required />
                        <span class="prv-pro-wizard-type-icon prv-pro-wizard-type-icon--@cat.ToneClass">
                            <i class="fas @cat.IconClass"></i>
                        </span>
                        <span class="prv-pro-type-tile-label">@UiDisplayLocalization.Localize(L, cat.Label)</span>
                        @if (isSelected)
                        {
                            <span class="prv-pro-type-tile-check"><i class="fas fa-check"></i></span>
                        }
                    </label>
                }
            </div>
        </section>

        <section class="prv-pro-wizard-card">
            <h2>@L["Job naming"]</h2>
            <label class="prv-pro-form-label">
                @L["Job name"]
                <input type="text" name="Title" id="createJobTitle" value="@jobTitle" placeholder="@L["Water Damage Inspection"]" required />
            </label>
            <small class="prv-pro-wizard-hint">@L["This will help classify the job in your list."]</small>
        </section>

        <div class="prv-pro-wizard-actions">
            <a asp-controller="Proveedor" asp-action="@createJobCancelAction" class="prv-pro-btn prv-pro-btn--outline">@L["Cancel"]</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">@L["Continue"]</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            var tiles = document.querySelectorAll('.prv-pro-type-tile');
            var titleInput = document.getElementById('createJobTitle');

            tiles.forEach(function (tile) {
                tile.addEventListener('click', function () {
                    tiles.forEach(function (t) {
                        t.classList.remove('is-selected');
                        var check = t.querySelector('.prv-pro-type-tile-check');
                        if (check) check.remove();
                    });
                    tile.classList.add('is-selected');
                    var checkEl = document.createElement('span');
                    checkEl.className = 'prv-pro-type-tile-check';
                    checkEl.innerHTML = '<i class="fas fa-check"></i>';
                    tile.appendChild(checkEl);
                    var radio = tile.querySelector('input[type="radio"]');
                    if (radio) radio.checked = true;
                    var suggested = tile.dataset.suggested;
                    if (suggested && titleInput && !titleInput.value.trim()) {
                        titleInput.value = suggested;
                    }
                });
            });
        })();
    </script>
}
