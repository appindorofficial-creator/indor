@model IndorMvcApp.ViewModels.InsuranceCoverageStepViewModel
@{
    ViewData["Title"] = $"{Model.PlanDisplayName} - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    ViewData["ProviderProExtraCss"] = "insurance-quote.css";

    var indorBenefits = IndorMvcApp.ViewModels.InsuranceCatalog.IndorBenefitsFor(Model.Plan);
    var securityBenefits = IndorMvcApp.ViewModels.InsuranceCatalog.SecurityBenefitsFor(Model.Plan);
}

<div class="prv-pro-shell ins-wiz@(Model.IsPremium ? " ins-wiz--premium" : "")">
    <header class="ins-hd">
        <a asp-controller="Proveedor" asp-action="InsurancePlans" class="ins-hd-back" aria-label="@L["Back"]"><i class="fas fa-chevron-left"></i></a>
        <div class="ins-hd-text">
            <h1>@L[Model.PlanDisplayName]</h1>
            <p>@L[Model.PlanSubtitle]</p>
        </div>
    </header>

    <div class="ins-summary">
        <span class="ins-summary-icon"><i class="fas fa-shield-halved"></i></span>
        <div class="ins-summary-body">
            <span class="ins-summary-lbl">
                @L[Model.PlanDisplayName]
                @if (Model.IsPopular)
                {
                    <span class="ins-popular">@L["Most Popular"]</span>
                }
            </span>
            <div class="ins-summary-price">
                <div><small>@L["Monthly"]</small><strong>$@Model.Monthly.ToString("0")<span>@L["/month"]</span></strong></div>
                <div><small>@L["Initial activation"]</small><strong>$@Model.PayToday.ToString("0")</strong></div>
            </div>
        </div>
    </div>

    <h2 class="ins-block-title">@L["INDOR benefits included"]</h2>
    <ol class="ins-benefit-list">
        @for (var i = 0; i < indorBenefits.Count; i++)
        {
            var f = indorBenefits[i];
            <li>
                <span class="ins-benefit-num">@(i + 1)</span>
                <span class="ins-benefit-icon"><i class="fas @f.Icon"></i></span>
                <strong>@UiDisplayLocalization.Localize(L, f.Title)</strong>
            </li>
        }
    </ol>

    <section class="ins-security-panel" aria-labelledby="insSecurityTitle">
        <h2 id="insSecurityTitle" class="ins-block-title ins-block-title--on-panel">@L["Security and backing included"]</h2>
        <ul class="ins-security-list">
            @foreach (var f in securityBenefits)
            {
                <li>
                    <span class="ins-security-check" aria-hidden="true"><i class="fas fa-check"></i></span>
                    <strong>@UiDisplayLocalization.Localize(L, f.Title)</strong>
                </li>
            }
        </ul>
    </section>

    <div class="ins-note ins-note--info">
        <i class="fas fa-circle-info"></i>
        <span>@L["After you continue, our licensed insurance partner will review your information and confirm coverage before your policy is issued."]</span>
    </div>

    <form asp-controller="Proveedor" asp-action="InsuranceQuote" method="post" class="ins-footer ins-footer--split">
        @Html.AntiForgeryToken()
        <a asp-controller="Proveedor" asp-action="InsurancePlans" class="ins-cta ins-cta--ghost">@L["Back"]</a>
        <button type="submit" class="ins-cta">@L["Continue"]</button>
    </form>
</div>
