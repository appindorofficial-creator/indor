@model IndorMvcApp.ViewModels.ProviderProCreateEstimatePricingViewModel
@using System.Globalization
@{
    ViewData["Title"] = L["Pricing & Line Items - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
}

<div class="prv-pro-shell prv-pro-shell--create-estimate">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="CreateEstimateDetails" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Pricing &amp; Line Items"]</h1>
            <small>@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</small>
        </div>
        <span class="prv-pro-step-badge">@L.T("Step {0} of {1}", Model.StepNumber, Model.TotalSteps)</span>
    </header>

    <form asp-controller="Proveedor" asp-action="CreateEstimatePricing" method="post" class="prv-pro-create-estimate-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="TaxRate" value="@Model.TaxRate" />

        <div class="prv-pro-pricing-lines">
            @for (var i = 0; i < Model.LineItems.Count; i++)
            {
                var line = Model.LineItems[i];
                <article class="prv-pro-pricing-line">
                    <input type="hidden" name="LineCategories" value="@line.Category" />
                    <input type="hidden" name="LineLabels" value="@line.Label" />
                    <input type="hidden" name="LineDescriptions" value="@line.Description" />
                    <input type="hidden" name="LineTaxable" value="@(line.IsTaxable ? "true" : "false")" />
                    <div class="prv-pro-pricing-line-head">
                        <strong>@UiDisplayLocalization.Localize(L, line.Label)</strong>
                        <span class="prv-pro-pricing-tax @(line.IsTaxable ? "is-taxable" : "")">@(line.IsTaxable ? L["Taxable"] : L["Non-Taxable"])</span>
                    </div>
                    <small>@line.Description</small>
                    <div class="prv-pro-pricing-line-fields">
                        <label>@L["Qty"]<input type="number" name="LineQtys" value="@line.Qty" step="0.01" min="0" /></label>
                        <label>@L["Unit"]<input type="text" name="LineUnits" value="@line.Unit" /></label>
                        <label>@L["Unit Price"]<input type="number" name="LineUnitPrices" value="@line.UnitPrice" step="0.01" min="0" /></label>
                        <label>@L["Amount"]<input type="number" name="LineAmounts" value="@line.Amount" step="0.01" min="0" /></label>
                    </div>
                </article>
            }
        </div>

        <section class="prv-pro-pricing-totals">
            <div><span>@L["Subtotal"]</span><strong>@Model.SubtotalAmount.ToString("C2", money)</strong></div>
            <div><span>@L.T("Tax ({0}%)", (Model.TaxRate * 100).ToString("0.##"))</span><strong>@Model.TaxAmount.ToString("C2", money)</strong></div>
            <div class="prv-pro-pricing-total"><span>@L["Total Estimate"]</span><strong>@Model.TotalAmount.ToString("C2", money)</strong></div>
        </section>

        <div class="prv-pro-create-job-actions">
            <a asp-controller="Proveedor" asp-action="CreateEstimateDetails" class="prv-pro-btn prv-pro-btn--outline">@L["Back"]</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">@L["Next"]</button>
        </div>
    </form>
</div>
