@model IndorMvcApp.ViewModels.InvitationSentViewModel
@{
    ViewData["Title"] = L["Invitation Sent"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-requests.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-req-shell">
    <header class="prv-req-hero prv-req-hero--confirm">
        <div class="prv-req-hero-top">
            <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-req-back" aria-label="@L["Back"]"><i class="fas fa-arrow-left"></i></a>
            <span class="prv-req-brand-word">@L["INDOR"]</span>
            <span class="prv-req-brand-pro">@L["PRO"]</span>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>
        <div class="prv-req-confirm-head">
            <span class="prv-req-confirm-check"><i class="fas fa-check"></i></span>
            <div>
                <h1>@L["Invitation Sent"]</h1>
                <p>@L.T("Your invitation was sent to {0}.", Model.Sub.Name)</p>
            </div>
        </div>
    </header>

    @await Html.PartialAsync("_InviteSubHeader", Model.Sub)

    <section class="prv-req-panel">
        <div class="prv-inv-summary">
            <div class="prv-inv-summary-row">
                <span><i class="fas fa-briefcase"></i> @L["Job"]</span>
                <strong>@Model.JobTitle</strong>
            </div>
            <div class="prv-inv-summary-row">
                <span><i class="fas fa-calendar-check"></i> @L["Schedule"]</span>
                <strong>@Model.ScheduleLabel</strong>
            </div>
            <div class="prv-inv-summary-row">
                <span><i class="fas fa-dollar-sign"></i> @L["Budget"]</span>
                <strong>@Model.BudgetRange</strong>
            </div>
        </div>
    </section>

    <section class="prv-req-panel">
        @await Html.PartialAsync("_RequestStepper", Model.Steps)
    </section>

    <section class="prv-req-panel">
        <h2 class="prv-req-panel-title">@L["What happens next"]</h2>
        <div class="prv-req-next">
            <div class="prv-req-next-item">
                <span class="prv-req-next-num">1</span>
                <i class="fas fa-file-magnifying-glass"></i>
                <span>@L["Contractor reviews request"]</span>
            </div>
            <div class="prv-req-next-item">
                <span class="prv-req-next-num">2</span>
                <i class="fas fa-comment-dots"></i>
                <span>@L["You receive quote or message"]</span>
            </div>
            <div class="prv-req-next-item">
                <span class="prv-req-next-num">3</span>
                <i class="fas fa-calendar-check"></i>
                <span>@L["Hire and schedule work"]</span>
            </div>
        </div>
    </section>

    <div class="prv-inv-info">
        <i class="fas fa-circle-info"></i>
        <span>@L.T("You can continue browsing other subcontractors while you wait. We'll notify you when {0} responds.", Model.Sub.Name)</span>
    </div>

    <a asp-controller="Proveedor" asp-action="InvitationSent" asp-route-id="@Model.Id" class="prv-req-btn prv-req-btn--primary prv-req-btn--block">
        <i class="fas fa-paper-plane"></i> @L["Track Request"]</a>
    <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-req-btn prv-req-btn--ghost prv-req-btn--block">
        @L["Back to Search"]
    </a>
</div>
