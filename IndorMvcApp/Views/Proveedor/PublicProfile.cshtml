@model IndorMvcApp.ViewModels.ProviderProProfilePageViewModel
@{
    ViewData["Title"] = L["Public Profile - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
    var allServices = Model.Categories.Concat(Model.Services).Distinct().ToList();
    var publicProfileUrl = Url.Action("PublicProfile", "Proveedor", null, Context.Request.Scheme);
    var servicesPending = L["Services pending"];
    var aboutText = !string.IsNullOrWhiteSpace(Model.SpecialtiesSummary) && Model.SpecialtiesSummary != servicesPending
        ? L.T("Professional services including {0}.", Model.SpecialtiesSummary.ToLowerInvariant())
        : L["Trusted local service provider on INDOR."];
    var hoursLabel = string.IsNullOrWhiteSpace(Model.BusinessHours)
        || string.Equals(Model.BusinessHours, L["Hours not set"], StringComparison.Ordinal)
        ? "—"
        : Model.BusinessHours;
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--public-profile">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head prv-pro-public-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back" aria-label="@L["Back to profile"]">
            <i class="fas fa-chevron-left"></i>
        </a>
        <div>
            <h1>@L["Public Profile"]</h1>
            <p>@L["Preview how homeowners see your business on INDOR."]</p>
        </div>
    </header>

    <section class="prv-pro-public-hero">
        <div class="prv-pro-public-hero-main">
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <img src="@Url.Content($"~{Model.LogoUrl}")" alt="@Model.CompanyName" class="prv-pro-profile-logo prv-pro-profile-logo--img" />
            }
            else
            {
                <div class="prv-pro-profile-logo">@Model.CompanyInitial</div>
            }
            <div>
                <div class="prv-pro-profile-name-row">
                    <h2>@Model.CompanyName</h2>
                    @if (Model.IsVerified)
                    {
                        <span class="prv-pro-verified"><i class="fas fa-circle-check"></i> @L["Verified Provider"]</span>
                    }
                    @if (Model.IsTopRated)
                    {
                        <span class="prv-pro-top-rated"><i class="fas fa-star"></i> @L["Top Rated"]</span>
                    }
                </div>
                <p class="prv-pro-profile-specialties">@UiDisplayLocalization.Localize(L, Model.SpecialtiesSummary)</p>
                <p class="prv-pro-profile-area"><i class="fas fa-location-dot"></i> @UiDisplayLocalization.Localize(L, Model.ServiceAreaLabel)</p>
            </div>
        </div>
        <div class="prv-pro-public-actions">
            <a asp-controller="Proveedor" asp-action="ProfileCompletion" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-pen"></i> @L["Edit Profile"]
            </a>
            <a href="@publicProfileUrl"
               class="prv-pro-btn prv-pro-btn--ghost"
               id="prvPublicShareBtn"
               data-provider-share
               data-share-url="@publicProfileUrl"
               data-share-title="@Model.CompanyName - INDOR PRO"
               data-share-text="@L["View my provider profile on INDOR"]"
               data-share-copied="@L["Profile link copied to clipboard."]"
               data-share-prompt="@L["Copy profile link:"]"
               role="button">
                <i class="fas fa-share-nodes"></i> @L["Share"]
            </a>
        </div>
    </section>

    <div class="prv-pro-profile-grid prv-pro-public-grid">
        <section class="prv-pro-profile-card prv-pro-profile-card--wide">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-circle-info"></i> @L["About"]</h3></header>
            <p class="prv-pro-public-about">@aboutText</p>
            <div class="prv-pro-profile-kv"><i class="fas fa-clock"></i><span>@hoursLabel</span></div>
            @if (Model.EmergencyService)
            {
                <div class="prv-pro-profile-kv"><i class="fas fa-bolt"></i><span>@L["Emergency service available"]</span></div>
            }
            @if (Model.SameDayJobs)
            {
                <div class="prv-pro-profile-kv"><i class="fas fa-calendar-day"></i><span>@L["Same-day jobs available"]</span></div>
            }
            @if (Model.TravelRadiusMiles > 0)
            {
                <div class="prv-pro-profile-kv"><i class="fas fa-route"></i><span>@L.T("Travel radius: {0} miles", Model.TravelRadiusMiles)</span></div>
            }
        </section>

        <section class="prv-pro-profile-card">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-wrench"></i> @L["Services Offered"]</h3></header>
            @if (allServices.Count == 0)
            {
                <p class="prv-pro-empty">@L["No services selected yet."]</p>
            }
            else
            {
                <div class="prv-pro-profile-tags">
                    @foreach (var svc in allServices)
                    {
                        <span class="prv-pro-pill prv-pro-pill--scheduled">@UiDisplayLocalization.Localize(L, svc)</span>
                    }
                </div>
            }
        </section>

        <section class="prv-pro-profile-card">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-map-location-dot"></i> @L["Service Areas"]</h3></header>
            @if (Model.ServiceAreas.Count == 0)
            {
                <p class="prv-pro-empty">@UiDisplayLocalization.Localize(L, Model.ServiceAreaLabel)</p>
            }
            else
            {
                @foreach (var area in Model.ServiceAreas)
                {
                    <div class="prv-pro-profile-kv"><i class="fas fa-location-dot"></i><span>@UiDisplayLocalization.Localize(L, area)</span></div>
                }
            }
        </section>

        <section class="prv-pro-profile-card">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-star"></i> @L["Reputation"]</h3></header>
            <div class="prv-pro-profile-kv-row">
                <span>@L["Provider Score"]</span>
                <strong>@(Model.ProviderScore > 0 ? Model.ProviderScore.ToString() : "—")</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>@L["Rating"]</span>
                <strong>@(Model.ReviewCount > 0 ? L.T("{0} ★ ({1} reviews)", Model.Rating.ToString("0.0"), Model.ReviewCount) : L["No reviews yet"])</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>@L["Jobs completed this year"]</span>
                <strong>@Model.JobsCompletedThisYear</strong>
            </div>
        </section>
    </div>
</div>

<div id="prvProfileToast" class="prv-pro-profile-toast" hidden role="status"></div>

@section Scripts {
<script src="~/js/provider-profile.js" asp-append-version="true"></script>
}
