@model IndorMvcApp.ViewModels.ProviderProEditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--edit-profile">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back"><i class="fas fa-arrow-left"></i></a>
        <div>
            <h1>Edit Profile</h1>
            <p>Update your business details and profile photo.</p>
        </div>
    </header>

    @if (TempData["ProfileSaved"] is true)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success">
            <i class="fas fa-circle-check"></i> Profile updated successfully.
        </div>
    }

    @if (TempData["ProfilePhotoError"] is string photoError)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @photoError
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error" role="alert">
            <i class="fas fa-circle-exclamation"></i>
            @Html.ValidationSummary(false)
        </div>
    }

    <form asp-controller="Proveedor" asp-action="EditProfile" method="post" enctype="multipart/form-data" class="prv-pro-edit-profile-form" novalidate>
        @Html.AntiForgeryToken()

        <section class="prv-pro-wizard-card" id="edit-profile-photo">
            <h2>Profile photo</h2>
            <p>Upload a logo or photo. It will appear on your provider profile.</p>
            <div class="prv-pro-edit-profile-photo-row">
                <div class="prv-pro-edit-profile-photo-preview" id="photoPreview">
                    @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                    {
                        <img src="@Url.Content($"~{Model.LogoUrl}")" alt="Current profile photo" id="photoPreviewImg" />
                    }
                    else
                    {
                        <span id="photoPreviewInitial">@Model.CompanyInitial</span>
                        <img src="" alt="" id="photoPreviewImg" hidden />
                    }
                </div>
                <div class="prv-pro-edit-profile-photo-actions">
                    <label class="prv-pro-btn prv-pro-btn--ghost prv-pro-edit-profile-upload-btn">
                        <i class="fas fa-camera"></i> Choose photo
                        <input type="file" name="profilePhoto" id="profilePhotoInput" accept="image/jpeg,image/png,image/webp" hidden />
                    </label>
                    <small>JPG, PNG or WEBP · Max 10 MB</small>
                </div>
            </div>
        </section>

        <section class="prv-pro-wizard-card" id="edit-profile-business">
            <h2>Business details</h2>
            <div class="prv-pro-edit-profile-fields">
                <label>
                    <span>Business name</span>
                    <input type="text" name="BusinessName" value="@Model.BusinessName" placeholder="Legal business name" />
                </label>
                <label>
                    <span>DBA / display name</span>
                    <input type="text" name="DbaName" value="@Model.DbaName" placeholder="Name shown to customers" />
                </label>
                <label>
                    <span>Primary contact</span>
                    <input type="text" name="PrimaryContact" value="@Model.PrimaryContact" placeholder="Contact person" />
                </label>
                <label>
                    <span>Phone</span>
                    <input type="tel" name="Phone" value="@Model.Phone" placeholder="Business phone" />
                </label>
                <label>
                    <span>Email</span>
                    <input type="email" name="Email" value="@Model.Email" placeholder="Business email" />
                </label>
                <label>
                    <span>Business address</span>
                    <input type="text" name="BusinessAddress" value="@Model.BusinessAddress" placeholder="Street address" />
                </label>
                <label>
                    <span>Business hours</span>
                    <input type="text" name="PreferredHours" value="@Model.PreferredHours" placeholder="e.g. Mon–Fri 8am–6pm" />
                </label>
                <label class="prv-pro-edit-profile-field--wide">
                    <span>Service description</span>
                    <textarea name="ServiceDescription" rows="3" placeholder="Brief description of your services">@Model.ServiceDescription</textarea>
                </label>
            </div>
        </section>

        <section class="prv-pro-wizard-card" id="edit-profile-areas">
            <h2>Service areas</h2>
            <p>Define where you accept jobs and how far you travel.</p>
            <div class="prv-pro-edit-profile-fields">
                <label>
                    <span>Primary city / service area</span>
                    <input type="text" name="PrimaryCity" value="@Model.PrimaryCity" placeholder="City, state" />
                </label>
                <label class="prv-pro-edit-profile-field--wide">
                    <span>ZIP codes served</span>
                    <input type="text" name="ServiceZipCodes" value="@Model.ServiceZipCodes" placeholder="28202, 28203, 28205" />
                </label>
                <label>
                    <span>Travel radius (miles)</span>
                    <input type="number" name="TravelRadiusMiles" value="@Model.TravelRadiusMiles" min="1" max="200" />
                </label>
            </div>
            <div class="prv-pro-edit-profile-toggles">
                <label class="prv-pro-toggle-row">
                    <input type="hidden" name="EmergencyService" value="false" />
                    <input type="checkbox" name="EmergencyService" value="true" checked="@Model.EmergencyService" />
                    <span>Emergency service available</span>
                </label>
                <label class="prv-pro-toggle-row">
                    <input type="hidden" name="SameDayJobs" value="false" />
                    <input type="checkbox" name="SameDayJobs" value="true" checked="@Model.SameDayJobs" />
                    <span>Same-day jobs available</span>
                </label>
            </div>
        </section>

        <footer class="prv-pro-edit-profile-actions">
            <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-btn prv-pro-btn--ghost">Cancel</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-floppy-disk"></i> Save profile
            </button>
        </footer>
    </form>
</div>

@section Scripts {
<script>
(function () {
    var input = document.getElementById('profilePhotoInput');
    var preview = document.getElementById('photoPreview');
    var img = document.getElementById('photoPreviewImg');
    var initial = document.getElementById('photoPreviewInitial');
    var activeSection = '@(ViewBag.ActiveSection ?? "business")';
    var sectionEl = document.getElementById('edit-profile-' + activeSection);
    if (sectionEl) {
        sectionEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
        var focusInput = sectionEl.querySelector('input, textarea, select');
        if (focusInput) {
            focusInput.focus({ preventScroll: true });
        }
    }

    input?.addEventListener('change', function () {
        const file = input.files && input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (e) {
            if (img) {
                img.src = e.target?.result || '';
                img.hidden = false;
            }
            if (initial) initial.style.display = 'none';
            preview?.classList.add('has-image');
        };
        reader.readAsDataURL(file);
    });
})();
</script>
}
