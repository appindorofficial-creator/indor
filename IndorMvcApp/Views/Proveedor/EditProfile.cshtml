@model IndorMvcApp.ViewModels.ProviderProEditProfileViewModel
@{
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
    var activeSection = (ViewBag.ActiveSection as string)?.Trim().ToLowerInvariant() ?? "full";
    var isFullEdit = activeSection == "full";
    var showPhoto = isFullEdit;
    var showBusiness = isFullEdit || activeSection == "business";
    var showAreas = isFullEdit || activeSection == "areas";
    var pageTitle = activeSection switch
    {
        "business" => "Business Information",
        "areas" => "Service Areas",
        _ => "Edit Profile"
    };
    ViewData["Title"] = $"{pageTitle} - INDOR PRO";
    var pageSubtitle = activeSection switch
    {
        "business" => "Update your company name, contact details, and hours.",
        "areas" => "Define where you accept jobs and how far you travel.",
        _ => "Update your business details and profile photo."
    };
    var saveLabel = activeSection switch
    {
        "business" => "Save business info",
        "areas" => "Save service areas",
        _ => "Save profile"
    };
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--edit-profile">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@pageTitle</h1>
            <p>@pageSubtitle</p>
        </div>
    </header>

    @if (TempData["ProfileSaved"] is true)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success">
            <i class="fas fa-circle-check"></i> Profile updated successfully.
        </div>
    }

    @if (TempData["ProfilePhotoError"] is string photoError)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @photoError
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error" role="alert">
            <i class="fas fa-circle-exclamation"></i>
            @Html.ValidationSummary(false)
        </div>
    }

    @if (showPhoto)
    {
    <div id="prvEditProfilePhotoAlerts"></div>
    @if (TempData["ProfilePhotoOk"] is string photoOk)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success" role="status">
            <i class="fas fa-circle-check"></i> @photoOk
        </div>
    }
    <section class="prv-pro-wizard-card" id="edit-profile-photo">
        <h2>Profile photo</h2>
        <p>Upload a logo or photo. It will appear on your provider profile.</p>
        <form asp-controller="Proveedor" asp-action="UploadProfilePhoto" method="post" enctype="multipart/form-data" id="prvEditProfilePhotoForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnTo" value="editar" />
            <div class="prv-pro-edit-profile-photo-row">
                <div class="prv-pro-edit-profile-photo-preview prv-pro-profile-photo-preview" id="prvEditProfilePhotoPreview">
                    @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                    {
                        <img src="@Url.Content($"~{Model.LogoUrl}")" alt="Current profile photo" class="prv-pro-profile-logo prv-pro-profile-logo--img" id="prvEditProfilePhotoImg" />
                        <span class="prv-pro-profile-logo" id="prvEditProfilePhotoPlaceholder" hidden>@Model.CompanyInitial</span>
                    }
                    else
                    {
                        <span class="prv-pro-profile-logo" id="prvEditProfilePhotoPlaceholder">@Model.CompanyInitial</span>
                        <img src="" alt="" class="prv-pro-profile-logo prv-pro-profile-logo--img" id="prvEditProfilePhotoImg" hidden />
                    }
                </div>
                <div class="prv-pro-edit-profile-photo-actions">
                    <button type="button" class="prv-pro-btn prv-pro-btn--ghost prv-pro-edit-profile-upload-btn" id="prvEditProfilePhotoBtn" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-camera"></i> Change photo
                    </button>
                    <div class="prv-pro-profile-photo-menu" id="prvEditProfilePhotoMenu" role="menu" hidden>
                        <button type="button" class="prv-pro-profile-photo-menu-item" id="prvEditProfilePhotoTake" role="menuitem">
                            <i class="fas fa-camera"></i> Take photo
                        </button>
                        <button type="button" class="prv-pro-profile-photo-menu-item" id="prvEditProfilePhotoChoose" role="menuitem">
                            <i class="fas fa-image"></i> Choose from library
                        </button>
                    </div>
                    <input type="file" id="prvEditProfilePhotoCamera" name="photo" accept="image/*" capture="environment" hidden />
                    <input type="file" id="prvEditProfilePhotoLibrary" name="photo" accept="image/jpeg,image/png,image/webp,image/*" hidden />
                    <small>JPG, PNG or WEBP · Max 10 MB</small>
                </div>
            </div>
        </form>
    </section>
    }

    <form asp-controller="Proveedor" asp-action="EditProfile" method="post" enctype="multipart/form-data" class="prv-pro-edit-profile-form" novalidate>
        @Html.AntiForgeryToken()
        @if (!isFullEdit)
        {
            <input type="hidden" name="activeSection" value="@activeSection" />
        }

        @if (!showBusiness)
        {
            <input type="hidden" name="BusinessName" value="@Model.BusinessName" />
            <input type="hidden" name="DbaName" value="@Model.DbaName" />
            <input type="hidden" name="PrimaryContact" value="@Model.PrimaryContact" />
            <input type="hidden" name="Phone" value="@Model.Phone" />
            <input type="hidden" name="Email" value="@Model.Email" />
            <input type="hidden" name="BusinessAddress" value="@Model.BusinessAddress" />
            <input type="hidden" name="PreferredHours" value="@Model.PreferredHours" />
            <input type="hidden" name="ServiceDescription" value="@Model.ServiceDescription" />
        }

        @if (!showAreas)
        {
            <input type="hidden" name="PrimaryCity" value="@Model.PrimaryCity" />
            <input type="hidden" name="ServiceZipCodes" value="@Model.ServiceZipCodes" />
            <input type="hidden" name="TravelRadiusMiles" value="@Model.TravelRadiusMiles" />
            <input type="hidden" name="EmergencyService" value="@(Model.EmergencyService ? "true" : "false")" />
            <input type="hidden" name="SameDayJobs" value="@(Model.SameDayJobs ? "true" : "false")" />
        }

        @if (showBusiness)
        {
        <section class="prv-pro-wizard-card" id="edit-profile-business">
            <h2>Business details</h2>
            <div class="prv-pro-edit-profile-fields">
                <label>
                    <span>Business name</span>
                    <input type="text" name="BusinessName" value="@Model.BusinessName" placeholder="Legal business name" />
                </label>
                <label>
                    <span>DBA / display name</span>
                    <input type="text" name="DbaName" value="@Model.DbaName" placeholder="Name shown to customers" />
                </label>
                <label>
                    <span>Primary contact</span>
                    <input type="text" name="PrimaryContact" value="@Model.PrimaryContact" placeholder="Contact person" />
                </label>
                <label>
                    <span>Phone</span>
                    <input type="tel" name="Phone" value="@Model.Phone" placeholder="Business phone" data-phone-input />
                </label>
                <label>
                    <span>Email</span>
                    <input type="email" name="Email" value="@Model.Email" placeholder="Business email" />
                </label>
                <label>
                    <span>Business address</span>
                    <input type="text" name="BusinessAddress" value="@Model.BusinessAddress" placeholder="Street address" />
                </label>
                <label>
                    <span>Business hours</span>
                    <input type="text" name="PreferredHours" value="@Model.PreferredHours" placeholder="e.g. Mon–Fri 8am–6pm" />
                </label>
                <label class="prv-pro-edit-profile-field--wide">
                    <span>Service description</span>
                    <textarea name="ServiceDescription" rows="3" placeholder="Brief description of your services">@Model.ServiceDescription</textarea>
                </label>
            </div>
        </section>
        }

        @if (showAreas)
        {
        <section class="prv-pro-wizard-card" id="edit-profile-areas">
            <h2>Service areas</h2>
            <p>Define where you accept jobs and how far you travel.</p>
            <div class="prv-pro-edit-profile-fields">
                <label>
                    <span>Primary city / service area</span>
                    <input type="text" name="PrimaryCity" value="@Model.PrimaryCity" placeholder="City, state" />
                </label>
                <label class="prv-pro-edit-profile-field--wide">
                    <span>ZIP codes served</span>
                    <input type="text" name="ServiceZipCodes" value="@Model.ServiceZipCodes" placeholder="28202, 28203, 28205" />
                </label>
                <label>
                    <span>Travel radius (miles)</span>
                    <input type="number" name="TravelRadiusMiles" value="@Model.TravelRadiusMiles" min="1" max="200" />
                </label>
            </div>
            <div class="prv-pro-edit-profile-toggles">
                <label class="prv-pro-toggle-row">
                    <input type="hidden" name="EmergencyService" value="false" />
                    <span>Emergency service available</span>
                    <input type="checkbox" name="EmergencyService" value="true" @(Model.EmergencyService ? "checked" : null) />
                </label>
                <label class="prv-pro-toggle-row">
                    <input type="hidden" name="SameDayJobs" value="false" />
                    <span>Same-day jobs available</span>
                    <input type="checkbox" name="SameDayJobs" value="true" @(Model.SameDayJobs ? "checked" : null) />
                </label>
            </div>
        </section>
        }

        <footer class="prv-pro-edit-profile-actions prv-pro-edit-profile-footer">
            <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-btn prv-pro-btn--ghost">Cancel</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-floppy-disk"></i> @saveLabel
            </button>
        </footer>
    </form>
</div>

@section Scripts {
<script src="~/js/profile-photo-upload.js" asp-append-version="true"></script>
<script>
(function () {
    var errorAlert = document.querySelector('.prv-pro-edit-profile-alert--error');
    if (errorAlert) {
        errorAlert.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    var form = document.querySelector('.prv-pro-edit-profile-form');
    if (!form) {
        return;
    }

    form.addEventListener('submit', function (e) {
        var phone = form.querySelector('[data-phone-input]');
        if (!phone || !phone.value.trim()) {
            return;
        }

        var valid = window.IndorPhoneInput
            ? window.IndorPhoneInput.isValidOptional(phone.value)
            : phone.value.replace(/\D/g, '').length === 10;

        if (!valid) {
            e.preventDefault();
            phone.setCustomValidity('Enter a valid 10-digit US phone number (e.g. 555 123 4567).');
            phone.reportValidity();
        }
    });
})();
</script>
}
