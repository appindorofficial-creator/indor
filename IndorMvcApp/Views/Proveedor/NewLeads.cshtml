@model IndorMvcApp.ViewModels.ProviderProNewLeadsPageViewModel
@{
    ViewData["Title"] = L["New Leads - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var filters = new (string Id, string Label, int Count)[]
    {
        ("new", "New", Model.NewCount),
        ("in_progress", "In Progress", Model.InProgressCount),
        ("responded", "Responded", Model.RespondedCount)
    };
}

<div class="prv-pro-shell prv-pro-shell--new-leads">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-new-leads-head">
        <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["New Leads"]</h1>
            <small>@L.T("{0} new · {1} high urgency", Model.NewCount, Model.HighUrgencyCount)</small>
        </div>
        <button type="button" class="prv-pro-lead-share" aria-label="@L["Notifications"]"><i class="fas fa-bell"></i></button>
    </header>

    @if (TempData["LeadAccepted"] as bool? == true)
    {
        <div class="prv-pro-lead-toast">@L["Lead accepted successfully."]</div>
    }

    <form method="get" asp-controller="Proveedor" asp-action="NewLeads" class="prv-pro-jobs-search">
        <input type="hidden" name="filter" value="@Model.ActiveFilter" />
        <div class="prv-pro-search-wrap">
            <i class="fas fa-magnifying-glass"></i>
            <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search by address, service or customer"]" />
        </div>
    </form>

    <nav class="prv-pro-lead-tabs" aria-label="@L["Lead tabs"]">
        @foreach (var (id, label, count) in filters)
        {
            <a asp-controller="Proveedor" asp-action="NewLeads"
               asp-route-filter="@id"
               asp-route-q="@Model.SearchQuery"
               class="@(Model.ActiveFilter == id ? "is-active" : "")">
                @UiDisplayLocalization.Localize(L, label) (@count)
            </a>
        }
    </nav>

    <section class="prv-pro-new-leads-list">
        @if (Model.Leads.Count == 0)
        {
            <div class="prv-pro-panel">
                <p class="prv-pro-empty">@L["No leads in this view yet. New opportunities from INDOR will appear here."]</p>
            </div>
        }
        else
        {
            @foreach (var lead in Model.Leads)
            {
                <article class="prv-pro-new-lead-card">
                    <img src="@Url.Content($"~{lead.ImageUrl}")" alt="Property" class="prv-pro-new-lead-img" />
                    <div class="prv-pro-new-lead-body">
                        <div class="prv-pro-new-lead-top">
                            <span class="prv-pro-pill prv-pro-pill--urgency-@lead.UrgencyClass">
                                <i class="fas @lead.UrgencyIcon"></i> @UiDisplayLocalization.Localize(L, lead.Urgency)
                            </span>
                            @if (!string.IsNullOrWhiteSpace(lead.ReceivedLabel))
                            {
                                <small class="prv-pro-new-lead-time">@UiDisplayLocalization.Localize(L, lead.ReceivedLabel)</small>
                            }
                        </div>
                        <strong>@lead.Address</strong>
                        <div class="prv-pro-new-lead-tags">
                            <span class="prv-pro-pill prv-pro-pill--scheduled"><i class="fas fa-wrench"></i> @lead.ServiceType</span>
                            @if (!string.IsNullOrWhiteSpace(lead.FindingSummary))
                            {
                                <span class="prv-pro-pill prv-pro-pill--realtor"><i class="fas fa-list-check"></i> @UiDisplayLocalization.Localize(L, lead.FindingSummary)</span>
                            }
                        </div>
                        <div class="prv-pro-new-lead-actions">
                            <a asp-controller="Proveedor" asp-action="LeadDetails" asp-route-id="@lead.Id"
                               class="prv-pro-btn prv-pro-btn--primary">@L["View Lead"]</a>
                            @if (lead.CanDecline)
                            {
                                <form asp-controller="Proveedor" asp-action="DeclineLead" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@lead.Id" />
                                    <button type="submit" class="prv-pro-btn prv-pro-btn--ghost">@L["Decline"]</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            }
        }
    </section>
</div>
