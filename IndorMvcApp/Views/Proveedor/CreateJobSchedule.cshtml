@model IndorMvcApp.ViewModels.ProviderProCreateJobScheduleViewModel
@{
    ViewData["Title"] = "Schedule - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "jobs";
}

<div class="prv-pro-shell prv-pro-shell--create-job">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="CreateJobDetails" class="prv-pro-lead-back"><i class="fas fa-arrow-left"></i></a>
        <div>
            <h1>Schedule</h1>
            <small>Step @Model.StepNumber of @Model.TotalSteps</small>
        </div>
        <span class="prv-pro-step-badge">Step @Model.StepNumber of @Model.TotalSteps</span>
    </header>

    <p class="prv-pro-create-job-intro">Select the date, time, and technician for this job.</p>

    <form asp-controller="Proveedor" asp-action="CreateJobSchedule" method="post" class="prv-pro-create-job-form">
        @Html.AntiForgeryToken()

        <label class="prv-pro-create-field">
            <i class="fas fa-calendar"></i>
            <span>Date <em class="prv-pro-required">*</em></span>
            <input type="date" name="VisitDate" value="@Model.VisitDate" required />
        </label>

        <label class="prv-pro-create-field">
            <i class="fas fa-clock"></i>
            <span>Start Time <em class="prv-pro-required">*</em></span>
            <select name="StartTimeLabel" required>
                @foreach (var time in Model.TimeOptions)
                {
                    <option value="@time" selected="@(Model.StartTimeLabel == time)">@time</option>
                }
            </select>
        </label>

        <label class="prv-pro-create-field">
            <i class="fas fa-clock"></i>
            <span>End Time <em class="prv-pro-required">*</em></span>
            <select name="EndTimeLabel" required>
                @foreach (var time in Model.TimeOptions)
                {
                    <option value="@time" selected="@(Model.EndTimeLabel == time)">@time</option>
                }
            </select>
        </label>

        <label class="prv-pro-create-toggle">
            <div>
                <i class="fas fa-calendar-plus"></i>
                <div>
                    <strong>Add to Calendar</strong>
                    <small>Add this job to your calendar</small>
                </div>
            </div>
            <input type="checkbox" name="AddToCalendar" value="true" @(Model.AddToCalendar ? "checked" : "") />
        </label>

        <label class="prv-pro-create-field">
            <i class="fas fa-bell"></i>
            <span>Reminder</span>
            <select name="Reminder">
                @foreach (var reminder in Model.ReminderOptions)
                {
                    <option value="@reminder" selected="@(Model.Reminder == reminder)">@reminder</option>
                }
            </select>
        </label>

        <label class="prv-pro-create-field">
            <i class="fas fa-user-gear"></i>
            <span>Assigned Technician</span>
            @if (Model.TechnicianOptions.Count > 0)
            {
                <select name="AssignedTechnician">
                    @foreach (var tech in Model.TechnicianOptions)
                    {
                        <option value="@tech" selected="@(Model.AssignedTechnician == tech)">@tech</option>
                    }
                </select>
            }
            else
            {
                <input type="text" name="AssignedTechnician" value="@Model.AssignedTechnician" placeholder="Technician name" />
            }
        </label>

        <div class="prv-pro-create-job-actions">
            <a asp-controller="Proveedor" asp-action="CreateJobDetails" class="prv-pro-btn prv-pro-btn--outline">Back</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">Next</button>
        </div>
    </form>
</div>
