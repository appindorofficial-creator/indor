@model IndorMvcApp.ViewModels.ProviderProJobsPageViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Jobs - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "jobs";
    ViewBag.CompanyInitial = Model.CompanyName.Trim().Length > 0
        ? Model.CompanyName.Trim()[0].ToString().ToUpperInvariant()
        : "P";
    var tabs = new[] {
        ("today", "Today"),
        ("leads", "Leads"),
        ("active", "Active"),
        ("estimates", "Estimates"),
        ("completed", "Completed")
    };
    var statCards = new[] {
        ("today", "fa-calendar-days", "blue", Model.TodayCount, "Today"),
        ("leads", "fa-user-plus", "green", Model.NewLeadsCount, "Leads"),
        ("active", "fa-circle-notch", "blue", Model.ActiveCount, "Active"),
        ("estimates", "fa-file-invoice-dollar", "purple", Model.EstimatesCount, "Estimates")
    };
    string listTitle = Model.ActiveTab switch
    {
        "today" => $"{Model.TodayCount} Job{(Model.TodayCount == 1 ? "" : "s")} Today",
        "leads" => $"{Model.NewLeadsCount} New Lead{(Model.NewLeadsCount == 1 ? "" : "s")}",
        "estimates" => $"{Model.EstimatesCount} Estimate{(Model.EstimatesCount == 1 ? "" : "s")}",
        "completed" => $"{Model.CompletedCount} Completed Job{(Model.CompletedCount == 1 ? "" : "s")}",
        _ => $"{Model.ActiveCount} Active Job{(Model.ActiveCount == 1 ? "" : "s")}"
    };
    string infoText = Model.ActiveTab switch
    {
        "today" => "Your schedule for today. Tap a job to view details, add notes, or update status.",
        "leads" => "New leads waiting for your response. Accept or create an estimate to get started.",
        "estimates" => "Review drafts and sent estimates. Tap to edit, send, or convert to a job.",
        "completed" => "Completed jobs and reports. Tap to view details or upload documentation.",
        _ => "Below are your active jobs. Tap a job to view details, add notes, or update status."
    };
}

<div class="prv-pro-shell prv-pro-shell--jobs prv-pro-shell--jobs-v2">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head">
        <h1>Jobs</h1>
        <p>Your operational hub for leads, jobs, estimates, reports, and payments.</p>
        <a asp-controller="Proveedor" asp-action="CreateJob" asp-route-from="jobs" class="prv-pro-jobs-create-btn">
            <i class="fas fa-plus"></i> Create Job
        </a>
    </header>

    <form method="get" asp-controller="Proveedor" asp-action="Jobs" class="prv-pro-jobs-search">
        <input type="hidden" name="tab" value="@Model.ActiveTab" />
        <div class="prv-pro-search-wrap">
            <i class="fas fa-magnifying-glass"></i>
            <input type="search" name="q" value="@Model.SearchQuery" placeholder="Search jobs, customers, properties" />
        </div>
        <button type="submit" class="prv-pro-filter-btn" title="Search"><i class="fas fa-sliders"></i></button>
    </form>

    <section class="prv-pro-jobs-stats">
        @foreach (var (tabId, icon, tone, count, label) in statCards)
        {
            <a asp-controller="Proveedor" asp-action="Jobs" asp-route-tab="@tabId"
               class="prv-pro-jobs-stat @(Model.ActiveTab == tabId ? "is-highlighted" : "")">
                <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--@tone"><i class="fas @icon"></i></span>
                <strong>@count</strong>
                <span>@label</span>
            </a>
        }
    </section>

    <nav class="prv-pro-jobs-tabs" aria-label="Jobs views">
        @foreach (var (id, label) in tabs)
        {
            <a asp-controller="Proveedor" asp-action="Jobs"
               asp-route-tab="@id"
               asp-route-q="@Model.SearchQuery"
               class="@(Model.ActiveTab == id ? "is-active" : "")">@label</a>
        }
    </nav>

    <div class="prv-pro-jobs-list-head">
        <h2>@listTitle</h2>
        @if (Model.ActiveTab == "today")
        {
            <a asp-controller="Proveedor" asp-action="DaySchedule"
               asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")"
               asp-route-from="jobs"
               class="prv-pro-jobs-list-schedule-link">View schedule <i class="fas fa-chevron-right"></i></a>
        }
    </div>
    <div class="prv-pro-jobs-info">
        <i class="fas fa-circle-info"></i>
        <p>@infoText</p>
    </div>

    <section class="prv-pro-jobs-list">
        @if (Model.Items.Count == 0)
        {
            <div class="prv-pro-jobs-empty">
                <p class="prv-pro-empty">No items in this view yet. Jobs, leads, and estimates from your account will appear here.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="prv-pro-job-card">
                    <button type="button" class="prv-pro-job-card-menu" aria-label="More options"><i class="fas fa-ellipsis-vertical"></i></button>

                    <div class="prv-pro-job-card-main">
                        <span class="prv-pro-job-card-icon prv-pro-job-card-icon--@item.IconTone">
                            <i class="fas @item.IconClass"></i>
                        </span>
                        <div class="prv-pro-job-card-body">
                            <div class="prv-pro-job-card-title-row">
                                <strong>@item.Title</strong>
                                <span class="prv-pro-pill prv-pro-pill--@item.StatusClass">@item.StatusLabel</span>
                                @if (!string.IsNullOrWhiteSpace(item.SecondaryBadge))
                                {
                                    <span class="prv-pro-pill prv-pro-pill--@item.SecondaryBadgeClass">@item.SecondaryBadge</span>
                                }
                            </div>
                            <small class="prv-pro-job-card-address">@item.Address</small>
                            @if (!string.IsNullOrWhiteSpace(item.CustomerName))
                            {
                                <small class="prv-pro-job-card-customer">@item.CustomerName</small>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.TimeLabel))
                            {
                                <small class="prv-pro-job-card-time">@item.TimeLabel</small>
                            }
                        </div>
                    </div>

                    <div class="prv-pro-job-quick-links">
                        @if (item.ShowEstimateLink)
                        {
                            @if (item.ItemKind == "Estimate" && item.ItemId.HasValue)
                            {
                                <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@item.ItemId" class="prv-pro-job-quick-link prv-pro-job-quick-link--blue">
                                    <i class="fas fa-file-invoice"></i><span>Estimate</span>
                                </a>
                            }
                            else if (item.ItemKind == "Lead" && item.ItemId.HasValue)
                            {
                                <a asp-controller="Proveedor" asp-action="QuickEstimate" asp-route-id="@item.ItemId" class="prv-pro-job-quick-link prv-pro-job-quick-link--blue">
                                    <i class="fas fa-file-invoice"></i><span>Estimate</span>
                                </a>
                            }
                            else if (item.ItemKind == "Job" && item.ClienteId.HasValue)
                            {
                                <a asp-controller="Proveedor" asp-action="CreateEstimate" asp-route-clienteId="@item.ClienteId" class="prv-pro-job-quick-link prv-pro-job-quick-link--blue">
                                    <i class="fas fa-file-invoice"></i><span>Estimate</span>
                                </a>
                            }
                        }
                        @if (item.ShowPhotosLink && item.ItemKind == "Job" && item.ItemId.HasValue)
                        {
                            <a asp-controller="Proveedor" asp-action="UploadReport" asp-route-filter="inprogress" class="prv-pro-job-quick-link prv-pro-job-quick-link--green">
                                <i class="fas fa-camera"></i><span>Photos</span>
                            </a>
                        }
                        @if (item.ShowChecklistLink && item.ItemKind == "Job" && item.ItemId.HasValue)
                        {
                            <a asp-controller="Proveedor" asp-action="ActiveJob" asp-route-id="@item.ItemId" class="prv-pro-job-quick-link prv-pro-job-quick-link--purple">
                                <i class="fas fa-list-check"></i><span>Checklist</span>
                            </a>
                        }
                        @if (item.ShowHouseFactsLink)
                        {
                            <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="housefacts" class="prv-pro-job-quick-link prv-pro-job-quick-link--orange">
                                <i class="fas fa-house"></i><span>House Facts</span>
                            </a>
                        }
                    </div>

                    <div class="prv-pro-job-card-actions">
                        @if (item.ItemKind == "Lead" && item.ItemId.HasValue)
                        {
                            <form asp-controller="Proveedor" asp-action="AcceptLead" method="post" class="prv-pro-job-action-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ItemId" />
                                <button type="submit" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@item.PrimaryAction</button>
                            </form>
                            <a asp-controller="Proveedor" asp-action="QuickEstimate" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--ghost">@item.SecondaryAction</a>
                        }
                        else if (item.ItemKind == "Estimate" && item.ItemId.HasValue)
                        {
                            <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@item.PrimaryAction</a>
                            @if (item.CanConvertToJob)
                            {
                                <form asp-controller="Proveedor" asp-action="ConvertEstimateToJob" method="post" class="prv-pro-job-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ItemId" />
                                    <button type="submit" class="prv-pro-btn prv-pro-btn--ghost">@item.SecondaryAction</button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Proveedor" asp-action="EstimateSent" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--ghost">@item.SecondaryAction</a>
                            }
                        }
                        else if (item.ItemKind == "Job" && item.ItemId.HasValue)
                        {
                            @if (item.StatusClass == "progress")
                            {
                                <a asp-controller="Proveedor" asp-action="ActiveJob" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@item.PrimaryAction</a>
                            }
                            else if (item.StatusClass == "completed")
                            {
                                <a asp-controller="Proveedor" asp-action="JobReport" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@item.PrimaryAction</a>
                            }
                            else
                            {
                                <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@item.PrimaryAction</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.SecondaryAction))
                            {
                                @if (item.SecondaryAction == "Upload Photos")
                                {
                                    <a asp-controller="Proveedor" asp-action="UploadReport" class="prv-pro-btn prv-pro-btn--ghost">@item.SecondaryAction</a>
                                }
                                else
                                {
                                    <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--ghost">@item.SecondaryAction</a>
                                }
                            }
                        }
                    </div>
                </article>
            }
        }
    </section>

    @if (Model.SmartSuggestions.Count > 0 && Model.ActiveTab is not "active" and not "today")
    {
        <section class="prv-pro-smart-suggestions">
            <div class="prv-pro-panel-head">
                <h2><i class="fas fa-wand-magic-sparkles"></i> Smart Suggestions</h2>
            </div>
            <div class="prv-pro-smart-scroll">
                @foreach (var tip in Model.SmartSuggestions)
                {
                    @if (!string.IsNullOrWhiteSpace(tip.Url))
                    {
                        <a href="@tip.Url" class="prv-pro-smart-card prv-pro-smart-card--@tip.Tone prv-pro-smart-card--link">
                            <i class="fas @tip.IconClass"></i>
                            <span>@tip.Text</span>
                        </a>
                    }
                    else
                    {
                        <article class="prv-pro-smart-card prv-pro-smart-card--@tip.Tone">
                            <i class="fas @tip.IconClass"></i>
                            <span>@tip.Text</span>
                        </article>
                    }
                }
            </div>
        </section>
    }

</div>
