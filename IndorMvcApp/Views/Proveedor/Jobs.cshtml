@model IndorMvcApp.ViewModels.ProviderProJobsPageViewModel
@using System.Globalization
@{
    ViewData["Title"] = L["Jobs - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "jobs";
    ViewBag.CompanyInitial = Model.CompanyName.Trim().Length > 0
        ? Model.CompanyName.Trim()[0].ToString().ToUpperInvariant()
        : "P";
    var tabs = new[] {
        ("all", "All"),
        ("today", "Today"),
        ("leads", "Leads"),
        ("active", "Active"),
        ("estimates", "Estimates"),
        ("completed", "Completed")
    };
    var statCards = new[] {
        ("today", "fa-calendar-days", "blue", Model.TodayCount, "Today"),
        ("leads", "fa-user-plus", "green", Model.NewLeadsCount, "Leads"),
        ("active", "fa-circle-notch", "blue", Model.ActiveCount, "Active"),
        ("estimates", "fa-file-invoice-dollar", "purple", Model.EstimatesCount, "Estimates"),
        ("completed", "fa-circle-check", "green", Model.CompletedCount, "Completed")
    };
    var visibleStatCards = Model.ActiveTab == "all"
        ? statCards
        : statCards.Where(card => card.Item1 == Model.ActiveTab);
    string listTitle = Model.ActiveTab switch
    {
        "all" => $"{Model.AllCount} Item{(Model.AllCount == 1 ? "" : "s")}",
        "today" => $"{Model.TodayCount} Job{(Model.TodayCount == 1 ? "" : "s")} Today",
        "leads" => $"{Model.NewLeadsCount} New Lead{(Model.NewLeadsCount == 1 ? "" : "s")}",
        "estimates" => $"{Model.EstimatesCount} Estimate{(Model.EstimatesCount == 1 ? "" : "s")}",
        "completed" => $"{Model.CompletedCount} Completed Job{(Model.CompletedCount == 1 ? "" : "s")}",
        _ => $"{Model.ActiveCount} Active Job{(Model.ActiveCount == 1 ? "" : "s")}"
    };
    string infoText = Model.ActiveTab switch
    {
        "all" => "Your full pipeline in one place — leads, active jobs, estimates, and completed work.",
        "today" => "Your schedule for today. Tap a job to view details, add notes, or update status.",
        "leads" => "New leads waiting for your response. Accept or create an estimate to get started.",
        "estimates" => "Review drafts and sent estimates. Tap to edit, send, or convert to a job.",
        "completed" => "Completed jobs and reports. Tap to view details or upload documentation.",
        _ => "Below are your active jobs. Tap a job to view details, add notes, or update status."
    };
}

<div class="prv-pro-shell prv-pro-shell--jobs prv-pro-shell--jobs-v2">
    <div class="prv-pro-portal-page-hero">
        <div class="prv-pro-jobs-hero-top">
            <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-brand prv-pro-brand--link prv-pro-brand--hero" aria-label="@L["INDOR PRO home"]">
                <i class="fas fa-house" aria-hidden="true"></i>
                <span class="prv-pro-brand-indor">@L["INDOR"]</span>
                <span class="prv-pro-brand-pro">@L["PRO"]</span>
            </a>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>
        <div class="prv-pro-jobs-hero-header">
            <div class="prv-pro-jobs-hero-title-row">
                <h1>@L["Jobs"]</h1>
                <a asp-controller="Proveedor" asp-action="CreateJob" asp-route-from="jobs" class="prv-pro-jobs-create-btn" aria-label="@L["Create job"]">
                    <i class="fas fa-plus" aria-hidden="true"></i> @L["Create Job"]
                </a>
            </div>
            <p>@L["Your operational hub for leads, jobs, estimates, reports, and payments."]</p>
        </div>

        <form method="get" asp-controller="Proveedor" asp-action="Jobs" class="prv-pro-jobs-hero-search">
            <div class="prv-pro-jobs-search-row">
                <div class="prv-pro-search-wrap">
                    <i class="fas fa-magnifying-glass"></i>
                    <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search jobs, customers, properties"]" />
                </div>
                <div class="prv-pro-filter-wrap">
                    <button type="button" class="prv-pro-filter-btn prv-pro-filter-btn--labeled" id="prvJobsFilterBtn" aria-haspopup="true" aria-expanded="false">
                        <i class="fas fa-sliders"></i> @L["Filter"]
                    </button>
                    <div class="prv-pro-filter-menu" id="prvJobsFilterMenu" role="menu" hidden>
                        @foreach (var (id, label) in tabs)
                        {
                            <a asp-controller="Proveedor" asp-action="Jobs"
                               asp-route-tab="@id"
                               asp-route-q="@Model.SearchQuery"
                               class="prv-pro-filter-menu-item @(Model.ActiveTab == id ? "is-active" : null)"
                               role="menuitem">
                                <span>@UiDisplayLocalization.Localize(L, label)</span>
                                @if (Model.ActiveTab == id)
                                {
                                    <i class="fas fa-check"></i>
                                }
                            </a>
                        }
                    </div>
                </div>
            </div>
            <div class="prv-pro-jobs-filter-chips">
                @foreach (var (id, label) in tabs)
                {
                    <a asp-controller="Proveedor" asp-action="Jobs"
                       asp-route-tab="@id"
                       asp-route-q="@Model.SearchQuery"
                       class="prv-pro-jobs-filter-chip @(Model.ActiveTab == id ? "is-active" : null)">@UiDisplayLocalization.Localize(L, label)</a>
                }
                <a asp-controller="Proveedor" asp-action="Network" class="prv-pro-jobs-filter-chip">@L["Network"]</a>
                <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-pro-jobs-filter-chip prv-pro-jobs-filter-chip--outline">@L["Subcontractors"]</a>
            </div>
        </form>
    </div>

    <section class="prv-pro-jobs-stats prv-pro-jobs-stats--overview">
        @foreach (var (tabId, icon, tone, count, label) in visibleStatCards)
        {
            <a asp-controller="Proveedor" asp-action="Jobs" asp-route-tab="@tabId" asp-route-q="@Model.SearchQuery"
               class="prv-pro-jobs-stat">
                <span class="prv-pro-jobs-stat-icon prv-pro-jobs-stat-icon--@tone"><i class="fas @icon"></i></span>
                <strong>@count</strong>
                <span>@UiDisplayLocalization.Localize(L, label)</span>
            </a>
        }
    </section>

    <div class="prv-pro-jobs-list-head">
        <h2>@UiDisplayLocalization.Localize(L, listTitle)</h2>
        @if (Model.ActiveTab == "today")
        {
            <a asp-controller="Proveedor" asp-action="DaySchedule"
               asp-route-date="@DateTime.Today.ToString("yyyy-MM-dd")"
               asp-route-from="jobs"
               class="prv-pro-jobs-list-schedule-link">@L["Today's schedule"]<i class="fas fa-chevron-right"></i></a>
        }
    </div>
    <div class="prv-pro-jobs-info">
        <i class="fas fa-circle-info"></i>
        <p>@UiDisplayLocalization.Localize(L, infoText)</p>
    </div>

    <section class="prv-pro-jobs-list">
        @if (Model.Items.Count == 0)
        {
            <div class="prv-pro-jobs-empty">
                <p class="prv-pro-empty">@L["No items in this view yet. Jobs, leads, and estimates from your account will appear here."]</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="prv-pro-job-card">
                    <button type="button" class="prv-pro-job-card-menu" aria-label="@L["More options"]"><i class="fas fa-ellipsis-vertical"></i></button>

                    <div class="prv-pro-job-card-main">
                        <span class="prv-pro-job-card-icon prv-pro-job-card-icon--@item.IconTone">
                            <i class="fas @item.IconClass"></i>
                        </span>
                        <div class="prv-pro-job-card-body">
                            <div class="prv-pro-job-card-title-row">
                                <strong>@item.Title</strong>
                                <span class="prv-pro-pill prv-pro-pill--@item.StatusClass">@UiDisplayLocalization.Localize(L, item.StatusLabel)</span>
                                @if (!string.IsNullOrWhiteSpace(item.SecondaryBadge))
                                {
                                    <span class="prv-pro-pill prv-pro-pill--@item.SecondaryBadgeClass">@UiDisplayLocalization.Localize(L, item.SecondaryBadge)</span>
                                }
                            </div>
                            <small class="prv-pro-job-card-address">@item.Address</small>
                            @if (!string.IsNullOrWhiteSpace(item.CustomerName))
                            {
                                <small class="prv-pro-job-card-customer">@item.CustomerName</small>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.TimeLabel))
                            {
                                <small class="prv-pro-job-card-time">@UiDisplayLocalization.Localize(L, item.TimeLabel)</small>
                            }
                        </div>
                    </div>

                    <div class="prv-pro-job-quick-links">
                        @if (item.ShowEstimateLink)
                        {
                            @if (item.ItemKind == "Estimate" && item.ItemId.HasValue)
                            {
                                <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@item.ItemId" class="prv-pro-job-quick-link prv-pro-job-quick-link--blue">
                                    <i class="fas fa-file-invoice"></i><span>@L["Estimate"]</span>
                                </a>
                            }
                            else if (item.ItemKind == "Lead" && item.ItemId.HasValue)
                            {
                                <a asp-controller="Proveedor" asp-action="QuickEstimate" asp-route-id="@item.ItemId" class="prv-pro-job-quick-link prv-pro-job-quick-link--blue">
                                    <i class="fas fa-file-invoice"></i><span>@L["Estimate"]</span>
                                </a>
                            }
                            else if (item.ItemKind == "Job" && item.ClienteId.HasValue)
                            {
                                <a asp-controller="Proveedor" asp-action="CreateEstimate" asp-route-clienteId="@item.ClienteId" class="prv-pro-job-quick-link prv-pro-job-quick-link--blue">
                                    <i class="fas fa-file-invoice"></i><span>@L["Estimate"]</span>
                                </a>
                            }
                        }
                        @if (item.ShowPhotosLink && item.ItemKind == "Job" && item.ItemId.HasValue)
                        {
                            <a asp-controller="Proveedor" asp-action="UploadReport" asp-route-filter="inprogress" class="prv-pro-job-quick-link prv-pro-job-quick-link--green">
                                <i class="fas fa-camera"></i><span>@L["Photos"]</span>
                            </a>
                        }
                        @if (item.ShowChecklistLink && item.ItemKind == "Job" && item.ItemId.HasValue)
                        {
                            <a asp-controller="Proveedor" asp-action="ActiveJob" asp-route-id="@item.ItemId" class="prv-pro-job-quick-link prv-pro-job-quick-link--purple">
                                <i class="fas fa-list-check"></i><span>@L["Checklist"]</span>
                            </a>
                        }
                        @if (item.ShowHouseFactsLink)
                        {
                            <a asp-controller="Proveedor" asp-action="Reports" asp-route-tab="housefacts" class="prv-pro-job-quick-link prv-pro-job-quick-link--orange">
                                <i class="fas fa-house"></i><span>@L["House Facts"]</span>
                            </a>
                        }
                    </div>

                    <div class="prv-pro-job-card-actions">
                        @if (item.ItemKind == "Lead" && item.ItemId.HasValue)
                        {
                            <form asp-controller="Proveedor" asp-action="AcceptLead" method="post" class="prv-pro-job-action-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.ItemId" />
                                    <button type="submit" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@UiDisplayLocalization.Localize(L, item.PrimaryAction)</button>
                                </form>
                                <a asp-controller="Proveedor" asp-action="QuickEstimate" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--ghost">@UiDisplayLocalization.Localize(L, item.SecondaryAction)</a>
                        }
                        else if (item.ItemKind == "Estimate" && item.ItemId.HasValue)
                        {
                            <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@UiDisplayLocalization.Localize(L, item.PrimaryAction)</a>
                            @if (item.CanConvertToJob)
                            {
                                <form asp-controller="Proveedor" asp-action="ConvertEstimateToJob" method="post" class="prv-pro-job-action-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ItemId" />
                                    <button type="submit" class="prv-pro-btn prv-pro-btn--ghost">@UiDisplayLocalization.Localize(L, item.SecondaryAction)</button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Proveedor" asp-action="EstimateSent" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--ghost">@UiDisplayLocalization.Localize(L, item.SecondaryAction)</a>
                            }
                        }
                        else if (item.ItemKind == "Job" && item.ItemId.HasValue)
                        {
                            @if (item.StatusClass == "progress")
                            {
                                <a asp-controller="Proveedor" asp-action="ActiveJob" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@UiDisplayLocalization.Localize(L, item.PrimaryAction)</a>
                            }
                            else if (item.StatusClass == "completed")
                            {
                                <a asp-controller="Proveedor" asp-action="JobReport" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@UiDisplayLocalization.Localize(L, item.PrimaryAction)</a>
                            }
                            else
                            {
                                <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--@item.PrimaryActionClass">@UiDisplayLocalization.Localize(L, item.PrimaryAction)</a>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.SecondaryAction))
                            {
                                @if (item.SecondaryAction == ProviderProDisplayLocalization.L("Upload Photos"))
                                {
                                    <a asp-controller="Proveedor" asp-action="UploadReport" class="prv-pro-btn prv-pro-btn--ghost">@UiDisplayLocalization.Localize(L, item.SecondaryAction)</a>
                                }
                                else
                                {
                                    <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@item.ItemId" class="prv-pro-btn prv-pro-btn--ghost">@UiDisplayLocalization.Localize(L, item.SecondaryAction)</a>
                                }
                            }
                        }
                    </div>
                </article>
            }
        }
    </section>

    @if (Model.SmartSuggestions.Count > 0 && Model.ActiveTab is not "active" and not "today")
    {
        <section class="prv-pro-smart-suggestions">
            <div class="prv-pro-panel-head">
                <h2><i class="fas fa-wand-magic-sparkles"></i> @L["Smart Suggestions"]</h2>
            </div>
            <div class="prv-pro-smart-scroll">
                @foreach (var tip in Model.SmartSuggestions)
                {
                    @if (!string.IsNullOrWhiteSpace(tip.Url))
                    {
                        <a href="@tip.Url" class="prv-pro-smart-card prv-pro-smart-card--@tip.Tone prv-pro-smart-card--link">
                            <i class="fas @tip.IconClass"></i>
                            <span>@UiDisplayLocalization.Localize(L, tip.Text)</span>
                        </a>
                    }
                    else
                    {
                        <article class="prv-pro-smart-card prv-pro-smart-card--@tip.Tone">
                            <i class="fas @tip.IconClass"></i>
                            <span>@UiDisplayLocalization.Localize(L, tip.Text)</span>
                        </article>
                    }
                }
            </div>
        </section>
    }

</div>

@section Scripts {
<script>
    (function () {
        var filterBtn = document.getElementById('prvJobsFilterBtn');
        var filterMenu = document.getElementById('prvJobsFilterMenu');
        if (!filterBtn || !filterMenu) {
            return;
        }

        function closeMenu() {
            filterMenu.hidden = true;
            filterBtn.setAttribute('aria-expanded', 'false');
        }

        filterBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = filterMenu.hidden;
            filterMenu.hidden = !willOpen;
            filterBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });

        document.addEventListener('click', closeMenu);
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeMenu();
            }
        });
    })();
</script>
}
