@model IndorMvcApp.ViewModels.ProviderProEstimateSentViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Estimate Sent - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
    var statusClass = Model.IsApproved ? "approved" : "waiting";
}

<div class="prv-pro-shell prv-pro-shell--estimate-sent">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <section class="prv-pro-estimate-sent-hero">
        <div class="prv-pro-estimate-sent-icon"><i class="fas fa-circle-check"></i></div>
        <h1>Estimate Sent!</h1>
        <p>Your estimate has been sent@(Model.IsApproved ? " and approved" : " and is awaiting approval").</p>
    </section>

    <section class="prv-pro-lead-section prv-pro-status-card">
        <div class="prv-pro-estimate-summary">
            <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Property" />
            <div>
                <strong>@Model.Address</strong>
                <small>@Model.ServiceType</small>
                <strong class="prv-pro-estimate-sent-amount">@Model.TotalAmount.ToString("C0", money)</strong>
                <span class="prv-pro-pill prv-pro-pill--@statusClass">
                    <i class="fas @(Model.IsApproved ? "fa-circle-check" : "fa-hourglass-half")"></i> @Model.StatusLabel
                </span>
            </div>
        </div>
    </section>

    @if (!Model.IsApproved)
    {
        <section class="prv-pro-lead-section">
            <h3>What's next?</h3>
            <p class="prv-pro-lead-hint">The customer will review your estimate. You'll be notified when it's approved.</p>
            <div class="prv-pro-estimate-sent-actions">
                <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-btn prv-pro-btn--ghost">
                    <i class="fas fa-pen-to-square"></i> View Estimate
                </a>
                <a asp-controller="Proveedor" asp-action="NewLeads" class="prv-pro-btn prv-pro-btn--ghost">
                    <i class="fas fa-chevron-left"></i> Back to Leads
                </a>
            </div>
        </section>
    }
    else
    {
        <section class="prv-pro-lead-section">
            <h3>Approved — next steps</h3>
            <div class="prv-pro-estimate-sent-actions">
                <a asp-controller="Proveedor" asp-action="EstimateAccepted" asp-route-id="@Model.EstimateId" class="prv-pro-btn prv-pro-btn--teal">
                    <i class="fas fa-circle-check"></i> View Approval Details
                </a>
                <a asp-controller="Proveedor" asp-action="CreateInvoice" asp-route-estimateId="@Model.EstimateId" class="prv-pro-btn prv-pro-btn--primary">
                    <i class="fas fa-file-invoice-dollar"></i> Create Invoice
                </a>
            </div>
        </section>

        @if (Model.CanConvertToJob)
        {
            <section class="prv-pro-estimate-convert">
                <form asp-controller="Proveedor" asp-action="ConvertEstimateToJob" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.EstimateId" />
                    <button type="submit" class="prv-pro-btn prv-pro-btn--teal prv-pro-btn--full">
                        <i class="fas fa-calendar-check"></i> Schedule Work
                    </button>
                </form>
            </section>
        }
        else if (Model.ConvertedJobId.HasValue)
        {
            <section class="prv-pro-estimate-convert">
                <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.ConvertedJobId" class="prv-pro-btn prv-pro-btn--teal prv-pro-btn--full">
                    <i class="fas fa-briefcase"></i> View Job
                </a>
            </section>
        }
    }

    <section class="prv-pro-lead-section">
        <h3>Estimate Tracking</h3>
        <div class="prv-pro-estimate-tracking">
            @foreach (var step in Model.TrackingSteps)
            {
                <div class="prv-pro-estimate-tracking-step prv-pro-estimate-tracking-step--@step.StateClass">
                    <span class="prv-pro-estimate-tracking-icon"><i class="fas @step.IconClass"></i></span>
                    <div>
                        <strong>@step.Label</strong>
                        @if (!string.IsNullOrWhiteSpace(step.Detail))
                        {
                            <small>@step.Detail</small>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <a asp-controller="Proveedor" asp-action="NewLeads" class="prv-pro-estimate-sent-back">
        <i class="fas fa-chevron-left"></i> Back to Leads
    </a>
</div>
