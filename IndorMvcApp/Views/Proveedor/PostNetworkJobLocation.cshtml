@model IndorMvcApp.ViewModels.PostJobLocationViewModel
@{
    ViewData["Title"] = L["Post a Job"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-network.css";
    ViewBag.NavActive = "jobs";
    var propertyTypes = new[] { ("House", "fa-house"), ("Townhome", "fa-house-chimney"), ("Condo", "fa-building"), ("Commercial", "fa-shop") };
    var whoOptions = new[] { ("Homeowner", "fa-user"), ("Tenant", "fa-user-tag"), ("PropertyManager", "fa-briefcase") };
    var lat = Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
    var lng = Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
}

<div class="prv-net-shell">
    <header class="prv-net-hero prv-net-hero--wizard">
        <div class="prv-net-hero-top">
            <a asp-controller="Proveedor" asp-action="PostNetworkJob" asp-route-id="@Model.DraftId" class="prv-net-back"><i class="fas fa-chevron-left"></i></a>
            <button type="submit" name="Mode" value="draft" form="locForm" class="prv-net-draft-btn"><i class="fas fa-file-lines"></i> @L["Save Draft"]</button>
        </div>
        <div class="prv-net-hero-title">
            <div>
                <h1>@L["Post a Job"]</h1>
                <p>@L["Add location and budget."]</p>
            </div>
        </div>
    </header>

    <div class="prv-net-stepper">
        <div class="prv-net-step is-done"><span class="prv-net-step-num"><i class="fas fa-check"></i></span><span class="prv-net-step-label">@L["Details"]</span></div>
        <span class="prv-net-step-line is-done"></span>
        <div class="prv-net-step is-active"><span class="prv-net-step-num">2</span><span class="prv-net-step-label">@L["Location &amp; Budget"]</span></div>
        <span class="prv-net-step-line"></span>
        <div class="prv-net-step"><span class="prv-net-step-num">3</span><span class="prv-net-step-label">@L["Review"]</span></div>
    </div>

    <form method="post" id="locForm" asp-controller="Proveedor" asp-action="PostNetworkJobLocation" class="prv-net-wizard-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="DraftId" value="@Model.DraftId" />
        <input type="hidden" name="Latitude" id="Latitude" value="@lat" />
        <input type="hidden" name="Longitude" id="Longitude" value="@lng" />

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">@L["Job Location"]</h3>
            <div class="prv-net-input-wrap">
                <i class="fas fa-location-dot prv-net-input-ic"></i>
                <input type="text" id="Location" name="Location" value="@Model.Location" maxlength="200"
                       placeholder="@L["Enter address or neighborhood"]" class="prv-net-input prv-net-input--ic" />
                <button type="button" class="prv-net-input-clear" id="locClear" aria-label="@L["Clear"]"><i class="fas fa-xmark"></i></button>
            </div>
            <div class="prv-net-map prv-net-map--sm">
                <div id="prvJobMap" class="prv-net-map-canvas"></div>
            </div>
        </div>

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">@L["Property Type"]</h3>
            <div class="prv-net-optionchips prv-net-optionchips--wrap">
                @foreach (var (id, icon) in propertyTypes)
                {
                    <label class="prv-net-optionchip">
                        <input type="radio" name="PropertyType" value="@id" checked="@(Model.PropertyType == id)" />
                        <span><i class="fas @icon"></i> @L[id]</span>
                    </label>
                }
            </div>

            <h3 class="prv-net-card-title" style="margin-top:16px;">@L["Who will meet the pro?"]</h3>
            <div class="prv-net-optionchips prv-net-optionchips--wrap">
                @foreach (var (id, icon) in whoOptions)
                {
                    <label class="prv-net-optionchip">
                        <input type="radio" name="WhoMeets" value="@id" checked="@(Model.WhoMeets == id)" />
                        <span><i class="fas @icon"></i> @(id == "PropertyManager" ? L["Property Manager"].ToString() : L[id].ToString())</span>
                    </label>
                }
            </div>
        </div>

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">@L["Budget"]</h3>
            <div class="prv-net-optionchips prv-net-optionchips--wrap">
                @foreach (var budget in Model.BudgetOptions)
                {
                    <label class="prv-net-optionchip">
                        <input type="radio" name="BudgetRange" value="@budget" checked="@(Model.BudgetRange == budget)" />
                        <span>@UiDisplayLocalization.Localize(L, budget)</span>
                    </label>
                }
            </div>

            <h3 class="prv-net-card-title" style="margin-top:16px;">@L["Quote Type"]</h3>
            <div class="prv-net-radio-cards">
                <label class="prv-net-radio-card">
                    <input type="radio" name="QuoteType" value="Fixed" checked="@(Model.QuoteType != "Hourly")" />
                    <span class="prv-net-radio-card-body">
                        <span class="prv-net-radio-card-ic prv-net-tool-ic--blue"><i class="fas fa-tag"></i></span>
                        <strong>@L["Fixed Price"]</strong>
                        <small>@L["Get a set price for the entire job."]</small>
                        <i class="fas fa-circle-check prv-net-radio-tick"></i>
                    </span>
                </label>
                <label class="prv-net-radio-card">
                    <input type="radio" name="QuoteType" value="Hourly" checked="@(Model.QuoteType == "Hourly")" />
                    <span class="prv-net-radio-card-body">
                        <span class="prv-net-radio-card-ic prv-net-radio-card-ic--muted"><i class="fas fa-clock"></i></span>
                        <strong>@L["Hourly Estimate"]</strong>
                        <small>@L["Pay for time and materials as the job goes."]</small>
                        <i class="fas fa-circle-check prv-net-radio-tick"></i>
                    </span>
                </label>
            </div>
        </div>

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">@L["Access Notes"]<span class="prv-net-optional">@L["(Optional)"]</span></h3>
            <textarea id="AccessNotes" name="AccessNotes" maxlength="200" class="prv-net-textarea"
                      placeholder="@L["Add any details about access, gate codes, parking, etc."]">@Model.AccessNotes</textarea>
            <div class="prv-net-field-hint"><span id="notesCount">0</span>/200</div>
        </div>

        <button type="submit" name="Mode" value="continue" class="prv-net-btn prv-net-btn--primary prv-net-btn--wizard">@L["Continue"]</button>
    </form>
</div>

@section Scripts {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
    (function () {
        var notes = document.getElementById('AccessNotes');
        var nc = document.getElementById('notesCount');
        function sync() { if (nc) { nc.textContent = (notes.value || '').length; } }
        if (notes) { notes.addEventListener('input', sync); sync(); }

        var loc = document.getElementById('Location');
        var clr = document.getElementById('locClear');
        if (clr && loc) { clr.addEventListener('click', function () { loc.value = ''; loc.focus(); }); }

        var el = document.getElementById('prvJobMap');
        if (!el || typeof L === 'undefined') { return; }
        var latEl = document.getElementById('Latitude');
        var lngEl = document.getElementById('Longitude');
        var startLat = parseFloat(latEl.value), startLng = parseFloat(lngEl.value);
        var hasStart = !isNaN(startLat) && !isNaN(startLng);
        var center = hasStart ? [startLat, startLng] : [39.8283, -98.5795];

        var map = L.map(el, { zoomControl: true }).setView(center, hasStart ? 14 : 4);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var marker = L.marker(center, { draggable: true }).addTo(map);
        function setLatLng(ll) { latEl.value = ll.lat.toFixed(6); lngEl.value = ll.lng.toFixed(6); }
        if (hasStart) { setLatLng({ lat: startLat, lng: startLng }); }
        marker.on('dragend', function () { setLatLng(marker.getLatLng()); });
        map.on('click', function (e) { marker.setLatLng(e.latlng); setLatLng(e.latlng); });

        setTimeout(function () {
            map.invalidateSize();
            if (!hasStart && navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(function (pos) {
                    var ll = { lat: pos.coords.latitude, lng: pos.coords.longitude };
                    map.setView([ll.lat, ll.lng], 14);
                    marker.setLatLng([ll.lat, ll.lng]);
                    setLatLng(ll);
                }, function () {}, { enableHighAccuracy: true, timeout: 8000 });
            }
        }, 150);
    })();
</script>
}
