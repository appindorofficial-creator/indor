@model IndorMvcApp.ViewModels.VerificationQueueViewModel
@{
    ViewData["Title"] = L["Verify Contractors"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-verify.css";
    ViewBag.NavActive = "verify";
}

<div class="prv-vf-shell">
    <header class="prv-vf-hero">
        <div class="prv-vf-hero-top">
            <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-vf-brand" aria-label="@L["INDOR PRO home"]">
                <span class="prv-vf-brand-word">@L["INDOR"]</span>
                <span class="prv-vf-brand-pro">@L["PRO"]</span>
            </a>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>

        <div class="prv-vf-hero-title">
            <h1>@L["Verify Contractors"]</h1>
            <p>@L["Review documents, insurance, and verification status."]</p>
        </div>

        <form method="get" asp-controller="Proveedor" asp-action="VerifyContractors" class="prv-vf-searchbar">
            <input type="hidden" name="tab" value="@Model.ActiveTab" />
            <div class="prv-vf-search">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.Query" placeholder="@L["Search contractors or companies"]" />
            </div>
            <button type="submit" class="prv-vf-filter"><i class="fas fa-sliders"></i> @L["Filter"]</button>
        </form>
    </header>

    @if (TempData["VerifyToast"] is string toast && !string.IsNullOrWhiteSpace(toast))
    {
        <div class="prv-vf-toast"><i class="fas fa-circle-check"></i> @toast</div>
    }

    <div class="prv-vf-tabs">
        @foreach (var t in Model.Tabs)
        {
            <a asp-controller="Proveedor" asp-action="VerifyContractors" asp-route-tab="@t.Id" asp-route-q="@Model.Query"
               class="prv-vf-tab @(Model.ActiveTab == t.Id ? "is-active" : "")">
                @t.Label <span class="prv-vf-tab-count">@t.Count</span>
            </a>
        }
    </div>

    @if (Model.Contractors.Count == 0)
    {
        <div class="prv-vf-empty">
            <i class="fas fa-clipboard-check"></i>
            <strong>@L["No contractors here"]</strong>
            <span>@L["There is nothing in this queue right now."]</span>
        </div>
    }
    else
    {
        <div class="prv-vf-list">
            @foreach (var c in Model.Contractors)
            {
                <a asp-controller="Proveedor" asp-action="ContractorVerification" asp-route-id="@c.Id" class="prv-vf-card">
                    <div class="prv-vf-card-top">
                        <span class="prv-vf-ico">
                            @if (!string.IsNullOrWhiteSpace(c.PhotoUrl))
                            {
                                <img src="@c.PhotoUrl" alt="@c.Name" />
                            }
                            else
                            {
                                <i class="fas @c.IconClass"></i>
                            }
                        </span>
                        <div class="prv-vf-card-id">
                            <div class="prv-vf-name">@c.Name</div>
                            @if (!string.IsNullOrWhiteSpace(c.TradeLabel))
                            {
                                <div class="prv-vf-trade"><i class="fas fa-screwdriver-wrench"></i> @c.TradeLabel</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(c.LocationLabel))
                            {
                                <div class="prv-vf-loc"><i class="fas fa-location-dot"></i> @c.LocationLabel</div>
                            }
                        </div>
                        <span class="prv-vf-pill prv-vf-pill--@c.PillKind">
                            <i class="fas @(c.PillKind == "ready" ? "fa-circle-check" : c.PillKind == "warn" ? "fa-triangle-exclamation" : "fa-clock")"></i>
                            @c.PillLabel
                        </span>
                    </div>

                    <div class="prv-vf-check">
                        <span class="prv-vf-shield @(c.ItemsComplete >= c.TotalItems ? "is-done" : "")">
                            <i class="fas fa-shield-halved"></i>
                        </span>
                        <div class="prv-vf-items">
                            @foreach (var it in c.Items)
                            {
                                <div class="prv-vf-item is-@it.State">
                                    <i class="fas @it.IconClass"></i>
                                    <span>@it.Label</span>
                                    <em>@it.StatusLabel</em>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="prv-vf-foot">
                        <div class="prv-vf-progress">
                            <span>@c.ItemsComplete / @c.TotalItems items complete</span>
                            <div class="prv-vf-bar"><i style="width:@(c.ProgressPercent)%"></i></div>
                        </div>
                        <span class="prv-vf-review">@L["Review"]<i class="fas fa-arrow-right"></i></span>
                    </div>
                </a>
            }
        </div>
    }
</div>
