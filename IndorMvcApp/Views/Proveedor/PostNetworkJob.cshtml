@model IndorMvcApp.ViewModels.PostJobDetailsViewModel
@{
    ViewData["Title"] = "Post a Job";
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-network.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-net-shell">
    <header class="prv-net-hero prv-net-hero--wizard">
        <div class="prv-net-hero-top">
            <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-net-brand" aria-label="INDOR PRO">
                <span class="prv-net-brand-word">INDOR</span>
                <span class="prv-net-brand-pro">PRO</span>
            </a>
            <a asp-controller="Proveedor" asp-action="Network" class="prv-net-close" aria-label="Close"><i class="fas fa-xmark"></i></a>
        </div>
        <div class="prv-net-hero-title">
            <div>
                <h1>Post a Job</h1>
                <p>Tell us what you need and get matched fast.</p>
            </div>
        </div>
    </header>

    <div class="prv-net-stepper">
        <div class="prv-net-step is-active"><span class="prv-net-step-num">1</span><span class="prv-net-step-label">Details</span></div>
        <span class="prv-net-step-line"></span>
        <div class="prv-net-step"><span class="prv-net-step-num">2</span><span class="prv-net-step-label">Location &amp; Budget</span></div>
        <span class="prv-net-step-line"></span>
        <div class="prv-net-step"><span class="prv-net-step-num">3</span><span class="prv-net-step-label">Review</span></div>
    </div>

    <form method="post" asp-controller="Proveedor" asp-action="PostNetworkJobDetails" enctype="multipart/form-data" class="prv-net-wizard-form">
        @Html.AntiForgeryToken()
        @if (Model.DraftId.HasValue)
        {
            <input type="hidden" name="DraftId" value="@Model.DraftId" />
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="prv-net-form-error"><i class="fas fa-circle-exclamation"></i> @Model.ErrorMessage</div>
        }

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">What do you need help with?</h3>
            <div class="prv-net-optionchips">
                @foreach (var trade in Model.TradeOptions)
                {
                    <label class="prv-net-optionchip">
                        <input type="radio" name="TradeId" value="@trade.Id" checked="@(Model.SelectedTradeId == trade.Id)" />
                        <span><i class="fas @trade.IconClass"></i> @trade.Label</span>
                    </label>
                }
            </div>

            <label class="prv-net-flabel" for="JobTitle">Job title</label>
            <div class="prv-net-input-wrap">
                <input type="text" id="JobTitle" name="JobTitle" value="@Model.JobTitle" maxlength="160"
                       placeholder="e.g. Fix leak under kitchen sink" class="prv-net-input" />
                <i class="fas fa-circle-check prv-net-input-ok" id="titleOk"></i>
            </div>

            <label class="prv-net-flabel" for="Description">Describe the job</label>
            <textarea id="Description" name="Description" maxlength="500" class="prv-net-textarea"
                      placeholder="Tell us more about the issue, what needs to be done, and any important details.">@Model.Description</textarea>
            <div class="prv-net-field-hint"><span id="descCount">0</span>/500</div>
        </div>

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">Add photos <span class="prv-net-optional">(optional)</span></h3>
            <p class="prv-net-card-sub">Photos help pros understand the job</p>
            <div class="prv-net-photos" id="photoGrid">
                @foreach (var photo in Model.Photos)
                {
                    <div class="prv-net-photo" data-existing="@photo">
                        <img src="@photo" alt="Job photo" />
                        <button type="button" class="prv-net-photo-x" aria-label="Remove"><i class="fas fa-xmark"></i></button>
                        <input type="hidden" name="ExistingPhotos" value="@photo" />
                    </div>
                }
                <label class="prv-net-photo-add" id="photoAdd">
                    <i class="fas fa-camera"></i>
                    <span>Add Photo</span>
                    <input type="file" name="Photos" accept="image/png,image/jpeg,image/webp" multiple hidden />
                </label>
            </div>
        </div>

        <div class="prv-net-card">
            <h3 class="prv-net-card-title">When do you need it?</h3>
            <div class="prv-net-optionchips prv-net-optionchips--3">
                <label class="prv-net-optionchip">
                    <input type="radio" name="Urgency" value="ASAP" checked="@(Model.Urgency == "ASAP")" />
                    <span><i class="fas fa-clock"></i> ASAP</span>
                </label>
                <label class="prv-net-optionchip">
                    <input type="radio" name="Urgency" value="ThisWeek" checked="@(Model.Urgency == "ThisWeek")" />
                    <span><i class="fas fa-calendar-day"></i> This Week</span>
                </label>
                <label class="prv-net-optionchip">
                    <input type="radio" name="Urgency" value="Flexible" checked="@(Model.Urgency == "Flexible")" />
                    <span><i class="fas fa-clock-rotate-left"></i> Flexible</span>
                </label>
            </div>
        </div>

        <button type="submit" class="prv-net-btn prv-net-btn--primary prv-net-btn--wizard">Continue</button>
    </form>
</div>

@section Scripts {
<script>
    (function () {
        var desc = document.getElementById('Description');
        var count = document.getElementById('descCount');
        function syncCount() { if (count) { count.textContent = (desc.value || '').length; } }
        if (desc) { desc.addEventListener('input', syncCount); syncCount(); }

        var title = document.getElementById('JobTitle');
        var ok = document.getElementById('titleOk');
        function syncTitle() { if (ok) { ok.style.display = (title.value || '').trim().length > 2 ? 'inline' : 'none'; } }
        if (title) { title.addEventListener('input', syncTitle); syncTitle(); }

        var grid = document.getElementById('photoGrid');
        var add = document.getElementById('photoAdd');
        var input = add ? add.querySelector('input[type=file]') : null;
        if (input) {
            input.addEventListener('change', function () {
                Array.prototype.forEach.call(input.files, function (file) {
                    if (!file.type.startsWith('image/')) { return; }
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        var div = document.createElement('div');
                        div.className = 'prv-net-photo';
                        div.innerHTML = '<img src="' + e.target.result + '" alt="New photo" />';
                        grid.insertBefore(div, add);
                    };
                    reader.readAsDataURL(file);
                });
            });
        }
        if (grid) {
            grid.addEventListener('click', function (ev) {
                var btn = ev.target.closest('.prv-net-photo-x');
                if (btn) { ev.preventDefault(); btn.closest('.prv-net-photo').remove(); }
            });
        }
    })();
</script>
}
