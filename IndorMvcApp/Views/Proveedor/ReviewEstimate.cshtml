@model IndorMvcApp.ViewModels.ProviderProReviewEstimateViewModel
@using System.Globalization
@{
    ViewData["Title"] = L["Estimate Review - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
    var scopeLines = Model.ScopeSummaryLines.Count > 0
        ? Model.ScopeSummaryLines
        : Model.ScopeItems.Select(i => i.Label).Where(l => !string.IsNullOrWhiteSpace(l)).ToList();
}

<div class="prv-pro-shell prv-pro-shell--estimate prv-pro-shell--estimate-wizard">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-wizard-head">
        <a asp-controller="Proveedor" asp-action="@(Model.LeadId > 0 ? "LeadDetails" : "PendingEstimates")" asp-route-id="@(Model.LeadId > 0 ? Model.LeadId : null)" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L.T("Step {0} of {1} · Estimate Review", Model.StepNumber, Model.TotalSteps)</h1>
            <p>@L["Review the draft, total estimate, scope summary, and AI recommendations before sending."]</p>
        </div>
    </header>

    @await Html.PartialAsync("_ProviderProEstimateTutorialCard", (
        Model.StepNumber,
        Model.TotalSteps,
        L["Estimate Review"].ToString(),
        L["Review the draft, total estimate, scope summary, and AI recommendations before sending."].ToString(),
        L["Next: Edit Estimate"].ToString(),
        Url.Action("EditEstimate", "Proveedor", new { id = Model.EstimateId })!,
        Model.WizardSteps))

    <div class="prv-pro-wizard-info">
        <i class="fas fa-circle-info"></i>
        <span>@L["If it is already ready, you can continue to Send Estimate."]</span>
    </div>

    <section class="prv-pro-est-review-job">
        <span class="prv-pro-wizard-type-icon prv-pro-wizard-type-icon--@Model.ServiceTone">
            <i class="fas @Model.ServiceIcon"></i>
        </span>
        <div>
            <strong>@UiDisplayLocalization.Localize(L, Model.Title)</strong>
            <small>@Model.CustomerName</small>
            <small>@Model.Address</small>
            <small>@UiDisplayLocalization.Localize(L, Model.DateLabel)</small>
            <span class="prv-pro-pill prv-pro-pill--@Model.StatusClass">@UiDisplayLocalization.Localize(L, Model.StatusLabel)</span>
        </div>
    </section>

    <section class="prv-pro-wizard-card prv-pro-est-breakdown">
        <h2><i class="fas fa-file-lines"></i> @L["Estimate breakdown"]</h2>
        @foreach (var item in Model.ScopeItems)
        {
            <div class="prv-pro-ai-estimate-row">
                <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
                <span>@item.Amount.ToString("C2", money)</span>
            </div>
        }
        @if (Model.ScopeItems.Count == 0)
        {
            <div class="prv-pro-ai-estimate-row">
                <span>@L["Labor"]</span>
                <span>@Model.LaborAmount.ToString("C2", money)</span>
            </div>
            <div class="prv-pro-ai-estimate-row">
                <span>@L["Materials"]</span>
                <span>@Model.MaterialsAmount.ToString("C2", money)</span>
            </div>
        }
        <div class="prv-pro-est-breakdown-total">
            <span>@L["Total estimate"]</span>
            <strong>@Model.TotalAmount.ToString("C2", money)</strong>
        </div>
    </section>

    @if (scopeLines.Count > 0)
    {
        <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-est-review-panel">
            <div>
                <h3><i class="fas fa-clipboard-list"></i> @L["Scope summary"]</h3>
                <ul>
                    @foreach (var line in scopeLines)
                    {
                        <li>@UiDisplayLocalization.Localize(L, line)</li>
                    }
                </ul>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    }

    @if (Model.AiRecommendations.Count > 0)
    {
        <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-est-review-panel prv-pro-est-review-panel--ai">
            <div>
                <h3><i class="fas fa-wand-magic-sparkles"></i> @L["AI recommendations"]</h3>
                <ul>
                    @foreach (var tip in Model.AiRecommendations)
                    {
                        <li>@UiDisplayLocalization.Localize(L, tip)</li>
                    }
                </ul>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    }

    <footer class="prv-pro-est-review-actions">
        <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-btn prv-pro-btn--ghost">
            <i class="fas fa-pen-to-square"></i> @L["Edit estimate"]
        </a>
        @if (Model.CanSend)
        {
            <a asp-controller="Proveedor" asp-action="SendEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-paper-plane"></i> @L["Continue to send"]
            </a>
        }
        else
        {
            <a asp-controller="Proveedor" asp-action="EstimateSent" asp-route-id="@Model.EstimateId" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-eye"></i> @L["View sent estimate"]
            </a>
        }
    </footer>
</div>
