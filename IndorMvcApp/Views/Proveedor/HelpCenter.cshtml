@model IndorMvcApp.ViewModels.ProviderProProfilePageViewModel
@{
    ViewData["Title"] = "Help Center - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    ViewBag.CompanyInitial = Model.CompanyInitial;
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-shell--support">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-jobs-head prv-pro-settings-head">
        <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-lead-back" aria-label="Back to profile">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1>Help Center</h1>
            <p>Guides and support for INDOR Pro providers.</p>
        </div>
    </header>

    <nav class="prv-pro-settings-nav">
        <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-settings-item">
            <span class="prv-pro-settings-icon"><i class="fas fa-gauge-high"></i></span>
            <div>
                <strong>Getting started with INDOR Pro</strong>
                <span>Manage clients, jobs, estimates, invoices, and reports.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="ProviderRegistration" asp-action="Verification" class="prv-pro-settings-item">
            <span class="prv-pro-settings-icon"><i class="fas fa-file-shield"></i></span>
            <div>
                <strong>Upload verification documents</strong>
                <span>Submit license, insurance, and ID to receive INDOR jobs.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="ProviderRegistration" asp-action="ActivationCall" class="prv-pro-settings-item">
            <span class="prv-pro-settings-icon"><i class="fas fa-phone-volume"></i></span>
            <div>
                <strong>Schedule activation call</strong>
                <span>Complete provider activation for INDOR lead opportunities.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Account" asp-action="Terms" asp-route-from="provider-help" class="prv-pro-settings-item">
            <span class="prv-pro-settings-icon"><i class="fas fa-scale-balanced"></i></span>
            <div>
                <strong>Terms &amp; Conditions</strong>
                <span>Review INDOR platform terms for service providers.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
        <a asp-controller="Account" asp-action="Privacy" asp-route-from="provider-help" class="prv-pro-settings-item">
            <span class="prv-pro-settings-icon"><i class="fas fa-user-shield"></i></span>
            <div>
                <strong>Privacy Policy</strong>
                <span>How INDOR handles your business and account data.</span>
            </div>
            <i class="fas fa-chevron-right"></i>
        </a>
    </nav>

    <section class="prv-pro-profile-card">
        <header class="prv-pro-profile-card-head"><h3><i class="fas fa-headset"></i> Need more help?</h3></header>
        <p class="prv-pro-support-copy">Contact INDOR support through your account representative or email <a href="mailto:support@homeindor.com">support@homeindor.com</a>.</p>
    </section>
</div>
