@model IndorMvcApp.ViewModels.ProviderProPendingEstimatesPageViewModel
@using System.Globalization
@{
    ViewData["Title"] = L["Pending Estimates - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
    var tabs = new[] {
        ("all", L["All"]),
        ("needsreview", L["Needs Review"]),
        ("aidraft", L["AI Draft"]),
        ("ready", L["Ready"])
    };
}

<div class="prv-pro-shell prv-pro-shell--pending-estimates prv-pro-shell--estimate-wizard">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <header class="prv-pro-wizard-head">
        <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L.T("Step {0} of {1} · Pending Estimates", Model.StepNumber, Model.TotalSteps)</h1>
            <p>@L["Here you can see all estimates waiting for action. Tap an estimate to review it."]</p>
        </div>
    </header>

    @await Html.PartialAsync("_ProviderProEstimateTutorialCard", (
        Model.StepNumber,
        Model.TotalSteps,
        L["Pending Estimates"],
        L["Here you can see all estimates waiting for action. Tap an estimate to review it."],
        L["Next: Estimate Review"],
        Model.Estimates.FirstOrDefault(e => e.CanReview)?.Id is int firstId
            ? Url.Action("ReviewEstimate", "Proveedor", new { id = firstId })!
            : Url.Action("PendingEstimates", "Proveedor")!,
        Model.WizardSteps))

    <form method="get" asp-controller="Proveedor" asp-action="PendingEstimates" class="prv-pro-jobs-search">
        <input type="hidden" name="tab" value="@Model.ActiveTab" />
        <div class="prv-pro-search-wrap">
            <i class="fas fa-magnifying-glass"></i>
            <input type="search" name="q" value="@Model.SearchQuery" placeholder="@L["Search estimates..."]" />
        </div>
        <button type="submit" class="prv-pro-filter-btn" title="@L["Search"]"><i class="fas fa-magnifying-glass"></i></button>
    </form>

    <section class="prv-pro-est-hub-stats">
        <div class="prv-pro-est-hub-stat">
            <span class="prv-pro-est-hub-stat-icon prv-pro-est-hub-stat-icon--amber"><i class="fas fa-file-lines"></i></span>
            <strong>@Model.PendingCount</strong>
            <small>@L["Pending Estimates"]</small>
        </div>
        <div class="prv-pro-est-hub-stat">
            <span class="prv-pro-est-hub-stat-icon prv-pro-est-hub-stat-icon--purple"><i class="fas fa-wand-magic-sparkles"></i></span>
            <strong>@Model.AiDraftCount</strong>
            <small>@L["AI Draft Estimates"]</small>
        </div>
        <div class="prv-pro-est-hub-stat">
            <span class="prv-pro-est-hub-stat-icon prv-pro-est-hub-stat-icon--orange"><i class="fas fa-eye"></i></span>
            <strong>@Model.NeedsReviewCount</strong>
            <small>@L["Needs Review"]</small>
        </div>
        <div class="prv-pro-est-hub-stat">
            <span class="prv-pro-est-hub-stat-icon prv-pro-est-hub-stat-icon--green"><i class="fas fa-paper-plane"></i></span>
            <strong>@Model.ReadyCount</strong>
            <small>@L["Ready to Send"]</small>
        </div>
    </section>

    <nav class="prv-pro-leads-filters" aria-label="@L["Estimate filters"]">
        @foreach (var (id, label) in tabs)
        {
            <a asp-controller="Proveedor" asp-action="PendingEstimates"
               asp-route-tab="@id"
               asp-route-q="@Model.SearchQuery"
               class="@(Model.ActiveTab == id ? "is-active" : "")">@label</a>
        }
    </nav>

    <section class="prv-pro-est-hub-list">
        @if (Model.Estimates.Count == 0)
        {
            <div class="prv-pro-panel">
                <p class="prv-pro-empty">@L["No estimates in this view yet. Create one from a lead or save a draft."]</p>
            </div>
        }
        else
        {
            @foreach (var est in Model.Estimates)
            {
                var href = est.CanView
                    ? Url.Action("EstimateSent", "Proveedor", new { id = est.Id })
                    : Url.Action("ReviewEstimate", "Proveedor", new { id = est.Id });
                <a href="@href" class="prv-pro-est-hub-card">
                    <span class="prv-pro-wizard-type-icon prv-pro-wizard-type-icon--@est.ServiceTone">
                        <i class="fas @est.ServiceIcon"></i>
                    </span>
                    <div class="prv-pro-est-hub-card-body">
                        <strong>@est.Title</strong>
                        <small>@est.CustomerName</small>
                        <small>@est.Address</small>
                        <span class="prv-pro-est-hub-date">@est.DateLabel</span>
                    </div>
                    <div class="prv-pro-est-hub-card-meta">
                        <span class="prv-pro-pill prv-pro-pill--@est.StatusClass">@est.Status</span>
                        <strong>@est.Amount.ToString("C2", money)</strong>
                    </div>
                </a>
            }
        }
    </section>
</div>
