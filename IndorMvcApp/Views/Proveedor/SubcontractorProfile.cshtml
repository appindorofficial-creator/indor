@model IndorMvcApp.ViewModels.SubcontractorProfileViewModel
@{
    ViewData["Title"] = "Verified Pro Profile";
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-network.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-net-shell">
    <header class="prv-net-pro-hero">
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-net-back"><i class="fas fa-chevron-left"></i> Back</a>
    </header>

    <section class="prv-net-profile-card">
        <div class="prv-net-profile-top">
            @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
            {
                <span class="prv-net-profile-avatar" style="background-image:url('@Model.PhotoUrl');background-size:cover;"></span>
            }
            else
            {
                <span class="prv-net-profile-avatar prv-net-avatar--trade"><i class="fas @Model.IconClass"></i></span>
            }
            <div class="prv-net-profile-info">
                <h1>@Model.Name</h1>
                @if (!string.IsNullOrWhiteSpace(Model.TradeLabel))
                {
                    <p class="trade">@Model.TradeLabel</p>
                }
                <div class="meta">
                    @if (Model.HasReviews)
                    {
                        <span class="prv-net-stars"><i class="fas fa-star"></i> @Model.Rating!.Value.ToString("0.0") (@Model.ReviewCount reviews)</span>
                    }
                    else
                    {
                        <span class="prv-net-sub-new">New to network</span>
                    }
                </div>
                <div class="meta">
                    @if (!string.IsNullOrWhiteSpace(Model.LocationLabel))
                    {
                        <span><i class="fas fa-location-dot"></i> @Model.LocationLabel</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.DistanceLabel))
                    {
                        <span>@Model.DistanceLabel away</span>
                    }
                </div>
            </div>
            @if (Model.IsVerified)
            {
                <span class="prv-net-verified-seal">
                    <i class="fas fa-shield-halved"></i>
                    Verified Pro
                </span>
            }
        </div>

        <div class="prv-net-ready">
            <span class="prv-net-ready-ic"><i class="fas fa-shield-halved"></i></span>
            <div class="prv-net-ready-copy">
                <strong>@(Model.IsVerified && Model.IsInsured ? "Ready to hire" : "Profile available")</strong>
                <small>Verified, insured, and qualified</small>
            </div>
            <div class="prv-net-ready-badges">
                <span class="@(Model.IsVerified ? "is-on" : null)"><i class="fas fa-circle-check"></i> Verified</span>
                <span class="@(Model.IsInsured ? "is-on" : null)"><i class="fas fa-shield-halved"></i> Insured</span>
                <span class="@(Model.IsDocsReady ? "is-on" : null)"><i class="fas fa-file-lines"></i> Docs</span>
            </div>
        </div>
    </section>

    <div class="prv-net-rows">
        <div class="prv-net-row">
            <span class="prv-net-row-ic"><i class="fas fa-umbrella"></i></span>
            <div class="prv-net-row-body">
                <strong>Insurance Status</strong>
                <span>@Model.InsuranceStatusLabel</span>
            </div>
            <span class="prv-net-tag @(Model.InsuranceActive ? null : "prv-net-tag--muted")">@(Model.InsuranceActive ? "Active" : "Not on file")</span>
        </div>

        <div class="prv-net-row">
            <span class="prv-net-row-ic"><i class="fas fa-file-contract"></i></span>
            <div class="prv-net-row-body">
                <strong>License / Documents</strong>
                <span>@(string.IsNullOrWhiteSpace(Model.LicenseNumber) ? "Documents on file" : $"License {Model.LicenseNumber}")</span>
            </div>
            <span class="prv-net-tag @(Model.LicenseVerified || Model.IsDocsReady ? null : "prv-net-tag--muted")">@(Model.LicenseVerified || Model.IsDocsReady ? "Verified" : "Pending")</span>
        </div>

        @if (Model.Services.Count > 0)
        {
            <div class="prv-net-row" style="align-items:flex-start;">
                <span class="prv-net-row-ic"><i class="fas fa-screwdriver-wrench"></i></span>
                <div class="prv-net-row-body">
                    <strong>Services Offered</strong>
                    <div class="prv-net-chips-inline">
                        @foreach (var svc in Model.Services.Take(8))
                        {
                            <span>@svc</span>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="prv-net-row">
            <span class="prv-net-row-ic"><i class="fas fa-clock"></i></span>
            <div class="prv-net-row-body">
                <strong>Availability</strong>
                <span>@Model.ResponseTimeLabel</span>
            </div>
            <span class="prv-net-tag @(Model.IsAvailableNow ? null : "prv-net-tag--muted")">@Model.AvailabilityLabel</span>
        </div>

        <div class="prv-net-row">
            <span class="prv-net-row-ic"><i class="fas fa-briefcase"></i></span>
            <div class="prv-net-row-body">
                <strong>Experience</strong>
                <span>@(Model.RecentJobsCount > 0 ? $"{Model.RecentJobsCount} hire(s) through INDOR" : "New to the INDOR network")</span>
            </div>
        </div>
    </div>

    @if (Model.HasReviews)
    {
        <section class="prv-net-reviews">
            <div class="prv-net-reviews-head">
                <div class="prv-net-reviews-score">
                    <strong>@Model.Rating!.Value.ToString("0.0")</strong>
                    <div>@for (var i = 0; i < 5; i++) { <i class="fas fa-star"></i> }</div>
                    <small>@Model.ReviewCount reviews</small>
                </div>
                <div class="prv-net-bars">
                    @foreach (var bar in Model.RatingBreakdown)
                    {
                        <div class="prv-net-bar">
                            <span>@bar.Stars</span>
                            <div class="prv-net-bar-track"><div class="prv-net-bar-fill" style="width:@bar.Percent%"></div></div>
                        </div>
                    }
                </div>
            </div>

            @foreach (var review in Model.Reviews)
            {
                <div class="prv-net-review">
                    <div class="prv-net-review-top">
                        <strong>@review.AuthorName</strong>
                        <span class="stars">@for (var i = 0; i < review.Rating; i++) { <i class="fas fa-star"></i> }</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(review.Comment))
                    {
                        <p>@review.Comment</p>
                    }
                    <small>@review.DateLabel</small>
                </div>
            }
        </section>
    }

    <div class="prv-net-actionbar">
        <a asp-controller="Proveedor" asp-action="InviteToJob" asp-route-id="@Model.Id" class="prv-net-btn prv-net-btn--primary">
            <i class="fas fa-paper-plane"></i> Invite to Job
        </a>
        <div class="prv-net-btn-row">
            <a asp-controller="Proveedor" asp-action="Network" class="prv-net-btn prv-net-btn--ghost"><i class="fas fa-comment"></i> Message</a>
            <form asp-controller="Proveedor" asp-action="ToggleSaveSubcontractor" method="post" style="flex:1;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="prv-net-btn prv-net-btn--ghost">
                    <i class="@(Model.IsSaved ? "fas" : "far") fa-bookmark"></i> @(Model.IsSaved ? "Saved" : "Save")
                </button>
            </form>
        </div>
    </div>
</div>
