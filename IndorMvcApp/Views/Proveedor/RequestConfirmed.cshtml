@model IndorMvcApp.ViewModels.RequestConfirmedViewModel
@{
    ViewData["Title"] = L["Request Confirmed"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-requests.css";
    ViewBag.NavActive = "jobs";
    var hasCoords = Model.Latitude.HasValue && Model.Longitude.HasValue;
}

<div class="prv-req-shell">
    <header class="prv-req-hero prv-req-hero--confirm">
        <div class="prv-req-hero-top">
            <span class="prv-req-brand-word">@L["INDOR"]</span>
            <span class="prv-req-brand-pro">@L["PRO"]</span>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>
        <div class="prv-req-confirm-head">
            <span class="prv-req-confirm-check"><i class="fas fa-check"></i></span>
            <div>
                <h1>@L["Request Confirmed"]</h1>
                <p>@L["Your contractor has been hired."]</p>
            </div>
        </div>
    </header>

    <section class="prv-req-jobcard">
        <div class="prv-req-jobcard-head">
            <span class="prv-req-ico prv-req-ico--@Model.IconTone prv-req-ico--lg"><i class="fas @Model.IconClass"></i></span>
            <div class="prv-req-card-id">
                <div class="prv-req-title prv-req-title--lg">@Model.Title</div>
                @if (!string.IsNullOrWhiteSpace(Model.TradeLabel))
                {
                    <div class="prv-req-meta"><i class="fas fa-screwdriver-wrench"></i> @Model.TradeLabel</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.LocationLabel))
                {
                    <div class="prv-req-meta"><i class="fas fa-location-dot"></i> @Model.LocationLabel</div>
                }
            </div>
            <span class="prv-req-pill prv-req-pill--hired"><i class="fas fa-circle-check"></i> @L["Hired"]</span>
        </div>

        <div class="prv-req-selected">
            <div>
                <span>@L["Selected Contractor"]</span>
                <strong>@Model.ContractorName @if (Model.IsVerified) { <i class="fas fa-circle-check prv-req-verified"></i> }</strong>
            </div>
            <div>
                <span>@L["Quote"]</span>
                <strong class="prv-req-selected-amt">@Model.QuoteLabel</strong>
            </div>
            <div>
                <span>@L["Scheduled"]</span>
                <strong><i class="fas fa-calendar-check"></i> @Model.ScheduledLabel</strong>
            </div>
        </div>

        <div class="prv-req-badges prv-req-badges--center">
            @if (Model.IsVerified)
            {
                <span class="prv-req-badge prv-req-badge--blue"><i class="fas fa-circle-check"></i> @L["Verified"]</span>
            }
            @if (Model.IsInsured)
            {
                <span class="prv-req-badge prv-req-badge--green"><i class="fas fa-shield-halved"></i> @L["Insurance Active"]</span>
            }
            @if (Model.IsDocsReady)
            {
                <span class="prv-req-badge prv-req-badge--purple"><i class="fas fa-file-lines"></i> @L["Docs Ready"]</span>
            }
        </div>

        <div class="prv-req-jobcard-foot">
            @await Html.PartialAsync("_RequestStepper", Model.Steps)
        </div>
    </section>

    <section class="prv-req-panel">
        <div class="prv-req-sched">
            <div id="prvConfirmMap" class="prv-req-map"></div>
            <div class="prv-req-sched-info">
                <strong>@Model.ScheduledLabel</strong>
                @if (!string.IsNullOrWhiteSpace(Model.AddressLine))
                {
                    <div class="prv-req-sched-line"><i class="fas fa-location-dot"></i> @Model.AddressLine</div>
                }
                <div class="prv-req-sched-line"><i class="fas fa-calendar"></i> @L.T("Estimated duration: {0}", UiDisplayLocalization.Localize(L, Model.DurationLabel))</div>
                <div class="prv-req-sched-note">
                    <i class="fas fa-circle-check"></i> @L.T("We've shared the details with {0}. They'll see you soon!", Model.ContractorName)
                </div>
            </div>
        </div>
    </section>

    <section class="prv-req-panel">
        <h2 class="prv-req-panel-title">@L["What happens next"]</h2>
        <div class="prv-req-next">
            <div class="prv-req-next-item">
                <span class="prv-req-next-num">1</span>
                <i class="fas fa-calendar-check"></i>
                <span>@L["Contractor confirms visit"]</span>
            </div>
            <div class="prv-req-next-item">
                <span class="prv-req-next-num">2</span>
                <i class="fas fa-comment-dots"></i>
                <span>@L["You receive updates"]</span>
            </div>
            <div class="prv-req-next-item">
                <span class="prv-req-next-num">3</span>
                <i class="fas fa-clipboard-check"></i>
                <span>@L["Job marked complete"]</span>
            </div>
        </div>
    </section>

    <a asp-controller="Proveedor" asp-action="SubcontractorProfile" asp-route-id="@Model.SubcontractorId" class="prv-req-btn prv-req-btn--primary prv-req-btn--block">
        <i class="fas fa-comment-dots"></i> @L["Message Contractor"]
    </a>
    <a asp-controller="Proveedor" asp-action="RequestDetails" asp-route-id="@Model.JobId" class="prv-req-btn prv-req-btn--ghost prv-req-btn--block">
        <i class="fas fa-file-lines"></i> @L["View Request"]
    </a>
</div>

@section Scripts {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
    (function () {
        var el = document.getElementById('prvConfirmMap');
        if (!el || typeof L === 'undefined') { return; }
        var hasCoords = @(hasCoords ? "true" : "false");
        var lat = @(Model.Latitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
        var lng = @(Model.Longitude?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "null");
        var center = hasCoords ? [lat, lng] : [35.2271, -80.8431];
        var map = L.map(el, { zoomControl: false, dragging: false, scrollWheelZoom: false, doubleClickZoom: false, boxZoom: false, keyboard: false, tap: false })
            .setView(center, hasCoords ? 14 : 11);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);
        L.marker(center).addTo(map);
        setTimeout(function () { map.invalidateSize(); }, 150);
    })();
</script>
}
