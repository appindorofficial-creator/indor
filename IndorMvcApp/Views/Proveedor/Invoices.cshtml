@model IndorMvcApp.ViewModels.ProviderProInvoicesPageViewModel
@using System.Globalization
@{
    ViewData["Title"] = $"{Model.PageTitle} - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
    var tabs = new[] { ("all", "All"), ("paid", "Paid"), ("pending", "Pending"), ("overdue", "Overdue") };
}

<div class="prv-pro-shell prv-pro-shell--invoices">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-new-leads-head">
        <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@Model.PageTitle</h1>
            @if (Model.ShowOverdueSummary)
            {
                <small>@Model.OverdueCount invoice@(Model.OverdueCount == 1 ? "" : "s") past due</small>
            }
            else if (Model.ShowPendingSummary)
            {
                <small>@Model.PendingCount invoice@(Model.PendingCount == 1 ? "" : "s") awaiting payment</small>
            }
            else
            {
                <small>@L["Manage invoices and pending payments"]</small>
            }
        </div>
    </header>

    @if (TempData["InvoicePaymentRecorded"] as bool? == true)
    {
        <div class="prv-pro-alert prv-pro-alert--success">
            <i class="fas fa-circle-check"></i> Payment recorded successfully. The invoice has moved to the Paid tab.
        </div>
    }

    <form method="get" asp-controller="Proveedor" asp-action="Invoices" class="prv-pro-jobs-search">
        <input type="hidden" name="tab" value="@Model.ActiveTab" />
        <div class="prv-pro-search-wrap">
            <i class="fas fa-magnifying-glass"></i>
            <input type="search" name="q" value="@Model.SearchQuery" placeholder="@Model.SearchPlaceholder" />
        </div>
        <button type="button" class="prv-pro-filter-btn" title="@L["Filters"]"><i class="fas fa-sliders"></i></button>
    </form>

    <nav class="prv-pro-leads-filters" aria-label="@L["Invoice filters"]">
        @foreach (var (id, label) in tabs)
        {
            <a asp-controller="Proveedor" asp-action="Invoices"
               asp-route-tab="@id"
               asp-route-q="@Model.SearchQuery"
               class="@(Model.ActiveTab == id ? "is-active" : "")">@label</a>
        }
    </nav>

    @if (Model.ShowOverdueSummary)
    {
        <section class="prv-pro-invoice-overdue-stats">
            <div class="prv-pro-invoice-stat prv-pro-invoice-stat--overdue">
                <i class="fas fa-circle-exclamation"></i>
                <div>
                    <strong>@Model.OverdueTotal.ToString("C0", money)</strong>
                    <span>@L["Total amount due"]</span>
                </div>
            </div>
            <div class="prv-pro-invoice-stat prv-pro-invoice-stat--late">
                <i class="fas fa-calendar-xmark"></i>
                <div>
                    <strong>@Model.OverdueCount Invoice@(Model.OverdueCount == 1 ? "" : "s") Late</strong>
                    <span>@L["Past due"]</span>
                </div>
            </div>
        </section>
    }
    else if (Model.ShowPendingSummary)
    {
        <section class="prv-pro-invoice-overdue-stats">
            <div class="prv-pro-invoice-stat prv-pro-invoice-stat--pending">
                <i class="fas fa-dollar-sign"></i>
                <div>
                    <strong>@Model.PendingTotal.ToString("C0", money)</strong>
                    <span>@L["Pending Total"]</span>
                </div>
            </div>
            <div class="prv-pro-invoice-stat prv-pro-invoice-stat--late">
                <i class="fas fa-file-invoice"></i>
                <div>
                    <strong>@Model.PendingCount Invoice@(Model.PendingCount == 1 ? "" : "s")</strong>
                    <span>@L["Awaiting Payment"]</span>
                </div>
            </div>
        </section>
    }
    else
    {
        <section class="prv-pro-invoice-summary-stats">
            <div class="prv-pro-invoice-stat prv-pro-invoice-stat--paid">
                <span class="dot dot--paid"></span>
                <div>
                    <strong>@Model.PaidThisMonth.ToString("C0", money)</strong>
                    <span>@L["Paid This Month"]</span>
                </div>
            </div>
            <a asp-controller="Proveedor" asp-action="Invoices" asp-route-tab="pending" class="prv-pro-invoice-stat prv-pro-invoice-stat--pending prv-pro-invoice-stat--link">
                <span class="dot dot--pending"></span>
                <div>
                    <strong>@Model.PendingTotal.ToString("C0", money)</strong>
                    <span>@L["Pending"]</span>
                </div>
            </a>
            <a asp-controller="Proveedor" asp-action="Invoices" asp-route-tab="overdue" class="prv-pro-invoice-stat prv-pro-invoice-stat--overdue prv-pro-invoice-stat--link">
                <span class="dot dot--overdue"></span>
                <div>
                    <strong>@Model.OverdueTotal.ToString("C0", money)</strong>
                    <span>@L["Overdue"]</span>
                </div>
            </a>
        </section>
    }

    <section class="prv-pro-invoices-list">
        @if (Model.Invoices.Count == 0)
        {
            <div class="prv-pro-panel">
                <p class="prv-pro-empty">@L["No invoices in this view yet."]</p>
            </div>
        }
        else
        {
            @foreach (var inv in Model.Invoices)
            {
                var fromTab = Model.ActiveTab;
                <article class="prv-pro-invoice-card">
                    <div class="prv-pro-invoice-card-icon prv-pro-invoice-card-icon--@inv.StatusClass">
                        <i class="fas @inv.StatusIcon"></i>
                    </div>
                    <div class="prv-pro-invoice-card-body">
                        <div class="prv-pro-invoice-card-top">
                            <div>
                                <strong>Invoice @inv.InvoiceCode</strong>
                                <small>@inv.Address</small>
                                @if (!string.IsNullOrWhiteSpace(inv.ServiceType))
                                {
                                    <small class="prv-pro-invoice-service">@inv.ServiceType</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(inv.DueDateLabel))
                                {
                                    <small class="prv-pro-invoice-due">@inv.DueDateLabel</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(inv.DaysLateLabel))
                                {
                                    <small class="prv-pro-invoice-late">@inv.DaysLateLabel</small>
                                }
                            </div>
                            <div class="prv-pro-invoice-card-meta">
                                <strong>@inv.Amount.ToString("C0", money)</strong>
                                <span class="prv-pro-pill prv-pro-pill--@inv.StatusClass">@inv.Status</span>
                            </div>
                        </div>
                        <div class="prv-pro-invoice-card-actions">
                            <a asp-controller="Proveedor" asp-action="InvoiceDetails" asp-route-id="@inv.Id" asp-route-from="@fromTab" class="prv-pro-btn prv-pro-btn--ghost">@L["View"]</a>
                            @if (inv.ShowReminderAction)
                            {
                                <a asp-controller="Proveedor" asp-action="SendInvoiceReminder" asp-route-id="@inv.Id" asp-route-from="@fromTab" class="prv-pro-btn prv-pro-btn--ghost">
                                    <i class="fas fa-bell"></i> Reminder
                                </a>
                            }
                            @if (inv.ShowMarkPaidAction)
                            {
                                <a asp-controller="Proveedor" asp-action="RecordPayment" asp-route-id="@inv.Id" asp-route-from="@fromTab" class="prv-pro-btn prv-pro-btn--ghost prv-pro-btn--success">
                                    <i class="fas fa-circle-check"></i> Mark Paid
                                </a>
                            }
                        </div>
                    </div>
                </article>
            }
        }
    </section>

    <footer class="prv-pro-invoices-footer">
        <button type="button" class="prv-pro-btn prv-pro-btn--primary"><i class="fas fa-plus"></i> Create Invoice</button>
        <button type="button" class="prv-pro-btn prv-pro-btn--ghost"><i class="fas fa-filter"></i> Filter</button>
        <button type="button" class="prv-pro-btn prv-pro-btn--ghost"><i class="fas fa-download"></i> Export</button>
    </footer>
</div>
