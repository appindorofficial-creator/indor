@model IndorMvcApp.ViewModels.NetworkSubcontractorCardViewModel

<a asp-controller="Proveedor" asp-action="SubcontractorProfile" asp-route-id="@Model.Id"
   class="prv-net-sub-card @(Model.IsRecommended ? "is-recommended" : null)">
    <div class="prv-net-sub-top">
        @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
        {
            <span class="prv-net-avatar prv-net-avatar--img" style="background-image:url('@Model.PhotoUrl');background-size:cover;">
                @if (Model.IsAvailableNow)
                {
                    <span class="prv-net-avatar-dot"></span>
                }
            </span>
        }
        else
        {
            <span class="prv-net-avatar prv-net-avatar--trade">
                <i class="fas @Model.IconClass"></i>
                @if (Model.IsAvailableNow)
                {
                    <span class="prv-net-avatar-dot"></span>
                }
            </span>
        }

        <div class="prv-net-sub-main">
            <p class="prv-net-sub-name">
                @Model.Name
                @if (Model.IsVerified)
                {
                    <i class="fas fa-circle-check" title="@L["Verified"]"></i>
                }
            </p>
            @if (!string.IsNullOrWhiteSpace(Model.TradeLabel))
            {
                <p class="prv-net-sub-trade">@Model.TradeLabel</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.DistanceLabel) || !string.IsNullOrWhiteSpace(Model.LocationLabel))
            {
                <p class="prv-net-sub-loc">
                    <i class="fas fa-location-dot"></i>
                    @(!string.IsNullOrWhiteSpace(Model.LocationLabel) ? Model.LocationLabel : Model.DistanceLabel)
                    @if (!string.IsNullOrWhiteSpace(Model.LocationLabel) && !string.IsNullOrWhiteSpace(Model.DistanceLabel))
                    {
                        <span class="prv-net-sub-dist">&middot; @Model.DistanceLabel</span>
                    }
                </p>
            }
        </div>

        <div class="prv-net-sub-side">
            @if (Model.IsRecommended)
            {
                <span class="prv-net-reco-tag">@L["Recommended"]</span>
            }
            <span class="prv-net-avail @(Model.IsAvailableNow ? null : "prv-net-avail--soft")">@Model.AvailabilityLabel</span>
            <i class="fas fa-chevron-right prv-net-chevron"></i>
        </div>
    </div>

    <div class="prv-net-badges">
        @if (Model.IsVerified)
        {
            <span class="prv-net-badge prv-net-badge--verified"><i class="fas fa-circle-check"></i> Verified</span>
        }
        @if (Model.IsInsured)
        {
            <span class="prv-net-badge prv-net-badge--insured"><i class="fas fa-shield-halved"></i> Insurance Active</span>
        }
        @if (Model.IsDocsReady)
        {
            <span class="prv-net-badge prv-net-badge--docs"><i class="fas fa-file-lines"></i> Docs Ready</span>
        }
    </div>

    <div class="prv-net-sub-stats">
        <span class="prv-net-stat">
            @if (Model.HasReviews)
            {
                <i class="fas fa-star prv-net-stat-star"></i>
                <strong>@Model.Rating!.Value.ToString("0.0")</strong>
                <span class="prv-net-sub-dist">(@Model.ReviewCount)</span>
            }
            else
            {
                <span class="prv-net-sub-new">@L["New"]</span>
            }
        </span>
        @if (Model.HasJobsCompleted)
        {
            <span class="prv-net-stat">
                <i class="fas fa-briefcase"></i> <strong>@Model.JobsCompletedCount</strong> jobs completed
            </span>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ResponseLabel))
        {
            <span class="prv-net-stat">
                <i class="fas fa-clock"></i> @Model.ResponseLabel
            </span>
        }
    </div>
</a>
