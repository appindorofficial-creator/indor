@model IndorMvcApp.ViewModels.ProviderProUploadReportJobSummaryViewModel

<section class="prv-pro-upload-report-job-summary">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="" />
    }
    else
    {
        <div class="prv-pro-upload-report-job-summary-icon"><i class="fas fa-house"></i></div>
    }
    <div>
        <strong>@Model.Title</strong>
        <span>@Model.Address</span>
        @if (!string.IsNullOrWhiteSpace(Model.JobCode))
        {
            <span>@L.T("Job #{0}", Model.JobCode.Replace("JOB-", "")) @if (!string.IsNullOrWhiteSpace(Model.ScheduledLabel)) { <text>• @UiDisplayLocalization.Localize(L, Model.ScheduledLabel)</text> }</span>
        }
        <span class="prv-pro-pill prv-pro-pill--@Model.StatusClass">@UiDisplayLocalization.Localize(L, Model.StatusLabel)</span>
    </div>
</section>
