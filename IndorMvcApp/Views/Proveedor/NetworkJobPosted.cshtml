@model IndorMvcApp.ViewModels.NetworkJobPostedViewModel
@{
    ViewData["Title"] = L["Job Posted"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-network.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-net-shell">
    <div class="prv-net-success">
        <span class="prv-net-success-ic"><i class="fas fa-check"></i></span>
        <h1>@L["Job posted!"]</h1>
        <p>
            @if (!string.IsNullOrWhiteSpace(Model.TradeLabel))
            {
                <text>Your @Model.TradeLabel job is now shared with verified subcontractors.</text>
            }
            else
            {
                <text>@L["Your job is now shared with verified subcontractors."]</text>
            }
        </p>
    </div>

    <div class="prv-net-sec-head">
        <h2>@Model.MatchedCount qualified match@(Model.MatchedCount == 1 ? "" : "es")</h2>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-trade="@(Model.TradeLabel == null ? "all" : "all")" class="prv-net-sort">@L["See all"]<i class="fas fa-chevron-right"></i></a>
    </div>

    @if (Model.Matches.Count == 0)
    {
        <div class="prv-net-empty">
            <i class="fas fa-user-clock"></i>
            <h3>@L["Matching in progress"]</h3>
            <p>@L["We'll notify you as verified subcontractors respond to your job."]</p>
        </div>
    }
    else
    {
        <div class="prv-net-list">
            @foreach (var sub in Model.Matches)
            {
                @await Html.PartialAsync("_NetworkSubcontractorCard", sub)
            }
        </div>
    }

    <div class="prv-net-actionbar" style="position:static;">
        <a asp-controller="Proveedor" asp-action="Network" class="prv-net-btn prv-net-btn--primary"><i class="fas fa-house"></i> Back to Network</a>
    </div>
</div>
