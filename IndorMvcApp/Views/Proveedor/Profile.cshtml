@model IndorMvcApp.ViewModels.ProviderProProfilePageViewModel
@using System.Globalization
@using System.Text.RegularExpressions
@{
    ViewData["Title"] = L["Profile - INDOR PRO"];
    ViewData["ProviderProExtraCss"] = "provider-profile-hub.css";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    var money = CultureInfo.GetCultureInfo("en-US");
    var initial = Model.CompanyInitial;
    ViewBag.CompanyInitial = initial;
    var allServices = Model.Categories.Concat(Model.Services).Distinct().ToList();
    var publicProfileUrl = Url.Action("PublicProfile", "Proveedor", null, Context.Request.Scheme);
    var displayName = !string.IsNullOrWhiteSpace(Model.BusinessName)
        ? Model.BusinessName
        : !string.IsNullOrWhiteSpace(Model.DbaName) ? Model.DbaName : Model.CompanyName;
    var cityLabel = !string.IsNullOrWhiteSpace(Model.PrimaryCity)
        ? Model.PrimaryCity
        : Model.ServiceAreas.FirstOrDefault(a => a.Contains(',')) ?? L["Add your location"];
    var locationLabel = !string.IsNullOrWhiteSpace(Model.ServiceAreaLabel)
        ? UiDisplayLocalization.Localize(L, Model.ServiceAreaLabel)
        : L.T("Serving {0} and surrounding areas", cityLabel);
    var zipCodes = Model.ServiceAreas
        .Where(a => Regex.IsMatch(a.Trim(), @"^\d{5}$"))
        .Distinct()
        .ToList();
    var ratingLabel = Model.ReviewCount > 0 ? Model.Rating.ToString("0.0") : null;
    var phoneLabel = string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone;
    var emailLabel = string.IsNullOrWhiteSpace(Model.Email) ? "—" : Model.Email;
    var hoursLabel = string.IsNullOrWhiteSpace(Model.BusinessHours)
        || string.Equals(Model.BusinessHours, L["Hours not set"], StringComparison.Ordinal)
        ? "—"
        : Model.BusinessHours;
    string ScoreLabel(int score) => score switch
    {
        >= 90 => L["Excellent"],
        >= 75 => L["Great"],
        >= 60 => L["Good"],
        >= 40 => L["Fair"],
        _ => L["Building"]
    };
    string VerifyIcon(string label) => label switch
    {
        var s when s.Contains("License", StringComparison.OrdinalIgnoreCase) => "fa-id-card",
        var s when s.Contains("Insurance", StringComparison.OrdinalIgnoreCase) => "fa-shield-halved",
        var s when s.Contains("Background", StringComparison.OrdinalIgnoreCase) => "fa-user-shield",
        _ => "fa-file-invoice"
    };
}

<div class="prv-pro-shell prv-pro-shell--profile prv-pro-profile-v2">
    <div class="prv-pro-profile-v2-hero">
        @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
        <header class="prv-pro-profile-v2-page-head">
            <h1>@L["Profile"]</h1>
            <p>@L["Your business profile and control center."]</p>
        </header>
    </div>

    <div class="prv-pro-profile-v2-body">
        @if (TempData["ProfileSaved"] is true)
        {
            <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success">
                <i class="fas fa-circle-check"></i> @L["Profile updated successfully."]
            </div>
        }
        @if (TempData["ProfileSectionError"] is string sectionError)
        {
            <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
                <i class="fas fa-circle-exclamation"></i> @UiDisplayLocalization.Localize(L, sectionError)
            </div>
        }

        <section class="prv-pro-profile-v2-overview">
            <div class="prv-pro-profile-v2-overview-top">
                <div class="prv-pro-profile-v2-avatar-wrap">
                    @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                    {
                        <img src="@Url.Content($"~{Model.LogoUrl}")" alt="@displayName" class="prv-pro-profile-v2-avatar" />
                    }
                    else
                    {
                        <span class="prv-pro-profile-v2-avatar">@initial</span>
                    }
                    @if (Model.IsVerified)
                    {
                        <span class="prv-pro-profile-v2-verified"><i class="fas fa-check"></i></span>
                    }
                </div>
                <div class="prv-pro-profile-v2-overview-copy">
                    <h2>@displayName</h2>
                    @if (Model.IsVerified)
                    {
                        <span class="prv-pro-profile-v2-badge"><i class="fas fa-circle-check"></i> @L["Verified Provider"]</span>
                    }
                    <p class="prv-pro-profile-v2-location"><i class="fas fa-location-dot"></i> @locationLabel</p>
                </div>
            </div>
            <div class="prv-pro-profile-v2-stats">
                <div class="prv-pro-profile-v2-stat">
                    <span class="prv-pro-profile-v2-stat-label">@L["Provider Score"]<i class="fas fa-circle-info" aria-hidden="true"></i></span>
                    <strong class="prv-pro-profile-v2-stat-value is-score">@Model.ProviderScore</strong>
                    <span class="prv-pro-profile-v2-stat-foot is-good"><i class="fas fa-star"></i> @ScoreLabel(Model.ProviderScore)</span>
                </div>
                <div class="prv-pro-profile-v2-stat">
                    <span class="prv-pro-profile-v2-stat-label">@L["Rating"]</span>
                    @if (ratingLabel is not null)
                    {
                        <strong class="prv-pro-profile-v2-stat-value"><i class="fas fa-star is-rating"></i> @ratingLabel</strong>
                        <span class="prv-pro-profile-v2-stat-foot">@Model.ReviewCount @L[Model.ReviewCount == 1 ? "review" : "reviews"]</span>
                    }
                    else
                    {
                        <strong class="prv-pro-profile-v2-stat-value"><i class="fas fa-star is-rating"></i> —</strong>
                        <span class="prv-pro-profile-v2-stat-foot">@L["No reviews yet"]</span>
                    }
                </div>
                <div class="prv-pro-profile-v2-stat">
                    <span class="prv-pro-profile-v2-stat-label">@L["Jobs Completed"]</span>
                    <strong class="prv-pro-profile-v2-stat-value is-jobs">@Model.JobsCompletedThisYear</strong>
                    <span class="prv-pro-profile-v2-stat-foot">@L["This Year"]</span>
                </div>
                <div class="prv-pro-profile-v2-stat">
                    <span class="prv-pro-profile-v2-stat-label">@L["Home Records"]</span>
                    <strong class="prv-pro-profile-v2-stat-value is-records">@Model.HomeRecordsCreated</strong>
                    <span class="prv-pro-profile-v2-stat-foot">@L["Created"]</span>
                </div>
            </div>
        </section>

        <nav class="prv-pro-profile-v2-actions" aria-label="@L["Profile shortcuts"]">
            <a asp-controller="Proveedor" asp-action="ProfileCompletion" class="prv-pro-profile-v2-action">
                <span class="prv-pro-profile-v2-action-icon prv-pro-profile-v2-action-icon--edit"><i class="fas fa-pen"></i></span>
                <span class="prv-pro-profile-v2-action-copy">
                    <strong>@L["Edit Profile"]</strong>
                    <small>@L["Update your business information"]</small>
                </span>
                <i class="fas fa-chevron-right"></i>
            </a>
            <a asp-controller="Proveedor" asp-action="ProfileCompletion" class="prv-pro-profile-v2-action">
                <span class="prv-pro-profile-v2-action-icon prv-pro-profile-v2-action-icon--public"><i class="fas fa-globe"></i></span>
                <span class="prv-pro-profile-v2-action-copy">
                    <strong>@L["Public Profile"]</strong>
                    <small>@L["View how customers see you"]</small>
                </span>
                <i class="fas fa-chevron-right"></i>
            </a>
            <a href="@publicProfileUrl"
               class="prv-pro-profile-v2-action"
               id="prvProfileShareBtn"
               data-provider-share
               data-share-url="@publicProfileUrl"
               data-share-title="@displayName - INDOR PRO"
               data-share-text="@L["View my provider profile on INDOR"]"
               data-share-copied="@L["Profile link copied to clipboard."]"
               data-share-prompt="@L["Copy profile link:"]"
               role="button">
                <span class="prv-pro-profile-v2-action-icon prv-pro-profile-v2-action-icon--share"><i class="fas fa-share-nodes"></i></span>
                <span class="prv-pro-profile-v2-action-copy">
                    <strong>@L["Share"]</strong>
                    <small>@L["Share your profile with customers"]</small>
                </span>
                <i class="fas fa-chevron-right"></i>
            </a>
            <a asp-controller="Proveedor" asp-action="Settings" class="prv-pro-profile-v2-action">
                <span class="prv-pro-profile-v2-action-icon prv-pro-profile-v2-action-icon--settings"><i class="fas fa-gear"></i></span>
                <span class="prv-pro-profile-v2-action-copy">
                    <strong>@L["Settings"]</strong>
                    <small>@L["Manage preferences and account"]</small>
                </span>
                <i class="fas fa-chevron-right"></i>
            </a>
        </nav>

        <div class="prv-pro-profile-v2-stack">
            <section class="prv-pro-profile-v2-card" aria-labelledby="prv-biz-info-heading">
                <a asp-controller="Proveedor"
                   asp-action="EditProfile"
                   class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--compact prv-pro-profile-v2-card-head--link"
                   aria-label="@L["Edit business information"]">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-building"></i></span>
                        <div><h3 id="prv-biz-info-heading">@L["Business Information"]</h3></div>
                    </div>
                    <i class="fas fa-chevron-right prv-pro-profile-v2-card-chevron"></i>
                </a>
                <div class="prv-pro-profile-v2-biz-row">
                    <span class="prv-pro-profile-v2-biz-icon"><i class="fas fa-phone"></i></span>
                    <span>@L["Phone"]</span>
                    <strong>@phoneLabel</strong>
                </div>
                <div class="prv-pro-profile-v2-biz-row">
                    <span class="prv-pro-profile-v2-biz-icon"><i class="fas fa-envelope"></i></span>
                    <span>@L["Email"]</span>
                    <strong class="prv-pro-profile-v2-biz-value">@emailLabel</strong>
                </div>
                <div class="prv-pro-profile-v2-biz-row">
                    <span class="prv-pro-profile-v2-biz-icon"><i class="fas fa-clock"></i></span>
                    <span>@L["Business Hours"]</span>
                    <strong>@hoursLabel</strong>
                </div>
            </section>

            <a asp-controller="Proveedor" asp-action="ProfileBusiness" class="prv-pro-profile-v2-card prv-pro-profile-v2-card--areas" aria-label="@L["Edit service areas"]">
                <header class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--areas">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-map-location-dot"></i></span>
                        <div>
                            <h3>@L["Service Areas"]</h3>
                            <p>@L["Where you provide your services"]</p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right prv-pro-profile-v2-card-chevron"></i>
                    <img src="~/images/profile-map-areas.png" alt="" class="prv-pro-profile-v2-areas-map-bg" aria-hidden="true" />
                </header>
                <div class="prv-pro-profile-v2-areas-row">
                    <div class="prv-pro-profile-v2-area-row">
                        <i class="fas fa-location-dot"></i>
                        <span>@cityLabel</span>
                    </div>
                    @if (zipCodes.Count > 0)
                    {
                        <div class="prv-pro-profile-v2-zips">
                            @foreach (var zip in zipCodes)
                            {
                                <span class="prv-pro-profile-v2-zip">@zip</span>
                            }
                        </div>
                    }
                    else if (Model.ServiceAreas.Count > 0)
                    {
                        <div class="prv-pro-profile-v2-zips">
                            @foreach (var area in Model.ServiceAreas.Take(4))
                            {
                                <span class="prv-pro-profile-v2-zip">@area</span>
                            }
                        </div>
                    }
                </div>
            </a>

            <a asp-controller="Proveedor" asp-action="ProfileBusiness" class="prv-pro-profile-v2-card" aria-label="@L["Edit services offered"]">
                <header class="prv-pro-profile-v2-card-head">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-wrench"></i></span>
                        <div>
                            <h3>@L["Services Offered"]</h3>
                            <p>@L["Add and manage the services you provide"]</p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right prv-pro-profile-v2-card-chevron"></i>
                </header>
                @if (allServices.Count == 0)
                {
                    <div class="prv-pro-profile-v2-empty">
                        <img src="~/images/profile-services-empty.png" alt="" aria-hidden="true" />
                        <h4>@L["No services selected yet"]</h4>
                        <p>@L["Add services to show customers what you offer."]</p>
                        <span class="prv-pro-profile-v2-add-btn"><i class="fas fa-plus"></i> @L["Add Services"]</span>
                    </div>
                }
                else
                {
                    <div class="prv-pro-profile-v2-tags">
                        @foreach (var svc in allServices)
                        {
                            <span class="prv-pro-profile-v2-tag">@UiDisplayLocalization.Localize(L, svc)</span>
                        }
                    </div>
                }
            </a>

            <a asp-controller="Proveedor" asp-action="ProfileDocuments" class="prv-pro-profile-v2-card" aria-label="@L["Verification and documents"]">
                <header class="prv-pro-profile-v2-card-head">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-shield-halved"></i></span>
                        <div>
                            <h3>@L["Verification &amp; Documents"]</h3>
                            <p>@L["Keep your documents up to date"]</p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right prv-pro-profile-v2-card-chevron"></i>
                </header>
                @foreach (var item in Model.VerificationItems)
                {
                    <div class="prv-pro-profile-v2-verify-row">
                        <span class="prv-pro-profile-v2-verify-icon"><i class="fas @VerifyIcon(item.Label)"></i></span>
                        <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
                        <span class="prv-pro-profile-v2-pending @(item.IsComplete ? "is-done" : "")">@(item.IsComplete ? L["Complete"] : L["Pending"])</span>
                        <i class="fas fa-chevron-right prv-pro-profile-v2-verify-chevron"></i>
                    </div>
                }
            </a>

            <a asp-controller="Proveedor" asp-action="EditProfilePayments" class="prv-pro-profile-v2-card" aria-label="@L["Payments and banking"]">
                <header class="prv-pro-profile-v2-card-head">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-credit-card"></i></span>
                        <div><h3>@L["Payments &amp; Banking"]</h3></div>
                    </div>
                    <i class="fas fa-chevron-right prv-pro-profile-v2-card-chevron"></i>
                </header>
                <div class="prv-pro-profile-v2-kv">
                    <span>@L["Payout Account"]</span>
                    <strong class="@(Model.PayoutConnected ? "is-ok" : "")">@(Model.PayoutConnected ? L["Connected"] : L["Not connected"])</strong>
                </div>
                <div class="prv-pro-profile-v2-kv">
                    <span>@L["Payment Processing"]</span>
                    <strong class="@(Model.PaymentProcessingActive ? "is-ok" : "")">@(Model.PaymentProcessingActive ? L["Active"] : L["Inactive"])</strong>
                </div>
                <div class="prv-pro-profile-v2-kv">
                    <span>@L["Next Payout"]</span>
                    <strong>@Model.NextPayoutAmount.ToString("C2", money)</strong>
                </div>
            </a>

            <section class="prv-pro-profile-v2-card">
                <header class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--compact">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-users"></i></span>
                        <div><h3>@L["Team Members"]</h3></div>
                    </div>
                </header>
                @if (Model.TeamMembers.Count == 0)
                {
                    <div class="prv-pro-profile-v2-team-empty">
                        <span class="prv-pro-profile-v2-team-empty-icon"><i class="fas fa-users"></i></span>
                        <p>@L["No team members listed yet."]</p>
                    </div>
                }
                else
                {
                    @foreach (var member in Model.TeamMembers)
                    {
                        <div class="prv-pro-profile-v2-kv">
                            <span>@member.Name</span>
                            <strong>@UiDisplayLocalization.Localize(L, member.Role)</strong>
                        </div>
                    }
                }
            </section>

            <section class="prv-pro-profile-v2-card">
                <header class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--compact">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-robot"></i></span>
                        <div><h3>@L["Automation &amp; Tools"]</h3></div>
                    </div>
                </header>
                <div class="prv-pro-profile-v2-auto-row">
                    <i class="fas fa-bell"></i>
                    <span>@L["Auto reminders"]</span>
                    <strong class="@(Model.AutoRemindersOn ? "is-ok" : "")">@(Model.AutoRemindersOn ? L["ON"] : L["OFF"])</strong>
                </div>
                <div class="prv-pro-profile-v2-auto-row">
                    <i class="fas fa-file-lines"></i>
                    <span>@L["Saved report templates"]</span>
                    <strong>@Model.ReportTemplatesCount</strong>
                </div>
                <div class="prv-pro-profile-v2-auto-row">
                    <i class="fas fa-paper-plane"></i>
                    <span>@L["Follow-up campaigns"]</span>
                    <strong class="@(Model.FollowUpCampaignsActive ? "is-ok" : "")">@(Model.FollowUpCampaignsActive ? L["Active"] : L["Inactive"])</strong>
                </div>
                <div class="prv-pro-profile-v2-auto-row">
                    <i class="fas fa-wand-magic-sparkles"></i>
                    <span>@L["AI assistant"]</span>
                    <strong class="@(Model.AiAssistantEnabled ? "is-ok" : "")">@(Model.AiAssistantEnabled ? L["Enabled"] : L["Disabled"])</strong>
                </div>
            </section>

            <section class="prv-pro-profile-v2-card">
                <header class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--compact">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-chart-line"></i></span>
                        <div><h3>@L["Performance"]</h3></div>
                    </div>
                </header>
                <div class="prv-pro-profile-v2-perf">
                    <div class="prv-pro-profile-v2-perf-item">
                        <span class="prv-pro-profile-v2-perf-icon prv-pro-profile-v2-perf-icon--time"><i class="fas fa-clock"></i></span>
                        <strong>@UiDisplayLocalization.Localize(L, Model.Performance.AvgResponseTime)</strong>
                        <span class="prv-pro-profile-v2-perf-label">@L["Avg. Response Time"]</span>
                    </div>
                    <div class="prv-pro-profile-v2-perf-item">
                        <span class="prv-pro-profile-v2-perf-icon prv-pro-profile-v2-perf-icon--check"><i class="fas fa-circle-check"></i></span>
                        <strong>@UiDisplayLocalization.Localize(L, Model.Performance.CompletionRate)</strong>
                        <span class="prv-pro-profile-v2-perf-label">@L["Completion Rate"]</span>
                    </div>
                    <div class="prv-pro-profile-v2-perf-item">
                        <span class="prv-pro-profile-v2-perf-icon prv-pro-profile-v2-perf-icon--thumb"><i class="fas fa-thumbs-up"></i></span>
                        <strong>@UiDisplayLocalization.Localize(L, Model.Performance.HomeownerApproval)</strong>
                        <span class="prv-pro-profile-v2-perf-label">@L["Homeowner Approval"]</span>
                    </div>
                    <div class="prv-pro-profile-v2-perf-item">
                        <span class="prv-pro-profile-v2-perf-icon prv-pro-profile-v2-perf-icon--home"><i class="fas fa-house"></i></span>
                        <strong class="is-facts">@Model.Performance.HouseFactsAdded</strong>
                        <span class="prv-pro-profile-v2-perf-label">@L["House Facts Added"]</span>
                    </div>
                </div>
            </section>

            <section class="prv-pro-profile-v2-card">
                <header class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--compact">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-star"></i></span>
                        <div><h3>@L["Reviews"]</h3></div>
                    </div>
                </header>
                @if (Model.Reviews.Count == 0)
                {
                <div class="prv-pro-profile-v2-reviews-empty">
                    <img src="~/images/profile-reviews-illustration.png" alt="" class="prv-pro-profile-v2-reviews-illus" aria-hidden="true" asp-append-version="true" />
                    <div class="prv-pro-profile-v2-reviews-copy">
                        <h4>@L["No reviews yet"]</h4>
                        <p>@L["Customer reviews will appear here after completed jobs."]</p>
                    </div>
                </div>
                }
                else
                {
                    @foreach (var review in Model.Reviews.Take(2))
                    {
                        <blockquote class="prv-pro-profile-v2-kv prv-pro-profile-v2-kv--review">
                            <strong>@review.Author · @review.Rating.ToString("0.0") ★</strong>
                            <span>@review.Comment</span>
                        </blockquote>
                    }
                }
            </section>

            <section class="prv-pro-profile-v2-card prv-pro-profile-card--support">
                <header class="prv-pro-profile-v2-card-head prv-pro-profile-v2-card-head--compact">
                    <div class="prv-pro-profile-v2-card-head-main">
                        <span class="prv-pro-profile-v2-card-icon"><i class="fas fa-life-ring"></i></span>
                        <div><h3>@L["Support &amp; Account"]</h3></div>
                    </div>
                </header>
                <a asp-controller="Proveedor" asp-action="HelpCenter" class="prv-pro-profile-link-row">
                    <i class="fas fa-book"></i>
                    <span>@L["Help Center"]</span>
                    <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
                </a>
                <a asp-controller="Proveedor" asp-action="Subscription" class="prv-pro-profile-link-row prv-pro-profile-link-row--plan">
                    <span><i class="fas fa-crown"></i> @L["Subscription / Plan"]</span>
                    <strong class="prv-pro-status-plan">@UiDisplayLocalization.Localize(L, Model.SubscriptionPlan)</strong>
                    <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
                </a>
                <a asp-controller="Proveedor" asp-action="Notifications" class="prv-pro-profile-link-row">
                    <i class="fas fa-bell"></i>
                    <span>@L["Notifications"]</span>
                    <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="prv-pro-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="prv-pro-profile-link-row prv-pro-profile-link-row--danger">
                        <span class="prv-pro-profile-link-row-label">
                            <i class="fas fa-right-from-bracket"></i> @L["Sign Out"]
                        </span>
                        <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
                    </button>
                </form>
                <a asp-controller="Account" asp-action="DeleteAccount" class="prv-pro-profile-link-row prv-pro-profile-link-row--danger">
                    <span class="prv-pro-profile-link-row-label">
                        <i class="fas fa-user-xmark"></i> @L["Delete account"]
                    </span>
                    <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
                </a>
            </section>
        </div>

        @if (!Model.IsApproved)
        {
            <div class="prv-pro-profile-v2-activation">
                <div class="prv-pro-profile-v2-activation-copy">
                    <div class="prv-pro-profile-v2-activation-title">
                        <span class="prv-pro-profile-v2-activation-icon"><i class="fas fa-shield-halved"></i></span>
                        <strong>@L["Complete your activation"]</strong>
                    </div>
                    <p>@L["Finish verification to unlock your full public profile and INDOR leads."]</p>
                    <a asp-controller="Proveedor" asp-action="ProfileCompletion">@L["Complete activation"]</a>
                </div>
            </div>
        }
    </div>
</div>

<div id="prvProfileToast" class="prv-pro-profile-toast" hidden role="status"></div>

@section Scripts {
<script src="~/js/provider-profile.js" asp-append-version="true"></script>
}
