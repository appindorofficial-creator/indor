@model IndorMvcApp.ViewModels.ProviderProProfilePageViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Profile - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "profile";
    var money = CultureInfo.GetCultureInfo("en-US");
    var initial = Model.CompanyInitial;
    ViewBag.CompanyInitial = initial;
    var allServices = Model.Categories.Concat(Model.Services).Distinct().ToList();
    var publicProfileUrl = Url.Action("PublicProfile", "Proveedor", null, Context.Request.Scheme);
}

<div class="prv-pro-shell prv-pro-shell--profile">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    <section class="prv-pro-jobs-head">
        <div>
            <h1>Profile</h1>
            <p>Your business profile and control center.</p>
        </div>
    </section>

    @if (TempData["ProfileSaved"] is true)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--success">
            <i class="fas fa-circle-check"></i> Profile updated successfully.
        </div>
    }
    @if (TempData["ProfilePhotoError"] is string photoError)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @photoError
        </div>
    }
    @if (TempData["ProfileSectionError"] is string sectionError)
    {
        <div class="prv-pro-edit-profile-alert prv-pro-edit-profile-alert--error">
            <i class="fas fa-circle-exclamation"></i> @sectionError
        </div>
    }

    <section class="prv-pro-profile-hero">
        <div class="prv-pro-profile-hero-main">
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <img src="@Url.Content($"~{Model.LogoUrl}")" alt="@Model.CompanyName" class="prv-pro-profile-logo prv-pro-profile-logo--img" />
            }
            else
            {
                <div class="prv-pro-profile-logo">@initial</div>
            }
            <div>
                <div class="prv-pro-profile-name-row">
                    <h2>@Model.CompanyName</h2>
                    @if (Model.IsVerified)
                    {
                        <span class="prv-pro-verified"><i class="fas fa-circle-check"></i> Verified Provider</span>
                    }
                    @if (Model.IsTopRated)
                    {
                        <span class="prv-pro-top-rated"><i class="fas fa-star"></i> Top Rated</span>
                    }
                </div>
                <p class="prv-pro-profile-specialties">@Model.SpecialtiesSummary</p>
                <p class="prv-pro-profile-area"><i class="fas fa-location-dot"></i> @Model.ServiceAreaLabel</p>
            </div>
        </div>
        <div class="prv-pro-profile-stats-row">
            <div class="prv-pro-profile-stat">
                <span>Provider Score <i class="fas fa-circle-info"></i></span>
                <strong>@(Model.ProviderScore > 0 ? Model.ProviderScore.ToString() : "—")</strong>
            </div>
            <div class="prv-pro-profile-stat">
                <span>Rating</span>
                <strong>@(Model.ReviewCount > 0 ? $"{Model.Rating:0.0} ★" : "—")</strong>
                <small>@(Model.ReviewCount > 0 ? $"{Model.ReviewCount} reviews" : "No reviews yet")</small>
            </div>
            <div class="prv-pro-profile-stat">
                <span>Jobs Completed</span>
                <strong>@Model.JobsCompletedThisYear</strong>
                <small>This Year</small>
            </div>
            <div class="prv-pro-profile-stat">
                <span>Home Records</span>
                <strong>@Model.HomeRecordsCreated</strong>
                <small>Created</small>
            </div>
        </div>
    </section>

    <section class="prv-pro-profile-quick">
        <a asp-controller="Proveedor" asp-action="EditProfile" class="prv-pro-profile-quick-btn"><i class="fas fa-pen"></i> Edit Profile</a>
        <a asp-controller="Proveedor" asp-action="PublicProfile" class="prv-pro-profile-quick-btn"><i class="fas fa-globe"></i> Public Profile</a>
        <a href="@publicProfileUrl"
           class="prv-pro-profile-quick-btn prv-pro-profile-quick-btn--share"
           id="prvProfileShareBtn"
           data-provider-share
           data-share-url="@publicProfileUrl"
           data-share-title="@Model.CompanyName - INDOR PRO"
           data-share-text="View my provider profile on INDOR"
           role="button">
            <i class="fas fa-share-nodes"></i> Share
        </a>
        <a asp-controller="Proveedor" asp-action="Settings" class="prv-pro-profile-quick-btn"><i class="fas fa-gear"></i> Settings</a>
    </section>

    <div class="prv-pro-profile-grid">
        <a asp-controller="Proveedor" asp-action="EditProfile" asp-route-section="business" class="prv-pro-profile-card prv-pro-profile-card--link" aria-label="Edit business information">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-building"></i> Business Information</h3><i class="fas fa-chevron-right"></i></header>
            @if (!string.IsNullOrWhiteSpace(Model.BusinessName) || !string.IsNullOrWhiteSpace(Model.DbaName))
            {
                <div class="prv-pro-profile-kv"><i class="fas fa-building"></i><span>@(string.IsNullOrWhiteSpace(Model.DbaName) ? Model.BusinessName : Model.DbaName)</span></div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.PrimaryContact))
            {
                <div class="prv-pro-profile-kv"><i class="fas fa-user"></i><span>@Model.PrimaryContact</span></div>
            }
            <div class="prv-pro-profile-kv"><i class="fas fa-phone"></i><span>@(string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone)</span></div>
            <div class="prv-pro-profile-kv"><i class="fas fa-envelope"></i><span>@(string.IsNullOrWhiteSpace(Model.Email) ? "—" : Model.Email)</span></div>
            <div class="prv-pro-profile-kv"><i class="fas fa-clock"></i><span>@Model.BusinessHours</span></div>
            @if (!string.IsNullOrWhiteSpace(Model.Website))
            {
                <div class="prv-pro-profile-kv"><i class="fas fa-globe"></i><span>@Model.Website</span></div>
            }
        </a>

        <a asp-controller="Proveedor" asp-action="EditProfile" asp-route-section="areas" class="prv-pro-profile-card prv-pro-profile-card--link" aria-label="Edit service areas">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-map-location-dot"></i> Service Areas</h3><i class="fas fa-chevron-right"></i></header>
            @if (Model.ServiceAreas.Count == 0)
            {
                <p class="prv-pro-empty">@Model.ServiceAreaLabel</p>
            }
            else
            {
                @foreach (var area in Model.ServiceAreas)
                {
                    <div class="prv-pro-profile-kv"><i class="fas fa-location-dot"></i><span>@area</span></div>
                }
            }
        </a>

        <a asp-controller="Proveedor" asp-action="EditProfileServices" class="prv-pro-profile-card prv-pro-profile-card--link" aria-label="Edit services offered">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-wrench"></i> Services Offered</h3><i class="fas fa-chevron-right"></i></header>
            @if (allServices.Count == 0)
            {
                <p class="prv-pro-empty">No services selected yet.</p>
            }
            else
            {
                <div class="prv-pro-profile-tags">
                    @foreach (var svc in allServices)
                    {
                        <span class="prv-pro-pill prv-pro-pill--scheduled">@svc</span>
                    }
                </div>
            }
        </a>

        <a asp-controller="Proveedor" asp-action="EditProfileVerification" class="prv-pro-profile-card prv-pro-profile-card--link" aria-label="Edit verification and documents">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-shield-halved"></i> Verification &amp; Documents</h3><i class="fas fa-chevron-right"></i></header>
            @foreach (var item in Model.VerificationItems)
            {
                <div class="prv-pro-profile-check @(item.IsComplete ? "is-complete" : "")">
                    <i class="fas @(item.IsComplete ? "fa-circle-check" : "fa-circle")"></i>
                    <span>@item.Label</span>
                </div>
            }
        </a>

        <a asp-controller="Proveedor" asp-action="EditProfilePayments" class="prv-pro-profile-card prv-pro-profile-card--link" aria-label="Edit payments and banking">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-credit-card"></i> Payments &amp; Banking</h3><i class="fas fa-chevron-right"></i></header>
            <div class="prv-pro-profile-kv-row">
                <span>Payout Account</span>
                <strong class="@(Model.PayoutConnected ? "prv-pro-status-ok" : "")">@(Model.PayoutConnected ? "Connected" : "Not connected")</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>Payment Processing</span>
                <strong class="@(Model.PaymentProcessingActive ? "prv-pro-status-ok" : "")">@(Model.PaymentProcessingActive ? "Active" : "Inactive")</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>Next Payout</span>
                <div>
                    <strong>@Model.NextPayoutAmount.ToString("C2", money)</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.NextPayoutDateLabel))
                    {
                        <small>@Model.NextPayoutDateLabel</small>
                    }
                </div>
            </div>
        </a>

        <section class="prv-pro-profile-card">
            <header class="prv-pro-profile-card-head">
                <h3><i class="fas fa-users"></i> Team Members</h3>
            </header>
            @if (Model.TeamMembers.Count == 0)
            {
                <p class="prv-pro-empty">No team members listed yet.</p>
            }
            else
            {
                @foreach (var member in Model.TeamMembers)
                {
                    <div class="prv-pro-profile-team-row">
                        <div class="prv-pro-profile-team-avatar"><i class="fas fa-user"></i></div>
                        <strong>@member.Name</strong>
                        <span class="prv-pro-pill prv-pro-pill--role-@member.RoleClass">@member.Role</span>
                    </div>
                }
            }
        </section>

        <section class="prv-pro-profile-card">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-robot"></i> Automation &amp; Tools</h3></header>
            <div class="prv-pro-profile-kv-row">
                <span>Auto reminders</span>
                <strong class="@(Model.AutoRemindersOn ? "prv-pro-status-ok" : "")">@(Model.AutoRemindersOn ? "ON" : "OFF")</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>Saved report templates</span>
                <strong>@Model.ReportTemplatesCount</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>Follow-up campaigns</span>
                <strong class="@(Model.FollowUpCampaignsActive ? "prv-pro-status-ok" : "")">@(Model.FollowUpCampaignsActive ? "Active" : "Inactive")</strong>
            </div>
            <div class="prv-pro-profile-kv-row">
                <span>AI assistant</span>
                <strong class="@(Model.AiAssistantEnabled ? "prv-pro-status-ok" : "")">@(Model.AiAssistantEnabled ? "Enabled" : "Disabled")</strong>
            </div>
        </section>

        <section class="prv-pro-profile-card">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-chart-line"></i> Performance</h3></header>
            <div class="prv-pro-profile-perf-grid">
                <div><strong>@Model.Performance.AvgResponseTime</strong><span>Avg. Response Time</span></div>
                <div><strong>@Model.Performance.CompletionRate</strong><span>Completion Rate</span></div>
                <div><strong>@Model.Performance.HomeownerApproval</strong><span>Homeowner Approval</span></div>
                <div><strong>@Model.Performance.HouseFactsAdded</strong><span>House Facts Added</span></div>
            </div>
        </section>

        <section class="prv-pro-profile-card prv-pro-profile-card--wide">
            <header class="prv-pro-profile-card-head">
                <h3><i class="fas fa-star"></i> Reviews</h3>
            </header>
            @if (Model.Reviews.Count == 0)
            {
                <div class="prv-pro-profile-reviews-empty">
                    <div class="prv-pro-profile-reviews-score">
                        <strong>—</strong>
                        <span>No reviews yet</span>
                    </div>
                    <p class="prv-pro-empty">Customer reviews will appear here after completed jobs.</p>
                </div>
            }
            else
            {
                <div class="prv-pro-profile-reviews-wrap">
                    <div class="prv-pro-profile-reviews-score">
                        <strong>@Model.Rating.ToString("0.0")</strong>
                        <span><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></span>
                        <small>Based on @Model.ReviewCount reviews</small>
                    </div>
                    <div class="prv-pro-profile-review-snippets">
                        @foreach (var review in Model.Reviews.Take(2))
                        {
                            <blockquote>
                                <span>@review.Author <i class="fas fa-star"></i> @review.Rating.ToString("0.0")</span>
                                <p>@review.Comment</p>
                            </blockquote>
                        }
                    </div>
                </div>
            }
        </section>

        <section class="prv-pro-profile-card prv-pro-profile-card--support">
            <header class="prv-pro-profile-card-head"><h3><i class="fas fa-life-ring"></i> Support &amp; Account</h3></header>
            <a asp-controller="Proveedor" asp-action="HelpCenter" class="prv-pro-profile-link-row">
                <i class="fas fa-book"></i>
                <span>Help Center</span>
                <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
            </a>
            <a asp-controller="Proveedor" asp-action="Subscription" class="prv-pro-profile-link-row prv-pro-profile-link-row--plan">
                <span><i class="fas fa-crown"></i> Subscription / Plan</span>
                <strong class="prv-pro-status-plan">@Model.SubscriptionPlan</strong>
                <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
            </a>
            <a asp-controller="Proveedor" asp-action="Notifications" class="prv-pro-profile-link-row">
                <i class="fas fa-bell"></i>
                <span>Notifications</span>
                <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="prv-pro-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="prv-pro-profile-signout">
                    <span><i class="fas fa-right-from-bracket"></i> Sign Out</span>
                </button>
            </form>
            <a asp-controller="Account" asp-action="DeleteAccount" class="prv-pro-profile-link-row" style="color:#B91C1C;">
                <i class="fas fa-user-xmark"></i>
                <span>Delete account</span>
                <i class="fas fa-chevron-right prv-pro-profile-link-chevron"></i>
            </a>
        </section>
    </div>

    @if (!Model.IsApproved)
    {
        <div class="prv-pro-activation-banner" style="margin-top:16px;">
            <div>
                <strong>Complete your activation</strong>
                <p>Finish verification to unlock your full public profile and INDOR leads.</p>
            </div>
            <a asp-controller="ProviderRegistration" asp-action="ActivationCall" class="prv-pro-activation-link">Complete activation</a>
        </div>
    }
</div>

<div id="prvProfileToast" class="prv-pro-profile-toast" hidden role="status"></div>

@section Scripts {
<script src="~/js/provider-profile.js" asp-append-version="true"></script>
}
