@model IndorMvcApp.ViewModels.InsuranceBusinessInfoStepViewModel
@{
    ViewData["Title"] = "Business & Owner Info - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    ViewData["ProviderProExtraCss"] = "insurance-quote.css";
}

<div class="prv-pro-shell ins-wiz@(Model.IsPremium ? " ins-wiz--premium" : "")">
    <header class="ins-hd">
        <a asp-controller="Proveedor" asp-action="InsuranceQuote" class="ins-hd-back" aria-label="Back"><i class="fas fa-arrow-left"></i></a>
        <div class="ins-hd-text">
            <h1>Business &amp; Owner Info</h1>
            <p>Tell us about your business so we can request your quote.</p>
        </div>
    </header>

    @await Html.PartialAsync("_InsuranceStepper", 2)

    <div class="ins-plancard">
        <span class="ins-plancard-icon"><i class="fas fa-shield-halved"></i></span>
        <div class="ins-plancard-name">
            <strong>@Model.PlanDisplayName@if (Model.IsPopular) {<span class="ins-popular">Most Popular</span>}</strong>
            <small>Your selected plan</small>
        </div>
        <div class="ins-plancard-price">
            <div><small>Pay today</small><strong>$@Model.PayToday.ToString("0")</strong></div>
            <div><small>Then</small><strong>$@Model.Monthly.ToString("0")<span>/month</span></strong></div>
        </div>
    </div>

    <form asp-controller="Proveedor" asp-action="InsuranceBusinessInfo" method="post">
        <div asp-validation-summary="ModelOnly" class="ins-error"></div>

        <div class="ins-fc">
            <div class="ins-bx">
                <span class="ins-bx-lbl">Trade / Industry</span>
                <div class="ins-bx-ctl">
                    <select asp-for="Trade" class="ins-bx-select">
                        <option value="">Select your trade or industry</option>
                        @foreach (var t in IndorMvcApp.ViewModels.InsuranceCatalog.Trades)
                        {
                            <option value="@t.Value" selected="@(Model.Trade == t.Value)">@t.Value</option>
                        }
                    </select>
                    <i class="fas fa-chevron-down ins-bx-caret"></i>
                </div>
            </div>

            <div class="ins-bx">
                <span class="ins-bx-lbl">Business Name</span>
                <div class="ins-bx-ctl">
                    <input asp-for="BusinessName" class="ins-bx-input" placeholder="Enter legal business name" />
                </div>
            </div>

            <div class="ins-bx">
                <span class="ins-bx-lbl">Street Address</span>
                <div class="ins-bx-ctl">
                    <input asp-for="StreetAddress" class="ins-bx-input" placeholder="Enter street address" />
                </div>
            </div>

            <div class="ins-bx-row ins-bx-row--3">
                <div class="ins-bx">
                    <span class="ins-bx-lbl">City</span>
                    <div class="ins-bx-ctl">
                        <input asp-for="City" class="ins-bx-input" placeholder="Enter city" />
                    </div>
                </div>
                <div class="ins-bx">
                    <span class="ins-bx-lbl">State</span>
                    <div class="ins-bx-ctl">
                        <select asp-for="State" class="ins-bx-select">
                            @foreach (var s in IndorMvcApp.ViewModels.InsuranceCatalog.States)
                            {
                                <option value="@s" selected="@(Model.State == s)">@s</option>
                            }
                        </select>
                        <i class="fas fa-chevron-down ins-bx-caret"></i>
                    </div>
                </div>
                <div class="ins-bx">
                    <span class="ins-bx-lbl">ZIP Code</span>
                    <div class="ins-bx-ctl">
                        <input asp-for="ZipCode" class="ins-bx-input" placeholder="Enter ZIP code" />
                    </div>
                </div>
            </div>

            <div class="ins-bx">
                <span class="ins-bx-lbl">Owner Name</span>
                <div class="ins-bx-ctl">
                    <input asp-for="OwnerName" class="ins-bx-input" placeholder="Enter owner full name" />
                </div>
            </div>

            <div class="ins-bx-row">
                <div class="ins-bx">
                    <span class="ins-bx-lbl">Owner Date of Birth</span>
                    <div class="ins-bx-ctl">
                        <input asp-for="OwnerDateOfBirth" type="date" class="ins-bx-input" placeholder="MM / DD / YYYY" />
                    </div>
                </div>
                <div class="ins-bx">
                    <span class="ins-bx-lbl">Owner Phone Number</span>
                    <div class="ins-bx-ctl">
                        <input asp-for="OwnerPhone" type="tel" class="ins-bx-input" placeholder="(000) 000-0000" />
                    </div>
                </div>
            </div>

            <div class="ins-bx">
                <span class="ins-bx-lbl">Owner Email</span>
                <div class="ins-bx-ctl">
                    <input asp-for="OwnerEmail" type="email" class="ins-bx-input" placeholder="Enter owner email address" />
                </div>
            </div>
        </div>

        <div class="ins-note ins-note--info">
            <i class="fas fa-circle-info"></i>
            <span><strong>ID may be requested by email.</strong> Your licensed insurance agent may ask for your SSN, ITIN, EIN, or business registration number after you submit. Please check your email for messages from INDOR.</span>
        </div>

        <div class="ins-footer ins-footer--split">
            <a asp-controller="Proveedor" asp-action="InsuranceQuote" class="ins-cta ins-cta--ghost">Back</a>
            <button type="submit" class="ins-cta">Continue</button>
        </div>
    </form>
</div>
