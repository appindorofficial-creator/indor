@model IndorMvcApp.ViewModels.ProviderProCreateJobQuoteViewModel
@{
    ViewData["Title"] = "Create Job - INDOR PRO";
    Layout = "_ProviderProLayout";
    var charCount = Model.QuoteRequestNotes?.Length ?? 0;
}

<div class="prv-pro-shell prv-pro-shell--create-job prv-pro-shell--wizard">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    @{
        ViewBag.WizardStepLine = $"Step {Model.StepNumber} of {Model.TotalSteps} · {Model.StepSubtitle}";
    }
    @await Html.PartialAsync("_CreateJobWizardHead")

    <section class="prv-pro-wizard-summary">
        <div>
            <small>Job type</small>
            <span class="prv-pro-wizard-type-icon prv-pro-wizard-type-icon--@Model.ServiceCategoryTone">
                <i class="fas @Model.ServiceCategoryIcon"></i>
            </span>
            <strong>@Model.ServiceCategoryLabel</strong>
        </div>
        <div>
            <small>Customer</small>
            <span class="prv-pro-customer-avatar prv-pro-customer-avatar--@Model.CustomerTone">@Model.CustomerInitials</span>
            <strong>@Model.CustomerName</strong>
        </div>
    </section>

    <form asp-controller="Proveedor" asp-action="CreateJobQuote" method="post" class="prv-pro-wizard-form" id="createJobQuoteForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="SendQuote" id="createJobSendQuote" value="@(Model.SendQuote ? "true" : "false")" />
        <input type="hidden" name="SubmitAction" id="createJobQuoteAction" value="ai" />

        <section class="prv-pro-wizard-card">
            <h2>Would you like to send a quote from INDOR?</h2>
            <p>You can write the request or record audio. INDOR's AI agent will use it to help build a detailed estimate.</p>

            <div class="prv-pro-quote-toggle">
                <button type="button" class="prv-pro-quote-toggle-btn @(Model.SendQuote ? "is-active" : "")" data-send="true">
                    <i class="fas fa-paper-plane"></i> Yes, send quote
                </button>
                <button type="button" class="prv-pro-quote-toggle-btn @(!Model.SendQuote ? "is-active" : "")" data-send="false">
                    Skip for now
                </button>
            </div>
        </section>

        <section class="prv-pro-wizard-card prv-pro-quote-inputs @(Model.SendQuote ? "" : "is-hidden")" id="createJobQuoteInputs">
            <label class="prv-pro-form-label">
                Describe what needs to be done
                <textarea name="QuoteRequestNotes" id="createJobQuoteNotes" rows="5" maxlength="@Model.MaxCharacters" placeholder="Describe the work, damage, and what the customer needs...">@Model.QuoteRequestNotes</textarea>
            </label>
            <div class="prv-pro-quote-charcount"><span id="createJobQuoteCount">@charCount</span> / @Model.MaxCharacters</div>

            <div class="prv-pro-quote-audio">
                <button type="button" class="prv-pro-quote-mic" title="Record audio"><i class="fas fa-microphone"></i></button>
                <div class="prv-pro-quote-audio-body">
                    <button type="button" class="prv-pro-quote-record-btn">Record audio</button>
                    <div class="prv-pro-quote-wave" aria-hidden="true">
                        @for (var i = 0; i < 24; i++) { <span></span> }
                    </div>
                    <small>00:00</small>
                </div>
            </div>
            <small class="prv-pro-wizard-hint">AI will transcribe audio automatically</small>

            <div class="prv-pro-quote-attachments">
                <h3>Add photos or inspection notes (optional)</h3>
                <div class="prv-pro-quote-attachment-list">
                    @foreach (var file in Model.Attachments)
                    {
                        <div class="prv-pro-quote-attachment" data-id="@file.Id">
                            @if (file.Kind == "image" && !string.IsNullOrWhiteSpace(file.ThumbnailUrl))
                            {
                                <img src="@file.ThumbnailUrl" alt="" />
                            }
                            else
                            {
                                <span class="prv-pro-quote-attachment-doc"><i class="fas fa-file-lines"></i></span>
                            }
                            <div>
                                <strong>@file.Name</strong>
                                <small>@file.SizeLabel</small>
                            </div>
                            <button type="button" class="prv-pro-quote-attachment-remove" title="Remove"><i class="fas fa-xmark"></i></button>
                        </div>
                    }
                </div>
            </div>
        </section>

        <div class="prv-pro-wizard-info">
            <i class="fas fa-circle-info"></i>
            <span>INDOR AI will read your notes, audio, and attachments to draft the quote.</span>
        </div>

        <div class="prv-pro-wizard-actions">
            <a asp-controller="Proveedor" asp-action="CreateJobDetails" class="prv-pro-btn prv-pro-btn--outline">Back</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary" id="createJobQuoteSubmit">Send to AI</button>
        </div>
    </form>

    @await Html.PartialAsync("_ProviderProWizardStepper", Model.WizardSteps)
</div>

@section Scripts {
    <script>
        (function () {
            var sendInput = document.getElementById('createJobSendQuote');
            var actionInput = document.getElementById('createJobQuoteAction');
            var submitBtn = document.getElementById('createJobQuoteSubmit');
            var inputs = document.getElementById('createJobQuoteInputs');
            var notes = document.getElementById('createJobQuoteNotes');
            var count = document.getElementById('createJobQuoteCount');
            var toggles = document.querySelectorAll('.prv-pro-quote-toggle-btn');

            function setSendQuote(enabled) {
                sendInput.value = enabled ? 'true' : 'false';
                actionInput.value = enabled ? 'ai' : 'skip';
                submitBtn.textContent = enabled ? 'Send to AI' : 'Continue';
                inputs?.classList.toggle('is-hidden', !enabled);
                toggles.forEach(function (btn) {
                    btn.classList.toggle('is-active', btn.dataset.send === (enabled ? 'true' : 'false'));
                });
            }

            toggles.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    setSendQuote(btn.dataset.send === 'true');
                });
            });

            notes?.addEventListener('input', function () {
                if (count) count.textContent = String(notes.value.length);
            });

            document.querySelectorAll('.prv-pro-quote-attachment-remove').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    btn.closest('.prv-pro-quote-attachment')?.remove();
                });
            });
        })();
    </script>
}
