@model IndorMvcApp.ViewModels.ProviderProDashboardViewModel
@using System.Globalization
@using IndorMvcApp.Services
@{
    ViewData["Title"] = L["INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    ViewBag.CompanyInitial = Model.CompanyInitial;
    var money = CultureInfo.GetCultureInfo("en-US");
}

<div class="prv-pro-shell prv-pro-shell--home">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)

    @if (Model.ActivationPending)
    {
        <div class="prv-pro-activation-banner prv-pro-activation-banner--v2" id="activationBanner">
            <span class="prv-pro-activation-icon" aria-hidden="true"><i class="fas fa-rocket"></i></span>
            <div class="prv-pro-activation-copy">
                <strong>@L["INDOR Activation Pending"]</strong>
                <p>@L["Complete verification and activation to unlock INDOR leads."]</p>
                <a asp-controller="ProviderRegistration" asp-action="ActivationCall" class="prv-pro-activation-link">@L["Complete activation"]</a>
            </div>
            <button type="button" class="prv-pro-activation-dismiss" aria-label="@L["Dismiss"]" onclick="document.getElementById('activationBanner').style.display='none'">
                <i class="fas fa-xmark"></i>
            </button>
        </div>
    }

    <a asp-controller="Proveedor" asp-action="Profile" class="prv-pro-home-profile-card">
        <div class="prv-pro-home-profile-top">
            <span class="prv-pro-home-profile-icon" aria-hidden="true"><i class="fas fa-building"></i></span>
            <div class="prv-pro-home-profile-text">
                <p class="prv-pro-home-greeting" data-indor-greeting data-indor-greeting-suffix=",">@Model.Greeting,</p>
                <h1>@Model.CompanyName</h1>
                @if (Model.IsVerified)
                {
                    <span class="prv-pro-verified"><i class="fas fa-circle-check"></i> @L["Verified Provider"]</span>
                }
                else if (Model.IsProActive)
                {
                    <span class="prv-pro-verified prv-pro-verified--pro"><i class="fas fa-circle-check"></i> @L["INDOR Pro Active"]</span>
                }
                else
                {
                    <span class="prv-pro-verified prv-pro-verified--pending"><i class="fas fa-clock"></i> @L["Activation in progress"]</span>
                }
            </div>
            <i class="fas fa-chevron-right prv-pro-home-profile-chevron"></i>
        </div>
        @if (Model.IsProActive || Model.ProviderScore > 0)
        {
            <div class="prv-pro-home-progress">
                <div class="prv-pro-home-progress-copy">
                    <strong class="prv-pro-home-score">@(Model.ProviderScore > 0 ? Model.ProviderScore : 82)</strong>
                    <div>
                        <span class="prv-pro-home-score-label">@UiDisplayLocalization.Localize(L, Model.ScoreLabel)</span>
                        <small>@UiDisplayLocalization.Localize(L, Model.ScoreSubtext)</small>
                    </div>
                </div>
                <div class="prv-pro-progress-ring" style="--progress: @(Model.ProviderScore > 0 ? Model.ProviderScore : 82)">
                    <svg viewBox="0 0 36 36" aria-hidden="true">
                        <path class="prv-pro-progress-ring-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        <path class="prv-pro-progress-ring-fill" stroke-dasharray="@(Model.ProviderScore > 0 ? Model.ProviderScore : 82), 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    </svg>
                    <span>@(Model.ProviderScore > 0 ? Model.ProviderScore : 82)%</span>
                </div>
            </div>
        }
    </a>

    <section class="prv-pro-home-metrics">
        <a asp-controller="Proveedor" asp-action="Jobs" asp-route-tab="today" class="prv-pro-home-metric">
            <span class="prv-pro-home-metric-icon prv-pro-home-metric-icon--blue"><i class="fas fa-calendar-days"></i></span>
            <div class="prv-pro-home-metric-copy">
                <strong><span class="prv-pro-home-metric-num">@Model.Metrics.JobsToday</span> @L["Jobs Today"]</strong>
                <em>@L["View all"]<i class="fas fa-chevron-right"></i></em>
            </div>
        </a>
        <a asp-controller="Proveedor" asp-action="NewLeads" class="prv-pro-home-metric">
            <span class="prv-pro-home-metric-icon prv-pro-home-metric-icon--green"><i class="fas fa-user-plus"></i></span>
            <div class="prv-pro-home-metric-copy">
                <strong><span class="prv-pro-home-metric-num">@Model.Metrics.NewLeads</span> @L["New Leads"]</strong>
                <em>@L["See leads"]<i class="fas fa-chevron-right"></i></em>
            </div>
        </a>
        <a asp-controller="Proveedor" asp-action="PendingEstimates" class="prv-pro-home-metric">
            <span class="prv-pro-home-metric-icon prv-pro-home-metric-icon--amber"><i class="fas fa-file-invoice"></i></span>
            <div class="prv-pro-home-metric-copy">
                <strong><span class="prv-pro-home-metric-num">@Model.Metrics.PendingEstimates</span> @L["Pending Estimates"]</strong>
                <em>@L["Review"]<i class="fas fa-chevron-right"></i></em>
            </div>
        </a>
        <a asp-controller="Proveedor" asp-action="Invoices" asp-route-tab="overdue" class="prv-pro-home-metric">
            <span class="prv-pro-home-metric-icon prv-pro-home-metric-icon--purple"><i class="fas fa-file-invoice-dollar"></i></span>
            <div class="prv-pro-home-metric-copy">
                <strong><span class="prv-pro-home-metric-num">@Model.Metrics.PaymentsDue.ToString("C0", money)</span> @L["Payments Due"]</strong>
                <em>@L["View invoices"]<i class="fas fa-chevron-right"></i></em>
            </div>
        </a>
    </section>

    <a asp-controller="Proveedor" asp-action="Network" class="prv-pro-net-banner">
        <span class="prv-pro-net-banner-ic"><i class="fas fa-people-group"></i></span>
        <div class="prv-pro-net-banner-body">
            <strong>@L["Contractor Network"]</strong>
            <span>@L["Find, verify &amp; hire verified subcontractors"]</span>
        </div>
        <i class="fas fa-chevron-right"></i>
    </a>

    <section class="prv-pro-quick prv-pro-quick--home">
        <h2>@L["Quick Actions"]</h2>
        <div class="prv-pro-quick-grid prv-pro-quick-grid--home">
            <a asp-controller="Proveedor" asp-action="AvailableRequests" class="prv-pro-quick-item prv-pro-quick-item--green">
                <i class="fas fa-bell-concierge"></i><span>@L["Available Requests"]</span>
            </a>
            <a asp-controller="Proveedor" asp-action="CreateJob" asp-route-from="home" class="prv-pro-quick-item prv-pro-quick-item--blue">
                <i class="fas fa-briefcase"></i><span>@L["New Job"]</span>
            </a>
            <a asp-controller="Proveedor" asp-action="CreateEstimate" class="prv-pro-quick-item prv-pro-quick-item--green">
                <i class="fas fa-file-invoice-dollar"></i><span>@L["New Estimate"]</span>
            </a>
            <a asp-controller="Proveedor" asp-action="AddCustomer" asp-route-fresh="true" class="prv-pro-quick-item prv-pro-quick-item--indigo">
                <i class="fas fa-user-plus"></i><span>@L["Add Customer"]</span>
            </a>
            <a asp-controller="Proveedor" asp-action="ReportTemplates" class="prv-pro-quick-item prv-pro-quick-item--orange">
                <i class="fas fa-file-lines"></i><span>@L["Create Report"]</span>
            </a>
        </div>
    </section>

    @if (ProfileDisplayService.ProviderInsuranceSalesEnabled)
    {
    <section class="prv-pro-ins" aria-labelledby="prvInsTitle">
        <div class="prv-pro-ins-card">
            <div class="prv-pro-ins-head">
                <span class="prv-pro-ins-shield" aria-hidden="true"><i class="fas fa-shield-halved"></i></span>
                <div class="prv-pro-ins-head-text">
                    <h3 id="prvInsTitle">@L["Join INDOR Pro"]</h3>
                    <p>@L["Grow with INDOR benefits, security and backing included."]</p>
                </div>
                <div class="prv-pro-ins-head-side">
                    @if (Model.IsInsured)
                    {
                        <span class="prv-pro-ins-state prv-pro-ins-state--ok"><i class="fas fa-circle-check"></i> @L["Insured"]</span>
                    }
                    else
                    {
                        <span class="prv-pro-ins-state prv-pro-ins-state--warn"><i class="fas fa-circle-exclamation"></i> @L["Not insured"]</span>
                    }
                </div>
            </div>

            <div class="prv-pro-ins-body">
                <ul class="prv-pro-ins-benefits">
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-id-badge"></i></span> @L["Professional profile within INDOR"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-eye"></i></span> @L["More visibility in the app"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-briefcase"></i></span> @L["More job opportunities"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-people-group"></i></span> @L["More trust with customers"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-file-lines"></i></span> @L["COI / proof from the app"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-house"></i></span> @L["Property damage claim support"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-gavel"></i></span> @L["Legal defense support"]</li>
                    <li><span class="prv-pro-ins-bic"><i class="fas fa-shield-halved"></i></span> @L["Security and backing included"]</li>
                </ul>
                <img src="~/images/insurance/ins-certificate.png" alt="" class="prv-pro-ins-illus" asp-append-version="true" />
            </div>

            @{
                var pBasic = IndorMvcApp.ViewModels.InsuranceCatalog.Pricing("basic");
                var pStandard = IndorMvcApp.ViewModels.InsuranceCatalog.Pricing("standard");
                var pPremium = IndorMvcApp.ViewModels.InsuranceCatalog.Pricing("premium");
            }
            <div class="prv-pro-ins-plans">
                <a asp-controller="Proveedor" asp-action="InsuranceQuote" asp-route-plan="basic" class="prv-pro-ins-plan prv-pro-ins-plan--basic">
                    <div class="prv-pro-ins-plan-head">
                        <div class="prv-pro-ins-plan-name">
                            <strong>@L["Basic"]</strong>
                            <small>@L["Membership + INDOR benefits"]</small>
                        </div>
                        <i class="fas fa-shield-halved prv-pro-ins-plan-shield prv-pro-ins-plan-shield--blue"></i>
                    </div>
                    <div class="prv-pro-ins-plan-price">$@pBasic.Monthly.ToString("0")<span>/mo</span></div>
                    <div class="prv-pro-ins-plan-down">@L["Initial activation"] $@pBasic.PayToday.ToString("0")</div>
                </a>

                <a asp-controller="Proveedor" asp-action="InsuranceQuote" asp-route-plan="standard" class="prv-pro-ins-plan prv-pro-ins-plan--standard is-popular">
                    <span class="prv-pro-ins-plan-badge">@L["MOST POPULAR"]</span>
                    <div class="prv-pro-ins-plan-head">
                        <div class="prv-pro-ins-plan-name">
                            <strong>@L["Standard"]</strong>
                            <small>@L["Membership + INDOR benefits"]</small>
                        </div>
                        <i class="fas fa-shield-halved prv-pro-ins-plan-shield prv-pro-ins-plan-shield--green"></i>
                    </div>
                    <div class="prv-pro-ins-plan-price">$@pStandard.Monthly.ToString("0")<span>/mo</span></div>
                    <div class="prv-pro-ins-plan-down">@L["Initial activation"] $@pStandard.PayToday.ToString("0")</div>
                </a>

                <a asp-controller="Proveedor" asp-action="InsuranceQuote" asp-route-plan="premium" class="prv-pro-ins-plan prv-pro-ins-plan--premium">
                    <div class="prv-pro-ins-plan-head">
                        <div class="prv-pro-ins-plan-name">
                            <strong>@L["Premium"]</strong>
                            <small>@L["Membership + INDOR benefits"]</small>
                        </div>
                        <i class="fas fa-shield-halved prv-pro-ins-plan-shield prv-pro-ins-plan-shield--purple"></i>
                    </div>
                    <div class="prv-pro-ins-plan-price">$@pPremium.Monthly.ToString("0")<span>/mo</span></div>
                    <div class="prv-pro-ins-plan-down">@L["Initial activation"] $@pPremium.PayToday.ToString("0")</div>
                </a>
            </div>

            <div class="prv-pro-ins-cta-row">
                <a asp-controller="Proveedor" asp-action="InsuranceQuote" asp-route-plan="standard" class="prv-pro-ins-cta prv-pro-ins-cta--solid">@L["Get Standard Plan"]</a>
                <a asp-controller="Proveedor" asp-action="InsurancePlans" class="prv-pro-ins-cta prv-pro-ins-cta--ghost">@L["View Plans"]</a>
            </div>
        </div>
    </section>
    }

    <section class="prv-pro-home-jobs">
        <div class="prv-pro-home-jobs-head">
            <h2><i class="fas fa-clipboard-list"></i> @L["Today's Jobs"]</h2>
        </div>
        @if (Model.TodaysJobs.Count == 0)
        {
            <div class="prv-pro-home-jobs-empty">
                <p class="prv-pro-empty">@L["No jobs scheduled for today."]</p>
            </div>
        }
        else
        {
            @foreach (var job in Model.TodaysJobs)
            {
                <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@job.Id" class="prv-pro-home-job-row">
                    <span class="prv-pro-home-job-icon prv-pro-home-job-icon--@job.IconTone"><i class="fas @job.IconClass"></i></span>
                    <div class="prv-pro-home-job-body">
                        <strong>@UiDisplayLocalization.Localize(L, job.Title)</strong>
                        <small>@UiDisplayLocalization.Localize(L, job.TimeLabel)@if (!string.IsNullOrWhiteSpace(job.Address)) { <text> &bull; @job.Address</text> }</small>
                    </div>
                    <span class="prv-pro-pill prv-pro-pill--@job.StatusClass">@UiDisplayLocalization.Localize(L, job.Status)</span>
                </a>
            }
        }
        <div class="prv-pro-home-jobs-actions">
            <a asp-controller="Proveedor" asp-action="Jobs" asp-route-tab="today" class="prv-pro-home-jobs-action prv-pro-home-jobs-action--schedule">
                @L["View all"] <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    </section>
</div>
