@model IndorMvcApp.ViewModels.NetworkHomeViewModel
@{
    ViewData["Title"] = L["Contractor Network"];
    Layout = "_ProviderProLayout";
    ViewData["ProviderProExtraCss"] = "provider-network.css";
    ViewBag.NavActive = "jobs";
}

<div class="prv-net-shell">
    <header class="prv-net-hero">
        <div class="prv-net-hero-top">
            <a asp-controller="Proveedor" asp-action="Dashboard" class="prv-net-brand" aria-label="@L["INDOR PRO home"]">
                <span class="prv-net-brand-word">@L["INDOR"]</span>
                <span class="prv-net-brand-pro">@L["PRO"]</span>
            </a>
            @await Component.InvokeAsync("ProviderProNotifications", new { tone = "inverse" })
        </div>

        <div class="prv-net-hero-title">
            <div>
                <h1>@L["Jobs"]</h1>
                <p>@L["Find and verify subcontractors faster."]</p>
            </div>
            <a asp-controller="Proveedor" asp-action="PostNetworkJob" class="prv-net-create">
                <i class="fas fa-plus"></i> @L["Post a Job"]
            </a>
        </div>

        <form method="get" asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-net-searchbar">
            <div class="prv-net-search">
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" placeholder="@L["Search subcontractors, trades, or services"]" />
            </div>
            <button type="submit" class="prv-net-filter"><i class="fas fa-sliders"></i> @L["Filter"]</button>
        </form>
    </header>

    @if (TempData["NetworkToast"] is string toast && !string.IsNullOrWhiteSpace(toast))
    {
        <div class="prv-net-toast"><i class="fas fa-circle-check"></i> @UiDisplayLocalization.Localize(L, toast)</div>
    }

    <div class="prv-net-toggle">
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-view="list" class="is-active"><i class="fas fa-list"></i> @L["Feed"]</a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-view="map"><i class="fas fa-map-location-dot"></i> @L["Map"]</a>
    </div>

    @if (Model.TradeChips.Count > 0)
    {
        <div class="prv-net-chips">
            <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-net-chip is-active"><i class="fas fa-border-all"></i> @L["All"]</a>
            @foreach (var chip in Model.TradeChips)
            {
                <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-trade="@chip.Id" class="prv-net-chip">
                    <i class="fas @chip.IconClass"></i> @UiDisplayLocalization.Localize(L, chip.Label)
                </a>
            }
        </div>
    }

    <section class="prv-net-illus-cards">
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-net-illus-card">
            <div class="prv-net-illus-head">
                <div>
                    <strong>@L["Find Subcontractors"]</strong>
                    <span>@L["Search and connect with verified pros."]</span>
                </div>
                <span class="prv-net-illus-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
            </div>
            <img src="~/images/network/find-subcontractors.png" alt="@L["Find subcontractors"]" class="prv-net-illus-img prv-net-illus-img--workers" asp-append-version="true" />
        </a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-trade="all" class="prv-net-illus-card">
            <div class="prv-net-illus-head">
                <div>
                    <strong>@L["Service Providers"]</strong>
                    <span>@L["Browse trusted specialists by trade or service."]</span>
                </div>
                <span class="prv-net-illus-badge">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
            </div>
            <img src="~/images/network/service-providers.png" alt="@L["Service providers"]" class="prv-net-illus-img prv-net-illus-img--services" asp-append-version="true" />
        </a>
    </section>

    <section class="prv-net-tools">
        <a asp-controller="Proveedor" asp-action="VerifyContractors" class="prv-net-tool">
            <span class="prv-net-tool-ic prv-net-tool-ic--blue">
                <svg viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M12 2 4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3zm-1.03 13.03L7.7 11.7l1.41-1.41 2.12 2.12 4.42-4.42 1.41 1.41-5.84 5.83z"/></svg>
            </span>
            <div>
                <strong>@L["Verified Subcontractors"]</strong>
                <span>@L.T("{0} insured, qualified pros near you", Model.VerifiedSubcontractorsCount)</span>
            </div>
            <span class="prv-net-tool-arrow" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
        </a>
        <a asp-controller="Proveedor" asp-action="FindSubcontractors" asp-route-docs="true" class="prv-net-tool">
            <span class="prv-net-tool-ic prv-net-tool-ic--purple">
                <svg viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2 5 5h-5V4zM8 13h8v2H8v-2zm0 4h8v2H8v-2z"/></svg>
            </span>
            <div>
                <strong>@L["Insurance &amp; Docs"]</strong>
                <span>@L["See insurance active and documents ready"]</span>
            </div>
            <span class="prv-net-tool-arrow" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
        </a>
        <a asp-controller="Proveedor" asp-action="PostNetworkJob" class="prv-net-tool">
            <span class="prv-net-tool-ic prv-net-tool-ic--green">
                <svg viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M11 11V4h2v7h7v2h-7v7h-2v-7H4v-2h7z"/></svg>
            </span>
            <div>
                <strong>@L["Post a Job"]</strong>
                <span>@L["Get matched with subcontractors fast"]</span>
            </div>
            <span class="prv-net-tool-arrow" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
        </a>
        <a asp-controller="Proveedor" asp-action="MyRequests" class="prv-net-tool">
            <span class="prv-net-tool-ic prv-net-tool-ic--amber">
                <svg viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M9 2h6a1 1 0 0 1 1 1v2h4a2 2 0 0 1 2 2v13a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h4V3a1 1 0 0 1 1-1zm1 3h4V4h-4v1zm-1 9.17 2.59 2.59L14 13l1.41 1.41L10 19.83 4.59 14.41 6 13l4 4 4-4.83z"/></svg>
            </span>
            <div>
                <strong>@L["My Requests"]</strong>
                <span>@L.T("{0} posted • {1} hires", Model.MyRequestsCount, Model.ActiveHiresCount)</span>
            </div>
            <span class="prv-net-tool-arrow" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></span>
        </a>
    </section>

    @if (Model.FeaturedSubcontractors.Count > 0)
    {
        <div class="prv-net-sec-head">
            <h2>@L["Verified Subcontractors"]</h2>
            <a asp-controller="Proveedor" asp-action="FindSubcontractors" class="prv-net-sort">@L["See all"]<i class="fas fa-chevron-right"></i></a>
        </div>
        <div class="prv-net-list">
            @foreach (var sub in Model.FeaturedSubcontractors.Take(3))
            {
                @await Html.PartialAsync("_NetworkSubcontractorCard", sub)
            }
        </div>
    }

    <section class="prv-net-why">
        <div class="prv-net-why-head"><i class="fas fa-circle-info"></i> @L["Why contractors use INDOR"]</div>
        <div class="prv-net-why-grid">
            <div class="prv-net-why-item"><i class="fas fa-circle-check"></i> @L["Verified"]</div>
            <div class="prv-net-why-item"><i class="fas fa-shield-halved"></i> @L["Insurance Active"]</div>
            <div class="prv-net-why-item"><i class="fas fa-file-lines"></i> @L["Docs Ready"]</div>
            <div class="prv-net-why-item"><i class="fas fa-bolt"></i> @L["Faster Hiring"]</div>
        </div>
    </section>
</div>
