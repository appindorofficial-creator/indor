@model IndorMvcApp.ViewModels.ProviderProConversationViewModel
@{
    ViewData["Title"] = "Conversation - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
}

<div class="prv-pro-shell prv-pro-shell--conversation">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="Messages" class="prv-pro-lead-back"><i class="fas fa-arrow-left"></i></a>
        <div>
            <h1>Conversation</h1>
        </div>
        <span class="prv-pro-step-badge">Step @Model.StepNumber of @Model.TotalSteps</span>
    </header>

    <section class="prv-pro-conversation-contact">
        <div class="prv-pro-conversation-avatar">@Model.CustomerInitials</div>
        <div>
            <strong>@Model.CustomerName</strong>
            @if (Model.IsCustomerOnline)
            {
                <span class="prv-pro-online"><i></i> Online</span>
            }
        </div>
        <div class="prv-pro-conversation-contact-actions">
            @if (!string.IsNullOrEmpty(Model.CustomerPhone))
            {
                <a href="tel:@Model.CustomerPhone" class="prv-pro-icon-btn" title="Call"><i class="fas fa-phone"></i></a>
            }
            <button type="button" class="prv-pro-icon-btn" title="Info"><i class="fas fa-circle-info"></i></button>
        </div>
    </section>

    <div class="prv-pro-conversation-context">
        @if (Model.JobId.HasValue)
        {
            <a asp-controller="Proveedor" asp-action="JobDetails" asp-route-id="@Model.JobId" class="prv-pro-context-card">
                <i class="fas fa-briefcase"></i>
                <span>View Job</span>
                <strong>#@Model.JobCode</strong>
                <small>@Model.JobTitle</small>
            </a>
        }
        @if (!string.IsNullOrEmpty(Model.PropertyAddress))
        {
            <div class="prv-pro-context-card prv-pro-context-card--static">
                <i class="fas fa-house"></i>
                <span>View Property</span>
                <small>@Model.PropertyAddress</small>
            </div>
        }
        @if (Model.EstimateId.HasValue)
        {
            <a asp-controller="Proveedor" asp-action="EditEstimate" asp-route-id="@Model.EstimateId" class="prv-pro-context-card">
                <i class="fas fa-file-invoice-dollar"></i>
                <span>View Estimate</span>
                <strong>#@Model.EstimateCode</strong>
                <small>@Model.EstimateAmountLabel</small>
            </a>
        }
    </div>

    <section class="prv-pro-chat-history">
        <div class="prv-pro-chat-date">Today</div>
        @foreach (var msg in Model.Messages)
        {
            <div class="prv-pro-chat-bubble prv-pro-chat-bubble--@(msg.SenderType == "Provider" ? "out" : "in")">
                <p>@msg.Body</p>
                <small>
                    @msg.TimeLabel
                    @if (msg.SenderType == "Provider")
                    {
                        <i class="fas fa-check-double @(msg.IsRead ? "is-read" : "")"></i>
                    }
                </small>
            </div>
        }
    </section>

    <div class="prv-pro-chat-quick-bar">
        <a asp-controller="Proveedor" asp-action="MessageQuickActions" asp-route-id="@Model.ConversationId" class="prv-pro-chat-quick-item">
            <i class="fas fa-paper-plane"></i><span>Send update</span>
        </a>
        <a asp-controller="Proveedor" asp-action="MessageQuickActions" asp-route-id="@Model.ConversationId" asp-route-action="estimate" class="prv-pro-chat-quick-item">
            <i class="fas fa-file-invoice-dollar"></i><span>Share estimate</span>
        </a>
        <a asp-controller="Proveedor" asp-action="UploadReport" class="prv-pro-chat-quick-item">
            <i class="fas fa-camera"></i><span>Upload photos</span>
        </a>
        <a asp-controller="Proveedor" asp-action="MessageQuickActions" asp-route-id="@Model.ConversationId" class="prv-pro-chat-quick-item">
            <i class="fas fa-ellipsis"></i><span>More actions</span>
        </a>
    </div>

    <form method="post" asp-controller="Proveedor" asp-action="Conversation" class="prv-pro-chat-compose">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ConversationId" value="@Model.ConversationId" />
        <button type="button" class="prv-pro-chat-attach" title="Attach"><i class="fas fa-plus"></i></button>
        <input type="text" name="Body" placeholder="Write a message..." required />
        <button type="submit" class="prv-pro-chat-send" title="Send"><i class="fas fa-paper-plane"></i></button>
    </form>
</div>
