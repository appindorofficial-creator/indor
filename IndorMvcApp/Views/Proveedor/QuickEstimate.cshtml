@model IndorMvcApp.ViewModels.ProviderProQuickEstimateViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Quick Estimate - INDOR PRO";
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "home";
    var money = CultureInfo.GetCultureInfo("en-US");
    var steps = new[] { ("service", "Service"), ("scope", "Scope"), ("price", "Price"), ("review", "Review") };
}

<div class="prv-pro-shell prv-pro-shell--estimate">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head">
        <a asp-controller="Proveedor" asp-action="SelectRepairItems" asp-route-id="@Model.LeadId" class="prv-pro-lead-back"><i class="fas fa-arrow-left"></i></a>
        <div><h1>Quick Estimate</h1></div>
    </header>

    @if (TempData["EstimateDraftSaved"] as bool? == true)
    {
        <div class="prv-pro-lead-toast">Estimate draft saved.</div>
    }

    <section class="prv-pro-estimate-summary">
        <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Property" />
        <div>
            <strong>@Model.Address</strong>
            <div class="prv-pro-lead-badges">
                <span class="prv-pro-pill prv-pro-pill--scheduled"><i class="fas fa-wrench"></i> @Model.ServiceType</span>
                @if (Model.IsHighUrgency)
                {
                    <span class="prv-pro-pill prv-pro-pill--urgency"><i class="fas fa-fire"></i> @Model.Urgency</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.DistanceLabel))
                {
                    <span class="prv-pro-pill prv-pro-pill--connected">@Model.DistanceLabel</span>
                }
            </div>
        </div>
    </section>

    <section class="prv-pro-lead-section prv-pro-estimate-customer">
        <div class="prv-pro-lead-homeowner-main">
            <div class="prv-pro-lead-homeowner-avatar">@Model.CustomerInitials</div>
            <div>
                <strong>@Model.CustomerName</strong>
                @if (Model.IsHomeownerVerified)
                {
                    <span class="prv-pro-verified"><i class="fas fa-circle-check"></i> Verified Homeowner</span>
                }
            </div>
        </div>
    </section>

    @await Html.PartialAsync("_ProviderProLeadJobContext", Model)

    <nav class="prv-pro-estimate-stepper" aria-label="Estimate steps">
        @foreach (var (id, label) in steps)
        {
            <span class="@(Model.ActiveStep == id ? "is-active" : id == "service" || (id == "scope") ? "is-done" : "")">@label</span>
        }
    </nav>

    <form asp-controller="Proveedor" asp-action="QuickEstimate" method="post" class="prv-pro-estimate-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="LeadId" value="@Model.LeadId" />
        @if (Model.EstimateId.HasValue)
        {
            <input type="hidden" name="EstimateId" value="@Model.EstimateId" />
        }

        <label class="prv-pro-create-field">
            <i class="fas fa-wrench"></i>
            <span>Service Type</span>
            <input type="text" name="ServiceType" value="@Model.ServiceType" />
        </label>

        <section class="prv-pro-lead-section prv-pro-scope-section">
            <h3>Scope of Work</h3>
            @if (Model.ScopeItems.Count == 0)
            {
                <p class="prv-pro-lead-hint">No line items yet. Add repair items from the job details above or create your own.</p>
            }
            <ol class="prv-pro-scope-list prv-pro-scope-list--cards" id="scopeItemsList">
                @for (var i = 0; i < Model.ScopeItems.Count; i++)
                {
                    var item = Model.ScopeItems[i];
                    var rowTotal = item.LaborAmount + item.MaterialAmount > 0
                        ? item.LaborAmount + item.MaterialAmount
                        : item.Amount;
                    <li class="prv-pro-scope-card">
                        <label class="prv-pro-scope-field prv-pro-scope-field--item">
                            <span>Repair item</span>
                            <input type="text" name="ScopeLabels" value="@item.Label" />
                        </label>
                        <div class="prv-pro-scope-amounts">
                            <label class="prv-pro-scope-field">
                                <span>Labor</span>
                                <input type="number" name="ScopeLaborAmounts" value="@item.LaborAmount.ToString("0")" step="1" min="0" inputmode="numeric" class="scope-labor" />
                            </label>
                            <label class="prv-pro-scope-field">
                                <span>Material</span>
                                <input type="number" name="ScopeMaterialAmounts" value="@item.MaterialAmount.ToString("0")" step="1" min="0" inputmode="numeric" class="scope-material" />
                            </label>
                            <label class="prv-pro-scope-field prv-pro-scope-field--total">
                                <span>Total</span>
                                <input type="number" name="ScopeAmounts" value="@rowTotal.ToString("0")" step="1" min="0" class="scope-total" readonly tabindex="-1" />
                            </label>
                        </div>
                    </li>
                }
            </ol>
            <button type="button" class="prv-pro-link-more" id="addScopeItem">+ Add Item</button>
        </section>

        <section class="prv-pro-estimate-pricing prv-pro-estimate-pricing--cards">
            <h3>Additional Costs</h3>
            <label class="prv-pro-estimate-cost-row">
                <span>Service Call / Assessment</span>
                <input type="number" name="LaborAmount" value="@Model.LaborAmount.ToString("0")" step="1" min="0" inputmode="numeric" />
            </label>
            <label class="prv-pro-estimate-cost-row">
                <span>Materials &amp; Tools</span>
                <input type="number" name="MaterialsAmount" value="@Model.MaterialsAmount.ToString("0")" step="1" min="0" inputmode="numeric" />
            </label>
            <div class="prv-pro-estimate-total">
                <span>Total Estimate</span>
                <strong id="estimateGrandTotal">@Model.TotalAmount.ToString("C0", money)</strong>
            </div>
        </section>

        <div class="prv-pro-estimate-meta-grid">
            <div class="prv-pro-lead-section">
                <h3><i class="fas fa-calendar"></i> Timeline</h3>
                <input type="text" name="Timeline" value="@Model.Timeline" class="prv-pro-estimate-inline-input" />
                <small>Estimated completion</small>
            </div>
            <div class="prv-pro-lead-section">
                <h3><i class="fas fa-shield"></i> Warranty</h3>
                <input type="text" name="Warranty" value="@Model.Warranty" class="prv-pro-estimate-inline-input" />
            </div>
        </div>

        <label class="prv-pro-create-field prv-pro-create-field--notes">
            <i class="fas fa-note-sticky"></i>
            <span>Notes to Homeowner</span>
            <textarea name="HomeownerNotes" rows="3">@Model.HomeownerNotes</textarea>
        </label>

        <div class="prv-pro-ai-banner">
            <i class="fas fa-wand-magic-sparkles"></i>
            <div>
                <strong>AI Estimate Assistant</strong>
                <small>I can suggest pricing based on local data and job complexity.</small>
            </div>
            <button type="button" class="prv-pro-btn prv-pro-btn--ghost">Suggest Prices</button>
        </div>

        <footer class="prv-pro-estimate-footer">
            <button type="submit" name="SaveAsDraft" value="true" class="prv-pro-btn prv-pro-btn--ghost">
                <i class="fas fa-floppy-disk"></i> Save Draft
            </button>
            <button type="submit" name="GoToReview" value="true" class="prv-pro-btn prv-pro-btn--primary">
                <i class="fas fa-paper-plane"></i> Review &amp; Send
            </button>
        </footer>
    </form>
</div>

@section Scripts {
<script>
(function () {
    const addBtn = document.getElementById('addScopeItem');
    const list = document.getElementById('scopeItemsList');
    const grandTotal = document.getElementById('estimateGrandTotal');
    const form = document.querySelector('.prv-pro-estimate-form');

    function recalcRow(row) {
        const labor = parseFloat(row.querySelector('.scope-labor')?.value || '0');
        const material = parseFloat(row.querySelector('.scope-material')?.value || '0');
        const totalInput = row.querySelector('.scope-total');
        if (totalInput) totalInput.value = String(Math.round(labor + material));
    }

    function recalcGrand() {
        let sum = 0;
        list?.querySelectorAll('li').forEach(row => {
            recalcRow(row);
            sum += parseFloat(row.querySelector('.scope-total')?.value || '0');
        });
        const extraLabor = parseFloat(form?.querySelector('[name="LaborAmount"]')?.value || '0');
        const extraMat = parseFloat(form?.querySelector('[name="MaterialsAmount"]')?.value || '0');
        sum += extraLabor + extraMat;
        if (grandTotal) grandTotal.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(sum);
    }

    list?.addEventListener('input', recalcGrand);
    form?.querySelector('[name="LaborAmount"]')?.addEventListener('input', recalcGrand);
    form?.querySelector('[name="MaterialsAmount"]')?.addEventListener('input', recalcGrand);

    addBtn?.addEventListener('click', () => {
        const row = document.createElement('li');
        row.className = 'prv-pro-scope-card';
        row.innerHTML = `
            <label class="prv-pro-scope-field prv-pro-scope-field--item">
                <span>Repair item</span>
                <input type="text" name="ScopeLabels" placeholder="Describe the repair" />
            </label>
            <div class="prv-pro-scope-amounts">
                <label class="prv-pro-scope-field">
                    <span>Labor</span>
                    <input type="number" name="ScopeLaborAmounts" value="0" step="1" min="0" inputmode="numeric" class="scope-labor" />
                </label>
                <label class="prv-pro-scope-field">
                    <span>Material</span>
                    <input type="number" name="ScopeMaterialAmounts" value="0" step="1" min="0" inputmode="numeric" class="scope-material" />
                </label>
                <label class="prv-pro-scope-field prv-pro-scope-field--total">
                    <span>Total</span>
                    <input type="number" name="ScopeAmounts" value="0" step="1" min="0" class="scope-total" readonly tabindex="-1" />
                </label>
            </div>`;
        list?.appendChild(row);
        recalcGrand();
    });

    form?.querySelectorAll('input, textarea').forEach(el => {
        el.addEventListener('focus', () => {
            window.setTimeout(() => el.scrollIntoView({ block: 'center', behavior: 'smooth' }), 300);
        });
    });
})();
</script>
}
