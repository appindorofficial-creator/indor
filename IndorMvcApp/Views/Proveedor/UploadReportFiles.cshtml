@model IndorMvcApp.ViewModels.ProviderProUploadReportFilesViewModel
@{
    ViewData["Title"] = L["Upload Files - INDOR PRO"];
    Layout = "_ProviderProLayout";
    ViewBag.NavActive = "reports";
}

<div class="prv-pro-shell prv-pro-shell--upload-report">
    @await Html.PartialAsync("_ProviderProTopbar", Model.CompanyName)
    @await Html.PartialAsync("_ProviderProFlowPath", Model.FlowSteps)

    <header class="prv-pro-workflow-head prv-pro-workflow-head--step">
        <a asp-controller="Proveedor" asp-action="UploadReportType" class="prv-pro-lead-back"><i class="fas fa-chevron-left"></i></a>
        <div>
            <h1>@L["Upload Files &amp; Photos"]</h1>
            <small>Step @Model.StepNumber of @Model.TotalSteps</small>
        </div>
        <span class="prv-pro-step-badge">Step @Model.StepNumber of @Model.TotalSteps</span>
    </header>

    @await Html.PartialAsync("_UploadReportJobCard", Model.Job)

    <form asp-controller="Proveedor" asp-action="UploadReportFiles" method="post" enctype="multipart/form-data" class="prv-pro-upload-report-files-form">
        @Html.AntiForgeryToken()

        <section class="prv-pro-upload-report-section">
            <h3>@L["Photos"]</h3>
            <div class="prv-pro-upload-photo-grid">
                <label class="prv-pro-upload-slot">
                    <span>@L["Before"]</span>
                    <input type="file" name="photoBefore" accept=".jpg,.jpeg,.png" />
                    @if (!string.IsNullOrWhiteSpace(Model.PhotoSlots.FirstOrDefault(s => s.Slot == "Before")?.FileName))
                    {
                        <small class="is-uploaded"><i class="fas fa-check"></i> @Model.PhotoSlots.First(s => s.Slot == "Before").FileName</small>
                    }
                </label>
                <label class="prv-pro-upload-slot">
                    <span>@L["During"]</span>
                    <input type="file" name="photoDuring" accept=".jpg,.jpeg,.png" />
                </label>
                <label class="prv-pro-upload-slot">
                    <span>@L["After"]</span>
                    <input type="file" name="photoAfter" accept=".jpg,.jpeg,.png" />
                </label>
                <label class="prv-pro-upload-slot">
                    <span>@L["Final Result"]</span>
                    <input type="file" name="photoFinal" accept=".jpg,.jpeg,.png" />
                </label>
            </div>
            <span class="prv-pro-upload-badge">@L["Before/After Required"]</span>
        </section>

        <section class="prv-pro-upload-report-section">
            <h3>@L["Documents"]</h3>
            @foreach (var doc in Model.DocumentSlots)
            {
                var inputName = doc.Slot switch
                {
                    "Invoice" => "docInvoice",
                    "Warranty Document" => "docWarranty",
                    _ => "docPermit"
                };
                <div class="prv-pro-upload-doc-row">
                    <div>
                        <strong>@doc.Slot @(doc.Required ? "(PDF)" : "")</strong>
                        <span>@(doc.Required ? "Required" : "Optional")</span>
                    </div>
                    <input type="file" name="@inputName" accept=".pdf,.jpg,.jpeg,.png" />
                    @if (!string.IsNullOrWhiteSpace(doc.FileName))
                    {
                        <small class="is-uploaded"><i class="fas fa-check"></i> @doc.FileName</small>
                    }
                </div>
            }
        </section>

        <section class="prv-pro-upload-dropzone">
            <i class="fas fa-cloud-arrow-up"></i>
            <strong>@L["Add photos or files"]</strong>
            <small>@L["JPG, PNG, PDF up to 10MB"]</small>
            <input type="file" name="generalFiles" multiple accept=".pdf,.jpg,.jpeg,.png" class="prv-pro-upload-dropzone-input" />
        </section>

        <label class="prv-pro-create-toggle">
            <div><i class="fas fa-house"></i><div><strong>@L["Attach to House Facts"]</strong><small>@L["Attach this report and files to the property's House Facts."]</small></div></div>
            <input type="checkbox" name="AttachToHouseFacts" value="true" @(Model.AttachToHouseFacts ? "checked" : "") />
        </label>

        <div class="prv-pro-upload-report-actions">
            <a asp-controller="Proveedor" asp-action="UploadReportType" class="prv-pro-btn prv-pro-btn--outline">@L["Back"]</a>
            <button type="submit" class="prv-pro-btn prv-pro-btn--primary">@L["Next"]</button>
        </div>
    </form>
</div>
