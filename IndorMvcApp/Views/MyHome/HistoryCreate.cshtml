@model IndorMvcApp.ViewModels.MyHomeHistoryFormViewModel
@{
    ViewData["Title"] = L["Add Record"];
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "history";
    ViewBag.MyHomeBackUrl = Url.Action("History", "MyHome", new { id = Model.PropiedadId });
}
<div class="hf-title-row">
    <h1 class="hf-title">@L["Add record"]</h1>
</div>
<form asp-controller="MyHome" asp-action="HistoryCreate" asp-route-id="@Model.PropiedadId" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PropiedadId" />
    <label asp-for="RecordType" class="hf-label">@L["Record type"]</label>
    <select asp-for="RecordType" class="hf-select">
        <option value="Improvement">@L["Improvement"]</option>
        <option value="Repair">@L["Repair"]</option>
        <option value="Maintenance">@L["Maintenance"]</option>
    </select>
    <label asp-for="Title" class="hf-label">@L["Title"]</label>
    <input asp-for="Title" class="hf-input" placeholder="@L["Kitchen remodel"]" />
    <label asp-for="ProviderName" class="hf-label">@L["Provider"]</label>
    <input asp-for="ProviderName" class="hf-input" placeholder="Kitchen Pro LLC" />
    <label asp-for="CompletionDate" class="hf-label">@L["Completion date"]</label>
    <input asp-for="CompletionDate" class="hf-input" type="date" />
    <label asp-for="TotalCost" class="hf-label">@L["Total cost"]</label>
    <input asp-for="TotalCost" class="hf-input" type="number" step="0.01" />
    <label asp-for="WarrantyStatus" class="hf-label">@L["Warranty status"]</label>
    <select asp-for="WarrantyStatus" class="hf-select">
        <option value="">@L["Not specified"]</option>
        <option value="Active">@L["Active"]</option>
        <option value="Expired">@L["Expired"]</option>
    </select>
    <label asp-for="Description" class="hf-label">@L["Description"]</label>
    <textarea asp-for="Description" class="hf-textarea" rows="4"></textarea>
    <button type="submit" class="hf-btn hf-btn-primary">@L["Save record"]</button>
</form>
