@using System.Text.Json
@model IndorMvcApp.ViewModels.MyHomeDocumentFormViewModel
@{
    ViewData["Title"] = L["Upload Document"];
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "documents";
    ViewBag.MyHomeBackUrl = Url.Action("Documents", "MyHome", new { id = Model.PropiedadId, from = ViewBag.MyHomeNavFrom });
}
@section Head {
    <style>
        .hf-validation-summary { background:#FEF2F2; border:1px solid #FECACA; color:#B91C1C; border-radius:12px; padding:12px 14px; margin-bottom:14px; font-size:0.86rem; line-height:1.45; }
        .hf-validation-summary ul { margin:0; padding-left:18px; }
        .hf-field-error { display:block; color:#B91C1C; font-size:0.82rem; font-weight:600; margin:-6px 0 12px; }
        .hf-document-form { padding-bottom:calc(var(--homeowner-bottom-nav-h, 80px) + 88px + env(safe-area-inset-bottom, 0px)); }
        .hf-file-picker { display:flex; align-items:center; gap:10px; flex-wrap:wrap; padding:12px 14px; border:1.5px solid #E5E7EB; border-radius:12px; background:#FFF; margin-bottom:12px; }
        .hf-file-picker:focus-within { border-color:#93C5FD; box-shadow:0 0 0 3px rgba(0,102,204,.15); }
        .hf-file-picker.has-file { border-color:#BFDBFE; }
        .hf-file-picker-input { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
        .hf-file-picker-btn { display:inline-flex; align-items:center; justify-content:center; min-height:36px; padding:0 14px; border:1.5px solid #0066CC; border-radius:10px; background:#FFF; color:#0066CC; font-size:0.82rem; font-weight:600; cursor:pointer; white-space:nowrap; }
        .hf-file-picker-btn:hover, .hf-file-picker-btn:focus-visible { background:rgba(0,102,204,0.08); }
        .hf-file-picker-name { font-size:0.82rem; color:#64748B; min-width:0; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .hf-file-picker-name.is-selected { color:#0A2540; font-weight:600; }
        .hf-form-actions {
            position:fixed;
            left:0;
            right:0;
            bottom:calc(var(--homeowner-bottom-nav-h, 80px) + env(safe-area-inset-bottom, 0px));
            z-index:90;
            padding:12px 16px;
            background:linear-gradient(180deg, rgba(233,242,254,0) 0%, rgba(233,242,254,.95) 28%, rgba(233,242,254,.98) 100%);
            backdrop-filter:blur(8px);
            -webkit-backdrop-filter:blur(8px);
        }
        .hf-form-actions-inner { max-width:520px; margin:0 auto; }
        .hf-form-actions .hf-btn-primary { box-shadow:0 8px 18px rgba(0,102,204,.28); }
    </style>
}
<div class="hf-title-row">
    <h1 class="hf-title">@L["Upload document"]</h1>
</div>
<form asp-controller="MyHome" asp-action="DocumentCreate" asp-route-id="@Model.PropiedadId" method="post" enctype="multipart/form-data" class="hf-document-form" id="documentCreateForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PropiedadId" />
    <div asp-validation-summary="All" class="hf-validation-summary"></div>
    <label asp-for="Category" class="hf-label">@L["Category"]</label>
    <select asp-for="Category" class="hf-select" required>
        @foreach (var cat in IndorMvcApp.Services.MyHomeDisplayService.DocumentCategories)
        {
            <option value="@cat">@L[cat]</option>
        }
    </select>
    <span asp-validation-for="Category" class="hf-field-error"></span>
    <label asp-for="Title" class="hf-label">@L["Title"]</label>
    <input asp-for="Title" class="hf-input" required maxlength="200" placeholder="@L["Document title"]" />
    <span asp-validation-for="Title" class="hf-field-error"></span>
    <label for="documentFile" class="hf-label">@L["File"]</label>
    <div class="hf-file-picker" id="documentFilePicker">
        <input type="file"
               name="file"
               id="documentFile"
               class="hf-file-picker-input"
               accept="image/*,.pdf,.doc,.docx,.heic,.heif"
               required />
        <label for="documentFile" class="hf-file-picker-btn">@L["Choose file"]</label>
        <span class="hf-file-picker-name" id="documentFileName" data-empty-label="@L["No file selected"]">@L["No file selected"]</span>
    </div>
    @if (ViewData.ModelState["file"]?.Errors.Count > 0)
    {
        <span class="hf-field-error">@ViewData.ModelState["file"]!.Errors[0].ErrorMessage</span>
    }
    <div class="hf-form-actions">
        <div class="hf-form-actions-inner">
            <button type="submit" class="hf-btn hf-btn-primary">@L["Save document"]</button>
        </div>
    </div>
</form>
@section Scripts {
<script>
    (function () {
        var form = document.getElementById('documentCreateForm');
        var fileInput = document.getElementById('documentFile');
        var fileName = document.getElementById('documentFileName');
        var picker = document.getElementById('documentFilePicker');
        var msgs = {
            fill: @Html.Raw(JsonSerializer.Serialize(L["Please fill out this field."].ToString())),
            select: @Html.Raw(JsonSerializer.Serialize(L["Please select an item in the list."].ToString()))
        };

        // Override browser-locale HTML5 tooltips (e.g. Spanish OS → "Llena este campo")
        // so messages follow app UI culture via L[].
        if (form) {
            form.noValidate = true;
            form.setAttribute('novalidate', 'novalidate');

            function validityMessage(field) {
                if (!field.validity.valueMissing) {
                    return msgs.fill;
                }
                if (field.tagName === 'SELECT') {
                    return msgs.select;
                }
                return msgs.fill;
            }

            function clearFieldValidity(field) {
                field.setCustomValidity('');
            }

            form.addEventListener('submit', function (e) {
                var fields = form.querySelectorAll('input, select, textarea');
                var firstInvalid = null;

                fields.forEach(function (field) {
                    clearFieldValidity(field);
                });

                fields.forEach(function (field) {
                    if (!firstInvalid && !field.checkValidity()) {
                        firstInvalid = field;
                    }
                });

                if (!firstInvalid) {
                    return;
                }

                e.preventDefault();
                firstInvalid.setCustomValidity(validityMessage(firstInvalid));
                firstInvalid.reportValidity();
                if (typeof firstInvalid.focus === 'function') {
                    firstInvalid.focus({ preventScroll: true });
                }
            });

            form.querySelectorAll('input, select, textarea').forEach(function (field) {
                field.addEventListener('input', function () { clearFieldValidity(field); });
                field.addEventListener('change', function () { clearFieldValidity(field); });
            });
        }

        if (!fileInput || !fileName || !picker) return;

        var emptyLabel = fileName.dataset.emptyLabel || 'No file selected';

        function syncFileLabel() {
            var selected = fileInput.files && fileInput.files[0];
            if (selected) {
                fileName.textContent = selected.name;
                fileName.classList.add('is-selected');
                picker.classList.add('has-file');
            } else {
                fileName.textContent = emptyLabel;
                fileName.classList.remove('is-selected');
                picker.classList.remove('has-file');
            }
        }

        fileInput.addEventListener('change', syncFileLabel);
        syncFileLabel();
    })();
</script>
}
