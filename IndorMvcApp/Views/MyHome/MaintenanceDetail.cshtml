@model IndorMvcApp.ViewModels.MyHomeMaintenanceDetailViewModel
@{
    ViewData["Title"] = L["Maintenance Details"];
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "maintenance";
    ViewBag.MyHomeBackUrl = Url.Action("Maintenance", "MyHome", new { id = Model.PropiedadId, from = Model.NavigationFrom });
}
<div class="hf-title-row">
    <h1 class="hf-title">@L["Maintenance details"]</h1>
</div>
<div class="hf-card">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
        <div style="width:48px;height:48px;border-radius:50%;background:rgba(0,102,204,0.1);display:flex;align-items:center;justify-content:center;color:#0066CC;"><i class="fas fa-clipboard-check"></i></div>
        <div style="flex:1;">
            <div style="font-weight:800;font-size:1.1rem;">@Model.Title</div>
            <span class="hf-badge">@L[IndorMvcApp.Services.MyHomeDisplayService.MaintenanceStatusLabel(Model.Status)]</span>
        </div>
    </div>
    <div class="hf-list-item"><i class="fas fa-calendar icon"></i><div class="meta"><div class="label">@L["Due date"]</div><div class="value">@IndorMvcApp.Services.MyHomeDisplayService.FormatDate(Model.DueDate)</div></div></div>
    @if (Model.CompletedDate.HasValue)
    {
        <div class="hf-list-item"><i class="fas fa-circle-check icon"></i><div class="meta"><div class="label">@L["Completed"]</div><div class="value">@IndorMvcApp.Services.MyHomeDisplayService.FormatDate(Model.CompletedDate)</div></div></div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ProviderName))
    {
        <div class="hf-list-item"><i class="fas fa-user icon"></i><div class="meta"><div class="label">@L["Provider"]</div><div class="value" style="color:#0066CC;">@Model.ProviderName</div></div></div>
    }
</div>
@if (!string.IsNullOrWhiteSpace(Model.Notes))
{
    <div class="hf-card">
        <div class="hf-label">@L["Notes"]</div>
        <p style="line-height:1.5;color:#475569;">@Model.Notes</p>
    </div>
}
@if (Model.CanRequestIndor && !string.IsNullOrWhiteSpace(Model.RequestServiceUrl))
{
    <a href="@Model.RequestServiceUrl" class="hf-btn hf-btn-primary">
        <i class="fas fa-user-shield"></i> @L["Request Indor specialist"]
    </a>
}
<a asp-action="MaintenanceEdit" asp-route-id="@Model.Id" asp-route-from="@Model.NavigationFrom" class="hf-btn hf-btn-outline"><i class="fas fa-pen"></i> @L["Edit task"]</a>
