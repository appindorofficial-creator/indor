@model IndorMvcApp.ViewModels.MyHomeProvidersViewModel
@{
    ViewData["Title"] = "Providers";
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "summary";
}
<div class="hf-title-row">
    <h1 class="hf-title">Providers</h1>
    <a asp-action="ProviderCreate" asp-route-id="@Model.PropiedadId" class="hf-btn">+ Add</a>
</div>
<form method="get" asp-action="Providers" asp-route-id="@Model.PropiedadId" style="margin-bottom:14px;">
    <input type="search" name="search" value="@Model.Search" class="hf-input" placeholder="Search providers" style="margin:0;" />
</form>
@if (Model.Items.Count == 0)
{
    <div class="hf-card" style="text-align:center;color:#64748B;">No providers yet. Add contractors and service pros you trust.</div>
}
else
{
    @foreach (var item in Model.Items)
    {
        <a asp-action="ProviderEdit" asp-route-id="@item.Id" class="hf-card hf-list-item" style="display:flex;margin-bottom:8px;">
            <div style="width:44px;height:44px;border-radius:50%;background:#E5E7EB;display:flex;align-items:center;justify-content:center;font-weight:800;color:#0066CC;">@item.Name.Substring(0,1)</div>
            <div class="meta">
                <div class="value">@item.Name</div>
                <div class="label">@item.ServiceCategory</div>
                @if (!string.IsNullOrWhiteSpace(item.Phone)) { <div class="label">@item.Phone</div> }
            </div>
            <i class="fas fa-chevron-right" style="color:#CBD5E1;"></i>
        </a>
    }
}
