@model IndorMvcApp.ViewModels.MyHomeMaintenanceFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Edit Maintenance" : "Add Maintenance";
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "maintenance";
}
<div class="hf-title-row">
    <a asp-action="Maintenance" asp-route-id="@Model.PropiedadId" asp-route-from="@Model.NavigationFrom" class="app-back-btn"><i class="fas fa-chevron-left"></i></a>
    <h1 class="hf-title">@(isEdit ? "Edit maintenance" : "Add maintenance")</h1>
</div>
<form asp-action="@(isEdit ? "MaintenanceEdit" : "MaintenanceCreate")" method="post">
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }
    <input type="hidden" asp-for="PropiedadId" />
    <input type="hidden" asp-for="NavigationFrom" />
    <label asp-for="Title" class="hf-label">Task title</label>
    <input asp-for="Title" class="hf-input" placeholder="Check AC system" />
    <label asp-for="DueDate" class="hf-label">Due date</label>
    <input asp-for="DueDate" class="hf-input" type="date" />
    <label asp-for="Status" class="hf-label">Status</label>
    <select asp-for="Status" class="hf-select">
        <option value="Upcoming">Upcoming</option>
        <option value="Completed">Completed</option>
    </select>
    <label asp-for="Notes" class="hf-label">Notes</label>
    <textarea asp-for="Notes" class="hf-textarea" rows="3"></textarea>
    <button type="submit" class="hf-btn hf-btn-primary">Save task</button>
</form>
