@model IndorMvcApp.ViewModels.MyHomeHistoryListViewModel
@{
    ViewData["Title"] = L["House History"];
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "history";
    var groups = Model.Items.GroupBy(i => i.MonthLabel).ToList();
    var from = ViewBag.MyHomeNavFrom as string;
}
<div class="hf-title-row">
    <h1 class="hf-title">@L["House History"]</h1>
    <a asp-controller="MyHome"
       asp-action="HistoryCreate"
       asp-route-id="@Model.PropiedadId"
       asp-route-from="@from"
       class="hf-btn">@L["+ Add"]</a>
</div>
<div class="hf-chip-row">
    @foreach (var f in new[] { "All", "Improvement", "Repair", "Maintenance" })
    {
        <a asp-controller="MyHome"
           asp-action="History"
           asp-route-id="@Model.PropiedadId"
           asp-route-filter="@f"
           asp-route-from="@from"
           class="hf-chip @(string.Equals(Model.Filter, f, StringComparison.OrdinalIgnoreCase) ? "active" : "")">@L[f]</a>
    }
</div>
@if (groups.Count == 0)
{
    <div class="hf-card" style="text-align:center;color:#64748B;">
        @L["No history records yet. Tap"] <strong>@L["+ Add"]</strong> @L["to log improvements, repairs, or maintenance."]
    </div>
    <div class="hf-action-grid" style="margin-bottom:12px;">
        <a asp-controller="MyHome" asp-action="HistoryCreate" asp-route-id="@Model.PropiedadId" asp-route-type="Improvement" asp-route-from="@from" class="hf-action">
            <i class="fas fa-hammer"></i>@L["Improvement"]
        </a>
        <a asp-controller="MyHome" asp-action="HistoryCreate" asp-route-id="@Model.PropiedadId" asp-route-type="Repair" asp-route-from="@from" class="hf-action">
            <i class="fas fa-wrench"></i>@L["Repair"]
        </a>
        <a asp-controller="MyHome" asp-action="HistoryCreate" asp-route-id="@Model.PropiedadId" asp-route-type="Maintenance" asp-route-from="@from" class="hf-action">
            <i class="fas fa-screwdriver-wrench"></i>@L["Maintenance"]
        </a>
    </div>
}
else
{
    <div class="hf-timeline">
        @foreach (var group in groups)
        {
            <div class="hf-timeline-month">@UiDisplayLocalization.Localize(L, group.Key)</div>
            @foreach (var item in group)
            {
                <a asp-controller="MyHome" asp-action="HistoryDetail" asp-route-id="@item.Id" class="hf-timeline-item">
                    <div class="hf-timeline-dot"><i class="fas @IndorMvcApp.Services.MyHomeDisplayService.RecordTypeIcon(item.RecordType)"></i></div>
                    <div class="hf-timeline-card">
                        <div class="body">
                            <div class="title">@UiDisplayLocalization.Localize(L, item.Title)</div>
                            <div class="sub">@UiDisplayLocalization.Localize(L, item.ProviderName ?? L["No provider"])</div>
                        </div>
                        <div class="cost">@IndorMvcApp.Services.MyHomeDisplayService.FormatCurrency(item.TotalCost)</div>
                        <i class="fas fa-chevron-right" style="color:#CBD5E1;font-size:0.75rem;"></i>
                    </div>
                </a>
            }
        }
    </div>
}
<div class="hf-banner">
    <i class="fas fa-shield-check"></i>
    <div><strong>@L["Keep your information up to date."]</strong> @L["A complete history gives you peace of mind and can increase your property value."] <span style="color:#0066CC;font-weight:700;">@L["Learn more >"]</span></div>
</div>
