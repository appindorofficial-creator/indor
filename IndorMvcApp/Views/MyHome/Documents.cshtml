@model IndorMvcApp.ViewModels.MyHomeDocumentsViewModel
@{
    ViewData["Title"] = L["Documents"];
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "documents";
    var hasSearch = !string.IsNullOrWhiteSpace(Model.Search);

    string FolderIcon(string category) => category switch
    {
        "Warranties" => "fa-shield-halved",
        "Permits" => "fa-file-signature",
        "Invoices" => "fa-receipt",
        "Contracts" => "fa-file-contract",
        "Inspections" => "fa-magnifying-glass-chart",
        "Manuals" => "fa-book",
        _ => "fa-folder"
    };
}
@section Styles {
    <style>
        .hf-filter { margin-bottom: 14px; }
        .hf-filter-row {
            display: flex;
            align-items: stretch;
            gap: 8px;
        }
        .hf-filter-field {
            position: relative;
            flex: 1;
            min-width: 0;
        }
        .hf-filter-field .hf-input {
            margin: 0;
            padding-right: 40px;
        }
        .hf-filter-clear {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 28px;
            height: 28px;
            border: none;
            border-radius: 50%;
            background: #E2E8F0;
            color: #475569;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-size: 0.72rem;
        }
        .hf-filter-submit {
            width: 48px;
            flex-shrink: 0;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #0066CC, #004FA3);
            color: #FFF;
            cursor: pointer;
            font-size: 0.95rem;
        }
        .hf-filter-empty {
            text-align: center;
            color: #64748B;
            padding: 28px 18px;
            font-weight: 600;
            font-size: 0.9rem;
            line-height: 1.45;
        }
        .hf-doc-cat {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            margin-bottom: 10px;
            text-decoration: none;
            color: inherit;
            background: #FFF;
            border: 1px solid #E5E7EB;
            border-radius: 16px;
            transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease;
        }
        .hf-doc-cat:active { transform: scale(.99); }
        .hf-doc-cat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 102, 204, 0.1);
            color: #0066CC;
            font-size: 1.05rem;
        }
        .hf-doc-cat-meta { flex: 1; min-width: 0; }
        .hf-doc-cat-title {
            font-weight: 800;
            font-size: 0.95rem;
            color: #0A2540;
            margin-bottom: 2px;
        }
        .hf-doc-cat-count {
            font-size: 0.8rem;
            font-weight: 600;
            color: #64748B;
        }
        .hf-doc-cat-count.has-docs { color: #0066CC; }
        .hf-doc-cat-chevron {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #F1F5F9;
            color: #64748B;
            font-size: 0.72rem;
        }
    </style>
}
<div class="hf-title-row">
    <h1 class="hf-title">@L["Documents"]</h1>
    <a asp-action="DocumentCreate" asp-route-id="@Model.PropiedadId" asp-route-from="@ViewBag.MyHomeNavFrom" class="hf-btn">@L["+ Upload document"]</a>
</div>
<form method="get" asp-action="Documents" asp-route-id="@Model.PropiedadId" asp-route-from="@ViewBag.MyHomeNavFrom" class="hf-filter" role="search">
    <div class="hf-filter-row">
        <div class="hf-filter-field">
            <input type="search" name="search" value="@Model.Search" class="hf-input" placeholder="@L["Search documents"]" autocomplete="off" />
            @if (hasSearch)
            {
                <a asp-action="Documents" asp-route-id="@Model.PropiedadId" asp-route-from="@ViewBag.MyHomeNavFrom" class="hf-filter-clear" aria-label="@L["Clear search"]" title="@L["Clear search"]">
                    <i class="fas fa-xmark"></i>
                </a>
            }
        </div>
        <button type="submit" class="hf-filter-submit" aria-label="@L["Search documents"]">
            <i class="fas fa-magnifying-glass"></i>
        </button>
    </div>
</form>
@if (Model.Categories.Count == 0)
{
    <div class="hf-card hf-filter-empty">
        @(hasSearch ? L["No documents match your search."] : L["No documents in this category yet."])
    </div>
}
else
{
    @foreach (var cat in Model.Categories)
    {
        <a asp-action="DocumentList"
           asp-route-id="@Model.PropiedadId"
           asp-route-category="@cat.Category"
           asp-route-from="@ViewBag.MyHomeNavFrom"
           class="hf-doc-cat">
            <span class="hf-doc-cat-icon" aria-hidden="true">
                <i class="fas @FolderIcon(cat.Category)"></i>
            </span>
            <div class="hf-doc-cat-meta">
                <div class="hf-doc-cat-title">@L[cat.Category]</div>
                <div class="hf-doc-cat-count @(cat.Count > 0 ? "has-docs" : null)">
                    @(cat.Count == 1 ? L.T("{0} document", cat.Count) : L.T("{0} documents", cat.Count))
                </div>
            </div>
            <span class="hf-doc-cat-chevron" aria-hidden="true">
                <i class="fas fa-chevron-right"></i>
            </span>
        </a>
    }
}
