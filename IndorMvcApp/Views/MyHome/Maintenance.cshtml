@model IndorMvcApp.ViewModels.MyHomeMaintenanceViewModel
@{
    ViewData["Title"] = "Maintenance";
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "maintenance";
    var groups = Model.Items.GroupBy(i => i.MonthLabel).ToList();
}
<div class="hf-title-row">
    <a href="@Model.BackUrl" class="app-back-btn"><i class="fas fa-chevron-left"></i></a>
    <h1 class="hf-title">Maintenance</h1>
    <a asp-action="MaintenanceCreate" asp-route-id="@Model.PropiedadId" asp-route-from="@Model.NavigationFrom" class="hf-btn">+ Add</a>
</div>
<div class="hf-chip-row">
    @foreach (var f in new[] { "Upcoming", "Completed", "All" })
    {
        <a asp-action="Maintenance" asp-route-id="@Model.PropiedadId" asp-route-filter="@f" asp-route-from="@Model.NavigationFrom" class="hf-chip @(string.Equals(Model.Filter, f, StringComparison.OrdinalIgnoreCase) ? "active" : "")">@f</a>
    }
</div>
@if (groups.Count == 0)
{
    <div class="hf-card" style="text-align:center;color:#64748B;">No maintenance tasks yet.</div>
}
else
{
    @foreach (var group in groups)
    {
        <div style="font-weight:800;margin:12px 0 8px;">@group.Key</div>
        @foreach (var item in group)
        {
            <a asp-action="MaintenanceDetail" asp-route-id="@item.Id" asp-route-from="@Model.NavigationFrom" class="hf-card hf-list-item" style="display:flex;margin-bottom:8px;">
                <i class="fas fa-clipboard-list icon"></i>
                <div class="meta">
                    <div class="value">@item.Title</div>
                    <div class="label">@IndorMvcApp.Services.MyHomeDisplayService.FormatDueDate(item.DueDate)</div>
                </div>
                <span class="hf-badge" style="font-size:0.72rem;padding:4px 8px;">@IndorMvcApp.Services.MyHomeDisplayService.MaintenanceStatusLabel(item.Status)</span>
                <i class="fas fa-chevron-right" style="color:#CBD5E1;margin-left:8px;"></i>
            </a>
        }
    }
}
