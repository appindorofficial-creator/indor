@model IndorMvcApp.ViewModels.MyHomePropertyDetailsViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = L["Property Details"];
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "summary";
    ViewBag.MyHomeBackUrl = Url.Action("Index", "MyHome", new { id = Model.PropiedadId });
    var tab = Model.ActiveTab;
    var syncMessage = TempData["AttomSyncMessage"] as string;

    string Row(string label, string? value, string icon = "fa-circle-info")
    {
        return $@"<div class=""hf-list-item""><i class=""fas {icon} icon""></i><div class=""meta""><div class=""label"">{label}</div><div class=""value"">{value ?? "—"}</div></div></div>";
    }
}
<div class="hf-title-row">
    <h1 class="hf-title">@L["Property Details"]</h1>
    <a asp-action="Edit" asp-route-id="@Model.PropiedadId" class="hf-btn hf-edit-btn">
        <i class="fas fa-pen" aria-hidden="true"></i>
        <span>@L["Edit"]</span>
    </a>
</div>
@if (!string.IsNullOrWhiteSpace(syncMessage))
{
    <div class="hf-banner" style="margin-bottom:12px;">@syncMessage</div>
}
<div class="hf-chip-row">
    <a asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="information" class="hf-chip @(tab == "information" ? "active" : "")">@L["Information"]</a>
    <a asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="public" class="hf-chip @(tab == "public" ? "active" : "")">@L["Public data"]</a>
    <a asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="hf-chip @(tab == "attom" ? "active" : "")">@L["House Fact profile"]</a>
</div>

@if (tab == "information")
{
    <div class="hf-card">
        @Html.Raw(Row(L["External ID"], Model.AttomPropertyId?.ToString(), "fa-fingerprint"))
        @Html.Raw(Row(L["Property type"], Model.PropertyType, "fa-house"))
        @Html.Raw(Row(L["Occupancy"], Model.Occupancy, "fa-user-check"))
        @Html.Raw(Row(L["Year built"], Model.YearBuilt?.ToString(), "fa-calendar"))
        @Html.Raw(Row(L["Effective year built"], Model.YearBuiltEffective?.ToString(), "fa-calendar-check"))
        @Html.Raw(Row(L["Living area"], MyHomeDisplayService.FormatArea(Model.LivingArea), "fa-ruler-combined"))
        @Html.Raw(Row(L["Lot size"], MyHomeDisplayService.FormatLot(Model.LotSizeAcres), "fa-vector-square"))
        @Html.Raw(Row(L["Lot size (sq ft)"], Model.LotSizeSqFt?.ToString("N0"), "fa-vector-square"))
        @Html.Raw(Row(L["Bedrooms"], Model.Bedrooms?.ToString(), "fa-bed"))
        @Html.Raw(Row(L["Bathrooms"], Model.Bathrooms?.ToString("0.#"), "fa-bath"))
        @Html.Raw(Row(L["Total rooms"], Model.RoomsTotal?.ToString(), "fa-door-open"))
        @Html.Raw(Row(L["Floors"], Model.Floors?.ToString(), "fa-stairs"))
        @Html.Raw(Row(L["Estimated value"], MyHomeDisplayService.FormatCurrency(Model.EstimatedValue), "fa-chart-line"))
        @Html.Raw(Row(L["Heating"], Model.HeatingType, "fa-fire"))
        @Html.Raw(Row(L["Heating fuel"], Model.HeatingFuel, "fa-gas-pump"))
        @Html.Raw(Row(L["Cooling"], Model.CoolingType, "fa-snowflake"))
        @Html.Raw(Row(L["Building condition"], Model.BuildingCondition, "fa-hammer"))
        @Html.Raw(Row(L["Wall type"], Model.WallType, "fa-border-all"))
        @Html.Raw(Row(L["Parking"], Model.ParkingType, "fa-square-parking"))
        @Html.Raw(Row(L["Garage"], Model.GarageType, "fa-warehouse"))
        @Html.Raw(Row(L["Basement (sq ft)"], Model.BasementSqFt?.ToString("N0"), "fa-layer-group"))
        @Html.Raw(Row(L["Fireplaces"], Model.Fireplaces?.ToString(), "fa-fire-burner"))
        @Html.Raw(Row(L["Location accuracy"], Model.LocationAccuracy, "fa-location-crosshairs"))
        @Html.Raw(Row(L["Latitude"], Model.Latitude?.ToString(), "fa-location-dot"))
        @Html.Raw(Row(L["Longitude"], Model.Longitude?.ToString(), "fa-location-dot"))
    </div>
    @if (Model.Features.Count > 0)
    {
        <div class="hf-card">
            <div class="hf-label">@L["Features"]</div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
                @foreach (var feature in Model.Features)
                {
                    <span class="hf-badge">@feature</span>
                }
            </div>
        </div>
    }
}
else if (tab == "public")
{
    <div class="hf-card">
        @Html.Raw(Row(L["Parcel ID (APN)"], Model.ParcelId, "fa-id-card"))
        @Html.Raw(Row(L["FIPS code"], Model.Fips, "fa-hashtag"))
        @Html.Raw(Row(L["Legal description"], Model.LegalDescription, "fa-file-contract"))
        @Html.Raw(Row(L["Zoning"], Model.Zoning, "fa-map"))
        @Html.Raw(Row(L["Subdivision"], Model.Subdivision, "fa-signs-post"))
        @Html.Raw(Row(L["Municipality"], Model.Municipality, "fa-city"))
        @Html.Raw(Row(L["County"], Model.County, "fa-landmark"))
        @Html.Raw(Row(L["Assigned school"], Model.AssignedSchool, "fa-graduation-cap"))
        @Html.Raw(Row(L["Last sale date"], MyHomeDisplayService.FormatDate(Model.LastSaleDate), "fa-tag"))
        @Html.Raw(Row(L["Last sale price"], MyHomeDisplayService.FormatCurrency(Model.LastSalePrice), "fa-tag"))
        @Html.Raw(Row(L["Annual tax"], MyHomeDisplayService.FormatCurrency(Model.AnnualTaxAmount), "fa-circle-dollar-to-slot"))
        @Html.Raw(Row(L["Tax year"], Model.TaxYear?.ToString(), "fa-receipt"))
    </div>
}
else
{
    @if (!Model.HasAttomData)
    {
        <div class="hf-card" style="text-align:center;color:#64748B;">
            @L["No enriched property data saved yet for this property."]
            <form asp-action="SyncAttom" asp-route-id="@Model.PropiedadId" method="post" style="margin-top:12px;" data-property-research-loading>
                @Html.AntiForgeryToken()
                <button type="submit" class="hf-btn hf-btn-primary" style="width:auto;">@L["Refresh property data"]</button>
            </form>
        </div>
    }
    else
    {
        ViewData["PropiedadId"] = Model.PropiedadId;
        ViewData["EditUrl"] = Url.Action("Edit", new { id = Model.PropiedadId });
        @await Html.PartialAsync("_HouseFactProfile", Model.HouseFact)
    }
}

<div class="hf-banner">
    <i class="fas fa-shield-check"></i>
    <div>
        <strong>@L["Property data source."]</strong>
        @L["Data source:"] <strong>@Model.DataSource</strong>.
        @if (Model.AttomPropertyId.HasValue) { <span> @L["External ID"] @Model.AttomPropertyId.</span> }
        @if (Model.AttomLastSyncUtc.HasValue) { <span> @L["Last synced"] @Model.AttomLastSyncUtc.Value.ToLocalTime().ToString("MMM dd, yyyy HH:mm").</span> }
        @if (Model.HasAttomData) { <span> @Model.HouseFact.FieldCount @L["fields stored."]</span> }
    </div>
</div>

<form asp-action="SyncAttom" asp-route-id="@Model.PropiedadId" method="post" data-property-research-loading>
    @Html.AntiForgeryToken()
    <button type="submit" class="hf-btn hf-btn-primary"><i class="fas fa-rotate"></i> @L["Refresh property data"]</button>
</form>

@await Html.PartialAsync("_PropertyResearchLoading")
