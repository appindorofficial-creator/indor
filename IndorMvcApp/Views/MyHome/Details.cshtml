@model IndorMvcApp.ViewModels.MyHomePropertyDetailsViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = "Property Details";
    Layout = "~/Views/Shared/_MyHomeLayout.cshtml";
    ViewBag.PropiedadId = Model.PropiedadId;
    ViewBag.MyHomeNav = "summary";
    var tab = Model.ActiveTab;
    var syncMessage = TempData["AttomSyncMessage"] as string;

    string Row(string label, string? value, string icon = "fa-circle-info")
    {
        return $@"<div class=""hf-list-item""><i class=""fas {icon} icon""></i><div class=""meta""><div class=""label"">{label}</div><div class=""value"">{value ?? "—"}</div></div></div>";
    }
}
<div class="hf-title-row">
    <a asp-action="Index" asp-route-id="@Model.PropiedadId" class="hf-back"><i class="fas fa-arrow-left"></i></a>
    <h1 class="hf-title">Property Details</h1>
    <a asp-action="Edit" asp-route-id="@Model.PropiedadId" class="hf-btn">Edit</a>
</div>
@if (!string.IsNullOrWhiteSpace(syncMessage))
{
    <div class="hf-banner" style="margin-bottom:12px;">@syncMessage</div>
}
<div class="hf-chip-row">
    <a asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="information" class="hf-chip @(tab == "information" ? "active" : "")">Information</a>
    <a asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="public" class="hf-chip @(tab == "public" ? "active" : "")">Public data</a>
    <a asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="hf-chip @(tab == "attom" ? "active" : "")">All ATTOM data</a>
</div>

@if (tab == "information")
{
    <div class="hf-card">
        @Html.Raw(Row("ATTOM ID", Model.AttomPropertyId?.ToString(), "fa-fingerprint"))
        @Html.Raw(Row("Property type", Model.PropertyType, "fa-house"))
        @Html.Raw(Row("Occupancy", Model.Occupancy, "fa-user-check"))
        @Html.Raw(Row("Year built", Model.YearBuilt?.ToString(), "fa-calendar"))
        @Html.Raw(Row("Effective year built", Model.YearBuiltEffective?.ToString(), "fa-calendar-check"))
        @Html.Raw(Row("Living area", MyHomeDisplayService.FormatArea(Model.LivingArea), "fa-ruler-combined"))
        @Html.Raw(Row("Lot size", MyHomeDisplayService.FormatLot(Model.LotSizeAcres), "fa-vector-square"))
        @Html.Raw(Row("Lot size (sq ft)", Model.LotSizeSqFt?.ToString("N0"), "fa-vector-square"))
        @Html.Raw(Row("Bedrooms", Model.Bedrooms?.ToString(), "fa-bed"))
        @Html.Raw(Row("Bathrooms", Model.Bathrooms?.ToString("0.#"), "fa-bath"))
        @Html.Raw(Row("Total rooms", Model.RoomsTotal?.ToString(), "fa-door-open"))
        @Html.Raw(Row("Floors", Model.Floors?.ToString(), "fa-stairs"))
        @Html.Raw(Row("Estimated value", MyHomeDisplayService.FormatCurrency(Model.EstimatedValue), "fa-chart-line"))
        @Html.Raw(Row("Heating", Model.HeatingType, "fa-fire"))
        @Html.Raw(Row("Heating fuel", Model.HeatingFuel, "fa-gas-pump"))
        @Html.Raw(Row("Cooling", Model.CoolingType, "fa-snowflake"))
        @Html.Raw(Row("Building condition", Model.BuildingCondition, "fa-hammer"))
        @Html.Raw(Row("Wall type", Model.WallType, "fa-border-all"))
        @Html.Raw(Row("Parking", Model.ParkingType, "fa-square-parking"))
        @Html.Raw(Row("Garage", Model.GarageType, "fa-warehouse"))
        @Html.Raw(Row("Basement (sq ft)", Model.BasementSqFt?.ToString("N0"), "fa-layer-group"))
        @Html.Raw(Row("Fireplaces", Model.Fireplaces?.ToString(), "fa-fire-burner"))
        @Html.Raw(Row("Location accuracy", Model.LocationAccuracy, "fa-location-crosshairs"))
        @Html.Raw(Row("Latitude", Model.Latitude?.ToString(), "fa-location-dot"))
        @Html.Raw(Row("Longitude", Model.Longitude?.ToString(), "fa-location-dot"))
    </div>
    @if (Model.Features.Count > 0)
    {
        <div class="hf-card">
            <div class="hf-label">Features</div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
                @foreach (var feature in Model.Features)
                {
                    <span class="hf-badge">@feature</span>
                }
            </div>
        </div>
    }
}
else if (tab == "public")
{
    <div class="hf-card">
        @Html.Raw(Row("Parcel ID (APN)", Model.ParcelId, "fa-id-card"))
        @Html.Raw(Row("FIPS code", Model.Fips, "fa-hashtag"))
        @Html.Raw(Row("Legal description", Model.LegalDescription, "fa-file-contract"))
        @Html.Raw(Row("Zoning", Model.Zoning, "fa-map"))
        @Html.Raw(Row("Subdivision", Model.Subdivision, "fa-signs-post"))
        @Html.Raw(Row("Municipality", Model.Municipality, "fa-city"))
        @Html.Raw(Row("County", Model.County, "fa-landmark"))
        @Html.Raw(Row("Assigned school", Model.AssignedSchool, "fa-graduation-cap"))
        @Html.Raw(Row("Last sale date", MyHomeDisplayService.FormatDate(Model.LastSaleDate), "fa-tag"))
        @Html.Raw(Row("Last sale price", MyHomeDisplayService.FormatCurrency(Model.LastSalePrice), "fa-tag"))
        @Html.Raw(Row("Annual tax", MyHomeDisplayService.FormatCurrency(Model.AnnualTaxAmount), "fa-circle-dollar-to-slot"))
        @Html.Raw(Row("Tax year", Model.TaxYear?.ToString(), "fa-receipt"))
    </div>
}
else
{
    @if (!Model.HasAttomData)
    {
        <div class="hf-card" style="text-align:center;color:#64748B;">
            No ATTOM payload saved yet for this property.
            <form asp-action="SyncAttom" asp-route-id="@Model.PropiedadId" method="post" style="margin-top:12px;">
                @Html.AntiForgeryToken()
                <button type="submit" class="hf-btn hf-btn-primary" style="width:auto;">Refresh from ATTOM</button>
            </form>
        </div>
    }
    else
    {
        @foreach (var group in Model.AttomFieldGroups)
        {
            <div class="hf-card">
                <div class="hf-label" style="margin-bottom:10px;">@group.Title</div>
                @foreach (var field in group.Fields)
                {
                    @Html.Raw(Row(field.Label, field.Value))
                }
            </div>
        }

        <details class="hf-card">
            <summary class="hf-label" style="cursor:pointer;">Full ATTOM JSON response</summary>
            <pre class="hf-json-block">@Model.AttomRawJsonPretty</pre>
        </details>
    }
}

<div class="hf-banner">
    <i class="fas fa-shield-check"></i>
    <div>
        <strong>Verified public source.</strong>
        Data source: <strong>@Model.DataSource</strong>.
        @if (Model.AttomPropertyId.HasValue) { <span> ATTOM ID @Model.AttomPropertyId.</span> }
        @if (Model.AttomLastSyncUtc.HasValue) { <span> Last synced @Model.AttomLastSyncUtc.Value.ToLocalTime().ToString("MMM dd, yyyy HH:mm").</span> }
        @if (Model.HasAttomData) { <span> @Model.AttomFieldGroups.Sum(g => g.Fields.Count) fields stored from ATTOM.</span> }
    </div>
</div>

<form asp-action="SyncAttom" asp-route-id="@Model.PropiedadId" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="hf-btn hf-btn-primary"><i class="fas fa-rotate"></i> Refresh from ATTOM</button>
</form>

@section Head {
<style>
    .hf-json-block { margin-top:12px; padding:12px; background:#0A2540; color:#E2E8F0; border-radius:12px; font-size:0.72rem; line-height:1.45; overflow:auto; max-height:420px; white-space:pre-wrap; word-break:break-word; }
</style>
}
