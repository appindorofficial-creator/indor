@model IndorMvcApp.ViewModels.PropertyAdministratorSecurityViewModel
@{
    ViewData["Title"] = L["Security"];
    Layout = "_PropertyAdminLayout";
}

<div class="pa-portal-shell pa-portal-shell--security">
    <header class="pa-personal-header">
        <a href="@Model.BackUrl" class="pa-profile-back" aria-label="@L["Back"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="pa-personal-header-text">
            <h1>@L["Security"]</h1>
            <p>@L["Manage your password and account security settings."]</p>
        </div>
    </header>

    @if (Model.PasswordChanged)
    {
        <div class="pa-notify-saved" role="status">@L["Password updated successfully."]</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="pa-security-error" role="alert">@Model.ErrorMessage</div>
    }

    <section class="pa-personal-section">
        <h2>@L["Password"]</h2>
        <form asp-controller="Administrador" asp-action="Security" method="post" class="pa-security-form">
            @Html.AntiForgeryToken()
            <label class="pa-security-field">
                <span>@L["Current password"]</span>
                <input type="password" name="currentPassword" value="@Model.CurrentPassword" required autocomplete="current-password" />
            </label>
            <label class="pa-security-field">
                <span>@L["New password"]</span>
                <input type="password" name="newPassword" value="@Model.NewPassword" required autocomplete="new-password" />
            </label>
            <label class="pa-security-field">
                <span>@L["Confirm new password"]</span>
                <input type="password" name="confirmPassword" value="@Model.ConfirmPassword" required autocomplete="new-password" />
            </label>
            <button type="submit" class="pa-security-submit">
                <i class="fas fa-key"></i> Change password
            </button>
        </form>
    </section>

    <section class="pa-personal-info-card">
        <div>
            <strong>@L["Account protection"]</strong>
            <p>@L["We never share your credentials. Learn more in our"] <a href="@Model.PrivacyPolicyUrl">@L["Privacy Policy"]</a>.</p>
        </div>
        <i class="fas fa-chevron-right"></i>
    </section>
</div>
