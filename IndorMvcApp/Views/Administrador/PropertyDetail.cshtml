@model IndorMvcApp.ViewModels.PropertyAdministratorPropertyDetailViewModel
@{
    ViewData["Title"] = Model.PropertyName;
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "properties";
    var tabs = new (string Key, string Label)[]
    {
        ("overview", L["Overview"]),
        ("details", L["Details"]),
        ("documents", L["Documents"]),
        ("activity", L["Activity"])
    };
}

<div class="pa-portal-shell pa-portal-shell--property-detail">
    <header class="pa-property-detail-header">
        <a href="@Model.BackUrl" class="pa-profile-back" aria-label="@L["Back"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="pa-property-detail-header-text">
            <h1>@Model.PropertyName</h1>
            <p>@Model.Location</p>
        </div>
        <a href="@Model.EditUrl" class="pa-property-detail-edit">@L["Edit"]</a>
    </header>

    <section class="pa-property-detail-hero">
        <img src="@(Model.ImageUrl ?? "/inspeccion2.jpeg")" alt="" />
        <span class="pa-property-detail-status">
            <span class="pa-portfolio-status-dot" aria-hidden="true"></span>
            @UiDisplayLocalization.Localize(L, Model.StatusLabel)
        </span>
    </section>

    <nav class="pa-property-detail-tabs" aria-label="@L["Property sections"]">
        @foreach (var (tab, label) in tabs)
        {
            <a href="@Url.Action("PropertyDetail", "Administrador", new { id = Model.PropertyId, tab = tab })"
               class="pa-property-detail-tab @(Model.ActiveTab == tab ? "is-active" : null)">
                @label
            </a>
        }
    </nav>

    @if (Model.ActiveTab == "overview")
    {
        <section class="pa-property-detail-card">
            <h2>@L["Property overview"]</h2>
            <div class="pa-property-overview-list">
                <div class="pa-property-overview-row">
                    <span class="pa-property-overview-icon"><i class="fas fa-house"></i></span>
                    <span class="pa-property-overview-label">@L["Property type"]</span>
                    <span class="pa-property-overview-value">@UiDisplayLocalization.Localize(L, Model.PropertyTypeLabel)</span>
                </div>
                <div class="pa-property-overview-row">
                    <span class="pa-property-overview-icon"><i class="fas fa-calendar"></i></span>
                    <span class="pa-property-overview-label">@L["Year built"]</span>
                    <span class="pa-property-overview-value">@Model.YearBuiltLabel</span>
                </div>
                <div class="pa-property-overview-row">
                    <span class="pa-property-overview-icon"><i class="fas fa-ruler-combined"></i></span>
                    <span class="pa-property-overview-label">@L["Square footage"]</span>
                    <span class="pa-property-overview-value">@UiDisplayLocalization.Localize(L, Model.SquareFootageLabel)</span>
                </div>
                <div class="pa-property-overview-row">
                    <span class="pa-property-overview-icon"><i class="fas fa-bed"></i></span>
                    <span class="pa-property-overview-label">@L["Bedrooms / Bathrooms"]</span>
                    <span class="pa-property-overview-value">@Model.BedsBathsLabel</span>
                </div>
                <div class="pa-property-overview-row">
                    <span class="pa-property-overview-icon is-status"><i class="fas fa-circle"></i></span>
                    <span class="pa-property-overview-label">@L["Status"]</span>
                    <span class="pa-portfolio-status is-active">
                        <span class="pa-portfolio-status-dot" aria-hidden="true"></span>
                        @UiDisplayLocalization.Localize(L, Model.StatusLabel)
                    </span>
                </div>
            </div>
        </section>

        <section class="pa-property-detail-card">
            <h2>@L["Quick actions"]</h2>
            <div class="pa-property-quick-actions">
                @foreach (var action in Model.QuickActions)
                {
                    <a href="@action.Url" class="pa-property-quick-action">
                        <span class="pa-property-quick-action-icon"><i class="fas @action.IconClass"></i></span>
                        <div>
                            <strong>@UiDisplayLocalization.Localize(L, action.Title)</strong>
                            <small>@UiDisplayLocalization.Localize(L, action.Subtitle)</small>
                        </div>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        </section>
    }
    else if (Model.ActiveTab == "details")
    {
        <section class="pa-property-detail-card">
            <h2>@L["Property details"]</h2>
            <div class="pa-property-overview-list">
                @foreach (var row in Model.DetailRows)
                {
                    <div class="pa-property-overview-row">
                        <span class="pa-property-overview-icon"><i class="fas @row.IconClass"></i></span>
                        <span class="pa-property-overview-label">@UiDisplayLocalization.Localize(L, row.Label)</span>
                        <span class="pa-property-overview-value">@UiDisplayLocalization.Localize(L, row.Value)</span>
                    </div>
                }
            </div>
        </section>
    }
    else if (Model.ActiveTab == "documents")
    {
        <section class="pa-property-detail-card">
            <h2>@L["Documents"]</h2>
            <div class="pa-empty-card">@L["No documents uploaded for this property yet."]</div>
        </section>
    }
    else
    {
        <section class="pa-property-detail-card">
            <h2>@L["Activity"]</h2>
            @if (Model.ActivityItems.Count == 0)
            {
                <div class="pa-empty-card">@L["No service activity for this property yet."]</div>
            }
            else
            {
                <div class="pa-property-activity-list">
                    @foreach (var item in Model.ActivityItems)
                    {
                        <div class="pa-property-activity-item">
                            <div>
                                <strong>@UiDisplayLocalization.Localize(L, item.Title)</strong>
                                <small>@UiDisplayLocalization.Localize(L, item.DateLabel)</small>
                            </div>
                            <span class="pa-badge pa-badge-added">@UiDisplayLocalization.Localize(L, item.StatusLabel)</span>
                        </div>
                    }
                </div>
            }
        </section>
    }
</div>
