@model IndorMvcApp.ViewModels.PropertyAdministratorSavedProvidersViewModel
@{
    ViewData["Title"] = L["Saved providers"];
    Layout = "_PropertyAdminLayout";
}

<div class="pa-portal-shell pa-portal-shell--providers">
    <header class="pa-personal-header">
        <a href="@Model.BackUrl" class="pa-profile-back" aria-label="@L["Back"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="pa-personal-header-text">
            <h1>@L["Saved providers"]</h1>
            <p>@L["Your trusted pros from past service requests. Book them again anytime."]</p>
        </div>
    </header>

    <section class="pa-personal-section">
        <h2>@L["Your providers"]</h2>
        @if (!Model.Providers.Any())
        {
            <div class="pa-empty-note">
                <p>@L["You don't have any saved providers yet. Providers you work with on service requests will appear here."]</p>
            </div>
        }
        <div class="pa-personal-list">
            @foreach (var provider in Model.Providers)
            {
                <div class="pa-provider-card">
                    <span class="pa-provider-avatar"><i class="fas fa-user-check"></i></span>
                    <div class="pa-provider-copy">
                        <strong>@provider.Name</strong>
                        <small>@UiDisplayLocalization.Localize(L, provider.TradeLabel)</small>
                        <span class="pa-provider-last">@L.T("Last service: {0}", provider.LastServiceLabel)</span>
                    </div>
                    <div class="pa-provider-meta">
                        @if (!string.IsNullOrWhiteSpace(provider.RatingLabel))
                        {
                            <span class="pa-provider-rating"><i class="fas fa-star"></i> @provider.RatingLabel</span>
                        }
                        <a href="@provider.RequestUrl" class="pa-provider-request">@L["Request again"]</a>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="pa-personal-info-card">
        <div>
            <strong>@L["Need someone new?"]</strong>
            <p>@L["Browse the full service catalog to find more trusted pros for your portfolio."]</p>
        </div>
        <a href="@Model.BrowseServicesUrl" class="pa-provider-browse" aria-label="@L["Browse services"]">
            <i class="fas fa-chevron-right"></i>
        </a>
    </section>
</div>
