@model IndorMvcApp.ViewModels.PropertyAdministratorJunkRemovalStep1ViewModel
@{
    ViewData["Title"] = L["Junk Removal"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Junk Removal"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what needs to be removed so we can match the right crew."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Index", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var items = Model.RemovalItems.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="JunkRemovalDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-trash-can pa-q-icon pa-q-icon--blue"></i> @L["What needs to be removed?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-junk-items-grid">
                @foreach (var i in new (string Value, string Label, string Icon)[]
                {
                    ("Furniture", L["Furniture"], "fa-couch"),
                    ("Boxes", L["Boxes"], "fa-box"),
                    ("BaggedTrash", L["Bagged trash"], "fa-trash"),
                    ("Appliances", L["Appliances"], "fa-blender"),
                    ("YardDebris", L["Yard debris"], "fa-leaf"),
                    ("MixedItems", L["Mixed items"], "fa-boxes-stacked")
                })
                {
                    <label class="pa-junk-item-card @(items.Contains(i.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="RemovalItemsList" value="@i.Value" @(items.Contains(i.Value) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <i class="fas @i.Icon"></i>
                        <span>@L[i.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-truck pa-q-icon pa-q-icon--blue"></i> @L["How much is there?"]</label>
            <div class="pa-junk-load-row">
                @foreach (var l in new (string Value, string Label, string Icon)[]
                {
                    ("SmallPickup", L["Small pickup"], "fa-bag-shopping"),
                    ("HalfLoad", L["Half load"], "fa-truck-pickup"),
                    ("FullLoad", L["Full load"], "fa-truck"),
                    ("MultipleLoads", L["Multiple loads"], "fa-truck-moving")
                })
                {
                    <label class="pa-junk-load-card @(Model.LoadSize == l.Value ? "is-selected" : null)">
                        <input type="radio" name="LoadSize" value="@l.Value" @(Model.LoadSize == l.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <i class="fas @l.Icon"></i>
                        <span>@l.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Is the property occupied right now?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.IsOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="Yes" @(Model.IsOccupied == "Yes" ? "checked" : null) />
                    <i class="fas fa-user"></i> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.IsOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="No" @(Model.IsOccupied == "No" ? "checked" : null) />
                    <i class="fas fa-user-slash"></i> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Are there guests currently inside?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) />
                    <i class="fas fa-users"></i> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) />
                    <i class="fas fa-user-slash"></i> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Do you need inside pickup or curbside only?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var p in new (string Value, string Label, string Icon)[] { ("InsidePickup", L["Inside pickup"], "fa-door-open"), ("Curbside", L["Curbside"], "fa-road"), ("Either", L["Either"], "fa-arrows-left-right") })
                {
                    <label class="pa-toggle-btn pa-toggle-btn--icon @(Model.PickupType == p.Value ? "is-selected" : null)">
                        <input type="radio" name="PickupType" value="@p.Value" @(Model.PickupType == p.Value ? "checked" : null) />
                        <i class="fas @p.Icon"></i> @p.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--blue"></i> @L["Quick details"] <small>@L["(optional)"]</small></label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" id="jrDetails">@Model.QuickDetails</textarea>
            <small class="pa-char-count"><span id="jrDetailsCount">@Model.QuickDetails.Length</span> / 250</small>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-junk-priority-banner">
            <i class="fas fa-circle-info"></i>
            <p>@L["Airbnb and rental property cleanout requests can be prioritized for faster scheduling."]</p>
            <i class="fas fa-calendar-check"></i>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-junk-item-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-junk-item-card')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-junk-load-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                document.querySelectorAll('.pa-junk-load-card').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-junk-load-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var details = document.getElementById('jrDetails');
        var counter = document.getElementById('jrDetailsCount');
        if (details && counter) {
            details.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
