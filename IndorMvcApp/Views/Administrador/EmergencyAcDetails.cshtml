@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyAcFormViewModel
@{
    ViewData["Title"] = "Emergency AC";
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowBackUrl = Url.Action("Index", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro">
        <h1>Emergency AC</h1>
        <p>Tell us what's happening and how the technician can get in.</p>
    </section>

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="EmergencyAcDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>What's the problem?</label>
            <div class="pa-chip-grid">
                @{
                    var problems = new (string Value, string Label, string Icon)[]
                    {
                        ("NoCooling", "No cooling", "fa-snowflake"),
                        ("WarmAir", "Warm air", "fa-temperature-high"),
                        ("NoAirflow", "No airflow", "fa-wind"),
                        ("WaterLeak", "Water leak", "fa-droplet"),
                        ("StrangeNoise", "Strange noise", "fa-volume-high"),
                        ("BurningSmell", "Burning smell", "fa-fire")
                    };
                }
                @foreach (var p in problems)
                {
                    <label class="pa-chip @(Model.ProblemType == p.Value ? "is-selected" : null)">
                        <input type="radio" name="ProblemType" value="@p.Value" @(Model.ProblemType == p.Value ? "checked" : null) />
                        <i class="fas @p.Icon"></i>
                        <span>@p.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>Is the home occupied right now?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.IsOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="Yes" @(Model.IsOccupied == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.IsOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="No" @(Model.IsOccupied == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>Are guests currently inside?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>How urgent is it?</label>
            <p class="pa-flow-urgent">Emergency — technician needed ASAP</p>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>Current indoor temperature</label>
            <div class="pa-field">
                <i class="fas fa-temperature-half"></i>
                <input type="text" name="IndoorTemperature" value="@Model.IndoorTemperature" placeholder="e.g. 82°F" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label>Can the technician enter now?</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @{
                    var entry = new (string Value, string Label)[]
                    {
                        ("SmartLock", "Yes, with smart lock"),
                        ("HostMeet", "Host will meet"),
                        ("NeedApproval", "Need approval")
                    };
                }
                @foreach (var e in entry)
                {
                    <label class="pa-chip pa-chip--wide @(Model.EntryAccess == e.Value ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Value" @(Model.EntryAccess == e.Value ? "checked" : null) />
                        <span>@e.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label>Smart lock / entry code</label>
            <div class="pa-field">
                <i class="fas fa-key"></i>
                <input type="text" name="EntryCode" value="@Model.EntryCode" placeholder="Front door code" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">8</span>
            <label>Who should receive updates?</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @{
                    var recipients = Model.UpdateRecipients.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
                }
                @foreach (var r in new[] { ("Me", "Me"), ("Guest", "Guest"), ("CoHost", "Co-host") })
                {
                    <label class="pa-chip @(recipients.Contains(r.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="UpdateRecipientsList" value="@r.Item1" @(recipients.Contains(r.Item1) ? "checked" : null) />
                        <span>@r.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">9</span>
            <label>Best phone number for urgent contact</label>
            <div class="pa-field">
                <i class="fas fa-phone"></i>
                <input type="tel" name="ContactPhone" value="@Model.ContactPhone" placeholder="(555) 555-0100" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">10</span>
            <label>Add details</label>
            <textarea class="pa-textarea" name="Details" rows="3" placeholder="Describe what guests or tenants are experiencing...">@Model.Details</textarea>
        </div>

        <div class="pa-media-actions">
            <button type="button" class="pa-media-btn"><i class="fas fa-camera"></i> Add photos</button>
            <button type="button" class="pa-media-btn"><i class="fas fa-microphone"></i> Voice note</button>
        </div>

        <div class="pa-flow-summary-grid">
            <div class="pa-flow-summary-card">
                <h3>Request summary</h3>
                <ul class="pa-summary-list">
                    <li><i class="fas fa-house"></i> @(Model.ViewingProperty?.PropertyName ?? "Property")</li>
                    <li><i class="fas fa-snowflake"></i> No cooling</li>
                    <li><i class="fas fa-users"></i> Occupied • Guests inside</li>
                    <li><i class="fas fa-temperature-half"></i> @Model.IndoorTemperature</li>
                    <li><i class="fas fa-key"></i> Smart lock access</li>
                    <li><i class="fas fa-bell"></i> Updates to you & guest</li>
                </ul>
            </div>
            <div class="pa-flow-pro-card">
                <div class="pa-flow-pro-head">
                    <span class="pa-flow-pro-icon"><i class="fas fa-user-gear"></i></span>
                    <div>
                        <strong>@Model.ProEtaLabel</strong>
                    </div>
                </div>
                <p>Estimated diagnostic visit: <strong>@Model.EstimatedPrice</strong></p>
                <p>Emergency priority fee: <span class="pa-included">Included</span></p>
                <div class="pa-trust-badges">
                    <span>Licensed</span>
                    <span>Insured</span>
                    <span>Fast response</span>
                </div>
            </div>
        </div>

        <div class="pa-notify-banner">
            <i class="fas fa-bell"></i>
            <span>We'll send status updates to you and the guest.</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">Request emergency service</button>
        <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">Edit details</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
            });
        });
    </script>
}
