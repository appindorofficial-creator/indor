@model IndorMvcApp.ViewModels.PropertyAdministratorPreventiveServicesStepViewModel
@{
    ViewData["Title"] = L["Preventive Maintenance"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Preventive Maintenance"].ToString();
    ViewBag.FlowSubtitle = L["Choose the upkeep services your property needs."].ToString();
    ViewBag.FlowSteps = new[] { L["Service"].ToString(), L["Plan"].ToString(), L["Schedule"].ToString(), L["Review"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @{
        ViewBag.BadgeLabel = Model.PropertyStatusLabel;
    }
    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="PreventiveMaintenanceServices" method="post" class="pa-preventive-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />
        @if (Model.PlanId.HasValue)
        {
            <input type="hidden" name="PlanId" value="@Model.PlanId" />
        }

        <section class="pa-prev-section" data-pa-required-group>
            <h2>@L["Recommended services"]</h2>
            <div class="pa-prev-service-grid">
                @foreach (var svc in Model.Services)
                {
                    <label class="pa-prev-service-card @(svc.IsSelected ? "is-selected" : null)">
                        <input type="checkbox" name="SelectedServices" value="@svc.ServiceKey" @(svc.IsSelected ? "checked" : null) />
                        <span class="pa-prev-service-check"><i class="fas fa-check"></i></span>
                        <span class="pa-prev-service-icon @svc.ToneClass"><i class="fas @svc.IconClass"></i></span>
                        <strong>@UiDisplayLocalization.Localize(L, svc.ServiceName)</strong>
                        <small>@UiDisplayLocalization.Localize(L, svc.DefaultFrequency)</small>
                    </label>
                }
            </div>
        </section>

        <section class="pa-prev-section" data-pa-validate-group>
            <h2>@L["Plan options"]</h2>
            <div class="pa-plan-tier-row">
                @foreach (var tier in Model.PlanTiers)
                {
                    <label class="pa-plan-tier-card @(tier.IsSelected ? "is-selected" : null)">
                        <input type="radio" name="PlanTier" value="@tier.TierKey" @(tier.IsSelected ? "checked" : null) />
                        <span class="pa-prev-service-check"><i class="fas fa-check"></i></span>
                        <strong>@UiDisplayLocalization.Localize(L, tier.Title)</strong>
                        <small>@UiDisplayLocalization.Localize(L, tier.Description)</small>
                        <span class="pa-plan-tier-price">@L.T("${0} /mo", tier.MonthlyPrice.ToString("0"))</span>
                    </label>
                }
            </div>
        </section>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-prev-service-card input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                var card = this.closest('.pa-prev-service-card');
                if (card) card.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-plan-tier-card input[type="radio"]').forEach(function (input) {
            input.addEventListener('change', function () {
                document.querySelectorAll('.pa-plan-tier-card').forEach(function (el) { el.classList.remove('is-selected'); });
                var card = this.closest('.pa-plan-tier-card');
                if (card) card.classList.add('is-selected');
            });
        });
    </script>
}
