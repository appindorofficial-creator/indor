@model IndorMvcApp.ViewModels.PropertyAdministratorFurnitureHaulAwayConfirmedViewModel
@{
    ViewData["Title"] = L["Furniture Haul Away request sent"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowShowBack = false;
    var propertyLabel = Model.ViewingProperty != null
        ? $"{Model.ViewingProperty.PropertyTypeLabel} • {Model.ViewingProperty.Location}"
        : "";
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro pa-flow-intro--confirmed">
        <span class="pa-furniture-success-icon"><i class="fas fa-couch"></i><span class="pa-furniture-success-check"><i class="fas fa-check"></i></span></span>
        <div>
            <h1>@L["Furniture Haul Away request sent"]</h1>
            <p>A removal crew is on the way to @(Model.ViewingProperty?.PropertyName ?? "your property").</p>
        </div>
    </section>

    <div class="pa-success-banner">
        <span class="pa-success-icon"><i class="fas fa-check"></i></span>
        <div>
            <strong>@L["Your request has been received"]</strong>
            <span>@L["We matched you with the nearest available crew."]</span>
        </div>
    </div>

    <article class="pa-tech-card">
        <div class="pa-tech-head">
            <img src="/inspeccion2.jpeg" alt="" class="pa-tech-avatar" />
            <div class="pa-tech-meta">
                <strong>@Model.TechnicianName</strong>
                <span><i class="fas fa-star"></i> @Model.TechnicianRating.ToString("0.0") • @Model.TechnicianRole</span>
                <small><i class="fas fa-check"></i> @Model.TechnicianTitle</small>
            </div>
            <span class="pa-eta-pill"><i class="fas fa-clock"></i> @Model.EtaLabel ETA</span>
        </div>
        <div class="pa-tech-stats">
            <div>
                <i class="fas fa-truck"></i>
                <strong>@Model.VehicleLabel</strong>
                <small>@L["Vehicle"]</small>
            </div>
            <div>
                <i class="fas fa-location-dot"></i>
                <strong>Viewing: @(Model.ViewingProperty?.PropertyName)</strong>
                <small>@L["Viewing"]</small>
            </div>
            <div>
                <i class="fas fa-house"></i>
                <strong>@propertyLabel</strong>
                <small>@L["Property"]</small>
            </div>
        </div>
    </article>

    <div class="pa-confirm-split">
        <article class="pa-timeline-card pa-timeline-card--inline">
            <h2>@L["Live updates"]</h2>
            <ul class="pa-timeline">
                @foreach (var step in Model.Timeline)
                {
                    <li class="pa-timeline-item pa-timeline-item--@step.State">
                        <span class="pa-timeline-dot"><i class="fas @step.IconClass"></i></span>
                        <div class="pa-timeline-body">
                            <strong>@step.Label</strong>
                            <span>@step.StatusLabel</span>
                        </div>
                    </li>
                }
            </ul>
        </article>

        <article class="pa-summary-card-block">
            <h2>@L["Request summary"]</h2>
            <ul class="pa-summary-detail-list">
                @foreach (var item in Model.Summary)
                {
                    <li>
                        <i class="fas @item.IconClass"></i>
                        <span>@item.Label</span>
                        <strong>@item.Value</strong>
                    </li>
                }
            </ul>
        </article>
    </div>

    <div class="pa-action-grid">
        <button type="button" class="pa-action-tile"><i class="fas fa-phone"></i><span>@L["Call crew"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-comment"></i><span>@L["Message guest"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-share"></i><span>@L["Share ETA"]</span></button>
        <a asp-controller="Administrador" asp-action="Tasks" class="pa-action-tile">
            <i class="fas fa-file-lines"></i><span>@L["View details"]</span>
        </a>
    </div>

    <div class="pa-junk-tip-banner">
        <i class="fas fa-circle-info"></i>
        <p><strong>@L["Helpful tip:"]</strong> @Model.Tip</p>
    </div>

    <a asp-controller="Administrador" asp-action="Tasks" class="ob-btn ob-btn-primary pa-flow-submit">
        <i class="fas fa-location-dot"></i> Track request
    </a>
    <a asp-controller="Administrador" asp-action="Services" class="ob-btn ob-btn-outline pa-flow-edit">
        Back to services
    </a>
</div>
