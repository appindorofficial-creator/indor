@{
    var title = (ViewBag.FlowTitle as string)
        ?? (ViewBag.InviteFlowTitle as string)
        ?? "";
    var subtitle = (ViewBag.FlowSubtitle as string)
        ?? (ViewBag.InviteFlowSubtitle as string)
        ?? "";
    var displayStep = ViewBag.InviteFlowStep as int?
        ?? ViewBag.FlowStep as int?
        ?? 1;
    var flowSteps = ViewBag.InviteFlowSteps as string[]
        ?? ViewBag.FlowSteps as string[]
        ?? new[] { L["Service"].ToString(), L["Details"].ToString(), L["Done"].ToString() };
    var anchorId = ViewBag.InviteFlowAnchorId as string;
    var backUrl = ViewBag.FlowBackUrl as string;
    var showBack = ViewBag.FlowShowBack as bool? ?? true;
    var hasBack = showBack && !string.IsNullOrWhiteSpace(backUrl);
}
<header class="pa-svc-invite-topbar">
    @if (hasBack)
    {
        <a href="@backUrl" class="pa-svc-invite-back" data-smart-back aria-label="@L["Back"]">
            <i class="fas fa-chevron-left"></i>
        </a>
    }
    <a asp-controller="Administrador" asp-action="Services" class="pa-svc-invite-logo" aria-label="@L["Services"]">
        <i class="fas fa-house"></i> INDOR
    </a>
</header>

<div class="pa-svc-invite-head"@(string.IsNullOrWhiteSpace(anchorId) ? null : Html.Raw($" id=\"{anchorId}\""))>
    @if (!string.IsNullOrWhiteSpace(title))
    {
        <h1>@title</h1>
    }
    @if (!string.IsNullOrWhiteSpace(subtitle))
    {
        <p>@subtitle</p>
    }
</div>

<nav class="pa-svc-invite-stepper" aria-label="@L["Service request progress"]">
    @for (var i = 0; i < flowSteps.Length; i++)
    {
        var stepNum = i + 1;
        var cls = stepNum < displayStep ? "is-done" : stepNum == displayStep ? "is-active" : "";
        <div class="pa-svc-invite-step @cls">
            @if (stepNum < displayStep)
            {
                <i class="fas fa-check"></i>
            }
            else
            {
                <span>@stepNum</span>
            }
            <small>@flowSteps[i]</small>
        </div>
        @if (i < flowSteps.Length - 1)
        {
            <div class="pa-svc-invite-step-line @(stepNum < displayStep ? "is-done" : "")"></div>
        }
    }
</nav>
