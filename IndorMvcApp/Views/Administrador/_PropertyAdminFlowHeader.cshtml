@model IndorMvcApp.ViewModels.PropertyAdministratorPortalShellViewModel
@{
    var flowStep = ViewBag.FlowStep as int? ?? 1;
    var totalSteps = ViewBag.FlowTotalSteps as int? ?? 3;
    var backUrl = ViewBag.FlowBackUrl as string ?? Url.Action("Index", "Administrador") ?? "#";
    var showBack = ViewBag.FlowShowBack as bool? ?? true;
}
<header class="pa-flow-header">
    @if (showBack)
    {
        <a href="@backUrl" class="pa-back-inline" aria-label="@L["Back"]"><i class="fas fa-arrow-left"></i></a>
    }
    else
    {
        <span class="pa-back-inline" style="visibility:hidden" aria-hidden="true"></span>
    }
    <a asp-controller="Administrador" asp-action="Index" class="pa-portal-logo pa-portal-logo--center" aria-label="@L["INDOR home"]">
        <span class="pa-portal-logo-text">@L["ÎNDÔR"]</span>
    </a>
    <span class="pa-flow-step-pill pa-flow-step-pill--sm">@L.T("Step {0} of {1}", flowStep, totalSteps)</span>
</header>
