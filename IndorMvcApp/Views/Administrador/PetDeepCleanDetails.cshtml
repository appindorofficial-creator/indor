@model IndorMvcApp.ViewModels.PropertyAdministratorPetDeepCleanFormViewModel
@{
    ViewData["Title"] = L["Pet Deep Cleaning"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pet Deep Cleaning"].ToString();
    ViewBag.FlowSubtitle = L["Tell us a few details so we can get this right."].ToString();
    ViewBag.FlowSteps = new[] { L["Service"].ToString(), L["Details"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var focusAreas = Model.FocusAreas.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)
@{
    ViewData["Title"] = L["Pet Deep Cleaning"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pet Deep Cleaning"].ToString();
    ViewBag.FlowSubtitle = L["Tell us a few details so we can get this right."].ToString();
    ViewBag.FlowSteps = new[] { L["Service"].ToString(), L["Details"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var focusAreas = Model.FocusAreas.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @{
        if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
        {
            ViewBag.BadgeLabel = Model.PropertyStatusLabel;
        }
    }
    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

<form asp-action="PetDeepCleanDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-wand-magic-sparkles pa-q-icon pa-q-icon--purple"></i> @L["What type of service do you need?"]</label>
            <div class="pa-chip-grid pa-chip-grid--scroll">
                @foreach (var s in new (string Value, string Label)[]
                {
                    ("AfterPetStayCleanup", L["After pet stay cleanup"]),
                    ("RoutinePetRefresh", L["Routine pet refresh"]),
                    ("OdorTreatmentAddon", L["Odor treatment add-on"])
                })
                {
                    <label class="pa-chip @(Model.ServiceType == s.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceType" value="@s.Value" @(Model.ServiceType == s.Value ? "checked" : null) />
                        <span>@s.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-paw pa-q-icon pa-q-icon--purple"></i> @L["How many pets were in the home?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--4">
                @foreach (var c in new (string Value, string Label)[] { ("1", L["1"]), ("2", L["2"]), ("3", L["3"]), ("FourPlus", L["4+"]) })
                {
                    <label class="pa-toggle-btn @(Model.PetCount == c.Value ? "is-selected" : null)">
                        <input type="radio" name="PetCount" value="@c.Value" @(Model.PetCount == c.Value ? "checked" : null) />
                        @c.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-dog pa-q-icon pa-q-icon--purple"></i> @L["What kind of pets?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var p in new (string Value, string Label, string Icon)[] { ("Dog", L["Dog"], "fa-dog"), ("Cat", L["Cat"], "fa-cat"), ("Other", L["Other"], "fa-paw") })
                {
                    <label class="pa-toggle-btn @(Model.PetType == p.Value ? "is-selected" : null)">
                        <input type="radio" name="PetType" value="@p.Value" @(Model.PetType == p.Value ? "checked" : null) />
                        <i class="fas @p.Icon"></i> @p.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label><i class="fas fa-bullseye pa-q-icon pa-q-icon--purple"></i> @L["What do you want us to focus on?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-pet-focus-grid">
                @foreach (var f in new (string Value, string Label, string Icon)[]
                {
                    ("PetHair", L["Pet hair"], "fa-paw"),
                    ("OdorRemoval", L["Odor removal"], "fa-wind"),
                    ("AccidentsStains", L["Accidents / stains"], "fa-droplet"),
                    ("BedsUpholstery", L["Beds & upholstery"], "fa-couch"),
                    ("Floors", L["Floors"], "fa-border-all"),
                    ("CratePetArea", L["Crate / pet area"], "fa-house-chimney")
                })
                {
                    <label class="pa-pet-focus-card @(focusAreas.Contains(f.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="FocusAreasList" value="@f.Value" @(focusAreas.Contains(f.Value) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--purple"><i class="fas fa-check"></i></span>
                        <i class="fas @f.Icon"></i>
                        <span>@f.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-calendar pa-q-icon pa-q-icon--purple"></i> @L["When do you need it?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var w in new[] { "Today", "Tomorrow", "Later" })
                {
                    <label class="pa-toggle-btn @(Model.ScheduleWhen == w ? "is-selected" : null)">
                        <input type="radio" name="ScheduleWhen" value="@w" @(Model.ScheduleWhen == w ? "checked" : null) /> @L[w]
                    </label>
                }
            </div>
            @await Html.PartialAsync("_PropertyAdminTimeSlotSelect", new PropertyAdministratorTimeSlotSelectViewModel
            {
                FieldName = "ScheduleTimeWindow",
                SelectedValue = Model.ScheduleTimeWindow
            })
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-lock pa-q-icon pa-q-icon--purple"></i> @L["Can the team enter?"]</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @foreach (var e in new (string Value, string Label)[] { ("SmartLock", L["Smart lock"]), ("HostMeet", L["Host will meet"]), ("GuestStillInside", L["Guest still inside"]) })
                {
                    <label class="pa-chip pa-chip--wide @(Model.EntryAccess == e.Value ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Value" @(Model.EntryAccess == e.Value ? "checked" : null) />
                        <span>@e.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--purple"></i> @L["Add notes"]</label>
            <textarea class="pa-textarea" name="Details" rows="3" maxlength="250" id="petDetails">@Model.Details</textarea>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")

        </div>

        <article class="pa-pet-info-box">
            <i class="fas fa-house-chimney-user"></i>
            <p>@L["Great for Airbnb turnovers and rental homes after dog stays. Our pet deep cleaning removes hair, dander, and odors so your next guests walk into a fresh, clean home."]</p>
        </article>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"] <i class="fas fa-arrow-right"></i></button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') return;
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-pet-focus-card input, .pa-chip input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-pet-focus-card, .pa-chip')?.classList.toggle('is-selected', this.checked);
            });
        });
    </script>
}