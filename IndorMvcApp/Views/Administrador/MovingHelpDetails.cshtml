@model IndorMvcApp.ViewModels.PropertyAdministratorMovingHelpFormViewModel
@{
    ViewData["Title"] = L["Moving Help"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Moving Help"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what needs to be moved so we can schedule the right team."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Review"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    // Only draft/session choices — never treat empty/null as "all selected".
    var items = string.IsNullOrWhiteSpace(Model.ItemsToMove)
        ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        : Model.ItemsToMove.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @if (Model.ViewingProperty != null && Model.ViewingProperty.Id > 0)
    {        <a href="@(Url.Action("Properties", "Administrador", new { from = "switch", returnUrl = Context.Request.Path + Context.Request.QueryString }))" class="pa-viewing-strip pa-viewing-strip--switchable" aria-label="@L["Switch property"]">
            <img src="@(Model.ViewingProperty.ImageUrl ?? "/inspeccion2.jpeg")" alt="" class="pa-viewing-strip-thumb" />
            <div class="pa-viewing-strip-main">
                <strong>@L.T("Viewing: {0}", Model.ViewingProperty.PropertyName)</strong>
                @if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
                {
                    <span class="pa-checkout-badge"><i class="fas fa-calendar-day"></i> @UiDisplayLocalization.Localize(L, Model.PropertyStatusLabel)</span>
                }
                <small>@Model.ViewingProperty.PropertyTypeLabel • @Model.ViewingProperty.Location</small>
            </div>
            <span class="pa-viewing-switch" aria-hidden="true"><span class="pa-viewing-switch-label">@L["Switch property"]</span><i class="fas fa-chevron-down pa-portfolio-chevron"></i></span>
        </a>
    }

    <form asp-action="MovingHelpDetails" method="post" class="pa-emergency-form" autocomplete="off">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-dolly pa-q-icon pa-q-icon--blue"></i> @L["What type of moving help do you need?"]</label>
            <div class="pa-moving-service-grid">
                @foreach (var s in new (string Value, string Label, string Icon)[]
                {
                    ("TurnoverSetup", L["Turnover setup"], "fa-dolly"),
                    ("FurnitureMoving", L["Furniture moving"], "fa-couch"),
                    ("BoxesSupplies", L["Boxes & supplies"], "fa-box"),
                    ("GuestMoveInOut", L["Guest move-in/out"], "fa-person-walking-luggage")
                })
                {
                    <label class="pa-moving-service-card @(Model.ServiceType == s.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceType" value="@s.Value" @(Model.ServiceType == s.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <span class="pa-moving-service-icon"><i class="fas @s.Icon"></i></span>
                        <span>@s.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-boxes-stacked pa-q-icon pa-q-icon--blue"></i> @L["What needs to be moved?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-moving-items-row">
                @foreach (var i in new (string Value, string Label, string Icon)[]
                {
                    ("Boxes", L["Boxes"], "fa-box"),
                    ("SmallFurniture", L["Small furniture"], "fa-couch"),
                    ("BeddingLinens", L["Bedding / linens"], "fa-bed"),
                    ("DecorSupplies", L["Decor / supplies"], "fa-seedling")
                })
                {
                    <label class="pa-moving-item-card @(items.Contains(i.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="ItemsToMoveList" value="@i.Value" @(items.Contains(i.Value) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <span class="pa-moving-item-icon"><i class="fas @i.Icon"></i></span>
                        <span>@i.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-users pa-q-icon pa-q-icon--blue"></i> @L["How much help do you need?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var h in new (string Value, string Label, string Icon)[] { ("One", L["1 helper"], "fa-user"), ("Two", L["2 helpers"], "fa-user-group"), ("ThreePlus", L["3+ helpers"], "fa-users") })
                {
                    <label class="pa-toggle-btn pa-toggle-btn--icon @(Model.HelperCount == h.Value ? "is-selected" : null)">
                        <input type="radio" name="HelperCount" value="@h.Value" @(Model.HelperCount == h.Value ? "checked" : null) />
                        <i class="fas @h.Icon"></i> @h.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label><i class="fas fa-calendar pa-q-icon pa-q-icon--blue"></i> @L["When do you need it?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var w in new[] { "Today", "Tomorrow", "Later" })
                {
                    <label class="pa-toggle-btn @(Model.ScheduleWhen == w ? "is-selected" : null)">
                        <input type="radio" name="ScheduleWhen" value="@w" @(Model.ScheduleWhen == w ? "checked" : null) />
                        <i class="fas fa-calendar-day"></i> @L[w]
                    </label>
                }
            </div>
            @await Html.PartialAsync("_PropertyAdminTimeSlotSelect", new PropertyAdministratorTimeSlotSelectViewModel
            {
                FieldName = "ScheduleTimeWindow",
                SelectedValue = Model.ScheduleTimeWindow
            })
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-key pa-q-icon pa-q-icon--blue"></i> @L["Can the team enter?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var a in new (string Value, string Label, string Icon)[] { ("SmartLock", L["Smart lock"], "fa-lock"), ("HostMeet", L["Host will meet"], "fa-user"), ("GuestOnSite", L["Guest on-site"], "fa-user-check") })
                {
                    <label class="pa-toggle-btn pa-toggle-btn--icon @(Model.EntryAccess == a.Value ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@a.Value" @(Model.EntryAccess == a.Value ? "checked" : null) />
                        <i class="fas @a.Icon"></i> @a.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--blue"></i> @L["Add notes"]</label>
            <textarea class="pa-textarea" name="Details" rows="3" maxlength="250" id="mhDetails">@Model.Details</textarea>
            <small class="pa-char-count"><span id="mhDetailsCount">@Model.Details.Length</span> / 250</small>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-moving-info-box">
            <i class="fas fa-circle-info"></i>
            <p>@L["Great for Airbnb turnovers and rental property move support. Trusted teams. On-time. Background checked."]</p>
        </div>

        <div class="pa-flow-actions">
            <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
            <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-moving-service-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                document.querySelectorAll('.pa-moving-service-card').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-moving-service-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-moving-item-card input').forEach(function (input) {
            // Respect server-rendered checked only — undo browser form autofill on first visit.
            if (!input.defaultChecked) {
                input.checked = false;
            }
            var card = input.closest('.pa-moving-item-card');
            if (card) card.classList.toggle('is-selected', input.checked);
            input.addEventListener('change', function () {
                this.closest('.pa-moving-item-card')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') return;
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
        var details = document.getElementById('mhDetails');
        var counter = document.getElementById('mhDetailsCount');
        if (details && counter) {
            details.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
