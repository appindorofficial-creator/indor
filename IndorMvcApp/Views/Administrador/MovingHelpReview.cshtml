@model IndorMvcApp.ViewModels.PropertyAdministratorMovingHelpReviewViewModel
@{
    ViewData["Title"] = L["Review moving request"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Review moving request"].ToString();
    ViewBag.FlowSubtitle = L["Confirm the details before we schedule your team."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Review"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("MovingHelpDetails", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var input = Model.Input;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    <article class="pa-moving-review-card">
        @foreach (var row in Model.SummaryRows)
        {
            <div class="pa-moving-review-row">
                <span class="pa-moving-review-label"><i class="fas @row.IconClass"></i> @UiDisplayLocalization.Localize(L, row.Label)</span>
                <strong class="pa-moving-review-value">@Html.Raw(UiDisplayLocalization.Localize(L, row.Value).Replace("\n", L["<br />"]))</strong>
            </div>
        }
    </article>

    <article class="pa-moving-availability-card">
        <span class="pa-moving-availability-art"><i class="fas fa-truck-ramp-box"></i></span>
        <div>
            <strong>@UiDisplayLocalization.Localize(L, Model.TeamEtaLabel)</strong>
            <small>@L["Background checked • On-time • Host-ready"]</small>
        </div>
    </article>

    <article class="pa-moving-pricing-card">
        <div class="pa-moving-pricing-row">
            <span><i class="fas fa-dollar-sign"></i> @L["Estimated service visit"]</span>
            <strong>@Model.EstimatedPrice</strong>
        </div>
        <button type="button" class="pa-moving-addon-row">
            <span><i class="fas fa-box-open"></i> @L["Extra supplies / staging help if needed"]</span>
            <i class="fas fa-chevron-right"></i>
        </button>
    </article>

    <div class="pa-moving-trust-grid">
        <div><i class="fas fa-shield-halved"></i><span>@L["Trusted team"]</span></div>
        <div><i class="fas fa-user-check"></i><span>@L["Background checked"]</span></div>
        <div><i class="fas fa-bolt"></i><span>@L["Fast response"]</span></div>
    </div>

    <div class="pa-moving-info-box">
        <i class="fas fa-circle-info"></i>
        <p>@L["Great for Airbnb turnovers, furniture resets, and rental home move support."]</p>
    </div>

    <form asp-action="MovingHelpReview" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@input.PropertyId" />
        <input type="hidden" name="ServiceType" value="@input.ServiceType" />
        <input type="hidden" name="HelperCount" value="@input.HelperCount" />
        <input type="hidden" name="ScheduleWhen" value="@input.ScheduleWhen" />
        <input type="hidden" name="ScheduleTimeWindow" value="@input.ScheduleTimeWindow" />
        <input type="hidden" name="EntryAccess" value="@input.EntryAccess" />
        <input type="hidden" name="Details" value="@input.Details" />
        @foreach (var item in input.ItemsToMoveList)
        {
            <input type="hidden" name="ItemsToMoveList" value="@item" />
        }
        @foreach (var recipient in input.UpdateRecipientsList)
        {
            <input type="hidden" name="UpdateRecipientsList" value="@recipient" />
        }

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Request moving help"]</button>
    </form>
    <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
        <a href="@Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id })" class="pa-back-link">@L["Back to start"]</a>
</div>
