@model IndorMvcApp.ViewModels.PropertyAdministratorCalendarViewModel
@{
    ViewData["Title"] = L["Calendar"];
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "calendar";
}

<div class="pa-portal-shell">
    @await Html.PartialAsync("_PropertyAdminTopbar", Model)

    <section class="pa-hero-block">
        <h1>@L["Calendar"]</h1>
        <p>@L["Upcoming visits and scheduled service across your portfolio."]</p>
    </section>

    @await Html.PartialAsync("_PropertyAdminPortfolioCard", Model)

    <section class="pa-section">
        <div class="pa-section-head">
            <h2>@L["Scheduled visits"]</h2>
        </div>
        @if (Model.Visits.Count == 0)
        {
            <div class="pa-empty-card">@L["No visits on the calendar yet."]</div>
        }
        else
        {
            @foreach (var visit in Model.Visits)
            {
                <article class="pa-calendar-visit">
                    <img src="@(visit.ImageUrl ?? "/inspeccion2.jpeg")" alt="" />
                    <div>
                        <strong>@UiDisplayLocalization.Localize(L, visit.Title)</strong>
                        <span>@UiDisplayLocalization.Localize(L, visit.PropertyName)</span>
                        <small>@UiDisplayLocalization.Localize(L, visit.DateLabel)</small>
                    </div>
                </article>
            }
        }
    </section>

    @if (Model.ScheduledRequests.Count > 0)
    {
        <section class="pa-section">
            <div class="pa-section-head">
                <h2>@L["Scheduled requests"]</h2>
                <a asp-controller="Administrador" asp-action="Tasks" asp-route-filter="scheduled">@L["View all"] <i class="fas fa-chevron-right"></i></a>
            </div>
            @foreach (var request in Model.ScheduledRequests)
            {
                <article class="pa-request-row">
                    <img src="@(request.ImageUrl ?? "/inspeccion2.jpeg")" alt="" />
                    <div class="pa-request-body">
                        <span class="pa-status-pill pa-status-pill--@request.StatusCss">@UiDisplayLocalization.Localize(L, request.StatusLabel)</span>
                        <strong>@UiDisplayLocalization.Localize(L, request.Title)</strong>
                        <small>@UiDisplayLocalization.Localize(L, request.PropertyName) · @UiDisplayLocalization.Localize(L, request.Location)</small>
                        <span class="pa-request-meta"><i class="fas fa-calendar"></i> @UiDisplayLocalization.Localize(L, request.DateLabel)</span>
                    </div>
                </article>
            }
        </section>
    }
</div>
