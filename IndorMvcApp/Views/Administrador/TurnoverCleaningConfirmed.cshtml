@model IndorMvcApp.ViewModels.PropertyAdministratorTurnoverCleaningConfirmedViewModel
@{
    ViewData["Title"] = "Turnover Cleaning scheduled";
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowShowBack = false;
    var propertyLabel = Model.ViewingProperty != null
        ? $"{Model.ViewingProperty.PropertyTypeLabel} • {Model.ViewingProperty.Location}"
        : "";
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro">
        <h1>Turnover Cleaning scheduled <span class="pa-flow-step-pill pa-flow-step-pill--inline pa-flow-step-pill--purple">Step @Model.FlowStep of @Model.TotalSteps</span></h1>
        <p>Your turnover service is booked and ready.</p>
    </section>

    <div class="pa-success-banner pa-success-banner--turnover">
        <span class="pa-success-icon"><i class="fas fa-check"></i></span>
        <div>
            <strong>Request received</strong>
            <span>Your turnover cleaning is scheduled.</span>
        </div>
    </div>

    <article class="pa-tech-card pa-tech-card--turnover">
        <div class="pa-tech-head">
            <img src="/inspeccion2.jpeg" alt="" class="pa-tech-avatar" />
            <div class="pa-tech-meta">
                <strong>@Model.TechnicianName</strong>
                <span><i class="fas fa-star"></i> @Model.TechnicianRating.ToString("0.0")</span>
                <small>@Model.TechnicianTitle</small>
            </div>
            <span class="pa-verified-badge"><i class="fas fa-check"></i> Verified</span>
            <span class="pa-tech-deco pa-tech-deco--purple" aria-hidden="true"><i class="fas fa-spray-can-sparkles"></i></span>
        </div>
        <div class="pa-tech-stats">
            <div>
                <i class="fas fa-clock"></i>
                <strong>@Model.ScheduleLabel</strong>
                <small>Scheduled</small>
            </div>
            <div>
                <i class="fas fa-car"></i>
                <strong>@Model.VehicleLabel</strong>
                <small>Vehicle</small>
            </div>
            <div>
                <i class="fas fa-house"></i>
                <strong>Viewing: @(Model.ViewingProperty?.PropertyName)</strong>
                <small>@propertyLabel</small>
            </div>
        </div>
    </article>

    <div class="pa-confirm-split">
        <article class="pa-summary-card-block">
            <h2><i class="fas fa-clipboard-list"></i> Request summary</h2>
            <ul class="pa-summary-detail-list">
                @foreach (var item in Model.Summary)
                {
                    <li>
                        <i class="fas @item.IconClass"></i>
                        <span>@item.Label</span>
                        <strong>@item.Value</strong>
                    </li>
                }
            </ul>
        </article>

        <article class="pa-timeline-card pa-timeline-card--inline">
            <h2><i class="fas fa-clock"></i> Service timeline</h2>
            <ul class="pa-timeline">
                @foreach (var step in Model.Timeline)
                {
                    <li class="pa-timeline-item pa-timeline-item--@step.State">
                        <span class="pa-timeline-dot"><i class="fas @step.IconClass"></i></span>
                        <div class="pa-timeline-body">
                            <strong>@step.Label</strong>
                            <span>@step.StatusLabel</span>
                        </div>
                    </li>
                }
            </ul>
        </article>
    </div>

    <div class="pa-action-grid">
        <button type="button" class="pa-action-tile"><i class="fas fa-comment"></i><span>Message co-host</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-calendar"></i><span>Reschedule</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-rotate"></i><span>Add recurring</span></button>
        <a asp-controller="Administrador" asp-action="Tasks" class="pa-action-tile">
            <i class="fas fa-file-lines"></i><span>View details</span>
        </a>
    </div>

    <div class="pa-tip-banner">
        <span class="pa-tip-icon"><i class="fas fa-lightbulb"></i></span>
        <p><strong>Tip:</strong> @Model.Tip</p>
    </div>

    <a asp-controller="Administrador" asp-action="Tasks" class="ob-btn ob-btn-primary pa-flow-submit">
        Track request <i class="fas fa-chevron-right"></i>
    </a>
    <a asp-controller="Administrador" asp-action="Index" asp-route-propertyId="@Model.ViewingProperty?.Id" class="ob-btn ob-btn-outline pa-flow-edit">
        Back to dashboard
    </a>
</div>
