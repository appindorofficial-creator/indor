@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyFloodFormViewModel
@{
    ViewData["Title"] = L["Emergency Flood"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    // Header back leaves the flow; Edit details stays on this form (scroll to fields).
    ViewBag.FlowBackUrl = Url.Action("Index", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro" id="pa-emergency-details">
        <h1>@L["Emergency Flood"] <span class="pa-flow-step-pill pa-flow-step-pill--inline">@L.T("Step {0} of {1}", Model.FlowStep, Model.TotalSteps)</span></h1>
        <p>@L["Tell us what's happening, how bad it is, and whether you have insurance details ready."]</p>
    </section>

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="EmergencyFloodDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-droplet pa-q-icon"></i> @L["What's the problem?"]</label>
            <div class="pa-chip-grid pa-chip-grid--scroll">
                @foreach (var p in new (string Value, string Label)[]
                {
                    ("ActiveFlooding", L["Active flooding"]),
                    ("BurstPipe", L["Burst pipe"]),
                    ("RoofLeak", L["Roof leak"]),
                    ("ApplianceLeak", L["Appliance leak"]),
                    ("SewageBackup", L["Sewage backup"]),
                    ("Overflow", L["Overflow"])
                })
                {
                    <label class="pa-chip @(Model.ProblemType == p.Value ? "is-selected" : null)">
                        <input type="radio" name="ProblemType" value="@p.Value" @(Model.ProblemType == p.Value ? "checked" : null) />
                        <span>@L[p.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-water pa-q-icon"></i> @L["Is water actively coming in right now?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var v in new[] { ("Yes", L["Yes"]), ("No", L["No"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-toggle-btn @(Model.WaterActivelyComingIn == v.Item1 ? "is-selected" : null)">
                        <input type="radio" name="WaterActivelyComingIn" value="@v.Item1" @(Model.WaterActivelyComingIn == v.Item1 ? "checked" : null) />
                        @v.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-users pa-q-icon"></i> @L["Are guests currently inside?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var v in new[] { ("Yes", L["Yes"]), ("No", L["No"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-toggle-btn @(Model.GuestsInside == v.Item1 ? "is-selected" : null)">
                        <input type="radio" name="GuestsInside" value="@v.Item1" @(Model.GuestsInside == v.Item1 ? "checked" : null) />
                        @v.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label><i class="fas fa-triangle-exclamation pa-q-icon"></i> @L["How urgent is it?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--4">
                @foreach (var u in new[] { ("Emergency", L["Emergency"]), ("Urgent", L["Urgent"]), ("Soon", L["Soon"]), ("NotUrgent", L["Not urgent"]) })
                {
                    <label class="pa-toggle-btn @(Model.Urgency == u.Item1 ? "is-selected" : null) @(u.Item1 == "Emergency" ? "is-urgent" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        @u.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-location-dot pa-q-icon"></i> @L["Where is the water?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var loc in new[] { ("LivingRoom", L["Living room"]), ("Bathroom", L["Bathroom"]), ("Kitchen", L["Kitchen"]), ("Laundry", L["Laundry"]), ("Ceiling", L["Ceiling"]), ("Other", L["Other"]) })
                {
                    <label class="pa-chip @(Model.WaterLocation == loc.Item1 ? "is-selected" : null)">
                        <input type="radio" name="WaterLocation" value="@loc.Item1" @(Model.WaterLocation == loc.Item1 ? "checked" : null) />
                        <span>@loc.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-lock pa-q-icon"></i> @L["Can the crew enter now?"]</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @foreach (var e in new[] { ("SmartLock", L["Yes, with smart lock"]), ("HostMeet", L["Host will meet"]), ("GuestApproval", L["Need guest approval"]) })
                {
                    <label class="pa-chip pa-chip--wide @(Model.EntryAccess == e.Item1 ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Item1" @(Model.EntryAccess == e.Item1 ? "checked" : null) />
                        <span>@e.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label><i class="fas fa-phone pa-q-icon"></i> @L["Best urgent contact number"]</label>
            <div class="pa-field">
                <i class="fas fa-phone"></i>
                <input type="tel" name="ContactPhone" value="@Model.ContactPhone" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">8</span>
            <label><i class="fas fa-note-sticky pa-q-icon"></i> @L["Notes (what's happening?)"]</label>
            <textarea class="pa-textarea" name="Notes" rows="3">@Model.Notes</textarea>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">9</span>
            <label><i class="fas fa-camera pa-q-icon"></i> @L["Photos & voice"]</label>
            <div class="pa-media-actions pa-media-actions--stack">
                <button type="button" class="pa-media-btn pa-media-btn--large"><i class="fas fa-camera"></i> @L["Add photos — Help us assess faster"]</button>
                <button type="button" class="pa-media-btn pa-media-btn--large"><i class="fas fa-microphone"></i> @L["Voice note — Tap to record"]</button>
            </div>
        </div>

        <article class="pa-insurance-card">
            <div class="pa-insurance-head">
                <i class="fas fa-shield-halved"></i>
                <strong>@L["Will this be processed through insurance?"]</strong>
            </div>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var v in new[] { ("Yes", L["Yes"]), ("No", L["No"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-toggle-btn @(Model.ProcessThroughInsurance == v.Item1 ? "is-selected" : null)">
                        <input type="radio" name="ProcessThroughInsurance" value="@v.Item1" @(Model.ProcessThroughInsurance == v.Item1 ? "checked" : null) />
                        @v.Item2
                    </label>
                }
            </div>
            <div class="pa-insurance-fields">
                <div class="pa-field">
                    <span>@L["Carrier"]</span>
                    <input type="text" name="InsuranceCarrier" value="@Model.InsuranceCarrier" placeholder="@L["e.g. State Farm"]" />
                </div>
                <div class="pa-field">
                    <span>@L["Claim opened?"]</span>
                    <input type="text" name="ClaimOpened" value="@Model.ClaimOpened" />
                </div>
                <div class="pa-field">
                    <span>@L["Claim # if available"]</span>
                    <input type="text" name="ClaimNumber" value="@Model.ClaimNumber" placeholder="@L["Enter claim number"]" />
                </div>
            </div>
            <button type="button" class="pa-upload-policy-btn"><i class="fas fa-cloud-arrow-up"></i> @L["Upload policy / claim docs"]</button>
        </article>

        <div class="pa-flow-summary-grid">
            <div class="pa-flow-summary-card">
                <h3>@L["Request summary"]</h3>
                <ul class="pa-summary-list">
                    <li><i class="fas fa-house"></i> @(Model.ViewingProperty?.PropertyName)</li>
                    <li><i class="fas fa-droplet"></i> @L["Active flooding"]</li>
                    <li><i class="fas fa-users"></i> @L["Guests inside: Yes"]</li>
                    <li><i class="fas fa-key"></i> @L["Smart lock"]</li>
                    <li><i class="fas fa-shield-halved"></i> @L["Insurance: Yes"]</li>
                </ul>
            </div>
            <div class="pa-flow-pro-card pa-flow-pro-card--flood">
                <strong>@Model.ProEtaLabel</strong>
                <small>@L["Licensed • Insured • IICRC-ready"]</small>
                <p>@L["Estimated:"] <strong>@Model.EstimatedPrice</strong> @L["diagnostic / emergency mitigation triage"]</p>
                <p>@L["Priority"] <span class="pa-included">@L["included"]</span> <i class="fas fa-star pa-included"></i></p>
            </div>
        </div>

        <div class="pa-notify-banner pa-notify-banner--warn">
            <i class="fas fa-circle-info"></i>
            <span>@L["We can help coordinate with insurance-backed mitigation if documentation is available."]</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Request emergency service"] <i class="fas fa-arrow-right"></i></button>
        <a href="#pa-emergency-details" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') return;
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair, .pa-insurance-card .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
