@model IndorMvcApp.ViewModels.PropertyAdministratorPoolHotTubStep1ViewModel
@{
    ViewData["Title"] = L["Pool & Hot Tub Repair"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pool & Hot Tub Repair"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what needs attention so we can send the right service pro."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Index", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="PoolHotTubDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-water-ladder pa-q-icon pa-q-icon--green"></i> @L["What do you need help with?"]</label>
            <div class="pa-pool-service-row">
                @foreach (var s in new (string Value, string Label, string Icon)[] {
                    ("PoolRepair", L["Pool repair"], "fa-screwdriver-wrench"),
                    ("HotTubRepair", L["Hot tub repair"], "fa-hot-tub-person"),
                    ("RoutinePoolService", L["Routine pool service"], "fa-water-ladder"),
                    ("SpaHotTubService", L["Spa / hot tub service"], "fa-spa") })
                {
                    <label class="pa-pool-option-card @(Model.ServiceHelpType == s.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceHelpType" value="@s.Value" @(Model.ServiceHelpType == s.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <i class="fas @s.Icon"></i>
                        <span>@s.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["What's the main issue?"]</label>
            <div class="pa-pool-issue-grid">
                @foreach (var i in new (string Value, string Label, string Icon)[] {
                    ("PumpNotWorking", L["Pump not working"], "fa-gears"),
                    ("HeaterIssue", L["Heater issue"], "fa-temperature-high"),
                    ("WaterLeak", L["Water leak"], "fa-droplet"),
                    ("CloudyDirtyWater", L["Cloudy / dirty water"], "fa-circle"),
                    ("JetsNotWorking", L["Jets not working"], "fa-wind"),
                    ("FilterProblem", L["Filter problem"], "fa-filter") })
                {
                    <label class="pa-pool-option-card @(Model.MainIssue == i.Value ? "is-selected" : null)">
                        <input type="radio" name="MainIssue" value="@i.Value" @(Model.MainIssue == i.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <i class="fas @i.Icon"></i>
                        <span>@L[i.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Is a guest stay affected?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestStayAffected == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestStayAffected" value="Yes" @(Model.GuestStayAffected == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.GuestStayAffected == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestStayAffected" value="No" @(Model.GuestStayAffected == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["How urgent is it?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var u in new[] { ("Routine", L["Routine"]), ("Urgent", L["Urgent"]), ("Emergency", L["Emergency"]) })
                {
                    <label class="pa-chip @(Model.Urgency == u.Item1 ? "is-selected" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        <span>@u.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--green"></i> @L["Add quick details"]</label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" id="poolDetails">@Model.QuickDetails</textarea>
            <small class="pa-char-count"><span id="poolDetailsCount">@Model.QuickDetails.Length</span> / 250</small>
        </div>

        @await Html.PartialAsync("_PropertyAdminMediaCapture")

        <div class="pa-lawn-photo-banner">
            <i class="fas fa-circle-info"></i>
            <div>
                <strong>@L["We'll match you with a pool or spa pro based on the issue."]</strong>
                <small>@L["Licensed, insured, and background-checked technicians."]</small>
            </div>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-pool-option-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                var row = this.closest('.pa-pool-service-row, .pa-pool-issue-grid');
                if (row) {
                    row.querySelectorAll('.pa-pool-option-card').forEach(function (el) { el.classList.remove('is-selected'); });
                }
                this.closest('.pa-pool-option-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('poolDetails');
        var counter = document.getElementById('poolDetailsCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
