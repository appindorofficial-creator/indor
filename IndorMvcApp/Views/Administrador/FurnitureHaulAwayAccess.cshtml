@model IndorMvcApp.ViewModels.PropertyAdministratorFurnitureHaulAwayStep2ViewModel
@{
    ViewData["Title"] = L["Furniture Haul Away"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Furniture Haul Away"].ToString();
    ViewBag.FlowSubtitle = L["Tell us how the crew can access the property and when to arrive."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("FurnitureHaulAwayDetails", "Administrador", new { propertyId = Model.PropertyId });
    var locations = Model.ItemLocations.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @if (Model.ViewingProperty != null && Model.ViewingProperty.Id > 0)
    {        <a href="@(Url.Action("Properties", "Administrador", new { from = "switch", returnUrl = Context.Request.Path + Context.Request.QueryString }))" class="pa-viewing-strip pa-viewing-strip--switchable" aria-label="@L["Switch property"]">
            <img src="@(Model.ViewingProperty.ImageUrl ?? "/inspeccion2.jpeg")" alt="" class="pa-viewing-strip-thumb" />
            <div class="pa-viewing-strip-main">
                <strong>@L.T("Viewing: {0}", Model.ViewingProperty.PropertyName)</strong>
                @if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
                {
                    <span class="pa-checkout-badge pa-checkout-badge--guest"><i class="fas fa-user"></i> @UiDisplayLocalization.Localize(L, Model.PropertyStatusLabel)</span>
                }
                <small>@Model.ViewingProperty.PropertyTypeLabel • @Model.ViewingProperty.Location</small>
            </div>
            <span class="pa-viewing-switch" aria-hidden="true"><span class="pa-viewing-switch-label">@L["Switch property"]</span><i class="fas fa-chevron-down pa-portfolio-chevron"></i></span>
        </a>
    }

    <form asp-action="FurnitureHaulAwayAccess" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
        <input type="hidden" name="ItemCount" value="@Model.ItemCount" />
        <input type="hidden" name="PickupSize" value="@Model.PickupSize" />
        <input type="hidden" name="IsOccupied" value="@Model.IsOccupied" />
        <input type="hidden" name="GuestsInside" value="@Model.GuestsInside" />
        <input type="hidden" name="QuickDetails" value="@Model.QuickDetails" />
        @foreach (var item in Model.FurnitureItems.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            <input type="hidden" name="FurnitureItemsList" value="@item" />
        }

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-bolt pa-q-icon pa-q-icon--blue"></i> @L["When should pickup happen?"]</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @foreach (var w in new (string Value, string Label, string Icon)[] { ("Asap", L["ASAP"], "fa-bolt"), ("TodayAfterCheckout", L["Today after checkout"], "fa-calendar-day"), ("ScheduledTime", L["Scheduled time"], "fa-calendar") })
                {
                    <label class="pa-chip pa-chip--wide @(Model.PickupWhen == w.Value ? "is-selected" : null)">
                        <input type="radio" name="PickupWhen" value="@w.Value" @(Model.PickupWhen == w.Value ? "checked" : null) />
                        <i class="fas @w.Icon"></i>
                        <span>@w.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-clock pa-q-icon pa-q-icon--blue"></i> @L["What time window works best?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var tw in new (string Value, string Label)[] { ("Morning", L["Morning"]), ("Afternoon", L["Afternoon"]), ("Evening", L["Evening"]) })
                {
                    <label class="pa-toggle-btn @(Model.TimeWindow == tw.Value ? "is-selected" : null)">
                        <input type="radio" name="TimeWindow" value="@tw.Value" @(Model.TimeWindow == tw.Value ? "checked" : null) />
                        <i class="fas fa-sun"></i> @tw.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-key pa-q-icon pa-q-icon--blue"></i> @L["Can the crew enter the property?"]</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @foreach (var e in new (string Value, string Label)[] { ("SmartLock", L["Yes, with smart lock"]), ("HostMeet", L["Host will meet crew"]), ("CurbsideOnly", L["Curbside pickup only"]) })
                {
                    <label class="pa-chip pa-chip--wide @(Model.EntryAccess == e.Value ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Value" @(Model.EntryAccess == e.Value ? "checked" : null) />
                        <span>@e.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Entry or gate code"] <small>@L["(optional)"]</small></label>
            <div class="pa-field">
                <i class="fas fa-key"></i>
                <input type="text" name="EntryCode" value="@Model.EntryCode" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-location-dot pa-q-icon pa-q-icon--blue"></i> @L["Where are the items located?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-furniture-items-grid pa-furniture-items-grid--6">
                @foreach (var loc in new (string Value, string Label, string Icon)[]
                {
                    ("LivingRoom", L["Living room"], "fa-couch"),
                    ("Bedroom", L["Bedroom"], "fa-bed"),
                    ("Garage", L["Garage"], "fa-warehouse"),
                    ("FrontCurb", L["Front curb"], "fa-road"),
                    ("StorageRoom", L["Storage room"], "fa-box"),
                    ("MultipleAreas", L["Multiple areas"], "fa-border-all")
                })
                {
                    <label class="pa-junk-item-card @(locations.Contains(loc.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="ItemLocationsList" value="@loc.Value" @(locations.Contains(loc.Value) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <i class="fas @loc.Icon"></i>
                        <span>@loc.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-stairs pa-q-icon pa-q-icon--blue"></i> @L["Are there stairs or elevator access?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var a in new (string Value, string Label, string Icon)[] { ("GroundFloor", L["Ground floor"], "fa-building"), ("Stairs", L["Stairs"], "fa-stairs"), ("Elevator", L["Elevator"], "fa-elevator") })
                {
                    <label class="pa-toggle-btn pa-toggle-btn--icon @(Model.AccessLevel == a.Value ? "is-selected" : null)">
                        <input type="radio" name="AccessLevel" value="@a.Value" @(Model.AccessLevel == a.Value ? "checked" : null) />
                        <i class="fas @a.Icon"></i> @a.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label><i class="fas fa-users pa-q-icon pa-q-icon--blue"></i> @L["Who should receive updates?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var r in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("CoHost", L["Co-host"]) })
                {
                    <label class="pa-toggle-btn @(Model.UpdateRecipient == r.Item1 ? "is-selected" : null)">
                        <input type="radio" name="UpdateRecipientsList" value="@r.Item1" @(Model.UpdateRecipient == r.Item1 ? "checked" : null) /> @r.Item2
                    </label>
                }
            </div>
        </div>

        @{
            ViewData["PaContactQnum"] = "8";
            ViewData["PaContactValue"] = Model.ContactPhone;
            ViewData["PaContactLabelIcon"] = "fa-phone pa-q-icon pa-q-icon--blue";
        }
        @await Html.PartialAsync("_PropertyAdminUrgentContactPhone")

        <div class="pa-junk-crew-banner">
            <i class="fas fa-circle-check"></i>
            <div>
                <strong>@Model.CrewEtaLabel</strong>
                <small>@L["We'll confirm final arrival time after review."]</small>
            </div>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Review request"] <i class="fas fa-arrow-right"></i></button>
        <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
        <a href="@Url.Action("Services", "Administrador", new { propertyId = Model.PropertyId })" class="pa-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-junk-item-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-junk-item-card')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
    </script>
}
