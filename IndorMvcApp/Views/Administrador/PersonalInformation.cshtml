@model IndorMvcApp.ViewModels.PropertyAdministratorPersonalInformationViewModel
@{
    ViewData["Title"] = L["Personal information"];
    Layout = "_PropertyAdminLayout";
}

<div class="pa-portal-shell pa-portal-shell--personal">
    <header class="pa-personal-header">
        <a asp-controller="Administrador" asp-action="Profile" class="pa-profile-back" aria-label="@L["Back"]">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="pa-personal-header-text">
            <h1>@L["Personal information"]</h1>
            <p>@L["Manage your personal details and how we contact you."]</p>
        </div>
    </header>

    <div id="paPersonalPhotoAlerts">
    @if (TempData["PersonalPhotoOk"] is string photoOk)
    {
        <div class="pa-personal-alert pa-personal-alert--success" role="status">@photoOk</div>
    }
    @if (TempData["PersonalPhotoError"] is string photoError)
    {
        <div class="pa-personal-alert pa-personal-alert--error" role="alert">@photoError</div>
    }
    </div>

    <section class="pa-personal-profile-card">
        <form asp-controller="Administrador" asp-action="UploadPersonalPhoto" method="post" enctype="multipart/form-data" id="paPersonalPhotoForm">
            @Html.AntiForgeryToken()
            <div class="pa-personal-photo-wrap">
                <div class="pa-personal-photo-preview" id="paPersonalPhotoPreview">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfilePhotoUrl))
                    {
                        <img src="@Model.ProfilePhotoUrl" alt="" class="pa-personal-photo" id="paPersonalPhotoImg" />
                    }
                    else
                    {
                        <span class="pa-personal-photo pa-personal-photo--placeholder" id="paPersonalPhotoPlaceholder"><i class="fas fa-user"></i></span>
                        <img src="" alt="" class="pa-personal-photo" id="paPersonalPhotoImg" hidden />
                    }
                </div>
                <button type="button" class="pa-personal-photo-edit" id="paPersonalPhotoBtn" aria-label="@L["Change profile photo"]" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-camera"></i>
                </button>
                <div class="pa-personal-photo-menu" id="paPersonalPhotoMenu" role="menu" hidden>
                    <button type="button" class="pa-personal-photo-menu-item" id="paPersonalPhotoTake" role="menuitem">
                        <i class="fas fa-camera"></i> @L["Take photo"]
                    </button>
                    <button type="button" class="pa-personal-photo-menu-item" id="paPersonalPhotoChoose" role="menuitem">
                        <i class="fas fa-image"></i> @L["Choose from library"]
                    </button>
                </div>
                <input type="file" id="paPersonalPhotoCamera" name="photo" accept="image/*" capture="environment" hidden />
                <input type="file" id="paPersonalPhotoLibrary" name="photo" accept="image/jpeg,image/png,image/webp,image/*" hidden />
            </div>
        </form>
        <strong>@Model.FullName</strong>
        <span class="pa-profile-badge">@UiDisplayLocalization.Localize(L, Model.RoleBadge)</span>
    </section>

    <section class="pa-personal-section">
        <h2>@L["Personal details"]</h2>
        <div class="pa-personal-list">
            <div class="pa-personal-row pa-personal-row--static">
                <span class="pa-personal-row-label">@L["Full name"]</span>
                <span class="pa-personal-row-value">@Model.FullName</span>
            </div>
            <div class="pa-personal-row pa-personal-row--static">
                <span class="pa-personal-row-label">@L["Email address"]</span>
                <span class="pa-personal-row-value">@Model.Email</span>
            </div>
            <a href="tel:@Model.Phone" class="pa-personal-row">
                <span class="pa-personal-row-label">@L["Phone number"]</span>
                <span class="pa-personal-row-value is-link">@Model.Phone</span>
                <i class="fas fa-chevron-right"></i>
            </a>
            <div class="pa-personal-row pa-personal-row--static">
                <span class="pa-personal-row-label">@L["Address"]</span>
                <span class="pa-personal-row-value">@Model.Address</span>
            </div>
            <div class="pa-personal-row pa-personal-row--static">
                <span class="pa-personal-row-label">@L["Date of birth"]</span>
                <span class="pa-personal-row-value">@UiDisplayLocalization.Localize(L, Model.DateOfBirthLabel)</span>
            </div>
        </div>
    </section>

    <section class="pa-personal-section">
        <h2>@L["Communication preferences"]</h2>
        <div class="pa-personal-list">
            <div class="pa-personal-row pa-personal-row--static">
                <span class="pa-personal-row-label">@L["Preferred contact method"]</span>
                <span class="pa-personal-row-value">@UiDisplayLocalization.Localize(L, Model.PreferredContactMethod)</span>
            </div>
            <div class="pa-personal-row pa-personal-row--toggle">
                <div>
                    <strong>@L["Marketing emails"]</strong>
                    <small>@L["Receive updates about new features and offers."]</small>
                </div>
                <span class="pa-personal-toggle @(Model.MarketingEmailsEnabled ? "is-on" : null)" aria-hidden="true">
                    <span class="pa-personal-toggle-knob"></span>
                </span>
            </div>
        </div>
    </section>

    <section class="pa-personal-section" id="security">
        <h2>@L["Security"]</h2>
        <div class="pa-personal-list">
            <a href="@Model.ChangePasswordUrl" class="pa-personal-row">
                <span class="pa-personal-row-icon"><i class="fas fa-lock"></i></span>
                <span class="pa-personal-row-label">@L["Change password"]</span>
                <i class="fas fa-chevron-right"></i>
            </a>
        </div>
    </section>

    <section class="pa-personal-info-card">
        <div>
            <strong>@L["How we use your information"]</strong>
            <p>@L["We use your information to provide and improve our services. Learn more in our"] <a href="@Model.PrivacyPolicyUrl">@L["Privacy Policy"]</a>.</p>
        </div>
        <i class="fas fa-chevron-right"></i>
    </section>
</div>

@section Scripts {
<script>
    (function () {
        var form = document.getElementById('paPersonalPhotoForm');
        var menuBtn = document.getElementById('paPersonalPhotoBtn');
        var menu = document.getElementById('paPersonalPhotoMenu');
        var takeBtn = document.getElementById('paPersonalPhotoTake');
        var chooseBtn = document.getElementById('paPersonalPhotoChoose');
        var cameraInput = document.getElementById('paPersonalPhotoCamera');
        var libraryInput = document.getElementById('paPersonalPhotoLibrary');
        var previewImg = document.getElementById('paPersonalPhotoImg');
        var placeholder = document.getElementById('paPersonalPhotoPlaceholder');

        if (!form || !menuBtn || !menu) {
            return;
        }

        function closeMenu() {
            menu.hidden = true;
            menuBtn.setAttribute('aria-expanded', 'false');
        }

        menuBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var willOpen = menu.hidden;
            menu.hidden = !willOpen;
            menuBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });

        document.addEventListener('click', closeMenu);
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeMenu();
            }
        });

        if (takeBtn && cameraInput) {
            takeBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                closeMenu();
                cameraInput.click();
            });
        }

        if (chooseBtn && libraryInput) {
            chooseBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                closeMenu();
                libraryInput.click();
            });
        }

        function showPhotoAlert(message, tone) {
            var wrap = document.getElementById('paPersonalPhotoAlerts');
            if (!wrap) {
                return;
            }

            wrap.innerHTML = '';
            var alert = document.createElement('div');
            alert.className = 'pa-personal-alert pa-personal-alert--' + tone;
            alert.setAttribute('role', tone === 'success' ? 'status' : 'alert');
            alert.textContent = message;
            wrap.appendChild(alert);
        }

        function handlePhotoSelected(input) {
            if (!input.files || input.files.length === 0) {
                return;
            }

            var file = input.files[0];
            if (previewImg && file.type.startsWith('image/')) {
                previewImg.src = URL.createObjectURL(file);
                previewImg.hidden = false;
                if (placeholder) {
                    placeholder.hidden = true;
                }
            }

            var formData = new FormData(form);
            formData.delete('photo');
            formData.append('photo', file);

            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(function (response) {
                    return response.json().then(function (data) {
                        if (!response.ok || !data.ok) {
                            throw new Error(data.message || 'Could not upload photo.');
                        }
                        return data;
                    });
                })
                .then(function (data) {
                    if (previewImg && data.photoUrl) {
                        previewImg.src = data.photoUrl;
                        previewImg.hidden = false;
                        if (placeholder) {
                            placeholder.hidden = true;
                        }
                    }
                    showPhotoAlert(data.message || 'Profile photo updated.', 'success');
                })
                .catch(function (error) {
                    showPhotoAlert(error.message || 'Could not upload photo.', 'error');
                })
                .finally(function () {
                    input.value = '';
                });
        }

        if (cameraInput) {
            cameraInput.addEventListener('change', function () {
                handlePhotoSelected(cameraInput);
            });
        }

        if (libraryInput) {
            libraryInput.addEventListener('change', function () {
                handlePhotoSelected(libraryInput);
            });
        }
    })();
</script>
}
