@model IndorMvcApp.ViewModels.PropertyAdministratorPestControlStep2ViewModel
@{
    ViewData["Title"] = L["Pest Control"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pest Control"].ToString();
    ViewBag.FlowSubtitle = L["Choose service timing and access so the pro can arrive prepared."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Schedule"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("PestControlDetails", "Administrador", new { propertyId = Model.PropertyId });
    ViewBag.BadgeLabel = Model.PropertyStatusLabel;
    var treatAreas = Model.TreatAreas.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
    var recipients = Model.UpdateRecipients.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="PestControlSchedule" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
        <input type="hidden" name="PestType" value="@Model.PestType" />
        <input type="hidden" name="IssueLocation" value="@Model.IssueLocation" />
        <input type="hidden" name="Urgency" value="@Model.Urgency" />
        <input type="hidden" name="GuestsStaying" value="@Model.GuestsStaying" />
        <input type="hidden" name="LivePestsToday" value="@Model.LivePestsToday" />
        <input type="hidden" name="QuickDetails" value="@Model.QuickDetails" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["What type of service do you need?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var s in new[] { ("OneTimeTreatment", L["One-time treatment"]), ("RecurringService", L["Recurring service"]), ("InspectionOnly", L["Inspection only"]) })
                {
                    <label class="pa-chip @(Model.ServiceType == s.Item1 ? "is-selected" : null)">
                        <input type="radio" name="ServiceType" value="@s.Item1" @(Model.ServiceType == s.Item1 ? "checked" : null) />
                        <span>@s.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-clock pa-q-icon pa-q-icon--green"></i> @L["Preferred arrival"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var a in new[] { ("Asap", L["ASAP"]), ("TodayLater", L["Today later"]), ("Tomorrow", L["Tomorrow"]) })
                {
                    <label class="pa-chip @(Model.PreferredArrival == a.Item1 ? "is-selected" : null)">
                        <input type="radio" name="PreferredArrival" value="@a.Item1" @(Model.PreferredArrival == a.Item1 ? "checked" : null) />
                        <span>@a.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-door-open pa-q-icon pa-q-icon--green"></i> @L["Can the technician enter now?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var e in new[] { ("SmartLock", L["Yes, with smart lock"]), ("HostOnSite", L["Host will meet"]), ("GuestApproval", L["Need guest approval"]) })
                {
                    <label class="pa-chip @(Model.EntryAccess == e.Item1 ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Item1" @(Model.EntryAccess == e.Item1 ? "checked" : null) />
                        <span>@e.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Are pets currently at the property?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.HasPets == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="HasPets" value="Yes" @(Model.HasPets == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.HasPets == "No" ? "is-selected" : null)">
                    <input type="radio" name="HasPets" value="No" @(Model.HasPets == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Areas to treat"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-pw-areas-grid">
                @foreach (var a in new[] { ("Kitchen", L["Kitchen"]), ("Pantry", L["Pantry"]), ("Bathroom", L["Bathroom"]), ("Bedrooms", L["Bedrooms"]), ("PatioExterior", L["Patio / exterior"]) })
                {
                    <label class="pa-pw-area-card @(treatAreas.Contains(a.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="TreatAreasList" value="@a.Item1" @(treatAreas.Contains(a.Item1) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <span>@a.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-users pa-q-icon pa-q-icon--green"></i> @L["Best contact for updates"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var r in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("CoHost", L["Co-host"]) })
                {
                    <label class="pa-chip @(recipients.Contains(r.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="UpdateRecipientsList" value="@r.Item1" @(recipients.Contains(r.Item1) ? "checked" : null) />
                        <span>@r.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label><i class="fas fa-key pa-q-icon pa-q-icon--green"></i> @L["Entry / access notes"]</label>
            <textarea class="pa-textarea" name="AccessNotes" rows="3" maxlength="200" id="pcAccessNotes">@Model.AccessNotes</textarea>
            <small class="pa-char-count"><span id="pcAccessNotesCount">@Model.AccessNotes.Length</span> / 200</small>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">8</span>
            <label><i class="fas fa-phone pa-q-icon pa-q-icon--green"></i> @L["Best phone number"]</label>
            <div class="pa-field">
                <i class="fas fa-phone"></i>
                <input type="tel" name="ContactPhone" value="@Model.ContactPhone" />
            </div>
        </div>

        <div class="pa-lawn-availability-banner">
            <div>
                <strong>@UiDisplayLocalization.Localize(L, Model.ProEtaLabel)</strong>
                <small>@L["We'll dispatch a licensed pest control pro based on your urgency and property access."]</small>
            </div>
            <i class="fas fa-clock"></i>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Review request"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-pw-area-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-pw-area-card')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-chip input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') return;
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('pcAccessNotes');
        var counter = document.getElementById('pcAccessNotesCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
