@model IndorMvcApp.ViewModels.PropertyAdministratorTrashOutConfirmedViewModel
@{
    ViewData["Title"] = L["Trash Out service scheduled"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Trash Out service scheduled"].ToString();
    ViewBag.FlowSubtitle = L.T("We'll take the bins out and bring them back for {0}.", Model.ViewingProperty?.PropertyName ?? L["your property"]);
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowShowBack = false;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <div class="pa-success-banner">
        <span class="pa-success-icon"><i class="fas fa-check"></i></span>
        <div>
            <strong>@L["Request received"]</strong>
            <span>@L["Your trash bin service is scheduled."]</span>
        </div>
    </div>

    <article class="pa-trash-summary-card">
        @if (Model.ViewingProperty != null && Model.ViewingProperty.Id > 0)
        {
            <img src="@(Model.ViewingProperty.ImageUrl ?? "/inspeccion2.jpeg")" alt="" class="pa-trash-summary-thumb" />
        }
        <ul class="pa-trash-summary-list">
            @foreach (var item in Model.Summary)
            {
                <li>
                    <i class="fas @item.IconClass"></i>
                    <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
                    <strong>@item.Value</strong>
                </li>
            }
        </ul>
    </article>

    <article class="pa-timeline-card">
        <h2>@L["Service timeline"]</h2>
        <ul class="pa-timeline">
            @foreach (var step in Model.Timeline)
            {
                <li class="pa-timeline-item pa-timeline-item--@step.State">
                    <span class="pa-timeline-dot"><i class="fas @step.IconClass"></i></span>
                    <div class="pa-timeline-body">
                        <strong>@UiDisplayLocalization.Localize(L, step.Label)</strong>
                        <span>@UiDisplayLocalization.Localize(L, step.StatusLabel)</span>
                    </div>
                </li>
            }
        </ul>
    </article>

    <article class="pa-trash-runner-card">
        <img src="/inspeccion2.jpeg" alt="" class="pa-trash-runner-avatar" />
        <div>
            <strong>@Model.RunnerLabel</strong>
            <small>@L.T("Arrival window: {0}", Model.ArrivalWindow)</small>
        </div>
        <button type="button" class="pa-pro-action-btn"><i class="fas fa-user-plus"></i></button>
    </article>

    <div class="pa-action-grid">
        <button type="button" class="pa-action-tile"><i class="fas fa-pen"></i><span>@L["Edit request"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-comment"></i><span>@L["Message guest"]</span></button>
        <a asp-controller="Administrador" asp-action="Tasks" class="pa-action-tile">
            <i class="fas fa-file-lines"></i><span>@L["View details"]</span>
        </a>
        <button type="button" class="pa-action-tile"><i class="fas fa-share"></i><span>@L["Share update"]</span></button>
    </div>

    <div class="pa-junk-tip-banner pa-junk-tip-banner--purple">
        <i class="fas fa-circle-info"></i>
        <p><strong>@L["Tip:"]</strong> @UiDisplayLocalization.Localize(L, Model.Tip)</p>
    </div>

    <a asp-controller="Administrador" asp-action="Tasks" class="ob-btn ob-btn-primary pa-flow-submit">
        @L["Track service"] <i class="fas fa-chevron-right"></i>
    </a>
    <a asp-controller="Administrador" asp-action="Index" asp-route-propertyId="@Model.ViewingProperty?.Id" class="ob-btn ob-btn-outline pa-flow-edit">
        @L["Back to start"]
    </a>
</div>
