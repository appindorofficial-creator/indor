@model IndorMvcApp.ViewModels.PropertyAdministratorPressureWashingStep1ViewModel
@{
    ViewData["Title"] = L["Pressure Washing"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pressure Washing"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what needs to be cleaned so we can prepare the right crew."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Schedule"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var areas = Model.WashAreas.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="PressureWashingDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-spray-can pa-q-icon pa-q-icon--green"></i> @L["What needs pressure washing?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-pw-areas-grid">
                @foreach (var a in new (string Value, string Label, string Icon)[]
                {
                    ("Driveway", L["Driveway"], "fa-road"),
                    ("Walkway", L["Walkway"], "fa-shoe-prints"),
                    ("Patio", L["Patio"], "fa-umbrella-beach"),
                    ("ExteriorWalls", L["Exterior walls"], "fa-house"),
                    ("Fence", L["Fence"], "fa-grip-lines-vertical"),
                    ("PoolDeck", L["Pool deck"], "fa-water-ladder"),
                    ("TrashArea", L["Trash area"], "fa-trash"),
                    ("Other", L["Other"], "fa-ellipsis")
                })
                {
                    <label class="pa-pw-area-card @(areas.Contains(a.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="WashAreasList" value="@a.Value" @(areas.Contains(a.Value) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <i class="fas @a.Icon"></i>
                        <span>@a.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["How large is the area?"]</label>
            <div class="pa-pw-size-row">
                @foreach (var s in new (string Value, string Label, string Sub)[] {
                    ("Small", "Small", "Up to 500 sq ft"),
                    ("Medium", "Medium", "500 – 2,000 sq ft"),
                    ("Large", "Large", "Over 2,000 sq ft") })
                {
                    <label class="pa-pw-size-card @(Model.AreaSize == s.Value ? "is-selected" : null)">
                        <input type="radio" name="AreaSize" value="@s.Value" @(Model.AreaSize == s.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <strong>@s.Label</strong>
                        <small>@s.Sub</small>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["What is the main reason for service?"]</label>
            <div class="pa-pw-reason-row">
                @foreach (var r in new (string Value, string Label, string Icon)[] {
                    ("GuestTurnover", L["Guest turnover"], "fa-calendar-check"),
                    ("RoutineUpkeep", L["Routine upkeep"], "fa-broom"),
                    ("HeavyDirtStains", L["Heavy dirt / stains"], "fa-droplet"),
                    ("HoaCurbAppeal", L["HOA / curb appeal"], "fa-house-chimney") })
                {
                    <label class="pa-pw-reason-card @(Model.ServiceReason == r.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceReason" value="@r.Value" @(Model.ServiceReason == r.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <i class="fas @r.Icon"></i>
                        <span>@r.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Is the property occupied right now?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.IsOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="Yes" @(Model.IsOccupied == "Yes" ? "checked" : null) />
                    <i class="fas fa-user"></i> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.IsOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="No" @(Model.IsOccupied == "No" ? "checked" : null) />
                    <i class="fas fa-house"></i> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Do guests need to be notified?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var n in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("Both", L["Both"]) })
                {
                    <label class="pa-chip @(Model.GuestNotification == n.Item1 ? "is-selected" : null)">
                        <input type="radio" name="GuestNotification" value="@n.Item1" @(Model.GuestNotification == n.Item1 ? "checked" : null) />
                        <span>@n.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--green"></i> @L["Add quick notes"] <small>@L["(optional)"]</small></label>
            <textarea class="pa-textarea" name="QuickNotes" rows="3" maxlength="200" id="pwNotes">@Model.QuickNotes</textarea>
            <small class="pa-char-count"><span id="pwNotesCount">@Model.QuickNotes.Length</span> / 200</small>
        </div>
        @{ ViewData["PaMediaShowVoice"] = false; }
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-lawn-availability-banner">
            <div>
                <strong>@L["Outdoor &amp; Exterior service"]</strong>
                <small>@L["Ideal for Airbnb turnovers and rental property upkeep."]</small>
            </div>
            <i class="fas fa-leaf"></i>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"] <i class="fas fa-chevron-right"></i></button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-pw-area-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-pw-area-card')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-pw-size-card input, .pa-pw-reason-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                var row = this.closest('.pa-pw-size-row, .pa-pw-reason-row');
                if (row) {
                    row.querySelectorAll('.pa-pw-size-card, .pa-pw-reason-card').forEach(function (el) { el.classList.remove('is-selected'); });
                }
                this.closest('.pa-pw-size-card, .pa-pw-reason-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('pwNotes');
        var counter = document.getElementById('pwNotesCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
