@model IndorMvcApp.ViewModels.PropertyAdministratorLockoutAccessStep1ViewModel
@{
    ViewData["Title"] = L["Lockout / Access"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Lockout / Access"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what happened so we can dispatch help fast."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    ViewBag.BadgeLabel = "Guest locked out";
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="LockoutAccessDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["What's the issue?"]</label>
            <div class="pa-chip-grid">
                @foreach (var item in new (string Value, string Label, string Icon)[]
                {
                    ("GuestLockedOut", L["Guest locked out"], "fa-key"),
                    ("SmartLockNotWorking", L["Smart lock not working"], "fa-mobile-screen"),
                    ("LostKey", L["Lost key"], "fa-key"),
                    ("CodeIssue", L["Code issue"], "fa-hashtag"),
                    ("DoorWontOpen", L["Door won't open"], "fa-door-closed")
                })
                {
                    <label class="pa-chip @(Model.IssueType == item.Value ? "is-selected" : null)">
                        <input type="radio" name="IssueType" value="@item.Value" @(Model.IssueType == item.Value ? "checked" : null) />
                        <i class="fas @item.Icon"></i>
                        <span>@L[item.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["Is someone currently outside?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.SomeoneOutside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="SomeoneOutside" value="Yes" @(Model.SomeoneOutside == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.SomeoneOutside == "No" ? "is-selected" : null)">
                    <input type="radio" name="SomeoneOutside" value="No" @(Model.SomeoneOutside == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Is the home occupied right now?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.HomeOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="HomeOccupied" value="Yes" @(Model.HomeOccupied == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.HomeOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="HomeOccupied" value="No" @(Model.HomeOccupied == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["How urgent is it?"]</label>
            <div class="pa-toggle-pair">
                @foreach (var u in new[] { ("Urgent", L["Urgent"]), ("Emergency", L["Emergency"]) })
                {
                    <label class="pa-toggle-btn @(Model.Urgency == u.Item1 ? "is-selected" : null) @(u.Item1 == "Emergency" ? "is-urgent" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        <i class="fas fa-bolt"></i> @u.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Who needs access?"]</label>
            <div class="pa-chip-grid pa-chip-grid--4">
                @foreach (var who in new (string Value, string Label, string Icon)[]
                {
                    ("Guest", L["Guest"], "fa-user"),
                    ("Me", L["Me"], "fa-house-user"),
                    ("Cleaner", L["Cleaner"], "fa-broom"),
                    ("CoHost", L["Co-host"], "fa-users")
                })
                {
                    <label class="pa-chip @(Model.WhoNeedsAccess == who.Value ? "is-selected" : null)">
                        <input type="radio" name="WhoNeedsAccess" value="@who.Value" @(Model.WhoNeedsAccess == who.Value ? "checked" : null) />
                        <i class="fas @who.Icon"></i>
                        <span>@who.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label>@L["Add quick details"]</label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" placeholder="@L["Describe what's happening..."]">@Model.QuickDetails</textarea>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-back-link">@L["Back to services"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
