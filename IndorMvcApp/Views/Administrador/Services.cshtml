@model IndorMvcApp.ViewModels.PropertyAdministratorServicesViewModel
@{
    ViewData["Title"] = L["Services"];
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "services";
    var filters = new[] {
        ("all", L["All services"], "fa-grid-2"),
        ("emergency", L["Emergency"], "fa-truck-medical"),
        ("homecare", L["Homecare"], "fa-house-chimney"),
        ("cleaning", L["Cleaning"], "fa-broom"),
        ("outdoor", L["Outdoor"], "fa-seedling"),
        ("moving", L["Moving"], "fa-truck")
    };
}

<div class="pa-portal-shell">
    @await Html.PartialAsync("_PropertyAdminTopbar", Model)

    @await Html.PartialAsync("_PropertyAdminPortfolioCard", Model)

    <div class="pa-search-bar" data-pa-service-search>
        <i class="fas fa-magnifying-glass"></i>
        <input type="search" id="pa-service-search"
               placeholder="@L["Search services (e.g., plumbing, cleaning)"]"
               aria-label="@L["Search services"]"
               autocomplete="off" />
        <button type="button" class="pa-portal-icon-btn" data-pa-service-search-focus aria-label="@L["Filter"]"><i class="fas fa-sliders"></i></button>
    </div>

    <div class="pa-filter-pills">
        @foreach (var (key, label, icon) in filters)
        {
            <a asp-controller="Administrador" asp-action="Services" asp-route-filter="@(key == "all" ? null : key)"
               class="pa-filter-pill @(Model.ActiveFilter == key ? "is-active" : null)">
                <i class="fas @icon"></i> @label
            </a>
        }
    </div>

    <div class="pa-emergency-banner">
        <div>
            <strong><i class="fas fa-phone"></i> @L["Help is available 24/7"]</strong>
            <p>@L["Call now to connect with an emergency service pro."]</p>
        </div>
        <a asp-controller="Administrador" asp-action="Services" asp-route-filter="emergency" class="pa-emergency-btn">@L["View emergency services"]</a>
    </div>

    <p class="pa-service-search-empty" data-pa-service-search-empty hidden>@L["No services match your search."]</p>

    @foreach (var category in Model.Categories)
    {
        <section class="pa-section" data-pa-service-section>
            <div class="pa-section-head">
                <h2>@UiDisplayLocalization.Localize(L, category.CategoryTitle)</h2>
                <a asp-controller="Administrador" asp-action="Services" asp-route-filter="@category.CategoryKey">@L["View all"] <i class="fas fa-chevron-right"></i></a>
            </div>
            <div class="pa-service-grid">
                @foreach (var item in category.Items)
                {
                    var localizedName = UiDisplayLocalization.Localize(L, item.ServiceName);
                    <a href="@item.Url" class="pa-service-grid-item" data-pa-service-item
                       data-search="@item.ServiceName @localizedName">
                        <span class="pa-service-hub-icon @item.ToneClass"><i class="fas @item.IconClass"></i></span>
                        <span>@localizedName</span>
                    </a>
                }
            </div>
        </section>
    }

    @if (Model.ActivePlans.Count > 0)
    {
        <section class="pa-section" data-pa-service-section data-pa-plans-section>
            <div class="pa-section-head">
                <h2>@L["Your service plans"]</h2>
                <a asp-controller="Administrador" asp-action="Services" asp-route-filter="homecare">@L["Manage all"] <i class="fas fa-chevron-right"></i></a>
            </div>
            <div class="pa-hscroll">
                @foreach (var plan in Model.ActivePlans)
                {
                    var planName = UiDisplayLocalization.Localize(L, plan.PlanName);
                    <article class="pa-plan-card" data-pa-service-item data-search="@plan.PlanName @planName">
                        <span class="pa-plan-icon @plan.ToneClass"><i class="fas @plan.IconClass"></i></span>
                        <strong>@planName</strong>
                        <small>@UiDisplayLocalization.Localize(L, plan.Frequency)</small>
                        <span class="pa-plan-next">@L.T("Next: {0}", plan.NextDueLabel)</span>
                        <span class="pa-plan-status">@UiDisplayLocalization.Localize(L, plan.StatusLabel)</span>
                    </article>
                }
            </div>
        </section>
    }

    <div class="pa-trust-row">
        <div><strong>@L["Vetted & insured"]</strong><small>@L["Service pros you can trust"]</small></div>
        <div><strong>@L["On-time guarantee"]</strong><small>@L["We show up when we say"]</small></div>
        <div><strong>@L["Quality guarantee"]</strong><small>@L["100% satisfaction promise"]</small></div>
        <div><strong>@L["Transparent pricing"]</strong><small>@L["Upfront & always fair"]</small></div>
    </div>
</div>
