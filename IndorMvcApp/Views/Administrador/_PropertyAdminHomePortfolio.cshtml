@model IndorMvcApp.ViewModels.PropertyAdministratorHomeViewModel
<div class="pa-portfolio-panel">
    <div class="pa-portfolio-head">
        <span class="pa-portfolio-icon"><i class="fas fa-building"></i></span>
        <div class="pa-portfolio-body">
            <strong>@UiDisplayLocalization.Localize(L, Model.PortfolioName)</strong>
            <small>@L.T(Model.ActivePropertyCount == 1 ? "{0} active property" : "{0} active properties", Model.ActivePropertyCount)</small>
        </div>
    </div>

    <div class="pa-portfolio-actions pa-portfolio-actions--single">
        <a asp-controller="PropertyAdministratorRegistration" asp-action="Properties" asp-route-mode="manual" class="pa-portfolio-action">
            <i class="fas fa-plus"></i> @L["Add property"]
        </a>
    </div>

    @if (Model.Properties.Count > 0 && Model.ViewingProperty != null)
    {
        <div class="pa-viewing-row">
            <div class="pa-property-thumb-stack">
                @foreach (var property in Model.Properties.Take(3))
                {
                    <a asp-controller="Administrador" asp-action="Index" asp-route-propertyId="@property.Id"
                       class="pa-property-thumb-btn @(Model.ViewingProperty.Id == property.Id ? "is-active" : null)"
                       title="@property.PropertyName">
                        <img src="@(property.ImageUrl ?? "/welcome-house.png")" alt="" />
                    </a>
                }
            </div>
            <a asp-controller="Administrador"
               asp-action="PropertyDetail"
               asp-route-id="@Model.ViewingProperty.Id"
               class="pa-viewing-property-main"
               aria-label="@L.T("Viewing: {0}", Model.ViewingProperty.PropertyName)">
                <strong>@L.T("Viewing: {0}", Model.ViewingProperty.PropertyName)</strong>
                @if (!string.IsNullOrWhiteSpace(Model.ViewingProperty.OccupancyLabel))
                {
                    <span class="pa-occupancy-badge">@UiDisplayLocalization.Localize(L, Model.ViewingProperty.OccupancyLabel)</span>
                }
                <small>@UiDisplayLocalization.Localize(L, Model.ViewingProperty.PropertyTypeLabel) • @Model.ViewingProperty.Location</small>
            </a>
            <a asp-controller="Administrador"
               asp-action="Properties"
               asp-route-from="switch"
               asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
               class="pa-viewing-switch"
               aria-label="@L["Switch property"]">
                <span class="pa-viewing-switch-label">@L["Switch property"]</span>
                <i class="fas fa-chevron-down pa-portfolio-chevron" aria-hidden="true"></i>
            </a>
        </div>
    }
</div>
