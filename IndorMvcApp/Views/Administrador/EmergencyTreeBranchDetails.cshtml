@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyTreeBranchStep1ViewModel
@{
    ViewData["Title"] = "Tree / Branch Emergency";
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var damageAreas = Model.DamageAreasList.ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro">
        <h1>Tree / Branch Emergency</h1>
        <p>Tell us what happened so we can dispatch help fast.</p>
    </section>

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="EmergencyTreeBranchDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>What happened?</label>
            <div class="pa-chip-grid">
                @foreach (var item in new (string Value, string Label, string Icon)[]
                {
                    ("TreeFellOnHouse", "Tree fell on house", "fa-house-chimney-crack"),
                    ("LargeHangingBranch", "Large hanging branch", "fa-code-branch"),
                    ("DrivewayBlocked", "Driveway blocked", "fa-road"),
                    ("FenceDamage", "Fence damage", "fa-border-all"),
                    ("RoofImpact", "Roof impact", "fa-house"),
                    ("NearPowerLine", "Near power line", "fa-bolt")
                })
                {
                    <label class="pa-chip @(Model.IssueType == item.Value ? "is-selected" : null)">
                        <input type="radio" name="IssueType" value="@item.Value" @(Model.IssueType == item.Value ? "checked" : null) />
                        <i class="fas @item.Icon"></i>
                        <span>@item.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>Is anyone in immediate danger?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.ImmediateDanger == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="ImmediateDanger" value="Yes" @(Model.ImmediateDanger == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.ImmediateDanger == "No" ? "is-selected" : null)">
                    <input type="radio" name="ImmediateDanger" value="No" @(Model.ImmediateDanger == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>Are guests currently inside?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) />
                    <i class="fas fa-users"></i> Yes
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) />
                    <i class="fas fa-user-slash"></i> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>How urgent is it?</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var u in new[] { ("Normal", "Normal"), ("Urgent", "Urgent"), ("Emergency", "Emergency") })
                {
                    <label class="pa-toggle-btn @(Model.Urgency == u.Item1 ? "is-selected" : null) @(u.Item1 == "Emergency" ? "is-urgent" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        @if (u.Item1 == "Emergency") { <i class="fas fa-circle-exclamation"></i> }
                        @u.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>Where is the damage?</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var loc in new (string Value, string Label, string Icon)[]
                {
                    ("FrontYard", "Front yard", "fa-tree"),
                    ("Backyard", "Backyard", "fa-seedling"),
                    ("Roof", "Roof", "fa-house-chimney"),
                    ("Driveway", "Driveway", "fa-road"),
                    ("Fence", "Fence", "fa-border-all"),
                    ("Other", "Other", "fa-ellipsis")
                })
                {
                    <label class="pa-chip @(damageAreas.Contains(loc.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="DamageAreasList" value="@loc.Value" @(damageAreas.Contains(loc.Value) ? "checked" : null) />
                        <i class="fas @loc.Icon"></i>
                        <span>@loc.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label>Do you need emergency tarp or temporary protection?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.TarpNeeded == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="TarpNeeded" value="Yes" @(Model.TarpNeeded == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.TarpNeeded == "No" ? "is-selected" : null)">
                    <input type="radio" name="TarpNeeded" value="No" @(Model.TarpNeeded == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label>Add quick details</label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" placeholder="Describe what happened...">@Model.QuickDetails</textarea>
        </div>

        <div class="pa-media-actions">
            <button type="button" class="pa-media-btn"><i class="fas fa-camera"></i> Add photos</button>
            <button type="button" class="pa-media-btn"><i class="fas fa-microphone"></i> Voice note</button>
        </div>

        <div class="pa-notify-banner">
            <i class="fas fa-bolt"></i>
            <span>If power lines are involved, keep guests away and we'll prioritize dispatch.</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">Continue</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-back-link">Back to services</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') {
                    this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
                    return;
                }
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
