@model IndorMvcApp.ViewModels.PropertyAdministratorLawnCareStep1ViewModel
@{
    ViewData["Title"] = L["Lawn Care / Grass Cutting"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Lawn Care / Grass Cutting"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what your property needs so we can schedule yard service."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Schedule"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)
@{
    ViewData["Title"] = L["Lawn Care / Grass Cutting"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Lawn Care / Grass Cutting"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what your property needs so we can schedule yard service."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Schedule"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @{
        if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
        {
            ViewBag.BadgeLabel = Model.PropertyStatusLabel;
        }
    }
    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

<form asp-action="LawnCareDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-seedling pa-q-icon pa-q-icon--green"></i> @L["What service do you need?"]</label>
            <div class="pa-lawn-service-row">
                @foreach (var s in new (string Value, string Label)[] { ("GrassCutting", L["Grass cutting"]), ("Edging", L["Edging"]), ("WeedTrimming", L["Weed trimming"]), ("FullYardRefresh", L["Full yard refresh"]) })
                {
                    <label class="pa-lawn-option-card @(Model.ServiceType == s.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceType" value="@s.Value" @(Model.ServiceType == s.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <span>@s.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["Which area?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var a in new[] { ("FrontYard", L["Front yard"]), ("Backyard", L["Backyard"]), ("Both", L["Both"]) })
                {
                    <label class="pa-chip @(Model.YardArea == a.Item1 ? "is-selected" : null)">
                        <input type="radio" name="YardArea" value="@a.Item1" @(Model.YardArea == a.Item1 ? "checked" : null) />
                        <span>@a.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["How large is the yard?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var s in new[] { "Small", "Medium", "Large" })
                {
                    <label class="pa-chip @(Model.YardSize == s ? "is-selected" : null)">
                        <input type="radio" name="YardSize" value="@s" @(Model.YardSize == s ? "checked" : null) />
                        <span>@L[s]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["How often?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var f in new[] { ("OneTime", L["One-time"]), ("Weekly", L["Weekly"]), ("BiWeekly", L["Bi-weekly"]) })
                {
                    <label class="pa-chip @(Model.Frequency == f.Item1 ? "is-selected" : null)">
                        <input type="radio" name="Frequency" value="@f.Item1" @(Model.Frequency == f.Item1 ? "checked" : null) />
                        <span>@f.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Is the property occupied right now?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.IsOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="Yes" @(Model.IsOccupied == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.IsOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="No" @(Model.IsOccupied == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-key pa-q-icon pa-q-icon--green"></i> @L["Do we need gate or yard access details?"]</label>
            <div class="pa-field">
                <i class="fas fa-door-open"></i>
                <input type="text" name="AccessDetails" value="@Model.AccessDetails" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--green"></i> @L["Add quick notes"]</label>
            <textarea class="pa-textarea" name="QuickNotes" rows="3" maxlength="250" id="lcNotes">@Model.QuickNotes</textarea>
            <small class="pa-char-count"><span id="lcNotesCount">@Model.QuickNotes.Length</span> / 250</small>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-lawn-availability-banner">
            <div>
                <strong>@UiDisplayLocalization.Localize(L, Model.AvailabilityLabel)</strong>
                <small>@L.T("Our team can arrive between {0}. You'll get updates and photos when the job is done.", Model.AvailabilityWindow)</small>
            </div>
            <i class="fas fa-circle-check"></i>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-lawn-option-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                document.querySelectorAll('.pa-lawn-option-card').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-lawn-option-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('lcNotes');
        var counter = document.getElementById('lcNotesCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}