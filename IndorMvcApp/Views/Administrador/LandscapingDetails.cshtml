@model IndorMvcApp.ViewModels.PropertyAdministratorLandscapingStep1ViewModel
@{
    ViewData["Title"] = "Landscaping";
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro">
        <h1><i class="fas fa-leaf pa-flow-title-icon pa-flow-title-icon--green"></i> Landscaping</h1>
        <p>Tell us what your yard needs so we can match the right landscaping pro.</p>
    </section>

    @if (Model.ViewingProperty != null && Model.ViewingProperty.Id > 0)
    {
        <div class="pa-viewing-strip">
            <img src="@(Model.ViewingProperty.ImageUrl ?? "/inspeccion2.jpeg")" alt="" class="pa-viewing-strip-thumb" />
            <div class="pa-viewing-strip-main">
                <strong>Viewing: @Model.ViewingProperty.PropertyName</strong>
                @if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
                {
                    <span class="pa-checkout-badge"><i class="fas fa-calendar-day"></i> @Model.PropertyStatusLabel</span>
                }
                <small>@Model.ViewingProperty.PropertyTypeLabel • @Model.ViewingProperty.Location</small>
            </div>
            <a asp-controller="Administrador" asp-action="Properties" class="pa-viewing-switch">Switch property <i class="fas fa-chevron-right"></i></a>
        </div>
    }

    <form asp-action="LandscapingDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-leaf pa-q-icon pa-q-icon--green"></i> What kind of landscaping help do you need?</label>
            <div class="pa-lawn-service-row">
                @foreach (var s in new (string Value, string Label, string Icon)[] {
                    ("GardenRefresh", "Garden refresh", "fa-seedling"),
                    ("ReplaceDamagedPlants", "Replace damaged plants", "fa-spa"),
                    ("TreeShrubInstall", "Tree / shrub install", "fa-tree"),
                    ("PatioHardscape", "Patio / hardscape", "fa-border-all") })
                {
                    <label class="pa-lawn-option-card @(Model.ServiceType == s.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceType" value="@s.Value" @(Model.ServiceType == s.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <i class="fas @s.Icon"></i>
                        <span>@s.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>Which area needs work?</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var a in new[] { ("FrontYard", "Front yard"), ("Backyard", "Backyard"), ("Both", "Both") })
                {
                    <label class="pa-chip @(Model.WorkArea == a.Item1 ? "is-selected" : null)">
                        <input type="radio" name="WorkArea" value="@a.Item1" @(Model.WorkArea == a.Item1 ? "checked" : null) />
                        <span>@a.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>What happened?</label>
            <div class="pa-lawn-service-row">
                @foreach (var r in new (string Value, string Label)[] {
                    ("RoutineUpgrade", "Routine upgrade"),
                    ("StormDamage", "Storm damage"),
                    ("CarDroveOverPlants", "Car drove over plants"),
                    ("PreparingForGuests", "Preparing for guests") })
                {
                    <label class="pa-lawn-option-card @(Model.ServiceReason == r.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceReason" value="@r.Value" @(Model.ServiceReason == r.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <span>@r.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label><i class="fas fa-clock pa-q-icon pa-q-icon--green"></i> When do you need this done?</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var t in new[] { ("Asap", "As soon as possible"), ("ThisWeek", "This week"), ("ScheduleLater", "Schedule later") })
                {
                    <label class="pa-chip @(Model.Timeline == t.Item1 ? "is-selected" : null)">
                        <input type="radio" name="Timeline" value="@t.Item1" @(Model.Timeline == t.Item1 ? "checked" : null) />
                        <span>@t.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>Is the property occupied right now?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.IsOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="Yes" @(Model.IsOccupied == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.IsOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="No" @(Model.IsOccupied == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--green"></i> Add quick notes</label>
            <textarea class="pa-textarea" name="QuickNotes" rows="3" maxlength="250" id="lsNotes">@Model.QuickNotes</textarea>
            <small class="pa-char-count"><span id="lsNotesCount">@Model.QuickNotes.Length</span> / 250</small>
        </div>

        <div class="pa-media-actions">
            <button type="button" class="pa-media-btn"><i class="fas fa-camera"></i> Add photos</button>
            <button type="button" class="pa-media-btn"><i class="fas fa-microphone"></i> Voice note</button>
        </div>

        <div class="pa-lawn-availability-banner">
            <div>
                <strong>Landscape consult available this week</strong>
                <small>We can schedule a landscaping pro to review the yard and prepare the right scope of work.</small>
            </div>
            <i class="fas fa-leaf"></i>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">Continue</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">Back</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-lawn-option-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                var row = this.closest('.pa-lawn-service-row');
                if (row) {
                    row.querySelectorAll('.pa-lawn-option-card').forEach(function (el) { el.classList.remove('is-selected'); });
                }
                this.closest('.pa-lawn-option-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('lsNotes');
        var counter = document.getElementById('lsNotesCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
