@model IndorMvcApp.ViewModels.PropertyAdministratorSmokeDetectorFormViewModel
@{
    ViewData["Title"] = L["Smoke Detector Check"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Smoke Detector Check"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what needs to be checked so we can schedule the visit."].ToString();
    ViewBag.FlowSteps = new[] { L["Service"].ToString(), L["Details"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var recipients = string.IsNullOrWhiteSpace(Model.UpdateRecipients)
        ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        : Model.UpdateRecipients
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="SmokeDetectorDetails" method="post" class="pa-emergency-form" autocomplete="off">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-clipboard-list pa-q-icon pa-q-icon--green"></i> @L["What do you need?"]</label>
            <div class="pa-sd-service-grid">
                @foreach (var s in new (string Value, string Label, string Icon)[]
                {
                    ("FullDetectorCheck", L["Full detector check"], "fa-bell"),
                    ("ReplaceBatteries", L["Replace batteries"], "fa-battery-full"),
                    ("ChirpingDetector", L["Chirping detector"], "fa-volume-high"),
                    ("InstallNewDetector", L["Install new detector"], "fa-plus")
                })
                {
                    <label class="pa-sd-service-card @(Model.ServiceType == s.Value ? "is-selected" : null)">
                        <input type="radio" name="ServiceType" value="@s.Value" @(Model.ServiceType == s.Value ? "checked" : null) />
                        <span class="pa-prev-service-check"><i class="fas fa-check"></i></span>
                        <span class="pa-sd-service-icon"><i class="fas @s.Icon"></i></span>
                        <span>@s.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-bell pa-q-icon pa-q-icon--green"></i> @L["How many detectors should we check?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var c in new (string Value, string Label)[] { ("OneToTwo", L["1–2"]), ("ThreeToFive", L["3–5"]), ("SixPlus", L["6+"]) })
                {
                    <label class="pa-toggle-btn @(Model.DetectorCount == c.Value ? "is-selected" : null)">
                        <input type="radio" name="DetectorCount" value="@c.Value" @(Model.DetectorCount == c.Value ? "checked" : null) />
                        @c.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-triangle-exclamation pa-q-icon pa-q-icon--green"></i> @L["Any urgent safety issue right now?"]</label>
            <div class="pa-toggle-pair">
                @foreach (var v in new[] { "No", "Yes" })
                {
                    <label class="pa-toggle-btn @(Model.UrgentSafetyIssue == v ? "is-selected" : null)">
                        <input type="radio" name="UrgentSafetyIssue" value="@v" @(Model.UrgentSafetyIssue == v ? "checked" : null) /> @L[v]
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label><i class="fas fa-plug pa-q-icon pa-q-icon--green"></i> @L["Do you know the detector type?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var t in new (string Value, string Label)[] { ("Battery", L["Battery"]), ("Hardwired", L["Hardwired"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-toggle-btn @(Model.DetectorType == t.Value ? "is-selected" : null)">
                        <input type="radio" name="DetectorType" value="@t.Value" @(Model.DetectorType == t.Value ? "checked" : null) />
                        @t.Label
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-lock pa-q-icon pa-q-icon--green"></i> @L["Can the technician enter now?"]</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @foreach (var e in new (string Value, string Label)[] { ("SmartLock", L["Yes, with smart lock"]), ("HostMeet", L["Host will meet"]), ("NeedApproval", L["Need guest approval"]) })
                {
                    <label class="pa-chip pa-chip--wide @(Model.EntryAccess == e.Value ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Value" @(Model.EntryAccess == e.Value ? "checked" : null) />
                        <span>@e.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-users pa-q-icon pa-q-icon--green"></i> @L["Who should receive updates?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var r in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("CoHost", L["Co-host"]) })
                {
                    var isChecked = recipients.Contains(r.Item1);
                    <label class="pa-chip @(isChecked ? "is-selected" : null)">
                        <input type="checkbox" name="UpdateRecipientsList" value="@r.Item1" autocomplete="off" @(isChecked ? "checked" : null) />
                        <span>@r.Item2</span>
                    </label>
                }
            </div>
        </div>

        @{
            ViewData["PaContactQnum"] = "7";
            ViewData["PaContactValue"] = Model.ContactPhone;
            ViewData["PaContactLabelIcon"] = "fa-phone pa-q-icon pa-q-icon--green";
        }
        @await Html.PartialAsync("_PropertyAdminUrgentContactPhone")

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">8</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--green"></i> @L["Add details"]</label>
            <textarea class="pa-textarea" name="Details" rows="3" maxlength="250" id="sdDetails">@Model.Details</textarea>
            <small class="pa-char-count"><span id="sdDetailsCount">@Model.Details.Length</span> @L["/ 250 characters"]</small>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-flow-pro-card pa-flow-pro-card--safety">
            <div class="pa-flow-pro-head">
                <span class="pa-flow-pro-icon pa-flow-pro-icon--green"><i class="fas fa-bell"></i></span>
                <div>
                    <strong>@UiDisplayLocalization.Localize(L, Model.ProEtaLabel)</strong>
                    <div class="pa-flow-pro-mini">
                        <img src="/inspeccion2.jpeg" alt="" class="pa-flow-pro-avatar" />
                        <div class="pa-trust-badges">
                            <span>@L["Licensed"]</span>
                            <span>@L["Insured"]</span>
                            <span>@L["Fast response"]</span>
                        </div>
                    </div>
                </div>
            </div>
            <p>@L["Estimated visit:"] <strong>@Model.EstimatedPrice</strong> <i class="fas fa-circle-info pa-price-info"></i></p>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Schedule detector check"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-sd-service-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                document.querySelectorAll('.pa-sd-service-card').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-sd-service-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') return;
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
            });
        });
        var details = document.getElementById('sdDetails');
        var counter = document.getElementById('sdDetailsCount');
        if (details && counter) {
            details.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
