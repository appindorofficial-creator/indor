@model IndorMvcApp.ViewModels.PropertyAdministratorPropertiesPortalViewModel
@{
    ViewData["Title"] = L["Portfolio & properties"];
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "properties";
    var hasPortfolio = Model.TotalPropertyCount > 0;
    var hasVisibleProperties = Model.Properties.Count > 0;
    var isSwitch = string.Equals(Model.EntryContext, "switch", StringComparison.OrdinalIgnoreCase);
    var isManage = string.Equals(Model.EntryContext, "manage", StringComparison.OrdinalIgnoreCase);
    var pageTitle = isSwitch
        ? L["Switch property"].ToString()
        : isManage
            ? L["Manage properties"].ToString()
            : L["Portfolio & properties"].ToString();
    var pageSubtitle = isSwitch
        ? L["Choose which home you want to view and manage."].ToString()
        : L["Add, organize, and manage all your Airbnb and short-term rental homes in one place."].ToString();
}

<div class="pa-portal-shell pa-portal-shell--portfolio">
    @if (Model.ShowBackHeader)
    {
        <header class="pa-portfolio-page-header">
            <a href="@Model.BackUrl" class="pa-profile-back" aria-label="@L["Back"]">
                <i class="fas fa-chevron-left"></i>
            </a>
            <div class="pa-portfolio-page-header-text">
                <h1>@pageTitle</h1>
                <p>@pageSubtitle</p>
            </div>
        </header>
    }
    else
    {
        @await Html.PartialAsync("_PropertyAdminTopbar", Model)
        <header class="pa-portfolio-page-header pa-portfolio-page-header--nav">
            <div class="pa-portfolio-page-header-text">
                <h1>@pageTitle</h1>
                <p>@pageSubtitle</p>
            </div>
        </header>
    }

    <section class="pa-portfolio-stats pa-portfolio-stats--3">
        <a href="@Model.TotalPropertiesUrl" class="pa-portfolio-stat @(Model.ActiveFilter == "all" ? "is-active" : null)">
            <span class="pa-portfolio-stat-icon"><i class="fas fa-building"></i></span>
            <div>
                <small>@L["Total properties"]</small>
                <strong>@Model.TotalPropertyCount</strong>
                <span class="pa-portfolio-stat-hint">@L["All your homes"]</span>
            </div>
        </a>
        <a href="@Model.ActivePropertiesUrl" class="pa-portfolio-stat @(Model.ActiveFilter == "active" ? "is-active" : null)">
            <span class="pa-portfolio-stat-icon"><i class="fas fa-house"></i></span>
            <div>
                <small>@L["Active properties"]</small>
                <strong>@Model.ActivePropertiesCount</strong>
                <span class="pa-portfolio-stat-hint">@L["Ready to rent"]</span>
            </div>
        </a>
        <a href="@Model.PendingTasksUrl" class="pa-portfolio-stat">
            <span class="pa-portfolio-stat-icon pa-portfolio-stat-icon--purple"><i class="fas fa-clipboard-check"></i></span>
            <div>
                <small>@L["Service tasks pending"]</small>
                <strong>@Model.ServiceTasksPendingCount</strong>
                <span class="pa-portfolio-stat-hint">@L["Stay on top"]</span>
            </div>
        </a>
    </section>

    <div class="pa-portfolio-cta-row">
        <a href="@Model.AddPropertyUrl" class="pa-btn-primary pa-portfolio-cta-primary">
            <i class="fas fa-plus"></i> @(hasPortfolio ? L["Add property"] : L["Add your first property"])
        </a>
        <a href="@Model.ImportPortfolioUrl" class="pa-btn-outline pa-portfolio-cta-import">
            <i class="fas fa-cloud-arrow-up"></i> @L["Import portfolio"]
        </a>
    </div>

    <section id="pa-properties-list" class="pa-portfolio-section">
        <h2>@L["Your properties"]</h2>
        @if (!hasPortfolio)
        {
            <div class="pa-portfolio-empty">
                <span class="pa-portfolio-empty-art" aria-hidden="true"><i class="fas fa-house-chimney"></i></span>
                <div class="pa-portfolio-empty-body">
                    <strong>@L["No properties added yet"]</strong>
                    <p>@L["Start by adding your first home to track services, maintenance, guests, and operations."]</p>
                    <a href="@Model.AddPropertyUrl" class="pa-btn-outline pa-btn-outline--sm">
                        <i class="fas fa-plus"></i> @L["Add property"]
                    </a>
                </div>
            </div>
        }
        else if (!hasVisibleProperties)
        {
            <div class="pa-empty-card">@L["No properties match this filter."]</div>
        }
        else
        {
            @foreach (var property in Model.Properties)
            {
                <a href="@property.DetailUrl" class="pa-portfolio-property-card">
                    <img src="@(property.ImageUrl ?? "/welcome-house.png")" alt="" class="pa-portfolio-property-thumb" />
                    <div class="pa-portfolio-property-body">
                        <strong>@property.PropertyName</strong>
                        <small>@property.Location</small>
                        <span class="pa-portfolio-status @(property.StatusLabel == L["Active"] || property.StatusLabel == "Active" ? "is-active" : null)">
                            <span class="pa-portfolio-status-dot" aria-hidden="true"></span>
                            @UiDisplayLocalization.Localize(L, property.StatusLabel)
                        </span>
                    </div>
                    <i class="fas fa-@(isSwitch ? "check" : "chevron-right") pa-portfolio-property-chevron"></i>
                </a>
            }
        }
    </section>

    @if (!hasPortfolio)
    {
        <section class="pa-portfolio-section">
            <h2>@L["What you can do here"]</h2>
            <div class="pa-portfolio-features">
                <div class="pa-portfolio-feature">
                    <span class="pa-portfolio-feature-icon"><i class="fas fa-chart-pie"></i></span>
                    <strong>@L["Track every home"]</strong>
                    <p>@L["Monitor performance, bookings, and status from one dashboard."]</p>
                </div>
                <div class="pa-portfolio-feature">
                    <span class="pa-portfolio-feature-icon"><i class="fas fa-screwdriver-wrench"></i></span>
                    <strong>@L["Manage services faster"]</strong>
                    <p>@L["Request cleaning, repairs, and maintenance with just a few taps."]</p>
                </div>
                <div class="pa-portfolio-feature">
                    <span class="pa-portfolio-feature-icon"><i class="fas fa-calendar-check"></i></span>
                    <strong>@L["Stay organized"]</strong>
                    <p>@L["Keep house details, schedules, and tasks all in one place."]</p>
                </div>
            </div>
        </section>

        <section class="pa-portfolio-banner">
            <span class="pa-portfolio-banner-icon"><i class="fas fa-star"></i></span>
            <div class="pa-portfolio-banner-body">
                <strong>@L["Built for portfolio owners"]</strong>
                <p>@L["Centralize operations across all your homes and save time managing what matters most."]</p>
            </div>
            <span class="pa-portfolio-banner-art" aria-hidden="true"><i class="fas fa-house-chimney-window"></i></span>
        </section>
    }
    else
    {
        <a href="@Model.KeepPortfolioUpdatedUrl"
           class="pa-portfolio-tip-card"
           aria-label="@L["Add property"]">
            <span class="pa-portfolio-tip-icon" aria-hidden="true"><i class="fas fa-house-circle-check"></i></span>
            <div class="pa-portfolio-tip-body">
                <strong>@L["Keep your portfolio up to date"]</strong>
                <p>@L["Add all your properties and keep details updated to get the most out of Home Indor."]</p>
            </div>
            <i class="fas fa-chevron-right pa-portfolio-tip-chevron" aria-hidden="true"></i>
        </a>
    }
</div>
