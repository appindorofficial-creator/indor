@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyRoofLeakStep2ViewModel
@{
    ViewData["Title"] = L["Emergency Roof Leak"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Emergency Roof Leak"].ToString();
    ViewBag.FlowSubtitle = L["Access, protection, and claim details."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("EmergencyRoofLeakDetails", "Administrador", new { propertyId = Model.PropertyId });
    ViewBag.BadgeLabel = Model.GuestsOnSiteLabel;
    var recipients = Model.UpdateRecipientsList.ToHashSet(StringComparer.OrdinalIgnoreCase);
    var damageItems = Model.InteriorDamage.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="EmergencyRoofLeakAccess" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
        <input type="hidden" name="RoofIssue" value="@Model.RoofIssue" />
        <input type="hidden" name="WaterEnteringNow" value="@Model.WaterEnteringNow" />
        <input type="hidden" name="GuestsInside" value="@Model.GuestsInside" />
        <input type="hidden" name="Urgency" value="@Model.Urgency" />
        <input type="hidden" name="LeakLocation" value="@Model.LeakLocation" />
        <input type="hidden" name="QuickDetails" value="@Model.QuickDetails" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["Technician inspection"]</label>
            <div class="pa-chip-grid pa-chip-grid--stack">
                @foreach (var e in new[] { ("SmartLock", L["Yes, with smart lock"]), ("HostMeet", L["Host will meet"]), ("GuestApproval", L["Need guest approval"]) })
                {
                    <label class="pa-chip pa-chip--wide @(Model.EntryAccess == e.Item1 ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Item1" @(Model.EntryAccess == e.Item1 ? "checked" : null) />
                        <span>@e.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["Smart lock / entry code"]</label>
            <div class="pa-field">
                <i class="fas fa-key"></i>
                <input type="text" name="EntryCode" value="@Model.EntryCode" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Area protection"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var p in new[] { ("BucketPlaced", L["Bucket placed"]), ("TarpNeeded", L["Tarp needed"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-chip @(Model.AreaProtection == p.Item1 ? "is-selected" : null)">
                        <input type="radio" name="AreaProtection" value="@p.Item1" @(Model.AreaProtection == p.Item1 ? "checked" : null) />
                        <span>@p.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Interior damage"]</label>
            <div class="pa-chip-grid pa-chip-grid--4">
                @foreach (var d in new[] { ("Ceiling", L["Ceiling"]), ("Wall", L["Wall"]), ("Floor", L["Floor"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-chip @(damageItems.Contains(d.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="InteriorDamageList" value="@d.Item1" @(damageItems.Contains(d.Item1) ? "checked" : null) />
                        <span>@d.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Insurance info"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var i in new[] { ("Yes", L["Yes"]), ("No", L["No"]), ("UploadLater", L["I'll upload later"]) })
                {
                    <label class="pa-chip @(Model.InsuranceInfo == i.Item1 ? "is-selected" : null)">
                        <input type="radio" name="InsuranceInfo" value="@i.Item1" @(Model.InsuranceInfo == i.Item1 ? "checked" : null) />
                        <span>@i.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label>@L["Photos or documents"]</label>
            @{
                ViewData["PaMediaShowVoice"] = false;
                ViewData["PaMediaPhotoLabel"] = L["Add photo or document"].ToString();
            }
            @await Html.PartialAsync("_PropertyAdminMediaCapture")
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label>@L["Access notes"]</label>
            <div class="pa-field">
                <i class="fas fa-note-sticky"></i>
                <input type="text" name="AccessNotes" value="@Model.AccessNotes" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">8</span>
            <label>@L["Who should receive updates?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var r in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("CoHost", L["Co-host"]) })
                {
                    <label class="pa-chip @(recipients.Contains(r.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="UpdateRecipientsList" value="@r.Item1" @(recipients.Contains(r.Item1) ? "checked" : null) />
                        <span>@r.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">9</span>
            <label>@L["Contact number"]</label>
            <div class="pa-field">
                <i class="fas fa-phone"></i>
                <input type="tel" name="ContactPhone" value="@Model.ContactPhone" />
            </div>
        </div>

        <div class="pa-notify-banner pa-notify-banner--success">
            <i class="fas fa-clock"></i>
            <span>@UiDisplayLocalization.Localize(L, Model.ProEtaLabel)</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Review request"]</button>
        <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
        <a href="@Url.Action("Services", "Administrador", new { propertyId = Model.PropertyId })" class="pa-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') {
                    this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
                    return;
                }
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
