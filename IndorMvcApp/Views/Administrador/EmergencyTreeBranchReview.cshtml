@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyTreeBranchReviewViewModel
@{
    ViewData["Title"] = L["Review tree emergency request"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Review tree emergency request"].ToString();
    ViewBag.FlowSubtitle = L["Make sure everything looks right before we dispatch help."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Review"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("EmergencyTreeBranchDetails", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    ViewBag.BadgeLabel = Model.GuestsOnSiteLabel;
    var input = Model.Input;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <article class="pa-tree-review-section">
        <h2><i class="fas fa-list-check"></i> @L["Request summary"]</h2>
        <div class="pa-moving-review-card">
            @foreach (var row in Model.RequestSummaryRows)
            {
                <div class="pa-moving-review-row">
                    <span class="pa-moving-review-label"><i class="fas @row.IconClass"></i> @row.Label</span>
                    @if (row.IsDangerBadge)
                    {
                        <strong class="pa-danger-pill">@row.Value</strong>
                    }
                    else
                    {
                        <strong class="pa-moving-review-value">@row.Value</strong>
                    }
                </div>
            }
        </div>
    </article>

    <article class="pa-tree-review-section">
        <h2><i class="fas fa-user-check"></i> @L["Access &amp; contact"]</h2>
        <div class="pa-moving-review-card">
            @foreach (var row in Model.AccessContactRows)
            {
                <div class="pa-moving-review-row">
                    <span class="pa-moving-review-label"><i class="fas @row.IconClass"></i> @row.Label</span>
                    <strong class="pa-moving-review-value">@row.Value</strong>
                </div>
            }
        </div>
    </article>

    <article class="pa-tree-pro-card">
        <div class="pa-tree-pro-head">
            <span class="pa-tree-pro-icon"><i class="fas fa-tree"></i></span>
            <div>
                <strong>@UiDisplayLocalization.Localize(L, Model.ProEtaLabel)</strong>
                <div class="pa-trust-badges">
                    <span>@L["Licensed"]</span><span>@L["Insured"]</span><span>@L["Storm response"]</span>
                </div>
            </div>
        </div>
        <p>@L["Estimated service visit:"] <strong>@Model.EstimatedPrice</strong></p>
        <p>@L["Emergency dispatch:"] <span class="pa-included">@L["Included"]</span></p>
        <button type="button" class="pa-tree-pro-link">@L["View pro details"] <i class="fas fa-chevron-right"></i></button>
    </article>

    <form asp-action="EmergencyTreeBranchReview" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@input.PropertyId" />
        <input type="hidden" name="IssueType" value="@input.IssueType" />
        <input type="hidden" name="ImmediateDanger" value="@input.ImmediateDanger" />
        <input type="hidden" name="GuestsInside" value="@input.GuestsInside" />
        <input type="hidden" name="Urgency" value="@input.Urgency" />
        <input type="hidden" name="TarpNeeded" value="@input.TarpNeeded" />
        <input type="hidden" name="QuickDetails" value="@input.QuickDetails" />
        <input type="hidden" name="EntryAccess" value="@input.EntryAccess" />
        <input type="hidden" name="GateParkingNotes" value="@input.GateParkingNotes" />
        <input type="hidden" name="ContactPhone" value="@input.ContactPhone" />
        <input type="hidden" name="InsuranceHelp" value="@input.InsuranceHelp" />
        @foreach (var area in input.DamageAreasList)
        {
            <input type="hidden" name="DamageAreasList" value="@area" />
        }
        @foreach (var recipient in input.UpdateRecipientsList)
        {
            <input type="hidden" name="UpdateRecipientsList" value="@recipient" />
        }

        <div class="pa-notify-banner pa-notify-banner--warn">
            <i class="fas fa-circle-info"></i>
            <span>@L["We'll send status updates to you and the guest."]</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Request emergency service"]</button>
    </form>
    <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
</div>
