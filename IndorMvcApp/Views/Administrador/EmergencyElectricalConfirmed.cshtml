@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyElectricalConfirmedViewModel
@{
    ViewData["Title"] = L["Emergency Electrical request sent"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowShowBack = false;
    var propertyLabel = Model.ViewingProperty != null
        ? $"{Model.ViewingProperty.PropertyTypeLabel} • {Model.ViewingProperty.Location}"
        : "";
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    @{
        var hasTechnician = !string.IsNullOrWhiteSpace(Model.TechnicianName);
    }

    <section class="pa-flow-intro">
        <h1>@L["Emergency Electrical request sent"]</h1>
        @if (hasTechnician)
        {
            <p>@L.T("An electrician is on the way to {0}.", Model.ViewingProperty?.PropertyName ?? L["your property"])</p>
        }
        else
        {
            <p>@L.T("We're connecting you with a verified electrician near {0}.", Model.ViewingProperty?.PropertyName ?? L["your property"])</p>
        }
    </section>

    <div class="pa-success-banner">
        <span class="pa-success-icon"><i class="fas fa-check"></i></span>
        <div>
            <strong>@L["Request received"]</strong>
            <span>@(hasTechnician ? L["We've dispatched a technician to help."] : L["We're matching your request with a verified, licensed electrician."])</span>
        </div>
    </div>

    @if (hasTechnician)
    {
        <article class="pa-tech-card">
            <div class="pa-tech-head">
                <img src="/inspeccion2.jpeg" alt="" class="pa-tech-avatar" />
                <div class="pa-tech-meta">
                    <strong>@Model.TechnicianName</strong>
                    <span><i class="fas fa-star"></i> @Model.TechnicianRating.ToString("0.0")</span>
                    <small>@UiDisplayLocalization.Localize(L, Model.TechnicianTitle)</small>
                </div>
                <span class="pa-verified-badge"><i class="fas fa-check"></i> @L["Verified"]</span>
            </div>
            <div class="pa-tech-stats">
                @if (!string.IsNullOrWhiteSpace(Model.EtaLabel))
                {
                    <div>
                        <i class="fas fa-clock"></i>
                        <strong>@UiDisplayLocalization.Localize(L, Model.EtaLabel)</strong>
                        <small>@L["ETA"]</small>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.VehicleLabel))
                {
                    <div>
                        <i class="fas fa-car"></i>
                        <strong>@UiDisplayLocalization.Localize(L, Model.VehicleLabel)</strong>
                        <small>@L["Vehicle"]</small>
                    </div>
                }
                <div>
                    <i class="fas fa-house"></i>
                    <strong>@L.T("Viewing: {0}", Model.ViewingProperty?.PropertyName)</strong>
                    <small>@propertyLabel</small>
                </div>
            </div>
        </article>
    }
    else
    {
        <article class="pa-tech-card pa-tech-card--matching">
            <div class="pa-tech-head">
                <span class="pa-tech-avatar-fallback"><i class="fas fa-bolt"></i></span>
                <div class="pa-tech-meta">
                    <strong>@L["Matching a verified electrician"]</strong>
                    <small>@L["We'll notify you as soon as a licensed pro accepts your request."]</small>
                </div>
            </div>
            <div class="pa-tech-stats">
                <div>
                    <i class="fas fa-house"></i>
                    <strong>@(Model.ViewingProperty?.PropertyName)</strong>
                    <small>@propertyLabel</small>
                </div>
            </div>
        </article>
    }

    <article class="pa-summary-card-block">
        <h2>@L["Request summary"]</h2>
        <ul class="pa-summary-detail-list">
            @foreach (var item in Model.Summary)
            {
                <li>
                    <i class="fas @item.IconClass"></i>
                    <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
                    <strong class="@(item.Highlight ? "is-alert" : null)">@item.Value</strong>
                </li>
            }
        </ul>
    </article>

    <article class="pa-timeline-card">
        <h2>@L["Request timeline"]</h2>
        <ul class="pa-timeline">
            @foreach (var step in Model.Timeline)
            {
                <li class="pa-timeline-item pa-timeline-item--@step.State">
                    <span class="pa-timeline-dot"><i class="fas @step.IconClass"></i></span>
                    <div class="pa-timeline-body">
                        <strong>@UiDisplayLocalization.Localize(L, step.Label)</strong>
                        <span>@UiDisplayLocalization.Localize(L, step.StatusLabel)</span>
                    </div>
                </li>
            }
        </ul>
    </article>

    <div class="pa-action-grid">
        <button type="button" class="pa-action-tile"><i class="fas fa-phone"></i><span>@L["Call technician"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-comment"></i><span>@L["Message guest"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-share"></i><span>@L["Share ETA"]</span></button>
        <a asp-controller="Administrador" asp-action="Tasks" asp-route-filter="inprogress" class="pa-action-tile">
            <i class="fas fa-file-lines"></i><span>@L["View details"]</span>
        </a>
    </div>

    <div class="pa-tip-banner">
        <span class="pa-tip-icon"><i class="fas fa-circle-info"></i></span>
        <p><strong>@L["Tip:"]</strong> @UiDisplayLocalization.Localize(L, Model.Tip)</p>
    </div>
    @{ ViewBag.ConfirmedPropertyId = Model.ViewingProperty?.Id; }
    @await Html.PartialAsync("_PropertyAdminConfirmedFooter")

</div>
