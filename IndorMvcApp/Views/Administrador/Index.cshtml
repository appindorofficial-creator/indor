@model IndorMvcApp.ViewModels.PropertyAdministratorHomeViewModel

@{

    ViewData["Title"] = "Home";

    Layout = "_PropertyAdminLayout";

    ViewBag.NavActive = "home";

}



<div class="pa-portal-shell">

    @await Html.PartialAsync("_PropertyAdminTopbar", Model)



    <section class="pa-hero-block pa-hero-block--flow">
        <div class="pa-hero-block-head">
            <div>
                <h1>@Model.Greeting</h1>
                <p>Manage service, homecare, and operations across your portfolio.</p>
            </div>
            <span class="pa-flow-step-pill">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
        </div>
    </section>

    @await Html.PartialAsync("_PropertyAdminHomePortfolio", Model)

    @if (Model.FeaturedPetDeepClean != null)
    {
        <a href="@Model.FeaturedPetDeepClean.StartUrl" class="pa-featured-turnover pa-featured-pet">
            <div class="pa-featured-turnover-top">
                <span class="pa-flow-step-pill pa-flow-step-pill--sm pa-flow-step-pill--purple">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
            </div>
            <div class="pa-featured-turnover-body">
                <div>
                    <strong class="pa-featured-turnover-title">@Model.FeaturedPetDeepClean.Title</strong>
                    <p class="pa-featured-turnover-sub">@Model.FeaturedPetDeepClean.Subtitle</p>
                </div>
                <span class="pa-featured-turnover-icon"><i class="fas fa-paw"></i></span>
            </div>
            <span class="pa-featured-turnover-btn">Start now</span>
        </a>
    }

    @if (Model.FeaturedStandardCleaning != null)
    {
        <a href="@Model.FeaturedStandardCleaning.StartUrl" class="pa-featured-turnover pa-featured-standard">
            <div class="pa-featured-turnover-top">
                <span class="pa-flow-step-pill pa-flow-step-pill--sm pa-flow-step-pill--purple">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
            </div>
            <div class="pa-featured-turnover-body">
                <div>
                    <strong class="pa-featured-turnover-title">@Model.FeaturedStandardCleaning.Title</strong>
                    <p class="pa-featured-turnover-sub">@Model.FeaturedStandardCleaning.Subtitle</p>
                </div>
                <span class="pa-featured-turnover-icon"><i class="fas fa-spray-can-sparkles"></i></span>
            </div>
            <span class="pa-featured-turnover-btn">Start now</span>
        </a>
    }

    @if (Model.FeaturedTurnoverCleaning != null)
    {
        <a href="@Model.FeaturedTurnoverCleaning.StartUrl" class="pa-featured-turnover">
            <div class="pa-featured-turnover-top">
                <span class="pa-flow-step-pill pa-flow-step-pill--sm pa-flow-step-pill--purple">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
            </div>
            <div class="pa-featured-turnover-body">
                <div>
                    <strong class="pa-featured-turnover-title">@Model.FeaturedTurnoverCleaning.Title</strong>
                    <p class="pa-featured-turnover-sub">@Model.FeaturedTurnoverCleaning.Subtitle</p>
                </div>
                <span class="pa-featured-turnover-icon"><i class="fas fa-broom"></i></span>
            </div>
            <span class="pa-featured-turnover-btn">Start now</span>
        </a>
    }

    @if (Model.FeaturedSmokeDetector != null)
    {
        <a href="@Model.FeaturedSmokeDetector.StartUrl" class="pa-featured-smokedetector">
            <div class="pa-featured-smokedetector-top">
                <span class="pa-flow-step-pill pa-flow-step-pill--sm pa-flow-step-pill--green">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
            </div>
            <div class="pa-featured-smokedetector-body">
                <div>
                    <strong class="pa-featured-smokedetector-title">@Model.FeaturedSmokeDetector.Title</strong>
                    <p class="pa-featured-smokedetector-sub">@Model.FeaturedSmokeDetector.Subtitle</p>
                </div>
                <span class="pa-featured-smokedetector-icon"><i class="fas fa-bell"></i></span>
            </div>
            <span class="pa-featured-smokedetector-btn">Start now</span>
        </a>
    }

    @if (Model.FeaturedAirFilter != null)
    {
        <a href="@Model.FeaturedAirFilter.StartUrl" class="pa-featured-airfilter">
            <div class="pa-featured-airfilter-top">
                <span class="pa-flow-step-pill pa-flow-step-pill--sm">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
            </div>
            <div class="pa-featured-airfilter-body">
                <div class="pa-featured-airfilter-copy">
                    <strong class="pa-featured-airfilter-title">@Model.FeaturedAirFilter.Title</strong>
                    <p class="pa-featured-airfilter-sub">@Model.FeaturedAirFilter.Subtitle</p>
                    <ul class="pa-featured-airfilter-benefits">
                        @foreach (var benefit in Model.FeaturedAirFilter.Benefits)
                        {
                            <li><i class="fas @benefit.IconClass"></i> @benefit.Label</li>
                        }
                    </ul>
                </div>
                <span class="pa-featured-airfilter-art" aria-hidden="true"><i class="fas fa-fan"></i></span>
            </div>
            <span class="pa-featured-airfilter-btn">Start now</span>
        </a>
    }

    @if (Model.FeaturedPreventive != null)
    {
        <a href="@Model.FeaturedPreventive.StartUrl" class="pa-featured-preventive">
            <div class="pa-featured-preventive-body">
                <div>
                    <div class="pa-featured-preventive-head">
                        <strong class="pa-featured-preventive-title">@Model.FeaturedPreventive.Title</strong>
                        <span class="pa-featured-preventive-badge">@Model.FeaturedPreventive.BadgeLabel</span>
                    </div>
                    <p class="pa-featured-preventive-sub">@Model.FeaturedPreventive.Subtitle</p>
                </div>
                <span class="pa-featured-preventive-icon"><i class="fas fa-clipboard-list"></i></span>
            </div>
            <span class="pa-featured-preventive-btn">Start now</span>
        </a>
    }

    @if (Model.FeaturedEmergency != null)
    {
        <a href="@Model.FeaturedEmergency.StartUrl" class="pa-featured-emergency pa-featured-emergency--flood">
            <div class="pa-featured-emergency-top">
                <span class="pa-flow-step-pill pa-flow-step-pill--sm">STEP @Model.HomeFlowStep OF @Model.HomeFlowTotalSteps</span>
            </div>
            <div class="pa-featured-emergency-body">
                <div>
                    <strong class="pa-featured-emergency-title">@Model.FeaturedEmergency.Title</strong>
                    <p class="pa-featured-emergency-sub">@Model.FeaturedEmergency.Subtitle</p>
                </div>
                <span class="pa-featured-emergency-icon"><i class="fas @Model.FeaturedEmergency.IconClass"></i></span>
            </div>
            <span class="pa-featured-emergency-btn">Start now</span>
        </a>
    }

    @if (Model.NearestPro != null)
    {
        <div class="pa-nearest-pro">
            <div class="pa-nearest-pro-copy">
                <span>Nearest @Model.NearestPro.ProTypeLabel pro available in <strong>@Model.NearestPro.EtaMinutes minutes</strong></span>
                <small>@Model.NearestPro.TrustLabel</small>
            </div>
            <span class="pa-nearest-pro-avatar"><img src="/inspeccion2.jpeg" alt="" /><span class="pa-online-dot"></span></span>
        </div>
    }



    @await Html.PartialAsync("_PropertyAdminStatRow", Model.SummaryStats)



    <section class="pa-section">

        <div class="pa-section-head">

            <h2>Service hub</h2>

            <a asp-controller="Administrador" asp-action="Services">View all services <i class="fas fa-chevron-right"></i></a>

        </div>

        <div class="pa-service-hub">

            @foreach (var item in Model.ServiceHub)

            {

                <a href="@item.Url" class="pa-service-hub-item">

                    <span class="pa-service-hub-icon @item.ToneClass"><i class="fas @item.IconClass"></i></span>

                    <span>@item.Label</span>

                </a>

            }

        </div>

    </section>



    @if (Model.RecentRequests.Count > 0)
    {
        <section class="pa-section">
            <div class="pa-section-head">
                <h2>Recent requests</h2>
                <a asp-controller="Administrador" asp-action="Tasks">View all <i class="fas fa-chevron-right"></i></a>
            </div>
            @foreach (var req in Model.RecentRequests)
            {
                <a href="@req.Url" class="pa-recent-request">
                    <div class="pa-recent-request-body">
                        <strong>@req.Title</strong>
                        <span>@req.PropertyName</span>
                    </div>
                    <span class="pa-status-pill pa-status-pill--@req.StatusCss">@req.StatusLabel</span>
                </a>
            }
        </section>
    }



    <section class="pa-section">

        <div class="pa-section-head">

            <h2>Today's service activity</h2>

        </div>

        <div class="pa-activity-row">

            @foreach (var chip in Model.TodayActivity)

            {

                <div class="pa-activity-chip">

                    <strong>@chip.Value</strong>

                    <span><i class="fas @chip.IconClass"></i> @chip.Label</span>

                </div>

            }

        </div>

    </section>



    @if (Model.UpcomingVisits.Count > 0)

    {

        <section class="pa-section">

            <div class="pa-section-head">

                <h2>Upcoming service visits</h2>

                <a asp-controller="Administrador" asp-action="Calendar">View calendar <i class="fas fa-chevron-right"></i></a>

            </div>

            <div class="pa-hscroll">

                @foreach (var visit in Model.UpcomingVisits)

                {

                    <article class="pa-visit-card">

                        <img src="@(visit.ImageUrl ?? "/inspeccion2.jpeg")" alt="" />

                        <div class="pa-visit-card-body">

                            <strong>@visit.Title</strong>

                            <span>@visit.PropertyName</span>

                            <small>@visit.DateLabel</small>

                        </div>

                    </article>

                }

            </div>

        </section>

    }

</div>


