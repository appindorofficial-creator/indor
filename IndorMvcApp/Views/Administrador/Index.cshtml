@model IndorMvcApp.ViewModels.PropertyAdministratorHomeViewModel
@using System.Text.Json
@{
    ViewData["Title"] = L["Home"];
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "home";
    var isMapView = Model.NetworkView == "map";
}

<div class="pa-portal-shell">
    @await Html.PartialAsync("_PropertyAdminTopbar", Model)

    <section class="pa-hero-banner">
        <div class="pa-hero-banner-content">
            <a asp-controller="Administrador" asp-action="Properties" class="pa-hero-pill">
                <i class="fas fa-chart-simple"></i> @L["PORTFOLIO OVERVIEW"]
            </a>
            <h1>@UiDisplayLocalization.Localize(L, Model.Greeting)</h1>
            <p>@L["Manage your Airbnb homes, guests, services &amp; local operations across your portfolio."]</p>
        </div>
        <div class="pa-hero-scene" aria-hidden="true">
            <i class="fas fa-sun pa-hero-sun"></i>
            <i class="fas fa-cloud pa-hero-cloud pa-hero-cloud--1"></i>
            <i class="fas fa-cloud pa-hero-cloud pa-hero-cloud--2"></i>
            <i class="fas fa-tree pa-hero-tree"></i>
            <i class="fas fa-house-chimney pa-hero-house"></i>
        </div>
    </section>

    @await Html.PartialAsync("_PropertyAdminHomePortfolio", Model)

    <section class="pa-network">
        <div class="pa-network-modes">
            <button type="button" class="pa-network-mode is-active" data-pamode="network">
                <span class="pa-network-mode-icon"><i class="fas fa-people-group"></i></span>
                <span class="pa-network-mode-body">
                    <strong>@L["Portfolio Network"]</strong>
                    <small>@L["Feed, nearby help, hosts &amp; local updates"]</small>
                </span>
            </button>
            <a asp-controller="Administrador" asp-action="Properties" class="pa-network-mode">
                <span class="pa-network-mode-icon pa-network-mode-icon--muted"><i class="fas fa-house"></i></span>
                <span class="pa-network-mode-body">
                    <strong>@L["My Properties"]</strong>
                    <small>@L["Your homes dashboard"]</small>
                </span>
            </a>
        </div>

        <div class="pa-network-viewtoggle" role="tablist" aria-label="@L["Network view"]">
            <a asp-controller="Administrador" asp-action="Index" asp-route-view="map" asp-route-filter="@Model.NetworkFilter"
               class="pa-network-viewbtn @(isMapView ? "is-active" : null)"><i class="fas fa-map"></i> @L["Map"]</a>
            <a asp-controller="Administrador" asp-action="Index" asp-route-view="feed" asp-route-filter="@Model.NetworkFilter"
               class="pa-network-viewbtn @(!isMapView ? "is-active" : null)"><i class="fas fa-list"></i> @L["Feed"]</a>
        </div>

        @if (isMapView)
        {
            var nm = Model.NearbyMap;
            <div class="pa-network-chips">
                @if (nm != null)
                {
                    foreach (var chip in nm.Filters)
                    {
                        <a asp-controller="Administrador" asp-action="Index" asp-route-view="map" asp-route-filter="@chip.Value"
                           class="pa-network-chip @(string.Equals(nm.ActiveFilter, chip.Value, StringComparison.OrdinalIgnoreCase) ? "is-active" : null)">
                            <i class="fas @chip.Icon"></i> @UiDisplayLocalization.Localize(L, chip.Label)
                        </a>
                    }
                }
            </div>

            if (nm != null && nm.HasGoogleMaps)
            {
                var mapConfigJson = JsonSerializer.Serialize(new
                {
                    home = new { lat = nm.CenterLatitude, lng = nm.CenterLongitude },
                    center = new { lat = nm.CenterLatitude, lng = nm.CenterLongitude },
                    homeLabel = nm.MapCenterLabel,
                    propertyAddress = nm.PropertyAddress,
                    radiusMiles = nm.RadiusMiles,
                    distanceAwayTemplate = L["{0} miles away"].ToString(),
                    activeFilter = nm.ActiveFilter,
                    carouselItems = nm.MapCarouselItems.Select(i => new
                    {
                        id = i.Id,
                        itemType = i.ItemType,
                        badgeLabel = i.BadgeLabel,
                        title = i.Title,
                        subtitle = i.Subtitle,
                        imageUrl = string.IsNullOrWhiteSpace(i.ImageUrl) ? null : Url.Content("~" + i.ImageUrl),
                        iconClass = i.IconClass,
                        latitude = i.Latitude,
                        longitude = i.Longitude,
                        distanceMiles = i.DistanceMiles,
                        metaLabel = i.MetaLabel,
                        tags = i.Tags,
                        isVerified = i.IsVerified,
                        primaryActionLabel = i.PrimaryActionLabel,
                        primaryActionUrl = i.PrimaryActionUrl,
                        secondaryActionLabel = i.SecondaryActionLabel,
                        secondaryActionUrl = i.SecondaryActionUrl
                    })
                }, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });

                <link rel="stylesheet" href="~/css/home-nearby-network.css" asp-append-version="true" />

                <section class="hn-map-shell" aria-label="@L["Nearby map"]">
                    <div id="hnNearbyNetworkMap" class="hn-map-canvas"></div>

                    <div class="hn-map-radius-badge" aria-hidden="true">@L.T("{0} mi", nm.RadiusMiles.ToString("0.#"))</div>

                    <button type="button" class="hn-map-recenter" id="hnMapRecenterBtn" aria-label="@L["Recenter on your portfolio"]">
                        <i class="fas fa-location-arrow"></i>
                    </button>

                    <div class="hn-map-carousel-panel" id="hnMapCarouselPanel">
                        <div class="hn-map-carousel-track" id="hnMapCarousel"></div>
                        <div class="hn-map-carousel-dots" id="hnMapCarouselDots"></div>
                    </div>

                    <script type="application/json" id="hn-network-map-data">@Html.Raw(mapConfigJson)</script>
                </section>

                <div class="hn-privacy-banner hn-privacy-banner--map">
                    <i class="fas fa-lock"></i>
                    @L["All communication happens in INDOR. No phone numbers shared."]
                </div>
            }
            else
            {
                <div class="pa-network-empty-map">
                    <i class="fas fa-map-location-dot"></i>
                    <p>@L["The map is not available right now. Add a property location to see nearby providers."]</p>
                </div>
            }
        }
        else
        {
            <form class="pa-network-search" asp-controller="Administrador" asp-action="Index" method="get">
                <input type="hidden" name="view" value="feed" />
                <input type="hidden" name="filter" value="@Model.NetworkFilter" />
                <i class="fas fa-magnifying-glass"></i>
                <input type="search" name="q" value="@Model.NetworkSearch" placeholder="@L["Search in my portfolio neighborhoods..."]" aria-label="@L["Search neighborhoods"]" />
            </form>

            <div class="pa-network-chips">
                <button type="button" class="pa-network-chip is-active"><i class="fas fa-table-cells-large"></i> @L["All"]</button>
                <button type="button" class="pa-network-chip"><i class="fas fa-house"></i> @L["Listings"]</button>
                <button type="button" class="pa-network-chip"><i class="fas fa-screwdriver-wrench"></i> @L["Services"]</button>
                <button type="button" class="pa-network-chip"><i class="fas fa-tag"></i> @L["Promotions"]</button>
                <button type="button" class="pa-network-chip pa-network-chip--danger"><i class="fas fa-triangle-exclamation"></i> @L["Emergency"]</button>
            </div>

            <div class="pa-network-actions">
                @{
                    var neighborPropiedadId = Model.ViewingProperty?.PropiedadId
                        ?? Model.Properties.FirstOrDefault(p => p.PropiedadId is > 0)?.PropiedadId;
                }
                @if (neighborPropiedadId is > 0)
                {
                    <a asp-controller="NeighborRequest" asp-action="Create" asp-route-propiedadId="@neighborPropiedadId" class="pa-network-action">
                        <span class="pa-network-action-icon"><i class="fas fa-plus"></i></span>
                        <strong>@L["Post a Request"]</strong>
                        <small>@L["Ask your network for help or recommendations"]</small>
                    </a>
                    <a asp-controller="NeighborRequest" asp-action="Mine" asp-route-propiedadId="@neighborPropiedadId" class="pa-network-action">
                        <span class="pa-network-action-icon pa-network-action-icon--chat"><i class="fas fa-comment-dots"></i></span>
                        <strong>@L["My Requests"]</strong>
                        <small>@L["Track &amp; manage your requests and updates"]</small>
                    </a>
                }
                else
                {
                    <a asp-controller="PropertyAdministratorRegistration" asp-action="Properties" class="pa-network-action">
                        <span class="pa-network-action-icon"><i class="fas fa-plus"></i></span>
                        <strong>@L["Post a Request"]</strong>
                        <small>@L["Add a property first to post a neighborhood request"]</small>
                    </a>
                    <a asp-controller="Administrador" asp-action="Tasks" class="pa-network-action">
                        <span class="pa-network-action-icon pa-network-action-icon--chat"><i class="fas fa-comment-dots"></i></span>
                        <strong>@L["My Requests"]</strong>
                        <small>@L["Track &amp; manage your requests and updates"]</small>
                    </a>
                }
            </div>

            <a asp-controller="Administrador" asp-action="EmergencyPlumbingDetails" class="pa-network-emergency">
                <span class="pa-network-emergency-badge">@L["EMERGENCY"]</span>
                <div class="pa-network-emergency-main">
                    <span class="pa-network-emergency-icon"><i class="fas fa-bell"></i></span>
                    <div class="pa-network-emergency-text">
                        <strong>@L["Emergency Help Nearby"]</strong>
                        <p>@L["Licensed plumber available near your Airbnb property"]</p>
                    </div>
                </div>
                <div class="pa-network-emergency-foot">
                    <div class="pa-network-emergency-meta">
                        <span><i class="far fa-clock"></i> @L["Average arrival time: 28 mins"]</span>
                        <span><i class="fas fa-location-dot"></i> @L["2.6 mi away"]</span>
                    </div>
                    <span class="pa-network-emergency-call">@L["Call now"] <i class="fas fa-chevron-right"></i></span>
                </div>
            </a>
        }
    </section>
</div>

@if (!isMapView)
{
    <script>
        (function () {
            var items = document.querySelectorAll('.pa-network-chip');
            items.forEach(function (item) {
                item.addEventListener('click', function () {
                    items.forEach(function (i) { i.classList.remove('is-active'); });
                    item.classList.add('is-active');
                });
            });
        })();
    </script>
}

@if (isMapView && Model.NearbyMap?.HasGoogleMaps == true)
{
    <script src="@Url.Content("~/js/homeowner-nearby-network-map.js")" asp-append-version="true"></script>
    <script>
        window.setTimeout(function () {
            if (!window.hnNearbyNetworkMapReady && window.google && window.google.maps && window.hnInitNearbyNetworkMap) {
                window.hnInitNearbyNetworkMap();
            }
        }, 8000);
    </script>
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=@Model.NearbyMap.GoogleMapsApiKey&amp;loading=async&amp;callback=hnInitNearbyNetworkMap"></script>
}
