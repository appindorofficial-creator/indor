@model IndorMvcApp.ViewModels.PropertyAdministratorHomeViewModel
@using System.Text.Json
@{
    ViewData["Title"] = L["Home"];
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "home";
    var isMapView = Model.NetworkView == "map";
}

<div class="pa-portal-shell">
    @await Html.PartialAsync("_PropertyAdminTopbar", Model)

    <section class="pa-hero-banner">
        <div class="pa-hero-banner-content">
            <a asp-controller="Administrador" asp-action="Properties" class="pa-hero-pill">
                <i class="fas fa-chart-simple"></i> @L["PORTFOLIO OVERVIEW"]
            </a>
            <h1>@UiDisplayLocalization.Localize(L, Model.Greeting)</h1>
            <p>@L["Manage your Airbnb homes, guests, services &amp; local operations across your portfolio."]</p>
        </div>
        <div class="pa-hero-scene" aria-hidden="true">
            <i class="fas fa-sun pa-hero-sun"></i>
            <i class="fas fa-cloud pa-hero-cloud pa-hero-cloud--1"></i>
            <i class="fas fa-cloud pa-hero-cloud pa-hero-cloud--2"></i>
            <i class="fas fa-tree pa-hero-tree"></i>
            <i class="fas fa-house-chimney pa-hero-house"></i>
        </div>
    </section>

    @await Html.PartialAsync("_PropertyAdminHomePortfolio", Model)

    <section class="pa-network">
        <div class="pa-network-modes">
            <button type="button" class="pa-network-mode is-active" data-pamode="network">
                <span class="pa-network-mode-icon"><i class="fas fa-people-group"></i></span>
                <span class="pa-network-mode-body">
                    <strong>@L["Portfolio Network"]</strong>
                    <small>@L["Feed, nearby help, hosts &amp; local updates"]</small>
                </span>
            </button>
            <a asp-controller="Administrador" asp-action="Properties" class="pa-network-mode">
                <span class="pa-network-mode-icon pa-network-mode-icon--muted"><i class="fas fa-house"></i></span>
                <span class="pa-network-mode-body">
                    <strong>@L["My Properties"]</strong>
                    <small>@L["Your homes dashboard"]</small>
                </span>
            </a>
        </div>

        <div class="pa-network-viewtoggle" role="tablist" aria-label="@L["Network view"]">
            <a asp-controller="Administrador" asp-action="Index" asp-route-view="map" asp-route-filter="@Model.NetworkFilter"
               class="pa-network-viewbtn @(isMapView ? "is-active" : null)"><i class="fas fa-map"></i> @L["Map"]</a>
            <a asp-controller="Administrador" asp-action="Index" asp-route-view="feed" asp-route-filter="@Model.NetworkFilter"
               class="pa-network-viewbtn @(!isMapView ? "is-active" : null)"><i class="fas fa-list"></i> @L["Feed"]</a>
        </div>

        @if (isMapView)
        {
            var nm = Model.NearbyMap;
            <div class="pa-network-chips">
                @if (nm != null)
                {
                    foreach (var chip in nm.Filters)
                    {
                        <a asp-controller="Administrador" asp-action="Index" asp-route-view="map" asp-route-filter="@chip.Value"
                           class="pa-network-chip @(string.Equals(nm.ActiveFilter, chip.Value, StringComparison.OrdinalIgnoreCase) ? "is-active" : null)">
                            <i class="fas @chip.Icon"></i> @UiDisplayLocalization.Localize(L, chip.Label)
                        </a>
                    }
                }
            </div>

            if (nm != null && nm.HasGoogleMaps)
            {
                var mapConfigJson = JsonSerializer.Serialize(new
                {
                    home = new { lat = nm.CenterLatitude, lng = nm.CenterLongitude },
                    center = new { lat = nm.CenterLatitude, lng = nm.CenterLongitude },
                    homeLabel = nm.MapCenterLabel,
                    propertyAddress = nm.PropertyAddress,
                    radiusMiles = nm.RadiusMiles,
                    distanceAwayTemplate = L["{0} miles away"].ToString(),
                    activeFilter = nm.ActiveFilter,
                    carouselItems = nm.MapCarouselItems.Select(i => new
                    {
                        id = i.Id,
                        itemType = i.ItemType,
                        badgeLabel = i.BadgeLabel,
                        title = i.Title,
                        subtitle = i.Subtitle,
                        imageUrl = string.IsNullOrWhiteSpace(i.ImageUrl) ? null : Url.Content("~" + i.ImageUrl),
                        iconClass = i.IconClass,
                        latitude = i.Latitude,
                        longitude = i.Longitude,
                        distanceMiles = i.DistanceMiles,
                        metaLabel = i.MetaLabel,
                        tags = i.Tags,
                        isVerified = i.IsVerified,
                        primaryActionLabel = i.PrimaryActionLabel,
                        primaryActionUrl = i.PrimaryActionUrl,
                        secondaryActionLabel = i.SecondaryActionLabel,
                        secondaryActionUrl = i.SecondaryActionUrl
                    })
                }, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });

                <link rel="stylesheet" href="~/css/home-nearby-network.css" asp-append-version="true" />

                <section class="hn-map-shell" aria-label="@L["Nearby map"]">
                    <div id="hnNearbyNetworkMap" class="hn-map-canvas"></div>

                    <div class="hn-map-radius-badge" aria-hidden="true">@L.T("{0} mi", nm.RadiusMiles.ToString("0.#"))</div>

                    <button type="button" class="hn-map-recenter" id="hnMapRecenterBtn" aria-label="@L["Recenter on your portfolio"]">
                        <i class="fas fa-location-arrow"></i>
                    </button>

                    <div class="hn-map-carousel-panel" id="hnMapCarouselPanel">
                        <div class="hn-map-carousel-track" id="hnMapCarousel"></div>
                        <div class="hn-map-carousel-dots" id="hnMapCarouselDots"></div>
                    </div>

                    <script type="application/json" id="hn-network-map-data">@Html.Raw(mapConfigJson)</script>
                </section>

                <div class="hn-privacy-banner hn-privacy-banner--map">
                    <i class="fas fa-lock"></i>
                    @L["All communication happens in INDOR. No phone numbers shared."]
                </div>
            }
            else
            {
                <div class="pa-network-empty-map">
                    <i class="fas fa-map-location-dot"></i>
                    <p>@L["The map is not available right now. Add a property location to see nearby providers."]</p>
                </div>
            }
        }
        else
        {
            var networkFilter = Model.NetworkFilter ?? "All";
            var hasSearch = !string.IsNullOrWhiteSpace(Model.NetworkSearch);
            var showListings = string.Equals(networkFilter, "All", StringComparison.OrdinalIgnoreCase)
                || string.Equals(networkFilter, "Listings", StringComparison.OrdinalIgnoreCase);
            var showServices = string.Equals(networkFilter, "All", StringComparison.OrdinalIgnoreCase)
                || string.Equals(networkFilter, "Services", StringComparison.OrdinalIgnoreCase);
            var showPromotions = string.Equals(networkFilter, "Promotions", StringComparison.OrdinalIgnoreCase);
            var showEmergency = string.Equals(networkFilter, "All", StringComparison.OrdinalIgnoreCase)
                || string.Equals(networkFilter, "Emergency", StringComparison.OrdinalIgnoreCase);
            var feedChips = new (string Key, string Label, string Icon, string Css)[]
            {
                ("All", L["All"], "fa-table-cells-large", ""),
                ("Listings", L["Listings"], "fa-house", ""),
                ("Services", L["Services"], "fa-screwdriver-wrench", ""),
                ("Promotions", L["Promotions"], "fa-tag", ""),
                ("Emergency", L["Emergency"], "fa-triangle-exclamation", "pa-network-chip--danger")
            };

            <form class="pa-network-search" id="paNetworkSearchForm" role="search" asp-controller="Administrador" asp-action="Index" method="get">
                <input type="hidden" name="view" value="feed" />
                <input type="hidden" name="filter" value="@networkFilter" />
                @if (Model.ViewingProperty != null)
                {
                    <input type="hidden" name="propertyId" value="@Model.ViewingProperty.Id" />
                }
                <button type="submit" class="pa-search-submit" aria-label="@L["Search"]" title="@L["Search"]">
                    <i class="fas fa-magnifying-glass" aria-hidden="true"></i>
                </button>
                <input type="search"
                       id="paNetworkSearch"
                       name="q"
                       value="@Model.NetworkSearch"
                       placeholder="@L["Search in my portfolio neighborhoods..."]"
                       aria-label="@L["Search neighborhoods"]"
                       autocomplete="off"
                       enterkeyhint="search" />
            </form>

            <div class="pa-network-chips">
                @foreach (var chip in feedChips)
                {
                    <a asp-controller="Administrador"
                       asp-action="Index"
                       asp-route-view="feed"
                       asp-route-filter="@(chip.Key == "All" ? null : chip.Key)"
                       asp-route-q="@Model.NetworkSearch"
                       asp-route-propertyId="@(Model.ViewingProperty?.Id)"
                       class="pa-network-chip @chip.Css @(string.Equals(networkFilter, chip.Key, StringComparison.OrdinalIgnoreCase) ? "is-active" : null)">
                        <i class="fas @chip.Icon"></i> @chip.Label
                    </a>
                }
            </div>

            <div class="pa-empty-card" id="paNetworkSearchEmpty" hidden>
                @L["No results match your search."]
            </div>

            <div class="pa-network-neighborhoods"
                 id="paNetworkNeighborhoods"
                 data-pa-network-block="listings"
                 hidden="@(showListings && (hasSearch || string.Equals(networkFilter, "Listings", StringComparison.OrdinalIgnoreCase)) ? null : "hidden")">
                <div class="pa-network-neighborhoods-head">
                    <strong>@L["Portfolio neighborhoods"]</strong>
                    <p>@L["Properties in your portfolio that match this search."]</p>
                </div>
                <div class="pa-network-neighborhood-list" role="list">
                    @foreach (var property in Model.Properties)
                    {
                        var neighborhoodHaystack = $"{property.PropertyName} {property.Location} {property.PropertyTypeLabel} {property.PropertyType}".ToLowerInvariant();
                        <a asp-controller="Administrador"
                           asp-action="Index"
                           asp-route-propertyId="@property.Id"
                           asp-route-view="feed"
                           class="pa-network-neighborhood"
                           role="listitem"
                           data-pa-network-item
                           data-pa-network-kind="listings"
                           data-search="@neighborhoodHaystack">
                            <span class="pa-network-neighborhood-thumb">
                                <img src="@(property.ImageUrl ?? "/inspeccion2.jpeg")" alt="" />
                            </span>
                            <span class="pa-network-neighborhood-body">
                                <strong>@property.PropertyName</strong>
                                <small>@property.Location</small>
                            </span>
                            <i class="fas fa-chevron-right" aria-hidden="true"></i>
                        </a>
                    }
                </div>
            </div>

            <div class="pa-network-actions"
                 data-pa-network-block="services"
                 hidden="@(showServices ? null : "hidden")">
                @{
                    var neighborPropiedadId = Model.ViewingProperty?.PropiedadId
                        ?? Model.Properties.FirstOrDefault(p => p.PropiedadId is > 0)?.PropiedadId;
                }
                @if (neighborPropiedadId is > 0)
                {
                    <a asp-controller="NeighborRequest" asp-action="Create" asp-route-propiedadId="@neighborPropiedadId"
                       class="pa-network-action" data-pa-network-item data-pa-network-kind="services"
                       data-search="post request help recommendations network services">
                        <span class="pa-network-action-icon"><i class="fas fa-plus"></i></span>
                        <strong>@L["Post a Request"]</strong>
                        <small>@L["Ask your network for help or recommendations"]</small>
                    </a>
                    <a asp-controller="NeighborRequest" asp-action="Mine" asp-route-propiedadId="@neighborPropiedadId"
                       class="pa-network-action" data-pa-network-item data-pa-network-kind="services"
                       data-search="my requests track manage updates network services">
                        <span class="pa-network-action-icon pa-network-action-icon--chat"><i class="fas fa-comment-dots"></i></span>
                        <strong>@L["My Requests"]</strong>
                        <small>@L["Track &amp; manage your requests and updates"]</small>
                    </a>
                }
                else
                {
                    <a asp-controller="PropertyAdministratorRegistration" asp-action="Properties"
                       class="pa-network-action" data-pa-network-item data-pa-network-kind="services"
                       data-search="post request add property neighborhood services">
                        <span class="pa-network-action-icon"><i class="fas fa-plus"></i></span>
                        <strong>@L["Post a Request"]</strong>
                        <small>@L["Add a property first to post a neighborhood request"]</small>
                    </a>
                    <a asp-controller="Administrador" asp-action="Tasks"
                       class="pa-network-action" data-pa-network-item data-pa-network-kind="services"
                       data-search="my requests track manage updates tasks services">
                        <span class="pa-network-action-icon pa-network-action-icon--chat"><i class="fas fa-comment-dots"></i></span>
                        <strong>@L["My Requests"]</strong>
                        <small>@L["Track &amp; manage your requests and updates"]</small>
                    </a>
                }
                <a asp-controller="Administrador" asp-action="Services"
                   class="pa-network-action" data-pa-network-item data-pa-network-kind="services"
                   data-search="browse services catalog plumbing cleaning outdoor moving emergency">
                    <span class="pa-network-action-icon"><i class="fas fa-screwdriver-wrench"></i></span>
                    <strong>@L["Browse services"]</strong>
                    <small>@L["Find help across your portfolio neighborhoods"]</small>
                </a>
            </div>

            <div class="pa-empty-card"
                 data-pa-network-block="promotions"
                 hidden="@(showPromotions ? null : "hidden")">
                @L["No promotions in your portfolio neighborhoods right now."]
            </div>

            <div class="pa-network-emergency-section"
                 data-pa-network-block="emergency"
                 hidden="@(showEmergency ? null : "hidden")">
                <div class="pa-network-emergency-section-head">
                    <span class="pa-network-emergency-badge">@L["EMERGENCY"]</span>
                    <strong>@L["Emergency Help Nearby"]</strong>
                    <p>@L["Certified plumbers, electricians & more — often arriving within 60 minutes."]</p>
                </div>
                @if (Model.EmergencyNearbyServices.Count > 0)
                {
                    <div class="pa-hscroll pa-network-emergency-scroll" role="list" aria-label="@L["Emergency Help Nearby"]">
                        @foreach (var emergency in Model.EmergencyNearbyServices)
                        {
                            var emergencyLocalizedName = UiDisplayLocalization.Localize(L, emergency.ServiceName);
                            var emergencyLocalizedSubtitle = UiDisplayLocalization.Localize(L, emergency.Subtitle);
                            var emergencyHaystack = $"{emergency.ServiceName} {emergencyLocalizedName} {emergency.Subtitle} {emergencyLocalizedSubtitle} emergency".ToLowerInvariant();
                            var callHref = string.IsNullOrWhiteSpace(emergency.CallUrl) ? "tel:18005554637" : emergency.CallUrl;
                            <article class="pa-network-emergency"
                                     role="listitem"
                                     data-pa-network-item
                                     data-pa-network-kind="emergency"
                                     data-search="@emergencyHaystack">
                                <a href="@emergency.Url"
                                   class="pa-network-emergency-main"
                                   aria-label="@emergencyLocalizedName">
                                    <span class="pa-network-emergency-icon"><i class="fas @emergency.IconClass"></i></span>
                                    <div class="pa-network-emergency-text">
                                        <strong>@emergencyLocalizedName</strong>
                                        <p>@emergencyLocalizedSubtitle</p>
                                    </div>
                                </a>
                                <div class="pa-network-emergency-foot">
                                    <div class="pa-network-emergency-meta">
                                        <span><i class="far fa-clock"></i> @L.T("Average arrival time: {0} mins", emergency.ArrivalMinutes)</span>
                                        <span><i class="fas fa-location-dot"></i> @L.T("{0} mi away", emergency.DistanceMiles)</span>
                                    </div>
                                    <a href="@callHref"
                                       class="pa-network-emergency-call"
                                       aria-label="@($"{L["Call now"]} — {emergency.PhoneNumber}")">
                                        @L["Call now"] <i class="fas fa-phone" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <a asp-controller="Administrador" asp-action="EmergencyServices"
                       class="pa-network-emergency"
                       data-pa-network-item
                       data-pa-network-kind="emergency"
                       data-search="emergency help nearby services">
                        <div class="pa-network-emergency-main">
                            <span class="pa-network-emergency-icon"><i class="fas fa-bell"></i></span>
                            <div class="pa-network-emergency-text">
                                <strong>@L["Emergency Help Nearby"]</strong>
                                <p>@L["Call now to connect with an emergency service pro."]</p>
                            </div>
                        </div>
                        <div class="pa-network-emergency-foot">
                            <span class="pa-network-emergency-call">@L["View emergency services"] <i class="fas fa-chevron-right"></i></span>
                        </div>
                    </a>
                }
            </div>
        }
    </section>
</div>

@if (isMapView && Model.NearbyMap?.HasGoogleMaps == true)
{
    <script src="@Url.Content("~/js/homeowner-nearby-network-map.js")" asp-append-version="true"></script>
    <script>
        window.setTimeout(function () {
            if (!window.hnNearbyNetworkMapReady && window.google && window.google.maps && window.hnInitNearbyNetworkMap) {
                window.hnInitNearbyNetworkMap();
            }
        }, 8000);
    </script>
    <script async defer src="https://maps.googleapis.com/maps/api/js?key=@Model.NearbyMap.GoogleMapsApiKey&amp;loading=async&amp;callback=hnInitNearbyNetworkMap"></script>
}
