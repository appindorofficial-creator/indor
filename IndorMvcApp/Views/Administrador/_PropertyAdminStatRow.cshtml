@model IReadOnlyList<IndorMvcApp.ViewModels.PropertyAdministratorStatCardViewModel>
@if (Model.Count > 0)
{
    <div class="pa-stats-row">
        @foreach (var stat in Model)
        {
            <div class="pa-stat-tile">
                <span class="pa-stat-tile-icon @stat.ToneClass"><i class="fas @stat.IconClass"></i></span>
                <strong>@stat.Value</strong>
                <span class="pa-stat-tile-label">@stat.Label</span>
                @if (!string.IsNullOrWhiteSpace(stat.LinkLabel))
                {
                    <a href="@stat.LinkUrl" class="pa-stat-tile-link">@stat.LinkLabel <i class="fas fa-chevron-right"></i></a>
                }
            </div>
        }
    </div>
}
