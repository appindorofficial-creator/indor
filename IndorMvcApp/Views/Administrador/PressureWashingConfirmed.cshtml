@model IndorMvcApp.ViewModels.PropertyAdministratorPressureWashingConfirmedViewModel
@{
    ViewData["Title"] = L["Pressure Washing scheduled"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pressure Washing scheduled"].ToString();
    ViewBag.FlowSubtitle = L.T("Your service has been booked for {0}.", Model.ViewingProperty?.PropertyName ?? L["your property"]).ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Schedule"].ToString(), L["Done"].ToString() };
    ViewBag.FlowShowBack = false;
    var propertyLabel = Model.ViewingProperty != null
        ? $"{Model.ViewingProperty.PropertyTypeLabel} • {Model.ViewingProperty.Location}"
        : "";
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    <div class="pa-success-banner pa-success-banner--green">
        <span class="pa-success-icon"><i class="fas fa-check"></i></span>
        <div>
            <strong>@L["Request received"]</strong>
            <span>@L["Crew confirmed for tomorrow."]</span>
        </div>
    </div>

    <article class="pa-tech-card">
        <div class="pa-tech-head">
            <img src="/inspeccion2.jpeg" alt="" class="pa-tech-avatar" />
            <div class="pa-tech-meta">
                <strong>@Model.TechnicianName</strong>
                <span><i class="fas fa-star"></i> @Model.TechnicianRating.ToString("0.0") (@L.T("{0} jobs", Model.TechnicianReviewCount))</span>
                <small>@UiDisplayLocalization.Localize(L, Model.TechnicianSubtitle)</small>
            </div>
            <span class="pa-verified-badge"><i class="fas fa-check"></i> @L["Verified"]</span>
        </div>
        <div class="pa-tech-stats">
            <div>
                <i class="fas fa-clock"></i>
                <strong>@UiDisplayLocalization.Localize(L, Model.EtaLabel)</strong>
                <small>@L["Arrival window"]</small>
            </div>
            <div>
                <i class="fas fa-house"></i>
                <strong>@(Model.ViewingProperty?.PropertyName)</strong>
                <small>@propertyLabel</small>
            </div>
            <div>
                <i class="fas fa-border-all"></i>
                <strong>@Model.ServiceAreasLabel</strong>
                <small>@L["Service area"]</small>
            </div>
        </div>
    </article>

    <article class="pa-lawn-progress-card">
        <h2>@L["Request timeline"]</h2>
        <div class="pa-lawn-progress-track">
            @foreach (var step in Model.Timeline)
            {
                <div class="pa-lawn-progress-step pa-lawn-progress-step--@step.State">
                    <span class="pa-lawn-progress-dot">
                        @if (step.State == "active")
                        {
                            <text>@step.StepNumber</text>
                        }
                        else
                        {
                            <i class="fas @step.IconClass"></i>
                        }
                    </span>
                    <strong>@UiDisplayLocalization.Localize(L, step.Label)</strong>
                    <small>@UiDisplayLocalization.Localize(L, step.StatusLabel)</small>
                </div>
            }
        </div>
    </article>

    <article class="pa-summary-card-block">
        <h2>@L["Service summary"]</h2>
        <ul class="pa-summary-detail-list pa-summary-detail-list--green">
            @foreach (var item in Model.Summary)
            {
                <li>
                    <i class="fas @item.IconClass"></i>
                    <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
                    <strong>@item.Value</strong>
                </li>
            }
        </ul>
        <p class="pa-pw-eco-note"><i class="fas fa-leaf"></i> @L["Eco-safe wash included"]</p>
    </article>

    <div class="pa-action-grid">
        <button type="button" class="pa-action-tile"><i class="fas fa-phone"></i><span>@L["Call crew"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-comment"></i><span>@L["Message guest"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-calendar"></i><span>@L["Reschedule"]</span></button>
        <a asp-controller="Administrador" asp-action="Tasks" class="pa-action-tile">
            <i class="fas fa-file-lines"></i><span>@L["View details"]</span>
        </a>
    </div>

    <div class="pa-lawn-tip-banner">
        <i class="fas fa-lightbulb"></i>
        <p><strong>@L["Tip:"]</strong> @UiDisplayLocalization.Localize(L, Model.Tip)</p>
    </div>

    <a asp-controller="Administrador" asp-action="Tasks" class="ob-btn ob-btn-primary pa-flow-submit">
        @L["Track request"] <i class="fas fa-location-dot"></i>
    </a>
    <a asp-controller="Administrador" asp-action="Index" asp-route-propertyId="@Model.ViewingProperty?.Id" class="ob-btn ob-btn-outline pa-flow-edit">
        @L["Back to start"]
    </a>
</div>
