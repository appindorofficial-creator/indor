@model IndorMvcApp.ViewModels.PropertyAdministratorMovingHelpConfirmedViewModel
@{
    ViewData["Title"] = L["Moving Help scheduled"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Moving Help scheduled"].ToString();
    ViewBag.FlowSubtitle = L.T("Your team is confirmed for {0}.", Model.ViewingProperty?.PropertyName ?? L["your property"]).ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Review"].ToString(), L["Done"].ToString() };
    ViewBag.FlowShowBack = false;
    var propertyLabel = Model.ViewingProperty != null
        ? $"{Model.ViewingProperty.PropertyTypeLabel} • {Model.ViewingProperty.Location}"
        : "";
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    <div class="pa-success-banner">
        <span class="pa-success-icon"><i class="fas fa-check"></i></span>
        <div>
            <strong>@L["Request received"]</strong>
            <span>@L["We've scheduled your moving team."]</span>
        </div>
    </div>

    <article class="pa-tech-card">
        <div class="pa-tech-head">
            <img src="/inspeccion2.jpeg" alt="" class="pa-tech-avatar" />
            <div class="pa-tech-meta">
                <strong>@Model.TechnicianName</strong>
                <span><i class="fas fa-star"></i> @Model.TechnicianRating.ToString("0.0")</span>
                <small>@UiDisplayLocalization.Localize(L, Model.TechnicianTitle)</small>
                <small class="pa-tech-role">@UiDisplayLocalization.Localize(L, Model.TechnicianRole)</small>
            </div>
            <span class="pa-verified-badge"><i class="fas fa-check"></i> @L["Verified"]</span>
        </div>
        <div class="pa-tech-stats">
            <div>
                <i class="fas fa-calendar"></i>
                <strong>@UiDisplayLocalization.Localize(L, Model.ScheduleLabel)</strong>
                <small>@L["ETA"]</small>
            </div>
            <div>
                <i class="fas fa-clock"></i>
                <strong>@UiDisplayLocalization.Localize(L, Model.TimeWindowLabel)</strong>
                <small>@L["Window"]</small>
            </div>
            <div>
                <i class="fas fa-house"></i>
                <strong>@L.T("Viewing: {0}", Model.ViewingProperty?.PropertyName)</strong>
                <small>@propertyLabel</small>
            </div>
        </div>
    </article>

    <div class="pa-confirm-split">
        <article class="pa-summary-card-block">
            <h2>@L["Booking details"]</h2>
            <ul class="pa-booking-detail-list pa-booking-detail-list--blue">
                @foreach (var item in Model.BookingDetails)
                {
                    <li>
                        <i class="fas @item.IconClass"></i>
                        <div>
                            <span>@UiDisplayLocalization.Localize(L, item.Label)</span>
                            <strong>@item.Value</strong>
                        </div>
                    </li>
                }
            </ul>
        </article>

        <article class="pa-timeline-card pa-timeline-card--inline">
            <h2>@L["Request timeline"]</h2>
            <ul class="pa-timeline">
                @foreach (var step in Model.Timeline)
                {
                    <li class="pa-timeline-item pa-timeline-item--@step.State">
                        <span class="pa-timeline-dot"><i class="fas @step.IconClass"></i></span>
                        <div class="pa-timeline-body">
                            <strong>@UiDisplayLocalization.Localize(L, step.Label)</strong>
                            <span>@UiDisplayLocalization.Localize(L, step.StatusLabel)</span>
                        </div>
                    </li>
                }
            </ul>
        </article>
    </div>

    <div class="pa-action-grid">
        <button type="button" class="pa-action-tile"><i class="fas fa-comment"></i><span>@L["Message team"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-calendar"></i><span>@L["Reschedule"]</span></button>
        <button type="button" class="pa-action-tile"><i class="fas fa-rotate"></i><span>@L["Add recurring"]</span></button>
        <a asp-controller="Administrador" asp-action="Tasks" class="pa-action-tile">
            <i class="fas fa-file-lines"></i><span>@L["View details"]</span>
        </a>
    </div>

    <div class="pa-moving-info-box">
        <i class="fas fa-circle-info"></i>
        <p>@UiDisplayLocalization.Localize(L, Model.InfoBanner)</p>
    </div>
    @{ ViewBag.ConfirmedPropertyId = Model.ViewingProperty?.Id; }
    @await Html.PartialAsync("_PropertyAdminConfirmedFooter")

</div>
