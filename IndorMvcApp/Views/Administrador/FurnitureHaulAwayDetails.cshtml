@model IndorMvcApp.ViewModels.PropertyAdministratorFurnitureHaulAwayStep1ViewModel
@{
    ViewData["Title"] = "Furniture Haul Away";
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowBackUrl = Url.Action("Index", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var items = Model.FurnitureItems.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro">
        <h1><i class="fas fa-couch pa-flow-title-icon"></i> Furniture Haul Away</h1>
        <p>Tell us what furniture needs to be removed so we can send the right crew.</p>
    </section>

    @if (Model.ViewingProperty != null && Model.ViewingProperty.Id > 0)
    {
        <div class="pa-viewing-strip">
            <img src="@(Model.ViewingProperty.ImageUrl ?? "/inspeccion2.jpeg")" alt="" class="pa-viewing-strip-thumb" />
            <div class="pa-viewing-strip-main">
                <strong>Viewing: @Model.ViewingProperty.PropertyName</strong>
                @if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
                {
                    <span class="pa-checkout-badge"><i class="fas fa-calendar-day"></i> @Model.PropertyStatusLabel</span>
                }
                <small>@Model.ViewingProperty.PropertyTypeLabel • @Model.ViewingProperty.Location</small>
            </div>
            <a asp-controller="Administrador" asp-action="Properties" class="pa-viewing-switch">Switch property <i class="fas fa-chevron-right"></i></a>
        </div>
    }

    <form asp-action="FurnitureHaulAwayDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-couch pa-q-icon pa-q-icon--blue"></i> What needs to be removed? <small>(Select all that apply)</small></label>
            <div class="pa-furniture-items-grid">
                @foreach (var i in new (string Value, string Label, string Icon)[]
                {
                    ("Couch", "Couch", "fa-couch"),
                    ("Mattress", "Mattress", "fa-bed"),
                    ("BedFrame", "Bed frame", "fa-bed"),
                    ("Dresser", "Dresser", "fa-archive"),
                    ("DiningTable", "Dining table", "fa-chair"),
                    ("Refrigerator", "Refrigerator", "fa-kitchen-set"),
                    ("WasherDryer", "Washer / Dryer", "fa-shirt"),
                    ("TvElectronics", "TV / Electronics", "fa-tv"),
                    ("Other", "Other", "fa-ellipsis")
                })
                {
                    <label class="pa-junk-item-card @(items.Contains(i.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="FurnitureItemsList" value="@i.Value" @(items.Contains(i.Value) ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <i class="fas @i.Icon"></i>
                        <span>@i.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>How many items?</label>
            <div class="pa-chip-grid pa-chip-grid--4">
                @foreach (var c in new (string Value, string Label)[] { ("One", "1 item"), ("TwoThree", "2–3"), ("FourSix", "4–6"), ("SevenPlus", "7+") })
                {
                    <label class="pa-chip @(Model.ItemCount == c.Value ? "is-selected" : null)">
                        <input type="radio" name="ItemCount" value="@c.Value" @(Model.ItemCount == c.Value ? "checked" : null) />
                        <span>@c.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-truck pa-q-icon pa-q-icon--blue"></i> How big is the pickup?</label>
            <div class="pa-junk-load-row pa-junk-load-row--3">
                @foreach (var l in new (string Value, string Label, string Icon)[] { ("SmallPickup", "Small pickup", "fa-truck-pickup"), ("HalfLoad", "Half load", "fa-truck"), ("FullLoad", "Full load", "fa-truck-moving") })
                {
                    <label class="pa-junk-load-card @(Model.PickupSize == l.Value ? "is-selected" : null)">
                        <input type="radio" name="PickupSize" value="@l.Value" @(Model.PickupSize == l.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--blue"><i class="fas fa-check"></i></span>
                        <i class="fas @l.Icon"></i>
                        <span>@l.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>Is the property occupied right now?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.IsOccupied == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="Yes" @(Model.IsOccupied == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.IsOccupied == "No" ? "is-selected" : null)">
                    <input type="radio" name="IsOccupied" value="No" @(Model.IsOccupied == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>Are guests currently inside?</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--blue"></i> Any quick details? <small>(optional)</small></label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" id="fhDetails">@Model.QuickDetails</textarea>
            <small class="pa-char-count"><span id="fhDetailsCount">@Model.QuickDetails.Length</span> / 250</small>
        </div>

        <div class="pa-media-actions">
            <button type="button" class="pa-media-btn"><i class="fas fa-camera"></i> Add photos</button>
            <button type="button" class="pa-media-btn"><i class="fas fa-microphone"></i> Voice note</button>
        </div>

        <div class="pa-junk-priority-banner">
            <i class="fas fa-circle-info"></i>
            <p>Large item pickups for Airbnb turnovers can be prioritized for faster scheduling.</p>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">Continue</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">Back</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-junk-item-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-junk-item-card')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-junk-load-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                document.querySelectorAll('.pa-junk-load-card').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-junk-load-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var details = document.getElementById('fhDetails');
        var counter = document.getElementById('fhDetailsCount');
        if (details && counter) {
            details.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
