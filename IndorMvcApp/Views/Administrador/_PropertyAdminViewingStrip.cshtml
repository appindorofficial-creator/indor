@model IndorMvcApp.ViewModels.PropertyAdministratorFlowPropertyViewModel
@if (Model != null && Model.Id > 0)
{
    <div class="pa-viewing-strip">
        <img src="@(Model.ImageUrl ?? "/welcome-house.png")" alt="" class="pa-viewing-strip-thumb" />
        <div class="pa-viewing-strip-main">
            <strong>@L.T("Viewing: {0}", Model.PropertyName)</strong>
            @if (!string.IsNullOrWhiteSpace(ViewBag.BadgeLabel as string ?? Model.OccupancyLabel))
            {
                <span class="pa-occupancy-badge">@UiDisplayLocalization.Localize(L, ViewBag.BadgeLabel as string ?? Model.OccupancyLabel)</span>
            }
            <small>@UiDisplayLocalization.Localize(L, Model.PropertyTypeLabel) • @Model.Location</small>
        </div>
        <a asp-controller="Administrador" asp-action="Properties" class="pa-viewing-switch" aria-label="@L["Switch property"]">
            <i class="fas fa-chevron-down pa-portfolio-chevron" aria-hidden="true"></i>
        </a>
    </div>
}
