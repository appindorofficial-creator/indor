@model IndorMvcApp.ViewModels.PropertyAdministratorPoolHotTubStep2ViewModel
@{
    ViewData["Title"] = L["Access & review details"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Access & review details"].ToString();
    ViewBag.FlowSubtitle = L["Tell us how the technician can access the area and confirm the service request."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("PoolHotTubDetails", "Administrador", new { propertyId = Model.PropertyId });
    ViewBag.BadgeLabel = Model.PropertyStatusLabel;
    var recipients = Model.UpdateRecipients.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <div class="pa-pool-summary-strip">
        @foreach (var chip in Model.Step1Summary)
        {
            <div class="pa-pool-summary-chip">
                <i class="fas @chip.IconClass"></i>
                <small>@chip.Label</small>
                <strong>@chip.Value</strong>
            </div>
        }
    </div>

    <form asp-action="PoolHotTubAccess" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
        <input type="hidden" name="ServiceHelpType" value="@Model.ServiceHelpType" />
        <input type="hidden" name="MainIssue" value="@Model.MainIssue" />
        <input type="hidden" name="GuestStayAffected" value="@Model.GuestStayAffected" />
        <input type="hidden" name="Urgency" value="@Model.Urgency" />
        <input type="hidden" name="QuickDetails" value="@Model.QuickDetails" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["Where is the equipment?"]</label>
            <div class="pa-chip-grid pa-chip-grid--2">
                @foreach (var l in new[] { ("PoolPad", L["Pool pad"]), ("BackyardSpa", L["Backyard spa"]), ("EquipmentRoom", L["Equipment room"]), ("Other", L["Other"]) })
                {
                    <label class="pa-chip @(Model.EquipmentLocation == l.Item1 ? "is-selected" : null)">
                        <input type="radio" name="EquipmentLocation" value="@l.Item1" @(Model.EquipmentLocation == l.Item1 ? "checked" : null) />
                        <span>@l.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-door-open pa-q-icon pa-q-icon--green"></i> @L["Can the pro enter now?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var e in new[] { ("GateCode", L["Yes, gate code"]), ("HostOnSite", L["Host will meet"]), ("GuestApproval", L["Need guest approval"]) })
                {
                    <label class="pa-chip @(Model.EntryAccess == e.Item1 ? "is-selected" : null)">
                        <input type="radio" name="EntryAccess" value="@e.Item1" @(Model.EntryAccess == e.Item1 ? "checked" : null) />
                        <span>@e.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-key pa-q-icon pa-q-icon--green"></i> @L["Gate / access code"]</label>
            <div class="pa-field">
                <i class="fas fa-lock"></i>
                <input type="text" name="AccessCode" value="@Model.AccessCode" />
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label><i class="fas fa-users pa-q-icon pa-q-icon--green"></i> @L["Who should receive updates?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var r in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("CoHost", L["Co-host"]) })
                {
                    <label class="pa-chip @(recipients.Contains(r.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="UpdateRecipientsList" value="@r.Item1" @(recipients.Contains(r.Item1) ? "checked" : null) />
                        <span>@r.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-phone pa-q-icon pa-q-icon--green"></i> @L["Best contact number"]</label>
            <div class="pa-field">
                <i class="fas fa-phone"></i>
                <input type="tel" name="ContactPhone" value="@Model.ContactPhone" />
            </div>
        </div>

        <div class="pa-lawn-availability-banner">
            <div>
                <strong>@UiDisplayLocalization.Localize(L, Model.ProEtaLabel)</strong>
                <small>@L["Licensed • Insured • Background checked"]</small>
            </div>
            <i class="fas fa-user-check"></i>
        </div>

        <article class="pa-pool-pricing-card">
            <div class="pa-pool-pricing-row">
                <span><i class="fas fa-tag"></i> @L["Estimated diagnostic visit"]</span>
                <strong>@Model.DiagnosticEstimate</strong>
            </div>
            <div class="pa-pool-pricing-row">
                <span><i class="fas fa-bolt"></i> @L["Emergency priority fee"]</span>
                <strong class="pa-pool-pricing-included">@Model.EmergencyFeeLabel</strong>
            </div>
        </article>

        <div class="pa-lawn-photo-banner">
            <i class="fas fa-circle-info"></i>
            <div>
                <strong>@L["We'll send status updates to you and the guest."]</strong>
            </div>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Request repair service"]</button>
        <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
        <a href="@Url.Action("Index", "Administrador", new { propertyId = Model.PropertyId })" class="pa-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"]').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid');
                if (!group) return;
                group.querySelectorAll('.pa-chip').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip')?.classList.add('is-selected');
            });
        });
    </script>
}
