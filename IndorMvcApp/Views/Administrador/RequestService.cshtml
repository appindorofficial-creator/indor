@{
    ViewData["Title"] = "Request service";
    Layout = "_PropertyAdminLayout";
    ViewBag.NavActive = "services";
    var service = ViewBag.ServiceSlug as string;
}

<div class="pa-portal-shell">
    <header class="pa-portal-topbar">
        <a asp-controller="Administrador" asp-action="Services" class="pa-back-inline"><i class="fas fa-arrow-left"></i></a>
        <span class="pa-portal-topbar-title">Request service</span>
        <span style="width:32px"></span>
    </header>

    <div class="pa-emergency-banner">
        <div>
            <strong>Emergency help is available 24/7</strong>
            <p>Call us anytime or request an emergency service.</p>
        </div>
        <a asp-controller="Administrador" asp-action="Services" asp-route-filter="emergency" class="pa-emergency-btn">Call now</a>
    </div>

    <section class="pa-section">
        <h2 class="pa-form-step">1. Select property</h2>
        <div class="pa-empty-card">Property selection will load from your portfolio.</div>

        <h2 class="pa-form-step">2. Choose service</h2>
        <p class="pa-form-hint">@(string.IsNullOrWhiteSpace(service) ? "Pick a service from the Services tab to pre-fill this step." : $"Selected: {service}")</p>

        <h2 class="pa-form-step">3. Urgency & schedule</h2>
        <div class="pa-choice-grid cols-3">
            <label class="pa-choice-card is-selected"><input type="radio" name="urgency" checked /><i class="fas fa-bolt"></i><span>Emergency ASAP</span></label>
            <label class="pa-choice-card"><input type="radio" name="urgency" /><i class="fas fa-sun"></i><span>Today</span></label>
            <label class="pa-choice-card"><input type="radio" name="urgency" /><i class="fas fa-calendar"></i><span>Schedule</span></label>
        </div>

        <h2 class="pa-form-step">4. Describe the issue</h2>
        <textarea class="pa-textarea" rows="4" placeholder="Tell us what needs attention..." maxlength="250"></textarea>

        <a asp-controller="Administrador" asp-action="RequestService" class="ob-btn ob-btn-primary" style="margin-top:20px;">
            Request now <i class="fas fa-chevron-right"></i>
        </a>
        <p class="pa-form-note">Full request workflow coming soon — this preview matches the mobile mockup layout.</p>
    </section>
</div>
