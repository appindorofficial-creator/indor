@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencyPlumbingStep1ViewModel
@{
    ViewData["Title"] = L["Emergency Plumbing"];
    Layout = "_PropertyAdminLayout";
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    ViewBag.InviteFlowTitle = L["Emergency Plumbing"].ToString();
    ViewBag.InviteFlowSubtitle = L["Fast plumbing help for occupied homes and Airbnb stays."].ToString();
    ViewBag.InviteFlowStep = Model.FlowStep <= 0 ? 1 : Model.FlowStep;
    ViewBag.InviteFlowSteps = new[] { L["Details"].ToString(), L["Access"].ToString(), L["Done"].ToString() };
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminInviteFlowHeader")

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="EmergencyPlumbingDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["What's the plumbing issue?"]</label>
            <div class="pa-chip-grid">
                @foreach (var item in new (string Value, string Label, string Icon)[]
                {
                    ("ActiveLeak", L["Active leak"], "fa-droplet"),
                    ("ClogBackup", L["Clog / backup"], "fa-toilet"),
                    ("NoHotWater", L["No hot water"], "fa-temperature-high"),
                    ("ToiletIssue", L["Toilet issue"], "fa-toilet"),
                    ("BurstPipe", L["Burst pipe"], "fa-circle-exclamation"),
                    ("NotDraining", L["Water not draining"], "fa-water")
                })
                {
                    <label class="pa-chip @(Model.IssueType == item.Value ? "is-selected" : null)">
                        <input type="radio" name="IssueType" value="@item.Value" @(Model.IssueType == item.Value ? "checked" : null) />
                        <i class="fas @item.Icon"></i>
                        <span>@L[item.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["Is water actively leaking right now?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.ActivelyLeaking == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="ActivelyLeaking" value="Yes" @(Model.ActivelyLeaking == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.ActivelyLeaking == "No" ? "is-selected" : null)">
                    <input type="radio" name="ActivelyLeaking" value="No" @(Model.ActivelyLeaking == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Are guests currently inside?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["How urgent is it?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var u in new[] { ("Normal", L["Normal"]), ("Urgent", L["Urgent"]), ("Emergency", L["Emergency"]) })
                {
                    <label class="pa-toggle-btn @(Model.Urgency == u.Item1 ? "is-selected" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        @if (u.Item1 == "Emergency") { <i class="fas fa-circle-exclamation"></i> }
                        @u.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Where is the problem?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var loc in new (string Value, string Label, string Icon)[]
                {
                    ("Kitchen", L["Kitchen"], "fa-kitchen-set"),
                    ("Bathroom", L["Bathroom"], "fa-sink"),
                    ("Laundry", L["Laundry"], "fa-shirt"),
                    ("WaterHeater", L["Water heater"], "fa-fire"),
                    ("MainLine", L["Main line"], "fa-grip-lines"),
                    ("Other", L["Other"], "fa-ellipsis")
                })
                {
                    <label class="pa-chip @(Model.ProblemLocation == loc.Value ? "is-selected" : null)">
                        <input type="radio" name="ProblemLocation" value="@loc.Value" @(Model.ProblemLocation == loc.Value ? "checked" : null) />
                        <i class="fas @loc.Icon"></i>
                        <span>@L[loc.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label>@L["Add quick details"]</label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" placeholder="@L["Describe what's happening..."]">@Model.QuickDetails</textarea>
        </div>

        <div class="pa-media-actions">
            <button type="button" class="pa-media-btn"><i class="fas fa-camera"></i> @L["Add photos"]</button>
            <button type="button" class="pa-media-btn"><i class="fas fa-microphone"></i> @L["Voice note"]</button>
        </div>

        <div class="pa-notify-banner pa-notify-banner--info">
            <i class="fas fa-circle-info"></i>
            <span>@L["Occupied guest stays are prioritized. We'll dispatch the closest available pro."]</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
