@model IndorMvcApp.ViewModels.PropertyAdministratorPestControlStep1ViewModel
@{
    ViewData["Title"] = L["Pest Control"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Pest Control"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what's happening so we can send the right pest control pro."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Schedule"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="PestControlDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-bug pa-q-icon pa-q-icon--green"></i> @L["What pest issue do you need help with?"]</label>
            <div class="pa-pc-options-grid">
                @foreach (var p in new[] { ("Ants", L["Ants"]), ("Roaches", L["Roaches"]), ("Rodents", L["Rodents"]), ("Termites", L["Termites"]), ("WaspsBees", L["Wasps / bees"]), ("Spiders", L["Spiders"]), ("Other", L["Other"]) })
                {
                    <label class="pa-chip @(Model.PestType == p.Item1 ? "is-selected" : null)">
                        <input type="radio" name="PestType" value="@p.Item1" @(Model.PestType == p.Item1 ? "checked" : null) />
                        <span>@p.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["Where are you seeing the issue?"]</label>
            <div class="pa-pc-options-grid">
                @foreach (var l in new[] { ("Kitchen", L["Kitchen"]), ("Bathroom", L["Bathroom"]), ("Bedroom", L["Bedroom"]), ("PatioExterior", L["Patio / exterior"]), ("Garage", L["Garage"]), ("WholeProperty", L["Whole property"]) })
                {
                    <label class="pa-chip @(Model.IssueLocation == l.Item1 ? "is-selected" : null)">
                        <input type="radio" name="IssueLocation" value="@l.Item1" @(Model.IssueLocation == l.Item1 ? "checked" : null) />
                        <span>@l.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["How urgent is it?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var u in new[] { ("Normal", L["Normal"]), ("Urgent", L["Urgent"]), ("Emergency", L["Emergency"]) })
                {
                    <label class="pa-chip @(Model.Urgency == u.Item1 ? "is-selected" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        <span>@u.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Are guests currently staying at the property?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsStaying == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsStaying" value="Yes" @(Model.GuestsStaying == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.GuestsStaying == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsStaying" value="No" @(Model.GuestsStaying == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Have you seen live pests today?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.LivePestsToday == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="LivePestsToday" value="Yes" @(Model.LivePestsToday == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.LivePestsToday == "No" ? "is-selected" : null)">
                    <input type="radio" name="LivePestsToday" value="No" @(Model.LivePestsToday == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-note-sticky pa-q-icon pa-q-icon--green"></i> @L["Add quick details"]</label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" id="pcDetails">@Model.QuickDetails</textarea>
            <small class="pa-char-count"><span id="pcDetailsCount">@Model.QuickDetails.Length</span> / 250</small>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-flow-back-link">@L["Back to services"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-pc-options-grid, .pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('pcDetails');
        var counter = document.getElementById('pcDetailsCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}
