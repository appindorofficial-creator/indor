@model IndorMvcApp.ViewModels.PropertyAdministratorBrokenWindowBoardUpStep1ViewModel
@{
    ViewData["Title"] = L["Broken Window / Board-Up"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    <section class="pa-flow-intro">
        <h1>@L["Broken Window / Board-Up"]</h1>
        <p>@L["Tell us what happened so we can secure the property fast."]</p>
    </section>

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="BrokenWindowDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["What needs help?"]</label>
            <div class="pa-chip-grid">
                @foreach (var item in new (string Value, string Label, string Icon)[]
                {
                    ("BrokenWindow", "Broken window", "fa-window-maximize"),
                    ("ShatteredGlass", "Shattered glass", "fa-glass-water"),
                    ("DoorGlass", "Door glass", "fa-door-open"),
                    ("BoardUpOnly", "Board-up only", "fa-hammer"),
                    ("ActiveBreakInDamage", "Active break-in damage", "fa-house-crack")
                })
                {
                    <label class="pa-chip @(Model.HelpType == item.Value ? "is-selected" : null)">
                        <input type="radio" name="HelpType" value="@item.Value" @(Model.HelpType == item.Value ? "checked" : null) />
                        <i class="fas @item.Icon"></i>
                        <span>@L[item.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["How urgent is it?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var u in new[] { ("Normal", L["Normal"]), ("Urgent", L["Urgent"]), ("Emergency", L["Emergency"]) })
                {
                    <label class="pa-toggle-btn @(Model.Urgency == u.Item1 ? "is-selected" : null) @(u.Item1 == "Emergency" ? "is-urgent" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        @if (u.Item1 == "Emergency") { <i class="fas fa-circle-exclamation"></i> }
                        @u.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Where is the damage?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var loc in new (string Value, string Label, string Icon)[]
                {
                    ("FrontWindow", "Front window", "fa-window-maximize"),
                    ("BackWindow", "Back window", "fa-window-restore"),
                    ("SlidingDoor", "Sliding door", "fa-door-open"),
                    ("BedroomWindow", "Bedroom window", "fa-bed"),
                    ("StorefrontOther", "Storefront / other", "fa-store")
                })
                {
                    <label class="pa-chip @(Model.DamageLocation == loc.Value ? "is-selected" : null)">
                        <input type="radio" name="DamageLocation" value="@loc.Value" @(Model.DamageLocation == loc.Value ? "checked" : null) />
                        <i class="fas @loc.Icon"></i>
                        <span>@L[loc.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Are guests currently inside?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) />
                    <i class="fas fa-users"></i> Yes
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) />
                    <i class="fas fa-user-slash"></i> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Is the opening exposed to weather or security risk?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.ExposedToRisk == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="ExposedToRisk" value="Yes" @(Model.ExposedToRisk == "Yes" ? "checked" : null) /> Yes
                </label>
                <label class="pa-toggle-btn @(Model.ExposedToRisk == "No" ? "is-selected" : null)">
                    <input type="radio" name="ExposedToRisk" value="No" @(Model.ExposedToRisk == "No" ? "checked" : null) /> No
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <label>@L["Additional details"] <small>@L["(optional)"]</small></label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" placeholder="@L["Describe what happened..."]">@Model.QuickDetails</textarea>
        </div>

        <div class="pa-media-actions">
            <button type="button" class="pa-media-btn"><i class="fas fa-camera"></i> @L["Add photos"]</button>
            <button type="button" class="pa-media-btn"><i class="fas fa-microphone"></i> @L["Voice note"]</button>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-back-link">@L["Back to services"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
