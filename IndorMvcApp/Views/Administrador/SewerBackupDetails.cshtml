@model IndorMvcApp.ViewModels.PropertyAdministratorEmergencySewerBackupStep1ViewModel
@{
    ViewData["Title"] = L["Sewer Backup Emergency"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Sewer Backup Emergency"].ToString();
    ViewBag.FlowSubtitle = L["Tell us what's happening so we can dispatch help fast."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Review"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("Services", "Administrador", new { propertyId = Model.ViewingProperty?.Id });
    var propertyId = Model.ViewingProperty?.Id ?? 0;
    var locations = Model.LocationsList.ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

    <form asp-action="SewerBackupDetails" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@propertyId" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label>@L["What's happening?"]</label>
            <div class="pa-chip-grid">
                @foreach (var item in new (string Value, string Label, string Icon)[]
                {
                    ("DrainBackingUp", L["Drain backing up"], "fa-arrow-up-from-ground-water"),
                    ("ToiletOverflow", L["Toilet overflow"], "fa-toilet"),
                    ("SewageSmell", L["Sewage smell"], "fa-wind"),
                    ("FloorDrainOverflow", L["Floor drain overflow"], "fa-grip-lines"),
                    ("MultipleFixtures", L["Multiple fixtures affected"], "fa-sink"),
                    ("Other", L["Other"], "fa-ellipsis")
                })
                {
                    <label class="pa-chip @(Model.IssueType == item.Value ? "is-selected" : null)">
                        <input type="radio" name="IssueType" value="@item.Value" @(Model.IssueType == item.Value ? "checked" : null) />
                        <i class="fas @item.Icon"></i>
                        <span>@L[item.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label>@L["Is sewage or dirty water coming back up now?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.SewageBackingUp == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="SewageBackingUp" value="Yes" @(Model.SewageBackingUp == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.SewageBackingUp == "No" ? "is-selected" : null)">
                    <input type="radio" name="SewageBackingUp" value="No" @(Model.SewageBackingUp == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label>@L["Are guests currently inside?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.GuestsInside == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="Yes" @(Model.GuestsInside == "Yes" ? "checked" : null) />
                    <i class="fas fa-users"></i> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.GuestsInside == "No" ? "is-selected" : null)">
                    <input type="radio" name="GuestsInside" value="No" @(Model.GuestsInside == "No" ? "checked" : null) />
                    <i class="fas fa-user-slash"></i> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["How urgent is it?"]</label>
            <div class="pa-toggle-pair pa-toggle-pair--3">
                @foreach (var u in new[] { ("Normal", L["Normal"]), ("Urgent", L["Urgent"]), ("Emergency", L["Emergency"]) })
                {
                    <label class="pa-toggle-btn @(Model.Urgency == u.Item1 ? "is-selected" : null) @(u.Item1 == "Emergency" ? "is-urgent" : null)">
                        <input type="radio" name="Urgency" value="@u.Item1" @(Model.Urgency == u.Item1 ? "checked" : null) />
                        @if (u.Item1 == "Emergency") { <i class="fas fa-circle-exclamation"></i> }
                        @u.Item2
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label>@L["Where is it happening?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var loc in new (string Value, string Label, string Icon)[]
                {
                    ("Bathroom", L["Bathroom"], "fa-sink"),
                    ("Kitchen", L["Kitchen"], "fa-kitchen-set"),
                    ("Laundry", L["Laundry"], "fa-shirt"),
                    ("Basement", L["Basement"], "fa-stairs"),
                    ("MainLine", L["Main line"], "fa-grip-lines"),
                    ("MultipleAreas", L["Multiple areas"], "fa-layer-group")
                })
                {
                    <label class="pa-chip @(locations.Contains(loc.Value) ? "is-selected" : null)">
                        <input type="checkbox" name="LocationsList" value="@loc.Value" @(locations.Contains(loc.Value) ? "checked" : null) />
                        <i class="fas @loc.Icon"></i>
                        <span>@L[loc.Label]</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label>@L["Add quick details"]</label>
            <textarea class="pa-textarea" name="QuickDetails" rows="3" maxlength="250" placeholder="@L["Describe what's happening..."]">@Model.QuickDetails</textarea>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-notify-banner pa-notify-banner--info">
            <i class="fas fa-shield-halved"></i>
            <span>@L["Occupied guest stays are prioritized. We'll dispatch the closest available sewer / drain pro."]</span>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Continue"]</button>
        <a href="@ViewBag.FlowBackUrl" class="pa-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-chip input, .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') {
                    this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
                    return;
                }
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                var parent = this.closest('.pa-chip, .pa-toggle-btn');
                if (parent) parent.classList.add('is-selected');
            });
        });
    </script>
}
