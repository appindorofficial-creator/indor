@model IndorMvcApp.ViewModels.PropertyAdministratorLandscapingStep2ViewModel
@{
    ViewData["Title"] = L["Landscaping details"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Landscaping details"].ToString();
    ViewBag.FlowSubtitle = L["Help us understand access, scope, and scheduling."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Scope"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("LandscapingDetails", "Administrador", new { propertyId = Model.PropertyId });
    var recipients = Model.UpdateRecipients.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)
@{
    ViewData["Title"] = L["Landscaping details"];
    Layout = "_PropertyAdminLayout";
    ViewBag.FlowStep = Model.FlowStep;
    ViewBag.FlowTotalSteps = Model.TotalSteps;
    ViewBag.FlowTitle = L["Landscaping details"].ToString();
    ViewBag.FlowSubtitle = L["Help us understand access, scope, and scheduling."].ToString();
    ViewBag.FlowSteps = new[] { L["Details"].ToString(), L["Scope"].ToString(), L["Done"].ToString() };
    ViewBag.FlowBackUrl = Url.Action("LandscapingDetails", "Administrador", new { propertyId = Model.PropertyId });
    var recipients = Model.UpdateRecipients.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<div class="pa-portal-shell pa-portal-shell--flow">
    @await Html.PartialAsync("_PropertyAdminFlowHeader", Model)

    

    @{
        ViewBag.AllowPropertySwitch = false;
        if (!string.IsNullOrWhiteSpace(Model.PropertyStatusLabel))
        {
            ViewBag.BadgeLabel = Model.PropertyStatusLabel;
        }
    }
    @await Html.PartialAsync("_PropertyAdminViewingStrip", Model.ViewingProperty)

<form asp-action="LandscapingScope" method="post" class="pa-emergency-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="PropertyId" value="@Model.PropertyId" />
        <input type="hidden" name="ServiceType" value="@Model.ServiceType" />
        <input type="hidden" name="WorkArea" value="@Model.WorkArea" />
        <input type="hidden" name="ServiceReason" value="@Model.ServiceReason" />
        <input type="hidden" name="Timeline" value="@Model.Timeline" />
        <input type="hidden" name="IsOccupied" value="@Model.IsOccupied" />
        <input type="hidden" name="QuickNotes" value="@Model.QuickNotes" />

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">1</span>
            <label><i class="fas fa-clipboard-list pa-q-icon pa-q-icon--green"></i> @L["What kind of visit do you need?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var v in new (string Value, string Label)[] {
                    ("QuoteWalkthrough", L["Quote / walkthrough"]),
                    ("OneTimeService", L["One-time service"]),
                    ("OngoingLandscaping", L["Ongoing landscaping"]) })
                {
                    <label class="pa-chip @(Model.VisitType == v.Value ? "is-selected" : null)">
                        <input type="radio" name="VisitType" value="@v.Value" @(Model.VisitType == v.Value ? "checked" : null) />
                        <span>@v.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">2</span>
            <label><i class="fas fa-seedling pa-q-icon pa-q-icon--green"></i> @L["Do you want us to provide plants/materials?"]</label>
            <div class="pa-toggle-pair">
                <label class="pa-toggle-btn @(Model.ProvideMaterials == "Yes" ? "is-selected" : null)">
                    <input type="radio" name="ProvideMaterials" value="Yes" @(Model.ProvideMaterials == "Yes" ? "checked" : null) /> @L["Yes"]
                </label>
                <label class="pa-toggle-btn @(Model.ProvideMaterials == "No" ? "is-selected" : null)">
                    <input type="radio" name="ProvideMaterials" value="No" @(Model.ProvideMaterials == "No" ? "checked" : null) /> @L["No"]
                </label>
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">3</span>
            <label><i class="fas fa-truck pa-q-icon pa-q-icon--green"></i> @L["Do you need haul away?"]</label>
            <div class="pa-lawn-service-row">
                @foreach (var h in new (string Value, string Label)[] {
                    ("RemoveDamagedPlants", L["Remove damaged plants"]),
                    ("RemoveTreeDebris", L["Remove tree debris"]),
                    ("RemoveOldMulch", L["Remove old mulch"]),
                    ("NoHaulAway", L["No haul away"]) })
                {
                    <label class="pa-lawn-option-card @(Model.HaulAwayType == h.Value ? "is-selected" : null)">
                        <input type="radio" name="HaulAwayType" value="@h.Value" @(Model.HaulAwayType == h.Value ? "checked" : null) />
                        <span class="pa-prev-service-check pa-prev-service-check--green"><i class="fas fa-check"></i></span>
                        <span>@h.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">4</span>
            <label>@L["Any irrigation or sprinkler lines in the area?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var i in new[] { ("Yes", L["Yes"]), ("No", L["No"]), ("NotSure", L["Not sure"]) })
                {
                    <label class="pa-chip @(Model.HasIrrigation == i.Item1 ? "is-selected" : null)">
                        <input type="radio" name="HasIrrigation" value="@i.Item1" @(Model.HasIrrigation == i.Item1 ? "checked" : null) />
                        <span>@i.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">5</span>
            <label><i class="fas fa-door-open pa-q-icon pa-q-icon--green"></i> @L["Can the crew access the yard?"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var a in new (string Value, string Label)[] {
                    ("UnlockedAccess", L["Unlocked access"]),
                    ("GateCode", L["Gate code"]),
                    ("MeetOnSite", L["Meet on-site"]) })
                {
                    <label class="pa-chip @(Model.YardAccess == a.Value ? "is-selected" : null)">
                        <input type="radio" name="YardAccess" value="@a.Value" @(Model.YardAccess == a.Value ? "checked" : null) />
                        <span>@a.Label</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">6</span>
            <label><i class="fas fa-calendar-day pa-q-icon pa-q-icon--green"></i> @L["Preferred date"]</label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var d in new[] { ("Tomorrow", L["Tomorrow"]), ("ThisWeek", L["This week"]), ("Flexible", L["Flexible"]) })
                {
                    <label class="pa-chip @(Model.PreferredDate == d.Item1 ? "is-selected" : null)">
                        <input type="radio" name="PreferredDate" value="@d.Item1" @(Model.PreferredDate == d.Item1 ? "checked" : null) />
                        <span>@d.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">7</span>
            <label><i class="fas fa-clock pa-q-icon pa-q-icon--green"></i> @L["Best time window"]</label>
            @await Html.PartialAsync("_PropertyAdminTimeSlotSelect", new PropertyAdministratorTimeSlotSelectViewModel
            {
                FieldName = "TimeWindow",
                SelectedValue = Model.TimeWindow
            })
        </div>

        <div class="pa-flow-question">
            <span class="pa-flow-qnum">8</span>
            <label><i class="fas fa-key pa-q-icon pa-q-icon--green"></i> @L["Access / project notes"]</label>
            <textarea class="pa-textarea" name="ProjectNotes" rows="3" maxlength="250" id="lsProjectNotes">@Model.ProjectNotes</textarea>
            <small class="pa-char-count"><span id="lsProjectNotesCount">@Model.ProjectNotes.Length</span> / 250</small>
        </div>
        @await Html.PartialAsync("_PropertyAdminMediaCapture")


        <div class="pa-flow-question">
            <span class="pa-flow-qnum">9</span>
            <label><i class="fas fa-users pa-q-icon pa-q-icon--green"></i> @L["Who should receive updates?"] <small>@L["(Select all that apply)"]</small></label>
            <div class="pa-chip-grid pa-chip-grid--3">
                @foreach (var r in new[] { ("Me", L["Me"]), ("Guest", L["Guest"]), ("CoHost", L["Co-host"]) })
                {
                    <label class="pa-chip @(recipients.Contains(r.Item1) ? "is-selected" : null)">
                        <input type="checkbox" name="UpdateRecipientsList" value="@r.Item1" @(recipients.Contains(r.Item1) ? "checked" : null) />
                        <span>@r.Item2</span>
                    </label>
                }
            </div>
        </div>

        <div class="pa-lawn-availability-banner">
            <div>
                <strong>@L["A landscaping pro can prepare a scope of work and estimate after the site review."]</strong>
                <small>@L["We'll confirm your consultation time and send updates as the request progresses."]</small>
            </div>
            <i class="fas fa-calendar-check"></i>
        </div>

        <button type="submit" class="ob-btn ob-btn-primary pa-flow-submit">@L["Review request"]</button>
        <a href="@ViewBag.FlowBackUrl" class="ob-btn ob-btn-outline pa-flow-edit">@L["Edit details"]</a>
        <a href="@Url.Action("Services", "Administrador", new { propertyId = Model.PropertyId })" class="pa-back-link">@L["Back to start"]</a>
    </form>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.pa-lawn-option-card input').forEach(function (input) {
            input.addEventListener('change', function () {
                var row = this.closest('.pa-lawn-service-row');
                if (row) {
                    row.querySelectorAll('.pa-lawn-option-card').forEach(function (el) { el.classList.remove('is-selected'); });
                }
                this.closest('.pa-lawn-option-card')?.classList.add('is-selected');
            });
        });
        document.querySelectorAll('.pa-chip input[type="checkbox"]').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.pa-chip')?.classList.toggle('is-selected', this.checked);
            });
        });
        document.querySelectorAll('.pa-chip input[type="radio"], .pa-toggle-btn input').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.type === 'checkbox') return;
                var group = this.closest('.pa-chip-grid, .pa-toggle-pair');
                if (!group) return;
                group.querySelectorAll('.pa-chip, .pa-toggle-btn').forEach(function (el) { el.classList.remove('is-selected'); });
                this.closest('.pa-chip, .pa-toggle-btn')?.classList.add('is-selected');
            });
        });
        var notes = document.getElementById('lsProjectNotes');
        var counter = document.getElementById('lsProjectNotesCount');
        if (notes && counter) {
            notes.addEventListener('input', function () { counter.textContent = this.value.length; });
        }
    </script>
}