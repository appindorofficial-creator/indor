@model IndorMvcApp.ViewModels.ExteriorPaintConfirmedViewModel
@{
    ViewData["Title"] = "Paint Review Requested - INDOR";
    ViewData["WizardTitle"] = Model.NombreServicio;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}


<div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Paint Review Requested</h1>
    </div>

    <div class="confirm-box">
        <i class="fas fa-circle-check"></i>
        <div>
            <strong>Your paint review was submitted!</strong>
            <p>Thanks! A home care pro will contact you soon to follow up.</p>
        </div>
    </div>

    @if (Model.WhyItMattersItems.Count > 0)
    {
        <div class="field-card">
            <div class="field-head"><i class="fas fa-lightbulb"></i><span>Why this matters</span></div>
            <div class="why-list">
                @foreach (var item in Model.WhyItMattersItems)
                {
                    <div class="item"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                }
            </div>
        </div>
    }

    @if (Model.NextStepsItems.Count > 0)
    {
        <div class="field-card">
            <div class="field-head"><i class="fas fa-list-check"></i><span>Your next steps</span></div>
            <div class="why-list">
                @foreach (var item in Model.NextStepsItems)
                {
                    <div class="item"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ReminderTexto))
    {
        <div class="reminder-box">
            <i class="fas fa-calendar-check"></i>
            <div>
                Exterior paint reminder saved
                <span class="sub">@Model.ReminderTexto</span>
            </div>
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn-primary">
        <i class="fas fa-house"></i> Back to Home Care Guide
    </a>

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-bell"></i> Set reminder
        </a>
    }
