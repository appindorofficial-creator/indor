@model IndorMvcApp.ViewModels.ExteriorPaintConditionViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("ExteriorPaintReview", "ExteriorPaint", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;

}


<div class="ep-title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.05rem;">@Model.PageTitle</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingSubtitulo))
            {
                <div class="tagline">@Model.LandingSubtitulo</div>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
        {
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.PageTitle" class="ep-thumb" />
        }
    </div>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="ep-condition-form" asp-action="ExteriorPaintCondition" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="ProblemasSeleccionados" id="ProblemasSeleccionados" />
        <input type="hidden" asp-for="AreasSeleccionadas" id="AreasSeleccionadas" />
        <input type="hidden" asp-for="ActualizacionColor" id="ActualizacionColor" />
        <input type="hidden" asp-for="LavadoPresionReciente" id="LavadoPresionReciente" />

        <div class="field-card">
            <div class="question-num">1</div>
            <div class="field-head"><i class="fas fa-eye"></i><span>@L["What issues do you notice?"]</span></div>
            <div class="issue-grid">
                <button type="button" class="issue-card" data-issue="PeelingFlaking"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-note-sticky main"></i><span class="label">@L["Peeling / flaking"]</span></button>
                <button type="button" class="issue-card" data-issue="Fading"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-sun main"></i><span class="label">@L["Fading"]</span></button>
                <button type="button" class="issue-card" data-issue="CrackedCaulk"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-spray-can main"></i><span class="label">@L["Cracked caulk"]</span></button>
                <button type="button" class="issue-card" data-issue="MildewStains"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle main"></i><span class="label">@L["Mildew / stains"]</span></button>
                <button type="button" class="issue-card" data-issue="WoodRot"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-tree main"></i><span class="label">@L["Wood rot"]</span></button>
                <button type="button" class="issue-card" data-issue="NoVisibleIssues"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-check main"></i><span class="label">@L["No visible issues"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="question-num">2</div>
            <div class="field-head"><i class="fas fa-house"></i><span>@L["Which areas need attention?"]</span></div>
            <div class="issue-grid">
                <button type="button" class="issue-card" data-area="FullExterior"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-house main"></i><span class="label">@L["Full exterior"]</span></button>
                <button type="button" class="issue-card" data-area="TrimFascia"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-border-top-left main"></i><span class="label">@L["Trim & fascia"]</span></button>
                <button type="button" class="issue-card" data-area="DoorsShutters"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-door-closed main"></i><span class="label">@L["Doors / shutters"]</span></button>
                <button type="button" class="issue-card" data-area="GarageDoor"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-warehouse main"></i><span class="label">@L["Garage door"]</span></button>
                <button type="button" class="issue-card" data-area="PorchRails"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-grip-lines main"></i><span class="label">@L["Porch / rails"]</span></button>
                <button type="button" class="issue-card" data-area="TouchUpOnly"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-paintbrush main"></i><span class="label">@L["Touch-up only"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="question-num">3</div>
            <div class="field-head"><i class="fas fa-palette"></i><span>@L["Do you want a color update?"]</span></div>
            <button type="button" class="color-update-card" data-color-update="Yes">
                <span class="radio"></span>
                <strong><i class="fas fa-palette"></i> @L["Yes"]</strong>
                <span>@L["Explore a new look"]</span>
            </button>
            <button type="button" class="color-update-card" data-color-update="No">
                <span class="radio"></span>
                <strong><i class="fas fa-paint-roller"></i> @L["No"]</strong>
                <span>@L["Keep current colors"]</span>
            </button>
        </div>

        <div class="field-card">
            <div class="question-num">4</div>
            <div class="field-head"><i class="fas fa-spray-can-sparkles"></i><span>@L["Was the exterior power washed recently?"]</span></div>
            <div class="choice-grid-3">
                <button type="button" class="choice-card" data-wash="Yes"><i class="fas fa-droplet main"></i><span class="label">@L["Yes"]</span></button>
                <button type="button" class="choice-card" data-wash="No"><i class="fas fa-xmark main"></i><span class="label">@L["No"]</span></button>
                <button type="button" class="choice-card" data-wash="NotSure"><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            Continue <i class="fas fa-chevron-right"></i>
        </button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        var issuesInput = document.getElementById('ProblemasSeleccionados');
        var areasInput = document.getElementById('AreasSeleccionadas');
        var colorInput = document.getElementById('ActualizacionColor');
        var washInput = document.getElementById('LavadoPresionReciente');

        function getValues(input) {
            return input.value ? input.value.split('|').filter(Boolean) : [];
        }

        function setValues(input, values) {
            input.value = values.join('|');
        }

        function bindMulti(groupSelector, attr, input, exclusiveCode) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var code = btn.getAttribute(attr);
                    var current = getValues(input);
                    if (exclusiveCode && code === exclusiveCode) {
                        document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                        btn.classList.add('active');
                        setValues(input, [exclusiveCode]);
                        return;
                    }
                    current = current.filter(function (v) { return v !== exclusiveCode; });
                    if (current.indexOf(code) >= 0) {
                        current = current.filter(function (v) { return v !== code; });
                        btn.classList.remove('active');
                    } else {
                        current.push(code);
                        btn.classList.add('active');
                    }
                    setValues(input, current);
                    if (exclusiveCode) {
                        document.querySelectorAll(groupSelector + '[data-' + attr.replace('data-', '') + '="' + exclusiveCode + '"]').forEach(function (b) {
                            b.classList.toggle('active', current.indexOf(exclusiveCode) >= 0);
                        });
                    }
                });
                if (getValues(input).indexOf(btn.getAttribute(attr)) >= 0) btn.classList.add('active');
            });
        }

        bindMulti('[data-issue]', 'data-issue', issuesInput, 'NoVisibleIssues');
        bindMulti('[data-area]', 'data-area', areasInput, null);

        document.querySelectorAll('[data-color-update]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-color-update]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                colorInput.value = btn.getAttribute('data-color-update');
            });
            if (btn.getAttribute('data-color-update') === colorInput.value) btn.classList.add('active');
        });

        document.querySelectorAll('[data-wash]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-wash]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                washInput.value = btn.getAttribute('data-wash');
            });
            if (btn.getAttribute('data-wash') === washInput.value) btn.classList.add('active');
        });

        var form = document.getElementById('ep-condition-form');
        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') return;

            var missing = [];
            if (!getValues(issuesInput).length) missing.push('Select at least one issue you\'ve noticed.');
            if (!getValues(areasInput).length) missing.push('Select at least one area that needs attention.');
            if (!colorInput.value || !colorInput.value.trim()) missing.push('Select whether you want a color update.');
            if (!washInput.value || !washInput.value.trim()) missing.push('Select whether the exterior was power washed recently.');

            if (missing.length) {
                e.preventDefault();
                alert(missing[0]);
            }
        });
    })();

</script>
}
