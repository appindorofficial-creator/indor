@model IndorMvcApp.ViewModels.MovingConfirmedViewModel
@{
    ViewData["Title"] = L["Booking Confirmed - INDOR"];
    ViewData["WizardTitle"] = L["Booking Confirmed"];
}

<div class="cl-success-wrap">
    <div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading">@L["Booking Confirmed"]</h1>
    <p class="page-lead">@L["Your moving service has been requested. We'll take it from here!"]</p>
</div>

<div class="summary-card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div style="display:flex;align-items:center;gap:10px;font-weight:800;">
            <i class="fas fa-truck-ramp-box" style="color:#0066CC;"></i>
            @Model.NombreServicio
        </div>
        <span class="status-badge">@L[Model.EstadoLabel]</span>
    </div>
    <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">@L["Move type"]</div><div class="summary-value">@Model.TipoMovimientoLabel</div></div></div>
    <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Date"]</div><div class="summary-value">@Model.FechaMovimientoLabel</div></div></div>
    <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Time window"]</div><div class="summary-value">@Model.VentanaHorarioLabel</div></div></div>
    <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-label">@L["From"]</div><div class="summary-value">@Model.DireccionOrigen</div></div></div>
    <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-label">@L["To"]</div><div class="summary-value">@Model.DireccionDestino</div></div></div>
    <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">@L["Status"]</div><div class="summary-value" style="color:#16A34A;">@L[Model.EstadoLabel]</div></div></div>
</div>

<div class="info-banner">
    <i class="fas fa-circle-info"></i>
    <span>@L["Your provider will review the move details and contact you before arrival."]</span>
</div>

<div class="cl-form-actions">
    <a asp-action="MovingReview" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-file-lines"></i> @L["View request"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-calendar"></i> @L["Go to Schedule"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Back to Home"] <i class="fas fa-chevron-right"></i></a>
</div>
