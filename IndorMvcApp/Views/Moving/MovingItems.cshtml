@model IndorMvcApp.ViewModels.MovingItemsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_MovingStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="MovingDetails" asp-route-id="@Model.SolicitudId" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_MovingStepper", 2)

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="MovingItems" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="ItemsMover" id="ItemsMover" />
        <input type="hidden" asp-for="TamanoMovimiento" id="TamanoMovimiento" />
        <input type="hidden" asp-for="CondicionesAcceso" id="CondicionesAcceso" />
        <input type="hidden" asp-for="RequiereMontaje" id="RequiereMontaje" />

        <div class="field-card">
            <span class="field-label">What needs to be moved?</span>
            <div class="tile-grid" id="itemsGroup">
                <button type="button" class="tile-btn" data-value="Sofa"><i class="fas fa-couch"></i>Sofa</button>
                <button type="button" class="tile-btn" data-value="Bed"><i class="fas fa-bed"></i>Bed</button>
                <button type="button" class="tile-btn" data-value="Mattress"><i class="fas fa-mattress-pillow"></i>Mattress</button>
                <button type="button" class="tile-btn" data-value="DiningTable"><i class="fas fa-utensils"></i>Dining table</button>
                <button type="button" class="tile-btn" data-value="Appliances"><i class="fas fa-blender"></i>Appliances</button>
                <button type="button" class="tile-btn" data-value="Boxes"><i class="fas fa-box"></i>Boxes</button>
                <button type="button" class="tile-btn" data-value="OfficeDesk"><i class="fas fa-desktop"></i>Office desk</button>
                <button type="button" class="tile-btn" data-value="Other"><i class="fas fa-ellipsis"></i>Other</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What's the size of your move?</span>
            <div class="tile-grid" data-target="TamanoMovimiento">
                <button type="button" class="tile-btn" data-value="FewItems"><i class="fas fa-box"></i>Few items<span class="sub">Just a few</span></button>
                <button type="button" class="tile-btn" data-value="Studio"><i class="fas fa-bed"></i>Studio<span class="sub">Small space</span></button>
                <button type="button" class="tile-btn" data-value="OneTwoBedroom"><i class="fas fa-door-open"></i>1-2 Bedroom<span class="sub">Medium home</span></button>
                <button type="button" class="tile-btn" data-value="ThreePlusBedroom"><i class="fas fa-house-user"></i>3+ Bedroom<span class="sub">Large home</span></button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">What are the access conditions?</span>
            <div class="chip-row" id="accessGroup" style="flex-wrap:wrap;">
                <button type="button" class="chip-btn" data-value="Stairs"><i class="fas fa-stairs"></i> Stairs</button>
                <button type="button" class="chip-btn" data-value="Elevator"><i class="fas fa-elevator"></i> Elevator</button>
                <button type="button" class="chip-btn" data-value="LongWalk"><i class="fas fa-person-walking"></i> Long walk</button>
                <button type="button" class="chip-btn" data-value="TightHallway"><i class="fas fa-arrows-left-right"></i> Tight hallway</button>
                <button type="button" class="chip-btn" data-value="ParkingIssue"><i class="fas fa-square-parking"></i> Parking issue</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Need assembly or disassembly?</span>
            <div class="tile-grid" style="grid-template-columns:1fr 1fr;" data-target="RequiereMontaje">
                <button type="button" class="tile-btn" data-value="Yes"><i class="fas fa-screwdriver-wrench"></i>Yes</button>
                <button type="button" class="tile-btn" data-value="No"><i class="fas fa-ban"></i>No</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Add photos or notes (optional)</span>
            <div class="upload-zone">
                <i class="fas fa-camera"></i>
                <p><strong>Upload photos</strong><br/>JPG, PNG up to 10MB</p>
                <input type="file" name="files" accept=".jpg,.jpeg,.png" multiple style="margin-top:10px;width:100%;" />
            </div>
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <p style="font-size:0.78rem;color:#64748B;margin-bottom:8px;">Uploaded files:</p>
                @foreach (var file in Model.ArchivosExistentes)
                {
                    <div class="included-row"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
                }
            }
            <div class="input-wrap" style="margin-top:10px;">
                <i class="fas fa-note-sticky"></i>
                <textarea asp-for="NotaCorta" rows="3" placeholder="Add notes"></textarea>
            </div>
        </div>

        <button type="submit" class="btn-primary">Continue <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>
</div>
<script>
    (function () {
        function initSingleTiles(containerSelector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const container = document.querySelector(containerSelector);
            if (!container || !hidden) return;
            const buttons = container.querySelectorAll('.tile-btn');
            function setActive(value) {
                hidden.value = value;
                buttons.forEach(b => b.classList.toggle('active', b.dataset.value === value));
            }
            buttons.forEach(btn => btn.addEventListener('click', () => setActive(btn.dataset.value)));
            setActive(initial || hidden.value || buttons[0]?.dataset.value);
        }

        initSingleTiles('[data-target="TamanoMovimiento"]', 'TamanoMovimiento', '@Model.TamanoMovimiento');
        initSingleTiles('[data-target="RequiereMontaje"]', 'RequiereMontaje', '@Model.RequiereMontaje');

        const itemsHidden = document.getElementById('ItemsMover');
        const selected = new Set((itemsHidden.value || '').split('|').filter(Boolean));
        document.querySelectorAll('#itemsGroup .tile-btn').forEach(btn => {
            if (selected.has(btn.dataset.value)) btn.classList.add('active');
            btn.addEventListener('click', () => {
                const value = btn.dataset.value;
                if (selected.has(value)) { selected.delete(value); btn.classList.remove('active'); }
                else { selected.add(value); btn.classList.add('active'); }
                itemsHidden.value = Array.from(selected).join('|');
            });
        });

        const accessHidden = document.getElementById('CondicionesAcceso');
        const accessSelected = new Set((accessHidden.value || '').split('|').filter(Boolean));
        document.querySelectorAll('#accessGroup .chip-btn').forEach(btn => {
            if (accessSelected.has(btn.dataset.value)) btn.classList.add('active');
            btn.addEventListener('click', () => {
                const value = btn.dataset.value;
                if (accessSelected.has(value)) { accessSelected.delete(value); btn.classList.remove('active'); }
                else { accessSelected.add(value); btn.classList.add('active'); }
                accessHidden.value = Array.from(accessSelected).join('|');
            });
        });
    })();
</script>
</body>
</html>
