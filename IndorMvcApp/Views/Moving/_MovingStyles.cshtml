<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; min-height: 100vh; padding: 20px 16px 32px; color: #0A2540; }
    .page-container { max-width: 520px; margin: 0 auto; }
    .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .back-btn { width: 44px; height: 44px; border-radius: 50%; background: #FFF; border: 1.5px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #0A2540; text-decoration: none; }
    .page-title { font-size: 1.05rem; font-weight: 800; text-align: center; flex: 1; }
    .hero-img { width: 100%; height: 160px; object-fit: cover; border-radius: 16px; margin-bottom: 16px; }
    .page-heading { font-size: 1.45rem; font-weight: 800; margin-bottom: 8px; }
    .page-lead { font-size: 0.9rem; color: #64748B; line-height: 1.5; margin-bottom: 18px; }
    .chip-row { display: flex; gap: 8px; overflow-x: auto; margin-bottom: 18px; padding-bottom: 4px; }
    .chip-btn { flex-shrink: 0; border: 1.5px solid #E5E7EB; background: #FFF; border-radius: 999px; padding: 10px 16px; font-weight: 600; font-size: 0.82rem; color: #64748B; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
    .chip-btn i { font-size: 0.95rem; }
    .chip-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .field-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(229,231,235,0.9); min-width: 0; overflow: hidden; }
    .field-label { font-size: 0.92rem; font-weight: 700; margin-bottom: 12px; display: block; }
    .included-row { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid #F1F5F9; font-size: 0.88rem; font-weight: 600; }
    .included-row:last-child { border-bottom: none; }
    .included-row i { color: #0066CC; width: 20px; text-align: center; }
    .info-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 18px; }
    .info-card { background: #FFF; border: 1px solid #E5E7EB; border-radius: 14px; padding: 14px; }
    .info-card i { color: #0066CC; margin-bottom: 8px; }
    .info-card .label { font-size: 0.72rem; color: #94A3B8; font-weight: 600; margin-bottom: 4px; }
    .info-card .value { font-size: 0.88rem; font-weight: 700; margin-bottom: 4px; }
    .info-card .note { font-size: 0.72rem; color: #64748B; }
    .tile-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; width: 100%; max-width: 100%; min-width: 0; }
    .tile-grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .tile-btn { border: 1.5px solid #E5E7EB; background: #F9FAFB; border-radius: 12px; padding: 12px 4px; font-weight: 600; font-size: 0.72rem; color: #64748B; cursor: pointer; text-align: center; line-height: 1.3; min-width: 0; width: 100%; max-width: 100%; box-sizing: border-box; overflow-wrap: anywhere; word-break: break-word; }
    .tile-btn i { display: block; font-size: 1rem; margin-bottom: 6px; color: #94A3B8; }
    .tile-btn.active { border-color: #0066CC; color: #0066CC; background: rgba(0,102,204,0.08); }
    .tile-btn.active i { color: #0066CC; }
    .tile-btn .sub { display: block; font-size: 0.65rem; font-weight: 500; color: #94A3B8; margin-top: 4px; }
    .tile-btn.active .sub { color: #64748B; }
    @@media (max-width: 480px) {
        .tile-grid-4 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
    .input-field label { display: block; font-size: 0.78rem; font-weight: 600; color: #64748B; margin-bottom: 6px; }
    .input-wrap { display: flex; align-items: center; gap: 8px; border: 1.5px solid #E5E7EB; border-radius: 12px; padding: 12px 14px; background: #FFF; }
    .input-wrap i { color: #0066CC; }
    .input-wrap input, .input-wrap select, .input-wrap textarea { border: none; background: transparent; width: 100%; font-family: inherit; font-size: 0.88rem; font-weight: 500; color: #0A2540; }
    .service-block { border: 1.5px solid #E5E7EB; border-radius: 14px; padding: 14px; margin-bottom: 10px; cursor: pointer; background: #F9FAFB; }
    .service-block.active { border-color: #0066CC; background: rgba(0,102,204,0.06); }
    .service-block strong { display: block; font-size: 0.92rem; margin-bottom: 4px; }
    .service-block span { font-size: 0.78rem; color: #64748B; }
    .summary-card { background: #FFF; border-radius: 16px; padding: 16px; margin-bottom: 16px; border: 1px solid rgba(229,231,235,0.9); }
    .summary-row { display: flex; align-items: flex-start; gap: 12px; padding: 10px 0; border-bottom: 1px solid #F1F5F9; }
    .summary-row:last-child { border-bottom: none; }
    .summary-row i { color: #0066CC; width: 18px; margin-top: 2px; text-align: center; }
    .summary-label { font-size: 0.72rem; color: #94A3B8; font-weight: 600; margin-bottom: 2px; }
    .summary-value { font-size: 0.88rem; font-weight: 600; line-height: 1.4; }
    .estimate-card { background: rgba(0,102,204,0.08); border: 1px solid rgba(0,102,204,0.15); border-radius: 16px; padding: 16px; margin-bottom: 14px; }
    .estimate-card .range { font-size: 1.2rem; font-weight: 800; margin-bottom: 6px; }
    .estimate-badges { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .estimate-badge { background: #FFF; border-radius: 999px; padding: 6px 10px; font-size: 0.68rem; font-weight: 700; color: #0066CC; }
    .disclaimer { font-size: 0.72rem; color: #94A3B8; line-height: 1.4; margin-bottom: 16px; }
    .upload-zone { border: 2px dashed #CBD5E1; border-radius: 14px; padding: 18px; text-align: center; margin-bottom: 12px; background: rgba(248,250,252,0.8); }
    .upload-zone i { color: #0066CC; font-size: 1.4rem; margin-bottom: 8px; }
    .upload-zone p { font-size: 0.82rem; color: #64748B; }
    .photo-hint { font-size: 0.74rem; color: #64748B; margin-bottom: 10px; line-height: 1.4; }
    .photo-upload-slot { position: relative; }
    .photo-upload {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        border: 1.5px dashed #CBD5E1; border-radius: 14px; padding: 18px; text-align: center;
        color: #64748B; background: #FFF; cursor: pointer; min-height: 96px;
        touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .photo-upload i { color: #0066CC; font-size: 1.2rem; margin-bottom: 8px; pointer-events: none; }
    .photo-upload p { font-size: 0.72rem; color: #64748B; margin: 0; line-height: 1.35; pointer-events: none; }
    .photo-upload strong { pointer-events: none; }
    .photo-upload.has-files { border-color: #0066CC; background: rgba(0,102,204,0.06); }
    .photo-input-hidden { display: none; }
    .photo-selected-list, .photo-attached-list { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
    .photo-selected-item {
        display: flex; align-items: center; gap: 8px; font-size: 0.78rem; color: #0A2540;
        background: #F8FAFC; border: 1px solid #E5E7EB; border-radius: 10px; padding: 8px 10px;
    }
    .photo-selected-item i { color: #0066CC; flex-shrink: 0; }
    .photo-selected-item span { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .photo-preview-thumb { width: 40px; height: 40px; border-radius: 8px; object-fit: cover; flex-shrink: 0; }
    .photo-remove-btn {
        margin-left: auto; width: 30px; height: 30px; border-radius: 50%; border: none;
        background: #FEE2E2; color: #DC2626; cursor: pointer; flex-shrink: 0;
        display: inline-flex; align-items: center; justify-content: center; font-size: 0.78rem;
        touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .photo-remove-btn:active { background: #FECACA; }
    .btn-primary, .btn-outline { width: 100%; padding: 15px 22px; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; }
    .btn-primary { border: none; background: linear-gradient(135deg, #0066CC, #004FA3); color: #FFF; margin-top: 8px; }
    .btn-outline { margin-top: 10px; border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; }
    .success-icon { width: 88px; height: 88px; border-radius: 50%; margin: 0 auto 18px; background: rgba(34,197,94,0.15); color: #16A34A; display: flex; align-items: center; justify-content: center; font-size: 2.4rem; }
    .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; background: rgba(34,197,94,0.12); color: #15803D; font-size: 0.72rem; font-weight: 700; }
    .info-banner { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); border-radius: 14px; padding: 14px 16px; display: flex; gap: 10px; margin-bottom: 18px; font-size: 0.86rem; line-height: 1.45; }
    .info-banner i { color: #16A34A; margin-top: 2px; flex-shrink: 0; }
    .field-error {
        display: block;
        margin-top: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #DC2626;
    }
    .validation-summary.validation-summary-errors { background: rgba(220,38,38,0.08); border: 1px solid rgba(220,38,38,0.2); border-radius: 12px; padding: 12px; margin-bottom: 14px; color: #B91C1C; font-size: 0.85rem; }
    .validation-summary.validation-summary-valid { display: none; }
</style>
