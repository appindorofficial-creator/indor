@model IndorMvcApp.ViewModels.MovingDetailsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;
    ViewData["WizardBackUrl"] = Url.Action("MovingService", "Moving", new { id = Model.MovingSetupServicioId });
}

<div class="cl-wizard-heading">
    <h2>Tell us about your move</h2>
</div>

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

<form asp-action="MovingDetails" method="post" novalidate id="movingDetailsForm" class="iw-step-form">        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="TipoMovimiento" id="TipoMovimiento" />
        <input type="hidden" asp-for="TipoPropiedad" id="TipoPropiedad" />
        <input type="hidden" asp-for="TamanoHogar" id="TamanoHogar" />
        <input type="hidden" asp-for="TipoServicio" id="TipoServicio" />
        <input type="hidden" asp-for="VentanaHorario" id="VentanaHorario" />

        <div class="field-card">
            <span class="field-label">Move type</span>
            <div class="tile-grid" data-target="TipoMovimiento">
                <button type="button" class="tile-btn" data-value="MoveIn"><i class="fas fa-house-circle-check"></i>Move-In</button>
                <button type="button" class="tile-btn" data-value="MoveOut"><i class="fas fa-house-circle-xmark"></i>Move-Out</button>
                <button type="button" class="tile-btn" data-value="FullMove"><i class="fas fa-truck-moving"></i>Full Move</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Property type</span>
            <div class="tile-grid tile-grid-4" data-target="TipoPropiedad">
                <button type="button" class="tile-btn" data-value="Apartment"><i class="fas fa-building"></i>Apartment</button>
                <button type="button" class="tile-btn" data-value="House"><i class="fas fa-house"></i>House</button>
                <button type="button" class="tile-btn" data-value="Condo"><i class="fas fa-city"></i>Condo</button>
                <button type="button" class="tile-btn" data-value="Townhome"><i class="fas fa-house-chimney"></i>Townhome</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Home size</span>
            <div class="tile-grid" data-target="TamanoHogar">
                <button type="button" class="tile-btn" data-value="Studio"><i class="fas fa-bed"></i>Studio</button>
                <button type="button" class="tile-btn" data-value="OneTwoBedrooms"><i class="fas fa-door-open"></i>1-2 Bedrooms</button>
                <button type="button" class="tile-btn" data-value="ThreePlusBedrooms"><i class="fas fa-house-user"></i>3+ Bedrooms</button>
            </div>
        </div>

        <div class="input-row">
            <div class="input-field">
                <label>From</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionOrigen" placeholder="Pick up address" data-address-autocomplete autocomplete="off" />
                </div>
                <span asp-validation-for="DireccionOrigen" class="field-error"></span>
            </div>
            <div class="input-field">
                <label>To</label>
                <div class="input-wrap">
                    <i class="fas fa-location-dot"></i>
                    <input asp-for="DireccionDestino" placeholder="Drop off address" data-address-autocomplete autocomplete="off" />
                </div>
                <span asp-validation-for="DireccionDestino" class="field-error"></span>
            </div>
        </div>

        <div class="input-row">
            <div class="input-field">
                <label>Move date</label>
                <div class="input-wrap">
                    <i class="fas fa-calendar"></i>
                    <input asp-for="FechaMovimiento" type="date" />
                </div>
                <span asp-validation-for="FechaMovimiento" class="field-error"></span>
            </div>
            <div class="input-field">
                <label>Preferred arrival time</label>
                <div class="input-wrap">
                    <i class="fas fa-clock"></i>
                    <select id="VentanaHorarioSelect">
                        <option value="Morning">9:00 AM – 11:00 AM</option>
                        <option value="MidMorning">11:00 AM – 1:00 PM</option>
                        <option value="Afternoon">2:00 PM – 4:00 PM</option>
                        <option value="Evening">4:00 PM – 6:00 PM</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Service type</span>
            <div class="service-block" data-target="TipoServicio" data-value="MoversOnly">
                <strong>Movers only</strong>
                <span>You provide the truck.</span>
            </div>
            <div class="service-block" data-target="TipoServicio" data-value="TruckAndMovers">
                <strong>Truck + Movers</strong>
                <span>We bring the truck.</span>
            </div>
        </div>

        <div class="cl-form-actions">
            <button type="submit" class="btn-primary">Continue <i class="fas fa-chevron-right"></i></button>
            <button type="submit" name="action" value="back" class="btn-outline">Back</button>
        </div>
    </form>

@section Scripts {
<script>    (function () {
        function initTiles(containerSelector, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const container = document.querySelector(containerSelector);
            if (!container || !hidden) return;
            const buttons = container.querySelectorAll('.tile-btn');
            function setActive(value) {
                hidden.value = value;
                buttons.forEach(b => b.classList.toggle('active', b.dataset.value === value));
            }
            buttons.forEach(btn => btn.addEventListener('click', () => setActive(btn.dataset.value)));
            setActive(initial || hidden.value || buttons[0]?.dataset.value);
        }

        initTiles('[data-target="TipoMovimiento"]', 'TipoMovimiento', '@Model.TipoMovimiento');
        initTiles('[data-target="TipoPropiedad"]', 'TipoPropiedad', '@Model.TipoPropiedad');
        initTiles('[data-target="TamanoHogar"]', 'TamanoHogar', '@Model.TamanoHogar');

        const serviceHidden = document.getElementById('TipoServicio');
        document.querySelectorAll('.service-block').forEach(block => {
            block.addEventListener('click', () => {
                document.querySelectorAll('.service-block').forEach(b => b.classList.remove('active'));
                block.classList.add('active');
                serviceHidden.value = block.dataset.value;
            });
            if (block.dataset.value === serviceHidden.value) block.classList.add('active');
        });

        const timeHidden = document.getElementById('VentanaHorario');
        const timeSelect = document.getElementById('VentanaHorarioSelect');
        timeSelect.value = timeHidden.value || 'Morning';
        timeSelect.addEventListener('change', () => timeHidden.value = timeSelect.value);

        const form = document.getElementById('movingDetailsForm');
        const addressMessage = 'Please enter a valid street address (e.g. 123 Main St, Charlotte, NC).';
        const requiredFields = [
            { id: 'DireccionOrigen', message: 'Please enter the pick-up address.', validateAddress: true },
            { id: 'DireccionDestino', message: 'Please enter the drop-off address.', validateAddress: true },
            { name: 'FechaMovimiento', message: 'Please select a move date.' }
        ];

        function isValidStreetAddress(value) {
            const address = String(value || '').trim();
            if (address.length < 5) return false;
            if (!/\p{L}/u.test(address)) return false;
            if (/^[\d\s.,#-]+$/.test(address)) return false;
            const tokens = address.split(/\s+/).filter(Boolean);
            const hasDigit = /\d/.test(address);
            const wordParts = tokens.filter(part => /\p{L}/u.test(part)).length;
            if (!hasDigit || wordParts < 2) return false;
            // Require a city/state hint: a comma separator or a 5-digit ZIP that is
            // not the leading street number (so a bare street line is rejected).
            const hasComma = address.includes(',');
            const hasZip = tokens.slice(1).some(t => /^\d{5}(-\d{4})?$/.test(t.replace(/[.,]+$/, '')));
            return hasComma || hasZip;
        }

        function fieldValidity(field, input) {
            const empty = !input.value || !String(input.value).trim();
            if (empty) return field.message;
            if (field.validateAddress && !isValidStreetAddress(input.value)) return addressMessage;
            return '';
        }

        requiredFields.forEach(field => {
            const input = field.id
                ? document.getElementById(field.id)
                : document.querySelector(`[name="${field.name}"]`);
            if (!input) return;
            input.addEventListener('input', () => input.setCustomValidity(fieldValidity(field, input)));
        });

        form.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') {
                return;
            }

            let firstInvalid = null;
            requiredFields.forEach(field => {
                const input = field.id
                    ? document.getElementById(field.id)
                    : document.querySelector(`[name="${field.name}"]`);
                if (!input) return;

                const message = fieldValidity(field, input);
                input.setCustomValidity(message);
                if (message && !firstInvalid) {
                    firstInvalid = input;
                }
            });

            if (firstInvalid) {
                e.preventDefault();
                firstInvalid.reportValidity();
            }
        });
    })();
</script>
@await Html.PartialAsync("_AddressAutocompleteScripts")
}