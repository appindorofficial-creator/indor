@model IndorMvcApp.ViewModels.MovingServiceViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("Index", "MovingSetup");
}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
{
    <img src="@Model.ImagenUrl" alt="@L.Catalog(Model.LandingTitulo)" class="cl-landing-hero" />
}

<h1 class="page-heading">@L.Catalog(Model.LandingTitulo)</h1>
<p class="page-lead">@L.Catalog(Model.LandingSubtitulo)</p>

<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

<form asp-action="MovingService" method="post">
    <input type="hidden" asp-for="MovingSetupServicioId" />
    <input type="hidden" asp-for="SolicitudId" />
    <input type="hidden" asp-for="NombreServicio" />
    <input type="hidden" asp-for="PageTitle" />
    <input type="hidden" asp-for="LandingTitulo" />
    <input type="hidden" asp-for="LandingSubtitulo" />
    <input type="hidden" asp-for="ImagenUrl" />
    <input type="hidden" asp-for="EstimatedTimeLabel" />
    <input type="hidden" asp-for="EstimatedTimeValue" />
    <input type="hidden" asp-for="EstimatedTimeNote" />
    <input type="hidden" asp-for="BestForLabel" />
    <input type="hidden" asp-for="BestForValue" />
    <input type="hidden" asp-for="BestForNote" />
    <input type="hidden" asp-for="CtaContinueTexto" />
    <input type="hidden" asp-for="CtaEstimateTexto" />
    <input type="hidden" asp-for="TipoMovimiento" id="TipoMovimiento" />

    <div class="field-card" data-svc-required="TipoMovimiento">
        <span class="field-label">@L["Move type"]</span>
        <div class="chip-row" id="moveTypeGroup">
            @foreach (var moveType in Model.MoveTypes)
            {
                <button type="button" class="chip-btn @(moveType.Value == Model.TipoMovimiento ? "active" : "")" data-value="@moveType.Value">
                    <i class="fas @moveType.Icon"></i> @L.Catalog(moveType.Label)
                </button>
            }
        </div>
    </div>

    @if (Model.IncludedItems.Count > 0)
    {
        <div class="field-card" data-svc-optional>
            <span class="field-label">@L["What's included"]</span>
            @foreach (var item in Model.IncludedItems)
            {
                <div class="included-row">
                    <i class="fas @item.Icon"></i>
                    <span>@L.Catalog(item.Text)</span>
                </div>
            }
        </div>
    }

    <div class="info-cards">
        <div class="info-card">
            <i class="fas fa-clock"></i>
            <div class="label">@L.Catalog(Model.EstimatedTimeLabel)</div>
            <div class="value">@L.Catalog(Model.EstimatedTimeValue)</div>
            @if (!string.IsNullOrWhiteSpace(Model.EstimatedTimeNote))
            {
                <div class="note">@L.Catalog(Model.EstimatedTimeNote)</div>
            }
        </div>
        <div class="info-card">
            <i class="fas fa-house"></i>
            <div class="label">@L.Catalog(Model.BestForLabel)</div>
            <div class="value">@L.Catalog(Model.BestForValue)</div>
            @if (!string.IsNullOrWhiteSpace(Model.BestForNote))
            {
                <div class="note">@L.Catalog(Model.BestForNote)</div>
            }
        </div>
    </div>

    <div class="sticky-footer">
        <button type="submit" name="action" value="continue" class="btn-primary">
            @L.Catalog(Model.CtaContinueTexto) <i class="fas fa-chevron-right"></i>
        </button>
        <button type="submit" name="action" value="estimate" class="btn-outline">@L.Catalog(Model.CtaEstimateTexto)</button>
    </div>
</form>

@section Scripts {
<script>
    (function () {
        const hidden = document.getElementById('TipoMovimiento');
        const buttons = document.querySelectorAll('#moveTypeGroup .chip-btn');
        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                buttons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                hidden.value = btn.dataset.value;
            });
        });
    })();
</script>
}
