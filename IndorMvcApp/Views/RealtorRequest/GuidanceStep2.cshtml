@model IndorMvcApp.ViewModels.RealtorGuidanceStep2ViewModel
@using IndorMvcApp.Services
@{
    ViewData["Title"] = "Home Preferences";
    Layout = null;
    ViewBag.GuidanceStep = 2;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    @await Html.PartialAsync("_NavigationLoadingHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-request.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    <div class="hvac-top">
        <a asp-action="GuidanceStep1" asp-route-id="@Model.SolicitudId" class="hvac-back"><i class="fas fa-chevron-left"></i></a>
        <div class="hvac-title">Home Preferences</div>
        <div style="width:40px;"></div>
    </div>
    <div class="hvac-content">
        <h1 class="rr-page-title">Home Preferences</h1>
        @await Html.PartialAsync("_GuidanceProgress")

        <form asp-action="GuidanceStep2" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SolicitudId" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="rr-field">
                <span class="rr-field-label">What type of place are you open to?</span>
                <div class="rr-home-grid">
                    @foreach (var opt in RealtorRequestDisplayService.HomeTypeOptions)
                    {
                        <label class="rr-home-card @(Model.HomeType == opt.Value ? "selected" : "")">
                            <input type="radio" asp-for="HomeType" value="@opt.Value" />
                            <i class="fas @opt.Icon"></i>
                            <span>@opt.Label</span>
                        </label>
                    }
                </div>
            </div>

            <div class="rr-field">
                <span class="rr-field-label">How many bedrooms do you need?</span>
                <div class="rr-chip-row">
                    @foreach (var n in RealtorRequestDisplayService.CountOptions)
                    {
                        <label class="rr-chip-btn @(Model.Bedrooms == n ? "selected" : "")">
                            <input type="radio" asp-for="Bedrooms" value="@n" /><span>@n</span>
                        </label>
                    }
                </div>
            </div>

            <div class="rr-field">
                <span class="rr-field-label">How many bathrooms would you prefer?</span>
                <div class="rr-chip-row">
                    @foreach (var n in RealtorRequestDisplayService.BathroomOptions)
                    {
                        <label class="rr-chip-btn @(Model.Bathrooms == n ? "selected" : "")">
                            <input type="radio" asp-for="Bathrooms" value="@n" /><span>@n</span>
                        </label>
                    }
                </div>
            </div>

            <div class="rr-field">
                <span class="rr-field-label">How many people will live in the home?</span>
                <div class="rr-chip-row">
                    @foreach (var n in RealtorRequestDisplayService.CountOptions)
                    {
                        <label class="rr-chip-btn @(Model.Occupants == n ? "selected" : "")">
                            <input type="radio" asp-for="Occupants" value="@n" /><span>@n</span>
                        </label>
                    }
                </div>
            </div>

            <button type="submit" class="hvac-save-btn">Continue</button>
        </form>
    </div>
    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
<script src="~/js/realtor-request.js" asp-append-version="true"></script>
</body>
</html>
