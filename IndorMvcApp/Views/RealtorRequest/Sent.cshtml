@model IndorMvcApp.ViewModels.RealtorRequestSentViewModel
@using IndorMvcApp.Localization
@{
    ViewData["Title"] = Model.IsGeneralGuidance ? L["Request Submitted"] : L["Request Sent"];
    Layout = null;
}
<!DOCTYPE html>
<html lang="@UiCulture.HtmlLang(L.CurrentCulture)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    @await Html.PartialAsync("_NavigationLoadingHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-request.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    <div class="hvac-top">
        <a asp-controller="Home" asp-action="Index" class="hvac-back" aria-label="@L["Back"]"><i class="fas fa-chevron-left"></i></a>
        <div class="hvac-title">@ViewData["Title"]</div>
        <div style="width:40px;"></div>
    </div>

    <div class="hvac-content">
        <div class="rr-sent-hero rr-sent-hero--stars">
            <div class="rr-sent-icon"><i class="fas fa-check"></i></div>
            <h1>@ViewData["Title"]</h1>
            @if (Model.IsGeneralGuidance)
            {
                <p>
                    <strong>@L["Your General Guidance request has been sent."]</strong>
                    @L["A real estate professional will review your answers and contact you soon to help guide your next step."]
                </p>
            }
            else
            {
                <p>
                    <strong>@L["We received your realtor request."]</strong>
                    @L["Our team will review your information and help connect you with a trusted real estate professional."]
                </p>
            }
        </div>

        <div class="rr-summary-list">
            @if (Model.IsGeneralGuidance)
            {
                <div class="rr-summary-row">
                    <i class="fas fa-dollar-sign"></i>
                    <span class="k">@L["Monthly rent comfort"]</span>
                    <span class="v">@UiDisplayLocalization.Localize(L, Model.RentComfortLabel)</span>
                </div>
                <div class="rr-summary-row">
                    <i class="far fa-calendar"></i>
                    <span class="k">@L["Move timeline"]</span>
                    <span class="v">@UiDisplayLocalization.Localize(L, Model.TimeframeLabel)</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-building"></i>
                    <span class="k">@L["Property type"]</span>
                    <span class="v">@UiDisplayLocalization.Localize(L, Model.HomeTypeLabel)</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-bed"></i>
                    <span class="k">@L["Bedrooms"]</span>
                    <span class="v">@Model.BedroomsLabel</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-bath"></i>
                    <span class="k">@L["Bathrooms"]</span>
                    <span class="v">@Model.BathroomsLabel</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-paw"></i>
                    <span class="k">@L["Pets"]</span>
                    <span class="v">@UiDisplayLocalization.Localize(L, Model.PetsLabel)</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-location-dot"></i>
                    <span class="k">@L["Preferred area"]</span>
                    <span class="v">@Model.AreaLabel</span>
                </div>
            }
            else
            {
                <div class="rr-summary-row">
                    <i class="fas fa-house"></i>
                    <span class="k">@L["Need"]</span>
                    <span class="v">@UiDisplayLocalization.Localize(L, Model.NeedLabel)</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-location-dot"></i>
                    <span class="k">@L["Area"]</span>
                    <span class="v">@Model.AreaLabel</span>
                </div>
                <div class="rr-summary-row">
                    <i class="far fa-calendar"></i>
                    <span class="k">@L["Timeframe"]</span>
                    <span class="v">@UiDisplayLocalization.Localize(L, Model.TimeframeLabel)</span>
                </div>
                <div class="rr-summary-row">
                    <i class="fas fa-rotate"></i>
                    <span class="k">@L["Status"]</span>
                    <span class="v status">@UiDisplayLocalization.Localize(L, Model.StatusLabel)</span>
                </div>
            }
        </div>

        @if (Model.IsGeneralGuidance)
        {
            <div class="rr-info-banner">
                <i class="fas fa-circle-info"></i>
                <span>@L["You can edit this information later if needed."]</span>
            </div>
            <a asp-controller="Home" asp-action="Index" class="hvac-save-btn" style="text-decoration:none;text-align:center;display:block;">@L["Done"]</a>
            <a asp-action="Request" class="rr-secondary-btn">@L["Request another consultation"]</a>
        }
        else
        {
            <h2 class="rr-next-title">@L["What happens next"]</h2>
            <div class="rr-steps">
                <div class="rr-step">
                    <span class="rr-step-num"><i class="fas fa-file-lines"></i></span>
                    <div class="rr-step-copy">
                        <strong>@L["We review your request"]</strong>
                        <span>@L["Our team will review your information."]</span>
                    </div>
                </div>
                <div class="rr-step">
                    <span class="rr-step-num"><i class="fas fa-users"></i></span>
                    <div class="rr-step-copy">
                        <strong>@L["We identify a trusted match"]</strong>
                        <span>@L["We'll find a real estate professional that fits your needs."]</span>
                    </div>
                </div>
                <div class="rr-step">
                    <span class="rr-step-num"><i class="fas fa-comment-dots"></i></span>
                    <div class="rr-step-copy">
                        <strong>@L["We contact you with next steps"]</strong>
                        <span>@L["We'll reach out with your match and next steps."]</span>
                    </div>
                </div>
            </div>
            <a asp-controller="Home" asp-action="Index" class="hvac-save-btn" style="text-decoration:none;text-align:center;display:block;">@L["Done"]</a>
        }
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
