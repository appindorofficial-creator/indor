@model IndorMvcApp.ViewModels.RealtorRequestSentViewModel
@{
    ViewData["Title"] = "Request Sent";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/realtor-request.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    <div class="hvac-top">
        <a asp-controller="Home" asp-action="Index" class="hvac-back" aria-label="Back"><i class="fas fa-chevron-left"></i></a>
        <div class="hvac-title">Request Sent</div>
        <div style="width:40px;"></div>
    </div>

    <div class="hvac-content">
        <div class="rr-sent-hero">
            <div class="rr-sent-icon"><i class="fas fa-check"></i></div>
            <h1>Request Sent</h1>
            <p>
                <strong>We received your realtor request.</strong>
                Our team will review your information and help connect you with a trusted real estate professional.
            </p>
        </div>

        <div class="rr-summary-list">
            <div class="rr-summary-row">
                <i class="fas fa-house"></i>
                <span class="k">Need</span>
                <span class="v">@Model.NeedLabel</span>
            </div>
            <div class="rr-summary-row">
                <i class="fas fa-location-dot"></i>
                <span class="k">Area</span>
                <span class="v">@Model.AreaLabel</span>
            </div>
            <div class="rr-summary-row">
                <i class="far fa-calendar"></i>
                <span class="k">Timeframe</span>
                <span class="v">@Model.TimeframeLabel</span>
            </div>
            <div class="rr-summary-row">
                <i class="fas fa-rotate"></i>
                <span class="k">Status</span>
                <span class="v status">@Model.StatusLabel</span>
            </div>
        </div>

        <h2 class="rr-next-title">What happens next</h2>
        <div class="rr-steps">
            <div class="rr-step">
                <span class="rr-step-num"><i class="fas fa-file-lines"></i></span>
                <div class="rr-step-copy">
                    <strong>We review your request</strong>
                    <span>Our team will review your information.</span>
                </div>
            </div>
            <div class="rr-step">
                <span class="rr-step-num"><i class="fas fa-users"></i></span>
                <div class="rr-step-copy">
                    <strong>We identify a trusted match</strong>
                    <span>We'll find a real estate professional that fits your needs.</span>
                </div>
            </div>
            <div class="rr-step">
                <span class="rr-step-num"><i class="fas fa-comment-dots"></i></span>
                <div class="rr-step-copy">
                    <strong>We contact you with next steps</strong>
                    <span>We'll reach out with your match and next steps.</span>
                </div>
            </div>
        </div>

        <a asp-controller="Home" asp-action="Index" class="hvac-save-btn" style="text-decoration:none;text-align:center;">Done</a>
        <a asp-controller="Home" asp-action="Index" class="rr-back-link">Back to Home</a>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
