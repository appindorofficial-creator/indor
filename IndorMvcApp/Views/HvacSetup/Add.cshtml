@model IndorMvcApp.ViewModels.HvacSetupStartViewModel
@{
    ViewData["Title"] = "Add HVAC System";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    @await Html.PartialAsync("_HvacSetupHeader", Model)

    <div class="hvac-content">
        <div class="hvac-prop-card">
            <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Your home" />
            <p>@Model.Address</p>
        </div>

        <div class="hvac-scan-hero">
            <div class="hvac-scan-icon-wrap">
                <span class="hvac-scan-sparkle hvac-scan-sparkle-1"><i class="fas fa-wand-magic-sparkles"></i></span>
                <span class="hvac-scan-sparkle hvac-scan-sparkle-2"><i class="fas fa-wand-magic-sparkles"></i></span>
                <span class="hvac-scan-camera"><i class="fas fa-camera"></i></span>
            </div>
            <h2 class="hvac-scan-title">Scan your unit label</h2>
            <p class="hvac-scan-desc">INDOR can read your serial/model label to auto-fill system details, estimate age, and check maintenance history.</p>
            <a asp-action="ScanLabel" asp-route-propiedadId="@Model.PropiedadId" class="hvac-save-btn hvac-btn-with-icon">
                <i class="fas fa-camera"></i> Scan label now
            </a>
            <a asp-action="Manual" asp-route-propiedadId="@Model.PropiedadId" class="hvac-outline-btn">Enter manually</a>
        </div>

        <div class="hvac-benefit-list">
            <div class="hvac-benefit-item">
                <span class="hvac-benefit-icon"><i class="fas fa-clipboard-list"></i></span>
                <div>
                    <strong>Auto-fill system info</strong>
                    <span>We'll capture serial number, model, and more.</span>
                </div>
            </div>
            <div class="hvac-benefit-item">
                <span class="hvac-benefit-icon"><i class="fas fa-clock"></i></span>
                <div>
                    <strong>Estimate unit age</strong>
                    <span>Get an estimated install year in seconds.</span>
                </div>
            </div>
            <div class="hvac-benefit-item">
                <span class="hvac-benefit-icon"><i class="fas fa-chart-line"></i></span>
                <div>
                    <strong>Find maintenance insights</strong>
                    <span>See past service and recommended care.</span>
                </div>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
