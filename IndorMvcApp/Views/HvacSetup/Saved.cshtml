@model IndorMvcApp.ViewModels.HvacSavedViewModel
@{
    ViewData["Title"] = "HVAC system added";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    @await Html.PartialAsync("_HvacSetupHeader", Model)

    <div class="hvac-content">
        <div class="hvac-celebrate">
            <div class="hvac-celebrate-icon"><i class="fas fa-check"></i></div>
            <h2>Your HVAC system has been saved</h2>
        </div>

        <h2 class="hvac-section-title">System summary</h2>
        <div class="hvac-summary-equipment @(string.IsNullOrWhiteSpace(Model.EquipmentImageUrl) ? "hvac-summary-equipment-no-image" : "")">
            @if (!string.IsNullOrWhiteSpace(Model.EquipmentImageUrl))
            {
                <img src="@Url.Content($"~{Model.EquipmentImageUrl}")" alt="Your HVAC label photo" />
            }
            <div class="hvac-summary-list hvac-summary-list-inline">
                <div class="hvac-summary-item"><i class="fas fa-snowflake icon"></i><span class="k">Type</span><span class="v">@Model.SystemTypeLabel</span></div>
                <div class="hvac-summary-item"><i class="fas fa-tag icon"></i><span class="k">Brand</span><span class="v">@Model.Brand</span></div>
                <div class="hvac-summary-item"><i class="fas fa-cube icon"></i><span class="k">Model</span><span class="v">@Model.EquipmentModel</span></div>
                <div class="hvac-summary-item"><i class="fas fa-barcode icon"></i><span class="k">Serial number</span><span class="v">@Model.SerialNumber</span></div>
                <div class="hvac-summary-item"><i class="far fa-calendar icon"></i><span class="k">Estimated age</span><span class="v">@Model.EstimatedAgeLabel</span></div>
            </div>
        </div>

        <div class="hvac-whats-next-box">
            <strong>What happens next</strong>
            <div class="hvac-whats-next-item"><i class="fas fa-bell"></i><span>Maintenance reminders activated</span></div>
            <div class="hvac-whats-next-item"><i class="fas fa-house-circle-check"></i><span>System saved to House Facts</span></div>
            <div class="hvac-whats-next-item"><i class="fas fa-file-lines"></i><span>Future service history can be attached</span></div>
        </div>

        <a href="@Model.MyHomeUrl" class="hvac-save-btn hvac-btn-with-icon" style="text-decoration:none;">
            <i class="fas fa-house"></i> Go to My Home
        </a>
        <a asp-controller="HvacFilterReplacement" asp-action="Pets" asp-route-id="@Model.PropiedadId" class="hvac-outline-btn hvac-btn-with-icon">
            <i class="fas fa-circle-plus"></i> Set up filter reminders
        </a>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
