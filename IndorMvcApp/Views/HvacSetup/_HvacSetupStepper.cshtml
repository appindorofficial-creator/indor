@model int
<div class="hvac-stepper" aria-label="Progress">
    @for (var step = 1; step <= 5; step++)
    {
        var state = step < Model ? "done" : step == Model ? "current" : "upcoming";
        <span class="hvac-stepper-node @state">
            @if (step < Model)
            {
                <i class="fas fa-check"></i>
            }
            else
            {
                @step
            }
        </span>
        @if (step < 5)
        {
            <span class="hvac-stepper-line @(step < Model ? "done" : "")"></span>
        }
    }
</div>
