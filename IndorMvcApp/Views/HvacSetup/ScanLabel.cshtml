@model IndorMvcApp.ViewModels.HvacScanLabelViewModel
@{
    ViewData["Title"] = L["Scan HVAC Label"];
    var hasSavedPreview = !string.IsNullOrWhiteSpace(Model.PreviewImageUrl);
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Model.BackUrl;
    ViewData["WizardStep"] = Model.CurrentStep;
    ViewData["WizardTotalSteps"] = 5;

}


        <p class="hvac-lead">@Model.ScanHint</p>

        <form asp-action="ScanLabel" method="post" enctype="multipart/form-data" id="scanForm">
            <input type="hidden" name="propiedadId" value="@Model.PropiedadId" />
            @Html.AntiForgeryToken()

            <div class="hvac-camera-panel">
                <div class="hvac-camera-toolbar">
                    <button type="button" class="hvac-camera-tool" aria-label="@L["Flash"]"><i class="fas fa-bolt"></i></button>
                    <button type="button" class="hvac-camera-tool" aria-label="@L["Help"]"><i class="fas fa-circle-question"></i></button>
                </div>
                <div class="hvac-camera-view" id="cameraPreview">
                    <video id="cameraVideo" class="hvac-camera-live @(hasSavedPreview ? "is-hidden" : "")" autoplay playsinline muted></video>
                    <div id="cameraEmpty" class="hvac-camera-empty @(hasSavedPreview ? "is-hidden" : "")">
                        <i class="fas fa-camera"></i>
                        <span>@L["Open your camera or upload a label photo"]</span>
                    </div>
                    <img src="@(hasSavedPreview ? Url.Content($"~{Model.PreviewImageUrl}") : "")"
                         alt="@L["Your HVAC label photo"]"
                         class="hvac-camera-sample @(hasSavedPreview ? "is-custom" : "is-hidden")"
                         id="previewImage" />
                    <div class="hvac-camera-frame" aria-hidden="true"></div>
                    <div class="hvac-camera-hint">@L["Center the manufacturer label in the frame"]</div>
                </div>
            </div>

            <div class="hvac-scan-tips">
                <div><i class="fas fa-sun"></i><span>@L["Good lighting"]</span></div>
                <div><i class="fas fa-magnifying-glass"></i><span>@L["Capture serial + model"]</span></div>
                <div><i class="fas fa-camera-slash"></i><span>@L["Avoid blurry photos"]</span></div>
            </div>

            <input type="file" name="labelFile" id="labelFile" class="hvac-sr-only" accept="image/*" capture="environment" />
            <input type="file" id="uploadFile" class="hvac-sr-only" accept="image/*,.jpg,.jpeg,.png,.webp" />

            <button type="button" class="hvac-save-btn hvac-btn-with-icon" id="captureBtn">
                <i class="fas fa-camera"></i> <span id="captureBtnText">@(hasSavedPreview ? "Use this photo" : "Capture label")</span>
            </button>
            <button type="button" class="hvac-text-btn" id="uploadBtn">@L["Upload photo instead"]</button>
            <button type="submit" class="hvac-text-btn">@L["Continue with estimated details"]</button>
        </form>

        <div class="hvac-info-banner">
            <i class="fas fa-wand-magic-sparkles"></i>
            <span>@L["Scanning helps INDOR pull brand, model, serial number, install-year estimate, and service insights automatically."]</span>
        </div>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
@section Scripts {
<script>
    (function () {
        const form = document.getElementById('scanForm');
        const labelFile = document.getElementById('labelFile');
        const uploadFile = document.getElementById('uploadFile');
        const previewImage = document.getElementById('previewImage');
        const cameraVideo = document.getElementById('cameraVideo');
        const cameraEmpty = document.getElementById('cameraEmpty');
        const captureBtn = document.getElementById('captureBtn');
        const captureBtnText = document.getElementById('captureBtnText');
        const uploadBtn = document.getElementById('uploadBtn');
        let hasSelectedFile = @(hasSavedPreview ? "true" : "false");
        let cameraStream = null;

        function hideElement(el) {
            if (el) el.classList.add('is-hidden');
        }

        function showElement(el) {
            if (el) el.classList.remove('is-hidden');
        }

        function showPreview(file) {
            if (!file) return;

            const dt = new DataTransfer();
            dt.items.add(file);
            labelFile.files = dt.files;

            const objectUrl = URL.createObjectURL(file);
            previewImage.src = objectUrl;
            previewImage.classList.add('is-custom');
            showElement(previewImage);
            hideElement(cameraVideo);
            hideElement(cameraEmpty);
            hasSelectedFile = true;
            captureBtnText.textContent = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Use this photo"]));
        }

        async function startCamera() {
            if (!navigator.mediaDevices?.getUserMedia) return;

            try {
                cameraStream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: { ideal: 'environment' } },
                    audio: false
                });
                cameraVideo.srcObject = cameraStream;
                showElement(cameraVideo);
                hideElement(cameraEmpty);
            } catch {
                showElement(cameraEmpty);
                hideElement(cameraVideo);
            }
        }

        function captureFromVideo() {
            if (!cameraStream || cameraVideo.readyState < 2) return false;

            const canvas = document.createElement('canvas');
            canvas.width = cameraVideo.videoWidth;
            canvas.height = cameraVideo.videoHeight;
            canvas.getContext('2d').drawImage(cameraVideo, 0, 0);

            canvas.toBlob(blob => {
                if (!blob) return;
                showPreview(new File([blob], 'hvac-label.jpg', { type: 'image/jpeg' }));
            }, 'image/jpeg', 0.92);

            return true;
        }

        captureBtn.addEventListener('click', () => {
            if (hasSelectedFile) {
                form.submit();
                return;
            }

            if (cameraStream && !hasSelectedFile) {
                if (captureFromVideo()) return;
            }

            labelFile.click();
        });

        uploadBtn.addEventListener('click', () => uploadFile.click());

        labelFile.addEventListener('change', () => {
            if (labelFile.files?.[0]) showPreview(labelFile.files[0]);
        });

        uploadFile.addEventListener('change', () => {
            if (uploadFile.files?.[0]) showPreview(uploadFile.files[0]);
        });

        if (!hasSelectedFile) {
            startCamera();
        }
    })();

</script>
}
