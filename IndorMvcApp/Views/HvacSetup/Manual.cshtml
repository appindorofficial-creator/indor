@model IndorMvcApp.ViewModels.AddHvacSystemViewModel
@{
    ViewData["Title"] = "Enter system details";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    @await Html.PartialAsync("_HvacSetupHeader", Model)

    <div class="hvac-content">
        <div class="hvac-prop-card">
            <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Your home" />
            <p>@Model.Address</p>
        </div>
        <p class="hvac-lead">@Model.OpenAiHintNote</p>

        <form asp-action="Manual" method="post">
            <input type="hidden" asp-for="PropiedadId" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="hvac-form-card">
                <div class="hvac-row hvac-row-stacked">
                    <div class="hvac-label">System type</div>
                    <div class="hvac-chips">
                        @foreach (var type in new[] { ("CentralAC", "Central AC", "fa-snowflake"), ("HeatPump", "Heat Pump", "fa-wind"), ("MiniSplit", "Mini Split", "fa-fan") })
                        {
                            <label class="hvac-chip @(Model.SystemType == type.Item1 ? "active" : "")">
                                <input type="radio" asp-for="SystemType" value="@type.Item1" />
                                <i class="fas @type.Item3"></i> @type.Item2
                            </label>
                        }
                    </div>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="Brand">Brand</label>
                    <input asp-for="Brand" class="hvac-input" placeholder="Enter brand" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="Model">Model</label>
                    <input asp-for="Model" class="hvac-input" placeholder="Enter model" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="SerialNumber">Serial number</label>
                    <input asp-for="SerialNumber" class="hvac-input" placeholder="Enter serial number" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="InstallYear">Approx. install year</label>
                    <select asp-for="InstallYear" class="hvac-select">
                        <option value="">Select year</option>
                        @foreach (var year in Model.InstallYearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>
            </div>

            <button type="submit" class="hvac-save-btn">Continue to review</button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
<script>
    document.querySelectorAll('.hvac-chip input[type=radio]').forEach(radio => {
        radio.addEventListener('change', () => {
            document.querySelectorAll('.hvac-chip').forEach(c => c.classList.remove('active'));
            radio.closest('.hvac-chip')?.classList.add('active');
        });
    });
</script>
</body>
</html>
