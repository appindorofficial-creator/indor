@model IndorMvcApp.ViewModels.AddHvacSystemViewModel
@using IndorMvcApp.Validation
@{
    ViewData["Title"] = "Enter system details";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Model.BackUrl;
    ViewData["WizardStep"] = Model.CurrentStep;
    ViewData["WizardTotalSteps"] = 5;

}


        <div class="hvac-prop-card">
            <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Your home" />
            <p>@Model.Address</p>
        </div>
        <p class="hvac-lead">@Model.OpenAiHintNote</p>
        @if (TempData["HvacSetupError"] is string setupError)
        {
            <div class="hvac-alert" role="alert">@setupError</div>
        }

        <form asp-action="Manual" method="post" id="manualForm">
            <input type="hidden" asp-for="PropiedadId" />
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="hvac-form-card">
                <div class="hvac-row hvac-row-stacked">
                    <div class="hvac-label">System type</div>
                    <div class="hvac-chips">
                        @foreach (var type in new[] { ("CentralAC", "Central AC", "fa-snowflake"), ("HeatPump", "Heat Pump", "fa-wind"), ("MiniSplit", "Mini Split", "fa-fan") })
                        {
                            <label class="hvac-chip @(Model.SystemType == type.Item1 ? "active" : "")">
                                <input type="radio" asp-for="SystemType" value="@type.Item1" required />
                                <i class="fas @type.Item3"></i> @type.Item2
                            </label>
                        }
                    </div>
                    <span asp-validation-for="SystemType" class="text-danger"></span>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="Brand">Brand</label>
                    <input asp-for="Brand" class="hvac-input" placeholder="Enter brand" required />
                    <span asp-validation-for="Brand" class="text-danger"></span>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="EquipmentModel">Model</label>
                    <input asp-for="EquipmentModel" class="hvac-input" placeholder="Enter model" required />
                    <span asp-validation-for="EquipmentModel" class="text-danger"></span>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="SerialNumber">Serial number</label>
                    <input asp-for="SerialNumber"
                           class="hvac-input"
                           id="serialInput"
                           placeholder="e.g., M123456789"
                           maxlength="@EquipmentSerialNumberAttribute.MaxLength"
                           autocomplete="off"
                           spellcheck="false"
                           required />
                    <span style="display:block;margin-top:6px;font-size:0.75rem;color:#64748B;">@EquipmentSerialNumberAttribute.HintText</span>
                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="InstallYear">Approx. install year</label>
                    <select asp-for="InstallYear" class="hvac-select" required>
                        <option value="">Select year</option>
                        @foreach (var year in Model.InstallYearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                    <span asp-validation-for="InstallYear" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="hvac-save-btn">Continue to review</button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
@section Scripts {
<script>
    (function () {
        var serialInput = document.getElementById('serialInput');
        var form = document.getElementById('manualForm');

        function serialErrorMessage(value) {
            var serial = String(value || '').trim();
            if (!serial) {
                return 'Enter the serial number.';
            }
            if (serial.length < @EquipmentSerialNumberAttribute.MinLength) {
                return 'Serial number must be at least @EquipmentSerialNumberAttribute.MinLength characters.';
            }
            if (serial.length > @EquipmentSerialNumberAttribute.MaxLength) {
                return 'Serial number cannot exceed @EquipmentSerialNumberAttribute.MaxLength characters.';
            }
            if (!/^[A-Za-z0-9\-]+$/.test(serial)) {
                return 'Use only letters, numbers, and hyphens.';
            }
            if (!/\p{L}/u.test(serial) || !/\d/.test(serial)) {
                return 'Serial number must include at least one letter and one number.';
            }
            return '';
        }

        function validateSerialField() {
            if (!serialInput) return true;
            var message = serialErrorMessage(serialInput.value);
            serialInput.setCustomValidity(message);
            return !message;
        }

        serialInput?.addEventListener('input', validateSerialField);
        serialInput?.addEventListener('blur', validateSerialField);

        form?.addEventListener('submit', function (e) {
            if (!validateSerialField()) {
                e.preventDefault();
                serialInput.reportValidity();
            }
        });

        document.querySelectorAll('.hvac-chip input[type=radio]').forEach(radio => {
            radio.addEventListener('change', () => {
                document.querySelectorAll('.hvac-chip').forEach(c => c.classList.remove('active'));
                radio.closest('.hvac-chip')?.classList.add('active');
            });
        });
    })();

</script>
}
