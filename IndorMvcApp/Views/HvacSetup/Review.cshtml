@model IndorMvcApp.ViewModels.HvacReviewViewModel
@{
    ViewData["Title"] = L["Review & consent"];
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Model.BackUrl;
    ViewData["WizardStep"] = Model.CurrentStep;
    ViewData["WizardTotalSteps"] = 5;

}


        <form asp-action="Review" method="post">
            <input type="hidden" asp-for="PropiedadId" />
            <input type="hidden" asp-for="SystemType" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="hvac-review-card">
                <div class="hvac-review-card-head">
                    <span class="hvac-review-icon"><i class="fas fa-clipboard-list"></i></span>
                    <div>
                        <strong>@L["Review your HVAC details"]</strong>
                        <p>@L["Please confirm the information captured from your equipment label."]</p>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.LabelImageUrl))
                {
                    <div class="hvac-review-label-photo">
                        <img src="@Url.Content($"~{Model.LabelImageUrl}")" alt="@L["Your uploaded HVAC label"]" />
                    </div>
                }
                <div class="hvac-review-rows">
                    <div class="hvac-review-row"><span>@L["System type"]</span><strong>@UiDisplayLocalization.Localize(L, Model.SystemTypeLabel)</strong></div>
                    <div class="hvac-review-row"><span>@L["Brand"]</span><strong>@Model.Brand</strong></div>
                    <div class="hvac-review-row"><span>@L["Model"]</span><strong>@Model.EquipmentModel</strong></div>
                    <div class="hvac-review-row"><span>@L["Serial number"]</span><strong>@Model.SerialNumber</strong></div>
                    <div class="hvac-review-row"><span>@L["Approx. install year"]</span><strong>@Model.InstallYearLabel</strong></div>
                </div>
            </div>

            <div class="hvac-review-card">
                <div class="hvac-review-card-head">
                    <span class="hvac-review-icon"><i class="fas fa-shield-halved"></i></span>
                    <div>
                        <strong>@L["Terms & Conditions"]</strong>
                        <p>@L["Your consent helps INDOR deliver personalized maintenance and protection for your home."]</p>
                    </div>
                </div>

                <label class="hvac-consent-row">
                    <input asp-for="ConfirmInfo" type="checkbox" />
                    <span>@L["I confirm this equipment information is correct or I have updated it before saving."]</span>
                </label>
                <span asp-validation-for="ConfirmInfo" class="text-danger"></span>

                <label class="hvac-consent-row">
                    <input asp-for="AuthorizeStorage" type="checkbox" />
                    <span>@L["I authorize INDOR to store this equipment data and use it to personalize reminders, organize home records, and surface maintenance insights."]</span>
                </label>
                <span asp-validation-for="AuthorizeStorage" class="text-danger"></span>

                <a asp-controller="Account"
                   asp-action="Terms"
                   asp-route-from="hvac-setup"
                   asp-route-propiedadId="@Model.PropiedadId"
                   class="hvac-terms-link">
                    <i class="fas fa-file-lines"></i>
                    @L["View full terms & privacy"]
                    <i class="fas fa-chevron-right"></i>
                </a>
            </div>

            <div class="sticky-footer">
                <button type="submit" class="hvac-save-btn">@L["Agree & save"]</button>
            </div>
        </form>

    @await Html.PartialAsync("_AppBottomNav", "home")
