@model IndorMvcApp.ViewModels.AddWaterHeaterViewModel
@{
    ViewData["Title"] = "Add Water Heater";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/water-heater-setup.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    <div class="hvac-top">
        <a asp-controller="Home" asp-action="Index" class="hvac-back" aria-label="Back"><i class="fas fa-chevron-left"></i></a>
        <div class="hvac-title">Add Water Heater</div>
        <div style="width:40px;"></div>
    </div>

    <div class="hvac-content">
        <div class="hvac-prop-card">
            <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Your home" />
            <p>@Model.Address</p>
        </div>
        <p class="hvac-lead">@Model.OpenAiHintNote</p>

        <form asp-action="Add" method="post">
            <input type="hidden" asp-for="PropiedadId" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="hvac-form-card">
                <div class="hvac-row hvac-row-stacked">
                    <div class="hvac-label">
                        <span class="hvac-label-num">1.</span>Water heater type
                        <i class="far fa-circle-question" style="color:#94A3B8;margin-left:4px;font-size:0.8rem;"></i>
                    </div>
                    <div class="wh-type-toggle">
                        <label class="wh-type-btn @(Model.HeaterType == "Tank" ? "active" : "")">
                            <input type="radio" asp-for="HeaterType" value="Tank" />
                            <i class="fas fa-database"></i> Tank
                        </label>
                        <label class="wh-type-btn @(Model.HeaterType == "Tankless" ? "active" : "")">
                            <input type="radio" asp-for="HeaterType" value="Tankless" />
                            <i class="fas fa-bolt"></i> Tankless
                        </label>
                    </div>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="Brand"><span class="hvac-label-num">2.</span>Brand</label>
                    <input asp-for="Brand" class="hvac-input" placeholder="e.g., Rheem" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="Model"><span class="hvac-label-num">3.</span>Model (optional)</label>
                    <input asp-for="Model" class="hvac-input" placeholder="e.g., PROG50-38N RH62" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="SerialNumber"><span class="hvac-label-num">4.</span>Serial number (optional)</label>
                    <input asp-for="SerialNumber" class="hvac-input" placeholder="e.g., M123456789" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="InstallYear"><span class="hvac-label-num">5.</span>Approx. install year (optional)</label>
                    <select asp-for="InstallYear" class="hvac-select">
                        <option value="">Select year</option>
                        @foreach (var year in Model.InstallYearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>

                <div class="hvac-row hvac-row-stacked" id="tankSizeRow" data-hidden="@(Model.HeaterType == "Tankless" ? "true" : "false")">
                    <label class="hvac-label" asp-for="TankSize"><span class="hvac-label-num">6.</span>Tank size</label>
                    <select asp-for="TankSize" class="hvac-select">
                        <option value="">Select tank size</option>
                        @foreach (var size in Model.TankSizeOptions)
                        {
                            <option value="@size">@size</option>
                        }
                    </select>
                    <div class="wh-field-hint">Examples: 40 gal, 50 gal, 75 gal</div>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="LastServiceDate"><span class="hvac-label-num">7.</span>Last service date (optional)</label>
                    <input asp-for="LastServiceDate" type="date" class="hvac-input" placeholder="Select date" />
                </div>
            </div>

            <div class="hvac-toggle-card">
                <div class="hvac-toggle-icon"><i class="far fa-bell"></i></div>
                <div class="hvac-toggle-copy">
                    <strong>Enable annual flush reminder</strong>
                    <span>We'll remind you once a year to flush your water heater.</span>
                </div>
                <label class="hvac-switch">
                    <input asp-for="FlushRemindersEnabled" type="checkbox" />
                    <span></span>
                </label>
            </div>

            <button type="submit" class="hvac-save-btn">Save &amp; Continue</button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
<script>
    document.querySelectorAll('.wh-type-btn input[type=radio]').forEach(radio => {
        radio.addEventListener('change', () => {
            document.querySelectorAll('.wh-type-btn').forEach(btn => btn.classList.remove('active'));
            radio.closest('.wh-type-btn')?.classList.add('active');
            const tankRow = document.getElementById('tankSizeRow');
            if (tankRow) {
                tankRow.dataset.hidden = radio.value === 'Tankless' ? 'true' : 'false';
            }
        });
    });
</script>
</body>
</html>
