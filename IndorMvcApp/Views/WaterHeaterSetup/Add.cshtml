@model IndorMvcApp.ViewModels.WaterHeaterSetupStartViewModel
@{
    ViewData["Title"] = "Scan Water Heater Label";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/water-heater-setup.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    @await Html.PartialAsync("_WaterHeaterSetupHeader", Model)

    <div class="hvac-content">
        @await Html.PartialAsync("_WaterHeaterPropertyCard", Model)

        <p class="hvac-lead">Scan the label on your water heater to automatically fill in brand, model, serial number, and maintenance reminders.</p>

        <div class="wh-scan-intro">
            <div class="wh-scan-intro-icon"><i class="fas fa-camera"></i></div>
            <strong>Scan the equipment label</strong>
            <p>Point your camera at the manufacturer label on your water heater.</p>
        </div>

        <a asp-action="ScanLabel" asp-route-propiedadId="@Model.PropiedadId" class="hvac-save-btn hvac-btn-with-icon">
            <i class="fas fa-camera"></i> Scan label now
        </a>

        <div class="wh-or-divider"><span>OR</span></div>

        <a asp-action="Manual" asp-route-propiedadId="@Model.PropiedadId" class="hvac-outline-btn hvac-btn-with-icon">
            <i class="fas fa-pen-to-square"></i> Enter details manually
        </a>

        <div class="hvac-info-banner">
            <i class="fas fa-circle-info"></i>
            <span>Scanning helps INDOR organize your equipment, estimate age, and set up maintenance reminders.</span>
        </div>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
