@model IndorMvcApp.ViewModels.AddWaterHeaterViewModel
@using IndorMvcApp.Validation
@{
    ViewData["Title"] = L["Enter water heater details"];
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Model.BackUrl;
    ViewData["WizardStep"] = 
Model.CurrentStep
;
    ViewData["WizardTotalSteps"] = Model.TotalSteps;

}


        @await Html.PartialAsync("_WaterHeaterPropertyCard", Model)
        @if (TempData["WaterHeaterSetupError"] is string setupError)
        {
            <div class="hvac-alert" role="alert">@setupError</div>
        }
        <p class="hvac-lead">@Model.OpenAiHintNote</p>

        <form asp-controller="WaterHeaterSetup" asp-action="Manual" method="post" id="manualForm">
            <input type="hidden" asp-for="PropiedadId" />
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="hvac-form-card">
                <div class="hvac-row hvac-row-stacked">
                    <div class="hvac-label">@L["Water heater type"]</div>
                    <div class="wh-type-toggle">
                        <label class="wh-type-btn @(Model.HeaterType == "Tank" ? "active" : "")">
                            <input type="radio" asp-for="HeaterType" value="Tank" />
                            <i class="fas fa-database"></i> @L["Tank"]
                        </label>
                        <label class="wh-type-btn @(Model.HeaterType == "Tankless" ? "active" : "")">
                            <input type="radio" asp-for="HeaterType" value="Tankless" />
                            <i class="fas fa-bolt"></i> @L["Tankless"]
                        </label>
                    </div>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="Brand">@L["Brand"]</label>
                    <input asp-for="Brand" class="hvac-input" placeholder="@L["e.g., Rheem"]" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="EquipmentModel">@L["Model"]</label>
                    <input asp-for="EquipmentModel" class="hvac-input" placeholder="@L["e.g., PROG50-38N RH62"]" />
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="SerialNumber">@L["Serial number"]</label>
                    <input asp-for="SerialNumber"
                           class="hvac-input"
                           id="serialInput"
                           placeholder="@L["e.g., M123456789"]"
                           maxlength="@EquipmentSerialNumberAttribute.MaxLength"
                           autocomplete="off"
                           spellcheck="false" />
                    <span class="wh-field-hint">@L[EquipmentSerialNumberAttribute.HintText]</span>
                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                </div>

                <div class="hvac-row hvac-row-stacked">
                    <label class="hvac-label" asp-for="InstallYear">@L["Approx. install year"]</label>
                    <select asp-for="InstallYear" class="hvac-select">
                        <option value="">@L["Select year"]</option>
                        @foreach (var year in Model.InstallYearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </div>

                <div class="hvac-row hvac-row-stacked" id="tankSizeRow" data-hidden="@(Model.HeaterType == "Tankless" ? "true" : "false")">
                    <label class="hvac-label" asp-for="TankSize">@L["Tank size"]</label>
                    <select asp-for="TankSize" class="hvac-select">
                        <option value="">@L["Select tank size"]</option>
                        @foreach (var size in Model.TankSizeOptions)
                        {
                            <option value="@size">@size</option>
                        }
                    </select>
                </div>
            </div>

            <div class="sticky-footer">
                <button type="submit" class="hvac-save-btn">@L["Continue to review"]</button>
            </div>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
@section Scripts {
<script>
    (function () {
        var serialInput = document.getElementById('serialInput');
        var form = document.getElementById('manualForm');

        function serialErrorMessage(value) {
            var serial = String(value || '').trim();
            if (!serial) {
                return '';
            }
            if (serial.length < @EquipmentSerialNumberAttribute.MinLength) {
                return @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L.T("Serial number must be at least {0} characters.", EquipmentSerialNumberAttribute.MinLength)));
            }
            if (serial.length > @EquipmentSerialNumberAttribute.MaxLength) {
                return @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L.T("Serial number cannot exceed {0} characters.", EquipmentSerialNumberAttribute.MaxLength)));
            }
            if (!/^[A-Za-z0-9\-]+$/.test(serial)) {
                return @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Use only letters, numbers, and hyphens."]));
            }
            if (!/\p{L}/u.test(serial) || !/\d/.test(serial)) {
                return @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Serial number must include at least one letter and one number."]));
            }
            return '';
        }

        function validateSerialField() {
            if (!serialInput) return true;
            var message = serialErrorMessage(serialInput.value);
            serialInput.setCustomValidity(message);
            return !message;
        }

        serialInput?.addEventListener('input', validateSerialField);
        serialInput?.addEventListener('blur', validateSerialField);

        form?.addEventListener('submit', function (e) {
            if (!validateSerialField()) {
                e.preventDefault();
                serialInput.reportValidity();
            }
        });
    })();

    document.querySelectorAll('.wh-type-btn input[type=radio]').forEach(radio => {
        radio.addEventListener('change', () => {
            document.querySelectorAll('.wh-type-btn').forEach(btn => btn.classList.remove('active'));
            radio.closest('.wh-type-btn')?.classList.add('active');
            const tankRow = document.getElementById('tankSizeRow');
            if (tankRow) tankRow.dataset.hidden = radio.value === 'Tankless' ? 'true' : 'false';
        });
    });

</script>
}
