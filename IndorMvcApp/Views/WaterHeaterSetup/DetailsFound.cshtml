@model IndorMvcApp.ViewModels.WaterHeaterDetailsFoundViewModel
@{
    ViewData["Title"] = L["Water Heater Details Found"];
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Model.BackUrl;
    ViewData["WizardStep"] = 
Model.CurrentStep
;
    ViewData["WizardTotalSteps"] = Model.TotalSteps;

}


        @await Html.PartialAsync("_WaterHeaterPropertyCard", Model)

        <div class="wh-scan-success">
            <div class="wh-scan-success-copy">
                <span class="wh-scan-success-icon"><i class="fas fa-check"></i></span>
                <div>
                    <strong>@L["Label scanned successfully"]</strong>
                    <p>@L["We automatically extracted the water heater details below."]</p>
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.LabelImageUrl))
            {
                <img src="@Url.Content($"~{Model.LabelImageUrl}")" alt="@L["Your uploaded label photo"]" class="wh-label-thumb" />
            }
        </div>

        <div class="hvac-summary-list">
            <div class="hvac-summary-item"><i class="fas fa-droplet icon"></i><span class="k">@L["Water heater type"]</span><span class="v">@Model.HeaterTypeLabel</span></div>
            <div class="hvac-summary-item"><i class="fas fa-tag icon"></i><span class="k">@L["Brand"]</span><span class="v">@Model.Brand</span></div>
            <div class="hvac-summary-item"><i class="fas fa-cube icon"></i><span class="k">@L["Model"]</span><span class="v">@Model.EquipmentModel</span></div>
            <div class="hvac-summary-item"><i class="fas fa-barcode icon"></i><span class="k">@L["Serial number"]</span><span class="v">@Model.SerialNumber</span></div>
            <div class="hvac-summary-item"><i class="far fa-calendar icon"></i><span class="k">@L["Install year"]</span><span class="v">@Model.InstallYearLabel</span></div>
            @if (Model.HeaterTypeLabel == "Tank")
            {
                <div class="hvac-summary-item"><i class="fas fa-droplet icon"></i><span class="k">@L["Capacity"]</span><span class="v">@Model.TankSizeLabel</span></div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.EstimatedAgeLabel))
        {
            <div class="wh-age-banner">
                <i class="fas fa-calendar-check"></i>
                <span>@L["Estimated age:"] <strong>@Model.EstimatedAgeLabel</strong></span>
            </div>
        }

        <div class="hvac-info-banner">
            <i class="fas fa-bell"></i>
            <span>@L["Maintenance reminders can be enabled. INDOR will keep you on track with service reminders."]</span>
        </div>

        <form asp-action="DetailsFound" method="post">
            <input type="hidden" name="propiedadId" value="@Model.PropiedadId" />
            @Html.AntiForgeryToken()
            <button type="submit" class="hvac-save-btn">@L["Continue"]</button>
            <button type="submit" name="action" value="rescan" class="hvac-outline-btn hvac-btn-with-icon">
                <i class="fas fa-rotate-right"></i> @L["Rescan label"]
            </button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
