@model IndorMvcApp.ViewModels.WaterHeaterSavedViewModel
@{
    ViewData["Title"] = "Water Heater Added";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/water-heater-setup.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    @await Html.PartialAsync("_WaterHeaterSetupHeader", Model)

    <div class="hvac-content">
        @await Html.PartialAsync("_WaterHeaterPropertyCard", Model)

        <div class="hvac-celebrate">
            <div class="hvac-celebrate-icon"><i class="fas fa-check"></i></div>
            <h2>Water heater added successfully!</h2>
            <p class="hvac-lead" style="text-align:center;margin-top:8px;">Your equipment has been saved and is ready to manage.</p>
        </div>

        <div class="hvac-summary-equipment @(string.IsNullOrWhiteSpace(Model.EquipmentImageUrl) ? "hvac-summary-equipment-no-image" : "")">
            @if (!string.IsNullOrWhiteSpace(Model.EquipmentImageUrl))
            {
                <img src="@Url.Content($"~{Model.EquipmentImageUrl}")" alt="Your uploaded water heater label" />
            }
            <div class="hvac-summary-list hvac-summary-list-inline">
                <div class="hvac-summary-item"><i class="fas fa-droplet icon"></i><span class="k">Type</span><span class="v">@Model.HeaterTypeLabel</span></div>
                <div class="hvac-summary-item"><i class="fas fa-tag icon"></i><span class="k">Brand</span><span class="v">@Model.Brand</span></div>
                <div class="hvac-summary-item"><i class="fas fa-cube icon"></i><span class="k">Model</span><span class="v">@Model.Model</span></div>
                @if (!string.IsNullOrWhiteSpace(Model.InstallYearLabel) && Model.InstallYearLabel != "—")
                {
                    <div class="hvac-summary-item"><i class="far fa-calendar icon"></i><span class="k">Install Year</span><span class="v">@Model.InstallYearLabel</span></div>
                }
            </div>
        </div>

        <div class="hvac-whats-next-box">
            <div class="hvac-whats-next-item"><i class="fas fa-check"></i><span>Maintenance reminders ready</span></div>
            <div class="hvac-whats-next-item"><i class="fas fa-check"></i><span>Equipment saved in House Facts</span></div>
            <div class="hvac-whats-next-item"><i class="fas fa-check"></i><span>You can edit details anytime</span></div>
        </div>

        <a href="@Model.HouseFactsUrl" class="hvac-save-btn hvac-btn-with-icon" style="text-decoration:none;">
            <i class="fas fa-house"></i> Go to House Facts
        </a>
        <a asp-controller="WaterHeaterFlushReminder" asp-action="Intro" asp-route-id="@Model.PropiedadId" class="hvac-outline-btn hvac-btn-with-icon">
            <i class="fas fa-circle-plus"></i> Set annual flush reminder
        </a>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
