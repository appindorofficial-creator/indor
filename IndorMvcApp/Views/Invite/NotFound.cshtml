@{
    ViewData["Title"] = "Invitation not found";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; background: #F8FAFC; font-family: "Segoe UI", system-ui, -apple-system, Arial, sans-serif; color: #0A2540; }
        .nf-wrap { max-width: 480px; margin: 0 auto; padding: 72px 22px; text-align: center; }
        .nf-logo { font-weight: 800; color: #0066CC; font-size: 20px; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 40px; }
        .nf-badge { width: 84px; height: 84px; border-radius: 50%; background: #FEF2F2; color: #DC2626; font-size: 36px; display: flex; align-items: center; justify-content: center; margin: 0 auto 22px; }
        .nf-title { font-size: 22px; font-weight: 800; margin: 0 0 10px; }
        .nf-text { color: #64748B; font-size: 15px; line-height: 1.55; margin: 0; }
    </style>
</head>
<body>
    <div class="nf-wrap">
        <div class="nf-logo"><i class="fas fa-house"></i> INDOR</div>
        <div class="nf-badge"><i class="fas fa-link-slash"></i></div>
        <h1 class="nf-title">Invitation not available</h1>
        <p class="nf-text">This invitation link is invalid or has expired. Please ask your realtor to send a new invitation.</p>
    </div>
</body>
</html>
