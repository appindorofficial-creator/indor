@model IndorMvcApp.ViewModels.ReviewInspectionReportViewModel
@{
    ViewData["Title"] = "Review Upload";
    Layout = null;
    var inspectionLabel = Model.InspectionDate?.ToString("MMM d, yyyy") ?? "—";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - INDOR</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/hvac-setup.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/inspection-report-upload.css" asp-append-version="true" />
</head>
<body>
<div class="hvac-page">
    <div class="hvac-top">
        <a asp-action="Upload" asp-route-propiedadId="@Model.PropiedadId" class="hvac-back" aria-label="Back"><i class="fas fa-chevron-left"></i></a>
        <div class="hvac-title">Review Upload</div>
        <div style="width:40px;"></div>
    </div>

    <div class="hvac-content">
        <div class="hvac-prop-card">
            <img src="@Url.Content($"~{Model.ImageUrl}")" alt="Your home" />
            <p>@Model.Address</p>
        </div>

        <div class="ir-file-card">
            <div class="ir-file-card-icon"><i class="fas fa-file-pdf"></i></div>
            <div class="ir-file-card-body">
                <strong>@Model.OriginalFileName</strong>
                <span>@Model.FileSizeLabel</span>
            </div>
        </div>

        <form asp-action="Review" asp-route-id="@Model.PropiedadId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PropiedadId" />
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

            <div class="hvac-form-card">
                <div class="ir-field">
                    <label>Document title</label>
                    <div class="ir-readonly-field"><i class="fas fa-file-lines"></i><span>@Model.Title</span></div>
                </div>

                <div class="ir-field">
                    <label>Inspection date</label>
                    <div class="ir-readonly-field"><i class="far fa-calendar"></i><span>@inspectionLabel</span></div>
                </div>

                <div class="ir-field">
                    <label>Document category</label>
                    <div class="ir-readonly-field"><i class="fas fa-folder-open"></i><span>@Model.CategoryLabel</span></div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <div class="ir-field">
                        <label>Notes</label>
                        <div class="ir-readonly-field" style="align-items:flex-start;white-space:normal;"><i class="fas fa-note-sticky"></i><span style="white-space:normal;">@Model.Notes</span></div>
                    </div>
                }
            </div>

            <a asp-action="Upload" asp-route-propiedadId="@Model.PropiedadId" class="ir-replace-link">
                <i class="fas fa-arrow-up-from-bracket"></i> Replace File
            </a>

            <button type="submit" class="hvac-save-btn">Upload Report</button>
        </form>
    </div>

    @await Html.PartialAsync("_AppBottomNav", "home")
</div>
</body>
</html>
