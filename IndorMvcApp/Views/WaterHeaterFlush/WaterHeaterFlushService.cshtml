@model IndorMvcApp.ViewModels.WaterHeaterFlushServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;
}


@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="hvac-hero-icon"><i class="fas fa-droplet"></i></span>
        </div>
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@Model.LandingTitulo</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@Model.LandingTagline</div>
            }
        </div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.BenefitItems.Count > 0)
    {
        <div class="whf-benefit-grid">
            @foreach (var item in Model.BenefitItems)
            {
                <div class="whf-benefit-card">
                    <i class="fas @item.Icon"></i>
                    <span>@item.Text</span>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.WhyItMattersTexto))
    {
        <div class="why-box">
            <i class="fas fa-circle-info"></i>
            <div>
                <strong>@L["Why it matters"]</strong>
                <p>@Model.WhyItMattersTexto</p>
            </div>
        </div>
    }

    @if (Model.PreviewItems.Count > 0)
    {
        <div class="preview-box">
            <div class="preview-label">@L["What we'll ask"]</div>
            <div class="preview-grid">
                @foreach (var item in Model.PreviewItems)
                {
                    <div class="preview-chip"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                }
            </div>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="WaterHeaterFlushService" method="post">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>
