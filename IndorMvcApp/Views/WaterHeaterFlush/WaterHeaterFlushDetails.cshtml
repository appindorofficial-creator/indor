@model IndorMvcApp.ViewModels.WaterHeaterFlushDetailsViewModel
@{
    ViewData["Title"] = L["Maintenance details - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("WaterHeaterFlushSetup", "WaterHeaterFlush", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;
}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Maintenance details"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@L["Help us understand the condition of your water heater."]</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="whf-details-form" asp-action="WaterHeaterFlushDetails" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="UltimoFlush" id="UltimoFlush" />
        <input type="hidden" asp-for="SintomasSeleccionados" id="SintomasSeleccionados" />
        <input type="hidden" asp-for="TipoServicio" id="TipoServicio" />
        <input type="hidden" asp-for="PreferenciaTiempo" id="PreferenciaTiempo" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-clock-rotate-left"></i><span>@L["When was the last flush?"]</span></div>
            <div class="segment-row">
                <button type="button" class="segment-btn" data-flush="Within1Year">@L["Within 1 year"]</button>
                <button type="button" class="segment-btn" data-flush="OneToTwoYears">@L["1–2 years ago"]</button>
                <button type="button" class="segment-btn" data-flush="MoreThan2Years">@L["More than 2 years"]</button>
                <button type="button" class="segment-btn" data-flush="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><i class="fas fa-ear-listen"></i><span>@L["What have you noticed?"]</span></div>
            <div class="symptom-grid">
                <button type="button" class="symptom-pill" data-symptom="RumblingNoise"><i class="fas fa-volume-high"></i>@L["Rumbling noise"]</button>
                <button type="button" class="symptom-pill" data-symptom="RustyWater"><i class="fas fa-droplet"></i>@L["Rusty / cloudy water"]</button>
                <button type="button" class="symptom-pill" data-symptom="SlowHotWater"><i class="fas fa-temperature-half"></i>@L["Slow hot water"]</button>
                <button type="button" class="symptom-pill" data-symptom="TempChanges"><i class="fas fa-temperature-arrow-up"></i>@L["Temperature changes"]</button>
                <button type="button" class="symptom-pill" data-symptom="NoIssues" style="grid-column:1/-1;"><i class="fas fa-shield-halved"></i>@L["No issues — just maintenance"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-wrench"></i><span>@L["Service preference"]</span></div>
            <button type="button" class="service-card" data-service="OneTime">
                <span class="radio"></span>
                <strong>@L["One-time flush"]</strong>
                <span>@L["Schedule a single service at a time that works for you."]</span>
            </button>
            <button type="button" class="service-card" data-service="YearlyReminder">
                <span class="radio"></span>
                <strong>@L["Set yearly reminder"]</strong>
                <span>@L["We'll remind you every year so you never miss it."]</span>
            </button>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>@L["When works best for you?"]</span></div>
            <div class="timing-grid">
                <button type="button" class="service-card" data-timing="NextAvailable">
                    <span class="radio"></span>
                    <strong>@L["Next available"]</strong>
                    <span>@L["We'll find the earliest spot"]</span>
                </button>
                <button type="button" class="service-card" data-timing="ThisWeek">
                    <span class="radio"></span>
                    <strong>@L["This week"]</strong>
                    <span>@L["Within the next 7 days"]</span>
                </button>
                <button type="button" class="service-card" data-timing="ChooseDate">
                    <span class="radio"></span>
                    <strong>@L["Choose date"]</strong>
                    <span>@L["Pick a specific date"]</span>
                </button>
            </div>
            <div id="datePickerWrap" style="margin-top:10px;display:none;">
                <input asp-for="FechaVisita" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><i class="fas fa-note-sticky"></i><span>@L["Anything else we should know?"]</span></div>
            <textarea asp-for="NotasAdicionales" placeholder="@L["Add notes (optional)"]" maxlength="200"></textarea>
        </div>

        <div class="estimate-box">
            <i class="fas fa-clipboard-list"></i>
            <span>Estimated service: @Model.ResumenServicioTexto</span>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            Review request <i class="fas fa-chevron-right"></i>
        </button>
    </form>

@section Scripts {
<script>
    (function () {
        var flushInput = document.getElementById('UltimoFlush');
        var symptomsInput = document.getElementById('SintomasSeleccionados');
        var serviceInput = document.getElementById('TipoServicio');
        var timingInput = document.getElementById('PreferenciaTiempo');
        var dateWrap = document.getElementById('datePickerWrap');

        document.querySelectorAll('[data-flush]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-flush]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                flushInput.value = btn.getAttribute('data-flush');
            });
            if (btn.getAttribute('data-flush') === flushInput.value) btn.classList.add('active');
        });

        function setSymptoms(values) {
            symptomsInput.value = values.join('|');
        }

        function getSymptoms() {
            return symptomsInput.value ? symptomsInput.value.split('|').filter(Boolean) : [];
        }

        document.querySelectorAll('[data-symptom]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var code = btn.getAttribute('data-symptom');
                var current = getSymptoms();
                if (code === 'NoIssues') {
                    document.querySelectorAll('[data-symptom]').forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    setSymptoms(['NoIssues']);
                    return;
                }
                current = current.filter(function (v) { return v !== 'NoIssues'; });
                if (current.indexOf(code) >= 0) {
                    current = current.filter(function (v) { return v !== code; });
                    btn.classList.remove('active');
                } else {
                    current.push(code);
                    btn.classList.add('active');
                }
                if (current.length === 0) current = ['NoIssues'];
                setSymptoms(current);
                document.querySelectorAll('[data-symptom="NoIssues"]').forEach(function (b) {
                    b.classList.toggle('active', current.indexOf('NoIssues') >= 0);
                });
            });
            if (getSymptoms().indexOf(btn.getAttribute('data-symptom')) >= 0) btn.classList.add('active');
        });

        document.querySelectorAll('[data-service]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-service]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                serviceInput.value = btn.getAttribute('data-service');
            });
            if (btn.getAttribute('data-service') === serviceInput.value) btn.classList.add('active');
        });

        function syncDatePicker() {
            dateWrap.style.display = timingInput.value === 'ChooseDate' ? 'block' : 'none';
        }

        document.querySelectorAll('[data-timing]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-timing]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                timingInput.value = btn.getAttribute('data-timing');
                syncDatePicker();
            });
            if (btn.getAttribute('data-timing') === timingInput.value) btn.classList.add('active');
        });

        syncDatePicker();
    })();

</script>
}
