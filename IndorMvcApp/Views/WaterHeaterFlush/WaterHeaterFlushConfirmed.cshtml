@model IndorMvcApp.ViewModels.WaterHeaterFlushConfirmedViewModel
@{
    ViewData["Title"] = L["Water heater maintenance booked - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.NombreServicio);
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
}


<div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">@L["Water heater maintenance booked"]</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">@L["Your annual flush request has been submitted."]</p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-droplet"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@L.Catalog(Model.NombreServicio)</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Frequency"]</div><div class="summary-value">@UiDisplayLocalization.Localize(L, Model.FrequencyLabel)</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Preferred time"]</div><div class="summary-value">@UiDisplayLocalization.Localize(L, Model.PreferredTimeLabel)</div></div></div>
        <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">@L["Unit info received"]</div><div class="summary-value">@UiDisplayLocalization.Localize(L, Model.UnitInfoLabel)</div></div></div>
    </div>

    <div class="benefit-row">
        <div class="item"><i class="fas fa-water"></i><span>@L["Helps remove sediment"]</span></div>
        <div class="item"><i class="fas fa-leaf"></i><span>@L["Supports better efficiency"]</span></div>
        <div class="item"><i class="fas fa-shield-halved"></i><span>@L["Can extend tank life"]</span></div>
    </div>

    <div class="next-steps">
        <h4>@L["What happens next"]</h4>
        <div class="next-flow">
            <div class="step"><i class="fas fa-file-lines"></i>@L["We'll review your request"]</div>
            <div class="step"><i class="fas fa-user-check"></i>@L["A provider will confirm details"]</div>
            <div class="step"><i class="fas fa-calendar-check"></i>@L["You'll receive a reminder before next year's maintenance"]</div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn-primary">@L["Done"]</a>
    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-house"></i> @L["View in My Home"]
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-house"></i> @L["View in My Home"]
        </a>
    }
