@model IndorMvcApp.ViewModels.WaterHeaterFlushConfirmedViewModel
@{
    ViewData["Title"] = "Water heater maintenance booked - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_WaterHeaterFlushStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.NombreServicio</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_WaterHeaterFlushStepper", 4)

    <div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Water heater maintenance booked</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">Your annual flush request has been submitted.</p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-droplet"></i><div><div class="summary-label">Service</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">Frequency</div><div class="summary-value">@Model.FrequencyLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">Preferred time</div><div class="summary-value">@Model.PreferredTimeLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">Unit info received</div><div class="summary-value">@Model.UnitInfoLabel</div></div></div>
    </div>

    <div class="benefit-row">
        <div class="item"><i class="fas fa-water"></i><span>Helps remove sediment</span></div>
        <div class="item"><i class="fas fa-leaf"></i><span>Supports better efficiency</span></div>
        <div class="item"><i class="fas fa-shield-halved"></i><span>Can extend tank life</span></div>
    </div>

    <div class="next-steps">
        <h4>What happens next</h4>
        <div class="next-flow">
            <div class="step"><i class="fas fa-file-lines"></i>We'll review your request</div>
            <div class="step"><i class="fas fa-user-check"></i>A provider will confirm details</div>
            <div class="step"><i class="fas fa-calendar-check"></i>You'll receive a reminder before next year's maintenance</div>
        </div>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn-primary">Done</a>
    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-house"></i> View in My Home
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-outline" style="margin-top:10px;">
            <i class="fas fa-house"></i> View in My Home
        </a>
    }
</div>
</body>
</html>
