@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@using IndorMvcApp.Models
@{
    Layout = "_LayoutStep";
    var slots = ViewBag.DocumentSlots as IReadOnlyList<ProviderDocumentSlot> ?? Array.Empty<ProviderDocumentSlot>();
    var hasDocuments = ViewBag.HasDocuments as bool? == true;
}

<div class="prv-verification-step">
    <div class="prv-wiz-step-label">Step @Model.Step of @Model.TotalSteps</div>
    <div class="ob-head-block">
        <h1>@Model.Title</h1>
        <p>@Model.Subtitle</p>
    </div>

    <div class="prv-wiz-card">
        <span class="prv-wiz-card-icon prv-wiz-icon-blue"><i class="fas fa-display"></i></span>
        <span class="prv-wiz-card-body">
            <span class="prv-wiz-badge prv-wiz-badge--green"><i class="fas fa-check"></i> Active</span>
            <strong>INDOR Pro Access</strong>
            <ul class="prv-wiz-bullets">
                <li>Clients &amp; CRM</li>
                <li>Jobs &amp; photos</li>
                <li>Estimates &amp; invoices</li>
                <li>Reports &amp; property history</li>
            </ul>
        </span>
    </div>

    <div class="prv-wiz-card">
        <span class="prv-wiz-card-icon prv-wiz-icon-orange"><i class="fas fa-clipboard-list"></i></span>
        <span class="prv-wiz-card-body">
            <span class="prv-wiz-badge prv-wiz-badge--orange"><i class="fas fa-shield-halved"></i> Pending</span>
            <strong>Requirements to Receive INDOR Jobs</strong>
            <ul class="prv-wiz-checklist">
                <li><i class="far fa-circle"></i> Business license or registration</li>
                <li><i class="far fa-circle"></i> Insurance (if applicable)</li>
                <li><i class="far fa-circle"></i> Government ID</li>
                <li><i class="far fa-circle"></i> Activation call with INDOR</li>
            </ul>
        </span>
    </div>

    <form asp-action="Verification"
          method="post"
          enctype="multipart/form-data"
          id="prvVerificationForm"
          class="prv-wiz-stack prv-verification-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="ob-summary"></div>

        @if (slots.Count > 0)
        {
            <div class="prv-doc-form">
                <div class="prv-doc-upload">
                    <span class="prv-doc-label">Government ID</span>
                    <label class="prv-file-picker">
                        <input type="file"
                               class="prv-file-picker-input"
                               id="prvGovernmentIdFile"
                               name="governmentIdFile"
                               accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/*" />
                        <span class="prv-file-picker-btn">Choose file</span>
                        <span class="prv-file-picker-name">No file selected</span>
                    </label>
                </div>
                <div class="prv-doc-upload">
                    <span class="prv-doc-label">Business license</span>
                    <label class="prv-file-picker">
                        <input type="file"
                               class="prv-file-picker-input"
                               id="prvLicenseFile"
                               name="licenseFile"
                               accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/*" />
                        <span class="prv-file-picker-btn">Choose file</span>
                        <span class="prv-file-picker-name">No file selected</span>
                    </label>
                </div>
                <div class="prv-doc-upload">
                    <span class="prv-doc-label">Insurance certificate</span>
                    <label class="prv-file-picker">
                        <input type="file"
                               class="prv-file-picker-input"
                               id="prvInsuranceFile"
                               name="insuranceFile"
                               accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/*" />
                        <span class="prv-file-picker-btn">Choose file</span>
                        <span class="prv-file-picker-name">No file selected</span>
                    </label>
                </div>
                <div class="prv-doc-upload">
                    <span class="prv-doc-label">Business registration</span>
                    <label class="prv-file-picker">
                        <input type="file"
                               class="prv-file-picker-input"
                               id="prvBusinessRegistrationFile"
                               name="businessRegistrationFile"
                               accept=".pdf,.jpg,.jpeg,.png,.webp,application/pdf,image/*" />
                        <span class="prv-file-picker-btn">Choose file</span>
                        <span class="prv-file-picker-name">No file selected</span>
                    </label>
                </div>
                <button type="submit" name="action" value="upload" class="ob-btn ob-btn-outline prv-verification-upload">
                    <i class="fas fa-upload"></i> Upload Documents
                </button>
            </div>
        }
    </form>

    <div class="prv-wiz-info prv-verification-note">
        <i class="fas fa-circle-info"></i>
        <div>
            <p>You can start using INDOR Pro even if your provider profile is not yet activated for INDOR leads.</p>
        </div>
    </div>

    @if (hasDocuments)
    {
        <p class="prv-wiz-note"><i class="fas fa-check text-success"></i> Documents uploaded</p>
    }

    <div class="prv-wiz-footer prv-verification-footer">
        <button type="submit"
                form="prvVerificationForm"
                name="action"
                value="continue"
                id="prvVerificationContinueBtn"
                class="ob-btn ob-btn-primary">
            Continue with Verification
        </button>
        <button type="submit"
                form="prvVerificationForm"
                name="action"
                value="pro-only"
                id="prvVerificationProOnlyBtn"
                class="ob-btn ob-btn-outline">
            Use Only INDOR Pro for Now
        </button>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        var form = document.getElementById('prvVerificationForm');
        var continueBtn = document.getElementById('prvVerificationContinueBtn');
        var proOnlyBtn = document.getElementById('prvVerificationProOnlyBtn');
        if (!form) {
            return;
        }

        function submitLinkedForm(button) {
            if (!button || button.disabled) {
                return;
            }

            if (typeof form.requestSubmit === 'function') {
                form.requestSubmit(button);
                return;
            }

            form.submit();
        }

        [continueBtn, proOnlyBtn].forEach(function (button) {
            if (!button) {
                return;
            }

            button.addEventListener('click', function (e) {
                if (button.getAttribute('form') !== form.id) {
                    return;
                }

                e.preventDefault();
                submitLinkedForm(button);
            });
        });
    })();
</script>
}
