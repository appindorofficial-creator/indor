@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@using IndorMvcApp.Models
@{
    var slots = ViewBag.DocumentSlots as IReadOnlyList<ProviderDocumentSlot> ?? Array.Empty<ProviderDocumentSlot>();
    var tradeLabel = ViewBag.TradeLabel as string ?? "trade";
    var isPlumbing = Model.State.IsPlumbingOnly;
    var isHvac = ViewBag.IsHvac as bool? == true || Model.State.IsHvacOnly;
    var isHandyman = ViewBag.IsHandyman as bool? == true || Model.State.IsHandymanOnly;
    var isConstruction = ViewBag.IsConstruction as bool? == true || Model.State.IsConstructionOnly;
    var isBathroom = ViewBag.IsBathroom as bool? == true || Model.State.IsBathroomOnly;
    var isKitchen = ViewBag.IsKitchen as bool? == true || Model.State.IsKitchenOnly;
    var isRoofing = ViewBag.IsRoofing as bool? == true || Model.State.IsRoofingOnly;
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<div asp-validation-summary="All" class="ob-summary"></div>

@foreach (var slot in slots)
{
    var uploaded = string.Equals(slot.Status, "Uploaded", StringComparison.OrdinalIgnoreCase);
    var statusClass = uploaded ? "is-uploaded" : slot.Required ? "is-required" : "is-optional";
    var statusText = uploaded ? "Uploaded" : ((isHvac || isHandyman || isConstruction || isBathroom || isKitchen || isRoofing) && slot.Required) ? "Required" : slot.Required ? "Required" : "Optional";
    <div class="prv-doc-row @statusClass">
        <div class="prv-doc-row-icon"><i class="fas @(uploaded ? "fa-circle-check" : "fa-file-lines")"></i></div>
        <div class="prv-doc-row-body">
            <strong>@slot.Label</strong>
            @if (!slot.Required) { <span class="prv-doc-optional">Optional</span> }
            @if (uploaded && !string.IsNullOrWhiteSpace(slot.DisplayFileName))
            {
                <span class="prv-doc-file-name">@slot.DisplayFileName</span>
            }
        </div>
        <span class="prv-doc-status">@statusText</span>
    </div>
}

<form asp-action="Documents" method="post" enctype="multipart/form-data" class="prv-doc-form">
    @Html.AntiForgeryToken()
    @if (isRoofing)
    {
        <div class="prv-doc-upload"><label for="roofingLicenseFile">Roofing license</label><input type="file" id="roofingLicenseFile" name="roofingLicenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="liabilityInsuranceFile">General liability insurance</label><input type="file" id="liabilityInsuranceFile" name="liabilityInsuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="governmentIdFile">Government ID</label><input type="file" id="governmentIdFile" name="governmentIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration or W-9</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="portfolioFile">Project photos</label><input type="file" id="portfolioFile" name="portfolioFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
        <div class="prv-doc-upload"><label for="tradeCertsFile">Additional certification (optional)</label><input type="file" id="tradeCertsFile" name="tradeCertsFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
    }
    else if (isKitchen)
    {
        <div class="prv-doc-upload"><label for="governmentIdFile">Photo ID</label><input type="file" id="governmentIdFile" name="governmentIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="licenseFile">License / qualification proof</label><input type="file" id="licenseFile" name="licenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="liabilityInsuranceFile">Certificate of insurance</label><input type="file" id="liabilityInsuranceFile" name="liabilityInsuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="portfolioFile">Portfolio photos</label><input type="file" id="portfolioFile" name="portfolioFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
        <div class="prv-doc-upload"><label for="referencesFile">Customer references (optional)</label><input type="file" id="referencesFile" name="referencesFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
    }
    else if (isBathroom)
    {
        <div class="prv-doc-upload"><label for="governmentIdFile">Photo ID</label><input type="file" id="governmentIdFile" name="governmentIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="licenseFile">License / qualification proof</label><input type="file" id="licenseFile" name="licenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="liabilityInsuranceFile">Certificate of insurance</label><input type="file" id="liabilityInsuranceFile" name="liabilityInsuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="portfolioFile">Portfolio photos</label><input type="file" id="portfolioFile" name="portfolioFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
        <div class="prv-doc-upload"><label for="referencesFile">Customer references (optional)</label><input type="file" id="referencesFile" name="referencesFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
    }
    else if (isConstruction)
    {
        <div class="prv-doc-upload"><label for="contractorLicenseFile">General contractor license</label><input type="file" id="contractorLicenseFile" name="contractorLicenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="liabilityInsuranceFile">Certificate of insurance</label><input type="file" id="liabilityInsuranceFile" name="liabilityInsuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="w9File">W-9 form</label><input type="file" id="w9File" name="w9File" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="governmentIdFile">Government ID</label><input type="file" id="governmentIdFile" name="governmentIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="portfolioFile">Project photos / portfolio (optional)</label><input type="file" id="portfolioFile" name="portfolioFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
    }
    else if (isHandyman)
    {
        <div class="prv-doc-upload"><label for="governmentIdFile">Government ID</label><input type="file" id="governmentIdFile" name="governmentIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="liabilityInsuranceFile">General liability insurance</label><input type="file" id="liabilityInsuranceFile" name="liabilityInsuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration (if applicable)</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="workPhotosFile">Photos of completed handyman work</label><input type="file" id="workPhotosFile" name="workPhotosFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
        <div class="prv-doc-upload"><label for="referencesFile">References (optional)</label><input type="file" id="referencesFile" name="referencesFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="tradeCertsFile">Certifications (optional)</label><input type="file" id="tradeCertsFile" name="tradeCertsFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
    }
    else if (isHvac)
    {
        <div class="prv-doc-upload"><label for="hvacLicenseFile">HVAC contractor license</label><input type="file" id="hvacLicenseFile" name="hvacLicenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="epaCertFile">EPA certification</label><input type="file" id="epaCertFile" name="epaCertFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="liabilityInsuranceFile">General liability insurance</label><input type="file" id="liabilityInsuranceFile" name="liabilityInsuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="governmentIdFile">Government ID</label><input type="file" id="governmentIdFile" name="governmentIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="w9File">W-9 form</label><input type="file" id="w9File" name="w9File" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
    }
    else if (isPlumbing)
    {
        <div class="prv-doc-upload"><label for="plumbingLicenseFile">Plumbing license</label><input type="file" id="plumbingLicenseFile" name="plumbingLicenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="photoIdFile">Photo ID</label><input type="file" id="photoIdFile" name="photoIdFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="insuranceFile">Certificate of insurance</label><input type="file" id="insuranceFile" name="insuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="businessRegistrationFile">Business registration</label><input type="file" id="businessRegistrationFile" name="businessRegistrationFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="w9File">W-9 form</label><input type="file" id="w9File" name="w9File" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="tradeCertsFile">Trade certifications (optional)</label><input type="file" id="tradeCertsFile" name="tradeCertsFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="portfolioFile">Portfolio photos (optional)</label><input type="file" id="portfolioFile" name="portfolioFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
    }
    else
    {
        <div class="prv-doc-upload"><label for="licenseFile">Trade license</label><input type="file" id="licenseFile" name="licenseFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="insuranceFile">Proof of insurance</label><input type="file" id="insuranceFile" name="insuranceFile" accept=".pdf,.jpg,.jpeg,.png,.webp,image/*,application/pdf" /></div>
        <div class="prv-doc-upload"><label for="logoFile">Company logo (optional)</label><input type="file" id="logoFile" name="logoFile" accept="image/*,.jpg,.jpeg,.png,.webp" /></div>
    }
    <div class="prv-rule-banner">
        <i class="fas @(isHvac ? "fa-shield-halved" : "fa-circle-info")"></i>
        <span>@(isRoofing ? "Only complete and valid documents allow account approval." : isKitchen || isBathroom ? "INDOR reviews every provider before activation." : isConstruction || isHandyman ? "Your documents are reviewed by INDOR before your account can receive jobs." : isHvac ? "Required documents help protect homeowners and keep the provider network exclusive." : $"Documents help verify that you can only receive {tradeLabel.ToLowerInvariant()} jobs you are licensed or qualified to perform.")</span>
    </div>
    <button type="submit" name="action" value="upload" class="ob-btn ob-btn-outline">Save uploads</button>
    <button type="submit" name="action" value="continue" class="ob-btn ob-btn-primary">Continue</button>
    <a href="@Model.BackUrl" class="prv-save-later">Back</a>
</form>
