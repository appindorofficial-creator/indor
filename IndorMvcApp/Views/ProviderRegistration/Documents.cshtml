@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@using IndorMvcApp.Models
@{
    var slots = ViewBag.DocumentSlots as IReadOnlyList<ProviderDocumentSlot> ?? Array.Empty<ProviderDocumentSlot>();
    var tradeLabel = ViewBag.TradeLabel as string ?? "trade";
    var isPlumbing = Model.State.IsPlumbingOnly;
    var isHvac = ViewBag.IsHvac as bool? == true || Model.State.IsHvacOnly;
    var isHandyman = ViewBag.IsHandyman as bool? == true || Model.State.IsHandymanOnly;
    var isConstruction = ViewBag.IsConstruction as bool? == true || Model.State.IsConstructionOnly;
    var isBathroom = ViewBag.IsBathroom as bool? == true || Model.State.IsBathroomOnly;
    var isKitchen = ViewBag.IsKitchen as bool? == true || Model.State.IsKitchenOnly;
    var isPainting = ViewBag.IsPainting as bool? == true || Model.State.IsPaintingOnly;
    var isFlooring = ViewBag.IsFlooring as bool? == true || Model.State.IsFlooringOnly;
    var isCleaning = ViewBag.IsCleaning as bool? == true || Model.State.IsCleaningOnly;
    var isLandscaping = ViewBag.IsLandscaping as bool? == true || Model.State.IsLandscapingOnly;
    var isPest = ViewBag.IsPest as bool? == true || Model.State.IsPestOnly;
    var isAppliance = ViewBag.IsAppliance as bool? == true || Model.State.IsApplianceOnly;
    var isRoofing = ViewBag.IsRoofing as bool? == true || Model.State.IsRoofingOnly;
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<div asp-validation-summary="All" class="ob-summary"></div>

@foreach (var slot in slots)
{
    var uploaded = string.Equals(slot.Status, "Uploaded", StringComparison.OrdinalIgnoreCase);
    var statusClass = uploaded ? "is-uploaded" : slot.Required ? "is-required" : "is-optional";
    var statusText = uploaded ? "Uploaded" : ((isHvac || isHandyman || isConstruction || isBathroom || isKitchen || isPainting || isFlooring || isCleaning || isLandscaping || isPest || isAppliance || isRoofing) && slot.Required) ? "Required" : slot.Required ? "Required" : (isAppliance ? "Pending" : "Optional");
    <div class="prv-doc-row @statusClass">
        <div class="prv-doc-row-icon"><i class="fas @(uploaded ? "fa-circle-check" : "fa-file-lines")"></i></div>
        <div class="prv-doc-row-body">
            <strong>@slot.Label</strong>
            @if (!slot.Required) { <span class="prv-doc-optional">@L["Optional"]</span> }
            @if (uploaded && !string.IsNullOrWhiteSpace(slot.DisplayFileName))
            {
                <span class="prv-doc-file-name">@slot.DisplayFileName</span>
            }
        </div>
        <span class="prv-doc-status">@statusText</span>
    </div>
}

