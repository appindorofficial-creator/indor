    {
        <a href="@Model.BackUrl" class="prv-save-later">Save and finish later</a>
    }
    else
    {
        <a asp-action="Categories" class="prv-save-later">Back</a>
    }
</form>
@section Scripts {
<script>
document.querySelectorAll('[data-provider-type]').forEach(btn => {
    btn.addEventListener('click', () => {
        document.getElementById('providerType').value = btn.dataset.providerType;
        document.querySelectorAll('[data-provider-type]').forEach(b => b.classList.toggle('is-selected', b === btn));
    });
});
document.querySelectorAll('[data-client-segment]').forEach(btn => {
    btn.addEventListener('click', () => {
        const hidden = document.getElementById('clientSegment');
        if (hidden) hidden.value = btn.dataset.clientSegment;
        document.querySelectorAll('[data-client-segment]').forEach(b => b.classList.toggle('is-selected', b === btn));
    });
});
document.querySelectorAll('[data-handyman-role-val]').forEach(btn => {
    btn.addEventListener('click', () => {
        const val = btn.dataset.handymanRoleVal;
        const hidden = document.getElementById('handymanRoleType');
        if (hidden) hidden.value = val;
        document.querySelectorAll('[data-handyman-role-val]').forEach(b => b.classList.toggle('is-selected', b === btn));
    });
});
const desc = document.querySelector('textarea[name="ServiceDescription"]');
const count = document.getElementById('svcDescCount') || document.getElementById('pestDescCount');
if (desc && count) {
    desc.addEventListener('input', () => { count.textContent = desc.value.length; });
}
</script>
}
