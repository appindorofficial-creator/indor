        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-clock"></i>
            <select class="ob-control" name="YearsExperience">
                <option value="">Years of experience</option>
                @foreach (var opt in new[] { "Less than 1 year", "1-2 years", "3-5 years", "6-10 years", "10+ years" })
                {
                    <option value="@opt" selected="@(s.YearsExperience == opt)">@opt</option>
                }
            </select>
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-certificate"></i>
            <input class="ob-control" name="LicenseNumber" value="@s.LicenseNumber" placeholder="License / certification (if applicable)" />
        </div>
        <p class="prv-field-label">Mobile service available</p>
        <div class="prv-chip-grid" style="grid-template-columns:1fr 1fr;margin-bottom:12px">
            <label class="prv-chip @(!s.EmergencyService ? "is-selected" : "")">
                <input type="radio" name="EmergencyService" value="false" @(!s.EmergencyService ? "checked" : "") /> Off
            </label>
            <label class="prv-chip @(s.EmergencyService ? "is-selected" : "")">
                <input type="radio" name="EmergencyService" value="true" @(s.EmergencyService ? "checked" : "") /> On
            </label>
        </div>
    }
    else if (isLandscaping)
