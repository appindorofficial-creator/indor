@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@{
    var s = Model.State;
    var isPlumbing = ViewBag.IsPlumbing as bool? == true;
    var isHvac = ViewBag.IsHvac as bool? == true;
    var isHandyman = ViewBag.IsHandyman as bool? == true;
    var isConstruction = ViewBag.IsConstruction as bool? == true;
    var isBathroom = ViewBag.IsBathroom as bool? == true;
    var isKitchen = ViewBag.IsKitchen as bool? == true;
    var isPainting = ViewBag.IsPainting as bool? == true;
    var isFlooring = ViewBag.IsFlooring as bool? == true;
    var isCleaning = ViewBag.IsCleaning as bool? == true;
    var isLandscaping = ViewBag.IsLandscaping as bool? == true;
    var isPest = ViewBag.IsPest as bool? == true;
    var isAppliance = ViewBag.IsAppliance as bool? == true;
    var isRoofing = ViewBag.IsRoofing as bool? == true;
    var clientSegment = s.ServiceDescription;
    var tradeLabel = ViewBag.TradeLabel as string ?? "Construction Company";
    var defaultCities = new[] { "Charlotte", "Mint Hill", "Matthews", "Indianapolis", "Carmel", "Fishers" };
    var selectedCities = s.ZipOrNeighborhoods.Count > 0 ? s.ZipOrNeighborhoods : defaultCities.Take(3).ToList();
    var providerType = s.ProviderType;
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>
<form asp-action="Business" method="post" class="ob-form-card">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary"></div>
    <input type="hidden" name="ProviderType" id="providerType" value="@providerType" />

    @if (isPlumbing)
    {
        <div class="ob-field prv-field-icon">
            <i class="fas fa-building"></i>
            <input class="ob-control" name="BusinessName" value="@s.BusinessName" placeholder="Business name" required />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-user"></i>
            <input class="ob-control" name="PrimaryContact" value="@s.PrimaryContact" placeholder="Contact name" required />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-phone"></i>
            <input class="ob-control" name="Phone" value="@s.Phone" type="tel" placeholder="Phone number" />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-envelope"></i>
            <input class="ob-control" name="Email" value="@s.Email" type="email" placeholder="Email" required />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-location-dot"></i>
            <input class="ob-control" name="BusinessAddress" value="@s.BusinessAddress" placeholder="Business address" />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-briefcase"></i>
            <select class="ob-control" name="YearsExperience">
                <option value="">Years of experience</option>
                @foreach (var opt in new[] { "1-2", "3-5", "6-10", "10+" })
                {
                    <option value="@opt" selected="@(s.YearsExperience == opt)">@opt years</option>
                }
            </select>
        </div>
        <p class="prv-field-label">Provider type</p>
        <div class="prv-provider-type-row">
            <button type="button" class="prv-type-card @(providerType == "LicensedPlumber" ? "is-selected" : "")" data-provider-type="LicensedPlumber">
                <i class="fas fa-user"></i><span>Licensed plumber</span>
            </button>
            <button type="button" class="prv-type-card @(providerType == "MasterPlumber" ? "is-selected" : "")" data-provider-type="MasterPlumber">
                <i class="fas fa-award"></i><span>Master plumber</span>
            </button>
            <button type="button" class="prv-type-card @(providerType == "PlumbingCompany" ? "is-selected" : "")" data-provider-type="PlumbingCompany">
                <i class="fas fa-building"></i><span>Plumbing company</span>
            </button>
        </div>
        <div class="prv-rule-banner">
            <i class="fas fa-shield-halved"></i>
            <span>Only approved plumbing providers can receive plumbing requests in INDOR.</span>
        </div>
    }
    else if (isRoofing)
    {
        <input type="hidden" name="ProviderType" value="RoofingContractor" />
        <div class="prv-selected-trade-card">
            <i class="fas fa-house-chimney"></i>
            <div>
                <span>Selected trade:</span>
                <strong>@tradeLabel</strong>
            </div>
            <i class="fas fa-circle-check"></i>
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-building"></i>
            <input class="ob-control" name="BusinessName" value="@s.BusinessName" placeholder="Business name" required />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-user"></i>
            <input class="ob-control" name="PrimaryContact" value="@s.PrimaryContact" placeholder="Owner / contact name" required />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-phone"></i>
            <input class="ob-control" name="Phone" value="@s.Phone" type="tel" placeholder="Phone number" />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-envelope"></i>
            <input class="ob-control" name="Email" value="@s.Email" type="email" placeholder="Email address" required />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-location-dot"></i>
            <input class="ob-control" name="BusinessAddress" value="@s.BusinessAddress" placeholder="Business address" />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-id-card"></i>
            <input class="ob-control" name="LicenseNumber" value="@s.LicenseNumber" placeholder="License number" />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-calendar"></i>
            <select class="ob-control" name="YearsExperience">
                <option value="">Years in business</option>
                @foreach (var opt in new[] { "Less than 1 year", "1-2 years", "3-5 years", "6-10 years", "10+ years" })
                {
                    <option value="@opt" selected="@(s.YearsExperience == opt)">@opt</option>
                }
            </select>
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-bullseye"></i>
            <input class="ob-control" name="ServiceZipCodes" value="@s.ServiceZipCodesDisplay" placeholder="Primary service area" />
        </div>
        <p class="prv-field-label">Company size</p>
        <div class="prv-chip-grid prv-chip-grid--team" data-chip-group>
            @foreach (var opt in new[] { "Solo", "2-5 crew", "6+ crew" })
            {
                <label class="prv-chip @(s.TeamSize == opt ? "is-selected" : "")">
                    <input type="radio" name="TeamSize" value="@opt" @(s.TeamSize == opt ? "checked" : "") /> @opt
                </label>
            }
        </div>
        <div class="prv-rule-banner">
            <i class="fas fa-shield-halved"></i>
            <span>This information helps INDOR verify your roofing business.</span>
        </div>
    }
