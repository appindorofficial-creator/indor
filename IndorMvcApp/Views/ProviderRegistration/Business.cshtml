                    <option value="@opt" selected="@(s.YearsExperience == opt)">@opt</option>
                }
            </select>
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-id-card"></i>
            <input class="ob-control" name="LicenseNumber" value="@s.LicenseNumber" placeholder="License / registration number" />
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-shield-halved"></i>
