        <div class="prv-chip-grid" style="grid-template-columns:1fr 1fr;margin-bottom:12px">
            <label class="prv-chip @(!s.IsInsured ? "is-selected" : "")">
                <input type="radio" name="IsInsured" value="false" @(!s.IsInsured ? "checked" : "") /> No
            </label>
            <label class="prv-chip @(s.IsInsured ? "is-selected" : "")">
                <input type="radio" name="IsInsured" value="true" @(s.IsInsured ? "checked" : "") /> Yes
            </label>
        </div>
        <div class="ob-field prv-field-icon">
            <i class="fas fa-file-lines"></i>
            <textarea class="ob-control" name="ServiceDescription" rows="3" maxlength="500" placeholder="Business description (optional)">@s.ServiceDescription</textarea>
        </div>
        <p class="prv-field-hint text-end"><span id="pestDescCount">@(s.ServiceDescription?.Length ?? 0)</span>/500</p>
    }
    else if (isAppliance)
