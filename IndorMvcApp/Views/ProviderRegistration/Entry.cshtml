@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@{
    Layout = "_LayoutStep";
    ViewData["PrvWizardSkin"] = "prv-page--entry";
    var s = Model.State;
    var selectedKind = string.Equals(s.OrganizationKind, "Independent", StringComparison.OrdinalIgnoreCase)
        ? "independent"
        : "company";
}

@section Head {
    <link rel="stylesheet" href="~/css/provider-entry-v1.css" asp-append-version="true" />
}

<div class="prv-entry-hero">
    <h1>@L["Welcome to INDOR for providers"]</h1>
    <p>@L["How do you want to enter?"]</p>
</div>

<form asp-action="Entry" method="post" id="prvEntryForm" class="prv-wiz-stack pa-validate" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary"></div>

    <input type="hidden" name="path" id="prvEntryPath" value="@selectedKind" />

    <div class="prv-entry-options" role="radiogroup" aria-label="@L["How do you want to enter?"]">
        <button type="button"
                class="prv-entry-card prv-entry-card--company @(selectedKind == "company" ? "is-selected" : "")"
                data-path="company"
                role="radio"
                aria-checked="@(selectedKind == "company" ? "true" : "false")"
                tabindex="0">
            <span class="prv-entry-card-select" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg>
            </span>
            <img src="~/images/prv-entry-company-art.png" alt="" class="prv-entry-card-art" loading="lazy" asp-append-version="true" />
            <div class="prv-entry-card-main">
                <strong>@L["As a company"]</strong>
                <p>@L["For businesses or service teams"]</p>
            </div>
        </button>

        <button type="button"
                class="prv-entry-card prv-entry-card--independent @(selectedKind == "independent" ? "is-selected" : "")"
                data-path="independent"
                role="radio"
                aria-checked="@(selectedKind == "independent" ? "true" : "false")"
                tabindex="0">
            <span class="prv-entry-card-select" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L19 7"/></svg>
            </span>
            <img src="~/images/prv-entry-independent-art.png" alt="" class="prv-entry-card-art" loading="lazy" asp-append-version="true" />
            <div class="prv-entry-card-main">
                <strong>@L["As an independent provider"]</strong>
                <p>@L["For people who work for themselves"]</p>
            </div>
        </button>
    </div>

    <p class="prv-entry-hint">@L["Complete the rest from your profile later."]</p>

    <label class="prv-wiz-terms">
        <input type="hidden" name="termsAccepted" value="false" />
        <input type="checkbox"
               id="prvEntryTermsAccepted"
               name="termsAccepted"
               value="true"
               @(s.TermsAccepted ? "checked" : null)
               data-pa-required="true"
               data-field-label="@L["Please agree to INDOR's Terms &amp; Conditions."]" />
        <span>@L["I agree to INDOR's"] <a asp-controller="Account" asp-action="Terms" asp-route-from="provider-entry">@L["Terms & Conditions"]</a></span>
    </label>
</form>

<div class="prv-wiz-footer">
    <button type="submit" form="prvEntryForm" class="ob-btn ob-btn-primary">@L["Continue"]</button>
</div>

@section Scripts {
    @await Html.PartialAsync("_PropertyAdminStepValidation")
}
