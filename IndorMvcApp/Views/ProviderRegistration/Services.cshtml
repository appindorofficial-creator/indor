@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@{
    var offerings = ViewBag.Offerings as IReadOnlyList<IndorMvcApp.Models.OnboardingOption> ?? [];
    var selected = ViewBag.SelectedIds as IList<string> ?? new List<string>();
}
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>
<form asp-action="Services" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary"></div>
    <div class="prv-chip-grid" data-chip-group>
        @foreach (var item in offerings)
        {
            var isOn = selected.Contains(item.Id, StringComparer.OrdinalIgnoreCase);
            <label class="prv-chip @(isOn ? "is-selected" : "")">
                <input type="checkbox" name="serviceIds" value="@item.Id" @(isOn ? "checked" : "") />
                <i class="fas @item.IconClass"></i>
                <span>@item.Label</span>
            </label>
        }
    </div>
    <button type="submit" class="ob-btn ob-btn-primary">Continue</button>
</form>
