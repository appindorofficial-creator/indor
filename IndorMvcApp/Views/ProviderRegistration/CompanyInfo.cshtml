@model IndorMvcApp.ViewModels.ProviderRegistrationStepViewModel
@{
    Layout = "_LayoutStep";
    var s = Model.State;
    var categories = ViewBag.Categories as IReadOnlyList<IndorMvcApp.Models.OnboardingOption> ?? Array.Empty<IndorMvcApp.Models.OnboardingOption>();
    var primaryCategory = s.SelectedCategoryIds.FirstOrDefault();
}
<div class="prv-wiz-step-label">@L.T("Step {0} of {1}", Model.Step, Model.TotalSteps)</div>
<div class="ob-head-block">
    <h1>@Model.Title</h1>
    <p>@Model.Subtitle</p>
</div>

<form asp-action="CompanyInfo" method="post" class="ob-form-card pa-validate" id="prvCompanyInfoForm" novalidate
      data-save-draft-url="@Url.Action("SaveCompanyInfoDraft", "ProviderRegistration")">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="ob-summary"></div>

    <div class="ob-field prv-field-icon">
        <i class="fas fa-building"></i>
        <input class="ob-control" name="businessName" value="@s.BusinessName" placeholder="@L["Company name"]" data-pa-required="true" data-field-label="@L["company name"]" />
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-user"></i>
        <input class="ob-control" name="primaryContact" value="@s.PrimaryContact" placeholder="@L["Contact name"]" data-pa-required="true" data-field-label="@L["contact name"]" />
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-phone"></i>
        <input class="ob-control" name="phone" value="@s.Phone" type="tel" placeholder="@L["Phone number"]" data-phone-input />
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-envelope"></i>
        <input class="ob-control" name="email" value="@s.Email" type="email" inputmode="email" autocomplete="email" placeholder="@L["Email address"]" data-pa-required="true" data-field-label="@L["email address"]" />
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-briefcase"></i>
        <select class="ob-control" name="primaryCategoryId">
            <option value="">@L["Primary service category"]</option>
            @foreach (var cat in categories)
            {
                <option value="@cat.Id" selected="@(primaryCategory == cat.Id)">@cat.Label</option>
            }
        </select>
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-location-dot"></i>
        <input class="ob-control" name="serviceAreas" value="@s.ServiceZipCodesDisplay" placeholder="@L["Service areas"]" />
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-globe"></i>
        <input class="ob-control" name="website" value="@s.Website" placeholder="@L["Website (optional)"]" />
    </div>
    <div class="ob-field prv-field-icon">
        <i class="fas fa-shield-halved"></i>
        <input class="ob-control" name="einNumber" value="@s.EinNumber" placeholder="@L["EIN / Company Verification Number"]" />
    </div>

    <div class="prv-wiz-info">
        <i class="fas fa-circle-info"></i>
        <div>
            <p>@L["This information helps set up INDOR Pro and starts your provider application."]</p>
        </div>
    </div>

    <label class="prv-wiz-terms">
        <input type="hidden" name="termsAccepted" value="false" />
        <input type="checkbox"
               id="prvCompanyTermsAccepted"
               name="termsAccepted"
               value="true"
               @(s.TermsAccepted ? "checked" : null)
               data-pa-required="true"
               data-field-label="@L["Please agree to INDOR's Terms &amp; Conditions."]" />
        <span>@L["I agree to INDOR's"]<a asp-controller="Account" asp-action="Terms" asp-route-from="provider-company-info">@L["Terms &amp; Conditions"]</a></span>
    </label>
</form>

<div class="prv-wiz-footer">
    <button type="submit" form="prvCompanyInfoForm" id="prvCompanyInfoContinueBtn" class="ob-btn ob-btn-primary">@L["Save &amp; Continue"]</button>
    <button type="submit" form="prvCompanyInfoForm" name="action" value="later" class="prv-save-later" formnovalidate>@L["I'll do this later"]</button>
</div>

@section Scripts {
    @await Html.PartialAsync("_PropertyAdminStepValidation")
    <script>
        (function () {
            var form = document.getElementById('prvCompanyInfoForm');
            var continueBtn = document.getElementById('prvCompanyInfoContinueBtn');
            if (!form || !continueBtn) {
                return;
            }

            continueBtn.addEventListener('click', function (e) {
                if (typeof window.validatePaForm !== 'function') {
                    return;
                }

                if (!window.validatePaForm(form)) {
                    e.preventDefault();
                    return;
                }

                if (typeof form.requestSubmit === 'function') {
                    e.preventDefault();
                    form.requestSubmit(continueBtn);
                }
            });
        })();
    </script>
}
