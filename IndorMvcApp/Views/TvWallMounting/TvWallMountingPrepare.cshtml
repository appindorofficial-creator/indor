@model IndorMvcApp.ViewModels.TvWallMountingPrepareViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("TvWallMountingProject", "TvWallMounting", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 3;

}


<h2 class="page-heading" style="font-size:1.1rem;">@L["Add photos, access, and timing"]</h2>
    <p class="page-lead" style="margin-top:-8px;">@L["This helps us prepare for a smooth installation."]</p>

    <div class="location-card">
        <div class="thumb" style="display:flex;align-items:center;justify-content:center;"><i class="fas fa-couch" style="color:#94A3B8;"></i></div>
        <div class="meta">
            <div class="addr">@Model.DireccionPropiedad</div>
            <div class="room">@Model.HabitacionLabel</div>
        </div>
        <a asp-action="TvWallMountingProject" asp-route-id="@Model.SolicitudId" style="color:#0066CC;font-weight:600;font-size:0.85rem;text-decoration:none;white-space:nowrap;">@L["Edit >"]</a>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="TvWallMountingPrepare" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="HabitacionLabel" />
        <input type="hidden" asp-for="ConfiguracionCables" id="ConfiguracionCables" />
        <input type="hidden" asp-for="TomaCercana" id="TomaCercana" />
        <input type="hidden" asp-for="MontajePrevio" id="MontajePrevio" />
        <input type="hidden" asp-for="DetallesAcceso" id="DetallesAcceso" />
        <input type="hidden" asp-for="VentanaHorario" id="VentanaHorario" />

        <div class="upload-zone">
            <i class="fas fa-cloud-arrow-up"></i>
            <p><strong>@L["Upload wall or TV photos"]</strong></p>
            <p style="font-size:0.78rem;margin-top:4px;">@L["Clear photos help us prepare the right tools and materials."]</p>
            <input type="file" name="files" accept=".jpg,.jpeg,.png,.pdf" multiple style="margin-top:10px;width:100%;" />
        </div>
        @foreach (var file in Model.ArchivosExistentes)
        {
            <div class="included-row"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
        }

        <div class="field-card">
            <div class="picker-inline">
                <div class="left"><i class="fas fa-plug"></i> @L["Cable setup"]</div>
                <div class="option-row" data-target="ConfiguracionCables">
                    <button type="button" class="option-btn" data-value="BasicVisible">@L["Basic visible cables"]</button>
                    <button type="button" class="option-btn" data-value="HideInCover">@L["Hide cables in cover"]</button>
                    <button type="button" class="option-btn" data-value="InWallConcealment">@L["In-wall concealment"]</button>
                    <button type="button" class="option-btn" data-value="NotSure">@L["Not sure"]</button>
                </div>
            </div>

            <div class="picker-inline">
                <div class="left"><i class="fas fa-outlet"></i> @L["Is there an outlet near the TV location?"]</div>
                <div class="option-row" data-target="TomaCercana">
                    <button type="button" class="option-btn" data-value="Yes">@L["Yes"]</button>
                    <button type="button" class="option-btn" data-value="No">@L["No"]</button>
                    <button type="button" class="option-btn" data-value="NotSure">@L["Not sure"]</button>
                </div>
            </div>

            <div class="picker-inline">
                <div class="left"><i class="fas fa-tv"></i> @L["Has a TV been mounted on this wall before?"]</div>
                <div class="option-row" data-target="MontajePrevio">
                    <button type="button" class="option-btn" data-value="Yes">@L["Yes"]</button>
                    <button type="button" class="option-btn" data-value="No">@L["No"]</button>
                    <button type="button" class="option-btn" data-value="NotSure">@L["Not sure"]</button>
                </div>
            </div>

            <div class="picker-inline">
                <div class="left"><i class="fas fa-building"></i> @L["Access details"]</div>
                <div class="option-row" data-target="DetallesAcceso">
                    <button type="button" class="option-btn" data-value="GroundFloor">@L["Ground floor"]</button>
                    <button type="button" class="option-btn" data-value="Stairs">@L["Stairs"]</button>
                    <button type="button" class="option-btn" data-value="Elevator">@L["Elevator"]</button>
                    <button type="button" class="option-btn" data-value="ParkingLimited">@L["Parking limited"]</button>
                </div>
            </div>

            <div class="picker-inline">
                <div class="left"><i class="fas fa-clock"></i> @L["Preferred arrival"]</div>
                <div class="option-row" data-target="VentanaHorario">
                    <button type="button" class="option-btn" data-value="Morning">@L["Morning"]</button>
                    <button type="button" class="option-btn" data-value="Afternoon">@L["Afternoon"]</button>
                    <button type="button" class="option-btn" data-value="Evening">@L["Evening"]</button>
                    <button type="button" class="option-btn" data-value="AsSoonAsPossible">@L["As soon as possible"]</button>
                </div>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Preferred service date"]</span>
            <div class="input-wrap">
                <i class="fas fa-calendar"></i>
                <input asp-for="FechaServicio" type="date" />
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["Notes for the installer"]</span>
            <div class="input-wrap">
                <i class="fas fa-note-sticky"></i>
                <textarea asp-for="NotaCorta" rows="3" maxlength="250" placeholder="@L["Customer would like centered placement above media console."]"></textarea>
            </div>
        </div>

        <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L["Photos and access details help your provider bring the right tools and ensure a smooth installation."]</span></div>

        <button type="submit" class="btn-primary">@L["Continue"] <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        const initial = {
            ConfiguracionCables: '@Model.ConfiguracionCables',
            TomaCercana: '@Model.TomaCercana',
            MontajePrevio: '@Model.MontajePrevio',
            DetallesAcceso: '@Model.DetallesAcceso',
            VentanaHorario: '@Model.VentanaHorario'
        };

        document.querySelectorAll('[data-target]').forEach(group => {
            const targetId = group.dataset.target;
            const hidden = document.getElementById(targetId);
            const current = initial[targetId] || hidden.value;

            group.querySelectorAll('.option-btn').forEach(btn => {
                if (btn.dataset.value === current) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    group.querySelectorAll('.option-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                });
            });

            if (current) hidden.value = current;
        });
    })();

</script>
}
