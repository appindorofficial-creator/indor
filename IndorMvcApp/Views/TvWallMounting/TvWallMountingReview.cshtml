@model IndorMvcApp.ViewModels.TvWallMountingReviewViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("TvWallMountingPrepare", "TvWallMounting", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 3;

}


<h2 class="page-heading" style="font-size:1.1rem;">@L["Review your request"]</h2>
    <p class="page-lead" style="margin-top:-8px;">@L["Check the details before booking."]</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-tv"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-screwdriver-wrench"></i><div><div class="summary-label">@L["Request"]</div><div class="summary-value">@Model.TipoSolicitudLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-up-right-and-down-left-from-center"></i><div><div class="summary-label">@L["TV size"]</div><div class="summary-value">@Model.TamanoTvLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-hashtag"></i><div><div class="summary-label">@L["Quantity"]</div><div class="summary-value">@Model.CantidadTvsLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-couch"></i><div><div class="summary-label">@L["Room"]</div><div class="summary-value">@Model.HabitacionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-border-all"></i><div><div class="summary-label">@L["Wall type"]</div><div class="summary-value">@Model.TipoParedLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-grip-lines-vertical"></i><div><div class="summary-label">@L["Wall mount"]</div><div class="summary-value">@Model.TieneSoporteLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-plug"></i><div><div class="summary-label">@L["Cable setup"]</div><div class="summary-value">@Model.ConfiguracionCablesLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-outlet"></i><div><div class="summary-label">@L["Outlet nearby"]</div><div class="summary-value">@Model.TomaCercanaLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-tv"></i><div><div class="summary-label">@L["Previous mount on wall"]</div><div class="summary-value">@Model.MontajePrevioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-building"></i><div><div class="summary-label">@L["Access"]</div><div class="summary-value">@Model.AccesoLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Arrival"]</div><div class="summary-value">@Model.VentanaHorarioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Date"]</div><div class="summary-value">@Model.FechaServicioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-hourglass-half"></i><div><div class="summary-label">@L["Estimated time"]</div><div class="summary-value">@Model.TiempoEstimadoLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-dollar-sign"></i><div><div class="summary-label">@L["Starting price"]</div><div class="summary-value price-highlight">$@Model.PrecioEstimado.ToString("0")</div></div></div>
        @if (!string.IsNullOrWhiteSpace(Model.NotaCorta))
        {
            <div class="summary-row"><i class="fas fa-note-sticky"></i><div><div class="summary-label">@L["Notes"]</div><div class="summary-value">@Model.NotaCorta</div></div></div>
        }
    </div>

    @if (Model.ArchivosExistentes.Count > 0)
    {
        <div class="field-card">
            <span class="field-label">@L["Uploaded photos"]</span>
            @foreach (var file in Model.ArchivosExistentes)
            {
                <div class="included-row"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
            }
        </div>
    }

    <form asp-action="TvWallMountingReview" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="NombreServicio" />
        <input type="hidden" asp-for="DisclaimerTexto" />

        <label class="checkbox-row">
            <input asp-for="AceptaDisclaimer" type="checkbox" />
            <span>@L["I understand final pricing may adjust based on wall type, mount hardware, cable concealment, or on-site conditions."]</span>
        </label>
        <span asp-validation-for="AceptaDisclaimer" style="color:#B91C1C;font-size:0.82rem;display:block;margin:-8px 0 12px;"></span>

        @if (!string.IsNullOrWhiteSpace(Model.DisclaimerTexto))
        {
            <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@Model.DisclaimerTexto</span></div>
        }

        <button type="submit" class="btn-primary">@L["Confirm booking"] <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back"]</button>
    </form>
