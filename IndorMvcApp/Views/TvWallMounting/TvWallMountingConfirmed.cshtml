@model IndorMvcApp.ViewModels.TvWallMountingConfirmedViewModel
@{
    ViewData["Title"] = L["Booking Confirmed - INDOR"];
    ViewData["WizardTitle"] = Model.NombreServicio;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading" style="text-align:center;font-size:1.2rem;">@L["Your TV wall mounting has been scheduled"]</h1>
    <p class="page-lead" style="text-align:center;">@L["Everything is confirmed. We've reserved your appointment and sent your request."]</p>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-tv"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">@L["Property"]</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Date"]</div><div class="summary-value">@Model.FechaServicioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">@L["Time"]</div><div class="summary-value">@Model.VentanaHorarioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-up-right-and-down-left-from-center"></i><div><div class="summary-label">@L["TV size"]</div><div class="summary-value">@Model.TamanoTvLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-couch"></i><div><div class="summary-label">@L["Room"]</div><div class="summary-value">@Model.HabitacionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-border-all"></i><div><div class="summary-label">@L["Wall type"]</div><div class="summary-value">@Model.TipoParedLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">@L["Status"]</div><div class="summary-value"><span class="status-badge"><i class="fas fa-check"></i> @L[Model.EstadoLabel]</span></div></div></div>
    </div>

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L["Your installer will review any uploaded photos and arrive with the right mounting hardware based on your request."]</span></div>

    <a asp-action="TvWallMountingReview" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-calendar"></i> @L["View appointment"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-calendar"></i> @L["Go to Schedule"] <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="MyHome" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> @L["Go to My Home"] <i class="fas fa-chevron-right"></i></a>
