@model IndorMvcApp.ViewModels.TvWallMountingConfirmedViewModel
@{
    ViewData["Title"] = "Booking Confirmed - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_TvWallMountingStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">Booking Confirmed</div>
        <div style="width:44px;"></div>
    </div>

    <div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading" style="text-align:center;font-size:1.2rem;">Your TV wall mounting has been scheduled</h1>
    <p class="page-lead" style="text-align:center;">Everything is confirmed. We've reserved your appointment and sent your request.</p>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-tv"></i><div><div class="summary-label">Service</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-house"></i><div><div class="summary-label">Property</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">Date</div><div class="summary-value">@Model.FechaServicioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">Time</div><div class="summary-value">@Model.VentanaHorarioLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-up-right-and-down-left-from-center"></i><div><div class="summary-label">TV size</div><div class="summary-value">@Model.TamanoTvLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-couch"></i><div><div class="summary-label">Room</div><div class="summary-value">@Model.HabitacionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-border-all"></i><div><div class="summary-label">Wall type</div><div class="summary-value">@Model.TipoParedLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-shield-check"></i><div><div class="summary-label">Status</div><div class="summary-value"><span class="status-badge"><i class="fas fa-check"></i> @Model.EstadoLabel</span></div></div></div>
    </div>

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>Your installer will review any uploaded photos and arrive with the right mounting hardware based on your request.</span></div>

    <a asp-action="TvWallMountingReview" asp-route-id="@Model.SolicitudId" class="btn-primary"><i class="fas fa-calendar"></i> View appointment <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline"><i class="fas fa-calendar"></i> Go to Schedule <i class="fas fa-chevron-right"></i></a>
    <a asp-controller="MyHome" asp-action="Index" class="btn-outline"><i class="fas fa-house"></i> Go to My Home <i class="fas fa-chevron-right"></i></a>
</div>
</body>
</html>
