@model IndorMvcApp.ViewModels.TvWallMountingServiceViewModel
@{
    ViewData["Title"] = L.Catalog(Model.PageTitle) + " - INDOR";
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

@if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <img src="@Model.ImagenUrl" alt="@L.Catalog(Model.LandingTitulo)" class="hero-img" />
    }

    <div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;"><i class="fas fa-tv" style="color:#0066CC;font-size:1rem;margin-right:6px;"></i>@L.Catalog(Model.LandingTitulo)</h1>
            @if (!string.IsNullOrWhiteSpace(Model.LandingTagline))
            {
                <div class="tagline">@L.Catalog(Model.LandingTagline)</div>
            }
        </div>
        <div class="price-from">@L["Starting at"] $@Model.PrecioDesde.ToString("0")</div>
    </div>
    <p class="page-lead">@L.Catalog(Model.LandingSubtitulo)</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="TvWallMountingService" method="post">
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="SolicitudId" />

        @if (Model.IncludedItems.Count > 0)
        {
            <div class="field-card">
                <span class="field-label">@L["What's included"]</span>
                <div class="included-inline">
                    @foreach (var item in Model.IncludedItems)
                    {
                        <span><i class="fas @item.Icon"></i> @L.Catalog(item.Text)</span>
                    }
                </div>
            </div>
        }

        @if (Model.BestForOptions.Count > 0)
        {
            <div class="field-card">
                <span class="field-label">@Model.BestForLabel</span>
                <div class="included-inline">
                    @foreach (var opt in Model.BestForOptions)
                    {
                        <span><i class="fas @opt.Icon"></i> @opt.Label</span>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.InfoBoxTexto))
        {
            <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L.Catalog(Model.InfoBoxTexto)</span></div>
        }

        <div class="info-cards">
            <div class="info-card">
                <i class="fas fa-clock"></i>
                <div class="label">@Model.EstimatedTimeLabel</div>
                <div class="value">@Model.EstimatedTimeValue</div>
            </div>
            <div class="info-card">
                <i class="fas fa-wand-magic-sparkles"></i>
                <div class="label">@Model.BestTimingLabel</div>
                <div class="value">@Model.BestTimingValue</div>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">@Model.CtaContinueTexto <i class="fas fa-chevron-right"></i></button>
        <button type="submit" name="action" value="upload" class="btn-outline"><i class="fas fa-cloud-arrow-up"></i> @Model.CtaUploadTexto</button>
    </form>
