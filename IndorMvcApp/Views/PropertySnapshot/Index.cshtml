@model IndorMvcApp.ViewModels.PropertySnapshotViewModel
@{
    ViewData["Title"] = L["Property Snapshot"];
    var hfPreview = ViewBag.HouseFactPreview as bool? == true;
    var tabs = new[] { ("overview", L["Overview"].ToString()), ("details", L["Details"].ToString()), ("lot", L["Lot"].ToString()), ("notes", L["Notes"].ToString()) };
}
@section Head {
    <link rel="stylesheet" href="~/css/property-snapshot.css" asp-append-version="true" />
}

<div class="ps-page-head">
    <h1 class="ps-title">@L["Property Snapshot"]</h1>
    <p class="ps-sub">@UiDisplayLocalization.Localize(L, Model.PageSubtitle)</p>
    <div class="ps-address">@Model.Address</div>
    <div class="ps-badges">
        <span class="ps-badge ps-badge-estimated"><i class="fas fa-circle-notch"></i> @UiDisplayLocalization.Localize(L, Model.ConfidenceBadge)</span>
        <span class="ps-badge ps-badge-fields"><i class="fas fa-table-cells"></i> @Model.FieldCount @L["fields"]</span>
    </div>
</div>

<div class="ps-tabs">
    @foreach (var (key, label) in tabs)
    {
        if (hfPreview)
        {
            <a class="ps-tab @(Model.ActiveTab == key ? "active" : "")"
               asp-controller="HouseFactPreview" asp-action="PropertySnapshot"
               asp-route-tab="@key">@label</a>
        }
        else
        {
            <a class="ps-tab @(Model.ActiveTab == key ? "active" : "")"
               asp-action="Index"
               asp-route-id="@Model.PropiedadId"
               asp-route-tab="@key">@label</a>
        }
    }
</div>

@if (!Model.HasData)
{
    <div class="ps-empty">
        <i class="fas fa-table-cells" style="font-size:2rem;color:#94A3B8;margin-bottom:10px;"></i>
        <div>@L["No snapshot data found in your saved House Fact profile."]</div>
        @if (hfPreview)
        {
            <a asp-controller="Propietario" asp-action="PropertyDetails" class="ps-btn-primary">@L["Refresh property data"]</a>
        }
        else
        {
            <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="ps-btn-primary">@L["Refresh property data"]</a>
        }
    </div>
}
else if (Model.ActiveTab == "details")
{
    <div class="ps-field-grid">
        @foreach (var field in Model.DetailFields)
        {
            <div class="ps-field @(field.FullWidth ? "full" : "")">
                <i class="fas @field.Icon"></i>
                <div class="k">@UiDisplayLocalization.Localize(L, field.Label)</div>
                <div class="v">
                    @UiDisplayLocalization.Localize(L, field.Value)
                    @if (field.IsEstimated) { <span class="ps-estimated-dot"></span> }
                </div>
            </div>
        }
    </div>
}
else if (Model.ActiveTab == "lot")
{
    <div class="ps-map-card">
        <div class="ps-map-thumb"><i class="fas fa-map-location-dot"></i></div>
        <div>
            <div class="ps-section-title" style="margin:0;">@L["Lot & location"]</div>
            <div class="ps-sub" style="margin-top:4px;">@L["View parcel outline and location from saved property coordinates."]</div>
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue && Model.Latitude != 0 && Model.Longitude != 0)
            {
                <div class="ps-sub" style="margin-top:6px;">@Model.Latitude.Value.ToString("0.#####"), @Model.Longitude.Value.ToString("0.#####")</div>
            }
        </div>
        <i class="fas fa-chevron-right" style="color:#CBD5E1;"></i>
    </div>

    <div class="ps-field-grid">
        @foreach (var field in Model.LotFields)
        {
            <div class="ps-field">
                <i class="fas @field.Icon"></i>
                <div class="k">@UiDisplayLocalization.Localize(L, field.Label)</div>
                <div class="v">
                    @UiDisplayLocalization.Localize(L, field.Value)
                    @if (field.IsEstimated) { <span class="ps-estimated-dot"></span> }
                </div>
            </div>
        }
    </div>
}
else if (Model.ActiveTab == "notes")
{
    <div class="ps-confidence-card">
        <div class="ps-confidence-ring"><i class="fas fa-shield-check"></i></div>
        <div>
            <div class="ps-section-title" style="margin:0;">@L["Snapshot confidence"]</div>
            <div class="ps-legend">
                <span class="c">@L["Confirmed"]</span>
                <span class="e">@L["Estimated"]</span>
                <span class="v">@L["Needs verification"]</span>
            </div>
            <p class="ps-sub" style="margin-top:8px;">@UiDisplayLocalization.Localize(L, Model.Notes.ConfidenceSummary)</p>
        </div>
    </div>

    <div class="ps-section-title">@L["Main sources"]</div>
    <div class="ps-sources">
        @foreach (var source in Model.Notes.Sources)
        {
            <div class="ps-source"><i class="fas @source.Icon"></i>@UiDisplayLocalization.Localize(L, source.Name)</div>
        }
    </div>

    <div class="ps-section-title">@L["Missing info to confirm"]</div>
    <div class="ps-missing-grid">
        @foreach (var item in Model.Notes.MissingItems)
        {
            <div class="ps-missing">
                <i class="fas @item.Icon"></i>
                <div>
                    <div class="t">@UiDisplayLocalization.Localize(L, item.Title)</div>
                    <div class="s">@UiDisplayLocalization.Localize(L, item.Status)</div>
                </div>
                <i class="fas fa-chevron-right chev"></i>
            </div>
        }
    </div>

    @if (hfPreview)
    {
        <a asp-controller="Propietario" asp-action="PropertyDetails" class="ps-btn-primary">@L["Done"]</a>
        <a asp-controller="HouseFactPreview" asp-action="SystemsProfile" class="ps-btn-secondary">@L["Go to Systems"]</a>
    }
    else
    {
        <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="ps-btn-primary">@L["Done"]</a>
        <a asp-controller="MyHome" asp-action="Details" asp-route-id="@Model.PropiedadId" asp-route-tab="attom" class="ps-btn-secondary">@L["Go to Systems"]</a>
    }
}
else
{
    <div class="ps-stat-grid">
        @foreach (var stat in Model.CoreStats)
        {
            <div class="ps-stat">
                <i class="fas @stat.Icon"></i>
                <div class="v">@UiDisplayLocalization.Localize(L, stat.Value)</div>
                <div class="k">@UiDisplayLocalization.Localize(L, stat.Label)</div>
            </div>
        }
    </div>

    <div class="ps-section-title">@L["Quick sections"]</div>
    <div class="ps-quick-scroll">
        @foreach (var quick in Model.QuickSections)
        {
            if (hfPreview)
            {
                <a class="ps-quick-card" asp-controller="HouseFactPreview" asp-action="PropertySnapshot" asp-route-tab="@quick.Tab">
                    <i class="fas @quick.Icon"></i>
                    <div class="t">@UiDisplayLocalization.Localize(L, quick.Title)</div>
                    <div class="s">@UiDisplayLocalization.Localize(L, quick.Subtitle)</div>
                    <div class="a">@L["Open"] <i class="fas fa-chevron-right"></i></div>
                </a>
            }
            else
            {
                <a class="ps-quick-card" asp-action="Index" asp-route-id="@Model.PropiedadId" asp-route-tab="@quick.Tab">
                    <i class="fas @quick.Icon"></i>
                    <div class="t">@UiDisplayLocalization.Localize(L, quick.Title)</div>
                    <div class="s">@UiDisplayLocalization.Localize(L, quick.Subtitle)</div>
                    <div class="a">@L["Open"] <i class="fas fa-chevron-right"></i></div>
                </a>
            }
        }
    </div>

    <div class="ps-section-title">@L["Snapshot highlights"]</div>
    <div class="ps-highlight-grid">
        @foreach (var item in Model.Highlights)
        {
            <div class="ps-highlight">
                <i class="fas @item.Icon"></i>
                <div class="k">@UiDisplayLocalization.Localize(L, item.Label)</div>
                <div class="v">
                    @UiDisplayLocalization.Localize(L, item.Value)
                    @if (item.IsEstimated) { <span class="ps-estimated-dot"></span> }
                </div>
            </div>
        }
    </div>
}

@if (Model.ActiveTab != "notes")
{
    if (hfPreview)
    {
        <a asp-controller="HouseFactPreview" asp-action="PropertySnapshot" asp-route-tab="@Model.NextTab" class="ps-btn-primary">
            @UiDisplayLocalization.Localize(L, Model.NextTabLabel)
        </a>
    }
    else
    {
        <a asp-action="Index" asp-route-id="@Model.PropiedadId" asp-route-tab="@Model.NextTab" class="ps-btn-primary">
            @UiDisplayLocalization.Localize(L, Model.NextTabLabel)
        </a>
    }
}
