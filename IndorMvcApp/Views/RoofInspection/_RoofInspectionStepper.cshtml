@model int
@{
    var current = Model;
}
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
    <div style="width:44px;"></div>
    <div class="step-count">Step @current of 3</div>
</div>
<div class="hvac-stepper">
    @for (var i = 1; i <= 3; i++)
    {
        var css = i < current ? "hvac-step-dot done" : i == current ? "hvac-step-dot active" : "hvac-step-dot";
        <div class="@css">@(i < current ? "✓" : i.ToString())</div>
        @if (i < 3)
        {
            <div class="line @(i < current ? "done" : "")"></div>
        }
    }
</div>
