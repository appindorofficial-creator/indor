@model IndorMvcApp.ViewModels.RoofInspectionScheduleViewModel
@{
    ViewData["Title"] = L["Schedule roof check - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("RoofInspectionDetails", "RoofInspection", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 3;

}

<div style="width:44px;text-align:right;color:#0066CC;"><i class="fas fa-shield-halved"></i></div>
    </div>

    
<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Schedule roof check"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@Model.ScheduleIntro</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="roof-schedule-form" asp-action="RoofInspectionSchedule" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="TipoServicio" id="TipoServicio" />
        <input type="hidden" asp-for="Frecuencia" id="Frecuencia" />
        <input type="hidden" asp-for="TimingPreferido" id="TimingPreferido" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-list-check"></i><span>@L["Choose service"]</span></div>
            <div class="choice-grid-2">
                <button type="button" class="choice-card" data-service="ReminderOnly"><i class="fas fa-bell main"></i><span class="label">@L["Reminder only"]</span></button>
                <button type="button" class="choice-card" data-service="BookInspection"><i class="fas fa-calendar main"></i><span class="label">@L["Book inspection"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-rotate"></i><span>@L["How often?"]</span></div>
            <div class="freq-grid">
                <button type="button" class="freq-card" data-freq="Yearly"><span class="badge">@L["Recommended"]</span><i class="fas fa-calendar"></i><span class="label">@L["Yearly"]</span></button>
                <button type="button" class="freq-card" data-freq="Every2Years"><i class="fas fa-calendar-days"></i><span class="label">@L["Every 2 years"]</span></button>
                <button type="button" class="freq-card" data-freq="AfterStorms"><i class="fas fa-cloud-bolt"></i><span class="label">@L["After major storms"]</span></button>
                <button type="button" class="freq-card" data-freq="Custom"><i class="fas fa-sliders"></i><span class="label">@L["Custom"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-seedling"></i><span>@L["Preferred timing"]</span></div>
            <div class="pill-row">
                <button type="button" class="segment-btn" data-timing="Spring"><i class="fas fa-seedling"></i> @L["Spring"]</button>
                <button type="button" class="segment-btn" data-timing="Fall"><i class="fas fa-leaf"></i> @L["Fall"]</button>
                <button type="button" class="segment-btn" data-timing="ThisMonth"><i class="fas fa-calendar"></i> @L["This month"]</button>
                <button type="button" class="segment-btn" data-timing="Flexible"><i class="fas fa-clock"></i> @L["Flexible"]</button>
            </div>
        </div>

        @if (Model.CoverageItems.Count > 0)
        {
            <div class="field-card">
                <div class="field-head"><i class="fas fa-clipboard-check"></i><span>@L["Inspection covers"]</span></div>
                <div class="coverage-grid">
                    @foreach (var item in Model.CoverageItems)
                    {
                        <div class="coverage-item"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                    }
                </div>
            </div>
        }

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>@L["Preferred date"]</span></div>
            <input asp-for="FechaPreferida" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><i class="fas fa-note-sticky"></i><span>@L["Notes (optional)"]</span></div>
            <textarea asp-for="Notas" placeholder="@L["Add any details"]" maxlength="300"></textarea>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar"></i> @L["Review request"] <i class="fas fa-chevron-right"></i>
        </button>

        @if (!string.IsNullOrWhiteSpace(Model.TrustTexto))
        {
            <div class="trust-footer"><i class="fas fa-shield-halved"></i><span>@Model.TrustTexto</span></div>
        }
    </form>
</div>
@section Scripts {
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        bindSingle('[data-service]', 'data-service', document.getElementById('TipoServicio'));
        bindSingle('[data-freq]', 'data-freq', document.getElementById('Frecuencia'));
        bindSingle('[data-timing]', 'data-timing', document.getElementById('TimingPreferido'));

        var form = document.getElementById('roof-schedule-form');
        var requiredFields = [
            { id: 'TipoServicio', message: 'Please choose a service.' },
            { id: 'Frecuencia', message: 'Please select how often you\'d like a roof check.' },
            { id: 'TimingPreferido', message: 'Please select your preferred timing.' }
        ];

        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') {
                return;
            }

            var firstMissing = null;
            requiredFields.forEach(function (field) {
                var input = document.getElementById(field.id);
                if (!input) return;
                var empty = !input.value || !String(input.value).trim();
                if (empty && !firstMissing) {
                    firstMissing = field;
                }
            });

            if (firstMissing) {
                e.preventDefault();
                alert(firstMissing.message);
            }
        });
    })();

</script>
}
