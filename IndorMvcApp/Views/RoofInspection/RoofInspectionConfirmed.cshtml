@model IndorMvcApp.ViewModels.RoofInspectionConfirmedViewModel
@{
    ViewData["Title"] = "Roof check set - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_RoofInspectionStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">INDOR</div>
        <div style="width:44px;text-align:right;color:#0066CC;"><i class="fas fa-shield-halved"></i></div>
    </div>

    @await Html.PartialAsync("_RoofInspectionStepper", 3)

    <div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">Roof check set</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">Your roof inspection reminder has been created.</p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-house-chimney"></i><div><div class="summary-label">Service</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">Frequency</div><div class="summary-value">@Model.FrequencyLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-seedling"></i><div><div class="summary-label">Timing</div><div class="summary-value">@Model.TimingLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-label">Property</div><div class="summary-value">@Model.PropertyLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">Last inspection</div><div class="summary-value">@Model.LastInspectionLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-magnifying-glass"></i><div><div class="summary-label">Focus</div><div class="summary-value">@Model.FocusLabel</div></div></div>
    </div>

    <div class="storm-banner">
        <i class="fas fa-bell"></i>
        <span>You'll also be prompted after major storms.</span>
    </div>

    @if (Model.PropiedadId.HasValue)
    {
        <a asp-controller="MyHome" asp-action="Maintenance" asp-route-id="@Model.PropiedadId" class="btn-primary">
            <i class="fas fa-house"></i> View in My Home
        </a>
    }
    else
    {
        <a asp-controller="Home" asp-action="Index" asp-fragment="section-myhome" class="btn-primary">
            <i class="fas fa-house"></i> View in My Home
        </a>
    }

    <a asp-action="RoofInspectionService" asp-route-id="@Model.HomeCarePriorityId" class="btn-outline" style="margin-top:10px;">
        <i class="fas fa-plus"></i> Set another reminder
    </a>

    <div class="trust-footer" style="margin-top:14px;"><i class="fas fa-shield-halved"></i><span>Stay ahead of leaks and protect your roof.</span></div>
</div>
</body>
</html>
