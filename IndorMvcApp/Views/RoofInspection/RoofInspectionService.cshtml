@model IndorMvcApp.ViewModels.RoofInspectionServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");

}

<div style="width:44px;text-align:right;color:#0066CC;"><i class="fas fa-shield-halved"></i></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="hvac-hero-icon"><i class="fas fa-house-chimney"></i></span>
        </div>
    }

    <h1 class="page-heading" style="font-size:1.2rem;margin-bottom:8px;">@Model.LandingTitulo</h1>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (Model.RecommendationItems.Count > 0)
    {
        <div class="preview-box">
            <div class="preview-label">Recommendations</div>
            @foreach (var item in Model.RecommendationItems)
            {
                <details class="roof-rec-item">
                    <summary class="roof-rec-row">
                        <div class="left"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                        <div class="right" aria-hidden="true"><i class="fas fa-chevron-right"></i></div>
                    </summary>
                    @if (!string.IsNullOrWhiteSpace(item.Subtext))
                    {
                        <p class="roof-rec-detail">@item.Subtext</p>
                    }
                </details>
            }
        </div>
    }

    @if (Model.CheckItems.Count > 0)
    {
        <div class="includes-box">
            <div class="includes-label">What we check</div>
            <div class="check-grid-3">
                @foreach (var item in Model.CheckItems)
                {
                    <div class="check-item"><i class="fas @item.Icon"></i><span>@item.Text</span></div>
                }
            </div>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="RoofInspectionService" method="post">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar-plus"></i> @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.TrustTexto))
    {
        <div class="trust-footer"><i class="fas fa-shield-halved"></i><span>@Model.TrustTexto</span></div>
    }
