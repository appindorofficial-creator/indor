@model IndorMvcApp.ViewModels.RoofInspectionDetailsViewModel
@{
    ViewData["Title"] = "Roof details - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_RoofInspectionStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <button type="submit" form="roof-details-form" name="action" value="back" class="back-btn" style="border:none;background:transparent;">
            <i class="fas fa-chevron-left"></i>
        </button>
        <div class="page-title">INDOR</div>
        <div style="width:44px;text-align:right;color:#0066CC;"><i class="fas fa-shield-halved"></i></div>
    </div>

    @await Html.PartialAsync("_RoofInspectionStepper", 1)

    <h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">Roof details</h1>
    <p class="page-lead" style="margin-bottom:16px;">Help us understand your roof so we can schedule the right inspection.</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="roof-details-form" asp-action="RoofInspectionDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="MotivoRevision" id="MotivoRevision" />
        <input type="hidden" asp-for="TipoTecho" id="TipoTecho" />
        <input type="hidden" asp-for="EdadTecho" id="EdadTecho" />
        <input type="hidden" asp-for="UltimaInspeccion" id="UltimaInspeccion" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-magnifying-glass"></i><span>Why do you need a roof check?</span></div>
            <div class="reason-grid">
                <button type="button" class="reason-card" data-reason="RoutineInspection"><i class="fas fa-calendar main"></i><span class="label">Routine inspection</span></button>
                <button type="button" class="reason-card" data-reason="AfterStorm"><i class="fas fa-cloud-bolt main"></i><span class="label">After a storm</span></button>
                <button type="button" class="reason-card" data-reason="RoofLeakSigns"><i class="fas fa-droplet main"></i><span class="label">Roof leak signs</span></button>
                <button type="button" class="reason-card" data-reason="MissingShingles"><i class="fas fa-house-chimney main"></i><span class="label">Missing shingles</span></button>
                <button type="button" class="reason-card" data-reason="FlashingConcern" style="grid-column:1/-1;"><i class="fas fa-spray-can main"></i><span class="label">Flashing / sealant concern</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-house-chimney"></i><span>Roof type</span></div>
            <div class="reason-grid">
                <button type="button" class="reason-card" data-roof="AsphaltShingle"><i class="fas fa-house-chimney main"></i><span class="label">Asphalt shingle</span></button>
                <button type="button" class="reason-card" data-roof="Metal"><i class="fas fa-layer-group main"></i><span class="label">Metal</span></button>
                <button type="button" class="reason-card" data-roof="Tile"><i class="fas fa-table-cells main"></i><span class="label">Tile</span></button>
                <button type="button" class="reason-card" data-roof="Flat"><i class="fas fa-square main"></i><span class="label">Flat</span></button>
                <button type="button" class="reason-card" data-roof="NotSure" style="grid-column:1/-1;"><i class="fas fa-circle-question main"></i><span class="label">Not sure</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-clock"></i><span>Approx. roof age</span></div>
            <div class="pill-row">
                <button type="button" class="segment-btn" data-age="ZeroToTen">0–10 yrs</button>
                <button type="button" class="segment-btn" data-age="ElevenToTwenty">11–20 yrs</button>
                <button type="button" class="segment-btn" data-age="TwentyPlus">20+ yrs</button>
                <button type="button" class="segment-btn" data-age="NotSure">Not sure</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>Last roof inspection</span></div>
            <div class="pill-row">
                <button type="button" class="segment-btn" data-last="ThisYear">This year</button>
                <button type="button" class="segment-btn" data-last="OneToTwoYears">1–2 years ago</button>
                <button type="button" class="segment-btn" data-last="ThreePlusYears">3+ years ago</button>
                <button type="button" class="segment-btn" data-last="DontKnow">I don't know</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-camera"></i><span>Add roof photos (optional)</span></div>
            <p style="font-size:0.74rem;color:#64748B;margin-bottom:10px;">Add up to 5 photos to help our pros prepare.</p>
            <label class="upload-drop" for="photoInput">
                <i class="fas fa-camera"></i>
                <strong>Add photos</strong>
            </label>
            <input type="file" name="files" id="photoInput" accept=".jpg,.jpeg,.png" multiple style="display:none;" />
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="upload-preview">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <img src="@Url.Content("~" + file.RutaArchivo)" alt="@file.NombreArchivo" />
                    }
                </div>
            }
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar"></i> Next <i class="fas fa-chevron-right"></i>
        </button>
        <div class="trust-footer" style="margin-top:12px;"><i class="fas fa-shield-halved"></i><span>Your information is secure and never shared.</span></div>
    </form>
</div>
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        bindSingle('[data-reason]', 'data-reason', document.getElementById('MotivoRevision'));
        bindSingle('[data-roof]', 'data-roof', document.getElementById('TipoTecho'));
        bindSingle('[data-age]', 'data-age', document.getElementById('EdadTecho'));
        bindSingle('[data-last]', 'data-last', document.getElementById('UltimaInspeccion'));
    })();
</script>
</body>
</html>
