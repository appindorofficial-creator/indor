@model IndorMvcApp.ViewModels.RoofInspectionDetailsViewModel
@{
    ViewData["Title"] = L["Roof details - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("RoofInspectionService", "RoofInspection", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 3;

}

<div style="width:44px;text-align:right;color:#0066CC;"><i class="fas fa-shield-halved"></i></div>
    </div>

    
<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Roof details"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@L["Help us understand your roof so we can schedule the right inspection. Select an answer for each question below."]</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="roof-details-form" asp-action="RoofInspectionDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="MotivoRevision" id="MotivoRevision" />
        <input type="hidden" asp-for="TipoTecho" id="TipoTecho" />
        <input type="hidden" asp-for="EdadTecho" id="EdadTecho" />
        <input type="hidden" asp-for="UltimaInspeccion" id="UltimaInspeccion" />

        <div class="field-card">
            <div class="field-head"><i class="fas fa-magnifying-glass"></i><span>@L["Why do you need a roof check?"]</span></div>
            <div class="reason-grid">
                <button type="button" class="reason-card" data-reason="RoutineInspection"><i class="fas fa-calendar main"></i><span class="label">@L["Routine inspection"]</span></button>
                <button type="button" class="reason-card" data-reason="AfterStorm"><i class="fas fa-cloud-bolt main"></i><span class="label">@L["After a storm"]</span></button>
                <button type="button" class="reason-card" data-reason="RoofLeakSigns"><i class="fas fa-droplet main"></i><span class="label">@L["Roof leak signs"]</span></button>
                <button type="button" class="reason-card" data-reason="MissingShingles"><i class="fas fa-house-chimney main"></i><span class="label">@L["Missing shingles"]</span></button>
                <button type="button" class="reason-card" data-reason="FlashingConcern" style="grid-column:1/-1;"><i class="fas fa-spray-can main"></i><span class="label">@L["Flashing / sealant concern"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-house-chimney"></i><span>@L["Roof type"]</span></div>
            <div class="reason-grid">
                <button type="button" class="reason-card" data-roof="AsphaltShingle"><i class="fas fa-house-chimney main"></i><span class="label">@L["Asphalt shingle"]</span></button>
                <button type="button" class="reason-card" data-roof="Metal"><i class="fas fa-layer-group main"></i><span class="label">@L["Metal"]</span></button>
                <button type="button" class="reason-card" data-roof="Tile"><i class="fas fa-table-cells main"></i><span class="label">@L["Tile"]</span></button>
                <button type="button" class="reason-card" data-roof="Flat"><i class="fas fa-square main"></i><span class="label">@L["Flat"]</span></button>
                <button type="button" class="reason-card" data-roof="NotSure" style="grid-column:1/-1;"><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-clock"></i><span>@L["Approx. roof age"]</span></div>
            <div class="pill-row">
                <button type="button" class="segment-btn" data-age="ZeroToTen">@L["0–10 yrs"]</button>
                <button type="button" class="segment-btn" data-age="ElevenToTwenty">@L["11–20 yrs"]</button>
                <button type="button" class="segment-btn" data-age="TwentyPlus">@L["20+ yrs"]</button>
                <button type="button" class="segment-btn" data-age="NotSure">@L["Not sure"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-calendar"></i><span>@L["Last roof inspection"]</span></div>
            <div class="pill-row">
                <button type="button" class="segment-btn" data-last="ThisYear">@L["This year"]</button>
                <button type="button" class="segment-btn" data-last="OneToTwoYears">@L["1–2 years ago"]</button>
                <button type="button" class="segment-btn" data-last="ThreePlusYears">@L["3+ years ago"]</button>
                <button type="button" class="segment-btn" data-last="DontKnow">@L["I don't know"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><i class="fas fa-camera"></i><span>@L["Add roof photos (optional)"]</span></div>
            <p class="field-hint" style="margin-top:0;margin-bottom:10px;">@L["Add up to 5 photos to help our pros prepare."]</p>
            <div class="upload-drop-wrap">
                <input type="file" name="files" id="photoInput" class="upload-input-hidden" multiple
                       accept="image/*,.jpg,.jpeg,.png,.webp,.heic,.heif" />
                <label class="upload-drop" id="photoDropzone" for="photoInput">
                    <i class="fas fa-camera"></i>
                    <strong>@L["Add photos"]</strong>
                    <span>@L["JPG or PNG, up to 10 MB each"]</span>
                </label>
            </div>
            <div class="upload-selected-list" id="photoSelectedList" hidden></div>
            @if (Model.ArchivosExistentes.Count > 0)
            {
                <div class="upload-selected-list" id="photoSavedList">
                    @foreach (var file in Model.ArchivosExistentes)
                    {
                        <div class="upload-selected-item">
                            <img class="upload-preview-thumb" src="@Url.Content($"~{file.RutaArchivo}")" alt="" loading="lazy" />
                            <span>@file.NombreArchivo</span>
                        </div>
                    }
                </div>
            }
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar"></i> @L["Next"] <i class="fas fa-chevron-right"></i>
        </button>
        <div class="trust-footer" style="margin-top:12px;"><i class="fas fa-shield-halved"></i><span>@L["Your information is secure and never shared."]</span></div>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        bindSingle('[data-reason]', 'data-reason', document.getElementById('MotivoRevision'));
        bindSingle('[data-roof]', 'data-roof', document.getElementById('TipoTecho'));
        bindSingle('[data-age]', 'data-age', document.getElementById('EdadTecho'));
        bindSingle('[data-last]', 'data-last', document.getElementById('UltimaInspeccion'));

        var form = document.getElementById('roof-details-form');
        var requiredFields = [
            { id: 'MotivoRevision', message: 'Please select why you need a roof check.' },
            { id: 'TipoTecho', message: 'Please select your roof type.' },
            { id: 'EdadTecho', message: 'Please indicate the approximate age of your roof.' },
            { id: 'UltimaInspeccion', message: 'Please indicate when your roof was last inspected.' }
        ];

        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') {
                return;
            }

            var firstMissing = null;
            requiredFields.forEach(function (field) {
                var input = document.getElementById(field.id);
                if (!input) return;
                var empty = !input.value || !String(input.value).trim();
                if (empty && !firstMissing) {
                    firstMissing = field;
                }
            });

            if (firstMissing) {
                e.preventDefault();
                alert(firstMissing.message);
            }
        });

        var photoInput = document.getElementById('photoInput');
        var photoDropzone = document.getElementById('photoDropzone');
        var photoSelectedList = document.getElementById('photoSelectedList');
        var maxPhotos = 5;
        var existingCount = @Model.ArchivosExistentes.Count;
        var pendingPhotos = [];

        function syncPhotoInputFiles() {
            if (!photoInput) return;
            var dt = new DataTransfer();
            pendingPhotos.slice(0, Math.max(0, maxPhotos - existingCount)).forEach(function (file) {
                dt.items.add(file);
            });
            photoInput.files = dt.files;
        }

        function mergePhotoFiles(newFiles) {
            Array.from(newFiles || []).forEach(function (file) {
                if (file && file.size > 0) {
                    pendingPhotos.push(file);
                }
            });
            var allowed = Math.max(0, maxPhotos - existingCount);
            if (pendingPhotos.length > allowed) {
                pendingPhotos = pendingPhotos.slice(0, allowed);
            }
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function removePendingPhoto(index) {
            pendingPhotos.splice(index, 1);
            syncPhotoInputFiles();
            renderPhotoSelection(pendingPhotos);
        }

        function renderPhotoSelection(files) {
            if (!photoSelectedList || !photoDropzone) return;
            var list = Array.from(files || []).filter(function (f) { return f && f.size > 0; });
            photoSelectedList.innerHTML = '';
            if (list.length === 0) {
                photoSelectedList.hidden = true;
                photoDropzone.classList.remove('has-files');
                return;
            }
            photoDropzone.classList.add('has-files');
            photoSelectedList.hidden = false;
            list.forEach(function (file, index) {
                var row = document.createElement('div');
                row.className = 'upload-selected-item';
                if (!file.type || file.type.indexOf('image/') === 0) {
                    var img = document.createElement('img');
                    img.className = 'upload-preview-thumb';
                    img.alt = 'Selected photo ' + (index + 1);
                    row.appendChild(img);
                    var reader = new FileReader();
                    reader.onload = function (ev) { img.src = ev.target.result; };
                    reader.readAsDataURL(file);
                } else {
                    var icon = document.createElement('i');
                    icon.className = 'fas fa-image';
                    row.appendChild(icon);
                }
                var name = document.createElement('span');
                name.textContent = file.name || ('Photo ' + (index + 1));
                row.appendChild(name);
                var removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'upload-remove-btn';
                removeBtn.setAttribute('aria-label', 'Remove ' + (file.name || 'photo'));
                removeBtn.innerHTML = '<i class="fas fa-xmark"></i>';
                removeBtn.addEventListener('click', function (ev) {
                    ev.preventDefault();
                    ev.stopPropagation();
                    removePendingPhoto(index);
                });
                row.appendChild(removeBtn);
                photoSelectedList.appendChild(row);
            });
        }

        photoInput?.addEventListener('change', function () {
            mergePhotoFiles(this.files);
            this.value = '';
        });
    })();

</script>
}
