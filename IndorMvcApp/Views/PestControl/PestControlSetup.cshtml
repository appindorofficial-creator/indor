@model IndorMvcApp.ViewModels.PestControlSetupViewModel
@{
    ViewData["Title"] = L["Tell us about your home - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("PestControlService", "PestControl", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;
}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Tell us about your home"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@L["A few details help us recommend the right pest control approach."]</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="pc-setup-form" asp-action="PestControlSetup" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="UltimoServicio" id="UltimoServicio" />
        <input type="hidden" asp-for="SignosSeleccionados" id="SignosSeleccionados" />
        <input type="hidden" asp-for="AreasPreocupacion" id="AreasPreocupacion" />
        <input type="hidden" asp-for="MascotasONinos" id="MascotasONinos" />

        <div class="field-card">
            <div class="field-head"><span class="question-num">1</span><span>@L["When was your last pest service?"]</span></div>
            <div class="segment-row">
                <button type="button" class="segment-btn" data-last="Within12Months">@L["Within 12 months"]</button>
                <button type="button" class="segment-btn" data-last="MoreThan12Months">@L["More than 12 months"]</button>
                <button type="button" class="segment-btn" data-last="DontKnow">@L["I don't know"]</button>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><span class="question-num">2</span><span>@L["Have you noticed any signs?"]</span></div>
            <div class="sign-grid">
                <button type="button" class="sign-card" data-sign="Ants"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-bug main"></i><span class="label">@L["Ants"]</span></button>
                <button type="button" class="sign-card" data-sign="Roaches"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-locust main"></i><span class="label">@L["Roaches"]</span></button>
                <button type="button" class="sign-card" data-sign="TermitesWoodDamage"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-tree main"></i><span class="label">@L["Termites / wood damage"]</span></button>
                <button type="button" class="sign-card" data-sign="Rodents"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-paw main"></i><span class="label">@L["Rodents"]</span></button>
                <button type="button" class="sign-card" data-sign="SpidersWasps"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-spider main"></i><span class="label">@L["Spiders / wasps"]</span></button>
                <button type="button" class="sign-card" data-sign="NoSigns"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-ban main"></i><span class="label">@L["No signs"]</span></button>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><span class="question-num">3</span><span>@L["Areas of concern"]</span></div>
            <div class="area-grid">
                <button type="button" class="area-chip" data-area="Kitchen"><i class="fas fa-utensils"></i> @L["Kitchen"]</button>
                <button type="button" class="area-chip" data-area="Bathrooms"><i class="fas fa-bath"></i> @L["Bathrooms"]</button>
                <button type="button" class="area-chip" data-area="Garage"><i class="fas fa-warehouse"></i> @L["Garage"]</button>
                <button type="button" class="area-chip" data-area="Attic"><i class="fas fa-house-chimney"></i> @L["Attic"]</button>
                <button type="button" class="area-chip" data-area="CrawlspaceBasement"><i class="fas fa-stairs"></i> @L["Crawlspace / basement"]</button>
                <button type="button" class="area-chip" data-area="ExteriorPerimeter"><i class="fas fa-border-all"></i> @L["Exterior perimeter"]</button>
                <button type="button" class="area-chip" data-area="Yard"><i class="fas fa-leaf"></i> @L["Yard"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">4</span><span>@L["Do you have pets or children at home?"]</span></div>
            <div class="yesno-row">
                <button type="button" class="yesno-btn" data-pets="Yes">@L["Yes"]</button>
                <button type="button" class="yesno-btn" data-pets="No">@L["No"]</button>
            </div>
        </div>

        <div class="field-card" data-svc-optional>
            <div class="field-head"><span class="question-num">5</span><span>@L["Any extra notes?"]</span></div>
            <textarea asp-for="Notas" placeholder="@L["Tell us anything else that might help..."]" maxlength="300"></textarea>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            @L["Continue"] <i class="fas fa-chevron-right"></i>
        </button>
    </form>

@section Scripts {
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        function bindMulti(groupSelector, attr, input) {
            function getValues() {
                return input.value ? input.value.split('|').filter(Boolean) : [];
            }

            function setValues(values) {
                input.value = values.join('|');
            }

            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var code = btn.getAttribute(attr);
                    var current = getValues();
                    if (current.indexOf(code) >= 0) {
                        current = current.filter(function (v) { return v !== code; });
                        btn.classList.remove('active');
                    } else {
                        current.push(code);
                        btn.classList.add('active');
                    }
                    setValues(current);
                });
                if (getValues().indexOf(btn.getAttribute(attr)) >= 0) btn.classList.add('active');
            });
        }

        bindSingle('[data-last]', 'data-last', document.getElementById('UltimoServicio'));
        bindMulti('[data-sign]', 'data-sign', document.getElementById('SignosSeleccionados'));
        bindMulti('[data-area]', 'data-area', document.getElementById('AreasPreocupacion'));
        bindSingle('[data-pets]', 'data-pets', document.getElementById('MascotasONinos'));

        var form = document.getElementById('pc-setup-form');
        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') return;

            var last = document.getElementById('UltimoServicio');
            var pets = document.getElementById('MascotasONinos');
            if (!last.value || !last.value.trim()) {
                e.preventDefault();
                alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Select when your last pest service was."].ToString())));
                return;
            }
            if (!pets.value || !pets.value.trim()) {
                e.preventDefault();
                alert(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Select whether you have pets or children at home."].ToString())));
            }
        });
    })();

</script>
}
