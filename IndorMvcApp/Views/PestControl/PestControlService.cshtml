@model IndorMvcApp.ViewModels.PestControlServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;
}


<div class="title-row">
        <div class="left">
            <h1 class="page-heading" style="margin-bottom:4px;font-size:1.2rem;">@Model.LandingTitulo</h1>
        </div>
    </div>
    <p class="page-lead">@Model.LandingSubtitulo</p>

    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="pc-hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.LandingTitulo" class="hero-img" />
            <span class="pc-yearly-badge">@L["Yearly"]</span>
            <span class="pc-hero-icon"><i class="fas fa-bug"></i></span>
        </div>
    }

    @if (Model.WhyItMattersItems.Count > 0)
    {
        <div class="why-matters-box">
            <h4><i class="fas fa-shield-halved"></i> @L["Why it matters"]</h4>
            <ul>
                @foreach (var item in Model.WhyItMattersItems)
                {
                    <li><i class="fas fa-check"></i><span>@item.Text</span></li>
                }
            </ul>
        </div>
    }

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="pc-service-form" asp-action="PestControlService" method="post">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="TipoAccionInicial" id="TipoAccionInicial" />

        <div class="field-card">
            <div class="field-head"><span>@L["What would you like to do?"]</span></div>
            <div class="action-grid-2">
                <button type="button" class="action-tile" data-action="Reminder">
                    <i class="fas fa-calendar main"></i>
                    <strong>@L["Set a reminder"]</strong>
                    <span>@L["We'll remind you when it's time."]</span>
                    <i class="fas fa-chevron-right chev"></i>
                </button>
                <button type="button" class="action-tile" data-action="ScheduleService">
                    <i class="fas fa-user-gear main"></i>
                    <strong>@L["Schedule service"]</strong>
                    <span>@L["Book with a trusted professional."]</span>
                    <i class="fas fa-chevron-right chev"></i>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.BestForTexto))
        {
            <div class="info-box-blue">
                <i class="fas fa-circle-info"></i>
                <span>@Model.BestForTexto</span>
            </div>
        }

        <button type="submit" name="action" value="continue" class="btn-primary">
            @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>

@section Scripts {
<script>
    (function () {
        var input = document.getElementById('TipoAccionInicial');
        document.querySelectorAll('[data-action]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-action]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                input.value = btn.getAttribute('data-action');
            });
            if (btn.getAttribute('data-action') === input.value) btn.classList.add('active');
        });
    })();

</script>
}
