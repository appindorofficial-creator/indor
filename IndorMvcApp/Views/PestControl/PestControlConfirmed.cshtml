@model IndorMvcApp.ViewModels.PestControlConfirmedViewModel
@{
    ViewData["Title"] = L["You're all set - INDOR"];
    ViewData["WizardTitle"] = Model.NombreServicio;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
}


<div class="success-wrap">
        <div class="success-icon"><i class="fas fa-check"></i></div>
        <h1 class="page-heading" style="font-size:1.15rem;margin-bottom:6px;">@L["You're all set"]</h1>
        <p class="page-lead" style="text-align:center;margin-bottom:16px;">@L["Your pest control reminder or service has been saved."]</p>
    </div>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-house-medical"></i><div><div class="summary-label">@L["Service"]</div><div class="summary-value">@Model.ServiceLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">@L["Timing"]</div><div class="summary-value">@Model.TimingLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-label">@L["Home concerns"]</div><div class="summary-value">@Model.ConcernsLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-people-group"></i><div><div class="summary-label">@L["Pets/children"]</div><div class="summary-value">@Model.PetsChildrenLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-circle-check"></i><div><div class="summary-label">@L["Status"]</div><div class="summary-value">@Model.StatusLabel</div></div></div>
    </div>

    @if (Model.WhyYearlyItems.Count > 0)
    {
        <div class="why-matters-box">
            <h4><i class="fas fa-shield-halved"></i> @L["Why yearly matters"]</h4>
            <ul>
                @foreach (var item in Model.WhyYearlyItems)
                {
                    <li><i class="fas fa-check"></i><span>@item.Text</span></li>
                }
            </ul>
        </div>
    }

    <a asp-controller="Home" asp-action="Index" class="btn-primary">
        @L["Back to Home Care Guide"] <i class="fas fa-chevron-right"></i>
    </a>
    <a asp-controller="PestControl" asp-action="PestControlPlan" asp-route-id="@Model.SolicitudId" class="btn-outline" style="margin-top:10px;">
        Edit plan
    </a>
