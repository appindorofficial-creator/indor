@model IndorMvcApp.ViewModels.HomeownerRequestsViewModel
@{
    ViewData["Title"] = "My Requests";
}

@functions {
    string PillClass(string status) => status switch
    {
        "Open" => "sr-pill--open",
        "Claimed" => "sr-pill--claimed",
        "Completed" => "sr-pill--completed",
        _ => "sr-pill--cancelled"
    };
    string StatusLabel(string status) => status switch
    {
        "Open" => "Waiting",
        "Claimed" => "Accepted",
        "Completed" => "Completed",
        _ => "Cancelled"
    };
}

@{
    void RenderCard(IndorMvcApp.ViewModels.ServiceRequestListItemViewModel r)
    {
        <a class="sr-card" href="@Url.Action("Detail", new { id = r.Id })">
            <div class="sr-card-head">
                <span class="sr-ico"><i class="fas @r.CategoryIcon"></i></span>
                <div class="sr-card-body">
                    <h3>@r.Title</h3>
                    <div class="sr-card-cat">@r.CategoryLabel</div>
                    <div class="sr-meta">
                        @if (!string.IsNullOrWhiteSpace(r.Location))
                        {
                            <span><i class="fas fa-location-dot"></i>@r.Location</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(r.WhenLabel))
                        {
                            <span><i class="fas fa-clock"></i>@r.WhenLabel</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(r.ClaimedProviderName))
                        {
                            <span><i class="fas fa-user-check"></i>@r.ClaimedProviderName</span>
                        }
                    </div>
                </div>
                <span class="sr-pill @PillClass(r.Status)">@L[StatusLabel(r.Status)]</span>
            </div>
        </a>
    }
}

@if (TempData["ServiceRequestToast"] is string toast && !string.IsNullOrWhiteSpace(toast))
{
    <div class="sr-toast"><i class="fas fa-circle-check"></i> @toast</div>
}

<div class="sr-hero">
    <h2>@L["My service requests"]</h2>
    <p>@L["Track requests you've posted and see which provider accepted them."]</p>
</div>

<a class="sr-btn sr-btn--primary sr-btn--block" href="@Url.Action("Create")" style="margin-bottom:6px;">
    <i class="fas fa-plus"></i> @L["New request"]
</a>

@if (Model.TotalCount == 0)
{
    <div class="sr-empty" style="margin-top:18px;">
        <div class="sr-empty-ico"><i class="fas fa-clipboard-list"></i></div>
        <h3>@L["No requests yet"]</h3>
        <p>@L["Post your first service request and matching providers will be notified right away."]</p>
        <a class="sr-btn sr-btn--primary" href="@Url.Action("Create")"><i class="fas fa-plus"></i> @L["Request a service"]</a>
    </div>
}
else
{
    if (Model.Open.Count > 0)
    {
        <div class="sr-section-title">@L["Waiting for a provider"]</div>
        foreach (var r in Model.Open) { RenderCard(r); }
    }
    if (Model.Claimed.Count > 0)
    {
        <div class="sr-section-title">@L["Accepted"]</div>
        foreach (var r in Model.Claimed) { RenderCard(r); }
    }
    if (Model.Closed.Count > 0)
    {
        <div class="sr-section-title">@L["Closed"]</div>
        foreach (var r in Model.Closed) { RenderCard(r); }
    }
}
