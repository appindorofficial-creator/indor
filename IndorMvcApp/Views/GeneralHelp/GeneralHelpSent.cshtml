@model IndorMvcApp.ViewModels.GeneralHelpSentViewModel
@{
    ViewData["Title"] = "Request Sent - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_GeneralHelpStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-controller="Home" asp-action="Index" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">Request Sent</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_GeneralHelpStepper", 4)

    <div class="success-icon"><i class="fas fa-check"></i></div>
    <h1 class="page-heading" style="text-align:center;font-size:1.15rem;">Request Sent</h1>
    <p class="page-lead" style="text-align:center;">Your general help request has been submitted.</p>

    <div class="summary-card">
        <div class="summary-row"><i class="fas fa-box-open"></i><div><div class="summary-label">Service</div><div class="summary-value">@Model.NombreServicio</div></div></div>
        <div class="summary-row"><i class="fas fa-location-dot"></i><div><div class="summary-label">Address</div><div class="summary-value">@Model.DireccionPropiedad</div></div></div>
        <div class="summary-row"><i class="fas fa-calendar"></i><div><div class="summary-label">Requested time</div><div class="summary-value">@Model.VentanaTiempoLabel</div></div></div>
        <div class="summary-row"><i class="fas fa-clock"></i><div><div class="summary-label">Status</div><div class="summary-value"><span class="status-pending">@Model.EstadoLabel</span></div></div></div>
    </div>

    <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>We're reviewing your request and will contact you shortly with next steps.</span></div>

    <a asp-action="GeneralHelpReview" asp-route-id="@Model.SolicitudId" class="btn-primary">View request</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline">Go to Schedule</a>
    <a asp-controller="Home" asp-action="Index" class="btn-outline">Back to Moving Setup</a>
</div>
</body>
</html>
