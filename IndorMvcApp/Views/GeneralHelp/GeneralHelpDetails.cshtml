@model IndorMvcApp.ViewModels.GeneralHelpDetailsViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/brand-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/app-background.css" asp-append-version="true" />
    @await Html.PartialAsync("_GeneralHelpStyles")
</head>
<body>
<div class="page-container">
    <div class="top-bar">
        <a asp-action="GeneralHelpRequest" asp-route-id="@Model.MovingSetupServicioId" class="back-btn"><i class="fas fa-chevron-left"></i></a>
        <div class="page-title">@Model.PageTitle</div>
        <div style="width:44px;"></div>
    </div>

    @await Html.PartialAsync("_GeneralHelpStepper", 2)

    <h2 class="page-heading" style="font-size:1.1rem;text-align:center;">@Model.PageTitle</h2>
    <p class="page-lead" style="margin-top:-8px;text-align:center;">Describe the request and add key details.</p>

    <div class="location-card">
        <i class="fas fa-house main"></i>
        <div class="meta">
            <div class="addr">@Model.DireccionPropiedad</div>
            <a asp-action="GeneralHelpRequest" asp-route-id="@Model.MovingSetupServicioId" class="change">Change address ></a>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="GeneralHelpDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="DireccionPropiedad" />
        <input type="hidden" asp-for="ContactoPreferido" id="ContactoPreferido" />
        <input type="hidden" asp-for="NotasAcceso" id="NotasAcceso" />

        <div class="field-card">
            <span class="field-label">Tell us more</span>
            <div class="input-wrap" style="align-items:flex-start;">
                <i class="fas fa-note-sticky" style="margin-top:12px;"></i>
                <textarea asp-for="Descripcion" id="Descripcion" rows="4" maxlength="500" required placeholder="Need help picking up a few extra moving supplies and carrying two items into the apartment..."></textarea>
            </div>
            <div class="char-count"><span id="charCount">0</span>/500</div>
        </div>

        <div class="field-card">
            <span class="field-label">Best contact</span>
            <div class="chip-scroll" id="contactGroup">
                <button type="button" class="chip-option" data-value="Call"><i class="fas fa-phone"></i> Call</button>
                <button type="button" class="chip-option" data-value="Text"><i class="fas fa-comment"></i> Text</button>
                <button type="button" class="chip-option" data-value="Either"><i class="fas fa-right-left"></i> Either</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Access notes</span>
            <div class="help-grid" id="accessGroup" style="grid-template-columns:repeat(3,1fr);">
                <button type="button" class="help-tile" data-value="Apartment"><i class="fas fa-building"></i>Apartment</button>
                <button type="button" class="help-tile" data-value="House"><i class="fas fa-house"></i>House</button>
                <button type="button" class="help-tile" data-value="GateCode"><i class="fas fa-keyboard"></i>Gate code</button>
                <button type="button" class="help-tile" data-value="Stairs"><i class="fas fa-stairs"></i>Stairs</button>
                <button type="button" class="help-tile" data-value="Elevator"><i class="fas fa-elevator"></i>Elevator</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">Add photos (optional)</span>
            <div class="upload-row">
                <div class="upload-drop">
                    <i class="fas fa-cloud-arrow-up"></i>
                    <p><strong>Drag and drop photos here</strong></p>
                    <p>Up to 5 photos, max 10MB each</p>
                    <input type="file" name="files" accept=".jpg,.jpeg,.png" multiple style="margin-top:8px;width:100%;font-size:0.72rem;" />
                </div>
            </div>
            @foreach (var file in Model.ArchivosExistentes)
            {
                <div class="included-row"><i class="fas fa-image"></i><span>@file.NombreArchivo</span></div>
            }
        </div>

        <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>The more details you provide, the faster our team can help.</span></div>

        <button type="submit" name="action" value="continue" class="btn-primary">Continue</button>
        <button type="submit" name="action" value="back" class="btn-outline">Back</button>
    </form>
</div>
<script>
    (function () {
        const desc = document.getElementById('Descripcion');
        const counter = document.getElementById('charCount');
        const updateCount = () => { counter.textContent = (desc.value || '').length; };
        desc.addEventListener('input', updateCount);
        updateCount();

        function initSingle(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' .chip-option').forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' .chip-option').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                });
            });
        }

        function initMulti(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            const selected = new Set((initial || hidden.value || '').split('|').filter(Boolean));
            document.querySelectorAll('#' + groupId + ' .help-tile').forEach(btn => {
                if (selected.has(btn.dataset.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    const value = btn.dataset.value;
                    if (selected.has(value)) { selected.delete(value); btn.classList.remove('active'); }
                    else { selected.add(value); btn.classList.add('active'); }
                    hidden.value = Array.from(selected).join('|');
                });
            });
            hidden.value = Array.from(selected).join('|');
        }

        initSingle('contactGroup', 'ContactoPreferido', '@Model.ContactoPreferido');
        initMulti('accessGroup', 'NotasAcceso', '@Model.NotasAcceso');
    })();
</script>
</body>
</html>
