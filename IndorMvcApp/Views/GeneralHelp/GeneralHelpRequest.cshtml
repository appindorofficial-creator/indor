@model IndorMvcApp.ViewModels.GeneralHelpRequestViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;

}


<div class="gh-hero-wrap">
        <img src="@Url.Content("~/general-help-hero.png")" alt="Moving help" class="gh-hero-img" loading="lazy" />
    </div>

    <h2 class="page-heading" style="font-size:1.1rem;text-align:center;">@Model.PageTitle</h2>
    <p class="page-lead" style="margin-top:-8px;text-align:center;">@L["Tell us what kind of moving help you need."]</p>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="GeneralHelpRequest" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="MovingSetupServicioId" />
        <input type="hidden" asp-for="TipoAyuda" id="TipoAyuda" />
        <input type="hidden" asp-for="VentanaTiempo" id="VentanaTiempo" />
        <input type="hidden" asp-for="Urgencia" id="Urgencia" />

        <div class="location-card">
            <i class="fas fa-house main"></i>
            <div class="meta">
                <input asp-for="DireccionPropiedad" placeholder="@L["Service address"]" required style="border:none;background:transparent;width:100%;font-family:inherit;font-weight:600;font-size:0.88rem;" />
                <a asp-controller="Home" asp-action="Index" class="change">@L["Change address >"]</a>
            </div>
        </div>
        <span asp-validation-for="DireccionPropiedad" style="color:#B91C1C;font-size:0.82rem;display:block;margin:-8px 0 12px;"></span>

        <div class="field-card">
            <span class="field-label">@L["What do you need help with?"]</span>
            <div class="help-grid" id="helpTypeGroup">
                <button type="button" class="help-tile" data-value="MovingQuestion"><i class="fas fa-circle-question"></i>@L["Moving question"]</button>
                <button type="button" class="help-tile" data-value="ExtraHands"><i class="fas fa-people-carry-box"></i>@L["Extra hands"]</button>
                <button type="button" class="help-tile" data-value="SmallTask"><i class="fas fa-wrench"></i>@L["Small task"]</button>
                <button type="button" class="help-tile" data-value="SuppliesPickup"><i class="fas fa-box"></i>@L["Supplies pickup"]</button>
                <button type="button" class="help-tile" data-value="DonationDropOff"><i class="fas fa-hand-holding-heart"></i>@L["Donation drop-off"]</button>
                <button type="button" class="help-tile" data-value="Other"><i class="fas fa-ellipsis"></i>@L["Other"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["When do you need help?"]</span>
            <div class="chip-scroll" id="timingGroup">
                <button type="button" class="chip-option" data-value="Today"><i class="fas fa-calendar-day"></i> @L["Today"]</button>
                <button type="button" class="chip-option" data-value="Tomorrow"><i class="fas fa-calendar"></i> @L["Tomorrow"]</button>
                <button type="button" class="chip-option" data-value="ThisWeek"><i class="fas fa-calendar-week"></i> @L["This week"]</button>
                <button type="button" class="chip-option" data-value="Flexible"><i class="fas fa-clock"></i> @L["Flexible"]</button>
            </div>
        </div>

        <div class="field-card">
            <span class="field-label">@L["How urgent is it?"]</span>
            <div class="chip-scroll" id="urgencyGroup">
                <button type="button" class="chip-option" data-value="Normal"><i class="fas fa-flag"></i> @L["Normal"]</button>
                <button type="button" class="chip-option" data-value="Priority"><i class="fas fa-shield"></i> @L["Priority"]</button>
                <button type="button" class="chip-option" data-value="Urgent"><i class="fas fa-bolt"></i> @L["Urgent"]</button>
            </div>
        </div>

        <div class="info-box-blue"><i class="fas fa-circle-info"></i><span>@L["Choose the option that best matches your situation. You can describe the details on the next step."]</span></div>

        <button type="submit" name="action" value="continue" class="btn-primary">@L["Next"]</button>
        <button type="submit" name="action" value="back" class="btn-outline">@L["Back to Moving Setup"]</button>
    </form>
</div>
@section Scripts {
<script>
    (function () {
        function initSingle(groupId, hiddenId, initial) {
            const hidden = document.getElementById(hiddenId);
            document.querySelectorAll('#' + groupId + ' .help-tile, #' + groupId + ' .chip-option').forEach(btn => {
                if (btn.dataset.value === (initial || hidden.value)) btn.classList.add('active');
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#' + groupId + ' .help-tile, #' + groupId + ' .chip-option').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    hidden.value = btn.dataset.value;
                });
            });
        }

        initSingle('helpTypeGroup', 'TipoAyuda', '@Model.TipoAyuda');
        initSingle('timingGroup', 'VentanaTiempo', '@Model.VentanaTiempo');
        initSingle('urgencyGroup', 'Urgencia', '@Model.Urgencia');
    })();

</script>
}
