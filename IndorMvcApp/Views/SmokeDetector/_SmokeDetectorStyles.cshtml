    .safety-visit .text { flex: 1; font-size: 0.74rem; line-height: 1.4; color: #64748B; }
    .safety-visit .text strong { display: block; color: #0F172A; font-size: 0.78rem; margin-bottom: 4px; }
    .btn-find-pro { border: 1.5px solid #0066CC; background: #FFF; color: #0066CC; border-radius: 999px; padding: 8px 12px; font-size: 0.68rem; font-weight: 700; white-space: nowrap; text-decoration: none; }
