@await Html.PartialAsync("../HvacMaintenance/_HvacMaintenanceStyles")
<style>
    /* iOS ignores user-scalable=no and double-tap-zooms when tapping controls.
       touch-action: manipulation disables that double-tap zoom (still allows
       normal scrolling and pinch) so selecting an option no longer zooms in. */
    .page-container button,
    .page-container input,
    .page-container select,
    .page-container a { touch-action: manipulation; }

    .sd-hero-wrap { position: relative; margin-bottom: 14px; }
