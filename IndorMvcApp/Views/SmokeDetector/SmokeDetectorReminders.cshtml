@model IndorMvcApp.ViewModels.SmokeDetectorRemindersViewModel
@{
    ViewData["Title"] = L["Set your reminders - INDOR"];
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("SmokeDetectorSetup", "SmokeDetector", new { id = Model.SolicitudId });
    ViewData["WizardStep"] = 3;
    ViewData["WizardTotalSteps"] = 4;
}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Set your reminders"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@L["Turn reminders on or off and choose how you'd like help."]</p>

    <div class="setup-summary">
        <div class="badge">@Model.AlarmCountLabel</div>
        <div class="row"><span class="label">@L["Type"]</span><span class="value">@Model.AlarmTypeLabel</span></div>
        <div class="row"><span class="label">@L["Locations"]</span><span class="value">@Model.LocationsLabel</span></div>
        <div class="row"><span class="label">@L["Installed"]</span><span class="value">@Model.InstalledLabel</span></div>
    </div>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="sd-reminders-form" asp-action="SmokeDetectorReminders" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="TipoAccionAyuda" id="TipoAccionAyuda" />

        <div class="field-card">
            <div class="toggle-row">
                <div class="left">
                    <strong>@L["Monthly test reminder"]</strong>
                    <span>@L["We'll remind you to test your alarms."]</span>
                    <span class="next">Next: @Model.NextMonthlyTestLabel</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" asp-for="RecordatorioMensual" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="toggle-row">
                <div class="left">
                    <strong>@L["Yearly battery reminder"]</strong>
                    <span>@L["Check and replace batteries once a year."]</span>
                    <span class="next">Next: @Model.NextBatteryLabel</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" asp-for="RecordatorioBateriaAnual" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="toggle-row">
                <div class="left">
                    <strong>@L["Replace unit in 10 years"]</strong>
                    <span>@L["Alarms should be replaced 10 years from installation."]</span>
                    <span class="next">Next: @Model.NextReplacementLabel</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" asp-for="RecordatorioReemplazo10Anos" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="toggle-row">
                <div class="left">
                    <strong>@L["Seasonal home safety review"]</strong>
                    <span>@L["A quick check to keep your home safe year-round."]</span>
                    <span class="next">Next: @Model.NextSeasonalLabel</span>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" asp-for="RecordatorioRevisionEstacional" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span>@L["Need help now?"]</span></div>
            <div class="help-grid">
                <button type="button" class="help-btn" data-help="ReminderOnly">
                    <i class="fas fa-bell"></i> Reminder only
                </button>
                <button type="button" class="help-btn" data-help="ScheduleSafetyCheck">
                    <i class="fas fa-user-check"></i> Schedule safety check
                </button>
            </div>
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-shield-halved"></i> @L["Review and confirm"] <i class="fas fa-chevron-right"></i>
        </button>
    </form>

@section Scripts {
<script>
    (function () {
        var helpInput = document.getElementById('TipoAccionAyuda');
        document.querySelectorAll('[data-help]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('[data-help]').forEach(function (b) { b.classList.remove('active'); });
                btn.classList.add('active');
                helpInput.value = btn.getAttribute('data-help');
            });
            if (btn.getAttribute('data-help') === helpInput.value) btn.classList.add('active');
        });
    })();

</script>
}
