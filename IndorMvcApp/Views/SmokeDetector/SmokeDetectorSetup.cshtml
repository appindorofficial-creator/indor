@model IndorMvcApp.ViewModels.SmokeDetectorSetupViewModel
@{
    ViewData["Title"] = L["Tell us about your alarms - INDOR"];
    ViewData["WizardTitle"] = L.Catalog(Model.PageTitle);
    ViewData["WizardBackUrl"] = Url.Action("SmokeDetectorService", "SmokeDetector", new { id = Model.HomeCarePriorityId });
    ViewData["WizardStep"] = 2;
    ViewData["WizardTotalSteps"] = 4;
}


<h1 class="page-heading" style="font-size:1.05rem;margin-bottom:4px;">@L["Tell us about your alarms"]</h1>
    <p class="page-lead" style="margin-bottom:16px;">@L["A few quick details to help us recommend the right care. Select an answer for each question below."]</p>

    <div asp-validation-summary="All" class="validation-summary"></div>

    <form id="sd-setup-form" asp-action="SmokeDetectorSetup" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="CantidadAlarmas" id="CantidadAlarmas" />
        <input type="hidden" asp-for="UbicacionesSeleccionadas" id="UbicacionesSeleccionadas" />
        <input type="hidden" asp-for="TiposAlarmas" id="TiposAlarmas" />
        <input type="hidden" asp-for="UltimaPrueba" id="UltimaPrueba" />
        <input type="hidden" asp-for="UltimoCambioBateria" id="UltimoCambioBateria" />
        <input type="hidden" asp-for="AnioInstalacionDesconocido" id="AnioInstalacionDesconocido" />

        <div class="field-card">
            <div class="field-head"><span class="question-num">1</span><span>@L["How many smoke alarms are in your home?"]</span></div>
            <div class="count-grid">
                <button type="button" class="count-btn" data-count="One">1</button>
                <button type="button" class="count-btn" data-count="Two">2</button>
                <button type="button" class="count-btn" data-count="Three">3</button>
                <button type="button" class="count-btn" data-count="Four">4</button>
                <button type="button" class="count-btn" data-count="FivePlus">5+</button>
                <button type="button" class="count-btn" data-count="DontKnow">@L["I don't know"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">2</span><span>@L["Where are they located?"]</span></div>
            <div class="area-grid">
                <button type="button" class="area-chip" data-area="Bedrooms"><i class="fas fa-bed"></i> @L["Bedrooms"]</button>
                <button type="button" class="area-chip" data-area="Hallway"><i class="fas fa-door-open"></i> @L["Hallway"]</button>
                <button type="button" class="area-chip" data-area="LivingRoom"><i class="fas fa-couch"></i> @L["Living room"]</button>
                <button type="button" class="area-chip" data-area="Basement"><i class="fas fa-stairs"></i> @L["Basement"]</button>
                <button type="button" class="area-chip" data-area="UpstairsLanding"><i class="fas fa-arrow-up"></i> @L["Upstairs landing"]</button>
                <button type="button" class="area-chip" data-area="DontKnow"><i class="fas fa-circle-question"></i> @L["I don't know"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">3</span><span>@L["What type of alarms do you have?"]</span></div>
            <div class="sign-grid">
                <button type="button" class="sign-card" data-type="Battery"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-battery-full main"></i><span class="label">@L["Battery"]</span></button>
                <button type="button" class="sign-card" data-type="Hardwired"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-plug main"></i><span class="label">@L["Hardwired"]</span></button>
                <button type="button" class="sign-card" data-type="TenYearSealed"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-shield-halved main"></i><span class="label">@L["10-year sealed"]</span></button>
                <button type="button" class="sign-card" data-type="SmokeCoCombo"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle main"></i><span class="label">@L["Smoke + CO combo"]</span></button>
                <button type="button" class="sign-card" data-type="DontKnow"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">@L["I don't know"]</span></button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">4</span><span>@L["When were they last tested?"]</span></div>
            <div class="segment-row">
                <button type="button" class="segment-btn" data-test="WithinLastMonth"><i class="fas fa-calendar"></i> @L["Within last month"]</button>
                <button type="button" class="segment-btn" data-test="OneToSixMonths">@L["1–6 months ago"]</button>
                <button type="button" class="segment-btn" data-test="MoreThanSixMonths">@L["More than 6 months ago"]</button>
                <button type="button" class="segment-btn" data-test="DontKnow">@L["I don't know"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">5</span><span>@L["When was the battery last changed?"]</span></div>
            <div class="segment-row">
                <button type="button" class="segment-btn" data-battery="WithinLast6Months">@L["Within last 6 months"]</button>
                <button type="button" class="segment-btn" data-battery="SixToTwelveMonths">@L["6–12 months ago"]</button>
                <button type="button" class="segment-btn" data-battery="MoreThan12Months">@L["More than 12 months ago"]</button>
                <button type="button" class="segment-btn" data-battery="DontKnow">@L["I don't know"]</button>
            </div>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">6</span><span>@L["What year were the alarms installed?"]</span></div>
            <div class="year-row">
                <input asp-for="AnioInstalacion" type="number" min="1990" max="@DateTime.Today.Year" placeholder="@L["Select year or enter age"]" id="AnioInstalacion" />
                <button type="button" class="segment-btn" id="year-unknown-btn">@L["I don't know"]</button>
            </div>
            <span asp-validation-for="AnioInstalacion" class="text-danger"></span>
        </div>

        <div class="field-card">
            <div class="field-head"><span class="question-num">7</span><span>@L["Are you experiencing any issues with your alarms?"]</span></div>
            <div class="sign-grid">
                <button type="button" class="sign-card" data-issue="Chirping"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-volume-high main"></i><span class="label">@L["Chirping"]</span></button>
                <button type="button" class="sign-card" data-issue="MissingBattery"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-battery-empty main"></i><span class="label">@L["Missing battery"]</span></button>
                <button type="button" class="sign-card" data-issue="NotSure"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-question main"></i><span class="label">@L["Not sure"]</span></button>
                <button type="button" class="sign-card" data-issue="AllWorking"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-circle-check main"></i><span class="label">@L["All working"]</span></button>
                <button type="button" class="sign-card" data-issue="DontKnow"><span class="check"><i class="fas fa-check"></i></span><i class="fas fa-ban main"></i><span class="label">@L["I don't know"]</span></button>
            </div>
            <input type="hidden" asp-for="ProblemasSeleccionados" id="ProblemasSeleccionados" />
        </div>

        <button type="submit" name="action" value="continue" class="btn-primary">
            @L["Continue"] <i class="fas fa-chevron-right"></i>
        </button>
    </form>

@section Scripts {
<script>
    (function () {
        function bindSingle(groupSelector, attr, input) {
            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    document.querySelectorAll(groupSelector).forEach(function (b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    input.value = btn.getAttribute(attr);
                });
                if (btn.getAttribute(attr) === input.value) btn.classList.add('active');
            });
        }

        function bindMulti(groupSelector, attr, input) {
            function getValues() {
                return input.value ? input.value.split('|').filter(Boolean) : [];
            }

            function setValues(values) {
                input.value = values.join('|');
            }

            document.querySelectorAll(groupSelector).forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var code = btn.getAttribute(attr);
                    var current = getValues();
                    if (current.indexOf(code) >= 0) {
                        current = current.filter(function (v) { return v !== code; });
                        btn.classList.remove('active');
                    } else {
                        current.push(code);
                        btn.classList.add('active');
                    }
                    setValues(current);
                });
                if (getValues().indexOf(btn.getAttribute(attr)) >= 0) btn.classList.add('active');
            });
        }

        bindSingle('[data-count]', 'data-count', document.getElementById('CantidadAlarmas'));
        bindMulti('[data-area]', 'data-area', document.getElementById('UbicacionesSeleccionadas'));
        bindMulti('[data-type]', 'data-type', document.getElementById('TiposAlarmas'));
        bindSingle('[data-test]', 'data-test', document.getElementById('UltimaPrueba'));
        bindSingle('[data-battery]', 'data-battery', document.getElementById('UltimoCambioBateria'));
        bindMulti('[data-issue]', 'data-issue', document.getElementById('ProblemasSeleccionados'));

        var yearUnknownInput = document.getElementById('AnioInstalacionDesconocido');
        var yearInput = document.getElementById('AnioInstalacion');
        var yearUnknownBtn = document.getElementById('year-unknown-btn');

        function syncYearUnknown(active) {
            yearUnknownInput.value = active ? 'true' : 'false';
            yearUnknownBtn.classList.toggle('active', active);
            if (active) yearInput.value = '';
        }

        yearUnknownBtn.addEventListener('click', function () {
            syncYearUnknown(yearUnknownInput.value !== 'true');
        });

        yearInput.addEventListener('input', function () {
            if (yearInput.value) syncYearUnknown(false);
        });

        if (yearUnknownInput.value === 'true') syncYearUnknown(true);

        var form = document.getElementById('sd-setup-form');
        var requiredFields = [
            { id: 'CantidadAlarmas', message: 'Please select how many smoke alarms are in your home.' },
            { id: 'UltimaPrueba', message: 'Please indicate when the alarms were last tested.' },
            { id: 'UltimoCambioBateria', message: 'Please indicate when the battery was last changed.' }
        ];

        form?.addEventListener('submit', function (e) {
            if (e.submitter && e.submitter.value === 'back') {
                return;
            }

            var firstMissing = null;
            requiredFields.forEach(function (field) {
                var input = document.getElementById(field.id);
                if (!input) return;
                var empty = !input.value || !String(input.value).trim();
                if (empty && !firstMissing) {
                    firstMissing = field;
                }
            });

            if (firstMissing) {
                e.preventDefault();
                alert(firstMissing.message);
            }
        });
    })();

</script>
}
