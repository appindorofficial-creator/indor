@model IndorMvcApp.ViewModels.SmokeDetectorServiceViewModel
@{
    ViewData["Title"] = Model.PageTitle + " - INDOR";
    ViewData["WizardTitle"] = Model.PageTitle;
    ViewData["WizardBackUrl"] = Url.Action("Index", "Home");
    ViewData["WizardStep"] = 1;
    ViewData["WizardTotalSteps"] = 4;
}


<h1 class="page-heading" style="font-size:1.15rem;margin-bottom:8px;">@Model.LandingTitulo</h1>
    <p class="page-lead" style="margin-bottom:14px;">@Model.LandingSubtitulo</p>

    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
    {
        <div class="sd-hero-wrap">
            <img src="@Url.Content("~" + Model.ImagenUrl)" alt="@Model.PageTitle" class="hero-img" />
            <span class="sd-hero-icon"><i class="fas fa-bell"></i></span>
        </div>
    }

    @if (Model.TrackItems.Count > 0)
    {
        <div class="field-card">
            <div class="field-head"><span>@L["What you'll track"]</span></div>
            <div class="track-grid">
                @foreach (var item in Model.TrackItems)
                {
                    <div class="track-card">
                        <i class="fas @item.Icon"></i>
                        <strong>@item.Text</strong>
                        @if (!string.IsNullOrWhiteSpace(item.Subtext))
                        {
                            <span>@item.Subtext</span>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (Model.WhereTrackItems.Count > 0)
    {
        <div class="where-label">@L["Where to track"]</div>
        <div class="where-grid">
            @foreach (var item in Model.WhereTrackItems)
            {
                <span class="where-pill"><i class="fas @item.Icon"></i> @item.Text</span>
            }
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ReminderBannerTexto))
    {
        <div class="indor-banner">
            <i class="fas fa-shield-halved"></i>
            <span>@Model.ReminderBannerTexto</span>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form asp-action="SmokeDetectorService" method="post">
        <input type="hidden" asp-for="HomeCarePriorityId" />
        <input type="hidden" asp-for="SolicitudId" />
        <button type="submit" name="action" value="continue" class="btn-primary">
            <i class="fas fa-calendar-plus"></i> @Model.CtaTexto <i class="fas fa-chevron-right"></i>
        </button>
    </form>
